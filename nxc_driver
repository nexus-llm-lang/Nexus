#!/usr/bin/env bash
#
# nxc_driver — Nexus self-hosted compiler
# Compiles .nx → standalone WASM (auto-bundles with stdlib)
#
# Usage: ./nxc_driver <input.nx> [output.wasm] [--no-bundle] [--verbose]
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NXC_WASM="$SCRIPT_DIR/nxc_driver.wasm"
WASM_MERGE="${NEXUS_WASM_MERGE:-wasm-merge}"
STDLIB_WASM="$SCRIPT_DIR/stdlib/stdlib.wasm"
HOST_STUB_WAT="$SCRIPT_DIR/nxlib/stdlib/nexus_host_stub.wat"
HOST_STUB_WASM="$SCRIPT_DIR/stdlib/nexus_host_stub.wasm"

# Parse args
input=""
output=""
no_bundle=false
passthrough=()
for arg in "$@"; do
  case "$arg" in
    --no-bundle) no_bundle=true ;;
    --verbose) passthrough+=(--verbose) ;;
    -*)  passthrough+=("$arg") ;;
    *)
      if [[ -z "$input" ]]; then
        input="$arg"
      elif [[ -z "$output" ]]; then
        output="$arg"
      fi
      ;;
  esac
done

if [[ -z "$input" ]]; then
  echo "Usage: nxc_driver <input.nx> [output.wasm] [--no-bundle] [--verbose]" >&2
  exit 1
fi

# Default output
if [[ -z "$output" ]]; then
  output="output.wasm"
fi

# Compile via nxc_driver.wasm
if [[ "$no_bundle" == "true" ]]; then
  exec wasmtime run -W max-wasm-stack=67108864,tail-call=y,exceptions=y --dir=. \
    "$NXC_WASM" "$input" "${passthrough[@]+"${passthrough[@]}"}" "$output"
fi

# Compile to temp, then bundle
core_wasm="$(mktemp "${TMPDIR:-/tmp}/nxc_core_XXXXXX.wasm")"
trap 'rm -f "$core_wasm"' EXIT
wasmtime run -W max-wasm-stack=67108864,tail-call=y,exceptions=y --dir=. --dir="${TMPDIR:-/tmp}" \
  "$NXC_WASM" "$input" "${passthrough[@]+"${passthrough[@]}"}" "$core_wasm"

# Bundle with stdlib via wasm-merge
if ! command -v "$WASM_MERGE" >/dev/null 2>&1; then
  echo "nxc: wasm-merge not found — output is unbundled (imports stdlib)" >&2
  mv "$core_wasm" "$output"
  exit 0
fi

# Compile host stub if needed
if [[ -f "$HOST_STUB_WAT" && ! -f "$HOST_STUB_WASM" ]]; then
  if command -v wat2wasm >/dev/null 2>&1; then
    wat2wasm "$HOST_STUB_WAT" -o "$HOST_STUB_WASM"
  fi
fi

merge_args=("$core_wasm" __main)
[[ -f "$STDLIB_WASM" ]] && merge_args+=("$STDLIB_WASM" "stdlib/stdlib.wasm")
[[ -f "$HOST_STUB_WASM" ]] && merge_args+=("$HOST_STUB_WASM" "nexus:cli/nexus-host")
merge_args+=(--all-features --enable-tail-call --rename-export-conflicts -o "$output")

"$WASM_MERGE" "${merge_args[@]}"
