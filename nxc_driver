#!/usr/bin/env bash
#
# nxc_driver — Nexus self-hosted compiler
# Compiles .nx → core WASM via nxc_driver.wasm
#
# The output is a core WASM module with WIT-style component model imports.
# Use `nexus build` or component tooling (wasm-tools, wac) to compose
# with stdlib and produce a standalone component.
#
# Usage: ./nxc_driver <input.nx> [output.wasm] [--verbose]
#
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NXC_WASM="$SCRIPT_DIR/nxc_driver.wasm"

# Parse args
input=""
output=""
passthrough=()
for arg in "$@"; do
  case "$arg" in
    --verbose) passthrough+=(--verbose) ;;
    -*)  passthrough+=("$arg") ;;
    *)
      if [[ -z "$input" ]]; then
        input="$arg"
      elif [[ -z "$output" ]]; then
        output="$arg"
      fi
      ;;
  esac
done

if [[ -z "$input" ]]; then
  echo "Usage: nxc_driver <input.nx> [output.wasm] [--verbose]" >&2
  exit 1
fi

if [[ -z "$output" ]]; then
  output="output.wasm"
fi

exec wasmtime run -W max-wasm-stack=67108864,tail-call=y,exceptions=y --dir=. --dir="${TMPDIR:-/tmp}" \
  "$NXC_WASM" "$input" "${passthrough[@]+"${passthrough[@]}"}" "$output"
