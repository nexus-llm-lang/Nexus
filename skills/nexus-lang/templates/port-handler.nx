import { Console }, * as stdio from stdlib/stdio.nx
import { Result, Ok, Err } from stdlib/result.nx
import as str from stdlib/string.nx

// --- Domain Types ---
type User = { id: i64, name: string, email: string }

// --- Port Definitions (Interfaces) ---
port Logger do
  fn info(msg: string) -> unit
  fn error(msg: string) -> unit
end

port UserRepository do
  fn find(id: i64) -> Result<User, string>
  fn save(user: User) -> Result<unit, string>
end

// --- Handler Implementations ---
let console_logger = handler Logger require { Console } do
  fn info(msg: string) -> unit do
    Console.println(val: "[INFO] " ++ msg)
    return ()
  end
  fn error(msg: string) -> unit do
    Console.println(val: "[ERROR] " ++ msg)
    return ()
  end
end

let mock_repo = handler UserRepository do
  fn find(id: i64) -> Result<User, string> do
    if id == 1 then
      return Ok(val: { id: 1, name: "Alice", email: "alice@example.com" })
    else
      return Err(err: "User not found: " ++ str.from_i64(n: id))
    end
  end
  fn save(user: User) -> Result<unit, string> do
    return Ok(val: ())
  end
end

// --- Business Logic (depends on ports, not implementations) ---
let register_user = fn (name: string, email: string) -> Result<unit, string> require { UserRepository, Logger } do
  Logger.info(msg: "Registering user: " ++ email)
  let user = { id: 0, name: name, email: email }
  let res = UserRepository.save(user: user)
  match res do
    case Ok(val: _) ->
      Logger.info(msg: "User registered successfully")
      return Ok(val: ())
    case Err(err: msg) ->
      Logger.error(msg: "Registration failed: " ++ msg)
      return Err(err: msg)
  end
end

// --- Main: Wire everything together ---
let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    inject console_logger do
      inject mock_repo do
        let res = register_user(name: "Bob", email: "bob@example.com")
        match res do
          case Ok(val: _) -> Console.println(val: "Done!")
          case Err(err: msg) -> Console.println(val: "Failed: " ++ msg)
        end
      end
    end
  end
  return ()
end
