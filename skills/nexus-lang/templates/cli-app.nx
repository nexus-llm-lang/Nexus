import { Console }, * as stdio from "std:stdio"
import { Fs }, * as fs_mod from "std:filesystem"
import * as str from "std:string_ops"
import * as list from "std:list"
import { Result, Ok, Err } from "std:result"

exception AppError(msg: string)

let process_file = fn (path: string) -> string require { Fs } throws { Exn } do
  if Fs.exists(path: path) then
    return Fs.read_to_string(path: path)
  else
    raise AppError(msg: "File not found: " ++ path)
  end
end

let main = fn () -> unit require { PermConsole, PermFs } do
  inject stdio.system_handler, fs_mod.system_handler do
    Console.println(val: "Enter file path:")
    let path = Console.read_line()
    let trimmed = str.trim(s: path)

    try
      let content = process_file(path: trimmed)
      let lines = str.split(s: content, sep: "\n")
      let count = list.length(xs: lines)
      Console.println(val: "Lines: " ++ str.from_i64(val: count))
      Console.println(val: content)
    catch
      | AppError(msg: m) -> Console.println(val: "Error: " ++ m)
      | _ -> Console.println(val: "Unexpected error")
    end
  end
  return ()
end
