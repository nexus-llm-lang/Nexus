import { Console }, * as stdio from "std:stdio"
import { Fs }, * as fs_mod from "std:fs"
import * as str from "std:str"
import * as list from "std:list"

exception AppError(msg: string)

// Domain logic: narrow throws to the function's own exception. Rule #7 says
// list what actually escapes — `AppError` is the only path out of here.
let count_lines = fn (content: string) -> i64 throws { AppError } do
  if str.length(s: content) == 0 then
    throw AppError(msg: "empty file")
  end
  return list.length(xs: str.split(s: content, sep: "\n"))
end

// I/O boundary: `Fs.read_to_string` declares `throws { Exn }` at the cap
// surface, so any function that calls it directly inherits `{ Exn }` in its
// row. Confine that broadening to a single boundary function (`main` here)
// rather than letting it leak into domain logic — rule #7 reserves
// `throws { Exn }` for true boundary code.
let main = fn () -> unit require { PermConsole, PermFs } do
  inject stdio.system_handler, fs_mod.system_handler do
    Console.println(val: "Enter file path:")
    let path = str.trim(s: Console.read_line())

    try
      if Fs.exists(path) then
        let content = Fs.read_to_string(path)
        let count = count_lines(content)
        Console.println(val: "Lines: " ++ str.from_i64(val: count))
        Console.println(val: content)
      else
        throw AppError(msg: "File not found: " ++ path)
      end
    catch
      | AppError(msg: m) -> Console.println(val: "Error: " ++ m)
      | _ -> Console.println(val: "Unexpected I/O error")
    end
  end
end
