# Normalize line endings on checkout
* text=auto eol=lf

# Source files
*.rs    text eol=lf
*.nix   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
*.nx    text eol=lf
*.scm   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Binary
*.pdb  binary
*.wasm binary
