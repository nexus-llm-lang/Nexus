// Negative fixture: module-level `let x = some_call()` is rejected with
// a clear UnsupportedTopLevelLet error from hir_build, naming the
// offending binding. Pre-fix (nexus-lfup) this was silently dropped, then
// later surfaced as a cryptic "Unresolved type in LIR lowering" at the
// reference site.
// Port of bootstrap/tests/ir/hir.rs::top_level_let_with_call_initializer_is_rejected.
external __nx_clock_now = "__nx_clock_now" : () -> i64
let start_time = __nx_clock_now()

let main = fn () -> unit do
    let _v = start_time
    return ()
end
