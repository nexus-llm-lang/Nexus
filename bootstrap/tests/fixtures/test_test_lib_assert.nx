// Smoke test for std:test/assert. Exercises every public helper on its
// happy path; the failure path is covered by raising AssertionFailed and
// unwinding via try/catch.
//
// `main` cannot declare `throws { Exn }` (typecheck rule), so the body
// runs in `safe_run` which converts every unexpected escape into a
// returned 0; main then traps via 1/0 if the body did not finish cleanly.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  test_assert.assert_true(cond: true, label: "tautology")
  test_assert.assert_false(cond: false, label: "contradiction")
  test_assert.assert_eq_i64(actual: 42, expected: 42, label: "i64-eq")
  test_assert.assert_ne_i64(actual: 1, forbidden: 2, label: "i64-ne")
  test_assert.assert_eq_bool(actual: true, expected: true, label: "bool-eq")
  test_assert.assert_eq_string(actual: "hello", expected: "hello", label: "string-eq")
  test_assert.assert_str_contains(haystack: "hello world", needle: "world", label: "substring")
  test_assert.assert_eq_i64_list(actual: [1, 2, 3], expected: [1, 2, 3], label: "i64-list")
  test_assert.assert_eq_string_list(actual: ["a", "b"], expected: ["a", "b"], label: "string-list")

  // Failure-path: raise AssertionFailed deliberately and verify the
  // rendered diff contains both operands.
  try
    test_assert.assert_eq_i64(actual: 3, expected: 4, label: "should-fail")
    raise RuntimeError(val: "expected AssertionFailed but assertion passed")
  catch e ->
    match e do
      | test_assert.AssertionFailed(msg) ->
        test_assert.assert_str_contains(haystack: msg, needle: "expected: 4", label: "diff-renders-expected")
        test_assert.assert_str_contains(haystack: msg, needle: "actual:   3", label: "diff-renders-actual")
      | _ -> raise e
    end
  end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  // Trap (divide-by-zero) when an exception escaped.
  let _ = 1 / ok
  return ()
end
