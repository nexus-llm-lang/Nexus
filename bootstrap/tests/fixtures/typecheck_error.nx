// Negative fixture for `nexus typecheck` (issue nexus-5er0).
// Calls `add` with the wrong argument types: the literal "hello" is a string
// but `add` expects two i64 parameters. The typechecker reports this as a
// TypeMismatch at the call site.
let add = fn (a: i64, b: i64) -> i64 do
  return a + b
end

let main = fn () -> unit do
  let _ = add(a: "hello", b: "world")
  return ()
end
