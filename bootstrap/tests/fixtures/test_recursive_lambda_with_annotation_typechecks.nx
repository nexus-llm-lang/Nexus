
    let test_fn = fn () -> i64 do
        let fact: (n: i64) -> i64 = fn (n: i64) -> i64 do
            if n == 0 then
                return 1
            else
                let n1 = n - 1
                let rec = fact(n: n1)
                return n * rec
            end
        end
        return fact(n: 5)
    end
    