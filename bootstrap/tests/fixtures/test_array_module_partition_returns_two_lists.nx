
    import * as array from "std:array"
    import * as list from "std:list"

    let gt_two = fn (val: i64) -> bool do
      return val > 2
    end

    let main = fn () -> i64 do
      let %arr = [| 1, 2, 3, 4 |]
      let arr_ref = &%arr
      let parts = array.partition(arr: arr_ref, pred: gt_two)
      match %arr do | _ -> () end
      match parts do
        | Partition(matched: m, rest: r) ->
          let a = list.length(xs: m)
          let b = list.length(xs: r)
          return a * 10 + b
      end
    end
    