// Negative fixture: external functions returning record types (e.g.
// `{ x: i64 }`) are not supported by the current WASM codegen and must
// surface a clear compile error (E2015).
// Port of bootstrap/tests/codegen/errors.rs::snapshot_codegen_error_unsupported_external.
import external "fake.wasm"
external bad = "bad" : (val: i64) -> { x: i64 }

let main = fn () -> unit do
    let x = bad(val: 42)
    return ()
end
