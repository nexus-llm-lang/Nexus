// Negative fixture: a user-defined linear record (`%t: Token`) must be
// consumed exactly once; falling out of scope is an error because
// generic-drop only applies to non-linear primitives.
// Port of bootstrap/tests/typecheck/linear.rs::
// test_generic_drop_user_defined_linear_consumes_once.
type Token = {
  id: i64
}

let main = fn () -> unit do
  let %t: Token = { id: 1 }
  return ()
end
