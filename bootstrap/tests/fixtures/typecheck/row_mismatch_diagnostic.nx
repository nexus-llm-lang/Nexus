// Negative fixture: a `throws {}` caller invoking a `throws { Exn }` callee
// must surface the surplus-label diagnostic, not a content-free
// "Row mismatch". The error string is asserted by
// row_mismatch_diagnostic.expected_error.txt.
exception Boom(code: i64)

let raiser = fn () -> unit throws { Exn } do
  raise Boom(code: 1)
end

let pure_caller = fn () -> unit throws {} do
  raiser()
end

let main = fn () -> unit do
  return ()
end
