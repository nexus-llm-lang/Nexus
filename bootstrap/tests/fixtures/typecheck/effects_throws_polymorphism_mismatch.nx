// Negative fixture: caller declared `throws {}` cannot apply a callee
// `throws { IO }`. The polymorphic apply forces E={} but its argument
// has E={IO}, exposing the mismatch.
// Port of bootstrap/tests/typecheck/effects.rs::
// test_throws_polymorphism_mismatch.
type IO = {}

let apply = fn <E>(f: () -> unit throws E) -> unit throws E do
  f()
end

let impure_fn = fn () -> unit throws { IO } do
  return ()
end

let test_fail = fn () -> unit throws {} do
  apply(f: impure_fn)
end

let main = fn () -> unit do
  return ()
end
