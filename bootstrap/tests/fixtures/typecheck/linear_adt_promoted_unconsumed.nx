// Negative fixture: wrapping a linear payload in an ADT promotes the
// ADT to linear; if the wrapper is then dropped without consumption,
// typecheck must fail.
// Port of bootstrap/tests/typecheck/linear.rs::
// test_adt_with_linear_arg_is_promoted_to_linear.
type Wrapper<T> = Wrap(val: T)

let main = fn () -> unit do
  let %r = { id: 1 }
  let w = Wrap(val: %r)
  return ()
end
