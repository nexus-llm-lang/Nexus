// Negative fixture: capturing a `@x` thunk in a closure makes the
// closure linear. Calling it twice must fail.
// Port of bootstrap/tests/typecheck/linear.rs::
// test_lazy_capture_linearizes_closure.
let main = fn () -> unit do
  let @x = 42
  let f = fn () -> i64 do return @x end
  f()
  f()
  return ()
end
