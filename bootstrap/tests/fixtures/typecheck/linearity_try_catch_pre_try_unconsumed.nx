// Negative fixture: a linear bound before `try` is consumed only on the
// success path. The catch arm inherits the pre-try snapshot (Strategy A,
// issue nexus-7eex.1) and leaves %t unconsumed — this must be rejected.
// Port of bootstrap/tests/typecheck/linearity.rs::
// test_try_catch_arm_starts_from_pre_try_linear_set.
exception Oops(msg: string)
type Token = { id: i64 }

let may_throw = fn () -> unit throws { Exn } do
  raise Oops(msg: "boom")
  return ()
end

let main = fn () -> unit do
  let %t: Token = { id: 1 }
  try
    may_throw()
    match %t do | { id: _ } -> () end
  catch _ -> ()
  end
  return ()
end
