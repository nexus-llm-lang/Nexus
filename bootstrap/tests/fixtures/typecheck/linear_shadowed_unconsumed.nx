// Negative fixture: shadowing a linear binding makes the OUTER value
// unreachable, so it can never be consumed — typecheck must reject.
// Port of bootstrap/tests/typecheck/linear.rs::
// prop_linear_shadowing_requires_consumption (one representative case).
let test_fn = fn () -> i64 do
  let %a = { id: 1 }
  let %a = { id: 2 }
  match %a do | _ -> () end
  match %a do | _ -> () end
  return 1
end
