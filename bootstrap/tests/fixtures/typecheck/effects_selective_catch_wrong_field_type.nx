// Negative fixture: catch arm field annotation mismatches the
// exception declaration. `Boom` carries `code: i64` but the arm
// annotates the bound name as `string`.
// Port of bootstrap/tests/typecheck/effects.rs::
// test_selective_catch_wrong_field_type_fails.
exception Boom(code: i64)

let main = fn () -> unit do
  try
    raise Boom(code: 42)
  catch
    | Boom(code: code) ->
      let x: string = code
      return ()
    | _ -> return ()
  end
  return ()
end
