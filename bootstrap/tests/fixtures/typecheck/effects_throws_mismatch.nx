// Negative fixture: a function declared `throws {}` (pure) cannot call
// a function that `throws { IO }`. The mismatch surfaces at the call
// site as a row-unification failure.
// Port of bootstrap/tests/typecheck/effects.rs::test_throws_mismatch.
type IO = {}

let f = fn () -> unit throws { IO } do
  return ()
end

let g = fn () -> unit throws {} do
  f()
end

let main = fn () -> unit do
  return ()
end
