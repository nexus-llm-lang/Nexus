// Negative fixture: or-pattern alternatives bind different variable names.
// `Left(v: v) | Right(v: w)` is rejected because `v` is unbound on the
// Right branch and `w` is unbound on the Left branch.
// Port of bootstrap/tests/typecheck/exhaustiveness.rs::
// test_or_pattern_alternatives_must_bind_same_variables.
type Either = Left(v: i64) | Right(v: i64)

let main = fn () -> unit do
  let e = Left(v: 1)
  match e do
    | Left(v: v) | Right(v: w) -> return ()
  end
end
