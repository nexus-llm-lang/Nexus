
    import * as list from "std:list"
    let main = fn () -> i64 do
      let empty = []
      let nonempty = 1 :: []
      let a = list.is_empty(xs: empty)
      let b = list.is_empty(xs: nonempty)
      if a then
        if b then return 0 else return 1 end
      else
        return 0
      end
    end
    