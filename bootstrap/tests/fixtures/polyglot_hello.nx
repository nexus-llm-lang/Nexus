// Tiny stdio program for the polyglot launcher acceptance test.
// Prints a known marker so the test can assert the launcher really executed
// the embedded wasm (and not, say, exited via the wasmtime-not-found path).
import { Console }, * as stdio from "std:stdio"

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    Console.println(val: "polyglot-hello")
  end
end
