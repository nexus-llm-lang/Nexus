// Smoke test for std:test/snapshot. Exercises round-trip parse +
// format on a constructed Snapshot value plus the malformed-input
// failure mode. The on-disk workflow exercises format + parse only;
// the Fs/Env-cap-bound write path is covered by the runtime test that
// drives NEXUS_SNAPSHOT_UPDATE=always.
import * as test_assert from "std:test/assert"
import { Snapshot, SnapshotHeader, HeaderEntry, SnapshotMalformed, format_snapshot, parse_snapshot } from "std:test/snapshot"
import { None, Some } from "std:option"

let body = fn () -> unit throws { Exn } do
  let header = SnapshotHeader(
    source: Some(val: "src/example.nx"),
    expression: Some(val: "example_case"),
    extras: [ HeaderEntry(key: "info", value: "round-trip") ],
  )
  let original = Snapshot(header: header, body: "line a\nline b\nline c")
  let text = format_snapshot(snap: original)

  test_assert.assert_str_contains(haystack: text, needle: "source: src/example.nx", label: "source-line")
  test_assert.assert_str_contains(haystack: text, needle: "expression: example_case", label: "expression-line")
  test_assert.assert_str_contains(haystack: text, needle: "info: round-trip", label: "extra-line")
  test_assert.assert_str_contains(haystack: text, needle: "line a\nline b\nline c", label: "body-preserved")

  let parsed = parse_snapshot(path: "<probe>", text: text)
  let Snapshot(_, body: parsed_body) = parsed
  test_assert.assert_eq_string(actual: parsed_body, expected: "line a\nline b\nline c", label: "round-trip-body")

  // Malformed input raises SnapshotMalformed.
  try
    let _ = parse_snapshot(path: "<bad>", text: "no leading dashes\n")
    raise RuntimeError(val: "expected SnapshotMalformed but parse succeeded")
  catch e ->
    match e do
      | SnapshotMalformed(_, reason) ->
        test_assert.assert_str_contains(haystack: reason, needle: "missing leading", label: "malformed-reason")
      | _ -> raise e
    end
  end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
