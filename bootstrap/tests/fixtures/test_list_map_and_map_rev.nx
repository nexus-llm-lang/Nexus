
    import * as list from "stdlib/list.nx"

    let twice = fn (val: i64) -> i64 do
      return val * 2
    end

    let main = fn () -> i64 do
      let xs = 1 :: 2 :: 3 :: []
      let mapped = list.map(xs: xs, f: twice)
      let rev_mapped = list.map_rev(xs: xs, f: twice)
      let a = list.nth(xs: mapped, n: 1)
      let b = list.head(xs: rev_mapped)
      return a * 10 + b
    end
    