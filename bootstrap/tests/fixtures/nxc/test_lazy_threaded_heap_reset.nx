/**
 * test_lazy_threaded_heap_reset: shared-memory threading + arena heap_mark /
 * heap_reset must actually reclaim worker-thread allocations (nexus-unf1).
 *
 * Layout: take a mark before any allocation, allocate in main and inside
 * two threaded thunks, join both, then heap_reset back to the original
 * mark. Take a *second* mark after the reset and assert the second mark
 * equals the first — i.e., the host-side alloc_ptr was actually rewound
 * to the pre-allocation snapshot, not just the (unused) G0 global.
 *
 * Without the fix (lazy host alloc disconnected from heap_reset), the
 * second mark would be larger than the first by at least the worker-side
 * Pair allocations + closure records, and the i64.div_s trap fires.
 */

import external "nexus:runtime/arena"

external __nx_heap_mark = "__nx_heap_mark" : () -> i64
external __nx_heap_reset = "__nx_heap_reset" : (mark: i64) -> unit

type Pair = Pair(a: i64, b: i64)

let main = fn () -> unit do
  let mark0 = __nx_heap_mark()
  let y = 7
  let @z = match Pair(a: y, b: y + 1) do
    | Pair(a: a, b: b) -> a + b
  end
  let @w = match Pair(a: y + 2, b: y + 3) do
    | Pair(a: a, b: b) -> a + b
  end
  let v1 = @z
  let v2 = @w
  let sum = v1 + v2
  let _ = if sum != 34 then 1 / 0 else 0 end

  __nx_heap_reset(mark: mark0)

  let mark1 = __nx_heap_mark()
  let _ = if mark1 != mark0 then 1 / 0 else 0 end
  return ()
end
