/**
 * test_lazy: Verify the nxc compiler can parse, typecheck, lift, and emit
 * call_indirect for @ lazy thunks.
 */

import { Console }, * as stdio from "stdlib/stdio.nx"

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    // Basic lazy binding and force (no captures)
    let @x = 42
    let v = @x

    // Lazy with captured variable
    let y = 10
    let @z = y + 1
    let w = @z

    // Compound force form: @(ident) parses as ExprForce on a thunk variable
    let @other = y + 2
    let a = @(other)

    Console.println(val: "lazy test passed")
    return ()
  end
end
