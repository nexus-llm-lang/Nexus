cap Gen do
  fn yield(val: i64) -> unit
end

let use_string = fn (s: string) -> unit do
  let _ = s
end

let collector = handler Gen do
  fn yield(val: i64) -> unit with @k do
    let _ = val
    use_string(s: @k)
  end
end

let main = fn () -> unit do
  inject collector do
    Gen.yield(val: 10)
  end
end
