// Tests for src/typecheck/infer — let annotation mismatch must raise InferExprErr.
// Regression test for nexus-9lp4.1: "hope for the best" on let type-annotation mismatch.
import { TyI64, TyUnit, LitString } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"
import { HirExpr, HirStmt, Let, Literal } from "src/ir/hir_types.nx"
import { InferExprOk, InferExprErr, tc_new_state } from "src/typecheck/types.nx"
import { infer_stmts } from "src/typecheck/infer.nx"
import { Some } from "std:option"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)

  // Build HIR for `let x: i64 = "hello"` — a type-annotation mismatch.
  let value = HirExpr(node: Literal(lit: LitString(val: "hello")), span: sp)
  let stmt = HirStmt(node: Let(name: "x", typ: Some(val: TyI64), value: value), span: sp)

  let state = tc_new_state(enum_defs: [], type_defs: [], exception_groups: [])
  let result = infer_stmts(state: state, stmts: [stmt], ret_type: TyUnit)

  match result do
    | InferExprErr(_) ->
      assert(cond: true, msg: "let x: i64 = \"hello\" correctly rejected")
    | InferExprOk(_) ->
      raise RuntimeError(val: "REGRESSION (nexus-9lp4.1): let x: i64 = \"hello\" incorrectly passed typecheck (silent default)")
  end

  return ()
end
