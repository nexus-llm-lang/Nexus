/**
 * test_runtime_mem_safe_oob_exn: covers the partial-function exception
 * contract on the safe_* mem wrappers. The unchecked primitives trap via
 * wasm; the safe_* wrappers must raise the catchable MemoryOutOfBounds
 * exception so callers don't have to catch a wasm trap.
 *
 * This is the dvr6.9.1 "specific exception" acceptance: addressing past
 * mem-size raises MemoryOutOfBounds(op, addr, access_size), not a generic
 * RuntimeError nor an unrecoverable trap.
 */

import { Console }, * as stdio from "std:stdio"
import { MemoryOutOfBounds, safe_load_i32, safe_store_i64, size } from "std:runtime_mem"
import { from_i64 } from "std:str"

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    // Pick an address well past current memory: (size + 100) pages * 65536.
    let pages = size()
    let oob_addr = (pages + 100) * 65536

    try
      let _ = safe_load_i32(addr: oob_addr)
      Console.println(val: "BUG: safe_load_i32 returned without raising")
    catch
      | MemoryOutOfBounds(op: o, addr: a, access_size: sz) ->
        Console.println(val: "load: " ++ o)
        Console.println(val: from_i64(val: a))
        Console.println(val: from_i64(val: sz))
    end

    try
      let _ = safe_store_i64(addr: oob_addr, val: 42)
      Console.println(val: "BUG: safe_store_i64 returned without raising")
    catch
      | MemoryOutOfBounds(op: o, addr: _, access_size: sz) ->
        Console.println(val: "store: " ++ o)
        Console.println(val: from_i64(val: sz))
    end
  end
end
