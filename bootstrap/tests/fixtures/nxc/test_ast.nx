import { Span } from "src/common/token.nx"
import { Sigil, BinaryOp, Literal, TypeExpr, Pattern, Expr, Stmt,
         SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel,
         Param, Function, MatchCase, CallArg, CtorArg, NamedExpr,
         NamedType, VariantField, CtorPatternField, RecordPatField,
         VariantDef, EnumDef, RecordDef, ExceptionDef, ImportDef,
         FunctionSig, Cap, GlobalLet, TopLevel, Program,
         RdrName, Unqual, Qual } from "src/common/ast.nx"
import * as str from "std:string_ops"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  // Construct a simple Span
  let sp = Span(offset: 0, line: 1, col: 1)

  // Construct sigils
  let s1 = SigilImmutable
  let s2 = SigilMutable

  // Construct a literal
  let lit = LitInt(val: 42)

  // Construct a type expression
  let ty = TyI64
  let ty_list = TyList(elem: TyString)
  let ty_arrow = TyArrow(
    params: [NamedType(name: "x", typ: TyI64)],
    ret: TyUnit,
    requires: TyRow(types: [], rest: None),
    throw_row: TyRow(types: [], rest: None)
  )

  // Construct a pattern
  let pat = PatVariable(name: "x", sigil: SigilImmutable)
  let sp_pat = SpannedPattern(node: pat, span: sp)

  // Construct an expression
  let expr_lit = ExprLiteral(lit: LitInt(val: 1))
  let sp_expr = SpannedExpr(node: expr_lit, span: sp)

  // Construct a binary op expression
  let expr_add = ExprBinaryOp(
    left: SpannedExpr(node: ExprLiteral(lit: LitInt(val: 1)), span: sp),
    op: OpAdd,
    right: SpannedExpr(node: ExprLiteral(lit: LitInt(val: 2)), span: sp)
  )

  // Construct a call expression
  let expr_call = ExprCall(
    func: Unqual(name: "foo"),
    args: [CallArg(name: "x", value: SpannedExpr(node: ExprLiteral(lit: LitInt(val: 10)), span: sp))]
  )

  // Construct a statement
  let stmt_let = StmtLet(
    name: "y",
    sigil: SigilImmutable,
    typ: Some(val: TyI64),
    value: SpannedExpr(node: ExprLiteral(lit: LitInt(val: 99)), span: sp)
  )
  let sp_stmt = SpannedStmt(node: stmt_let, span: sp)

  // Construct a function
  let func = Function(
    name: "my_fn",
    is_public: true,
    type_params: [],
    params: [Param(name: "a", sigil: SigilImmutable, typ: TyI64)],
    ret_type: TyUnit,
    requires: TyRow(types: [], rest: None),
    throw_row: TyRow(types: [], rest: None),
    body: [SpannedStmt(node: StmtReturn(value: SpannedExpr(node: ExprLiteral(lit: LitUnit), span: sp)), span: sp)]
  )

  // Construct a match case
  let mc = MatchCase(
    pattern: SpannedPattern(node: PatWildcard, span: sp),
    body: [SpannedStmt(node: StmtExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitUnit), span: sp)), span: sp)]
  )

  // Construct top-level items
  let tl_import = TLImport(def: ImportDef(path: "stdlib/string_ops.nx", alias: Some(val: "str"), items: [], is_external: false))
  let tl_enum = TLEnum(def: EnumDef(
    name: "Color",
    is_public: true,
    is_opaque: false,
    type_params: [],
    variants: [
      VariantDef(name: "Red", fields: []),
      VariantDef(name: "Green", fields: []),
      VariantDef(name: "Blue", fields: [])
    ]
  ))

  // Construct a Program
  let prog = Program(definitions: [
    SpannedTopLevel(node: tl_import, span: sp),
    SpannedTopLevel(node: tl_enum, span: sp)
  ])

  // Verify we can pattern match on the constructed AST
  match prog do
    | Program(definitions: defs) ->
      match defs do
        | SpannedTopLevel(node: n, span: _) :: _ ->
          match n do
            | TLImport(def: ImportDef(path: p, alias: _, items: _, is_external: _)) ->
              assert(cond: p == "stdlib/string_ops.nx", msg: "expected import path")
            | _ -> raise RuntimeError(val: "expected TLImport")
          end
        | _ -> raise RuntimeError(val: "expected non-empty definitions")
      end
  end

  return ()
end
