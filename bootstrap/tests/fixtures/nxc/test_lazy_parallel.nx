/**
 * test_lazy_parallel: Verify the lir_opt parallelize_consecutive_forces pass
 * fires on natural Nexus syntax and the threaded runtime produces correct
 * forced values.
 *
 * `let v1 = @a; let v2 = @b` becomes two adjacent CallIndirect ops in LIR
 * (the closure-creation stmts for @a and @b sit before this run, so the
 * forces themselves are back-to-back). The pass rewrites this run as
 * spawn(a); spawn(b); join → join, which under the core-wasm exec path
 * with LazyRuntime actually spawns worker threads.
 *
 * Self-asserts via i64.div_s trap-on-mismatch (main must return unit per
 * validate_main_returns_unit).
 */

let main = fn () -> unit do
  let @a = 11
  let @b = 22
  let v1 = @a
  let v2 = @b
  let sum = v1 + v2
  let divisor = if sum == 33 then 1 else 0 end
  let _ = 1 / divisor
  return ()
end
