/**
 * test_rand_range_in_bounds: smoke test that Random.range stays in [min, max).
 *
 * Phase A: lazy-init seeded from __nx_now() (real PRNG path), 8 iterations.
 *   Each Random.range(10, 20) result must satisfy 10 <= r < 20. Out-of-bounds
 *   values raise RuntimeError, which surfaces as a wasm trap and fails the
 *   harness assertion that stdout matches.
 *
 * Phase B: explicit seed=1 to confirm range() applies the same modulo to a
 *   known sequence — avoids "lazy_init succeeded but step was wrong" passing
 *   silently.
 *
 * Output is a single "ok" line per phase (interleave-checked by the harness)
 * so that a partial failure surfaces as a missing line, not a green run.
 */

import { Console }, * as stdio from "std:stdio"
import { Random, seed_with, reset }, * as rng from "std:rand"

let check_in_bounds = fn (r: i64, lo: i64, hi: i64) -> unit throws { Exn } do
  if r < lo then raise RuntimeError(val: "range result below lower bound") end
  if r >= hi then raise RuntimeError(val: "range result at/above upper bound") end
  return ()
end

let phase_a = fn () -> unit require { PermRandom } throws { Exn } do
  let _ = check_in_bounds(r: Random.range(min: 10, max: 20), lo: 10, hi: 20)
  let _ = check_in_bounds(r: Random.range(min: 10, max: 20), lo: 10, hi: 20)
  let _ = check_in_bounds(r: Random.range(min: 10, max: 20), lo: 10, hi: 20)
  let _ = check_in_bounds(r: Random.range(min: 10, max: 20), lo: 10, hi: 20)
  let _ = check_in_bounds(r: Random.range(min: 10, max: 20), lo: 10, hi: 20)
  let _ = check_in_bounds(r: Random.range(min: 10, max: 20), lo: 10, hi: 20)
  let _ = check_in_bounds(r: Random.range(min: 10, max: 20), lo: 10, hi: 20)
  let _ = check_in_bounds(r: Random.range(min: 10, max: 20), lo: 10, hi: 20)
  return ()
end

let phase_b = fn () -> unit require { PermRandom } throws { Exn } do
  let _ = reset()
  let _ = seed_with(seed: 1)
  let _ = check_in_bounds(r: Random.range(min: 10, max: 20), lo: 10, hi: 20)
  let _ = check_in_bounds(r: Random.range(min: 10, max: 20), lo: 10, hi: 20)
  let _ = check_in_bounds(r: Random.range(min: 10, max: 20), lo: 10, hi: 20)
  return ()
end

let main = fn () -> unit require { PermConsole, PermRandom } do
  inject stdio.system_handler do
    inject rng.system_handler do
      let _ = phase_a()
      Console.println(val: "ok-lazy-seed")
      let _ = phase_b()
      Console.println(val: "ok-explicit-seed")
    end
  end
end
