import { Console }, * as stdio from "std:stdio"
import { Sched }, * as sched from "std:sched"

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler, sched.scheduler do
      Console.println(val: "before yield")
      Sched.yield()
      Console.println(val: "after yield")
  end
end
