/**
 * test_opcode_arithmetic_rejected: regression for nexus-fnzs.
 *
 * `op_block`, `op_call`, etc. are now exposed as `() -> Opcode` zero-arg
 * functions over an opaque `Opcode` type. Wrapping closes the door on
 * mistakes like `op_block + 1` or `op_block + op_call` that the previous
 * raw-`i64` representation accepted silently.
 *
 * This fixture imports `op_block` / `op_call` and adds them with the integer
 * `+` operator. Both expressions are typed `Opcode` from outside `defs.nx`
 * (the constructors are private to the defining module thanks to `opaque
 * type`), so the binary `+` rule in
 * `src/typecheck/infer.nx::resolve_binop_types` cannot unify with `TyI64`
 * and surfaces a typecheck error. The compiler is expected to reject this
 * fixture; the test asserts that rejection.
 */
import { op_block, op_call } from "src/backend/wasm/defs.nx"

let main = fn () -> unit do
  // Both sides are `Opcode`; `+` cannot unify with an integer type.
  // This intentionally causes a typecheck error.
  let _bad = op_block() + op_call()
  return ()
end
