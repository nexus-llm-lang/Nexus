/**
 * test_lazy_threaded_captures: end-to-end shared-memory threading for
 * capture-bearing thunks (nexus-tb6p slice 2).
 *
 * `let @z = y; let @w = y + 11` are two thunks that each capture `y`.
 * `let v1 = @z; let v2 = @w` produces two adjacent zero-arg CallIndirect
 * ops in LIR; the parallelize_consecutive_forces pass rewrites them as
 * spawn(z, num_captures=1) + spawn(w, num_captures=1) + join + join.
 *
 * Compiled with the threaded codegen path (host-imported shared memory)
 * and run via the harness's `exec_threaded`, the two spawns dispatch to
 * worker threads in `LazyRuntime::with_shared_memory` mode — workers
 * read each thunk's capture (y) through the shared memory the caller
 * allocated their closure records in. Without slice 2's codegen path or
 * slice 1's runtime support, both thunks would take the inline fallback
 * and never exercise threading on capture-bearing closures.
 *
 * Self-asserts via i64.div_s trap-on-mismatch (main must return unit).
 */

let main = fn () -> unit do
  let y = 11
  let @z = y
  let @w = y + 11
  let v1 = @z
  let v2 = @w
  let sum = v1 + v2
  let divisor = if sum == 33 then 1 else 0 end
  let _ = 1 / divisor
  return ()
end
