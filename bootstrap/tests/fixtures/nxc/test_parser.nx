import { Token, Span, SpannedToken } from "src/common/token.nx"
import { Sigil, BinaryOp, Literal, TypeExpr, Pattern, Expr, Stmt,
         SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel,
         Param, Function, MatchCase, CallArg, CtorArg, NamedExpr,
         NamedType, VariantField, CtorPatternField, RecordPatField,
         VariantDef, EnumDef, RecordDef, ExceptionDef, ImportDef, ImportItem,
         FunctionSig, Port, GlobalLet, TopLevel, Program } from "src/common/ast.nx"
import { tokenize } from "src/frontend/lexer.nx"
import { parse } from "src/frontend/parser.nx"
let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  // ── Test 1: Parse a simple let + main function ───────────────────────
  let src1 = "let main = fn () -> unit do\n  return ()\nend\n"
  let tokens1 = tokenize(src: src1)
  let prog1 = parse(tokens: tokens1)

  match prog1 do
    | Program(definitions: defs) ->
      // Should have exactly one top-level definition (a global let)
      match defs do
        | SpannedTopLevel(node: n, span: _) :: [] ->
          match n do
            | TLLet(def: GlobalLet(name: nm, is_public: _, typ: _, value: _)) ->
              assert(cond: nm == "main", msg: "expected global let named main")
            | _ -> raise RuntimeError(val: "expected TLLet")
          end
        | _ -> raise RuntimeError(val: "expected exactly 1 top-level def")
      end
  end

  // ── Test 2: Parse import statement ───────────────────────────────────
  let src2 = "import { foo } from \"bar/baz.nx\"\nlet main = fn () -> unit do\n  return ()\nend\n"
  let tokens2 = tokenize(src: src2)
  let prog2 = parse(tokens: tokens2)

  match prog2 do
    | Program(definitions: defs) ->
      match defs do
        | SpannedTopLevel(node: n, span: _) :: _ :: [] ->
          match n do
            | TLImport(def: ImportDef(path: p, alias: _, items: itms, is_external: _)) ->
              assert(cond: p == "bar/baz.nx", msg: "expected import path bar/baz.nx")
              match itms do
                | ImportItem(name: item_name, item_alias: _) :: [] ->
                  assert(cond: item_name == "foo", msg: "expected import item foo")
                | _ -> raise RuntimeError(val: "expected 1 import item")
              end
            | _ -> raise RuntimeError(val: "expected TLImport")
          end
        | _ -> raise RuntimeError(val: "expected 2 top-level defs")
      end
  end

  // ── Test 3: Parse enum definition ────────────────────────────────────
  let src3 = "export type Color = Red | Green | Blue\nlet main = fn () -> unit do\n  return ()\nend\n"
  let tokens3 = tokenize(src: src3)
  let prog3 = parse(tokens: tokens3)

  match prog3 do
    | Program(definitions: defs) ->
      match defs do
        | SpannedTopLevel(node: n, span: _) :: _ ->
          match n do
            | TLEnum(def: EnumDef(name: nm, is_public: pub_flag, is_opaque: _, type_params: _, variants: vs)) ->
              assert(cond: nm == "Color", msg: "expected enum named Color")
              assert(cond: pub_flag, msg: "expected enum to be public")
              // Check first variant is Red
              match vs do
                | VariantDef(name: n1, fields: _) :: VariantDef(name: n2, fields: _) :: VariantDef(name: n3, fields: _) :: [] ->
                  assert(cond: n1 == "Red", msg: "expected Red")
                  assert(cond: n2 == "Green", msg: "expected Green")
                  assert(cond: n3 == "Blue", msg: "expected Blue")
                | _ -> raise RuntimeError(val: "expected 3 variants")
              end
            | _ -> raise RuntimeError(val: "expected TLEnum")
          end
        | _ -> raise RuntimeError(val: "expected defs")
      end
  end

  // ── Test 4: Parse binary expression ──────────────────────────────────
  let src4 = "let main = fn () -> unit do\n  let x = 1 + 2\n  return ()\nend\n"
  let tokens4 = tokenize(src: src4)
  let prog4 = parse(tokens: tokens4)

  match prog4 do
    | Program(definitions: defs) ->
      match defs do
        | SpannedTopLevel(node: n, span: _) :: [] ->
          match n do
            | TLLet(def: GlobalLet(name: _, is_public: _, typ: _, value: SpannedExpr(node: body_expr, span: _))) ->
              // The value is a lambda expression (fn () -> unit do ... end)
              match body_expr do
                | ExprLambda(params: _, ret_type: _, requires: _, throw_row: _, body: stmts) ->
                  // First statement should be let x = 1 + 2
                  match stmts do
                    | SpannedStmt(node: sn, span: _) :: _ ->
                      match sn do
                        | StmtLet(name: nm, sigil: _, typ: _, value: SpannedExpr(node: rhs_node, span: _)) ->
                          assert(cond: nm == "x", msg: "expected let x")
                          match rhs_node do
                            | ExprBinaryOp(left: _, op: op_val, right: _) ->
                              match op_val do
                                | OpAdd -> ()
                                | _ -> raise RuntimeError(val: "expected OpAdd")
                              end
                            | _ -> raise RuntimeError(val: "expected ExprBinaryOp")
                          end
                        | _ -> raise RuntimeError(val: "expected StmtLet")
                      end
                    | _ -> raise RuntimeError(val: "expected stmts")
                  end
                | _ -> raise RuntimeError(val: "expected ExprLambda")
              end
            | _ -> raise RuntimeError(val: "expected TLLet")
          end
        | _ -> raise RuntimeError(val: "expected 1 def")
      end
  end

  // ── Test 5: Parse match expression ───────────────────────────────────
  let src5 = "let main = fn () -> unit do\n  let x = 1\n  match x do\n    | 0 -> ()\n    | _ -> ()\n  end\n  return ()\nend\n"
  let tokens5 = tokenize(src: src5)
  let prog5 = parse(tokens: tokens5)

  // If we got here without a runtime error, parsing succeeded
  match prog5 do
    | Program(_) -> ()
  end

  // ── Test 6: Parse if expression ──────────────────────────────────────
  let src6 = "let main = fn () -> unit do\n  if true then return ()\n  else return ()\n  end\nend\n"
  let tokens6 = tokenize(src: src6)
  let prog6 = parse(tokens: tokens6)

  match prog6 do
    | Program(_) -> ()
  end

  // ── Test 7: Parse function with params and type annotation ───────────
  let src7 = "let add = fn (a: i64, b: i64) -> i64 do\n  return a + b\nend\nlet main = fn () -> unit do\n  return ()\nend\n"
  let tokens7 = tokenize(src: src7)
  let prog7 = parse(tokens: tokens7)

  match prog7 do
    | Program(definitions: defs) ->
      match defs do
        | SpannedTopLevel(node: n, span: _) :: _ ->
          match n do
            | TLLet(def: GlobalLet(name: nm, is_public: _, typ: _, value: _)) ->
              assert(cond: nm == "add", msg: "expected global let named add")
            | _ -> raise RuntimeError(val: "expected TLLet for add")
          end
        | _ -> raise RuntimeError(val: "expected defs")
      end
  end

  // ── Test 8: Punning in function call — f(x) desugars to f(x: x) ──────
  let src8 = "let f = fn (x: i64) -> i64 do\n  return x\nend\nlet main = fn () -> i64 do\n  let x = 5\n  return f(x)\nend\n"
  let Program(definitions: defs8) = parse(tokens: tokenize(src: src8))
  match defs8 do
    | _ :: SpannedTopLevel(node: TLLet(def: GlobalLet(name: _, is_public: _, typ: _, value: SpannedExpr(node: ExprLambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: _ :: SpannedStmt(node: StmtReturn(value: SpannedExpr(node: ExprCall(func: _, args: CallArg(name: an, value: SpannedExpr(node: ExprVariable(name: Unqual(name: vn), sigil: _), span: _)) :: []), span: _)), span: _) :: []), span: _))), span: _) :: [] ->
      assert(cond: an == "x", msg: "punned fn call: label should be 'x'")
      assert(cond: vn == "x", msg: "punned fn call: value should be variable 'x'")
    | _ -> raise RuntimeError(val: "expected punned fn call AST")
  end

  // ── Test 9: Punning in ctor call — Con(v) desugars to Con(v: v) ──────
  let src9 = "type Wrap = Mk(val: i64)\nlet main = fn () -> Wrap do\n  let val = 42\n  return Mk(val)\nend\n"
  let Program(definitions: defs9) = parse(tokens: tokenize(src: src9))
  match defs9 do
    | _ :: SpannedTopLevel(node: TLLet(def: GlobalLet(name: _, is_public: _, typ: _, value: SpannedExpr(node: ExprLambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: _ :: SpannedStmt(node: StmtReturn(value: SpannedExpr(node: ExprConstructor(name: _, args: CtorArg(name: an, value: SpannedExpr(node: ExprVariable(name: Unqual(name: vn), sigil: _), span: _)) :: []), span: _)), span: _) :: []), span: _))), span: _) :: [] ->
      assert(cond: an == "val", msg: "punned ctor call: label should be 'val'")
      assert(cond: vn == "val", msg: "punned ctor call: value should be variable 'val'")
    | _ -> raise RuntimeError(val: "expected punned ctor call AST")
  end

  // ── Test 10: Punning in ctor pattern — | Con(v) → Con(v: v) ──────
  let src10 = "type Wrap = Mk(val: i64)\nlet main = fn () -> i64 do\n  let w = Mk(val: 7)\n  match w do\n    | Mk(val) -> return val\n  end\nend\n"
  let Program(definitions: defs10) = parse(tokens: tokenize(src: src10))
  match defs10 do
    | _ :: SpannedTopLevel(node: TLLet(def: GlobalLet(name: _, is_public: _, typ: _, value: SpannedExpr(node: ExprLambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: _ :: SpannedStmt(node: StmtExpr(expr: SpannedExpr(node: ExprMatch(target: _, cases: MatchCase(pattern: SpannedPattern(node: PatConstructor(name: _, fields: CtorPatternField(name: fn_, pattern: SpannedPattern(node: PatVariable(name: vn, sigil: _), span: _)) :: []), span: _), body: _) :: []), span: _)), span: _) :: []), span: _))), span: _) :: [] ->
      assert(cond: fn_ == "val", msg: "punned ctor pat: field label should be 'val'")
      assert(cond: vn == "val", msg: "punned ctor pat: pattern should be PatVariable('val')")
    | _ -> raise RuntimeError(val: "expected punned ctor pattern AST")
  end

  return ()
end
