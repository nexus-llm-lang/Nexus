/**
 * test_chan_recv_before_send_traps: Phase 1 single-threaded execution
 * model — `recv` on an empty channel must trap (no scheduler exists yet
 * to suspend the receiver). Phase 3 will replace the trap with a yield;
 * this fixture's expectation will need to change at that point.
 *
 * The fixture deliberately calls `recv` first, then `send` (unreachable
 * after the trap). The harness asserts the trap message contains
 * "empty" via `exec_with_stdlib_core_should_trap`-style matching at the
 * Rust test layer.
 */

import * as chan from "std:chan"

let main = fn () -> unit do
  let ChanPair(tx: %tx, rx: %rx) = chan.oneshot()
  let _v = chan.recv(rx: %rx)
  chan.send(tx: %tx, val: 1)
  return ()
end
