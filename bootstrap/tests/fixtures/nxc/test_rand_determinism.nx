/**
 * test_rand_determinism: covers nexus-dvr6.9.6 — pure-Nexus PCG PRNG.
 *
 * Acceptance:
 *   (5) same seed → same 10+ next_i64 sequence (byte-equal across runs)
 *   (6) different seeds → divergent sequences
 *
 * Strategy: install a fixed seed via the test-only `seed_with` hatch, then
 * print the raw PCG output (state-mask form) for the first ten steps. The
 * harness asserts each line equals an offline-computed reference value
 * (Rust `wrapping_mul` + `wrapping_add` over u64). A divergence on any
 * line catches both PCG-step regressions (constants changed, multiply
 * order swapped) and state-cell layout corruption (load/store offset drift).
 *
 * After the seed=1 sequence we reset and re-seed with `2` to print one
 * line whose value differs from the seed=1 step-1 line — this covers
 * the smoke test (different seed → different sequence) inline so the
 * interleave assertion catches "ensure_seeded never re-seeds after reset"
 * as a regression rather than silently passing because the same state
 * was reused across both phases.
 */

import { Console }, * as stdio from "std:stdio"
import { Random, seed_with, reset }, * as rng from "std:rand"
import { from_i64 } from "std:str"

let main = fn () -> unit require { PermConsole, PermRandom } do
  inject stdio.system_handler do
    inject rng.system_handler do
      // Phase A: seed = 1, ten steps. Reference values computed by
      // u64 wrapping_mul/add of (6364136223846793005, 1442695040888963407)
      // starting from state = 1, with top-bit cleared on each output.
      let _ = seed_with(seed: 1)
      let r1 = Random.next_i64()
      Console.println(val: from_i64(val: r1))   // 7806831264735756412
      let r2 = Random.next_i64()
      Console.println(val: from_i64(val: r2))   // 173536691264035611
      let r3 = Random.next_i64()
      Console.println(val: from_i64(val: r3))   // 2736747771374053902
      let r4 = Random.next_i64()
      Console.println(val: from_i64(val: r4))   // 7062582979898595269
      let r5 = Random.next_i64()
      Console.println(val: from_i64(val: r5))   // 5450049017633417712
      let r6 = Random.next_i64()
      Console.println(val: from_i64(val: r6))   // 9431502868738175
      let r7 = Random.next_i64()
      Console.println(val: from_i64(val: r7))   // 994931806658971810
      let r8 = Random.next_i64()
      Console.println(val: from_i64(val: r8))   // 1206773305466921929
      let r9 = Random.next_i64()
      Console.println(val: from_i64(val: r9))   // 6266840599827907236
      let r10 = Random.next_i64()
      Console.println(val: from_i64(val: r10))  // 3660572683296592931

      // Phase B: reset state, seed = 2, one step. Must differ from r1
      // (proves seed_with installs the new seed AND ensure_seeded is
      // not skipped on a stale flag — reset() clears both fields).
      let _ = reset()
      let _ = seed_with(seed: 2)
      let s1 = Random.next_i64()
      Console.println(val: from_i64(val: s1))   // 4947595451727773609
    end
  end
end
