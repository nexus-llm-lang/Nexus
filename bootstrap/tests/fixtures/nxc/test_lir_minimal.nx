import { MirProgram, MirFunction, MirStmt, MirExpr } from "src/ir/mir_types.nx"
import { LirProgram } from "src/ir/lir_types.nx"
import { lower_mir_to_lir } from "src/ir/lir.nx"
import { Span } from "src/common/token.nx"
import { Literal, TypeExpr } from "src/common/ast.nx"

let main = fn () -> unit throws { Exn } do
  let func = MirFunction(
    name: "test",
    params: [],
    ret_type: TyUnit,
    body: MirStmtReturn(expr: MirLiteral(lit: LitUnit)) :: [],
    span: Span(offset: 0, line: 0, col: 0)
  )
  let mir = MirProgram(functions: func :: [], externals: [])
  let lir = lower_mir_to_lir(mir: mir, enum_defs: [])
  return ()
end
