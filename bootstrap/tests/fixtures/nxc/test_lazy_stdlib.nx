/**
 * test_lazy_stdlib: Verify stdlib/lazy.nx combinators compile and run.
 *
 * Covers race, cancel, detach from nxlib/stdlib/lazy.nx. Sequential
 * semantics: each combinator forces its thunks in source order.
 */

import { Console }, * as stdio from "stdlib/stdio.nx"
import * as lazy from "stdlib/lazy.nx"

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let @a = 10
    let @b = 20
    let winner = lazy.race(a: a, b: b)

    let @c = 7
    lazy.cancel(a: c)

    let @d = 3
    lazy.detach(a: d)

    Console.println(val: "lazy stdlib ok")
    return ()
  end
end
