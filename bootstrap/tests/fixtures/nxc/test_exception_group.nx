/**
 * test_exception_group: Verify the nxc compiler handles exception groups.
 *
 * Tests: per-phase exceptions, group definition, selective catch by group.
 */

import { Console }, * as stdio from "std:stdio"

exception NotFound(path: string)
exception PermDenied(path: string)
exception group IOError = NotFound | PermDenied

let risky = fn () -> unit throws { Exn } do
  raise NotFound(path: "/tmp/missing")
  return ()
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    try
      risky()
    catch
      | IOError ->
        Console.println(val: "caught IOError group member")
        return ()
    end
    return ()
  end
end
