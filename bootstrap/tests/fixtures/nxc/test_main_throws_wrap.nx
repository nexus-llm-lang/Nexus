/**
 * test_main_throws_wrap: Verify the self-host main-wrap HIR pass (issue
 * nexus-urf5).
 *
 * `main` declares a non-empty throws-row and raises an unhandled exception.
 * The HIR pass synthesises a top-level catch-all wrapper that:
 *   - prints the variant tag (here: `Boom(...)\n`) to stderr
 *   - prints `  at <frame>\n` for every captured backtrace entry
 *   - calls `__nx_exit(1)` so the process terminates non-zero
 *
 * The test harness invokes the wasm and asserts:
 *   (a) execution traps with WASI's `proc_exit(1)` (Stop reason matching `1`)
 *   (b) stderr contains both the variant tag and at least one `  at ` frame
 *
 * This fixture must be compiled via the **self-hosted** nxc — the bootstrap
 * Rust compiler still rejects non-empty `main` throws (acceptance #1 was
 * scoped out of urf5 because dvr6 will decommission the bootstrap).
 */

exception Boom(code: i64)
exception group BoomGroup = Boom

let main = fn () -> unit throws { BoomGroup } do
  raise Boom(code: 42)
  return ()
end
