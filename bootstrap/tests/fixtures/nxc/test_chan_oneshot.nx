/**
 * test_chan_oneshot: Verify one-shot channels round-trip a value through
 * the `nexus:runtime/chan` host functions. Acceptance fixture for nexus-lim
 * (Phase 1 of the concurrency epic).
 *
 * Self-asserts via `i64.div_s` trap-on-mismatch (main returns unit per
 * `validate_main_returns_unit`). Routes through the core-wasm + WASI path
 * (`exec_with_stdlib_core`) — `nexus:runtime/chan` is a runtime import,
 * not part of the stdlib component.
 */

import * as chan from "std:chan"

let main = fn () -> unit do
  let ChanPair(tx: %tx, rx: %rx) = chan.oneshot()
  chan.send(tx: %tx, val: 42)
  let v = chan.recv(rx: %rx)

  // Trap-on-mismatch: divide by zero if v != 42.
  let ok = if v == 42 then 1 else 0 end
  let _ = 1 / ok
  return ()
end
