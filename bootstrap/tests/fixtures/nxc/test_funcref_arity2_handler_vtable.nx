/**
 * Verifies the nxc-codegen path handles top-level fn refs stored as
 * record fields (the handler-vtable shape that trips nexus-pt8g).
 * Pre-fix: codegen raises E3001 "closure arity '2' not found" on the
 * `Vt2(f: arity_2_fn)` constructor literal because `collect_closure_arities`
 * only walks `__closure_*` definitions and never registered an arity-2
 * call_indirect type. Post-fix: every value-position reference to a
 * named top-level fn lifts a `__closure_wrap_<target>` thunk which
 * carries the canonical (env, args...) signature, registering the
 * matching arity automatically and closing the codegen path.
 */
import { Console }, * as stdio from "std:stdio"
import * as str from "std:str"

type Vt2 = Vt2(f: (a: i64, b: i64) -> i64)

let add2 = fn (a: i64, b: i64) -> i64 do return a + b end
let mul2 = fn (a: i64, b: i64) -> i64 do return a * b end

let dispatch = fn (vt: Vt2, x: i64, y: i64) -> i64 do
  match vt do | Vt2(f) -> return f(a: x, b: y) end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let vt_add = Vt2(f: add2)
    let vt_mul = Vt2(f: mul2)
    let s = dispatch(vt: vt_add, x: 3, y: 4)
    let p = dispatch(vt: vt_mul, x: 3, y: 4)
    Console.println(val: "add=" ++ str.from_i64(val: s) ++ " mul=" ++ str.from_i64(val: p))
  end
end
