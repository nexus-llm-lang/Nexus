/**
 * test_net_echo_server: a minimal Nexus HTTP echo server fixture
 * (nexus-gv2u acceptance #1).
 *
 * Shape:
 *   listen → loop { accept → respond(echo body) } → stop
 *
 * The fixture only typecheck-and-compiles in CI: actually driving traffic
 * through it requires the wasi:http + wasi:sockets host capabilities which
 * the test harness doesn't wire up. The 100k-iter sustained-load assertion
 * lives in `bootstrap/tests/stdlib/arena.rs::
 * arena_100k_echo_workload_g0_bounded_with_reset` — it inlines the
 * user-side per-iteration workload (the part of decode_request /
 * response-build that flows through the *user's* routed allocator) and
 * exercises mark/reset on it. Net-crate allocations route through the net
 * crate's *own* nexus_wasm_alloc::ALLOCATIONS storage and are out of reach
 * of user-side heap_mark / heap_reset (open design question in nexus-gv2u;
 * see the follow-up issue for a shared cross-module allocator).
 *
 * The handler-loop is wrapped in arena.heap_mark / heap_reset so the
 * decode_request / response-build temporaries that *do* route through the
 * user's allocator are reclaimed every iteration. This is the
 * recommended-pattern half of the acceptance: a worked example that
 * downstream Nexus servers can copy.
 *
 * Address binding uses port 0 + immediate stop so the fixture exits without
 * blocking the harness.
 */

import { Net }, * as net_mod from "std:network"
import { Console }, * as stdio from "std:stdio"
import { heap_mark, heap_reset } from "std:arena"
import { request_body } from "std:network"

let main = fn () -> unit require { PermNet, PermConsole } do
  inject net_mod.system_handler, stdio.system_handler do
    try
      let server = Net.listen(addr: "127.0.0.1:0")
      // Drain at most one request and shut down. Real servers loop until a
      // shutdown signal; the fixture stays bounded so CI doesn't hang.
      let mark = heap_mark()
      let req = Net.accept(server: &server)
      let body = request_body(req: &req)
      // nexus-7eex.2 hole-2: close the linear `server` before the throwable
      // `Net.respond` call so a respond-time raise doesn't leak `server`.
      // This is the same pattern used in
      // bootstrap/tests/stdlib/net.rs::net_respond_consumes_request.
      Net.stop(server: server)
      Net.respond(req: req, status: 200, body: body)
      heap_reset(mark: mark)
      Console.println(val: "echo-served")
    catch e ->
      // Without a real wasi:http+sockets host the bind/accept fails;
      // print a deterministic marker so the harness can verify the
      // typecheck+codegen path executed end-to-end.
      Console.println(val: "echo-bind-failed")
    end
  end
end
