/**
 * test_lazy_host_force: Verify host_force invokes thunks via the
 * nexus:runtime/lazy host functions (Rust __nx_lazy_spawn).
 * End-to-end exercise of the lazy runtime from nexus source.
 *
 * Self-asserts via `i64.div_s` trap-on-mismatch (main must return unit
 * per `validate_main_returns_unit`). Stdio-free so the harness skips
 * `wasm-merge` bundling, avoiding the multimemory UTF-8 trap.
 */

import * as lazy from "std:lazy"

let main = fn () -> unit do
  let @x = 42
  let v1 = lazy.host_force(a: x)

  let y = 10
  let @z = y + 1
  let v2 = lazy.host_force(a: z)

  // Trap on mismatch: divide by zero if either forced value is wrong.
  // v1 must be 42 (no captures); v2 must be 11 (captures y=10).
  let ok = if v1 == 42 then if v2 == 11 then 1 else 0 end else 0 end
  let _ = 1 / ok
  return ()
end
