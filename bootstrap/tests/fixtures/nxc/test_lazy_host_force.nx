/**
 * test_lazy_host_force: Verify host_force invokes thunks via the
 * nexus:runtime/lazy host functions (Rust __nx_lazy_spawn).
 * End-to-end exercise of the lazy runtime from nexus source.
 */

import { Console }, * as stdio from "stdlib/stdio.nx"
import * as lazy from "stdlib/lazy.nx"

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let @x = 42
    let _ = lazy.host_force(a: x)

    let y = 10
    let @z = y + 1
    let _ = lazy.host_force(a: z)

    Console.println(val: "host force ok")
    return ()
  end
end
