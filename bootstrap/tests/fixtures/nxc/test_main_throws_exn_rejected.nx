/**
 * test_main_throws_exn_rejected: Verify the self-host validate_main narrowing
 * (acceptance #1 of nexus-urf5).
 *
 * The wrap pass routes closed rows of named exception variants/groups
 * (including `Exn`) through a synthesised top-level catch-all. Rows whose
 * entries are not named exception types fall through unchanged, and
 * `validate_main` raises `MainThrowsTooBroad` (E2007).
 *
 * `i64` is not a named exception type, so the validate_main row walker
 * rejects it. This fixture is *expected to fail* compilation via self-host
 * nxc with error code E2007.
 */

let main = fn () -> unit throws { i64 } do
  return ()
end
