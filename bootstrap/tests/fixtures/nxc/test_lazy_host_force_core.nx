/**
 * test_lazy_host_force_core: Routes `host_force` through the
 * `nexus:runtime/lazy` host imports without touching stdlib I/O. This
 * lets the test execute through the core-wasm + WASI preview1 path
 * (`exec_with_stdlib_core`) where the real `LazyRuntime` invokes thunks
 * via the merged module's memory + indirect function table.
 *
 * The component-model harness path (`exec_with_stdlib`) stubs lazy host
 * functions to return `(0,)` — running this fixture there would make
 * the trap-on-mismatch fire because `v1` would come back as `0`, not
 * `42`. Acceptance test for nexus-ug96.
 *
 * Self-asserts via `i64.div_s` trap-on-mismatch (main must return unit
 * per `validate_main_returns_unit`).
 */

import * as lazy from "stdlib/lazy.nx"

let main = fn () -> unit do
  let @x = 42
  let v1 = lazy.host_force(a: x)

  let y = 10
  let @z = y + 1
  let v2 = lazy.host_force(a: z)

  // Trap-on-mismatch via i64.div_s by zero. Both forced values must
  // round-trip through the runtime intact: v1 = 42 (no captures, threaded
  // path) and v2 = 11 (captures y; inline-fallback path).
  let ok = if v1 == 42 then if v2 == 11 then 1 else 0 end else 0 end
  let _ = 1 / ok
  return ()
end
