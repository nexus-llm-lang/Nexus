// Tests for src/typecheck/capture: closure-capture linearization (nexus-mqin.6).
// Spec: docs/spec/type-system-formal.md T-Lambda — capturing a linear binding
// makes the closure type linear; capturing a mutable ref is rejected.

import { TypeExpr, TyI64, TyUnit, TyArrow, TyLinear, TyRef, TyRow, LitInt, SigilImmutable } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"
import { HirExpr, HirStmt, Variable, Expr, Return, Literal, Lambda } from "src/ir/hir_types.nx"
import { tc_new_state, state_with_env, env_insert, mono, InferExprOk, InferExprErr } from "src/typecheck/types.nx"
import { infer_expr } from "src/typecheck/infer.nx"
import { Some, None } from "std:option"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)

  // Outer env: x has linear type %i64, r has mutable-ref type ~i64.
  let st0 = tc_new_state(enum_defs: [], type_defs: [], exception_groups: [])
  let env_x = env_insert(env: [], name: "x", scheme: mono(typ: TyLinear(inner: TyI64)))
  let env_xr = env_insert(env: env_x, name: "r", scheme: mono(typ: TyRef(inner: TyI64)))
  let state = state_with_env(state: st0, env: env_xr)

  // Test 1: lambda body references %x → arrow must be wrapped with TyLinear.
  // We use Expr(Variable) (not Return) so the body type-checks regardless of
  // the lambda's declared ret_type — the test isolates capture analysis.
  let body1 = [HirStmt(node: Expr(expr: HirExpr(node: Variable(name: "x", sigil: SigilImmutable), span: sp)), span: sp)]
  let lambda1 = HirExpr(node: Lambda(type_params: [], params: [], ret_type: TyUnit, body: body1), span: sp)
  match infer_expr(state, expr: lambda1, ret_type: TyUnit) do
    | InferExprErr(message: m, span: _) ->
      raise RuntimeError(val: "Test 1 unexpectedly errored: " ++ m)
    | InferExprOk(state: _, subst: _, typ: t) ->
      match t do
        | TyLinear(inner: TyArrow(_)) ->
          assert(cond: true, msg: "linear capture wraps closure")
        | _ ->
          raise RuntimeError(val: "REGRESSION (nexus-mqin.6): lambda capturing %x not wrapped with %arrow")
      end
  end

  // Test 2: lambda body references ~r → typecheck must reject.
  let body2 = [HirStmt(node: Expr(expr: HirExpr(node: Variable(name: "r", sigil: SigilImmutable), span: sp)), span: sp)]
  let lambda2 = HirExpr(node: Lambda(type_params: [], params: [], ret_type: TyUnit, body: body2), span: sp)
  match infer_expr(state, expr: lambda2, ret_type: TyUnit) do
    | InferExprOk(_) ->
      raise RuntimeError(val: "REGRESSION (nexus-mqin.6): lambda capturing ~r should have been rejected")
    | InferExprErr(_) ->
      assert(cond: true, msg: "ref capture rejected")
  end

  // Test 3: lambda body has no captures → arrow stays plain.
  let body3 = [HirStmt(node: Return(expr: HirExpr(node: Literal(lit: LitInt(val: 42)), span: sp)), span: sp)]
  let lambda3 = HirExpr(node: Lambda(type_params: [], params: [], ret_type: TyI64, body: body3), span: sp)
  match infer_expr(state, expr: lambda3, ret_type: TyUnit) do
    | InferExprErr(message: m, span: _) ->
      raise RuntimeError(val: "Test 3 unexpectedly errored: " ++ m)
    | InferExprOk(state: _, subst: _, typ: t) ->
      match t do
        | TyArrow(_) -> assert(cond: true, msg: "no capture leaves arrow plain")
        | _ -> raise RuntimeError(val: "Test 3 expected plain TyArrow")
      end
  end

  return ()
end
