/**
 * test_lazy_runtime_raw: Exercise __nx_lazy_spawn + __nx_lazy_join via the
 * raw host imports (no stdlib, no component composition). Runs via the
 * core-wasm exec path so our Rust LazyRuntime handles the calls directly
 * on worker threads.
 *
 * Self-asserts by trapping (i64.div_s by zero) if the forced value differs
 * from the expected 42 — `main` must return unit per the codegen contract,
 * so we surface a wrong result via a runtime trap that the test harness
 * picks up as a failure.
 */

import external "nexus:runtime/lazy"

external __nx_lazy_spawn = "__nx_lazy_spawn" : <T>(thunk: @T, num_captures: i32) -> i64
external __nx_lazy_join = "__nx_lazy_join" : <T>(task_id: i64) -> T

let main = fn () -> unit do
  let @x = 42
  let handle = __nx_lazy_spawn(thunk: x, num_captures: 0)
  let v = __nx_lazy_join(task_id: handle)
  let divisor = if v == 42 then 1 else 0 end
  let _ = 1 / divisor
  return ()
end
