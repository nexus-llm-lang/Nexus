/**
 * test_lazy_runtime_raw: Exercise __nx_lazy_spawn via the raw host
 * imports (no stdlib). Run via the core-wasm exec path so our Rust
 * runtime (bootstrap/src/runtime/lazy.rs) handles the call directly,
 * proving invoke_thunk works end-to-end on nxc-compiled code.
 */

import external "nexus:runtime/lazy"

external __nx_lazy_spawn = "__nx_lazy_spawn" : <T>(thunk: @T, num_captures: i32) -> T

let main = fn () -> unit do
  let @x = 42
  let _ = __nx_lazy_spawn(thunk: x, num_captures: 0)
  return ()
end
