// nexus-w9ne regression: bare `if FLOAT_LIT >. FLOAT_LIT then ... end`
// at main entry. Pre-fix the self-host LIR `infer_binary_type` returned
// `lhs_type` (TyF64) for OpFGt instead of TyBool, so the temp holding the
// comparison result was allocated as f64 and the `local.set` of an i32
// (the f64.gt result) into an f64 local failed wasmtime validation with
// 'type mismatch' at the function's entry block.
//
// Coverage spans every f64 relational operator so a future regression
// in any single arm is caught — `>.`, `<.`, `>=.`, `<=.`, `==.`, `!=.`.

import { Console }, * as stdio from "std:stdio"

let main = fn () -> unit require { Console } throws { Exn } do
  if 3.14 >. 3.13 then Console.println(val: "gt") end
  if 3.13 <. 3.14 then Console.println(val: "lt") end
  if 3.14 >=. 3.14 then Console.println(val: "ge") end
  if 3.14 <=. 3.14 then Console.println(val: "le") end
  if 3.14 ==. 3.14 then Console.println(val: "eq") end
  if 3.14 !=. 3.13 then Console.println(val: "ne") end
  return ()
end
