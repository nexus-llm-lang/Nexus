import { RdrName, Unqual, Qual } from "src/common/ast.nx"
import { DefId, ImportSpec, GlobalRdrElt, ModuleEnv,
         LookupResult, Resolved, Ambiguous, NotInScope,
         empty_env, add_def, lookup, defid_eq,
         mk_unqual_spec, mk_qual_spec } from "src/ir/rdrname.nx"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let expect_resolved = fn (r: LookupResult, expected: DefId, label: string) -> unit throws { Exn } do
  match r do
    case Resolved(val: d) ->
      assert(cond: defid_eq(a: d, b: expected), msg: label ++ ": DefId mismatch")
    case Ambiguous(_) -> raise RuntimeError(val: label ++ ": expected Resolved, got Ambiguous")
    case NotInScope -> raise RuntimeError(val: label ++ ": expected Resolved, got NotInScope")
  end
end

let expect_not_in_scope = fn (r: LookupResult, label: string) -> unit throws { Exn } do
  match r do
    case NotInScope -> return ()
    case _ -> raise RuntimeError(val: label ++ ": expected NotInScope")
  end
end

let expect_ambiguous = fn (r: LookupResult, label: string) -> unit throws { Exn } do
  match r do
    case Ambiguous(_) -> return ()
    case _ -> raise RuntimeError(val: label ++ ": expected Ambiguous")
  end
end

let main = fn () -> unit throws { Exn } do
  let foo_in_mod = DefId(module: "mod.nx", name: "foo")
  let concat_in_buf = DefId(module: "buf.nx", name: "concat")
  let foo_in_a = DefId(module: "a.nx", name: "foo")
  let foo_in_b = DefId(module: "b.nx", name: "foo")

  // 1. Selective unqualified import:
  //    import { foo } from "mod.nx" — Unqual("foo") resolves; Qual("mod","foo") too (via default alias).
  let env1 = add_def(
    env: empty_env(),
    elt: GlobalRdrElt(
      defid: foo_in_mod,
      occ: "foo",
      specs: [mk_unqual_spec(source_path: "mod.nx")]))

  expect_resolved(r: lookup(env: env1, name: Unqual(name: "foo")),
                  expected: foo_in_mod, label: "selective unqual foo")

  // 2. Wildcard import with explicit alias:
  //    import * as buf from "buf.nx" — Qual("buf","concat") resolves; Unqual does NOT.
  let env2 = add_def(
    env: empty_env(),
    elt: GlobalRdrElt(
      defid: concat_in_buf,
      occ: "concat",
      specs: [mk_qual_spec(source_path: "buf.nx", alias: "buf")]))

  expect_resolved(r: lookup(env: env2, name: Qual(alias: "buf", name: "concat")),
                  expected: concat_in_buf, label: "wildcard qual buf.concat")

  expect_not_in_scope(r: lookup(env: env2, name: Unqual(name: "concat")),
                      label: "wildcard-only should not expose unqual concat")

  // 3. Qual with wrong alias -> NotInScope.
  expect_not_in_scope(r: lookup(env: env2, name: Qual(alias: "wrong", name: "concat")),
                      label: "qual with wrong alias")

  // 4. Diamond: same DefId reachable through two distinct ImportSpecs.
  //    Both paths collapse to a single Resolved result (no Ambiguous, no duplicate).
  let env3 = add_def(
    env: empty_env(),
    elt: GlobalRdrElt(
      defid: foo_in_mod,
      occ: "foo",
      specs: [mk_unqual_spec(source_path: "mod.nx"),
              mk_unqual_spec(source_path: "mod.nx")]))

  expect_resolved(r: lookup(env: env3, name: Unqual(name: "foo")),
                  expected: foo_in_mod, label: "diamond collapses to single DefId")

  // 5. True ambiguity: two DIFFERENT DefIds visible under the same occ name.
  let env4 = add_def(
    env: add_def(
      env: empty_env(),
      elt: GlobalRdrElt(
        defid: foo_in_a,
        occ: "foo",
        specs: [mk_unqual_spec(source_path: "a.nx")])),
    elt: GlobalRdrElt(
      defid: foo_in_b,
      occ: "foo",
      specs: [mk_unqual_spec(source_path: "b.nx")]))

  expect_ambiguous(r: lookup(env: env4, name: Unqual(name: "foo")),
                   label: "distinct DefIds under same name → Ambiguous")

  // 6. Ambiguity is resolved by qualifying: Qual("a","foo") picks only foo_in_a.
  //    To make this work, the two imports must carry aliases.
  let env5 = add_def(
    env: add_def(
      env: empty_env(),
      elt: GlobalRdrElt(
        defid: foo_in_a,
        occ: "foo",
        specs: [mk_qual_spec(source_path: "a.nx", alias: "a")])),
    elt: GlobalRdrElt(
      defid: foo_in_b,
      occ: "foo",
      specs: [mk_qual_spec(source_path: "b.nx", alias: "b")]))

  expect_resolved(r: lookup(env: env5, name: Qual(alias: "a", name: "foo")),
                  expected: foo_in_a, label: "qualified a.foo picks a's DefId")

  expect_resolved(r: lookup(env: env5, name: Qual(alias: "b", name: "foo")),
                  expected: foo_in_b, label: "qualified b.foo picks b's DefId")

  expect_not_in_scope(r: lookup(env: env5, name: Unqual(name: "foo")),
                      label: "qualified-only imports do not expose unqual foo")

  // 7. Unknown name -> NotInScope.
  expect_not_in_scope(r: lookup(env: env1, name: Unqual(name: "nonexistent")),
                      label: "unknown name")

  // 8. DefId equality is structural.
  assert(cond: defid_eq(a: foo_in_mod, b: DefId(module: "mod.nx", name: "foo")),
         msg: "defid_eq: same module+name equals")
  assert(cond: defid_eq(a: foo_in_mod, b: foo_in_a) == false,
         msg: "defid_eq: different module -> not equal")
  assert(cond: defid_eq(a: foo_in_a, b: DefId(module: "a.nx", name: "bar")) == false,
         msg: "defid_eq: different name -> not equal")

  return ()
end
