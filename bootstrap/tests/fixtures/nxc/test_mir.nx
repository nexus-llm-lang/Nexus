import { Span } from "src/common/token.nx"
import { Literal, TypeExpr, Sigil, BinaryOp, EnumDef, TyArrow, NamedType } from "src/common/ast.nx"
import { HirExprKind, HirStmtKind, HirCallArg, HirParam, HirFunction,
         HirPort, HirPortMethod, HirExternal, HirHandlerBinding,
         HirHandlerBindingEntry, HirProgram, HirMatchCase, HirPatternKind,
         HirNamedExpr, HirExpr, HirStmt, HirBody, EagerBody } from "src/ir/hir_types.nx"
import { MirProgram, MirFunction, MirParam, MirExpr, MirStmt, MirMatchCase, MirPattern } from "src/ir/mir_types.nx"
import { lower_hir_to_mir } from "src/ir/mir.nx"
import * as str from "std:string_ops"
import * as list from "std:list"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let dummy_span = fn () -> Span do return Span(offset: 0, line: 0, col: 0) end

// Helper: wrap HirExprKind in HirExpr with dummy span
let se = fn (e: HirExprKind) -> HirExpr do return HirExpr(node: e, span: dummy_span()) end

// Helper: wrap HirStmtKind in HirStmt with dummy span
let ss = fn (s: HirStmtKind) -> HirStmt do return HirStmt(node: s, span: dummy_span()) end

// ─── Test 1: Basic lowering ─────────────────────────────────────────────────

let test_basic = fn () -> unit throws { Exn } do
  let body = [ss(s: Return(expr: se(e: Literal(lit: LitInt(val: 42)))))]
  let func = HirFunction(name: "main", type_params: [], params: [], ret_type: TyUnit,
    body: EagerBody(stmts: body), span: dummy_span())
  let hir = HirProgram(
    ports: [], functions: [func],
    externals: [], handler_bindings: [], enum_defs: []
  )
  let mir = lower_hir_to_mir(hir: hir)
  match mir do
    | MirProgram(functions: MirFunction(name: n, _) :: _, _) ->
      assert(cond: n == "main", msg: "basic: function name is main")
    | _ -> raise RuntimeError(val: "basic: no functions")
  end
end

// ─── Test 2: Port call resolution ───────────────────────────────────────────

let test_port_call = fn () -> unit throws { Exn } do
  // Build: port Console { print }
  let console_port = HirPort(name: "Console", methods: [HirPortMethod(name: "print")])
  // Build: handler function __handler_myHandler_print
  let handler_fn = HirFunction(
    name: "__handler_myHandler_print",
    type_params: [],
    params: [HirParam(name: "msg", label: "msg", typ: TyString)],
    ret_type: TyUnit,
    body: EagerBody(stmts: [ss(s: Return(expr: se(e: Literal(lit: LitUnit))))]),
    span: dummy_span()
  )
  // Build: main function that calls Console.print
  let main_body = [
    ss(s: Expr(expr: se(e: Call(
      func: "Console.print",
      args: [HirCallArg(label: "msg", value: se(e: Literal(lit: LitString(val: "hello"))))]
    )))),
    ss(s: Return(expr: se(e: Literal(lit: LitUnit))))
  ]
  let main_fn = HirFunction(name: "main", type_params: [], params: [], ret_type: TyUnit,
    body: EagerBody(stmts: main_body), span: dummy_span())
  let binding = HirHandlerBinding(port_name: "Console", functions: [handler_fn])
  let binding_entry = HirHandlerBindingEntry(name: "myHandler", binding: binding)
  let hir = HirProgram(
    ports: [console_port],
    functions: [main_fn, handler_fn],
    externals: [],
    handler_bindings: [binding_entry],
    enum_defs: []
  )
  let mir = lower_hir_to_mir(hir: hir)
  // Verify MIR lowered the main function.
  match mir do
    | MirProgram(functions: MirFunction(name: n, _) :: _, _) ->
      assert(cond: n == "main", msg: "port_call: expected main as first MIR function")
    | _ -> raise RuntimeError(val: "port_call: no functions")
  end
end

// ─── Test 3: Inline lambda lifted to __closure_* MIR function ────────────────

/// Find the first function whose name starts with the given prefix.
let find_func_by_prefix = fn (funcs: [MirFunction], prefix: string) -> MirFunction throws { Exn } do
  match funcs do
    | [] -> raise RuntimeError(val: "find_func_by_prefix: no match for " ++ prefix)
    | f :: rest ->
      let MirFunction(name: n, _) = f
      if str.starts_with(s: n, prefix: prefix) then return f end
      return find_func_by_prefix(funcs: rest, prefix: prefix)
  end
end

/// Extract the MirMakeClosure expression from a `let <name> = MakeClosure(...)`
/// statement, raising if it isn't shaped that way.
let expect_make_closure = fn (stmt: MirStmt, expected_name: string) -> MirExpr throws { Exn } do
  let MirStmtLet(name: ln, typ: _, expr: e) = stmt
  assert(cond: ln == expected_name,
    msg: "expect_make_closure: Let name mismatch, got " ++ ln)
  return e
end

/// Non-capturing lambda: `let f = fn (x) -> x` should produce a
/// MirMakeClosure expression and a new top-level lifted MirFunction.
let test_lambda_lifted = fn () -> unit throws { Exn } do
  let lambda = Lambda(
    type_params: [],
    params: [HirParam(name: "x", label: "x", typ: TyI64)],
    ret_type: TyI64,
    body: [ss(s: Return(expr: se(e: Variable(name: "x", sigil: SigilImmutable))))]
  )
  let main_body = [
    ss(s: Let(name: "f", typ: None, value: se(e: lambda))),
    ss(s: Return(expr: se(e: Literal(lit: LitUnit))))
  ]
  let main_fn = HirFunction(name: "main", type_params: [], params: [], ret_type: TyUnit,
    body: EagerBody(stmts: main_body), span: dummy_span())
  let hir = HirProgram(ports: [], functions: [main_fn],
    externals: [], handler_bindings: [], enum_defs: [])
  let MirProgram(functions: mir_funcs, externals: _) = lower_hir_to_mir(hir: hir)
  let MirFunction(name: mname, body: main_body2, _) = list.head(xs: mir_funcs)
  assert(cond: mname == "main", msg: "lambda: first fn must be main")
  let closure_expr = expect_make_closure(stmt: list.head(xs: main_body2), expected_name: "f")
  match closure_expr do
    | MirMakeClosure(func_name: fname, captures: []) ->
      assert(cond: str.starts_with(s: fname, prefix: "__closure_"),
        msg: "lambda: MirMakeClosure func_name must start with __closure_")
      let lifted = find_func_by_prefix(funcs: mir_funcs, prefix: "__closure_")
      match lifted do
        | MirFunction(name: ln, params: lps, ret_type: _, body: _, span: _) ->
          assert(cond: ln == fname, msg: "lambda: lifted fn name must match closure")
          match list.head(xs: lps) do
            | MirParam(label: _, name: env_name, typ: _) ->
              assert(cond: env_name == "__env", msg: "lambda: lifted fn's first param must be __env")
          end
      end
    | _ -> raise RuntimeError(val: "lambda: expected MirMakeClosure with no captures")
  end
end

/// Capturing lambda: `let y = 10; let f = fn (x) -> x + y` captures `y`.
/// Expect MirMakeClosure with one capture, and the lifted body must start with
/// `let y = MirEnvLoad("__env", 0)` so references to y resolve via env.
let test_lambda_captures = fn () -> unit throws { Exn } do
  let lambda = Lambda(
    type_params: [],
    params: [HirParam(name: "x", label: "x", typ: TyI64)],
    ret_type: TyI64,
    body: [ss(s: Return(expr: se(e: BinOp(
      left: se(e: Variable(name: "x", sigil: SigilImmutable)),
      op: OpAdd,
      right: se(e: Variable(name: "y", sigil: SigilImmutable))
    ))))]
  )
  let main_body = [
    ss(s: Let(name: "y", typ: Some(val: TyI64), value: se(e: Literal(lit: LitInt(val: 10))))),
    ss(s: Let(name: "f", typ: None, value: se(e: lambda))),
    ss(s: Return(expr: se(e: Literal(lit: LitUnit))))
  ]
  let main_fn = HirFunction(name: "main", type_params: [], params: [], ret_type: TyUnit,
    body: EagerBody(stmts: main_body), span: dummy_span())
  let hir = HirProgram(ports: [], functions: [main_fn],
    externals: [], handler_bindings: [], enum_defs: [])
  let MirProgram(functions: mir_funcs, externals: _) = lower_hir_to_mir(hir: hir)
  let MirFunction(body: main_body2, _) = list.head(xs: mir_funcs)
  // main's 2nd stmt is `let f = ...`; inspect only its MakeClosure captures.
  let closure_expr = expect_make_closure(
    stmt: list.head(xs: list.tail(xs: main_body2)),
    expected_name: "f"
  )
  match closure_expr do
    | MirMakeClosure(func_name: _, captures: MirVariable(name: cap_name) :: []) ->
      assert(cond: cap_name == "y", msg: "captures: capture must be MirVariable(y)")
    | _ -> raise RuntimeError(val: "captures: expected MirMakeClosure with one MirVariable capture")
  end
  let lifted = find_func_by_prefix(funcs: mir_funcs, prefix: "__closure_")
  let MirFunction(body: lb, _) = lifted
  match list.head(xs: lb) do
    | MirStmtLet(name: bind_name, typ: _, expr: MirEnvLoad(env_var: env, index: idx)) ->
      assert(cond: bind_name == "y", msg: "captures: lifted preamble must bind y")
      assert(cond: env == "__env", msg: "captures: env var must be __env")
      assert(cond: idx == 0, msg: "captures: index must be 0 for first capture")
    | _ -> raise RuntimeError(val: "captures: lifted body first stmt must be Let from MirEnvLoad")
  end
end

// ─── Test 4: Library-module port fallback (regression: issue #205) ─────────
// A function in an imported .nx file has the port in scope (via stdlib import)
// but no handler_binding — the caller will inject at the top-level. MIR must
// still resolve Console.println to __handler_stdio.system_handler_println so
// codegen doesn't emit an undefined-symbol reference.

let test_library_module_port_fallback = fn () -> unit throws { Exn } do
  let console_port = HirPort(name: "Console", methods: [HirPortMethod(name: "println")])
  let body = [
    ss(s: Expr(expr: se(e: Call(
      func: "Console.println",
      args: [HirCallArg(label: "val", value: se(e: Literal(lit: LitString(val: "hi"))))]
    )))),
    ss(s: Return(expr: se(e: Literal(lit: LitUnit))))
  ]
  let lib_fn = HirFunction(name: "lib_helper", type_params: [], params: [],
    ret_type: TyUnit, body: EagerBody(stmts: body), span: dummy_span())
  // Empty handler_bindings — simulates a library module with no local
  // handler in scope. The MIR hardcoded fallback must still kick in.
  let hir = HirProgram(
    ports: [console_port], functions: [lib_fn], externals: [],
    handler_bindings: [], enum_defs: []
  )
  let mir = lower_hir_to_mir(hir: hir)
  match mir do
    | MirProgram(functions: MirFunction(name: n,
           body: MirStmtExpr(expr: MirCall(func: fname, _)) :: _, _) :: _, _) ->
      assert(cond: n == "lib_helper", msg: "fallback: expected lib_helper function")
      assert(cond: fname == "__handler_stdio.system_handler_println",
        msg: "fallback: Console.println should resolve to stdio.system_handler")
    | _ -> raise RuntimeError(val: "fallback: unexpected MIR shape")
  end
end

// ─── Test 5: Call of function-typed parameter → MirCallClosure ─────────────
// Regression: nexus-mtlp — the self-hosted compiler used to emit MirCall(func:
// "f") for f(x: arg) inside a fn with parameter f, which broke codegen because
// no top-level function named "f" exists. We now detect that f is not a known
// top-level name and emit MirCallClosure(closure: MirVariable("f"), ...).

let test_param_call_to_closure = fn () -> unit throws { Exn } do
  let f_arrow = TyArrow(
    params: [NamedType(name: "x", typ: TyI64)],
    ret: TyI64,
    requires: TyRow(types: [], rest: None),
    throw_row: TyRow(types: [], rest: None)
  )
  let body = [
    ss(s: Return(expr: se(e: Call(
      func: "f",
      args: [HirCallArg(label: "x", value: se(e: Variable(name: "arg", sigil: SigilImmutable)))]
    ))))
  ]
  let apply_fn = HirFunction(
    name: "apply", type_params: [],
    params: [
      HirParam(name: "f", label: "f", typ: f_arrow),
      HirParam(name: "arg", label: "arg", typ: TyI64)
    ],
    ret_type: TyI64, body: EagerBody(stmts: body), span: dummy_span()
  )
  let hir = HirProgram(
    ports: [], functions: [apply_fn],
    externals: [], handler_bindings: [], enum_defs: []
  )
  let mir = lower_hir_to_mir(hir: hir)
  match mir do
    | MirProgram(functions: MirFunction(name: n,
           body: MirStmtReturn(expr:
             MirCallClosure(closure: MirVariable(name: vn), args: _, ret_type: _)) :: _, _) :: _, _) ->
      assert(cond: n == "apply", msg: "param_call: expected apply as first fn")
      assert(cond: vn == "f", msg: "param_call: closure must be MirVariable(\"f\")")
    | _ -> raise RuntimeError(val: "param_call: expected MirCallClosure(MirVariable(\"f\"), ...)")
  end
end

// ─── Test 6: Call of known top-level function stays MirCall ─────────────────

let test_known_function_stays_mir_call = fn () -> unit throws { Exn } do
  let helper = HirFunction(
    name: "helper", type_params: [], params: [HirParam(name: "x", label: "x", typ: TyI64)],
    ret_type: TyI64,
    body: EagerBody(stmts: [ss(s: Return(expr: se(e: Variable(name: "x", sigil: SigilImmutable))))]),
    span: dummy_span()
  )
  let main_body = [
    ss(s: Return(expr: se(e: Call(
      func: "helper",
      args: [HirCallArg(label: "x", value: se(e: Literal(lit: LitInt(val: 5))))]
    ))))
  ]
  let main_fn = HirFunction(
    name: "main", type_params: [], params: [], ret_type: TyI64,
    body: EagerBody(stmts: main_body), span: dummy_span()
  )
  let hir = HirProgram(
    ports: [], functions: [main_fn, helper],
    externals: [], handler_bindings: [], enum_defs: []
  )
  let mir = lower_hir_to_mir(hir: hir)
  match mir do
    | MirProgram(functions: MirFunction(name: n,
           body: MirStmtReturn(expr: MirCall(func: fname, _)) :: _, _) :: _, _) ->
      assert(cond: n == "main", msg: "known_fn: expected main as first fn")
      assert(cond: fname == "helper", msg: "known_fn: top-level call must stay MirCall(helper)")
    | _ -> raise RuntimeError(val: "known_fn: expected MirCall(helper, ...)")
  end
end

let main = fn () -> unit throws { Exn } do
  test_basic()
  test_port_call()
  test_lambda_lifted()
  test_lambda_captures()
  test_library_module_port_fallback()
  test_param_call_to_closure()
  test_known_function_stays_mir_call()
end
