import { Span } from "src/common/token.nx"
import { Literal, TypeExpr, Sigil, BinaryOp, EnumDef } from "src/common/ast.nx"
import { HirExprKind, HirStmtKind, HirCallArg, HirParam, HirFunction,
         HirPort, HirPortMethod, HirExternal, HirHandlerBinding,
         HirHandlerBindingEntry, HirProgram, HirMatchCase, HirPatternKind,
         HirNamedExpr, HirExpr, HirStmt, HirBody, EagerBody } from "src/ir/hir_types.nx"
import { MirProgram, MirFunction, MirExpr, MirStmt, MirMatchCase, MirPattern } from "src/ir/mir_types.nx"
import { lower_hir_to_mir } from "src/ir/mir.nx"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let dummy_span = fn () -> Span do return Span(offset: 0, line: 0, col: 0) end

// Helper: wrap HirExprKind in HirExpr with dummy span
let se = fn (e: HirExprKind) -> HirExpr do return HirExpr(node: e, span: dummy_span()) end

// Helper: wrap HirStmtKind in HirStmt with dummy span
let ss = fn (s: HirStmtKind) -> HirStmt do return HirStmt(node: s, span: dummy_span()) end

// ─── Test 1: Basic lowering ─────────────────────────────────────────────────

let test_basic = fn () -> unit throws { Exn } do
  let body = [ss(s: Return(expr: se(e: Literal(lit: LitInt(val: 42)))))]
  let func = HirFunction(name: "main", type_params: [], params: [], ret_type: TyUnit,
    body: EagerBody(stmts: body), span: dummy_span())
  let hir = HirProgram(
    ports: [], functions: [func],
    externals: [], handler_bindings: [], enum_defs: []
  )
  let mir = lower_hir_to_mir(hir: hir)
  match mir do
    case MirProgram(functions: MirFunction(name: n, _) :: _, _) ->
      assert(cond: n == "main", msg: "basic: function name is main")
    case _ -> raise RuntimeError(val: "basic: no functions")
  end
end

// ─── Test 2: Port call resolution ───────────────────────────────────────────

let test_port_call = fn () -> unit throws { Exn } do
  // Build: port Console { print }
  let console_port = HirPort(name: "Console", methods: [HirPortMethod(name: "print")])
  // Build: handler function __handler_myHandler_print
  let handler_fn = HirFunction(
    name: "__handler_myHandler_print",
    type_params: [],
    params: [HirParam(name: "msg", label: "msg", typ: TyString)],
    ret_type: TyUnit,
    body: EagerBody(stmts: [ss(s: Return(expr: se(e: Literal(lit: LitUnit))))]),
    span: dummy_span()
  )
  // Build: main function that calls Console.print
  let main_body = [
    ss(s: Expr(expr: se(e: Call(
      func: "Console.print",
      args: [HirCallArg(label: "msg", value: se(e: Literal(lit: LitString(val: "hello"))))]
    )))),
    ss(s: Return(expr: se(e: Literal(lit: LitUnit))))
  ]
  let main_fn = HirFunction(name: "main", type_params: [], params: [], ret_type: TyUnit,
    body: EagerBody(stmts: main_body), span: dummy_span())
  let binding = HirHandlerBinding(port_name: "Console", functions: [handler_fn])
  let binding_entry = HirHandlerBindingEntry(name: "myHandler", binding: binding)
  let hir = HirProgram(
    ports: [console_port],
    functions: [main_fn, handler_fn],
    externals: [],
    handler_bindings: [binding_entry],
    enum_defs: []
  )
  let mir = lower_hir_to_mir(hir: hir)
  // Verify MIR lowered the main function.
  match mir do
    case MirProgram(functions: MirFunction(name: n, _) :: _, _) ->
      assert(cond: n == "main", msg: "port_call: expected main as first MIR function")
    case _ -> raise RuntimeError(val: "port_call: no functions")
  end
end

// ─── Test 3: Lambda lowered to unit ─────────────────────────────────────────

let test_lambda_unit = fn () -> unit throws { Exn } do
  // Build: let f = fn (x) -> x end (lambda should be lowered to Unit in MIR)
  let lambda = Lambda(
    type_params: [],
    params: [HirParam(name: "x", label: "x", typ: TyI64)],
    ret_type: TyI64,
    body: [ss(s: Return(expr: se(e: Variable(name: "x", sigil: SigilImmutable))))]
  )
  let main_body = [
    ss(s: Let(name: "f", typ: None, value: se(e: lambda))),
    ss(s: Return(expr: se(e: Literal(lit: LitUnit))))
  ]
  let main_fn = HirFunction(name: "main", type_params: [], params: [], ret_type: TyUnit,
    body: EagerBody(stmts: main_body), span: dummy_span())
  let hir = HirProgram(
    ports: [], functions: [main_fn],
    externals: [], handler_bindings: [], enum_defs: []
  )
  let mir = lower_hir_to_mir(hir: hir)
  match mir do
    case MirProgram(functions: MirFunction(body: MirStmtLet(name: n, expr: MirLiteral(lit: LitUnit), _) :: _, _) :: _, _) ->
      assert(cond: n == "f", msg: "lambda: expected let f = Unit as first stmt")
    case _ -> raise RuntimeError(val: "lambda: expected first fn body to start with `let f = Unit`")
  end
end

// ─── Test 4: Library-module port fallback (regression: issue #205) ─────────
// A function in an imported .nx file has the port in scope (via stdlib import)
// but no handler_binding — the caller will inject at the top-level. MIR must
// still resolve Console.println to __handler_stdio.system_handler_println so
// codegen doesn't emit an undefined-symbol reference.

let test_library_module_port_fallback = fn () -> unit throws { Exn } do
  let console_port = HirPort(name: "Console", methods: [HirPortMethod(name: "println")])
  let body = [
    ss(s: Expr(expr: se(e: Call(
      func: "Console.println",
      args: [HirCallArg(label: "val", value: se(e: Literal(lit: LitString(val: "hi"))))]
    )))),
    ss(s: Return(expr: se(e: Literal(lit: LitUnit))))
  ]
  let lib_fn = HirFunction(name: "lib_helper", type_params: [], params: [],
    ret_type: TyUnit, body: EagerBody(stmts: body), span: dummy_span())
  // Empty handler_bindings — simulates a library module with no local
  // handler in scope. The MIR hardcoded fallback must still kick in.
  let hir = HirProgram(
    ports: [console_port], functions: [lib_fn], externals: [],
    handler_bindings: [], enum_defs: []
  )
  let mir = lower_hir_to_mir(hir: hir)
  match mir do
    case MirProgram(functions: MirFunction(name: n,
           body: MirStmtExpr(expr: MirCall(func: fname, _)) :: _, _) :: _, _) ->
      assert(cond: n == "lib_helper", msg: "fallback: expected lib_helper function")
      assert(cond: fname == "__handler_stdio.system_handler_println",
        msg: "fallback: Console.println should resolve to stdio.system_handler")
    case _ -> raise RuntimeError(val: "fallback: unexpected MIR shape")
  end
end

let main = fn () -> unit throws { Exn } do
  test_basic()
  test_port_call()
  test_lambda_unit()
  test_library_module_port_fallback()
end
