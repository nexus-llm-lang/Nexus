import { LirProgram, LirFunction, LirStmt, LirExpr, LirAtom, LirParam,
         LirExternal, LirCallArg, LirNamedAtom } from "src/ir/lir_types.nx"
import { compile_lir_to_wasm } from "src/backend/codegen.nx"
import { ByteBuffer, empty, length, get_byte, free, write_file, push_byte } from "stdlib/bytebuffer.nx"
import { BinaryOp } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"

// Test 1: Empty main compiles to valid WASM
let test_empty_main = fn () -> unit require { PermFs } throws { Exn } do
  let sp = Span(offset: 0, line: 0, col: 0)
  let func = LirFunction(
    name: "main", params: [], ret_type: TyUnit,
    body: [], ret: LirAtomUnit, span: sp
  )
  let prog = LirProgram(functions: func :: [], externals: [])
  let %wasm = compile_lir_to_wasm(program: prog, string_data_base: 0)
  let ok = write_file(buf: &wasm, path: "/nxc_test_empty.wasm")
  free(buf: %wasm)
  if ok == false then raise RuntimeError(val: "failed to write empty.wasm") end
  return ()
end

// Test 2: Main with i64 return (let x = 42; return x)
let test_i64_return = fn () -> unit require { PermFs } throws { Exn } do
  let sp = Span(offset: 0, line: 0, col: 0)
  let body = LirStmtLet(
      name: "x", typ: TyI64,
      expr: LirExprAtom(atom: LirAtomInt(val: 42))
    ) :: []
  let func = LirFunction(
    name: "main", params: [], ret_type: TyI64,
    body: body, ret: LirAtomVar(name: "x", typ: TyI64), span: sp
  )
  let prog = LirProgram(functions: func :: [], externals: [])
  let %wasm = compile_lir_to_wasm(program: prog, string_data_base: 0)
  let ok = write_file(buf: &wasm, path: "/nxc_test_i64.wasm")
  free(buf: %wasm)
  if ok == false then raise RuntimeError(val: "failed to write i64.wasm") end
  return ()
end

// Test 3: Two functions with call (helper returns 7, main calls helper)
let test_function_call = fn () -> unit require { PermFs } throws { Exn } do
  let sp = Span(offset: 0, line: 0, col: 0)
  let helper = LirFunction(
    name: "helper", params: [], ret_type: TyI64,
    body: [], ret: LirAtomInt(val: 7), span: sp
  )
  let main_body = LirStmtLet(
      name: "result", typ: TyI64,
      expr: LirExprCall(func: "helper", args: [], typ: TyI64)
    ) :: []
  let main_fn = LirFunction(
    name: "main", params: [], ret_type: TyI64,
    body: main_body, ret: LirAtomVar(name: "result", typ: TyI64), span: sp
  )
  let funcs = helper :: main_fn :: []
  let prog = LirProgram(functions: funcs, externals: [])
  let %wasm = compile_lir_to_wasm(program: prog, string_data_base: 0)
  let ok = write_file(buf: &wasm, path: "/nxc_test_call.wasm")
  free(buf: %wasm)
  if ok == false then raise RuntimeError(val: "failed to write call.wasm") end
  return ()
end

// Test 4: Arithmetic (let x = 3 + 4; return x)
let test_arithmetic = fn () -> unit require { PermFs } throws { Exn } do
  let sp = Span(offset: 0, line: 0, col: 0)
  let body = LirStmtLet(
      name: "x", typ: TyI64,
      expr: LirExprBinary(op: OpAdd, lhs: LirAtomInt(val: 3), rhs: LirAtomInt(val: 4), typ: TyI64)
    ) :: []
  let func = LirFunction(
    name: "main", params: [], ret_type: TyI64,
    body: body, ret: LirAtomVar(name: "x", typ: TyI64), span: sp
  )
  let prog = LirProgram(functions: func :: [], externals: [])
  let %wasm = compile_lir_to_wasm(program: prog, string_data_base: 0)
  let ok = write_file(buf: &wasm, path: "/nxc_test_arith.wasm")
  free(buf: %wasm)
  if ok == false then raise RuntimeError(val: "failed to write arith.wasm") end
  return ()
end

// Test 5: If statement (if true then let x = 1 else let x = 2; return 0)
let test_if_stmt = fn () -> unit require { PermFs } throws { Exn } do
  let sp = Span(offset: 0, line: 0, col: 0)
  let then_body = LirStmtLet(name: "x", typ: TyI64, expr: LirExprAtom(atom: LirAtomInt(val: 1))) :: []
  let else_body = LirStmtLet(name: "x", typ: TyI64, expr: LirExprAtom(atom: LirAtomInt(val: 2))) :: []
  let body = LirStmtIf(cond: LirAtomBool(val: true), then_body: then_body, else_body: else_body) :: []
  let func = LirFunction(
    name: "main", params: [], ret_type: TyUnit,
    body: body, ret: LirAtomUnit, span: sp
  )
  let prog = LirProgram(functions: func :: [], externals: [])
  let %wasm = compile_lir_to_wasm(program: prog, string_data_base: 0)
  let ok = write_file(buf: &wasm, path: "/nxc_test_if.wasm")
  free(buf: %wasm)
  if ok == false then raise RuntimeError(val: "failed to write if.wasm") end
  return ()
end

// Test 6: f64 literal (let x = 3.14; return x)
let test_f64_literal = fn () -> unit require { PermFs } throws { Exn } do
  let sp = Span(offset: 0, line: 0, col: 0)
  let body = LirStmtLet(
      name: "x", typ: TyF64,
      expr: LirExprAtom(atom: LirAtomFloat(val: "3.14"))
    ) :: []
  let func = LirFunction(
    name: "main", params: [], ret_type: TyF64,
    body: body, ret: LirAtomVar(name: "x", typ: TyF64), span: sp
  )
  let prog = LirProgram(functions: func :: [], externals: [])
  let %wasm = compile_lir_to_wasm(program: prog, string_data_base: 0)
  let ok = write_file(buf: &wasm, path: "/nxc_test_f64.wasm")
  free(buf: %wasm)
  if ok == false then raise RuntimeError(val: "failed to write f64.wasm") end
  return ()
end

let main = fn () -> unit require { PermFs } throws { Exn } do
  test_empty_main()
  test_i64_return()
  test_function_call()
  test_arithmetic()
  test_if_stmt()
  test_f64_literal()
  return ()
end
