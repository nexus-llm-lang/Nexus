import { Console }, * as stdio from "std:stdio"
import { Sched }, * as sched from "std:sched"
import { ChanPair, Tx, Rx }, * as chan from "std:chan"
import { from_i64 } from "std:string_ops"

let consumer = fn (rx: %Rx<i64>) -> i64 require { Sched, PermConsole } do
  Sched.yield()
  let v = chan.recv(rx: %rx)
  Console.println(val: from_i64(val: v))
  return 0
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    inject sched.scheduler do
      let ChanPair(tx: %tx, rx: %rx) = chan.oneshot()
      chan.send(tx: %tx, val: 42)
      let @t_c = consumer(rx: %rx)
      Sched.spawn(thunk: t_c)
      Sched.yield()
    end
  end
end
