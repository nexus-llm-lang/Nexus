import { Console }, * as stdio from "std:stdio"
import { Sched }, * as sched from "std:sched"

let fiber1 = fn () -> i64 require { PermConsole, Sched } do
  Console.println(val: "f1.a")
  Sched.yield()
  Console.println(val: "f1.b")
  Sched.yield()
  Console.println(val: "f1.c")
  return 0
end

let fiber2 = fn () -> i64 require { PermConsole, Sched } do
  Console.println(val: "f2.a")
  Sched.yield()
  Console.println(val: "f2.b")
  Sched.yield()
  Console.println(val: "f2.c")
  return 0
end

let fiber3 = fn () -> i64 require { PermConsole, Sched } do
  Console.println(val: "f3.a")
  Sched.yield()
  Console.println(val: "f3.b")
  Sched.yield()
  Console.println(val: "f3.c")
  return 0
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    inject sched.scheduler do
      let @t1 = fiber1()
      let @t2 = fiber2()
      let @t3 = fiber3()
      Sched.spawn(thunk: t1)
      Sched.spawn(thunk: t2)
      Sched.spawn(thunk: t3)
      Sched.yield()
    end
  end
end
