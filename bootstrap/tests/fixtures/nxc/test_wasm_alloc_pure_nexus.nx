/**
 * test_wasm_alloc_pure_nexus: covers nexus-dvr6.9.2 — pure-Nexus
 * `nxlib/stdlib/wasm_alloc.nx` allocator.
 *
 * The fixture prints one line per acceptance assertion (alignment,
 * grow trigger, mark/reset round-trip, multi-iter RSS bounded).  Each
 * line is a literal expected token so the harness can assert the full
 * interleave (line count + content), catching both value drift and
 * silently dropped intrinsic dispatch.
 */

import { Console }, * as stdio from "std:stdio"
import * as alloc from "std:wasm_alloc"
import * as mem from "std:runtime_mem"
import { from_i64 } from "std:str"

/// (1) Two consecutive `allocate` calls return distinct, 16-byte-aligned
/// addresses with the second strictly greater than the first by at least
/// the requested aligned size.
let case_alignment = fn () -> unit throws { Exn } do
  let p1 = alloc.allocate(size: 24)
  let p2 = alloc.allocate(size: 24)
  let aligned_24 = 32  // align_up(24) under 16-byte alignment
  if p2 - p1 == aligned_24 then
    Console.println(val: "ok-align")
  else
    Console.println(val: "fail-align")
  end
  return ()
end

/// (2) An allocation larger than the remaining headroom forces
/// `memory.grow`.  We drain a known number of bytes, then request a
/// page-and-a-bit so the grow path is exercised regardless of where
/// the allocator started.
let case_grow_trigger = fn () -> unit throws { Exn } do
  let pages_before = mem.size()
  let _ = alloc.allocate(size: 65520)  // ~one page of allocations
  let _ = alloc.allocate(size: 70000)  // forces grow
  let pages_after = mem.size()
  if pages_after > pages_before then
    Console.println(val: "ok-grow")
  else
    Console.println(val: "fail-grow")
  end
  return ()
end

/// (3) Mark, allocate a few buffers, reset.  Post-reset bump pointer
/// MUST equal the saved mark.  Without reset the post-mark bump would
/// be strictly greater.
let case_mark_reset = fn () -> unit throws { Exn } do
  let m0 = alloc.mark()
  let _ = alloc.allocate(size: 100)
  let _ = alloc.allocate(size: 200)
  let _ = alloc.allocate(size: 300)
  alloc.reset(m: m0)
  let m1 = alloc.mark()
  if m1 == m0 then
    Console.println(val: "ok-reset")
  else
    Console.println(val: "fail-reset")
  end
  return ()
end

/// (4) Multi-iteration: 1000 alloc+reset round-trips MUST keep the
/// bump pointer (and therefore RSS) bounded.  Drives the same shape
/// as the gv2u arena workloads — without `reset` this loop would grow
/// the bump pointer linearly.
let multi_iter_go = fn (i: i64, n: i64) -> unit throws { Exn } do
  if i >= n then return () end
  let m = alloc.mark()
  let _ = alloc.allocate(size: 64)
  let _ = alloc.allocate(size: 128)
  let _ = alloc.allocate(size: 256)
  alloc.reset(m)
  return multi_iter_go(i: i + 1, n)
end

let case_multi_iter_bounded = fn () -> unit throws { Exn } do
  let m_pre = alloc.mark()
  let _ = multi_iter_go(i: 0, n: 1000)
  let m_post = alloc.mark()
  if m_pre == m_post then
    Console.println(val: "ok-bounded")
  else
    Console.println(val: "fail-bounded")
  end
  return ()
end

/// (5) read_string round-trip with store_string_result.  Allocate a
/// buffer, write the bytes of "hello", read them back, compare via
/// the Nexus string-equality byte-length check.
let case_string_roundtrip = fn () -> unit throws { Exn } do
  let packed = alloc.store_string_result(s: "hello")
  let ptr = (packed / 4294967296) & 4294967295
  let len = packed & 4294967295
  let s = alloc.read_string(ptr, len)
  if s == "hello" then
    Console.println(val: "ok-string")
  else
    Console.println(val: "fail-string")
  end
  return ()
end

let main = fn () -> unit require { PermConsole } throws { Exn } do
  inject stdio.system_handler do
    let _ = case_alignment()
    let _ = case_grow_trigger()
    let _ = case_mark_reset()
    let _ = case_multi_iter_bounded()
    let _ = case_string_roundtrip()
  end
  return ()
end
