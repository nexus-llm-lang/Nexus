/**
 * test_math_pure_nexus_integer_ops: covers nexus-dvr6.9.4 — verifies
 * abs/max/min/mod_i64 are implemented in pure Nexus (no `std:math` host
 * call) and behave per spec.
 *
 * mod_i64 raises RuntimeError on division by zero (memory
 * `feedback_partial_functions_raise`); the Rust impl returned i64::MIN
 * as a sentinel which silently corrupts callers.
 */
import * as math from "std:math"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then
    return ()
  else
    raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  // abs: positive, negative, zero
  assert(cond: math.abs(val: 7) == 7, msg: "abs 7")
  assert(cond: math.abs(val: -7) == 7, msg: "abs -7")
  assert(cond: math.abs(val: 0) == 0, msg: "abs 0")

  // max / min
  assert(cond: math.max(a: 3, b: 5) == 5, msg: "max 3 5")
  assert(cond: math.max(a: 5, b: 3) == 5, msg: "max 5 3")
  assert(cond: math.max(a: -3, b: -5) == -3, msg: "max -3 -5")
  assert(cond: math.min(a: 3, b: 5) == 3, msg: "min 3 5")
  assert(cond: math.min(a: 5, b: 3) == 3, msg: "min 5 3")
  assert(cond: math.min(a: -3, b: -5) == -5, msg: "min -3 -5")

  // mod_i64
  assert(cond: math.mod_i64(a: 10, b: 3) == 1, msg: "10 mod 3")
  assert(cond: math.mod_i64(a: 10, b: 5) == 0, msg: "10 mod 5")
  assert(cond: math.mod_i64(a: -10, b: 3) == -1, msg: "-10 mod 3")

  // mod_i64 by zero raises (specific Exn, not silent sentinel)
  try
    let _ = math.mod_i64(a: 10, b: 0)
    raise RuntimeError(val: "mod_i64 by 0 returned without raising")
  catch
    | RuntimeError(val: msg) ->
      // The specific contract: the message must come from mod_i64, not the
      // post-call assertion-fail above.
      assert(cond: msg == "mod_i64: division by zero", msg: "wrong RuntimeError msg: " ++ msg)
  end

  // Float unary ops route through runtime_math intrinsics
  let s = math.sqrt(val: 9.0)
  assert(cond: math.float_to_i64(val: s) == 3, msg: "sqrt 9 == 3")
  let f = math.floor(val: 2.7)
  assert(cond: math.float_to_i64(val: f) == 2, msg: "floor 2.7 == 2")
  let c = math.ceil(val: 2.3)
  assert(cond: math.float_to_i64(val: c) == 3, msg: "ceil 2.3 == 3")
  let a = math.abs_float(val: -.4.0)
  assert(cond: math.float_to_i64(val: a) == 4, msg: "abs -4.0 == 4")

  return ()
end
