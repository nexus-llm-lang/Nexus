import { Token, Span, SpannedToken, keyword_lookup } from "src/common/token.nx"
import { tokenize } from "src/frontend/lexer.nx"
import * as str from "std:string_ops"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let assert_eq = fn (a: i64, b: i64, msg: string) -> unit throws { Exn } do
  if a == b then return ()
  else raise RuntimeError(val: msg ++ ": expected " ++ str.from_i64(val: b) ++ " got " ++ str.from_i64(val: a))
  end
end

let main = fn () -> unit throws { Exn } do
  let tokens = tokenize(src: "=")
  return ()
end
