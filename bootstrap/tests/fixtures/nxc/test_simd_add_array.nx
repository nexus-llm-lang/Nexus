/**
 * test_simd_add_array: covers nexus-s60w — wires `i64x2_add_array` and
 * `f64x2_add_array` autovectorized intrinsics into codegen.
 *
 * Strategy parallels `test_simd_lane_op_coverage.nx`:
 *   - Reserve a fresh wasm page so SIMD load/store cannot collide with
 *     compiler globals or arena allocations.
 *   - For `i64x2_add_array`, run the SIMD intrinsic and a hand-written
 *     scalar reference loop over the same input region into disjoint
 *     output regions, then byte-compare the two outputs. A 64-byte
 *     agreement count means every i64 element matched exactly.
 *   - For `f64x2_add_array`, run the SIMD intrinsic twice on identical
 *     inputs (into disjoint output regions) and assert the two outputs
 *     are bitwise identical (determinism gate — no scalar f64 reference
 *     exists at this layer).
 *
 * Bytecode-side acceptance lives in the Rust harness
 * (`bootstrap/tests/nxc/codegen.rs`); it scans the compiled wasm bytes
 * for i64x2.add (sub 0xCE) and f64x2.add (sub 0xF0).
 */

import { Console }, * as stdio from "std:stdio"
import * as mem from "std:runtime/mem"
import * as simd from "std:simd"
import { from_i64 } from "std:str"

// Compare two memory regions byte-for-byte; return the number of equal bytes.
let cmp_bytes = fn (a: i64, b: i64, n: i64) -> i64 do
  return cmp_bytes_go(a, b, n, idx: 0, eq: 0)
end

let cmp_bytes_go = fn (a: i64, b: i64, n: i64, idx: i64, eq: i64) -> i64 do
  if idx >= n then return eq end
  let av = mem.load_u8(addr: a + idx)
  let bv = mem.load_u8(addr: b + idx)
  let inc = if av == bv then 1 else 0 end
  return cmp_bytes_go(a, b, n, idx: idx + 1, eq: eq + inc)
end

// Initialise an i64 array of length n with values 1..=n.
let init_i64_seq = fn (base: i64, n: i64) -> unit do
  return init_i64_seq_go(base, n, idx: 0)
end

let init_i64_seq_go = fn (base: i64, n: i64, idx: i64) -> unit do
  if idx >= n then return () end
  let _ = mem.store_i64(addr: base + idx * 8, val: idx + 1)
  return init_i64_seq_go(base, n, idx: idx + 1)
end

// Zero an n-byte region (n must be a multiple of 8).
let zero_region = fn (base: i64, n: i64) -> unit do
  return zero_region_go(base, n, idx: 0)
end

let zero_region_go = fn (base: i64, n: i64, idx: i64) -> unit do
  if idx >= n then return () end
  let _ = mem.store_i64(addr: base + idx, val: 0)
  return zero_region_go(base, n, idx: idx + 8)
end

// Scalar reference: dst[i] = a[i] + b[i] for `count` i64 elements.
let scalar_i64_add_ref = fn (a: i64, b: i64, d: i64, count: i64) -> unit do
  if count <= 0 then return () end
  let av = mem.load_i64(addr: a)
  let bv = mem.load_i64(addr: b)
  let _ = mem.store_i64(addr: d, val: av + bv)
  return scalar_i64_add_ref(a: a + 8, b: b + 8, d: d + 8, count: count - 1)
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let prev_pages = mem.grow(delta: 1)
    let base = prev_pages * 65536

    // Region layout (each region is 64 bytes, 8 i64 elements / 4 quads):
    //   a:    base + 0     // input 1
    //   b:    base + 64    // input 2
    //   simd: base + 128   // SIMD-path output
    //   scal: base + 192   // scalar-path output (or second SIMD pass for floats)
    let a_addr = base
    let b_addr = base + 64
    let simd_addr = base + 128
    let scal_addr = base + 192
    let n_quads = 4

    // i64x2_add_array vs scalar reference -----------------------------------
    init_i64_seq(base: a_addr, n: 8)
    // b: 100 + index, ensures non-trivial sums.
    let _ = mem.store_i64(addr: b_addr, val: 101)
    let _ = mem.store_i64(addr: b_addr + 8, val: 102)
    let _ = mem.store_i64(addr: b_addr + 16, val: 103)
    let _ = mem.store_i64(addr: b_addr + 24, val: 104)
    let _ = mem.store_i64(addr: b_addr + 32, val: 105)
    let _ = mem.store_i64(addr: b_addr + 40, val: 106)
    let _ = mem.store_i64(addr: b_addr + 48, val: 107)
    let _ = mem.store_i64(addr: b_addr + 56, val: 108)
    zero_region(base: simd_addr, n: 64)
    zero_region(base: scal_addr, n: 64)
    let _ = simd.i64x2_add_array(a_addr, b_addr, dst_addr: simd_addr, n_quads)
    scalar_i64_add_ref(a: a_addr, b: b_addr, d: scal_addr, count: 8)
    Console.println(val: from_i64(val: cmp_bytes(a: simd_addr, b: scal_addr, n: 64))) // 64

    // f64x2_add_array determinism -------------------------------------------
    // No scalar f64 reference at this layer (no f64-arith primitive over
    // mem ops), so run the SIMD intrinsic twice on identical inputs and
    // require bitwise agreement — drift would mean the lane-op is
    // non-deterministic or mis-encoded. Inputs reused as f64 lanes.
    init_i64_seq(base: a_addr, n: 8)
    init_i64_seq(base: b_addr, n: 8)
    zero_region(base: simd_addr, n: 64)
    zero_region(base: scal_addr, n: 64)
    let _ = simd.f64x2_add_array(a_addr, b_addr, dst_addr: simd_addr, n_quads)
    let _ = simd.f64x2_add_array(a_addr, b_addr, dst_addr: scal_addr, n_quads)
    Console.println(val: from_i64(val: cmp_bytes(a: simd_addr, b: scal_addr, n: 64))) // 64
  end
end
