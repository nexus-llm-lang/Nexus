/**
 * test_lazy_threaded_alloc: end-to-end test that worker thunks share the
 * caller's heap via the host-side atomic bump allocator (nexus-hqjy /
 * nexus-tb6p slice 3).
 *
 * Each thunk body constructs and destructures a `Pair` — a heap allocation
 * that under sufficient threading races without slice 3 (each worker
 * instance has its own per-instance heap-pointer global initialized to
 * heap_base, so two workers' first allocations would land at the same
 * address in shared memory and corrupt each other). With slice 3, all
 * allocations route through the runtime-provided `nexus:runtime/lazy::alloc`
 * function, which atomically advances a single host-side AtomicI32 shared
 * across caller and every worker.
 *
 * The LIR optimizer's scalar-replace-aggregates pass may eliminate
 * trivial constructor allocations like the Pair below; even when SRA
 * fires the test still exercises the plumbing because the *closures*
 * for @z and @w are allocated by main itself and now route through the
 * same __nx_alloc. Either way the assertion proves end-to-end correctness.
 *
 * Self-asserts via i64.div_s trap-on-mismatch.
 */

type Pair = Pair(a: i64, b: i64)

let main = fn () -> unit do
  let y = 11
  let @z = match Pair(a: y, b: y + 1) do
    | Pair(a: a, b: b) -> a + b
  end
  let @w = match Pair(a: y + 11, b: y + 12) do
    | Pair(a: a, b: b) -> a + b
  end
  let v1 = @z
  let v2 = @w
  let sum = v1 + v2
  let divisor = if sum == 68 then 1 else 0 end
  let _ = 1 / divisor
  return ()
end
