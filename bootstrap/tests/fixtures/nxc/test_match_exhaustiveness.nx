// Tests for src/typecheck/exhaustive: top-column match exhaustiveness
// (nexus-mqin.3). Drives check_match_exhaustive directly to avoid the
// constructor-registration plumbing that infer_expr relies on.

import {
  TypeExpr, TyBool, TyI64, TyList, TyLinear, TyUserDefined,
  EnumDef, VariantDef, VariantField,
  LitBool, LitInt
} from "src/common/ast.nx"
import {
  HirMatchCase, HirPatternKind, HirPatternField, HirStmt, HirExpr, Literal, Expr,
  PWild, PCtor, PLit, PVar
} from "src/ir/hir_types.nx"
import { Span } from "src/common/token.nx"
import { EnumEntry } from "src/typecheck/types.nx"
import {
  ExhaustiveResult, Exhaustive, NonExhaustive, check_match_exhaustive
} from "src/typecheck/exhaustive.nx"
import { SigilImmutable } from "src/common/ast.nx"
import { Some, None } from "std:option"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let is_exhaustive = fn (r: ExhaustiveResult) -> bool do
  match r do
    | Exhaustive -> return true
    | NonExhaustive(_) -> return false
  end
end

let is_non_exhaustive = fn (r: ExhaustiveResult) -> bool do
  match r do
    | Exhaustive -> return false
    | NonExhaustive(_) -> return true
  end
end

let main = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)
  let body_unit = [HirStmt(node: Expr(expr: HirExpr(node: Literal(lit: LitInt(val: 0)), span: sp)), span: sp)]

  // Color enum: three nullary variants. enum_defs is the only thing
  // exhaustive needs — the env is irrelevant to the structural check.
  let color_def = EnumDef(
    name: "Color",
    is_public: true,
    is_opaque: false,
    type_params: [],
    variants: [
      VariantDef(name: "Red", fields: []),
      VariantDef(name: "Green", fields: []),
      VariantDef(name: "Blue", fields: [])
    ]
  )
  let enums = [EnumEntry(name: "Color", def: color_def)]
  let color_ty = TyUserDefined(name: "Color", args: [])

  // Test 1: all three variants covered → Exhaustive.
  let cases1 = [
    HirMatchCase(pattern: PCtor(variant: "Red", fields: []), body: body_unit),
    HirMatchCase(pattern: PCtor(variant: "Green", fields: []), body: body_unit),
    HirMatchCase(pattern: PCtor(variant: "Blue", fields: []), body: body_unit)
  ]
  assert(
    cond: is_exhaustive(r: check_match_exhaustive(cases: cases1, scrutinee_type: color_ty, enum_defs: enums)),
    msg: "Red+Green+Blue is exhaustive over Color"
  )

  // Test 2: Blue elided → NonExhaustive.
  let cases2 = [
    HirMatchCase(pattern: PCtor(variant: "Red", fields: []), body: body_unit),
    HirMatchCase(pattern: PCtor(variant: "Green", fields: []), body: body_unit)
  ]
  assert(
    cond: is_non_exhaustive(r: check_match_exhaustive(cases: cases2, scrutinee_type: color_ty, enum_defs: enums)),
    msg: "Color missing Blue is non-exhaustive"
  )

  // Test 3: wildcard alone is exhaustive over any type.
  let cases3 = [HirMatchCase(pattern: PWild, body: body_unit)]
  assert(
    cond: is_exhaustive(r: check_match_exhaustive(cases: cases3, scrutinee_type: color_ty, enum_defs: enums)),
    msg: "wildcard alone is exhaustive over Color"
  )

  // Test 4: variable pattern alone is also exhaustive (binds the scrutinee).
  let cases4 = [HirMatchCase(pattern: PVar(name: "c", sigil: SigilImmutable), body: body_unit)]
  assert(
    cond: is_exhaustive(r: check_match_exhaustive(cases: cases4, scrutinee_type: color_ty, enum_defs: enums)),
    msg: "variable pattern alone is exhaustive over Color"
  )

  // Test 5: bool — `true` only → non-exhaustive.
  let cases5 = [HirMatchCase(pattern: PLit(lit: LitBool(val: true)), body: body_unit)]
  assert(
    cond: is_non_exhaustive(r: check_match_exhaustive(cases: cases5, scrutinee_type: TyBool, enum_defs: enums)),
    msg: "bool with only true is non-exhaustive"
  )

  // Test 6: bool — true + false → exhaustive.
  let cases6 = [
    HirMatchCase(pattern: PLit(lit: LitBool(val: true)), body: body_unit),
    HirMatchCase(pattern: PLit(lit: LitBool(val: false)), body: body_unit)
  ]
  assert(
    cond: is_exhaustive(r: check_match_exhaustive(cases: cases6, scrutinee_type: TyBool, enum_defs: enums)),
    msg: "bool true+false is exhaustive"
  )

  // Test 7: list — Nil + Cons → exhaustive (TyList path with built-in
  // Nil/Cons constructor names).
  let list_ty = TyList(elem: TyI64)
  let cases7 = [
    HirMatchCase(pattern: PCtor(variant: "Nil", fields: []), body: body_unit),
    HirMatchCase(pattern: PCtor(variant: "Cons", fields: [
      HirPatternField(name: None, pattern: PWild),
      HirPatternField(name: None, pattern: PWild)
    ]), body: body_unit)
  ]
  assert(
    cond: is_exhaustive(r: check_match_exhaustive(cases: cases7, scrutinee_type: list_ty, enum_defs: enums)),
    msg: "list Nil + Cons is exhaustive"
  )

  // Test 8: list — only Nil → non-exhaustive.
  let cases8 = [HirMatchCase(pattern: PCtor(variant: "Nil", fields: []), body: body_unit)]
  assert(
    cond: is_non_exhaustive(r: check_match_exhaustive(cases: cases8, scrutinee_type: list_ty, enum_defs: enums)),
    msg: "list with only Nil is non-exhaustive"
  )

  // Test 9: modality stripping — match on %Color stripped to Color, same
  // exhaustiveness behaviour.
  let lin_color = TyLinear(inner: color_ty)
  assert(
    cond: is_non_exhaustive(r: check_match_exhaustive(cases: cases2, scrutinee_type: lin_color, enum_defs: enums)),
    msg: "%Color missing Blue is still non-exhaustive"
  )

  // Test 10: numeric type with wildcard → exhaustive.
  let cases10 = [HirMatchCase(pattern: PWild, body: body_unit)]
  assert(
    cond: is_exhaustive(r: check_match_exhaustive(cases: cases10, scrutinee_type: TyI64, enum_defs: enums)),
    msg: "i64 with wildcard is exhaustive"
  )

  // Test 11: numeric type with only literal → non-exhaustive.
  let cases11 = [HirMatchCase(pattern: PLit(lit: LitInt(val: 0)), body: body_unit)]
  assert(
    cond: is_non_exhaustive(r: check_match_exhaustive(cases: cases11, scrutinee_type: TyI64, enum_defs: enums)),
    msg: "i64 with only 0 is non-exhaustive"
  )

  return ()
end
