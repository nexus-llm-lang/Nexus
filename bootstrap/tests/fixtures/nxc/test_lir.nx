import { Span } from "src/common/token.nx"
import { Literal, TypeExpr, Sigil, BinaryOp, EnumDef } from "src/common/ast.nx"
import { HirExprKind, HirStmtKind, HirCallArg, HirParam, HirFunction,
         HirPort, HirPortMethod, HirExternal, HirHandlerBinding,
         HirHandlerBindingEntry, HirProgram,
         HirNamedExpr, HirExpr, HirStmt,
         HirBody, EagerBody, LazyBody } from "src/ir/hir_types.nx"
import { MirProgram, MirFunction, MirExpr, MirStmt, MirParam, MirExternal,
         MirCallArg, MirMatchCase, MirPattern } from "src/ir/mir_types.nx"
import { lower_hir_to_mir } from "src/ir/mir.nx"
import { LirProgram, LirFunction, LirStmt, LirExpr, LirAtom, LirCallArg } from "src/ir/lir_types.nx"
import { lower_mir_to_lir } from "src/ir/lir.nx"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let dummy_span = fn () -> Span do return Span(offset: 0, line: 0, col: 0) end

// Helper: wrap HirExprKind in HirExpr with dummy span
let se = fn (e: HirExprKind) -> HirExpr do return HirExpr(node: e, span: dummy_span()) end

// Helper: wrap HirStmtKind in HirStmt with dummy span
let ss = fn (s: HirStmtKind) -> HirStmt do return HirStmt(node: s, span: dummy_span()) end

// ─── Test 1: Basic function lowering ─────────────────────────────────────────

let test_basic = fn () -> unit throws { Exn } do
  // Build a simple MIR function: main() -> return 42
  let body = MirStmtReturn(expr: MirLiteral(lit: LitInt(val: 42))) :: []
  let func = MirFunction(
    name: "main",
    params: [],
    ret_type: TyUnit,
    body: body,
    span: dummy_span()
  )
  let mir = MirProgram(functions: func :: [], externals: [])
  let lir = lower_mir_to_lir(mir: mir, enum_defs: [])
  match lir do | LirProgram(functions: fs, externals: _) ->
    match fs do
      | f :: _ ->
        match f do | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) ->
          assert(cond: n == "main", msg: "basic: function name is main")
        end
      | [] -> raise RuntimeError(val: "basic: no functions")
    end
  end
end

// ─── Test 2: Let binding ANF ─────────────────────────────────────────────────

let test_let_binding = fn () -> unit throws { Exn } do
  // let x = 1 + 2; return x
  let body = MirStmtLet(name: "x", typ: TyI64,
      expr: MirBinaryOp(left: MirLiteral(lit: LitInt(val: 1)), op: OpAdd,
                         right: MirLiteral(lit: LitInt(val: 2))))
    :: MirStmtReturn(expr: MirVariable(name: "x"))
    :: []
  let func = MirFunction(name: "test", params: [], ret_type: TyI64, body: body, span: dummy_span())
  let mir = MirProgram(functions: func :: [], externals: [])
  let lir = lower_mir_to_lir(mir: mir, enum_defs: [])
  match lir do | LirProgram(functions: fs, externals: _) ->
    match fs do
      | f :: _ ->
        match f do | LirFunction(name: _, params: _, ret_type: _, body: stmts, ret: _, span: _) ->
          // Body should have: let __t0 = 1 + 2, let x = __t0
          match stmts do
            | s1 :: _ ->
              match s1 do
                | LirStmtLet(name: _, typ: _, expr: e) ->
                  match e do
                    | LirExprBinary(_) ->
                      assert(cond: true, msg: "let_binding: binary expr found")
                    | _ -> assert(cond: true, msg: "let_binding: some expr found")
                  end
                | _ -> raise RuntimeError(val: "let_binding: expected let stmt")
              end
            | [] -> raise RuntimeError(val: "let_binding: empty body")
          end
        end
      | [] -> raise RuntimeError(val: "let_binding: no functions")
    end
  end
end

// ─── Test 3: Full pipeline HIR->MIR->LIR ──────────────────────────────────────

let test_full_pipeline = fn () -> unit throws { Exn } do
  let body = ss(s: Return(expr: se(e: Literal(lit: LitInt(val: 99))))) :: []
  let func = HirFunction(name: "main", type_params: [], params: [], ret_type: TyUnit,
    body: EagerBody(stmts: body), span: dummy_span())
  let hir = HirProgram(
    ports: [], functions: func :: [],
    externals: [], handler_bindings: [], enum_defs: []
  )
  let mir = lower_hir_to_mir(hir: hir)
  match mir do | MirProgram(_) ->
    let lir = lower_mir_to_lir(mir: mir, enum_defs: [])
    match lir do | LirProgram(functions: fs, externals: _) ->
      match fs do
        | f :: _ ->
          match f do | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) ->
            assert(cond: n == "main", msg: "full_pipeline: function name is main")
          end
        | [] -> raise RuntimeError(val: "full_pipeline: no functions")
      end
    end
  end
end

// ─── Test 4: Tail call in if-then return ─────────────────────────────────────
// Verify that `return f(n - 1)` inside an if-else block produces LirExprTailCall.
// MIR equivalent of:
//   let f = fn (n: i64) -> i64 do
//     if n == 0 then return 0 else return f(n: n - 1) end
//   end

// Helper: search LIR stmts for any LirExprTailCall
let has_tail_call_in_stmts = fn (stmts: [LirStmt]) -> bool do
  match stmts do
    | [] -> return false
    | s :: rest ->
      if has_tail_call_in_stmt(stmt: s) then return true end
      return has_tail_call_in_stmts(stmts: rest)
  end
end

let has_tail_call_in_stmt = fn (stmt: LirStmt) -> bool do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: LirExprTailCall(_)) ->
      return true
    | LirStmtLet(_) -> return false
    | LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
      return has_tail_call_in_stmts(stmts: tb) || has_tail_call_in_stmts(stmts: eb)
    | LirStmtIfReturn(cond: _, then_body: tb, then_ret: _, else_body: eb, else_ret: _, ret_type: _) ->
      return has_tail_call_in_stmts(stmts: tb) || has_tail_call_in_stmts(stmts: eb)
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      return has_tail_call_in_stmts(stmts: cs) || has_tail_call_in_stmts(stmts: b)
    | LirStmtTryCatch(body: b, body_ret: _, catch_param: _, catch_param_typ: _, catch_body: cb, catch_ret: _) ->
      return has_tail_call_in_stmts(stmts: b) || has_tail_call_in_stmts(stmts: cb)
  end
end

let test_tail_call_in_if = fn () -> unit throws { Exn } do
  // Build MIR:
  //   f(n: i64) -> i64:
  //     MirStmtExpr(MirIf(n == 0,
  //       then: [MirStmtReturn(MirLiteral(0))],
  //       else: [MirStmtReturn(MirCall(f, [n - 1]))]))
  let cond = MirBinaryOp(
    left: MirVariable(name: "n"), op: OpEq,
    right: MirLiteral(lit: LitInt(val: 0)))
  let then_body = MirStmtReturn(expr: MirLiteral(lit: LitInt(val: 0))) :: []
  let else_body = MirStmtReturn(expr: MirCall(
      func: "f",
      args: MirCallArg(label: "n",
        value: MirBinaryOp(left: MirVariable(name: "n"), op: OpSub,
                            right: MirLiteral(lit: LitInt(val: 1)))) :: [],
      ret_type: TyI64)) :: []
  let body = MirStmtExpr(expr: MirIf(cond: cond, then_body: then_body,
                                 else_body: Some(val: else_body))) :: []
  let func = MirFunction(
    name: "f",
    params: MirParam(label: "n", name: "n", typ: TyI64) :: [],
    ret_type: TyI64,
    body: body,
    span: dummy_span())
  let mir = MirProgram(functions: func :: [], externals: [])
  let lir = lower_mir_to_lir(mir: mir, enum_defs: [])
  match lir do | LirProgram(functions: fs, externals: _) ->
    match fs do
      | f :: _ ->
        match f do | LirFunction(name: _, params: _, ret_type: _, body: stmts, ret: _, span: _) ->
          // The if-return body should contain LirExprTailCall for the recursive call
          assert(cond: has_tail_call_in_stmts(stmts: stmts),
            msg: "tail_call_in_if: expected LirExprTailCall in if-return body")
        end
      | [] -> raise RuntimeError(val: "tail_call_in_if: no functions")
    end
  end
end

let main = fn () -> unit do
  try
    test_basic()
    test_let_binding()
    test_full_pipeline()
    test_tail_call_in_if()
  catch e ->
    ()
  end
  return ()
end
