/**
 * Verifies that the nxc-codegen `heap_reset` path reclaims allocations
 * tracked by the routed allocator's LIFO bookkeeping (the "delta_pages"
 * leak shape called out by nexus-a7ai). Without `__nx_alloc_reset` wired
 * into emit_heap_reset, every iteration's string concat / from_i64
 * allocations accumulate in `nexus_wasm_alloc::ALLOCATIONS` and the
 * underlying `memory.size` grows monotonically.
 *
 * The loop runs 100k iterations of a representative per-request workload
 * (8 small allocations: from_i64, two concats, length, format header,
 * full response, substring, total length). Wrapped in heap_mark/reset,
 * the post-loop page count must equal the pre-loop value — every routed
 * allocation since the mark gets popped LIFO inside `__nx_alloc_reset`.
 */
import { Console }, * as stdio from "std:stdio"
import { heap_mark, heap_reset } from "std:arena"
import { length, from_i64, substring } from "std:str"
import * as mem from "std:runtime_mem"

let work = fn (i: i64) -> i64 do
  let id_str = from_i64(val: i)
  let path = "/echo/" ++ id_str
  let body = "ping " ++ id_str
  let header = "ct:text/plain\nlen:" ++ from_i64(val: length(s: body))
  let resp = header ++ "\n\n" ++ "echo: " ++ body ++ " path=" ++ path
  let _ = substring(s: resp, start: 0, len: 4)
  return length(s: resp)
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let pages_before = mem.size()
    let ~i = 0
    let ~acc = 0
    while ~i < 100000 do
      let m = heap_mark()
      let n = work(i: ~i)
      ~acc <- ~acc + n
      heap_reset(mark: m)
      ~i <- ~i + 1
    end
    let pages_after = mem.size()
    let delta = pages_after - pages_before
    Console.println(val: "delta_pages=" ++ from_i64(val: delta))
    // Self-assertion: with __nx_alloc_reset wired, the LIFO bookkeeping
    // pops every routed allocation each iter. delta_pages must be 0 —
    // whole-page reclamation is exact when the workload's per-iter
    // footprint < page_size and the mark/reset bracket is symmetric.
    if delta != 0 then
      Console.println(val: "FAIL: routed allocator leak — delta_pages=" ++ from_i64(val: delta))
      let ~zero = 0
      let _ = 1 / ~zero
    end
  end
end
