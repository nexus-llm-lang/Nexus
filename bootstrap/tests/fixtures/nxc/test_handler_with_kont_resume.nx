import { Console }, * as stdio from "std:stdio"
import { from_i64 } from "std:str"

cap Gen do
  fn yield(val: i64) -> unit
end

let collector = handler Gen do
  fn yield(val: i64) -> unit with @k do
    Console.println(val: from_i64(val))
    @k
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    inject collector do
      Gen.yield(val: 10)
      Gen.yield(val: 20)
      Gen.yield(val: 30)
    end
  end
end
