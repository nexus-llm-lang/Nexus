import { Token, SpannedToken } from "src/common/token.nx"
import { tokenize } from "src/frontend/lexer.nx"
import { parse } from "src/frontend/parser.nx"
import { Program } from "src/common/ast.nx"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  let src = "let x = 1\n"
  let tokens = tokenize(src: src)
  let prog = parse(tokens: tokens)
  match prog do
    case Program(definitions: defs) ->
      match defs do
        case _ :: [] -> ()
        case _ -> raise RuntimeError(val: "expected exactly 1 definition")
      end
  end
  return ()
end
