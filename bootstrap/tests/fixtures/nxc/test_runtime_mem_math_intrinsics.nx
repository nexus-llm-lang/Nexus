/**
 * test_runtime_mem_math_intrinsics: covers nexus-dvr6.9.1 — memory load/store
 * round-trip (i32, i64, u8), memory.size before/after grow, and the four
 * f64 unary math ops (sqrt, floor, ceil, abs).
 *
 * Rationale: each printed line is the answer for one acceptance case, so
 * an interleave assertion at the harness level catches both correctness
 * (value mismatch) and ordering (intrinsic dispatch dropped a call).
 *
 * Address policy: we pick a high address (heap_base + 64KiB headroom) so
 * round-trip writes don't collide with stdlib bump allocations or the
 * compiler's globals.
 */

import { Console }, * as stdio from "std:stdio"
import * as mem from "std:runtime_mem"
import * as fmath from "std:runtime_math"
import { from_i64 } from "std:str"
import { float_to_i64 } from "std:math"

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    // Reserve a fresh page above the existing heap so the arena allocator
    // never overwrites our scratch buffer mid-test. mem.grow returns the
    // previous page count; the new buffer starts at prev_pages * 65536.
    let prev_pages = mem.grow(delta: 1)
    let scratch = prev_pages * 65536

    // (1) i32 round-trip: store 0x1234_5678 / 305419896 then reload.
    let _ = mem.store_i32(addr: scratch, val: 305419896)
    let v32 = mem.load_i32(addr: scratch)
    Console.println(val: from_i64(val: v32))

    // (2) u8 round-trip: store 0xAB / 171 then reload.
    let _ = mem.store_u8(addr: scratch + 8, val: 171)
    let v8 = mem.load_u8(addr: scratch + 8)
    Console.println(val: from_i64(val: v8))

    // (3) i64 round-trip with explicit address.
    let _ = mem.store_i64(addr: scratch + 16, val: 9223372036854775000)
    let v64 = mem.load_i64(addr: scratch + 16)
    Console.println(val: from_i64(val: v64))

    // (4) mem-size = N → grow(1) → mem-size = N+1. Print the delta
    // (always 1) so the interleave assertion is invariant of starting
    // memory layout.
    let n0 = mem.size()
    let _ = mem.grow(delta: 1)
    let n1 = mem.size()
    Console.println(val: from_i64(val: n1 - n0))

    // (5) f64 unary ops. Print integer truncations of the results so
    // the assertion is platform-stable (no float-formatting drift).
    let r_sqrt = fmath.sqrt(val: 4.0)
    Console.println(val: from_i64(val: float_to_i64(val: r_sqrt)))   // 2

    let r_floor = fmath.floor(val: 2.7)
    Console.println(val: from_i64(val: float_to_i64(val: r_floor)))  // 2

    let r_ceil = fmath.ceil(val: 2.3)
    Console.println(val: from_i64(val: float_to_i64(val: r_ceil)))   // 3

    // f64.abs(-3.5) = 3.5 → truncates to 3 via float_to_i64. Pair with
    // f64.abs(-30.0) = 30.0 → 30 so the integer assertion still discriminates
    // sign-bit handling from a plain identity.
    let r_abs_small = fmath.abs(val: -.3.5)
    Console.println(val: from_i64(val: float_to_i64(val: r_abs_small)))  // 3
    let r_abs_large = fmath.abs(val: -.30.0)
    Console.println(val: from_i64(val: float_to_i64(val: r_abs_large)))  // 30
  end
end
