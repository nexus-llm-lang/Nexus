// Tests for src/typecheck/infer Handler case (nexus-mqin.9).
// Handler expressions in expression position type as TyHandler(port, requires)
// rather than collapsing to TyUnit, so handler values can flow through let
// bindings and downstream code can distinguish them from unit.

import { TypeExpr, TyUnit, TyHandler, TyArrow, TyRecord, TyRow, NamedType } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"
import { HirExpr, HirStmt, HirParam, HirNamedExpr, Handler, Let, Expr, Variable, Lambda, Record } from "src/ir/hir_types.nx"
import { tc_new_state, InferExprOk, InferExprErr } from "src/typecheck/types.nx"
import { infer_expr, infer_stmts } from "src/typecheck/infer.nx"
import { SigilImmutable } from "src/common/ast.nx"
import { None } from "std:option"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)
  let st0 = tc_new_state(enum_defs: [], type_defs: [])

  // Test 1: bare Handler expression types as TyHandler(port, empty-row).
  let handler_expr = HirExpr(node: Handler(port_name: "Logger", arms: []), span: sp)
  match infer_expr(state: st0, expr: handler_expr, ret_type: TyUnit) do
    | InferExprErr(message: m, span: _) ->
      raise RuntimeError(val: "Test 1 errored: " ++ m)
    | InferExprOk(state: _, subst: _, typ: t) ->
      match t do
        | TyHandler(name: n, requires: _) ->
          if n == "Logger" then
            assert(cond: true, msg: "Handler expression types as TyHandler(\"Logger\", _)")
          else
            raise RuntimeError(val: "REGRESSION (nexus-mqin.9): Handler typed with wrong port name: " ++ n)
          end
        | TyUnit ->
          raise RuntimeError(val: "REGRESSION (nexus-mqin.9): Handler expression collapsed to TyUnit")
        | _ ->
          raise RuntimeError(val: "REGRESSION (nexus-mqin.9): Handler typed as something other than TyHandler")
      end
  end

  // Test 2: Handler expression bound by let; subsequent reference to the
  // binder retains TyHandler typing — i.e. the type survives let-binding.
  let stmts = [
    HirStmt(node: Let(name: "h", typ: None, value: HirExpr(node: Handler(port_name: "Logger", arms: []), span: sp)), span: sp),
    HirStmt(node: Expr(expr: HirExpr(node: Variable(name: "h", sigil: SigilImmutable), span: sp)), span: sp)
  ]
  match infer_stmts(state: st0, stmts, ret_type: TyUnit) do
    | InferExprErr(message: m, span: _) ->
      raise RuntimeError(val: "Test 2 errored: " ++ m)
    | InferExprOk(state: _, subst: _, typ: t) ->
      match t do
        | TyHandler(name: n, requires: _) ->
          if n == "Logger" then
            assert(cond: true, msg: "let-bound handler retains TyHandler type at reference")
          else
            raise RuntimeError(val: "Test 2: wrong port name: " ++ n)
          end
        | _ ->
          raise RuntimeError(val: "REGRESSION (nexus-mqin.9): let h = handler ... ; h didn't preserve TyHandler")
      end
  end

  // Test 3: lambda taking a handler param survives type-checking — proxy for
  // "pass a handler through \h -> h". The body just references the param so
  // capture analysis (mqin.6) sees no captures and the arrow stays plain.
  let logger_ty = TyHandler(name: "Logger", requires: TyRow(types: [], rest: None))
  let body3 = [HirStmt(node: Expr(expr: HirExpr(node: Variable(name: "h", sigil: SigilImmutable), span: sp)), span: sp)]
  let lambda3 = HirExpr(
    node: Lambda(
      type_params: [],
      params: [HirParam(name: "h", label: "h", typ: logger_ty)],
      ret_type: logger_ty,
      body: body3
    ),
    span: sp
  )
  match infer_expr(state: st0, expr: lambda3, ret_type: TyUnit) do
    | InferExprErr(message: m, span: _) ->
      raise RuntimeError(val: "Test 3 errored: " ++ m)
    | InferExprOk(state: _, subst: _, typ: t) ->
      match t do
        | TyArrow(_) ->
          assert(cond: true, msg: "\\h -> h with handler param type-checks as TyArrow")
        | _ ->
          raise RuntimeError(val: "Test 3: lambda over handler did not produce TyArrow")
      end
  end

  // Test 4: record literal with a handler-typed field — verifies handler
  // values can sit in record positions.
  let rec_expr = HirExpr(
    node: Record(fields: [HirNamedExpr(name: "h", value: HirExpr(node: Handler(port_name: "Logger", arms: []), span: sp))]),
    span: sp
  )
  match infer_expr(state: st0, expr: rec_expr, ret_type: TyUnit) do
    | InferExprErr(message: m, span: _) ->
      raise RuntimeError(val: "Test 4 errored: " ++ m)
    | InferExprOk(state: _, subst: _, typ: t) ->
      match t do
        | TyRecord(fields: [NamedType(name: fn_, typ: TyHandler(name: pn, requires: _))]) ->
          if fn_ == "h" then
            if pn == "Logger" then
              assert(cond: true, msg: "record { h: handler Logger ... } typed correctly")
            else
              raise RuntimeError(val: "Test 4: wrong handler port: " ++ pn)
            end
          else
            raise RuntimeError(val: "Test 4: wrong field name: " ++ fn_)
          end
        | _ ->
          raise RuntimeError(val: "REGRESSION (nexus-mqin.9): record with handler field didn't carry TyHandler in field type")
      end
  end

  return ()
end
