// Tests for src/hir.nx — HIR types, AST→HIR conversion, and reachability analysis.
import { tokenize } from "src/frontend/lexer.nx"
import { parse } from "src/frontend/parser.nx"
import { Span } from "src/common/token.nx"
import { Program, SpannedTopLevel, TopLevel, GlobalLet, EnumDef,
         VariantDef, Cap, SpannedExpr, Expr, Literal, TypeExpr } from "src/common/ast.nx"
import { RenameEntry, rename, rename_add } from "src/ir/symtab.nx"
import { HirExprKind, HirStmtKind, HirCallArg, HirParam, HirFunction,
         HirHandlerArm,
         HirMatchCase, HirPatternKind, HirPatternField,
         HirPort, HirPortMethod, HirExternal, HirHandlerBinding,
         HirHandlerBindingEntry, HirProgram, HirAccum,
         HirExpr, HirStmt, HirBody, EagerBody } from "src/ir/hir_types.nx"
import { convert_expr, convert_stmts, convert_pattern,
         process_defs, empty_accum,
         resolve_one_lazy } from "src/ir/hir.nx"
import { collect_calls_stmts, collect_reachable,
         filter_reachable_functions, filter_reachable_externals } from "src/ir/hir/reachability.nx"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let get_defs = fn (prog: Program) -> [SpannedTopLevel] do
  match prog do | Program(definitions: defs) -> return defs end
end

// ─── Helper: count list length ────────────────────────────────────────────
let list_len = fn (xs: [HirFunction]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + list_len(xs: rest)
  end
end

let str_list_len = fn (xs: [string]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + str_list_len(xs: rest)
  end
end

let port_list_len = fn (xs: [HirPort]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + port_list_len(xs: rest)
  end
end

let enum_list_len = fn (xs: [EnumDef]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + enum_list_len(xs: rest)
  end
end

let binding_list_len = fn (xs: [HirHandlerBindingEntry]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + binding_list_len(xs: rest)
  end
end

let ext_list_len = fn (xs: [HirExternal]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + ext_list_len(xs: rest)
  end
end

let str_in_list = fn (s: string, xs: [string]) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true
      else return str_in_list(s: s, xs: rest)
      end
  end
end

// Helper: dummy span for manual HIR construction
let s0 = fn () -> Span do return Span(offset: 0, line: 0, col: 0) end

// Helper: wrap HirExprKind in HirExpr with dummy span
let se = fn (e: HirExprKind) -> HirExpr do return HirExpr(node: e, span: s0()) end

// Helper: wrap HirStmtKind in HirStmt with dummy span
let ss = fn (s: HirStmtKind) -> HirStmt do return HirStmt(node: s, span: s0()) end

// ─── Test convert_expr: literal passthrough ───────────────────────────────
let test_convert_expr_literal = fn () -> unit throws { Exn } do
  let src = "export let x = fn () -> i64 do return 42 end\n"
  let prog = parse(tokens: tokenize(src: src))
  let defs = get_defs(prog: prog)
  // Process defs into HIR, check the function body has a Return with Literal
  let accum = process_defs(defs: defs, entries: [],
    accum: empty_accum(), source_file: "")
  match accum do | HirAccum(ports: _, functions: fs, externals: _, handler_bindings: _, enum_defs: _, wasm_module: _, exception_groups: _) ->
    // All test functions use EagerBody, so no lazy resolution needed
let fs = fs
    assert(cond: list_len(xs: fs) == 1, msg: "literal: expected 1 function")
    match fs do | f :: _ ->
      match f do | HirFunction(name: n, type_params: _, params: _, ret_type: _, body: b, span: _) -> let body = match b do | EagerBody(stmts: s) -> s | LazyBody(ast_expr: e, entries: ents) -> match convert_expr(expr: e, entries: ents) do | HirExpr(node: Lambda(type_params: _, params: _, ret_type: _, body: lb), span: _) -> lb | _ -> [] end end
        assert(cond: n == "x", msg: "literal: function name is x")
        // Body should have a return stmt with literal 42
        match body do | ss1 :: _ ->
          match ss1 do
            | HirStmt(node: Return(expr: se1), span: _) ->
              match se1 do
                | HirExpr(node: Literal(lit: l), span: _) ->
                  match l do
                    | LitInt(val: v) ->
                      assert(cond: v == 42, msg: "literal: value is 42")
                    | _ -> raise RuntimeError(val: "literal: expected LitInt")
                  end
                | _ -> raise RuntimeError(val: "literal: expected Literal")
              end
            | _ -> raise RuntimeError(val: "literal: expected Return")
          end
        | [] -> raise RuntimeError(val: "literal: expected non-empty body")
        end
      end
    | [] -> raise RuntimeError(val: "literal: no functions")
    end
  end
end

// ─── Test convert_expr: variable renaming ─────────────────────────────────
let test_convert_expr_rename = fn () -> unit throws { Exn } do
  let src = "export let f = fn (x: i64) -> i64 do return x end\n"
  let prog = parse(tokens: tokenize(src: src))
  let defs = get_defs(prog: prog)
  // Use rename entries to qualify "f" → "mod.f"
  let entries = rename_add(entries: [], original: "f", qualified: "mod.f")
  let accum = process_defs(defs: defs, entries: entries,
    accum: empty_accum(), source_file: "")
  match accum do | HirAccum(ports: _, functions: fs, externals: _, handler_bindings: _, enum_defs: _, wasm_module: _, exception_groups: _) ->
    match fs do | func :: _ ->
      match func do | HirFunction(name: n, type_params: _, params: _, ret_type: _, body: _, span: _) ->
        assert(cond: n == "mod.f", msg: "rename: function name is mod.f, got " ++ n)
      end
    | [] -> raise RuntimeError(val: "rename: no functions")
    end
  end
end

// ─── Test process_defs: port extraction ───────────────────────────────────
let test_process_defs_port = fn () -> unit throws { Exn } do
  let src = "cap Logger do\n  fn log(msg: string) -> unit\nend\n"
  let prog = parse(tokens: tokenize(src: src))
  let defs = get_defs(prog: prog)
  let accum = process_defs(defs: defs, entries: [],
    accum: empty_accum(), source_file: "")
  match accum do | HirAccum(ports: ps, functions: _, externals: _, handler_bindings: _, enum_defs: _, wasm_module: _, exception_groups: _) ->
    assert(cond: port_list_len(xs: ps) == 1, msg: "port: expected 1 port")
    match ps do | p :: _ ->
      match p do | HirPort(name: n, methods: ms) ->
        assert(cond: n == "Logger", msg: "port: name is Logger")
        match ms do | m :: _ ->
          match m do | HirPortMethod(name: mn) ->
            assert(cond: mn == "log", msg: "port: method name is log")
          end
        | [] -> raise RuntimeError(val: "port: no methods")
        end
      end
    | [] -> raise RuntimeError(val: "port: no ports")
    end
  end
end

// ─── Test process_defs: enum extraction ───────────────────────────────────
let test_process_defs_enum = fn () -> unit throws { Exn } do
  let src = "type Color = Red | Green | Blue\n"
  let prog = parse(tokens: tokenize(src: src))
  let defs = get_defs(prog: prog)
  let accum = process_defs(defs: defs, entries: [],
    accum: empty_accum(), source_file: "")
  match accum do | HirAccum(ports: _, functions: _, externals: _, handler_bindings: _, enum_defs: eds, wasm_module: _, exception_groups: _) ->
    // +1 for seeded Exn enum in empty_accum
    assert(cond: enum_list_len(xs: eds) == 2, msg: "enum: expected 2 enum defs (Color + Exn)")
    match eds do | ed :: _ ->
      match ed do | EnumDef(name: n, is_public: _, is_opaque: _, type_params: _, variants: _) ->
        assert(cond: n == "Color", msg: "enum: name is Color")
      end
    | [] -> raise RuntimeError(val: "enum: no enum defs")
    end
  end
end

// ─── Test process_defs: multiple definitions ──────────────────────────────
let test_process_defs_mixed = fn () -> unit throws { Exn } do
  let src = "export let add = fn (a: i64, b: i64) -> i64 do return a + b end\nexport let sub = fn (a: i64, b: i64) -> i64 do return a - b end\ntype Pair = Pair(x: i64, y: i64)\ncap Printer do\n  fn print(s: string) -> unit\nend\n"
  let prog = parse(tokens: tokenize(src: src))
  let defs = get_defs(prog: prog)
  let accum = process_defs(defs: defs, entries: [],
    accum: empty_accum(), source_file: "")
  match accum do | HirAccum(ports: ps, functions: fs, externals: _, handler_bindings: _, enum_defs: eds, wasm_module: _, exception_groups: _) ->
    assert(cond: list_len(xs: fs) == 2, msg: "mixed: expected 2 functions")
    assert(cond: port_list_len(xs: ps) == 1, msg: "mixed: expected 1 port")
    // +1 for seeded Exn enum in empty_accum
    assert(cond: enum_list_len(xs: eds) == 2, msg: "mixed: expected 2 enums (Pair + Exn)")
  end
end

// ─── Test collect_calls and reachability ──────────────────────────────────
let test_reachability = fn () -> unit throws { Exn } do
  // Build HIR functions manually for reachability test
  let main_body =
    ss(s: Expr(expr: se(e: Call(func: "helper", args: []))))
    :: ss(s: Return(expr: se(e: Literal(lit: LitUnit))))
    :: []
  let main_fn = HirFunction(name: "main", type_params: [], params: [], ret_type: TyUnit, body: EagerBody(stmts: main_body), span: s0())

  let helper_body = ss(s: Return(expr: se(e: Call(func: "utility", args: [])))) :: []
  let helper_fn = HirFunction(name: "helper", type_params: [], params: [], ret_type: TyI64, body: EagerBody(stmts: helper_body), span: s0())

  let utility_body = ss(s: Return(expr: se(e: Literal(lit: LitInt(val: 42))))) :: []
  let utility_fn = HirFunction(name: "utility", type_params: [], params: [], ret_type: TyI64, body: EagerBody(stmts: utility_body), span: s0())

  // Dead function — not called from "main"
  let dead_body = ss(s: Return(expr: se(e: Literal(lit: LitInt(val: 0))))) :: []
  let dead_fn = HirFunction(name: "dead_func", type_params: [], params: [], ret_type: TyI64, body: EagerBody(stmts: dead_body), span: s0())

  let all_funcs = main_fn :: helper_fn :: utility_fn :: dead_fn :: []

  // Test collect_calls_stmts
  let main_calls = collect_calls_stmts(stmts: main_body)
  assert(cond: str_in_list(s: "helper", xs: main_calls), msg: "calls: main calls helper")

  // Test collect_reachable
  let reachable = collect_reachable(functions: all_funcs, handler_bindings: [])
  assert(cond: str_in_list(s: "main", xs: reachable), msg: "reachable: main is reachable")
  assert(cond: str_in_list(s: "helper", xs: reachable), msg: "reachable: helper is reachable")
  assert(cond: str_in_list(s: "utility", xs: reachable), msg: "reachable: utility is reachable")
  assert(cond: str_in_list(s: "dead_func", xs: reachable) == false, msg: "reachable: dead_func is NOT reachable")

  // Test filter_reachable_functions
  let filtered = filter_reachable_functions(functions: all_funcs, reachable: reachable)
  assert(cond: list_len(xs: filtered) == 3, msg: "filter: 3 reachable functions (not 4)")
end

// ─── Test desugar list literal ────────────────────────────────────────────
let test_list_desugar = fn () -> unit throws { Exn } do
  let src = "export let xs = fn () -> [i64] do return [1, 2] end\n"
  let prog = parse(tokens: tokenize(src: src))
  let defs = get_defs(prog: prog)
  let accum = process_defs(defs: defs, entries: [],
    accum: empty_accum(), source_file: "")
  match accum do | HirAccum(ports: _, functions: fs, externals: _, handler_bindings: _, enum_defs: _, wasm_module: _, exception_groups: _) ->
    // All test functions use EagerBody, so no lazy resolution needed
let fs = fs
    assert(cond: list_len(xs: fs) == 1, msg: "list: expected 1 function")
    match fs do | f :: _ ->
      match f do | HirFunction(name: _, type_params: _, params: _, ret_type: _, body: b, span: _) -> let body = match b do | EagerBody(stmts: s) -> s | LazyBody(ast_expr: e, entries: ents) -> match convert_expr(expr: e, entries: ents) do | HirExpr(node: Lambda(type_params: _, params: _, ret_type: _, body: lb), span: _) -> lb | _ -> [] end end
        // Body should return a desugared :: / [] chain: 1 :: 2 :: []
        match body do | ss1 :: _ ->
          match ss1 do
            | HirStmt(node: Return(expr: se1), span: _) ->
              match se1 do
                | HirExpr(node: Ctor(variant: v, args: _), span: _) ->
                  assert(cond: v == "Cons", msg: "list: outer is Cons")
                | _ -> raise RuntimeError(val: "list: expected Ctor(Cons)")
              end
            | _ -> raise RuntimeError(val: "list: expected Return")
          end
        | [] -> raise RuntimeError(val: "list: empty body")
        end
      end
    | [] -> raise RuntimeError(val: "list: no functions")
    end
  end
end

// ─── Test if-expression in HIR ────────────────────────────────────────────
let test_if_expr = fn () -> unit throws { Exn } do
  let src = "export let pick = fn (a: i64, b: i64) -> i64 do\n  let r = if a > b then a else b end\n  return r\nend\n"
  let prog = parse(tokens: tokenize(src: src))
  let defs = get_defs(prog: prog)
  let accum = process_defs(defs: defs, entries: [],
    accum: empty_accum(), source_file: "")
  match accum do | HirAccum(ports: _, functions: fs, externals: _, handler_bindings: _, enum_defs: _, wasm_module: _, exception_groups: _) ->
    // All test functions use EagerBody, so no lazy resolution needed
let fs = fs
    assert(cond: list_len(xs: fs) == 1, msg: "if: expected 1 function")
    match fs do | f :: _ ->
      match f do | HirFunction(name: n, type_params: _, params: ps, ret_type: _, body: b, span: _) -> let body = match b do | EagerBody(stmts: s) -> s | LazyBody(ast_expr: e, entries: ents) -> match convert_expr(expr: e, entries: ents) do | HirExpr(node: Lambda(type_params: _, params: _, ret_type: _, body: lb), span: _) -> lb | _ -> [] end end
        assert(cond: n == "pick", msg: "if: function name is pick")
        // Body: [let r = if ..., return r]
        match body do
          | ss1 :: ss2 :: [] ->
            match ss1 do
              | HirStmt(node: Let(name: rn, typ: _, value: val), span: _) ->
                assert(cond: rn == "r", msg: "if: let name is r")
                match val do
                  | HirExpr(node: If(_), span: _) ->
                    return ()  // Success — if-expression properly converted
                  | _ -> raise RuntimeError(val: "if: expected If in let value")
                end
              | _ -> raise RuntimeError(val: "if: expected Let")
            end
          | _ -> raise RuntimeError(val: "if: expected 2 stmts in body")
        end
      end
    | [] -> raise RuntimeError(val: "if: no functions")
    end
  end
end

// ─── Test handler reachability includes externals ─────────────────────────
let test_handler_reachability_externals = fn () -> unit throws { Exn } do
  // main calls inject with handler "my_handler"
  let main_body =
    ss(s: Inject(
      handlers: "my_handler" :: [],
      body: ss(s: Expr(expr: se(e: Call(func: "port_println", args: [])))) :: []
    ))
    :: ss(s: Return(expr: se(e: Literal(lit: LitUnit))))
    :: []
  let main_fn = HirFunction(name: "main", type_params: [], params: [], ret_type: TyUnit, body: EagerBody(stmts: main_body), span: s0())

  // Handler function body calls an external "ext_print"
  let handler_body =
    ss(s: Expr(expr: se(e: Call(func: "ext_print", args: []))))
    :: ss(s: Return(expr: se(e: Literal(lit: LitUnit))))
    :: []
  let handler_fn = HirFunction(name: "__handler_my_handler_println", type_params: [], params: [], ret_type: TyUnit, body: EagerBody(stmts: handler_body), span: s0())

  let handler_binding = HirHandlerBindingEntry(
    name: "my_handler",
    binding: HirHandlerBinding(port_name: "Console", arms: HirHandlerArm(arm: handler_fn, cont_binder: None) :: [])
  )

  let ext = HirExternal(name: "ext_print", wasm_module: "stdlib", wasm_name: "__nx_print",
    type_params: [], params: [], ret_type: TyUnit, throw_row: TyUnit)

  let all_funcs = main_fn :: []
  let all_bindings = handler_binding :: []
  let all_exts = ext :: []

  let reachable = collect_reachable(functions: all_funcs, handler_bindings: all_bindings)

  // Handler binding name should be reachable
  assert(cond: str_in_list(s: "my_handler", xs: reachable), msg: "handler_ext: my_handler is reachable")
  // External called by handler function should be reachable
  assert(cond: str_in_list(s: "ext_print", xs: reachable), msg: "handler_ext: ext_print is reachable")

  // filter_reachable_externals should keep the external
  let filtered_exts = filter_reachable_externals(externals: all_exts, reachable: reachable)
  assert(cond: ext_list_len(xs: filtered_exts) == 1, msg: "handler_ext: external survives filtering")
end

// ─── Main ────────────────────────────────────────────────────────────────
let run_tests = fn () -> unit throws { Exn } do
  test_convert_expr_literal()
  test_convert_expr_rename()
  test_process_defs_port()
  test_process_defs_enum()
  test_process_defs_mixed()
  test_reachability()
  test_list_desugar()
  test_if_expr()
  test_handler_reachability_externals()
end

let main = fn () -> unit do
  try
    run_tests()
  catch _ ->
    ()
  end
end
