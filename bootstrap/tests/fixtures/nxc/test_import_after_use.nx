/// Regression: import-order independence under canonical naming.
/// src/typecheck/check.nx uses `str_length` at line 257 and imports it
/// at line 448. After Step 4 canonical naming, function bodies must
/// resolve names regardless of source ordering.

let compute_length = fn (s: string) -> i64 do
  return str_length(s: s)
end

import { length as str_length } from "std:string_ops"

let main = fn () -> unit throws { Exn } do
  let n = compute_length(s: "hello")
  if n != 5 then raise RuntimeError(val: "compute_length hello should be 5") end
  return ()
end
