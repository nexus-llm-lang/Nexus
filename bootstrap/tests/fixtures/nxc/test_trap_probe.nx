/**
 * test_trap_probe: confirm that `let _ = 1 / 0` actually traps at runtime
 * when the divisor is computed via runtime values. If this passes silently,
 * the LIR optimizer is dead-code-eliminating the trap and every fixture that
 * relies on i64.div_s as an assertion mechanism is a no-op.
 */

let main = fn () -> unit do
  let one = 1
  let zero = if one == 1 then 0 else 1 end
  let _ = 1 / zero
  return ()
end
