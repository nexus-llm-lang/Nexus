import * as list from "stdlib/list.nx"
import * as str from "stdlib/string.nx"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  // Diamond: list.nx and string.nx both get transitively imported multiple times
  // via stdlib internals. With caller_entries propagation, each reference resolves
  // to a single registered function — no forwarder stubs emitted.

  let xs = list.reverse(xs: [1, 2, 3])
  match xs do
    case h :: _ -> assert(cond: h == 3, msg: "list.reverse head should be 3")
    case _ -> raise RuntimeError(val: "reverse produced empty list")
  end

  let n = list.length(xs: [10, 20, 30, 40])
  assert(cond: n == 4, msg: "list.length should be 4")

  let greeting = "hello"
  let glen = str.length(s: greeting)
  assert(cond: glen == 5, msg: "str.length should be 5")

  let s2 = str.substring(s: "abcdef", start: 1, len: 3)
  assert(cond: s2 == "bcd", msg: "str.substring bcd")

  return ()
end
