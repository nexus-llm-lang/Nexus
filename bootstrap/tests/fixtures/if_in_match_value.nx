// Repro: if-expression inside match-expression used as let initializer
// drops the if result — returns default value instead of the if branch result.
let pick = fn (flag: bool, a: i64, b: i64) -> i64 do
  let result = match flag do
    | true ->
      if a > b then a else b end
    | false -> 0
  end
  return result
end

let main = fn () -> unit throws { Exn } do
  let r1 = pick(flag: true, a: 10, b: 20)
  if r1 == 20 then return ()
  else raise RuntimeError(val: "expected 20, got default")
  end
end
