// Smoke test for std:test/property. Exercises i64, string, and i64-list
// drivers; verifies a deliberately-failing predicate produces a
// Counterexample with cases_run == 1 and a shrunk witness.
//
// `main` cannot declare `throws { Exn }`, so the body is wrapped in
// `safe_run` which converts unexpected escapes into a non-zero exit
// trapped by 1/0.
import * as test_assert from "std:test/assert"
import * as prop from "std:test/property"

let body = fn () -> unit throws { Exn } do
  // Holds: every val sampled from [0, 100) is non-negative.
  let outcome = prop.for_all_i64(
    name: "i64-non-negative",
    min: 0, max: 100, cases: 32, seed: 7,
    prop: fn (val: i64) -> bool do
      return val >= 0
    end)
  match outcome do
    | prop.PropertyHolds -> test_assert.assert_true(cond: true, label: "holds-non-negative")
    | prop.Counterexample(value, after_shrink, cases_run) ->
      raise RuntimeError(val: "expected PropertyHolds for non-negative")
  end

  // Fails: assert val < 5; with seed 7 some values exceed.
  let bad_outcome = prop.for_all_i64(
    name: "i64-lt-5",
    min: 0, max: 100, cases: 32, seed: 7,
    prop: fn (val: i64) -> bool do
      return val < 5
    end)
  match bad_outcome do
    | prop.PropertyHolds ->
      raise RuntimeError(val: "expected Counterexample for lt-5")
    | prop.Counterexample(value, after_shrink, cases_run) ->
      // Shrunk witness should be in [5, 100) (still failing the predicate)
      // and >= 5 (the smallest value that fails).
      test_assert.assert_true(cond: after_shrink >= 5, label: "shrunk-still-fails")
      test_assert.assert_true(cond: cases_run >= 1, label: "ran-at-least-once")
  end

  // String driver: non-empty alphanumeric strings.
  let str_outcome = prop.for_all_string(
    name: "alnum-non-empty",
    min_len: 3, max_len: 8, cases: 16, seed: 13,
    prop: fn (val: string) -> bool do
      return true
    end)
  match str_outcome do
    | prop.PropertyHolds -> test_assert.assert_true(cond: true, label: "string-trivial-holds")
    | prop.Counterexample(value, after_shrink, cases_run) ->
      raise RuntimeError(val: "trivial string property unexpectedly failed")
  end

  // i64 list driver: lengths within [2, 4].
  let list_outcome = prop.for_all_i64_list(
    name: "list-bounded",
    min_len: 2, max_len: 4, elem_min: 0, elem_max: 10, cases: 8, seed: 21,
    prop: fn (val: [ i64 ]) -> bool do
      return true
    end)
  match list_outcome do
    | prop.PropertyHolds -> test_assert.assert_true(cond: true, label: "list-trivial-holds")
    | prop.Counterexample(value, after_shrink, cases_run) ->
      raise RuntimeError(val: "trivial list property unexpectedly failed")
  end

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
