import * as smap from "stdlib/stringmap.nx"

let list_length = fn <T>(xs: [T]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + list_length(xs: rest)
  end
end

let main = fn () -> unit do
  let m0 = smap.empty()
  let m1 = smap.put(map: m0, key: "x", value: 1)
  let m2 = smap.put(map: m1, key: "y", value: 2)
  let m3 = smap.put(map: m2, key: "z", value: 3)
  let ks = smap.keys(map: &m3)
  let vs = smap.values(map: &m3)
  let sz = smap.size(map: &m3)
  smap.free(map: m3)
  let klen = list_length(xs: ks)
  let vlen = list_length(xs: vs)
  if sz != 3 then raise RuntimeError(val: "expected size 3") end
  if klen != 3 then raise RuntimeError(val: "expected 3 keys") end
  if vlen != 3 then raise RuntimeError(val: "expected 3 values") end
  return ()
end
