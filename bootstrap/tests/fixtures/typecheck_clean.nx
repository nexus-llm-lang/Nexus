// Positive fixture for `nexus typecheck` (issue nexus-5er0).
// Compiles cleanly through the front-end pipeline (parse → HIR → resolve →
// linearity → typecheck → tc-linearity). Used to assert exit code 0.
let add = fn (a: i64, b: i64) -> i64 do
  return a + b
end

let main = fn () -> unit do
  let _ = add(a: 1, b: 2)
  return ()
end
