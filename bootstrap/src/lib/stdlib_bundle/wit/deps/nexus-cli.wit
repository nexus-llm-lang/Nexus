package nexus:cli;

interface nexus-host {
  host-http-request: func(method: string, url: string, headers: string, body: string) -> string;
  host-http-listen: func(addr: string) -> s64;
  host-http-accept: func(server-id: s64) -> string;
  host-http-respond: func(req-id: s64, status: s64, headers: string, body: string) -> s32;
  host-http-stop: func(server-id: s64) -> s32;
  /// Drain all server / connection state held by the bridge guest. Idempotent.
  /// Returns the number of (server + connection) entries that were dropped.
  host-bridge-finalize: func() -> s64;

  /// Streaming response API. `…-chunk-start` writes status + headers and
  /// leaves the connection open; `…-chunk-write` appends a body chunk;
  /// `…-chunk-finish` terminates the response and drops the connection.
  host-http-respond-chunk-start: func(req-id: s64, status: s64, headers: string) -> s32;
  host-http-respond-chunk-write: func(req-id: s64, body-chunk: string) -> s32;
  host-http-respond-chunk-finish: func(req-id: s64) -> s32;

  /// Outbound HTTP request with a per-call timeout. timeout-ms = 0 ⇒ no
  /// timeout (identical to host-http-request).
  host-http-request-with-options: func(
    method: string, url: string, headers: string, body: string, timeout-ms: s64
  ) -> string;
  /// Cancel a server's blocking accept loop. Idempotent.
  host-http-cancel-accept: func(server-id: s64) -> s32;
}
