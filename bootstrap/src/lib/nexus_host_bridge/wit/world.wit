package nexus:cli;

interface nexus-host {
  host-http-request: func(method: string, url: string, headers: string, body: string) -> string;
  host-http-listen: func(addr: string) -> s64;
  host-http-accept: func(server-id: s64) -> string;
  host-http-respond: func(req-id: s64, status: s64, headers: string, body: string) -> s32;
  host-http-stop: func(server-id: s64) -> s32;
  /// Drain all server / connection state held by the bridge guest. Idempotent.
  /// Returns the number of (server + connection) entries that were dropped.
  /// Callable by the embedding host between wasm executions, or by the guest
  /// itself when reaching a known clean point. A wasm trap inside listen-stop
  /// or accept-respond intervals leaves resources in the bridge's thread-local
  /// state because Rust thread_local Drop only fires on thread exit; this
  /// export lets the host force a teardown without dropping the whole Store.
  host-bridge-finalize: func() -> s64;

  /// Begin a streaming response. Writes status line + headers + chunked
  /// transfer-encoding marker, but keeps the connection entry alive so the
  /// caller can append body chunks. Use `respond-chunk-write` to append, then
  /// `respond-chunk-finish` to terminate. `1` = success, `0` = failure.
  /// Bulk `host-http-respond` remains the recommended path for small bodies;
  /// streaming is for bodies that don't fit in a single buffer or for
  /// progressive output.
  host-http-respond-chunk-start: func(req-id: s64, status: s64, headers: string) -> s32;
  /// Append a chunk to a streaming response opened with `…-chunk-start`.
  /// `1` = success, `0` = failure (e.g. unknown req-id, write error).
  host-http-respond-chunk-write: func(req-id: s64, body-chunk: string) -> s32;
  /// Terminate a streaming response: writes the zero-length trailer chunk
  /// and drops the connection entry. `1` = success, `0` = failure.
  host-http-respond-chunk-finish: func(req-id: s64) -> s32;
}

world bridge {
  import wasi:http/outgoing-handler@0.2.6;
  import wasi:http/types@0.2.6;
  import wasi:io/streams@0.2.6;
  import wasi:io/poll@0.2.6;
  import wasi:sockets/tcp@0.2.6;
  import wasi:sockets/tcp-create-socket@0.2.6;
  import wasi:sockets/instance-network@0.2.6;
  import wasi:sockets/network@0.2.6;
  export nexus-host;
}
