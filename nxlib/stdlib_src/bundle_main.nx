/**
 * bundle_main: entry point for the Nexus-written stdlib bundle.
 *
 * Compiled with:
 *   nexus build nxlib/stdlib_src/bundle_main.nx --bundle-exports <all __nx_* + allocate/deallocate/__nx_alloc_mark/__nx_alloc_reset> -o nxlib/stdlib/stdlib.wasm
 *
 * The produced module replaces the old source-less prebuilt stdlib.wasm: the
 * stdlib-merge step links its exports into every program. main is never run
 * (the module is linked, not executed); it just anchors the pipeline.
 * --bundle-exports mode skips DCE, so importing the impl modules below keeps
 * all their exported functions. The dummy inner lambda forces codegen to emit
 * a function table + __indirect_function_table export, which the stdlib-merge
 * step expects the dep to provide (it appends the user module's closures onto
 * it). Without it the merge produces a module whose closure table/elem/export
 * dangle.
 */
import * as alloc from "nxlib/stdlib_src/alloc.nx"
import * as buffer from "nxlib/stdlib_src/buffer.nx"
import * as collection from "nxlib/stdlib_src/collection.nx"
import * as strops from "nxlib/stdlib_src/string.nx"
import * as sysmath from "nxlib/stdlib_src/sys_math.nx"
import * as sysio from "nxlib/stdlib_src/sys_io.nx"
import * as prochttp from "nxlib/stdlib_src/sys_proc_http.nx"

let main = fn () -> unit do
  let f = fn () -> i64 do return 0 end
  let _ = f()
  return ()
end
