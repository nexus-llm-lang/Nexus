/**
 * runtime/bundle_main: entry point for the Nexus-written stdlib bundle.
 *
 * Compiled with: nexus build nxlib/stdlib_src/bundle_main.nx
 *   --bundle-exports allocate,deallocate,cabi_realloc,__nx_alloc_mark,...
 *   -o nxlib/stdlib/stdlib.wasm   (see ).
 *
 * main is never run: the produced module's _start is dead because the module
 * is linked into other programs, not executed. It just anchors the pipeline.
 * --bundle-exports mode skips DCE, so the exported functions in the imported
 * runtime modules survive even though nothing here references them.
 */
import * as alloc from "nxlib/stdlib_src/alloc.nx"

let main = fn () -> unit do return () end
