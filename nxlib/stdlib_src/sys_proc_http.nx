/**
 * runtime/sys_proc_http: STUB implementations of the subprocess (`__nx_exec*`)
 * and HTTP (`__nx_http_*`) runtime functions.
 *
 * The old source-less prebuilt `stdlib.wasm` provided
 * these via WASI preview2 / the component model. The Nexus-built replacement
 * runtime targets WASI preview1 (forced by `-S threads`), which has NO
 * subprocess-spawn primitive and NO HTTP client/server. There is no preview1
 * equivalent, so these CANNOT be properly reimplemented here.
 *
 * Every function below is a STUB returning the "this failed / empty" value so
 * the bundle compiles. A real implementation needs a separate preview2 build
 * path (component imports for wasi:http and a process/exec interface).
 *
 * Consequences until that path exists:
 *   - stdlib `Proc.exec` (proc.nx) always reports failure: exit code -1,
 *     empty stdout/stderr.
 *   - stdlib `Net.http_*` (network.nx) always reports failure: 0 handles,
 *     empty responses, false on respond.
 *
 * TODO: add a preview2 runtime variant that imports wasi:http and
 * a subprocess interface, and wire these symbols to it.
 *
 * ABI note: Nexus lays out wasm function params in alphabetical name order,
 * while codegen passes them positionally in external-decl order (each `string`
 * param expanded to ptr,len). So every exported stub prefixes its params
 * a_, b_, c_, ... in that codegen-call order, so alphabetical == positional.
 * `string` param  = two i32 params (ptr, len).
 * `string` return = packed i64 ((ptr<<32)|len); 0 means the empty string.
 * `bool` = i32 (0 = false). `unit` = no result.
 */

// --- subprocess: __nx_exec* (see nxlib/stdlib/proc.nx external decls) ---

/**
 * STUB: WASI preview1 has no subprocess-spawn. Always reports failure (-1, the
 * error sentinel `Proc.exec` checks for).
 * external __nx_exec : (cmd: string, args: string) -> i64
 */
export let __nx_exec = fn (a_cmd_ptr: i32, b_cmd_len: i32, c_args_ptr: i32, d_args_len: i32) -> i64 do
  return 0 - 1
end

/**
 * STUB: no subprocess handles exist; always returns -1 (no such handle).
 * external __nx_exec_exit_code : (id: i64) -> i64
 */
export let __nx_exec_exit_code = fn (a_id: i64) -> i64 do
  return 0 - 1
end

/**
 * STUB: no captured stdout; returns the empty string (packed 0).
 * external __nx_exec_stdout : (id: i64) -> string
 */
export let __nx_exec_stdout = fn (a_id: i64) -> i64 do
  return 0
end

/**
 * STUB: no captured stderr; returns the empty string (packed 0).
 * external __nx_exec_stderr : (id: i64) -> string
 */
export let __nx_exec_stderr = fn (a_id: i64) -> i64 do
  return 0
end

/**
 * STUB: nothing to free; reports false (no such handle).
 * external __nx_exec_free : (id: i64) -> bool
 */
export let __nx_exec_free = fn (a_id: i64) -> bool do
  return false
end

// --- HTTP: __nx_http_* (see nxlib/stdlib/network.nx external decls) ---

/**
 * STUB: WASI preview1 has no HTTP client; returns the empty string (packed 0),
 * which decodes to a failure response.
 * external __nx_http_get : (url: string) -> string
 */
export let __nx_http_get = fn (a_url_ptr: i32, b_url_len: i32) -> i64 do
  return 0
end

/**
 * STUB: WASI preview1 has no HTTP client; returns the empty string (packed 0).
 *
 * external __nx_http_request : (method: string, url: string, headers: string, body: string) -> string
 */
export let __nx_http_request = fn (
  a_method_ptr: i32, b_method_len: i32,
  c_url_ptr: i32, d_url_len: i32,
  e_headers_ptr: i32, f_headers_len: i32,
  g_body_ptr: i32, h_body_len: i32
) -> i64 do
  return 0
end

/**
 * STUB: WASI preview1 has no HTTP client; returns the empty string (packed 0).
 *
 * external __nx_http_request_with_options :
 *   (method: string, url: string, headers: string, body: string, timeout_ms: i64) -> string
 */
export let __nx_http_request_with_options = fn (
  a_method_ptr: i32, b_method_len: i32,
  c_url_ptr: i32, d_url_len: i32,
  e_headers_ptr: i32, f_headers_len: i32,
  g_body_ptr: i32, h_body_len: i32,
  i_timeout_ms: i64
) -> i64 do
  return 0
end

/**
 * STUB: WASI preview1 has no HTTP server; returns 0 (failed to listen).
 * external __nx_http_listen : (addr: string) -> i64
 */
export let __nx_http_listen = fn (a_addr_ptr: i32, b_addr_len: i32) -> i64 do
  return 0
end

/**
 * STUB: no HTTP server; returns the empty string (packed 0).
 * external __nx_http_accept : (server_id: i64) -> string
 */
export let __nx_http_accept = fn (a_server_id: i64) -> i64 do
  return 0
end

/**
 * STUB: no HTTP server; reports false.
 * external __nx_http_cancel_accept : (server_id: i64) -> bool
 */
export let __nx_http_cancel_accept = fn (a_server_id: i64) -> bool do
  return false
end

/**
 * STUB: no HTTP server; reports false.
 * external __nx_http_respond : (req_id: i64, status: i64, headers: string, body: string) -> bool
 */
export let __nx_http_respond = fn (
  a_req_id: i64, b_status: i64,
  c_headers_ptr: i32, d_headers_len: i32,
  e_body_ptr: i32, f_body_len: i32
) -> bool do
  return false
end

/**
 * STUB: no HTTP server; reports false.
 * external __nx_http_respond_chunk_start : (req_id: i64, status: i64, headers: string) -> bool
 */
export let __nx_http_respond_chunk_start = fn (
  a_req_id: i64, b_status: i64,
  c_headers_ptr: i32, d_headers_len: i32
) -> bool do
  return false
end

/**
 * STUB: no HTTP server; reports false.
 * external __nx_http_respond_chunk_write : (req_id: i64, body_chunk: string) -> bool
 */
export let __nx_http_respond_chunk_write = fn (
  a_req_id: i64,
  b_body_chunk_ptr: i32, c_body_chunk_len: i32
) -> bool do
  return false
end

/**
 * STUB: no HTTP server; reports false.
 * external __nx_http_respond_chunk_finish : (req_id: i64) -> bool
 */
export let __nx_http_respond_chunk_finish = fn (a_req_id: i64) -> bool do
  return false
end

/**
 * STUB: no HTTP server; reports false.
 * external __nx_http_stop : (server_id: i64) -> bool
 */
export let __nx_http_stop = fn (a_server_id: i64) -> bool do
  return false
end

let main = fn () -> unit do return () end
