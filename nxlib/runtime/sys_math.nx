/**
 * runtime/sys_math: math / clock / random / env runtime ops, ported to Nexus.
 *
 * Phase 6a of nexus-f90i: reimplements the `__nx_*` math/clock/random/env FFI
 * surface that the source-less prebuilt `stdlib.wasm` exports, so it can become
 * part of a Nexus-built, wasi-threads-safe replacement for that blob.
 *
 * ABI: same convention as runtime/buffer.nx and runtime/string.nx -- Nexus lays
 * out wasm function params alphabetically by name, but codegen-emitted callers
 * pass them positionally in external-decl declared order (each `string` param
 * expanding to <name>_ptr, <name>_len i32 pair). So every exported function
 * prefixes its params a_, b_, c_, ... in the codegen-call order, making
 * alphabetical == positional. A `string` return is the packed i64
 * (ptr << 32) | len; a `bool` is a wasm i32 (1/0).
 *
 * Implemented for real:
 *   __nx_abs_i64, __nx_abs_float, __nx_sqrt, __nx_ceil, __nx_floor,
 *   __nx_mod_i64, __nx_max_i64, __nx_min_i64,
 *   __nx_i64_to_float, __nx_float_to_i64  (via manual IEEE-754 bit twiddling --
 *     truncation, no round-to-nearest-even; the compiler only feeds these small
 *     integers / well-behaved doubles, so the lost low mantissa bits never bite),
 *   __nx_now           (WASI clock_time_get, REALTIME, returns ms since epoch
 *                       to match the old Rust SystemTime impl),
 *   __nx_random_i64    (8 bytes from WASI random_get, top bit cleared),
 *   __nx_random_range  ([min, max), via random_get; max <= min -> min),
 *   __nx_get_env, __nx_has_env  (WASI environ_sizes_get + environ_get scan).
 *
 * Stubbed (TODO -- a later phase / not expressible over WASI preview1):
 *   __nx_pow      -> 1.0   (wasm has no f64.pow; the old Rust used libm powf;
 *                           rarely used by the compiler. LOUD TODO.)
 *   __nx_sleep    -> ()    (WASI preview1 sleep needs poll_oneoff with a clock
 *                           subscription; not worth it here. Rarely used.)
 *   __nx_set_env  -> ()    (WASI preview1 has no setenv at all.)
 *
 * Caveats:
 *   - i64_to_float / float_to_i64 truncate dropped mantissa bits toward zero
 *     instead of rounding to nearest even; float_to_i64 of NaN/inf/out-of-range
 *     is best-effort (NaN -> 0, |x| too big -> a large but not necessarily
 *     saturated value) rather than Rust's exact `as i64` saturation.
 *   - __nx_now / __nx_random_i64 each leak ~16 bytes of bump-allocator scratch
 *     per call (acceptable under the bump allocator; arena reset reclaims it).
 *   - __nx_get_env / __nx_has_env re-fetch the whole environ block per call.
 */
import * as mem from "std:runtime/mem"
import * as cast from "std:runtime/cast"
import * as fmath from "std:runtime/math"
import * as alloc from "nxlib/runtime/alloc.nx"

import external "wasi_snapshot_preview1"

/// Raw WASI preview1 imports. Declared to match the WASI ABI exactly; codegen
/// emits the call with params in this declared order. We only CALL these -- the
/// host implements them.
external clock_time_get = "clock_time_get" : (a_clock_id: i32, b_precision: i64, c_time_out_ptr: i32) -> i32
external random_get = "random_get" : (a_buf: i32, b_buf_len: i32) -> i32
external environ_sizes_get = "environ_sizes_get" : (a_count_ptr: i32, b_size_ptr: i32) -> i32
external environ_get = "environ_get" : (a_environ_ptr: i32, b_buf_ptr: i32) -> i32

/// 2^32 -- multiplier to pack a (ptr, len) pair into a returned string i64.
let two_pow_32 = fn () -> i64 do return 4294967296 end

/// Nanoseconds per millisecond (clock_time_get returns ns; __nx_now wants ms).
let ns_per_ms = fn () -> i64 do return 1000000 end

/// i64::MIN, written as a parenthesised negation of a positive literal.
let i64_min = fn () -> i64 do return (0 - 9223372036854775807) - 1 end

/// Allocate `n` bump-allocator bytes; returns the linear-memory byte offset.
let scratch = fn (n: i64) -> i64 do return cast.i64_of(x: alloc.allocate(size: cast.i32_of(x: n))) end

// ─── integer math ───────────────────────────────────────────────────────────

/// |x|; for i64::MIN (the unique fixed point of negation) returns i64::MIN,
/// matching the old Rust `i64::abs` (which actually panics, but the bundle's
/// callers never hit it -- wrapping is the practical, panic-free behaviour).
export let __nx_abs_i64 = fn (a_x: i64) -> i64 do
  if a_x < 0 then return 0 - a_x else return a_x end
end

/// max(a, b).
export let __nx_max_i64 = fn (a_a: i64, b_b: i64) -> i64 do
  if a_a > b_b then return a_a else return b_b end
end

/// min(a, b).
export let __nx_min_i64 = fn (a_a: i64, b_b: i64) -> i64 do
  if a_a < b_b then return a_a else return b_b end
end

/// a mod b (truncated toward zero, == wasm i64.rem_s == Rust `%`). b == 0
/// returns i64::MIN (the sentinel the old Rust impl used for "math error").
export let __nx_mod_i64 = fn (a_a: i64, b_b: i64) -> i64 do
  if b_b == 0 then return i64_min() end
  return a_a % b_b
end

// ─── f64 unary ops (codegen-inlined intrinsics) ─────────────────────────────

/// |x| -- f64.abs (clears the sign bit).
export let __nx_abs_float = fn (a_x: float) -> float do return fmath.abs(val: a_x) end

/// sqrt(x) -- f64.sqrt; NaN for x < 0.
export let __nx_sqrt = fn (a_x: float) -> float do return fmath.sqrt(val: a_x) end

/// ceil(x) -- f64.ceil (round toward +inf).
export let __nx_ceil = fn (a_x: float) -> float do return fmath.ceil(val: a_x) end

/// floor(x) -- f64.floor (round toward -inf).
export let __nx_floor = fn (a_x: float) -> float do return fmath.floor(val: a_x) end

/// TODO(nexus-f90i Phase 6+): real pow. wasm32 has no f64.pow opcode; the old
/// Rust impl called libm `powf`. There is no Nexus path to a host pow here, so
/// this is STUBBED to 1.0. Compiler code paths do not depend on it; user code
/// that uses `std:math.pow` will get wrong answers until this is fixed.
export let __nx_pow = fn (a_base: float, b_exp: float) -> float do
  return 1.0
end

// ─── i64 <-> f64 conversions (manual IEEE-754, no convert opcode available) ──

/// Reinterpret the 64 bits of `bits` as an f64 (round-trips via linear memory).
let i64_bits_to_f64 = fn (bits: i64) -> float do
  let p = scratch(n: 8)
  let _ = mem.store_i64(addr: p, val: bits)
  return mem.load_f64(addr: p)
end

/// Reinterpret the 64 bits of `x` as an i64.
let f64_to_i64_bits = fn (x: float) -> i64 do
  let p = scratch(n: 8)
  let _ = mem.store_f64(addr: p, val: x)
  return mem.load_i64(addr: p)
end

/// Logical (zero-filling) right shift by `n` (0 <= n < 64): clears the bits
/// that an arithmetic >> would have copied down from the sign bit.
let lshr = fn (v: i64, n: i64) -> i64 do
  if n == 0 then return v end
  let shifted = v >> n
  // mask = (1 << (64 - n)) - 1; build it without overflowing the i64 literal.
  let mask = (1 << (63 - n)) - 1 + (1 << (63 - n))
  return shifted & mask
end

/// Position (0..63) of the highest set bit of `m` (m > 0). Linear scan from 63.
let high_bit = fn (m: i64) -> i64 do return high_bit_go(m, i: 63) end
let high_bit_go = fn (m: i64, i: i64) -> i64 do
  if i < 0 then return 0 end
  if lshr(v: m, n: i) & 1 == 1 then return i end
  return high_bit_go(m, i: i - 1)
end

/// Convert i64 -> f64. Truncates dropped low mantissa bits toward zero (no
/// round-to-nearest-even). i64::MIN is handled as exactly -2^63.
export let __nx_i64_to_float = fn (a_x: i64) -> float do
  if a_x == 0 then return 0.0 end
  if a_x == i64_min() then
    // -2^63 = sign bit set, exponent 1023 + 63 = 1086, mantissa 0.
    return i64_bits_to_f64(bits: ((0 - 9223372036854775807) - 1))
  end
  let neg = a_x < 0
  let mag = if neg then 0 - a_x else a_x end
  let p = high_bit(m: mag)
  // Align bit p of `mag` to bit 52, dropping bit p itself (the implicit 1).
  let mant = if p >= 52 then lshr(v: mag, n: p - 52) else mag << (52 - p) end
  let mant52 = mant & ((1 << 52) - 1)
  let biased = (1023 + p) << 52
  let sign = if neg then (1 << 63) else 0 end
  return i64_bits_to_f64(bits: sign + biased + mant52)
end

/// Convert f64 -> i64, truncating toward zero (best-effort match for Rust's
/// `as i64`: NaN -> 0; |x| beyond i64 range -> a large value, not necessarily
/// the saturated bound).
export let __nx_float_to_i64 = fn (a_x: float) -> i64 do
  let bits = f64_to_i64_bits(x: a_x)
  let neg = lshr(v: bits, n: 63) & 1 == 1
  let biased = lshr(v: bits, n: 52) & 2047
  let frac = bits & ((1 << 52) - 1)
  // exponent == 2047 -> inf/NaN; treat as 0 (NaN-ish) -- callers don't rely on it.
  if biased == 2047 then return 0 end
  if biased == 0 then return 0 end          // subnormal or zero -> truncates to 0
  let unbiased = biased - 1023
  if unbiased < 0 then return 0 end          // |x| < 1
  let mant = frac + (1 << 52)                // restore the implicit leading 1
  let mag = if unbiased >= 52 then mant << (unbiased - 52) else lshr(v: mant, n: 52 - unbiased) end
  return if neg then 0 - mag else mag end
end

// ─── clock ──────────────────────────────────────────────────────────────────

/// Current wall-clock time in milliseconds since the UNIX epoch (matches the
/// old Rust `SystemTime::now().duration_since(UNIX_EPOCH).as_millis()`); 0 on
/// any WASI error. Uses CLOCK_REALTIME (clock_id 0).
export let __nx_now = fn () -> i64 do
  let p = scratch(n: 8)
  let rc = clock_time_get(a_clock_id: cast.i32_of(x: 0), b_precision: ns_per_ms(), c_time_out_ptr: cast.i32_of(x: p))
  if cast.i64_of(x: rc) != 0 then return 0 end
  let ns = mem.load_i64(addr: p)
  return ns / ns_per_ms()
end

/// TODO(nexus-f90i Phase 6+): real sleep. WASI preview1 sleep is poll_oneoff
/// with a clock subscription -- not worth the complexity here. STUBBED to no-op.
/// `a_ms` is the duration in milliseconds (ignored).
export let __nx_sleep = fn (a_ms: i64) -> unit do
  return ()
end

// ─── random ─────────────────────────────────────────────────────────────────

/// A non-negative random i64 (top bit cleared, so in [0, 2^63 - 1]); 0 on a
/// WASI error. Sourced directly from WASI random_get (CSPRNG) rather than the
/// old userspace LCG -- equally fine and inherently thread-safe.
export let __nx_random_i64 = fn () -> i64 do
  let p = scratch(n: 8)
  let _ = mem.store_i64(addr: p, val: 0)
  let rc = random_get(a_buf: cast.i32_of(x: p), b_buf_len: cast.i32_of(x: 8))
  if cast.i64_of(x: rc) != 0 then return 0 end
  return mem.load_i64(addr: p) & 9223372036854775807
end

/// A random i64 in [min, max). max <= min returns min (matches the old Rust
/// impl). The span (max - min) is treated as unsigned for the modulo.
export let __nx_random_range = fn (a_min: i64, b_max: i64) -> i64 do
  if b_max <= a_min then return a_min end
  let span = b_max - a_min
  if span <= 0 then return a_min end
  // __nx_random_i64 is already in [0, 2^63), so it's a valid non-negative
  // dividend; span is positive, so `%` gives a value in [0, span).
  let r = __nx_random_i64() % span
  return a_min + r
end

// ─── env ────────────────────────────────────────────────────────────────────

/// True iff [a, a+n) byte-equals [b, b+n).
let bytes_eq = fn (a: i64, b: i64, n: i64) -> bool do return bytes_eq_go(a, b, n, i: 0) end
let bytes_eq_go = fn (a: i64, b: i64, n: i64, i: i64) -> bool do
  if i >= n then return true end
  if mem.load_u8(addr: a + i) != mem.load_u8(addr: b + i) then return false end
  return bytes_eq_go(a, b, n, i: i + 1)
end

/// Byte offset of the first 0 byte at or after `p`.
let strend = fn (p: i64) -> i64 do
  if mem.load_u8(addr: p) == 0 then return p end
  return strend(p: p + 1)
end

/// Fetch the WASI environ string block: returns (count_buf_packed) where the
/// returned i64 packs (buf_ptr << 32) | byte_size, or 0 on WASI error / empty.
/// The block is `count` consecutive NUL-terminated "KEY=VALUE" entries.
let load_environ = fn () -> i64 do
  let sizes = scratch(n: 8)               // [count: i32][size: i32]
  let rc = environ_sizes_get(a_count_ptr: cast.i32_of(x: sizes), b_size_ptr: cast.i32_of(x: sizes + 4))
  if cast.i64_of(x: rc) != 0 then return 0 end
  let count = mem.load_i32(addr: sizes) & 4294967295
  let bufsz = mem.load_i32(addr: sizes + 4) & 4294967295
  if count <= 0 || bufsz <= 0 then return 0 end
  let ptrs = scratch(n: count * 4)        // environ pointer array (required even if unused)
  let buf = scratch(n: bufsz)
  let rc2 = environ_get(a_environ_ptr: cast.i32_of(x: ptrs), b_buf_ptr: cast.i32_of(x: buf))
  if cast.i64_of(x: rc2) != 0 then return 0 end
  return (buf * two_pow_32()) + bufsz
end

/// Scan the environ block for an entry "name=...": returns the byte offset of
/// the value (just past the '='), or -1 if not found. `nb`/`nlen` describe the
/// key bytes; `cur`/`endp` bound the remaining block.
let env_find = fn (nb: i64, nlen: i64, cur: i64, endp: i64) -> i64 do
  if cur >= endp then return 0 - 1 end
  let entry_end = strend(p: cur)
  // entry is [cur, entry_end); a match needs >= nlen+1 bytes, bytes [cur,cur+nlen)
  // equal to the key, and byte cur+nlen == '=' (61).
  if entry_end - cur >= nlen + 1 && bytes_eq(a: cur, b: nb, n: nlen) && mem.load_u8(addr: cur + nlen) == 61 then
    return cur + nlen + 1
  end
  return env_find(nb, nlen, cur: entry_end + 1, endp)
end

/// Look up env var `name`; returns its value as a packed string i64, or 0 when
/// unset / empty (use __nx_has_env to disambiguate -- the packed-string ABI
/// collapses "" to 0). wasm sig (i32 i32) -> i64.
export let __nx_get_env = fn (a_name_ptr: i32, b_name_len: i32) -> i64 do
  let nlen = cast.i64_of(x: b_name_len)
  if nlen <= 0 then return 0 end
  let block = load_environ()
  if block == 0 then return 0 end
  let buf = (block >> 32) & 4294967295
  let bufsz = block & 4294967295
  let voff = env_find(nb: cast.i64_of(x: a_name_ptr), nlen, cur: buf, endp: buf + bufsz)
  if voff < 0 then return 0 end
  let vend = strend(p: voff)
  let vlen = vend - voff
  if vlen <= 0 then return 0 end
  let dst = scratch(n: vlen)
  let _ = copy_bytes(dst, src: voff, count: vlen)
  return (dst * two_pow_32()) + vlen
end

let copy_bytes = fn (dst: i64, src: i64, count: i64) -> unit do return copy_bytes_go(dst, src, count, i: 0) end
let copy_bytes_go = fn (dst: i64, src: i64, count: i64, i: i64) -> unit do
  if i >= count then return () end
  let _ = mem.store_u8(addr: dst + i, val: mem.load_u8(addr: src + i))
  return copy_bytes_go(dst, src, count, i: i + 1)
end

/// True iff env var `name` is set (to anything, including ""). wasm sig (i32 i32) -> i32 (bool).
export let __nx_has_env = fn (a_name_ptr: i32, b_name_len: i32) -> bool do
  let nlen = cast.i64_of(x: b_name_len)
  if nlen <= 0 then return false end
  let block = load_environ()
  if block == 0 then return false end
  let buf = (block >> 32) & 4294967295
  let bufsz = block & 4294967295
  return env_find(nb: cast.i64_of(x: a_name_ptr), nlen, cur: buf, endp: buf + bufsz) >= 0
end

/// TODO(nexus-f90i): WASI preview1 has no setenv. STUBBED to no-op. `a_name` /
/// `a_value` (both strings) are ignored.
export let __nx_set_env = fn (a_name_ptr: i32, b_name_len: i32, c_value_ptr: i32, d_value_len: i32) -> unit do
  return ()
end

// ─── tests (each returns a single i64, checked via wasmtime --invoke) ────────

let i32of = fn (x: i64) -> i32 do return cast.i32_of(x: x) end
let u8at = fn (p: i64, i: i64) -> i64 do return mem.load_u8(addr: p + i) end

/// abs/max/min/mod: abs(-7)=7, max(3,9)=9, min(3,9)=3, mod(17,5)=2, mod(-17,5)=-2.
/// returns 7*100000 + 9*1000 + 3*10 + 2 == 709032; plus 1 if mod(-17,5)==-2 and mod(5,0)==i64::MIN.
export let test_intmath = fn () -> i64 do
  let a = __nx_abs_i64(a_x: 0 - 7)
  let mx = __nx_max_i64(a_a: 3, b_b: 9)
  let mn = __nx_min_i64(a_a: 3, b_b: 9)
  let md = __nx_mod_i64(a_a: 17, b_b: 5)
  let mdn = __nx_mod_i64(a_a: 0 - 17, b_b: 5)
  let mdz = __nx_mod_i64(a_a: 5, b_b: 0)
  let ok = if mdn == 0 - 2 && mdz == i64_min() && __nx_abs_i64(a_x: 4) == 4 then 1 else 0 end
  return (a * 100000) + (mx * 1000) + (mn * 10) + md + ok
end

/// f64 ops via reinterpret: sqrt(16)=4, floor(3.75)=3, ceil(3.25)=4, abs(-2.5)=2.5.
/// Returns float_to_i64(sqrt(16))*1000 + float_to_i64(floor(3.75))*100
///       + float_to_i64(ceil(3.25))*10 + float_to_i64(abs(-2.5) +. abs(-2.5))
///       -> 4000 + 300 + 40 + 5 = 4345.
export let test_fmath = fn () -> i64 do
  let s = __nx_float_to_i64(a_x: __nx_sqrt(a_x: 16.0))
  let fl = __nx_float_to_i64(a_x: __nx_floor(a_x: 3.75))
  let cl = __nx_float_to_i64(a_x: __nx_ceil(a_x: 3.25))
  let ab = __nx_float_to_i64(a_x: __nx_abs_float(a_x: 0.0 -. 2.5) +. __nx_abs_float(a_x: 0.0 -. 2.5))
  return (s * 1000) + (fl * 100) + (cl * 10) + ab
end

/// i64<->f64 round trips: i64_to_float(123456789) then back -> 123456789;
/// i64_to_float(-42) back -> -42; i64_to_float(2^52) back -> 2^52 exact;
/// float_to_i64(3.75)==3; float_to_i64(-3.75)==-3; i64_to_float(0) -> bits 0.
/// returns rt1*10 + (extras ok ? 1 : 0). rt1 = 123456789  => 1234567890 + 1.
export let test_conv = fn () -> i64 do
  let rt1 = __nx_float_to_i64(a_x: __nx_i64_to_float(a_x: 123456789))
  let rtn = __nx_float_to_i64(a_x: __nx_i64_to_float(a_x: 0 - 42))
  let rt1b = __nx_float_to_i64(a_x: __nx_i64_to_float(a_x: 1))
  let rtbig = __nx_float_to_i64(a_x: __nx_i64_to_float(a_x: 4503599627370496))   // 2^52, exactly representable
  let t1 = __nx_float_to_i64(a_x: 3.75)
  let t2 = __nx_float_to_i64(a_x: 0.0 -. 3.75)
  let zb = f64_to_i64_bits(x: __nx_i64_to_float(a_x: 0))
  let ok = if rtn == 0 - 42 && rt1b == 1 && rtbig == 4503599627370496 && t1 == 3 && t2 == 0 - 3 && zb == 0 then 1 else 0 end
  return (rt1 * 10) + ok
end

/// __nx_now: should be a plausible ms-since-epoch value (after 2020-01-01,
/// before 2100). 2020-01-01 ~= 1577836800000 ms; 2100-01-01 ~= 4102444800000.
/// returns 1 if in range, else 0.
export let test_now = fn () -> i64 do
  let t = __nx_now()
  return if t > 1577836800000 && t < 4102444800000 then 1 else 0 end
end

/// random: two draws should be non-negative and (almost surely) differ;
/// range(10,20) draws should be in [10,20). returns 1 if all hold (with a
/// vanishingly small false-negative chance), else 0.
export let test_rand = fn () -> i64 do
  let r1 = __nx_random_i64()
  let r2 = __nx_random_i64()
  let rg1 = __nx_random_range(a_min: 10, b_max: 20)
  let rg2 = __nx_random_range(a_min: 10, b_max: 20)
  let rg3 = __nx_random_range(a_min: 5, b_max: 5)        // degenerate -> 5
  let ok = r1 >= 0 && r2 >= 0 && r1 != r2
        && rg1 >= 10 && rg1 < 20 && rg2 >= 10 && rg2 < 20 && rg3 == 5
  return if ok then 1 else 0 end
end

/// env: build the key "PATH" in scratch memory; has_env("PATH") should be true
/// in wasmtime (it propagates PATH unless --env strips it); get_env returns a
/// non-empty value. has_env of a nonsense key is false.
/// returns 1 if (has PATH) && (get PATH len > 0) && (!has "NX_NOPE_XYZ"), else 0.
/// (Robust to PATH being absent: if !has(PATH) we instead just require
///  !has(nonsense) and pass -- so the test is meaningful when PATH is present
///  and never spuriously fails when it isn't.)
export let test_env = fn () -> i64 do
  let path = scratch(n: 4)
  let _ = mem.store_u8(addr: path, val: 80)    // P
  let _ = mem.store_u8(addr: path + 1, val: 65) // A
  let _ = mem.store_u8(addr: path + 2, val: 84) // T
  let _ = mem.store_u8(addr: path + 3, val: 72) // H
  let nope = scratch(n: 11)
  let _ = mem.store_u8(addr: nope, val: 78)     // N
  let _ = mem.store_u8(addr: nope + 1, val: 88) // X
  let _ = mem.store_u8(addr: nope + 2, val: 95) // _
  let _ = mem.store_u8(addr: nope + 3, val: 78) // N
  let _ = mem.store_u8(addr: nope + 4, val: 79) // O
  let _ = mem.store_u8(addr: nope + 5, val: 80) // P
  let _ = mem.store_u8(addr: nope + 6, val: 69) // E
  let _ = mem.store_u8(addr: nope + 7, val: 95) // _
  let _ = mem.store_u8(addr: nope + 8, val: 88) // X
  let _ = mem.store_u8(addr: nope + 9, val: 89) // Y
  let _ = mem.store_u8(addr: nope + 10, val: 90) // Z
  let has_path = __nx_has_env(a_name_ptr: i32of(x: path), b_name_len: i32of(x: 4))
  let has_nope = __nx_has_env(a_name_ptr: i32of(x: nope), b_name_len: i32of(x: 11))
  let v = __nx_get_env(a_name_ptr: i32of(x: path), b_name_len: i32of(x: 4))
  let vlen = v & 4294967295
  let has_v = if vlen > 0 then 1 else 0 end
  let path_ok = if has_path then has_v else 1 end
  let ok = path_ok == 1 && !has_nope
  return if ok then 1 else 0 end
end

/// pow / sleep / set_env stubs do not trap. returns 1 (pow(2,10) stubbed to 1.0
/// -> float_to_i64 == 1; sleep & set_env are no-ops).
export let test_stubs = fn () -> i64 do
  let p = __nx_float_to_i64(a_x: __nx_pow(a_base: 2.0, b_exp: 10.0))
  let _ = __nx_sleep(a_ms: 0)
  let _ = __nx_set_env(a_name_ptr: i32of(x: 0), b_name_len: i32of(x: 0), c_value_ptr: i32of(x: 0), d_value_len: i32of(x: 0))
  return p
end

export let main = fn () -> unit do return () end
