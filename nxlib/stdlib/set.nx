/**
 * set: FFI-backed hash set of i64 values.
 *
 * Backed by Rust std::collections::HashSet via WASM FFI.
 * Uses opaque linear handles — each set must be freed after use.
 * Supports standard set algebra: insert, remove, contains, union,
 * intersection, and difference.
 */
import external "stdlib/stdlib.wasm"
import { length, substring, index_of } from "stdlib/string_ops.nx"

external to_i64 = "__nx_string_to_i64" : (s: string) -> i64

/// An opaque hash set handle (linear — must be freed).
export opaque type Set = Set(id: i64)

// --- FFI externals ---

external __nx_hset_new = "__nx_hset_new" : () -> i64
external __nx_hset_insert = "__nx_hset_insert" : (id: i64, val: i64) -> bool
external __nx_hset_contains = "__nx_hset_contains" : (id: i64, val: i64) -> bool
external __nx_hset_remove = "__nx_hset_remove" : (id: i64, val: i64) -> bool
external __nx_hset_size = "__nx_hset_size" : (id: i64) -> i64
external __nx_hset_to_list = "__nx_hset_to_list" : (id: i64) -> string
external __nx_hset_union = "__nx_hset_union" : (id_a: i64, id_b: i64) -> i64
external __nx_hset_intersection = "__nx_hset_intersection" : (id_a: i64, id_b: i64) -> i64
external __nx_hset_difference = "__nx_hset_difference" : (id_a: i64, id_b: i64) -> i64
external __nx_hset_free = "__nx_hset_free" : (id: i64) -> bool

// --- Helpers ---

let parse_i64_list_go = fn (s: string, acc: [ i64 ]) -> [ i64 ] do
  if length(s: s) == 0 then
    return acc
  else
    let idx = index_of(s: s, sub: "\n")
    if idx < 0 then
      let v = to_i64(s: s)
      return v :: acc
    else
      let head = substring(s: s, start: 0, len: idx)
      let v = to_i64(s: head)
      let tail_start = idx + 1
      let tail_len = length(s: s) - tail_start
      let tail = substring(s: s, start: tail_start, len: tail_len)
      let next = v :: acc
      return parse_i64_list_go(s: tail, acc: next)
    end
  end
end

let reverse_go = fn <T>(xs: [ T ], acc: [ T ]) -> [ T ] do
  match xs do
    | [] -> return acc
    | v :: rest ->
      let next = v :: acc
      return reverse_go(xs: rest, acc: next)
  end
end

let parse_i64_list = fn (s: string) -> [ i64 ] do
  return reverse_go(xs: parse_i64_list_go(s: s, acc: []), acc: [])
end

let insert_list_go = fn (id: i64, xs: [ i64 ]) -> unit do
  match xs do
    | [] -> return ()
    | v :: rest ->
      let _ = __nx_hset_insert(id: id, val: v)
      return insert_list_go(id: id, xs: rest)
  end
end

// --- Public API ---

/// Creates an empty set.
export let empty = fn () -> %Set do
  let id = __nx_hset_new()
  let s = Set(id: id)
  let %ls = s
  return %ls
end

/// Inserts a value into the set. Consumes and returns the set.
export let insert = fn (set: %Set, val: i64) -> %Set do
  let Set(id: id) = set
  let _ = __nx_hset_insert(id: id, val: val)
  let s = Set(id: id)
  let %ls = s
  return %ls
end

/// Returns true if the set contains the given value.
export let contains = fn (set: &Set, val: i64) -> bool do
  let Set(id: id) = set
  return __nx_hset_contains(id: id, val: val)
end

/// Removes a value from the set. Consumes and returns the set.
export let remove = fn (set: %Set, val: i64) -> %Set do
  let Set(id: id) = set
  let _ = __nx_hset_remove(id: id, val: val)
  let s = Set(id: id)
  let %ls = s
  return %ls
end

/// Returns the number of elements in the set.
export let size = fn (set: &Set) -> i64 do
  let Set(id: id) = set
  return __nx_hset_size(id: id)
end

/// Creates a set from a list of values.
export let from_list = fn (xs: [ i64 ]) -> %Set do
  let id = __nx_hset_new()
  let _ = insert_list_go(id: id, xs: xs)
  let s = Set(id: id)
  let %ls = s
  return %ls
end

/// Converts the set to a list of its elements.
export let to_list = fn (set: &Set) -> [ i64 ] do
  let Set(id: id) = set
  let raw = __nx_hset_to_list(id: id)
  return parse_i64_list(s: raw)
end

/// Returns the union of two sets (new set).
export let union = fn (left: &Set, right: &Set) -> %Set do
  let Set(id: lid) = left
  let Set(id: rid) = right
  let new_id = __nx_hset_union(id_a: lid, id_b: rid)
  let s = Set(id: new_id)
  let %ls = s
  return %ls
end

/// Returns the intersection of two sets (new set).
export let intersection = fn (left: &Set, right: &Set) -> %Set do
  let Set(id: lid) = left
  let Set(id: rid) = right
  let new_id = __nx_hset_intersection(id_a: lid, id_b: rid)
  let s = Set(id: new_id)
  let %ls = s
  return %ls
end

/// Returns elements in left that are not in right (new set).
export let difference = fn (left: &Set, right: &Set) -> %Set do
  let Set(id: lid) = left
  let Set(id: rid) = right
  let new_id = __nx_hset_difference(id_a: lid, id_b: rid)
  let s = Set(id: new_id)
  let %ls = s
  return %ls
end

/// Frees the set. Consumes the linear handle.
export let free = fn (set: %Set) -> unit do
  let Set(id: id) = set
  let _ = __nx_hset_free(id: id)
  return ()
end
