pub type SetEq<K> = SetEq(eq: (left: K, right: K) -> bool)
pub type SetHash<K> = SetHash(hash: (key: K) -> i64)
pub type SetKeyOps<K> = SetKeyOps(eq: SetEq<K>, hash: SetHash<K>)

pub type SetEntry<K> = SetEntry(hash: i64, key: K)
pub type Set<K> = Set(key_ops: SetKeyOps<K>, entries: List<SetEntry<K>>)

pub let make_key_ops = fn <K>(eq: (left: K, right: K) -> bool, hash: (key: K) -> i64) -> SetKeyOps<K> do
  let eq_dict = SetEq(eq: eq)
  let hash_dict = SetHash(hash: hash)
  return SetKeyOps(eq: eq_dict, hash: hash_dict)
endfn

let i64_eq = fn (left: i64, right: i64) -> bool do
  return left == right
endfn

let i64_hash = fn (key: i64) -> i64 do
  if key < 0 then
    return 0 - key
  else
    return key
  endif
endfn

pub let i64_key_ops = fn () -> SetKeyOps<i64> do
  return make_key_ops(eq: i64_eq, hash: i64_hash)
endfn

let key_eq = fn <K>(key_ops: SetKeyOps<K>, left: K, right: K) -> bool do
  match key_ops do
    case SetKeyOps(eq: eq_dict, hash: _) ->
      match eq_dict do
        case SetEq(eq: eq_fn) -> return eq_fn(left: left, right: right)
      endmatch
  endmatch
endfn

let key_hash = fn <K>(key_ops: SetKeyOps<K>, key: K) -> i64 do
  match key_ops do
    case SetKeyOps(eq: _, hash: hash_dict) ->
      match hash_dict do
        case SetHash(hash: hash_fn) -> return hash_fn(key: key)
      endmatch
  endmatch
endfn

let reverse_go = fn <T>(xs: List<T>, acc: List<T>) -> List<T> do
  match xs do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) ->
      let next = Cons(v: v, rest: acc)
      return reverse_go(xs: rest, acc: next)
  endmatch
endfn

let reverse = fn <T>(xs: List<T>) -> List<T> do
  let empty = Nil()
  return reverse_go(xs: xs, acc: empty)
endfn

let set_key_ops = fn <K>(set: Set<K>) -> SetKeyOps<K> do
  match set do
    case Set(key_ops: key_ops, entries: _) -> return key_ops
  endmatch
endfn

let set_entries = fn <K>(set: Set<K>) -> List<SetEntry<K>> do
  match set do
    case Set(key_ops: _, entries: entries) -> return entries
  endmatch
endfn

pub let empty = fn <K>(key_ops: SetKeyOps<K>) -> Set<K> do
  let empty_entries = Nil()
  return Set(key_ops: key_ops, entries: empty_entries)
endfn

let contains_go = fn <K>(xs: List<SetEntry<K>>, key_ops: SetKeyOps<K>, target_hash: i64, target_key: K) -> bool do
  match xs do
    case Nil() -> return false
    case Cons(v: entry, rest: rest) ->
      match entry do
        case SetEntry(hash: hash, key: key) ->
          if hash == target_hash then
            if key_eq(key_ops: key_ops, left: key, right: target_key) then
              return true
            else
              return contains_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key)
            endif
          else
            return contains_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key)
          endif
      endmatch
  endmatch
endfn

pub let contains = fn <K>(set: Set<K>, val: K) -> bool do
  let ops = set_key_ops(set: set)
  let h = key_hash(key_ops: ops, key: val)
  let xs = set_entries(set: set)
  return contains_go(xs: xs, key_ops: ops, target_hash: h, target_key: val)
endfn

let remove_go = fn <K>(xs: List<SetEntry<K>>, key_ops: SetKeyOps<K>, target_hash: i64, target_key: K, acc: List<SetEntry<K>>) -> List<SetEntry<K>> do
  match xs do
    case Nil() -> return reverse(xs: acc)
    case Cons(v: entry, rest: rest) ->
      match entry do
        case SetEntry(hash: hash, key: key) ->
          if hash == target_hash then
            if key_eq(key_ops: key_ops, left: key, right: target_key) then
              return remove_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key, acc: acc)
            else
              let keep = SetEntry(hash: hash, key: key)
              let next = Cons(v: keep, rest: acc)
              return remove_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key, acc: next)
            endif
          else
            let keep = SetEntry(hash: hash, key: key)
            let next = Cons(v: keep, rest: acc)
            return remove_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key, acc: next)
          endif
      endmatch
  endmatch
endfn

pub let remove = fn <K>(set: Set<K>, val: K) -> Set<K> do
  let ops = set_key_ops(set: set)
  let h = key_hash(key_ops: ops, key: val)
  let xs = set_entries(set: set)
  let empty_entries = Nil()
  let next = remove_go(xs: xs, key_ops: ops, target_hash: h, target_key: val, acc: empty_entries)
  return Set(key_ops: ops, entries: next)
endfn

pub let insert = fn <K>(set: Set<K>, val: K) -> Set<K> do
  let ops = set_key_ops(set: set)
  let h = key_hash(key_ops: ops, key: val)
  let xs = set_entries(set: set)
  if contains_go(xs: xs, key_ops: ops, target_hash: h, target_key: val) then
    return set
  else
    let entry = SetEntry(hash: h, key: val)
    let next = Cons(v: entry, rest: xs)
    return Set(key_ops: ops, entries: next)
  endif
endfn

let insert_go = fn <K>(xs: List<K>, set: Set<K>) -> Set<K> do
  match xs do
    case Nil() -> return set
    case Cons(v: v, rest: rest) ->
      let next = insert(set: set, val: v)
      return insert_go(xs: rest, set: next)
  endmatch
endfn

pub let from_list = fn <K>(key_ops: SetKeyOps<K>, xs: List<K>) -> Set<K> do
  let init = empty(key_ops: key_ops)
  return insert_go(xs: xs, set: init)
endfn

let to_list_go = fn <K>(xs: List<SetEntry<K>>, acc: List<K>) -> List<K> do
  match xs do
    case Nil() -> return reverse(xs: acc)
    case Cons(v: entry, rest: rest) ->
      match entry do
        case SetEntry(hash: _, key: key) ->
          let next = Cons(v: key, rest: acc)
          return to_list_go(xs: rest, acc: next)
      endmatch
  endmatch
endfn

pub let to_list = fn <K>(set: Set<K>) -> List<K> do
  let xs = set_entries(set: set)
  let empty_values = Nil()
  return to_list_go(xs: xs, acc: empty_values)
endfn

let size_go = fn <T>(xs: List<T>, acc: i64) -> i64 do
  match xs do
    case Nil() -> return acc
    case Cons(v: _, rest: rest) ->
      let next = acc + 1
      return size_go(xs: rest, acc: next)
  endmatch
endfn

pub let size = fn <K>(set: Set<K>) -> i64 do
  let xs = set_entries(set: set)
  return size_go(xs: xs, acc: 0)
endfn

let union_go = fn <K>(xs: List<K>, acc: Set<K>) -> Set<K> do
  match xs do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) ->
      let next = insert(set: acc, val: v)
      return union_go(xs: rest, acc: next)
  endmatch
endfn

pub let union = fn <K>(left: Set<K>, right: Set<K>) -> Set<K> do
  let xs = to_list(set: right)
  return union_go(xs: xs, acc: left)
endfn

let intersection_go = fn <K>(xs: List<K>, right: Set<K>, acc: Set<K>) -> Set<K> do
  match xs do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) ->
      if contains(set: right, val: v) then
        let next = insert(set: acc, val: v)
        return intersection_go(xs: rest, right: right, acc: next)
      else
        return intersection_go(xs: rest, right: right, acc: acc)
      endif
  endmatch
endfn

pub let intersection = fn <K>(left: Set<K>, right: Set<K>) -> Set<K> do
  let xs = to_list(set: left)
  let ops = set_key_ops(set: left)
  let init = empty(key_ops: ops)
  return intersection_go(xs: xs, right: right, acc: init)
endfn

let difference_go = fn <K>(xs: List<K>, right: Set<K>, acc: Set<K>) -> Set<K> do
  match xs do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) ->
      if contains(set: right, val: v) then
        return difference_go(xs: rest, right: right, acc: acc)
      else
        let next = insert(set: acc, val: v)
        return difference_go(xs: rest, right: right, acc: next)
      endif
  endmatch
endfn

pub let difference = fn <K>(left: Set<K>, right: Set<K>) -> Set<K> do
  let xs = to_list(set: left)
  let ops = set_key_ops(set: left)
  let init = empty(key_ops: ops)
  return difference_go(xs: xs, right: right, acc: init)
endfn
