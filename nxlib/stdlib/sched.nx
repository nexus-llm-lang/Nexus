/**
 * sched: Cooperative scheduler.
 *
 * Provides a `Sched` capability with `yield()` and `spawn(thunk)` for
 * cooperative multitasking. The `scheduler` handler enqueues the captured
 * continuation `@k` on `yield()`, dequeues the next runnable, and routes
 * it via `__nx_sched_set_next`. `spawn(thunk)` queues the thunk on the
 * host pending stack and threads through a trampoline that forces it.
 * `queue_size` exposes the host FIFO depth for diagnostics.
 *
 * Usage:
 *   inject sched.scheduler do
 *     Sched.yield()                    // suspend, resume next runnable
 *     Sched.spawn(thunk: @body_fn())   // enqueue a fresh fiber
 *   end
 */
import external "nexus:runtime/sched"

external __nx_sched_enqueue = "__nx_sched_enqueue" : (k: @unit) -> unit
external __nx_sched_dequeue = "__nx_sched_dequeue" : () -> @unit
external __nx_sched_set_next = "__nx_sched_set_next" : (k: @unit) -> unit
external __nx_sched_queue_size = "__nx_sched_queue_size" : () -> i64
external __nx_sched_spawn = "__nx_sched_spawn" : (thunk: @i64) -> unit
external __nx_sched_push_pending = "__nx_sched_push_pending" : (thunk: @i64) -> unit
external __nx_sched_pop_pending = "__nx_sched_pop_pending" : () -> @i64

/// Trampoline function used by spawn(): pops a pending thunk and forces it.
/// Each `Sched.spawn(thunk: t)` call emits inline code that:
///   1. push_pending(t)   — host stashes t in a FIFO of pending thunks
///   2. allocate cont_table slot, cont.new($__nx_sched_trampoline_body)
///   3. enqueue(slot)     — slot joins the round-robin run queue
/// When the dispatcher dequeues that slot and resumes the cont, this body runs:
/// it pulls the matching thunk and forces it, executing the spawned fiber.
export let __nx_sched_trampoline_body = fn () -> unit do
  let t = __nx_sched_pop_pending()
  let _ = @t
  return ()
end

cap Sched do
  fn yield() -> unit
  fn spawn(thunk: @i64) -> unit
end

export let scheduler = handler Sched do
  fn yield() -> unit with @k do
    __nx_sched_enqueue(k: k)
    let next = __nx_sched_dequeue()
    __nx_sched_set_next(k: next)
  end
  fn spawn(thunk: @i64) -> unit with @k do
    __nx_sched_spawn(thunk: thunk)
    @k
  end
end

export let queue_size = fn () -> i64 do
  return __nx_sched_queue_size()
end
