/** tuple: Pair type for combining two values. */

/// A pair of two values.
pub type Pair<A, B> = Pair(left: A, right: B)

/// Returns the first element of a pair.
pub let fst = fn <A, B>(p: Pair<A, B>) -> A do
  match p do
    case Pair(left: l, _) -> return l
  end
end

/// Returns the second element of a pair.
pub let snd = fn <A, B>(p: Pair<A, B>) -> B do
  match p do
    case Pair(right: r, _) -> return r
  end
end
