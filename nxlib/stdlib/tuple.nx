/** tuple: Pair type for combining two values. */

/// A pair of two values.
export type Pair<A, B> = Pair(left: A, right: B)

/// Returns the first element of a pair.
export let fst = fn <A, B>(p: Pair<A, B>) -> A do
  let Pair(left: l, _) = p
  return l
end

/// Returns the second element of a pair.
export let snd = fn <A, B>(p: Pair<A, B>) -> B do
  let Pair(right: r, _) = p
  return r
end
