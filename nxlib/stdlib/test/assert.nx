/**
 * test/assert: Assertion helpers for .nx test fixtures.
 *
 * Provides a small expect/assert API modeled after helpers that have
 * been duplicated across bootstrap/tests/fixtures/. Each helper raises
 * AssertionFailed (a domain-specific exception) on failure with a
 * multi-line message that includes the operator, both operands, and the
 * caller-supplied label.
 *
 * Diff rendering for strings is line-based: the message contains the two
 * full strings prefixed with `actual:` / `expected:` and a per-line
 * `- expected` / `+ actual` block when they differ. This is intentionally
 * simpler than pretty_assertions but mirrors what assert_eq printers
 * surface for short snapshots.
 */

import { from_i64, from_bool, split, join, length as str_length } from "std:str"
import { length as list_length, fold_left, reverse, map } from "std:list"

/// Raised by every helper in this module on failure. The single `msg`
/// field carries the rendered diff so test runners can print it
/// verbatim.
export exception AssertionFailed(msg: string)

let indent_lines = fn (s: string, prefix: string) -> string do
  let lines = split(s, sep: "\n")
  let prefixed = map(xs: lines, f: fn (val: string) -> string do
    return prefix ++ val
  end)
  return join(xs: prefixed, sep: "\n")
end

/// Assert a boolean condition; raise AssertionFailed on `false`.
export let assert_true = fn (cond: bool, label: string) -> unit throws { Exn } do
  if cond then
    return ()
  else
    raise AssertionFailed(msg: "assert_true failed: " ++ label ++ "\n  expected: true\n  actual:   false")
  end
end

/// Assert a boolean condition is `false`.
export let assert_false = fn (cond: bool, label: string) -> unit throws { Exn } do
  if cond then
    raise AssertionFailed(msg: "assert_false failed: " ++ label ++ "\n  expected: false\n  actual:   true")
  else
    return ()
  end
end

/// Plain assertion with caller-supplied message; equivalent to the inline
/// `assert` helper duplicated across fixture files.
export let assert = fn (cond: bool, label: string) -> unit throws { Exn } do
  return assert_true(cond, label)
end

/// Equality assertion for i64. Renders both values on failure.
export let assert_eq_i64 = fn (actual: i64, expected: i64, label: string) -> unit throws { Exn } do
  if actual == expected then
    return ()
  else
    let msg = "assert_eq_i64 failed: " ++ label
      ++ "\n  expected: " ++ from_i64(val: expected)
      ++ "\n  actual:   " ++ from_i64(val: actual)
    raise AssertionFailed(msg)
  end
end

/// Inequality assertion for i64.
export let assert_ne_i64 = fn (actual: i64, forbidden: i64, label: string) -> unit throws { Exn } do
  if actual == forbidden then
    let msg = "assert_ne_i64 failed: " ++ label
      ++ "\n  forbidden: " ++ from_i64(val: forbidden)
      ++ "\n  actual:    " ++ from_i64(val: actual)
    raise AssertionFailed(msg)
  else
    return ()
  end
end

/// Equality assertion for bool.
export let assert_eq_bool = fn (actual: bool, expected: bool, label: string) -> unit throws { Exn } do
  if actual == expected then
    return ()
  else
    let msg = "assert_eq_bool failed: " ++ label
      ++ "\n  expected: " ++ from_bool(val: expected)
      ++ "\n  actual:   " ++ from_bool(val: actual)
    raise AssertionFailed(msg)
  end
end

/// String equality with a per-line diff on mismatch.
export let assert_eq_string = fn (actual: string, expected: string, label: string) -> unit throws { Exn } do
  if actual == expected then
    return ()
  else
    let diff = render_string_diff(actual, expected)
    let msg = "assert_eq_string failed: " ++ label ++ "\n" ++ diff
    raise AssertionFailed(msg)
  end
end

/// Substring containment for strings.
export let assert_str_contains = fn (haystack: string, needle: string, label: string) -> unit throws { Exn } do
  if str_contains(haystack, needle) then
    return ()
  else
    let msg = "assert_str_contains failed: " ++ label
      ++ "\n  needle:   " ++ needle
      ++ "\n  haystack: " ++ haystack
    raise AssertionFailed(msg)
  end
end

/// Equality assertion for i64 lists. Renders both lists on mismatch.
export let assert_eq_i64_list = fn (actual: [ i64 ], expected: [ i64 ], label: string) -> unit throws { Exn } do
  if i64_list_eq(xs: actual, ys: expected) then
    return ()
  else
    let msg = "assert_eq_i64_list failed: " ++ label
      ++ "\n  expected: " ++ render_i64_list(xs: expected)
      ++ "\n  actual:   " ++ render_i64_list(xs: actual)
    raise AssertionFailed(msg)
  end
end

/// Equality assertion for string lists.
export let assert_eq_string_list = fn (actual: [ string ], expected: [ string ], label: string) -> unit throws { Exn } do
  if string_list_eq(xs: actual, ys: expected) then
    return ()
  else
    let msg = "assert_eq_string_list failed: " ++ label
      ++ "\n" ++ render_string_list_diff(actual, expected)
    raise AssertionFailed(msg)
  end
end

/// Equality assertion that takes a user-supplied formatter; the formatter
/// is only invoked on failure, so callers don't pay rendering cost on the
/// success path.
export let assert_eq_with = fn <T>(actual: T, expected: T, eq: (a: T, b: T) -> bool, fmt: (val: T) -> string, label: string) -> unit throws { Exn } do
  if eq(a: actual, b: expected) then
    return ()
  else
    let actual_str = fmt(val: actual)
    let expected_str = fmt(val: expected)
    let diff = render_string_diff(actual: actual_str, expected: expected_str)
    let msg = "assert_eq_with failed: " ++ label ++ "\n" ++ diff
    raise AssertionFailed(msg)
  end
end

// ─── Renderers ───────────────────────────────────────────────────────────────

let render_i64_list = fn (xs: [ i64 ]) -> string do
  let parts = map(xs, f: fn (val: i64) -> string do
    return from_i64(val)
  end)
  return "[" ++ join(xs: parts, sep: ", ") ++ "]"
end

let i64_list_eq = fn (xs: [ i64 ], ys: [ i64 ]) -> bool do
  match xs do
    | [] ->
      match ys do
        | [] -> return true
        | _ :: _ -> return false
      end
    | x :: xrest ->
      match ys do
        | [] -> return false
        | y :: yrest ->
          if x == y then
            return i64_list_eq(xs: xrest, ys: yrest)
          else
            return false
          end
      end
  end
end

let string_list_eq = fn (xs: [ string ], ys: [ string ]) -> bool do
  match xs do
    | [] ->
      match ys do
        | [] -> return true
        | _ :: _ -> return false
      end
    | x :: xrest ->
      match ys do
        | [] -> return false
        | y :: yrest ->
          if x == y then
            return string_list_eq(xs: xrest, ys: yrest)
          else
            return false
          end
      end
  end
end

let render_string_diff = fn (actual: string, expected: string) -> string do
  return "  expected:\n" ++ indent_lines(s: expected, prefix: "    | ")
    ++ "\n  actual:\n" ++ indent_lines(s: actual, prefix: "    | ")
    ++ "\n  line-diff:\n" ++ render_line_diff(actual, expected)
end

let render_string_list_diff = fn (actual: [ string ], expected: [ string ]) -> string do
  return "  expected:\n" ++ indent_lines(s: join(xs: expected, sep: "\n"), prefix: "    | ")
    ++ "\n  actual:\n" ++ indent_lines(s: join(xs: actual, sep: "\n"), prefix: "    | ")
end

// ─── Per-line diff (intentionally simple) ────────────────────────────────────

let line_diff_walk = fn (actual_lines: [ string ], expected_lines: [ string ], idx: i64, acc: [ string ]) -> [ string ] do
  match actual_lines do
    | [] ->
      match expected_lines do
        | [] -> return reverse(xs: acc)
        | e :: erest ->
          let line = "    -[" ++ from_i64(val: idx) ++ "] " ++ e
          return line_diff_walk(actual_lines, expected_lines: erest, idx: idx + 1, acc: line :: acc)
      end
    | a :: arest ->
      match expected_lines do
        | [] ->
          let line = "    +[" ++ from_i64(val: idx) ++ "] " ++ a
          return line_diff_walk(actual_lines: arest, expected_lines, idx: idx + 1, acc: line :: acc)
        | e :: erest ->
          if a == e then
            let line = "     [" ++ from_i64(val: idx) ++ "] " ++ a
            return line_diff_walk(actual_lines: arest, expected_lines: erest, idx: idx + 1, acc: line :: acc)
          else
            let minus = "    -[" ++ from_i64(val: idx) ++ "] " ++ e
            let plus = "    +[" ++ from_i64(val: idx) ++ "] " ++ a
            let acc1 = minus :: acc
            return line_diff_walk(actual_lines: arest, expected_lines: erest, idx: idx + 1, acc: plus :: acc1)
          end
      end
  end
end

let render_line_diff = fn (actual: string, expected: string) -> string do
  let actual_lines = split(s: actual, sep: "\n")
  let expected_lines = split(s: expected, sep: "\n")
  let diff_lines = line_diff_walk(actual_lines, expected_lines, idx: 0, acc: [])
  return join(xs: diff_lines, sep: "\n")
end

// ─── String contains (kept local to avoid circular import via str.contains) ──

external __nx_string_contains = "__nx_string_contains" : (s: string, sub: string) -> bool

let str_contains = fn (haystack: string, needle: string) -> bool do
  return __nx_string_contains(s: haystack, sub: needle)
end
