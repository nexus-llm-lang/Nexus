/**
 * test/snapshot: insta-compatible snapshot assertions.
 *
 * Workflow (matches `cargo insta`):
 *   1. First run for a given (dir, name) writes `<dir>/<name>.snap.new`
 *      and raises SnapshotPending so the test fails loudly.
 *   2. After human review the user renames `.snap.new` → `.snap`.
 *      Subsequent runs read `.snap` and compare; matches return ok,
 *      mismatches write `.snap.new` and raise SnapshotMismatch.
 *   3. With env var `NEXUS_SNAPSHOT_UPDATE=always` the helper accepts the
 *      current body unconditionally and writes `.snap` directly — used by
 *      the equivalent of `INSTA_UPDATE=always`.
 *
 * File format mirrors insta's textual snapshots:
 *
 *   ---
 *   source: <source>
 *   expression: <name>
 *   ---
 *   <body>
 *
 * Existing snapshot fixtures under bootstrap/tests/stdlib/snapshots/ load
 * round-trip through parse_snapshot + format_snapshot so .nx-side ports of
 * those tests can reuse the legacy fixtures verbatim.
 */

import { Fs } from "std:fs"
import { Env } from "std:env"
import { Option, Some, None } from "std:option"
import { length as str_length, split, join, starts_with } from "std:str"
import { reverse, fold_left } from "std:list"

/// Raised on the first run when no `.snap` file exists yet.
export exception SnapshotPending(name: string, path: string)

/// Raised when the captured body differs from the on-disk snapshot.
export exception SnapshotMismatch(name: string, diff: string)

/// Raised on malformed `.snap` files (missing leading `---` etc.).
export exception SnapshotMalformed(path: string, reason: string)

/// Header metadata of a snapshot file. `source` and `expression` are the
/// two fields produced by insta when the snapshot is recorded; additional
/// keys are kept verbatim in `extras` so round-tripping doesn't lose data.
export type SnapshotHeader = SnapshotHeader(
  source: Option<string>,
  expression: Option<string>,
  extras: [ HeaderEntry ],
)

export type HeaderEntry = HeaderEntry(key: string, value: string)

export type Snapshot = Snapshot(header: SnapshotHeader, body: string)

let empty_header = fn () -> SnapshotHeader do
  return SnapshotHeader(source: None, expression: None, extras: [])
end

// ─── Header serialisation ────────────────────────────────────────────────────

let render_header_lines = fn (header: SnapshotHeader, acc: [ string ]) -> [ string ] do
  let with_source = match header do
    | SnapshotHeader(source: Some(val: s), expression, extras) ->
      let line = "source: " ++ s
      return line :: acc
    | SnapshotHeader(source: None, _) -> return acc
  end
  let with_expr = match header do
    | SnapshotHeader(expression: Some(val: e), _) ->
      let line = "expression: " ++ e
      return line :: with_source
    | SnapshotHeader(expression: None, _) -> return with_source
  end
  let SnapshotHeader(extras: extras) = header
  return fold_left(xs: extras, init: with_expr, f: fn (acc: [ string ], val: HeaderEntry) -> [ string ] do
    let HeaderEntry(key, value) = val
    let line = key ++ ": " ++ value
    return line :: acc
  end)
end

/// Render a Snapshot back to the on-disk `.snap` text.
export let format_snapshot = fn (snap: Snapshot) -> string do
  let Snapshot(header, body) = snap
  let header_lines = reverse(xs: render_header_lines(header, acc: []))
  let header_text = join(xs: header_lines, sep: "\n")
  return "---\n" ++ header_text ++ "\n---\n" ++ body
end

// ─── Header parsing ──────────────────────────────────────────────────────────

let parse_header_field = fn (line: string) -> Option<HeaderEntry> do
  let parts = split(s: line, sep: ": ")
  match parts do
    | [] -> return None
    | _ :: [] -> return None
    | k :: rest ->
      let value = join(xs: rest, sep: ": ")
      return Some(val: HeaderEntry(key: k, value))
  end
end

let collect_header = fn (lines: [ string ], acc_extras: [ HeaderEntry ], acc_source: Option<string>, acc_expr: Option<string>) -> { header: SnapshotHeader, rest: [ string ] } do
  match lines do
    | [] ->
      let header = SnapshotHeader(source: acc_source, expression: acc_expr, extras: reverse(xs: acc_extras))
      return { header: header, rest: [] }
    | line :: rest ->
      if line == "---" then
        let header = SnapshotHeader(source: acc_source, expression: acc_expr, extras: reverse(xs: acc_extras))
        return { header: header, rest: rest }
      else
        match parse_header_field(line) do
          | None ->
            return collect_header(lines: rest, acc_extras, acc_source, acc_expr)
          | Some(val: HeaderEntry(key, value)) ->
            if key == "source" then
              return collect_header(lines: rest, acc_extras, acc_source: Some(val: value), acc_expr)
            else
              if key == "expression" then
                return collect_header(lines: rest, acc_extras, acc_source, acc_expr: Some(val: value))
              else
                let entry = HeaderEntry(key, value)
                return collect_header(lines: rest, acc_extras: entry :: acc_extras, acc_source, acc_expr)
              end
            end
        end
      end
  end
end

/// Parse a `.snap` text payload. Tolerates a trailing newline on the body.
export let parse_snapshot = fn (path: string, text: string) -> Snapshot throws { Exn } do
  let all_lines = split(s: text, sep: "\n")
  match all_lines do
    | first :: rest ->
      if first == "---" then
        let collected = collect_header(lines: rest, acc_extras: [], acc_source: None, acc_expr: None)
        let body = join(xs: collected.rest, sep: "\n")
        let trimmed_body = strip_trailing_newline(body)
        return Snapshot(header: collected.header, body: trimmed_body)
      else
        raise SnapshotMalformed(path, reason: "missing leading '---' header")
      end
    | [] ->
      raise SnapshotMalformed(path, reason: "empty file")
  end
end

let strip_trailing_newline = fn (s: string) -> string do
  let lines = split(s, sep: "\n")
  let rev = reverse(xs: lines)
  match rev do
    | last :: rest ->
      if last == "" then
        return join(xs: reverse(xs: rest), sep: "\n")
      else
        return s
      end
    | [] -> return s
  end
end

// ─── On-disk operations ──────────────────────────────────────────────────────

/// Default snapshot directory — relative to the test runner's cwd.
export let default_snapshot_dir = fn () -> string do
  return "tests/snapshots"
end

let snapshot_path = fn (dir: string, name: string) -> string do
  return dir ++ "/" ++ name ++ ".snap"
end

let pending_path = fn (dir: string, name: string) -> string do
  return dir ++ "/" ++ name ++ ".snap.new"
end

/// Reserved-cell convention for "should accept current run unconditionally"
/// — checked once per `assert_snapshot` call. `NEXUS_SNAPSHOT_UPDATE=always`
/// matches insta's environment variable semantics.
let update_mode = fn () -> bool require { Env } do
  match Env.get(key: "NEXUS_SNAPSHOT_UPDATE") do
    | Some(val: v) -> return v == "always"
    | None -> return false
  end
end

let make_snapshot = fn (name: string, body: string) -> Snapshot do
  let header = SnapshotHeader(source: None, expression: Some(val: name), extras: [])
  return Snapshot(header, body)
end

/// Ensure `dir` exists. Creates intermediate directories.
let ensure_dir = fn (dir: string) -> unit require { Fs } throws { Exn } do
  if Fs.exists(path: dir) then
    return ()
  else
    return Fs.create_dir_all(path: dir)
  end
end

/// Compare two snapshot bodies; returns a human-readable diff.
let render_body_diff = fn (actual: string, expected: string) -> string do
  let alines = split(s: actual, sep: "\n")
  let elines = split(s: expected, sep: "\n")
  return diff_lines(actual_lines: alines, expected_lines: elines, idx: 0, acc: [])
end

let diff_lines = fn (actual_lines: [ string ], expected_lines: [ string ], idx: i64, acc: [ string ]) -> string do
  match actual_lines do
    | [] ->
      match expected_lines do
        | [] -> return join(xs: reverse(xs: acc), sep: "\n")
        | e :: erest ->
          let line = "  - " ++ e
          return diff_lines(actual_lines, expected_lines: erest, idx: idx + 1, acc: line :: acc)
      end
    | a :: arest ->
      match expected_lines do
        | [] ->
          let line = "  + " ++ a
          return diff_lines(actual_lines: arest, expected_lines, idx: idx + 1, acc: line :: acc)
        | e :: erest ->
          if a == e then
            return diff_lines(actual_lines: arest, expected_lines: erest, idx: idx + 1, acc)
          else
            let minus = "  - " ++ e
            let plus = "  + " ++ a
            return diff_lines(actual_lines: arest, expected_lines: erest, idx: idx + 1, acc: plus :: minus :: acc)
          end
      end
  end
end

/// Write the pending snapshot file (`.snap.new`) for human review.
let write_pending = fn (dir: string, name: string, body: string) -> unit require { Fs } throws { Exn } do
  let snap = make_snapshot(name, body)
  let text = format_snapshot(snap)
  let path = pending_path(dir, name)
  return Fs.write_string(path, content: text)
end

/// Accept a snapshot unconditionally — writes `.snap`, removes `.snap.new`.
let accept_snapshot = fn (dir: string, name: string, body: string) -> unit require { Fs } throws { Exn } do
  let snap = make_snapshot(name, body)
  let text = format_snapshot(snap)
  let path = snapshot_path(dir, name)
  let pending = pending_path(dir, name)
  let _ = Fs.write_string(path, content: text)
  if Fs.exists(path: pending) then
    return Fs.remove_file(path: pending)
  else
    return ()
  end
end

/// Compare `body` against `<dir>/<name>.snap`. The function is the public
/// entry point; failure modes raise either SnapshotPending (no baseline)
/// or SnapshotMismatch (baseline disagrees). On NEXUS_SNAPSHOT_UPDATE=always
/// the body is accepted unconditionally and the function returns ok.
export let assert_snapshot_in = fn (dir: string, name: string, body: string) -> unit require { Fs, Env } throws { Exn } do
  let _ = ensure_dir(dir)

  if update_mode() then
    return accept_snapshot(dir, name, body)
  else
    let path = snapshot_path(dir, name)
    if Fs.exists(path) then
      let raw = Fs.read_to_string(path)
      let snap = parse_snapshot(path, text: raw)
      let Snapshot(header, body: stored) = snap
      if stored == body then
        let pending = pending_path(dir, name)
        if Fs.exists(path: pending) then
          return Fs.remove_file(path: pending)
        else
          return ()
        end
      else
        let _ = write_pending(dir, name, body)
        let diff = render_body_diff(actual: body, expected: stored)
        raise SnapshotMismatch(name, diff)
      end
    else
      let _ = write_pending(dir, name, body)
      raise SnapshotPending(name, path: pending_path(dir, name))
    end
  end
end

/// Convenience wrapper using `default_snapshot_dir()`.
export let assert_snapshot = fn (name: string, body: string) -> unit require { Fs, Env } throws { Exn } do
  return assert_snapshot_in(dir: default_snapshot_dir(), name, body)
end
