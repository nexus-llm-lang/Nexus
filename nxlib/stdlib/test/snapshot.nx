/**
 * test/snapshot: File-backed snapshot assertions for .nx test fixtures.
 *
 * Provides `assert_snapshot`, which compares `actual` against a stored
 * snapshot file at `path`. On first run (snapshot absent) or when the
 * environment variable `NEXUS_SNAPSHOT=update` is set, the file is
 * written and the assertion passes. On subsequent runs the file is read
 * and compared via `assert_eq_string`; a mismatch raises `AssertionFailed`.
 *
 * Design note: env-var reads use `std:env::raw_get` (no PermEnv/Env cap
 * needed). Filesystem access does require `%fs: Fs`, which the caller must
 * supply (typically via `inject fs_mod.system_handler`). This keeps the
 * snapshot API consistent with the rest of the fs-using stdlib tests.
 */

import { AssertionFailed, AssertError, assert_eq_string } from "std:test/assert"
import { Fs, FsThrow, FileNotFound, WriteError } from "std:fs"
import { raw_get } from "std:env"
import { Some, None } from "std:option"

/**
Assert that `actual` matches the snapshot stored at `path`.

- If `NEXUS_SNAPSHOT=update` is set in the environment, the file at
  `path` is (re)written with `actual` and the assertion passes.
- If the file does not yet exist, it is created with `actual` and the
  assertion passes (first-run write).
- Otherwise the file is read and compared with `actual` via
  `assert_eq_string`; a mismatch raises `AssertionFailed` whose `msg`
  field includes the per-line diff rendered by that helper.

`label` is forwarded verbatim to `assert_eq_string` on mismatch, and
appears in the diff header exactly as in other assert helpers.

Requires the `Fs` capability to be active in the calling scope.
*/
export let assert_snapshot = fn (actual: string, path: string, label: string) -> unit require { Fs } throws { AssertError | FsThrow } do
  let should_update = match raw_get(key: "NEXUS_SNAPSHOT") do
    | Some(val: v) -> v == "update"
    | None -> false
  end
  let file_exists = Fs.exists(path)
  if should_update || file_exists == false then
    Fs.write_string(path, content: actual)
    return ()
  else
    let expected = Fs.read_to_string(path)
    return assert_eq_string(actual, expected, label)
  end
end
