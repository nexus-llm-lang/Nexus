/**
 * test/property: Property-based testing primitives.
 *
 * A `Gen<T>` is a deterministic function from the RNG state to a `(value,
 * new_state)` pair, paired with a shrinker that produces a finite list of
 * "smaller" candidate values. The library is deliberately minimal: it
 * carries the proptest features actually used by `bootstrap/tests/`
 * (i64 ranges, alphanumeric strings, length-bounded lists, tuples) and
 * leaves regex generation, frequency, and stateful machines out of
 * scope.
 *
 * ── RNG ─────────────────────────────────────────────────────────────────
 *
 * A pure linear-congruential generator with a 64-bit state. Output is
 * reproducible from a seed, which is the property that matters for
 * shrinking: when a counterexample is found, we report the seed so
 * runs are replayable.
 *
 * ── Shrinking ──────────────────────────────────────────────────────────
 *
 * Each `Gen<T>` exposes a `shrink: (val: T) -> [ T ]` companion. The
 * shrink loop performs greedy single-step descent: starting from the
 * failing value, generate candidates, retain the first that still fails
 * the property, repeat until no candidate fails. This is intentionally
 * simpler than proptest's binary-search shrinker but suffices for
 * primitive values and small composite structures.
 */

import { from_i64, from_char_code, length as str_length, byte_substring, byte_length, contains as str_contains, join } from "std:str"
import { length as list_length, fold_left, reverse, map, take, drop_n } from "std:list"
import { Option, Some, None } from "std:option"

// ─── PRNG ────────────────────────────────────────────────────────────────────

/// 64-bit linear congruential RNG state. The constants below are the
/// MMIX/Knuth pair, well-known to give a full period over i64.
export type Rng = Rng(state: i64)

/// Numerically derive a fresh `Rng` from a user-supplied seed.
export let rng_of_seed = fn (seed: i64) -> Rng do
  return Rng(state: seed)
end

let lcg_step = fn (s: i64) -> i64 do
  // (a * s + c) — wrapping i64 arithmetic; the modulus is the implicit i64 overflow.
  return (s * 6364136223846793005) + 1442695040888963407
end

/// Advance the RNG and return a new state plus a 63-bit non-negative
/// magnitude (the high bit is masked off so callers can treat the result
/// as an unsigned magnitude without negative-overflow surprises).
export let rng_next_i64 = fn (rng: Rng) -> { rng: Rng, val: i64 } do
  let Rng(state) = rng
  let next = lcg_step(s: state)
  let masked = mask_high_bit(next)
  return { rng: Rng(state: next), val: masked }
end

let mask_high_bit = fn (val: i64) -> i64 do
  if val < 0 then
    return val + 9223372036854775807 + 1
  else
    return val
  end
end

let modulo = fn (a: i64, m: i64) -> i64 do
  if m == 0 then
    return 0
  else
    let r = a - ((a / m) * m)
    if r < 0 then
      return r + m
    else
      return r
    end
  end
end

// ─── Gen<T> shape ────────────────────────────────────────────────────────────

/// A generator: pure function from RNG state to a value, plus a shrink
/// strategy. Both are first-class function values.
export type Gen<T> = Gen(
  produce: (rng: Rng) -> { rng: Rng, val: T },
  shrink: (val: T) -> [ T ],
)

/// Run a generator once; returns the value and the advanced RNG.
export let gen_run = fn <T>(g: Gen<T>, rng: Rng) -> { rng: Rng, val: T } do
  let Gen(produce, _) = g
  return produce(rng)
end

/// Inspect a generator's shrinker without running it.
export let gen_shrinks = fn <T>(g: Gen<T>, val: T) -> [ T ] do
  let Gen(_, shrink) = g
  return shrink(val)
end

// ─── Primitive generators ───────────────────────────────────────────────────

/// Always produce the same value; no shrinks.
export let gen_const = fn <T>(val: T) -> Gen<T> do
  let produce = fn (rng: Rng) -> { rng: Rng, val: T } do
    return { rng: rng, val: val }
  end
  let shrink = fn (val: T) -> [ T ] do
    return []
  end
  return Gen(produce, shrink)
end

/// Bernoulli-1/2 boolean. Shrinks `true` → `[false]`, `false` is minimal.
export let gen_bool = fn () -> Gen<bool> do
  let produce = fn (rng: Rng) -> { rng: Rng, val: bool } do
    let step = rng_next_i64(rng)
    let bit = modulo(a: step.val, m: 2)
    return { rng: step.rng, val: bit == 1 }
  end
  let shrink = fn (val: bool) -> [ bool ] do
    if val then
      return [ false ]
    else
      return []
    end
  end
  return Gen(produce, shrink)
end

/// Uniform i64 in `[min, max)`. Shrinks toward 0 if 0 is in range,
/// otherwise toward the closer of min/max-1.
export let gen_i64_range = fn (min: i64, max: i64) -> Gen<i64> throws { Exn } do
  if min >= max then
    raise RuntimeError(val: "gen_i64_range: empty range")
  else
    let span = max - min
    let produce = fn (rng: Rng) -> { rng: Rng, val: i64 } do
      let step = rng_next_i64(rng)
      let v = min + modulo(a: step.val, m: span)
      return { rng: step.rng, val: v }
    end
    let shrink = fn (val: i64) -> [ i64 ] do
      return shrink_i64(val, min, max)
    end
    return Gen(produce, shrink)
  end
end

let shrink_i64 = fn (val: i64, min: i64, max: i64) -> [ i64 ] do
  // Candidates: 0, val/2, val-1 (clamped into range).
  let cands = []
  let with_zero = if (min <= 0) && (max > 0) then
    if val == 0 then
      return cands
    else
      return 0 :: cands
    end
  else
    return cands
  end
  let halved = val / 2
  let with_half = if halved == val then
    return with_zero
  else
    if (halved >= min) && (halved < max) then
      return halved :: with_zero
    else
      return with_zero
    end
  end
  let near_zero = if val > 0 then
    return val - 1
  else
    if val < 0 then
      return val + 1
    else
      return val
    end
  end
  let with_step = if (near_zero >= min) && (near_zero < max) && (near_zero != val) then
    return near_zero :: with_half
  else
    return with_half
  end
  return reverse(xs: with_step)
end

// ─── String generators ──────────────────────────────────────────────────────

let alnum_table = fn () -> [ i64 ] do
  // 0..9, A..Z, a..z encoded as ASCII codepoints.
  let digits = build_codes(start: 48, count: 10, acc: [])
  let upper = build_codes(start: 65, count: 26, acc: digits)
  let lower = build_codes(start: 97, count: 26, acc: upper)
  return reverse(xs: lower)
end

let build_codes = fn (start: i64, count: i64, acc: [ i64 ]) -> [ i64 ] do
  if count == 0 then
    return acc
  else
    return build_codes(start: start + 1, count: count - 1, acc: start :: acc)
  end
end

let pick_alnum = fn (rng: Rng, table: [ i64 ]) -> { rng: Rng, code: i64 } throws { Exn } do
  let len = list_length(xs: table)
  if len == 0 then
    raise RuntimeError(val: "pick_alnum: empty alphabet")
  else
    let step = rng_next_i64(rng)
    let idx = modulo(a: step.val, m: len)
    let code = nth_i64(xs: table, n: idx)
    return { rng: step.rng, code }
  end
end

let nth_i64 = fn (xs: [ i64 ], n: i64) -> i64 throws { Exn } do
  match xs do
    | [] -> raise RuntimeError(val: "nth_i64: out of bounds")
    | v :: rest ->
      if n == 0 then
        return v
      else
        return nth_i64(xs: rest, n: n - 1)
      end
  end
end

let build_alnum = fn (rng: Rng, len: i64, table: [ i64 ], acc: string) -> { rng: Rng, val: string } throws { Exn } do
  if len <= 0 then
    return { rng: rng, val: acc }
  else
    let pick = pick_alnum(rng, table)
    let ch = from_char_code(code: pick.code)
    return build_alnum(rng: pick.rng, len: len - 1, table, acc: acc ++ ch)
  end
end

/// Generate alphanumeric strings of length in `[min_len, max_len]`.
/// Mirrors proptest's `"[a-zA-Z0-9]{N,M}"` regex.
export let gen_alphanumeric_string = fn (min_len: i64, max_len: i64) -> Gen<string> throws { Exn } do
  if (min_len < 0) || (max_len < min_len) then
    raise RuntimeError(val: "gen_alphanumeric_string: invalid length range")
  else
    let table = alnum_table()
    let len_span = (max_len - min_len) + 1
    let produce = fn (rng: Rng) -> { rng: Rng, val: string } do
      let lstep = rng_next_i64(rng)
      let len = min_len + modulo(a: lstep.val, m: len_span)
      return build_alnum(rng: lstep.rng, len, table, acc: "")
    end
    let shrink = fn (val: string) -> [ string ] do
      return shrink_string(val, min_len)
    end
    return Gen(produce, shrink)
  end
end

let shrink_string = fn (val: string, min_len: i64) -> [ string ] do
  let cur = str_length(s: val)
  if cur <= min_len then
    return []
  else
    let half = cur / 2
    let cands = []
    let with_min = if min_len < cur then
      return prefix(s: val, n: min_len) :: cands
    else
      return cands
    end
    let with_half = if (half > min_len) && (half < cur) then
      return prefix(s: val, n: half) :: with_min
    else
      return with_min
    end
    let with_minus_one = if (cur - 1) >= min_len then
      return prefix(s: val, n: cur - 1) :: with_half
    else
      return with_half
    end
    return reverse(xs: with_minus_one)
  end
end

let prefix = fn (s: string, n: i64) -> string do
  if n <= 0 then
    return ""
  else
    // Alphanumeric chars are 1 byte each in UTF-8, so byte_substring is
    // a faithful character-prefix when the input came from
    // `gen_alphanumeric_string`.
    let blen = byte_length(s)
    if n >= blen then
      return s
    else
      return byte_substring(s, start: 0, len: n)
    end
  end
end

// ─── Combinators ─────────────────────────────────────────────────────────────

/// Map a generator: derives the produced value through `f`. The shrink
/// strategy is the original generator's shrinker composed with `f`, so
/// shrinks remain meaningful for the new type.
export let gen_map = fn <T, U>(g: Gen<T>, f: (val: T) -> U) -> Gen<U> do
  let Gen(produce, shrink) = g
  let new_produce = fn (rng: Rng) -> { rng: Rng, val: U } do
    let step = produce(rng)
    return { rng: step.rng, val: f(val: step.val) }
  end
  let new_shrink = fn (val: U) -> [ U ] do
    // Without an inverse for f we can't shrink — proptest has the same
    // limitation in its `prop_map` combinator (callers use `prop_filter_map`
    // or supply a custom shrinker for non-trivial maps).
    return []
  end
  return Gen(produce: new_produce, shrink: new_shrink)
end

/// Pair two generators. Shrinks one component at a time.
export let gen_tuple2 = fn <A, B>(ga: Gen<A>, gb: Gen<B>) -> Gen<{ a: A, b: B }> do
  let Gen(produce: pa, shrink: sha) = ga
  let Gen(produce: pb, shrink: shb) = gb
  let produce = fn (rng: Rng) -> { rng: Rng, val: { a: A, b: B } } do
    let astep = pa(rng)
    let bstep = pb(rng: astep.rng)
    return { rng: bstep.rng, val: { a: astep.val, b: bstep.val } }
  end
  let shrink = fn (val: { a: A, b: B }) -> [ { a: A, b: B } ] do
    let { a: a, b: b } = val
    let a_shrinks = sha(val: a)
    let b_shrinks = shb(val: b)
    let from_a = map(xs: a_shrinks, f: fn (a2: A) -> { a: A, b: B } do
      return { a: a2, b: b }
    end)
    let from_b = map(xs: b_shrinks, f: fn (b2: B) -> { a: A, b: B } do
      return { a: a, b: b2 }
    end)
    return concat_pairs(xs: from_a, ys: from_b)
  end
  return Gen(produce, shrink)
end

let concat_pairs = fn <T>(xs: [ T ], ys: [ T ]) -> [ T ] do
  match xs do
    | [] -> return ys
    | v :: rest -> return v :: concat_pairs(xs: rest, ys)
  end
end

/// Generate a list of length in `[min_len, max_len]` from the inner gen.
export let gen_list = fn <T>(inner: Gen<T>, min_len: i64, max_len: i64) -> Gen<[ T ]> throws { Exn } do
  if (min_len < 0) || (max_len < min_len) then
    raise RuntimeError(val: "gen_list: invalid length range")
  else
    let len_span = (max_len - min_len) + 1
    let produce = fn (rng: Rng) -> { rng: Rng, val: [ T ] } do
      let lstep = rng_next_i64(rng)
      let len = min_len + modulo(a: lstep.val, m: len_span)
      return build_list(inner, rng: lstep.rng, len, acc: [])
    end
    let shrink = fn (val: [ T ]) -> [ [ T ] ] do
      return shrink_list(val, min_len)
    end
    return Gen(produce, shrink)
  end
end

let build_list = fn <T>(inner: Gen<T>, rng: Rng, len: i64, acc: [ T ]) -> { rng: Rng, val: [ T ] } do
  if len <= 0 then
    return { rng: rng, val: reverse(xs: acc) }
  else
    let Gen(produce, _) = inner
    let step = produce(rng)
    return build_list(inner, rng: step.rng, len: len - 1, acc: step.val :: acc)
  end
end

let shrink_list = fn <T>(val: [ T ], min_len: i64) -> [ [ T ] ] do
  let cur = list_length(xs: val)
  if cur <= min_len then
    return []
  else
    let half = cur / 2
    let cands = []
    let with_min = if min_len < cur then
      return take(xs: val, n: min_len) :: cands
    else
      return cands
    end
    let with_half = if (half > min_len) && (half < cur) then
      return take(xs: val, n: half) :: with_min
    else
      return with_min
    end
    let with_minus_one = if (cur - 1) >= min_len then
      return take(xs: val, n: cur - 1) :: with_half
    else
      return with_half
    end
    return reverse(xs: with_minus_one)
  end
end

// ─── Test runner ─────────────────────────────────────────────────────────────

/// Result of a single-property run.
export type PropertyOutcome<T> =
    PropertyHolds
  | Counterexample(value: T, after_shrink: T, cases_run: i64)

/// Run `prop` against `cases` random inputs; on first failure, attempt
/// shrinking and return a `Counterexample`. The user-supplied predicate
/// returns `true` on success — same orientation as proptest's
/// `prop_assert!` (truthy = pass).
export let for_all = fn <T>(name: string, gen: Gen<T>, cases: i64, seed: i64, prop: (val: T) -> bool) -> PropertyOutcome<T> do
  let rng = rng_of_seed(seed)
  return run_loop(gen, cases, idx: 0, rng, prop)
end

let run_loop = fn <T>(gen: Gen<T>, cases: i64, idx: i64, rng: Rng, prop: (val: T) -> bool) -> PropertyOutcome<T> do
  if idx >= cases then
    return PropertyHolds
  else
    let step = gen_run(gen, rng)
    if prop(val: step.val) then
      return run_loop(gen, cases, idx: idx + 1, rng: step.rng, prop)
    else
      let shrunk = shrink_loop(gen, original: step.val, prop)
      return Counterexample(value: step.val, after_shrink: shrunk, cases_run: idx + 1)
    end
  end
end

let shrink_loop = fn <T>(gen: Gen<T>, original: T, prop: (val: T) -> bool) -> T do
  let candidates = gen_shrinks(gen, val: original)
  let next = pick_failing(candidates, prop)
  match next do
    | None -> return original
    | Some(val: smaller) -> return shrink_loop(gen, original: smaller, prop)
  end
end

let pick_failing = fn <T>(candidates: [ T ], prop: (val: T) -> bool) -> Option<T> do
  match candidates do
    | [] -> return None
    | v :: rest ->
      if prop(val: v) then
        return pick_failing(candidates: rest, prop)
      else
        return Some(val: v)
      end
  end
end
