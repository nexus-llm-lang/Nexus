/**
 * stringmap: linear hash map from string keys to a generic value type `V`.
 *
 * Open-addressed (linear probing); keys are copied on put. See
 * std:runtime/collection for the i64-channel implementation. Uses opaque
 * linear handles — each map must be freed after use. Suitable for symbol
 * tables, environments, and other string-keyed lookups.
 *
 * Generic over the value type: `%StringMap<V>` stores values of any single
 * type `V` once the instantiation is fixed (value restriction makes each
 * use-site monomorphic). At the WASM level every Nexus value is an i64, so
 * `V` rides the runtime's type-erased i64 value channel; `value_to_i64` /
 * `value_of_i64` are pure type puns that widen/narrow at the FFI boundary.
 */
import { byte_at as str_byte_at, byte_substring } from "std:str"
import * as char from "std:char"
import * as list from "std:list"
import { value_to_i64, value_of_i64 } from "std:runtime/lazy"
import {
  smap_put_str,
  smap_get_str,
  smap_has_str,
  smap_del_str,
  smap_keys_str
} from "std:runtime/collection"
import { smap_new, smap_size, smap_val_count, smap_val_at, smap_free } from "std:runtime/collection"

/** An opaque string map handle (linear — must be freed). The phantom `V`
 *  pins the stored value type so the type-erased i64 channel is not misused
 *  across put/get. */
export opaque type StringMap<V> = StringMap(id: i64)

/** Result of a key lookup: Found with a value, or Missing. */
export type Lookup<V> = Found(value: V) | Missing

// --- Helpers ---

// Read a little-endian u32 from byte offset `off` in `s`.
let read_u32 = fn (s: string, off: i64) -> i64 do
  let b0 = char.ord(c: str_byte_at(s, idx: off))
  let b1 = char.ord(c: str_byte_at(s, idx: off + 1))
  let b2 = char.ord(c: str_byte_at(s, idx: off + 2))
  let b3 = char.ord(c: str_byte_at(s, idx: off + 3))
  return b0 + (b1 * 256) + (b2 * 65536) + (b3 * 16777216)
end

// Decode length-prefixed keys: [count_i32][(len_i32)(bytes)...] -> [string].
// Accumulates in reverse; caller must list.reverse the result.
let decode_keys = fn (s: string, off: i64, cnt: i64, acc: [ string ]) -> [ string ] do
  if cnt <= 0 then
    return acc
  end
  let kl = read_u32(s, off)
  let key = byte_substring(s, start: off + 4, len: kl)
  return decode_keys(s, off: off + 4 + kl, cnt: cnt - 1, acc: key :: acc)
end

let collect_vals = fn <V>(id: i64, idx: i64, count: i64, acc: [ V ]) -> [ V ] do
  if idx >= count then
    return acc
  else
    let v = value_of_i64(a_x: smap_val_at(a_id: id, b_idx: idx))
    return collect_vals(id, idx: idx + 1, count, acc: v :: acc)
  end
end

// --- Public API ---

/** Creates an empty string map. */
export let empty = fn <V>() -> %StringMap<V> do
  let id = smap_new()
  let m = StringMap(id)
  let %lm = m
  return %lm
end

/** Inserts or updates a key-value pair. Consumes and returns the map. */
export let put = fn <V>(map: %StringMap<V>, key: string, value: V) -> %StringMap<V> do
  let StringMap(id) = map
  smap_put_str(id, key, value: value_to_i64(a_x: value))
  let m = StringMap(id)
  let %lm = m
  return %lm
end

/** Looks up a key, returning Found(value) or Missing. */
export let get = fn <V>(map: &StringMap<V>, key: string) -> Lookup<V> do
  let StringMap(id) = map
  let found = smap_has_str(id, key)
  if found then
    let v = value_of_i64(a_x: smap_get_str(id, key, default_val: 0))
    return Found(value: v)
  else
    return Missing
  end
end

/** Looks up a key, returning the value or a default if missing. Single FFI
 *  probe: the typed `default` is punned to the i64 channel and handed to the
 *  runtime, which returns it verbatim for absent keys (keeps the hot path at
 *  one lookup, matching the i64-only map this generalises). */
export let get_or = fn <V>(map: &StringMap<V>, key: string, default: V) -> V do
  let StringMap(id) = map
  return value_of_i64(a_x: smap_get_str(id, key, default_val: value_to_i64(a_x: default)))
end

/** Returns true if the map contains the given key. */
export let contains_key = fn <V>(map: &StringMap<V>, key: string) -> bool do
  let StringMap(id) = map
  return smap_has_str(id, key)
end

/** Removes a key from the map. Consumes and returns the map. */
export let remove = fn <V>(map: %StringMap<V>, key: string) -> %StringMap<V> do
  let StringMap(id) = map
  smap_del_str(id, key)
  let m = StringMap(id)
  let %lm = m
  return %lm
end

/** Returns the number of entries in the map. */
export let size = fn <V>(map: &StringMap<V>) -> i64 do
  let StringMap(id) = map
  return smap_size(a_id: id)
end

/** Returns a list of all keys in the map. */
export let keys = fn <V>(map: &StringMap<V>) -> [ string ] do
  let StringMap(id) = map
  let raw = smap_keys_str(id)
  let n = read_u32(s: raw, off: 0)
  if n <= 0 then
    return []
  end
  let rev = decode_keys(s: raw, off: 4, cnt: n, acc: [])
  return list.reverse(xs: rev)
end

/** Returns a list of all values in the map. */
export let values = fn <V>(map: &StringMap<V>) -> [ V ] do
  let StringMap(id) = map
  let count = smap_val_count(a_id: id)
  let rev = collect_vals(id, idx: 0, count, acc: [])
  return list.reverse(xs: rev)
end

/** Frees the string map. Consumes the linear handle. */
export let free = fn <V>(map: %StringMap<V>) -> unit do
  let StringMap(id) = map
  smap_free(a_id: id)
  return ()
end
