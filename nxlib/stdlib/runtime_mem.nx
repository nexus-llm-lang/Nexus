/**
 * runtime_mem: raw linear-memory load/store + memory.size/grow intrinsics.
 *
 * The compiler (codegen.nx) recognises `nexus:runtime/memory` externals and
 * inline-emits the corresponding WASM op, so these declarations carry no
 * import section overhead — they exist purely as a typed FFI surface.
 *
 * Argument policy (i64 across the FFI boundary, wrapped to i32 internally):
 *   load_i32 / load_u8 / load_i64    : (addr) -> value
 *   store_i32 / store_u8 / store_i64 : (addr, val) -> unit
 *   size  : () -> i64 pages   (wasm `memory.size` extended u→i64)
 *   grow  : (delta_pages) -> i64 prev_pages, or -1 on failure
 *
 * Safety: load / store traps via wasm on out-of-bounds. The unchecked
 * primitives are the inline ops; `safe_load_i32` / `safe_store_i32` wrap
 * them with an explicit bounds check that raises `MemoryOutOfBounds` so
 * callers can catch a domain-specific exception instead of a wasm trap.
 */
import external "nexus:runtime/memory"

/// Raised by safe_* wrappers when the address (plus access size) exceeds
/// the current linear-memory allocation. The unchecked primitives below
/// trap directly via wasm; this exception is the catchable analogue.
export exception MemoryOutOfBounds(op: string, addr: i64, access_size: i64)

/// Load a 32-bit signed integer from linear memory. Traps on OOB.
export external load_i32 = "__nx_mem_load_i32" : (addr: i64) -> i64

/// Store a 32-bit integer to linear memory. Traps on OOB.
export external store_i32 = "__nx_mem_store_i32" : (addr: i64, val: i64) -> unit

/// Load a single byte (zero-extended) from linear memory. Traps on OOB.
export external load_u8 = "__nx_mem_load_u8" : (addr: i64) -> i64

/// Store the low byte of `val` to linear memory. Traps on OOB.
export external store_u8 = "__nx_mem_store_u8" : (addr: i64, val: i64) -> unit

/// Load a 64-bit integer from linear memory. Traps on OOB.
export external load_i64 = "__nx_mem_load_i64" : (addr: i64) -> i64

/// Store a 64-bit integer to linear memory. Traps on OOB.
export external store_i64 = "__nx_mem_store_i64" : (addr: i64, val: i64) -> unit

/// Current linear-memory size in 64KiB pages.
export external size = "__nx_mem_size" : () -> i64

/// Request `delta` more pages. Returns previous page count, or `-1` on
/// failure (no allocation performed).
export external grow = "__nx_mem_grow" : (delta: i64) -> i64

let wasm_page_bytes = fn () -> i64 do return 65536 end

let in_bounds = fn (addr: i64, access_size: i64) -> bool do
  if addr < 0 then return false end
  let total = size() * wasm_page_bytes()
  return addr + access_size <= total
end

/// Bounds-checked 32-bit load. Raises MemoryOutOfBounds when `addr..addr+4`
/// is not within the current memory.
export let safe_load_i32 = fn (addr: i64) -> i64 throws { Exn } do
  if !in_bounds(addr, access_size: 4) then
    raise MemoryOutOfBounds(op: "safe_load_i32", addr, access_size: 4)
  end
  return load_i32(addr)
end

/// Bounds-checked 32-bit store. Raises MemoryOutOfBounds on OOB.
export let safe_store_i32 = fn (addr: i64, val: i64) -> unit throws { Exn } do
  if !in_bounds(addr, access_size: 4) then
    raise MemoryOutOfBounds(op: "safe_store_i32", addr, access_size: 4)
  end
  return store_i32(addr, val)
end

/// Bounds-checked 64-bit load. Raises MemoryOutOfBounds on OOB.
export let safe_load_i64 = fn (addr: i64) -> i64 throws { Exn } do
  if !in_bounds(addr, access_size: 8) then
    raise MemoryOutOfBounds(op: "safe_load_i64", addr, access_size: 8)
  end
  return load_i64(addr)
end

/// Bounds-checked 64-bit store. Raises MemoryOutOfBounds on OOB.
export let safe_store_i64 = fn (addr: i64, val: i64) -> unit throws { Exn } do
  if !in_bounds(addr, access_size: 8) then
    raise MemoryOutOfBounds(op: "safe_store_i64", addr, access_size: 8)
  end
  return store_i64(addr, val)
end

/// Bounds-checked single-byte load. Raises MemoryOutOfBounds on OOB.
export let safe_load_u8 = fn (addr: i64) -> i64 throws { Exn } do
  if !in_bounds(addr, access_size: 1) then
    raise MemoryOutOfBounds(op: "safe_load_u8", addr, access_size: 1)
  end
  return load_u8(addr)
end

/// Bounds-checked single-byte store. Raises MemoryOutOfBounds on OOB.
export let safe_store_u8 = fn (addr: i64, val: i64) -> unit throws { Exn } do
  if !in_bounds(addr, access_size: 1) then
    raise MemoryOutOfBounds(op: "safe_store_u8", addr, access_size: 1)
  end
  return store_u8(addr, val)
end
