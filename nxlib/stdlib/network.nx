/** net: HTTP networking operations. */
import external "std:network"
import { length as str_length, substring, index_of } from "std:str"

/// Raised when an HTTP request fails.
export exception RequestError(url: string)

/// Raised when a server fails to bind to an address.
export exception BindError(addr: string)

/// Raised when sending an HTTP response fails.
export exception ResponseError(msg: string)

external to_i64 = "__nx_string_to_i64" : (s: string) -> i64

/// An HTTP header with a name and value.
export type Header = Header(name: string, value: string)

/// An HTTP response with a status code, headers, and body.
export type Response = Response(status: i64, headers: string, body: string)

/// A running HTTP server handle (linear — must be stopped).
export opaque type Server = Server(id: i64)

/// An incoming HTTP request (linear — must be answered with respond).
export opaque type Request = Request(method: string, path: string, headers: string, body: string, req_id: i64)

/// A streaming response in progress (linear — must be terminated with
/// `respond_streaming_finish` after one or more `respond_streaming_write`
/// calls). Created by `respond_streaming_start`, which consumes the linear
/// `Request`.
export opaque type RespondStream = RespondStream(req_id: i64)

// FFI ABI contract for the externals below.
// Pinned by tests in bootstrap/src/compiler/codegen/emit.rs (abi_tests).
//   string (param)  → WASM (i32 ptr, i32 len)
//   string (return) → WASM packed i64 ((ptr << 32) | len), Packed ABI
//                     (file-path modules like "stdlib/stdlib.wasm")
//   bool   (return) → WASM i32, non-zero = true
// The Rust bindings in bootstrap/src/lib/net/src/lib.rs implement the
// lowered signatures directly.
external __nx_http_request = "__nx_http_request" : (method: string, url: string, headers: string, body: string) -> string
external __nx_http_listen = "__nx_http_listen" : (addr: string) -> i64
external __nx_http_accept = "__nx_http_accept" : (server_id: i64) -> string
external __nx_http_respond = "__nx_http_respond" : (req_id: i64, status: i64, headers: string, body: string) -> bool
external __nx_http_stop = "__nx_http_stop" : (server_id: i64) -> bool
external __nx_http_respond_chunk_start = "__nx_http_respond_chunk_start" : (req_id: i64, status: i64, headers: string) -> bool
external __nx_http_respond_chunk_write = "__nx_http_respond_chunk_write" : (req_id: i64, body_chunk: string) -> bool
external __nx_http_respond_chunk_finish = "__nx_http_respond_chunk_finish" : (req_id: i64) -> bool
external __nx_http_request_with_options = "__nx_http_request_with_options" : (method: string, url: string, headers: string, body: string, timeout_ms: i64) -> string
external __nx_http_cancel_accept = "__nx_http_cancel_accept" : (server_id: i64) -> bool

/// Create a Header.
export let header = fn (name: string, value: string) -> Header do
  return Header(name, value)
end

/// Canonical bridge headers format: 'name:value\n' per header, no space
/// after the colon, single-`\n` terminator, no trailing blank line. The
/// bridge (`bootstrap/src/lib/nexus_host_bridge/src/host_impl.rs`) converts
/// to/from HTTP/1.1 wire form ('name: value\r\n') only at the socket
/// boundary. Spec note: a documented wire-format spec belongs in
/// docs/spec/net.md; that submodule is read-only from this worktree, so the
/// canonical form is pinned in source comments and tests until a doc-update
/// issue lands.
let encode_headers_go = fn (headers: [ Header ], acc: string) -> string do
  match headers do
    | [] -> return acc
    | Header(name, value) :: rest ->
      let line = name ++ ":" ++ value ++ "\n"
      let next = acc ++ line
      return encode_headers_go(headers: rest, acc: next)
  end
end

let encode_headers = fn (headers: [ Header ]) -> string do
  return encode_headers_go(headers, acc: "")
end

let decode_response = fn (raw: string) -> Response do
  let sep1 = index_of(s: raw, sub: "\n")
  if sep1 < 0 then
    return Response(status: 0, headers: "", body: raw)
  else
    let status_s = substring(s: raw, start: 0, len: sep1)
    let status = to_i64(s: status_s)
    let rest1_start = sep1 + 1
    let rest1_len = str_length(s: raw) - rest1_start
    let rest1 = substring(s: raw, start: rest1_start, len: rest1_len)
    let sep2 = index_of(s: rest1, sub: "\n")
    if sep2 < 0 then
      return Response(status, headers: "", body: rest1)
    else
      let hlen_s = substring(s: rest1, start: 0, len: sep2)
      let hlen = to_i64(s: hlen_s)
      let content_start = sep2 + 1
      let headers_s = substring(s: rest1, start: content_start, len: hlen)
      let body_start = content_start + hlen
      let body_len = str_length(s: rest1) - body_start
      let body_s = substring(s: rest1, start: body_start, len: body_len)
      return Response(status, headers: headers_s, body: body_s)
    end
  end
end


let split_at_newline = fn (s: string) -> { head: string, rest: string } do
  let sep = index_of(s, sub: "\n")
  if sep < 0 then
    return { head: s, rest: "" }
  else
    let head = substring(s, start: 0, len: sep)
    let rest_start = sep + 1
    let rest_len = str_length(s) - rest_start
    let rest = substring(s, start: rest_start, len: rest_len)
    return { head: head, rest: rest }
  end
end

let decode_request = fn (raw: string) -> %Request do
  let { head: req_id_s, rest: rest1 } = split_at_newline(s: raw)
  if str_length(s: req_id_s) == 0 then
    let r = Request(method: "", path: "", headers: "", body: "", req_id: -1)
    let %lr = r
    return %lr
  end
  let req_id = to_i64(s: req_id_s)
  let { head: method, rest: rest2 } = split_at_newline(s: rest1)
  let { head: path, rest: rest3 } = split_at_newline(s: rest2)
  let { head: headers, rest: body } = split_at_newline(s: rest3)
  let r = Request(method, path, headers, body, req_id)
  let %lr = r
  return %lr
end

/// Extract the status code from a Response.
export let response_status = fn (res: Response) -> i64 do
  let Response(status, headers: _, body: _) = res
  return status
end

/// Extract the headers string from a Response.
export let response_headers = fn (res: Response) -> string do
  let Response(status: _, headers, body: _) = res
  return headers
end

/// Extract the body from a Response.
export let response_body = fn (res: Response) -> string do
  let Response(status: _, headers: _, body) = res
  return body
end

/// Extract the method from a Request (borrowed).
export let request_method = fn (req: &Request) -> string do
  let Request(method: m, path: _, headers: _, body: _, req_id: _) = req
  return m
end

/// Extract the path from a Request (borrowed).
export let request_path = fn (req: &Request) -> string do
  let Request(method: _, path: p, headers: _, body: _, req_id: _) = req
  return p
end

/// Extract the body from a Request (borrowed).
export let request_body = fn (req: &Request) -> string do
  let Request(method: _, path: _, headers: _, body: b, req_id: _) = req
  return b
end

/// HTTP GET request. Returns the response body. Raises on failure.
let get = fn (url: string) -> string throws { Exn } do
  let res = decode_response(raw: __nx_http_request(method: "GET", url, headers: "", body: ""))
  if response_status(res) == 0 then
    raise RequestError(url)
  else
    return response_body(res)
  end
end

/// HTTP POST request. Returns the response body. Raises on failure.
let post = fn (url: string, body: string) -> string throws { Exn } do
  let res = decode_response(raw: __nx_http_request(method: "POST", url, headers: "", body))
  if response_status(res) == 0 then
    raise RequestError(url)
  else
    return response_body(res)
  end
end

/// HTTP request with custom method and raw header string. Raises on failure.
let request_raw = fn (method: string, url: string, headers: string, body: string) -> Response throws { Exn } do
  let res = decode_response(raw: __nx_http_request(method, url, headers, body))
  if response_status(res) == 0 then
    raise RequestError(url)
  else
    return res
  end
end

/// HTTP request with typed headers. Raises on failure.
let request = fn (method: string, url: string, headers: [ Header ], body: string) -> Response throws { Exn } do
  let encoded = encode_headers(headers)
  return request_raw(method, url, headers: encoded, body)
end

/// Start listening on the given address. Returns a linear server handle. Raises on failure.
let listen = fn (addr: string) -> %Server throws { Exn } do
  let id = __nx_http_listen(addr)
  if id < 0 then
    raise BindError(addr)
  else
    let s = Server(id)
    let %ls = s
    return %ls
  end
end

/// Accept an incoming request from a server (borrows server handle).
/// Returns a linear Request — caller must respond to release host-side resources.
let accept = fn (server: &Server) -> %Request do
  let Server(id) = server
  let raw = __nx_http_accept(server_id: id)
  return decode_request(raw)
end

/// Respond to an incoming request. Consumes the linear Request. Raises on failure.
let respond = fn (req: %Request, status: i64, body: string) -> unit throws { Exn } do
  let Request(method: _, path: _, headers: _, body: _, req_id: rid) = req
  let ok = __nx_http_respond(req_id: rid, status, headers: "", body)
  if ok then
    return ()
  else
    raise ResponseError(msg: "failed to send response")
  end
end

/// Respond to an incoming request with custom headers. Consumes the linear Request. Raises on failure.
let respond_with_headers = fn (req: %Request, status: i64, headers: [ Header ], body: string) -> unit throws { Exn } do
  let Request(method: _, path: _, headers: _, body: _, req_id: rid) = req
  let encoded = encode_headers(headers)
  let ok = __nx_http_respond(req_id: rid, status, headers: encoded, body)
  if ok then
    return ()
  else
    raise ResponseError(msg: "failed to send response")
  end
end

/// Stop a server (consumes the linear handle).
let stop = fn (server: %Server) -> unit do
  let Server(id) = server
  let _ = __nx_http_stop(server_id: id)
  return ()
end

/// Streaming response: open a chunked response on the wire and return a
/// linear `RespondStream` handle. Consumes the linear `Request`. Use
/// `respond_streaming_write` to append chunks (any number of times), then
/// `respond_streaming_finish` to terminate. Raises on failure.
let respond_streaming_start = fn (req: %Request, status: i64, headers: [ Header ]) -> %RespondStream throws { Exn } do
  let Request(method: _, path: _, headers: _, body: _, req_id: rid) = req
  let encoded = encode_headers(headers)
  let ok = __nx_http_respond_chunk_start(req_id: rid, status, headers: encoded)
  if ok then
    let s = RespondStream(req_id: rid)
    let %ls = s
    return %ls
  else
    raise ResponseError(msg: "failed to start streaming response")
  end
end

/// Append a chunk to a streaming response (borrows the handle). Returns true
/// on success.
let respond_streaming_write = fn (stream: &RespondStream, chunk: string) -> bool do
  let RespondStream(req_id: rid) = stream
  return __nx_http_respond_chunk_write(req_id: rid, body_chunk: chunk)
end

/// Terminate a streaming response. Consumes the linear `RespondStream`.
/// Raises on failure.
let respond_streaming_finish = fn (stream: %RespondStream) -> unit throws { Exn } do
  let RespondStream(req_id: rid) = stream
  let ok = __nx_http_respond_chunk_finish(req_id: rid)
  if ok then
    return ()
  else
    raise ResponseError(msg: "failed to finish streaming response")
  end
end

/// HTTP request with custom method, headers, body, and a per-call
/// timeout (milliseconds). `timeout_ms = 0` ⇒ no timeout (identical to
/// `request`). Raises `RequestError` on failure (including timeout).
let request_with_timeout = fn (method: string, url: string, headers: [ Header ], body: string, timeout_ms: i64) -> Response throws { Exn } do
  let encoded = encode_headers(headers)
  let raw = __nx_http_request_with_options(method, url, headers: encoded, body, timeout_ms)
  let res = decode_response(raw)
  if response_status(res) == 0 then
    raise RequestError(url)
  else
    return res
  end
end

/// Cancel a running server's blocking `accept`. Borrows the server handle
/// (does not consume it; the linear `Server` must still be released by
/// `stop`). Idempotent. Returns true if the cancel was accepted.
let cancel_accept = fn (server: &Server) -> bool do
  let Server(id) = server
  return __nx_http_cancel_accept(server_id: id)
end

export cap Net do
  fn get(url: string) -> string throws { Exn }
  fn request(method: string, url: string, headers: [ Header ], body: string) -> Response throws { Exn }
  fn listen(addr: string) -> %Server throws { Exn }
  fn accept(server: &Server) -> %Request
  fn respond(req: %Request, status: i64, body: string) -> unit throws { Exn }
  fn respond_with_headers(req: %Request, status: i64, headers: [ Header ], body: string) -> unit throws { Exn }
  fn stop(server: %Server) -> unit
  fn respond_streaming_start(req: %Request, status: i64, headers: [ Header ]) -> %RespondStream throws { Exn }
  fn respond_streaming_write(stream: &RespondStream, chunk: string) -> bool
  fn respond_streaming_finish(stream: %RespondStream) -> unit throws { Exn }
  fn request_with_timeout(method: string, url: string, headers: [ Header ], body: string, timeout_ms: i64) -> Response throws { Exn }
  fn cancel_accept(server: &Server) -> bool
end

/// Default Net handler — delegates to direct-call API.
export let system_handler = handler Net require { PermNet } do
  fn get(url: string) -> string throws { Exn } do
    return get(url)
  end
  fn request(method: string, url: string, headers: [ Header ], body: string) -> Response throws { Exn } do
    return request(method, url, headers, body)
  end
  fn listen(addr: string) -> %Server throws { Exn } do
    return listen(addr)
  end
  fn accept(server: &Server) -> %Request do
    return accept(server)
  end
  fn respond(req: %Request, status: i64, body: string) -> unit throws { Exn } do
    return respond(req, status, body)
  end
  fn respond_with_headers(req: %Request, status: i64, headers: [ Header ], body: string) -> unit throws { Exn } do
    return respond_with_headers(req, status, headers, body)
  end
  fn stop(server: %Server) -> unit do
    return stop(server)
  end
  fn respond_streaming_start(req: %Request, status: i64, headers: [ Header ]) -> %RespondStream throws { Exn } do
    return respond_streaming_start(req, status, headers)
  end
  fn respond_streaming_write(stream: &RespondStream, chunk: string) -> bool do
    return respond_streaming_write(stream, chunk)
  end
  fn respond_streaming_finish(stream: %RespondStream) -> unit throws { Exn } do
    return respond_streaming_finish(stream)
  end
  fn request_with_timeout(method: string, url: string, headers: [ Header ], body: string, timeout_ms: i64) -> Response throws { Exn } do
    return request_with_timeout(method, url, headers, body, timeout_ms)
  end
  fn cancel_accept(server: &Server) -> bool do
    return cancel_accept(server)
  end
end
