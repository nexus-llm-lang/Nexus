/**
 * list: Singly-linked immutable list and common operations.
 *
 * Lists are the fundamental recursive data structure in Nexus. They are
 * defined as either [] (empty) or Cons (a head element and a tail list).
 * Most operations are implemented as tail-recursive loops with an
 * accumulator, then reversed to preserve order.
 *
 * Higher-order operations (map, fold_left, map_rev) accept function
 * values as parameters. fold_left is the general-purpose reducer;
 * map is built on top of map_rev + reverse.
 */

/// Raised by head/tail/last on an empty list.
export exception EmptyList(op: string)

/// Raised by nth when the index is negative or beyond the list's length.
export exception IndexOutOfBounds(op: string, index: i64)

/// Result of partitioning: elements matching the predicate and the rest.
export type Partition<T> = Partition(matched: [ T ], rest: [ T ])

/// Returns an empty list.
export let empty = fn <T>() -> [ T ] do
  return []
end

/// Prepends an element to the front of the list.
export let cons = fn <T>(x: T, xs: [ T ]) -> [ T ] do
  return x :: xs
end

/// Returns true if the list is empty.
export let is_empty = fn <T>(xs: [ T ]) -> bool do
  match xs do
    | [] -> return true
    | _ :: _ -> return false
  end
end

let length_go = fn <T>(xs: [ T ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return length_go(xs: rest, acc: acc + 1)
  end
end

/// Returns the number of elements in the list.
export let length = fn <T>(xs: [ T ]) -> i64 do
  return length_go(xs: xs, acc: 0)
end

/// Returns the first element. Raises EmptyList on empty list.
export let head = fn <T>(xs: [ T ]) -> T throws { Exn } do
  match xs do
    | [] -> raise EmptyList(op: "head")
    | v :: _ -> return v
  end
end

/// Returns the list without its first element. Raises EmptyList on empty list.
export let tail = fn <T>(xs: [ T ]) -> [ T ] throws { Exn } do
  match xs do
    | [] -> raise EmptyList(op: "tail")
    | _ :: rest -> return rest
  end
end

export let reverse_go = fn <T>(xs: [ T ], acc: [ T ]) -> [ T ] do
  match xs do
    | [] -> return acc
    | v :: rest -> let next = v :: acc
      return reverse_go(xs: rest, acc: next)
  end
end

/// Reverses the list.
export let reverse = fn <T>(xs: [ T ]) -> [ T ] do
  return reverse_go(xs: xs, acc: [])
end

let concat_from_rev = fn <T>(rev_xs: [ T ], ys: [ T ]) -> [ T ] do
  match rev_xs do
    | [] -> return ys
    | v :: rest -> return concat_from_rev(rev_xs: rest, ys: v :: ys)
  end
end

/**
 * Concatenates two lists (xs ++ ys).
 * Tail-recursive: first reverses xs with an accumulator, then folds each
 * element onto ys via a second tail-recursive pass. Safe for arbitrarily
 * long xs; stack depth is O(1).
 */
export let concat = fn <T>(xs: [ T ], ys: [ T ]) -> [ T ] do
  return concat_from_rev(rev_xs: reverse_go(xs: xs, acc: []), ys: ys)
end

/// Returns the last element. Raises EmptyList on empty list.
export let last = fn <T>(xs: [ T ]) -> T throws { Exn } do
  match xs do
    | [] -> raise EmptyList(op: "last")
    | v :: rest ->
      match rest do
        | [] -> return v
        | _ :: _ -> return last(xs: rest)
      end
  end
end

let take_go = fn <T>(xs: [ T ], n: i64, acc: [ T ]) -> [ T ] do
  if n <= 0 then
    return reverse_go(xs: acc, acc: [])
  else
    match xs do
      | [] -> return reverse_go(xs: acc, acc: [])
      | v :: rest -> return take_go(xs: rest, n: n - 1, acc: v :: acc)
    end
  end
end

/// Returns the first n elements.
export let take = fn <T>(xs: [ T ], n: i64) -> [ T ] do
  return take_go(xs: xs, n: n, acc: [])
end

/// Drops the first n elements.
export let drop_n = fn <T>(xs: [ T ], n: i64) -> [ T ] do
  if n <= 0 then
    return xs
  else
    match xs do
      | [] -> return []
      | _ :: rest -> let next_n = n - 1
        return drop_n(xs: rest, n: next_n)
    end
  end
end

/// Returns the element at index n (0-based). Raises IndexOutOfBounds on
/// negative index or when n is beyond the list's length.
export let nth = fn <T>(xs: [ T ], n: i64) -> T throws { Exn } do
  if n < 0 then
    raise IndexOutOfBounds(op: "nth", index: n)
  else
    match xs do
      | [] -> raise IndexOutOfBounds(op: "nth", index: n)
      | v :: rest ->
        if n == 0 then
          return v
        else
          let next_n = n - 1
          return nth(xs: rest, n: next_n)
        end
    end
  end
end

/// Returns true if the i64 list contains the given value.
export let contains = fn (xs: [ i64 ], val: i64) -> bool do
  match xs do
    | [] -> return false
    | v :: rest ->
      if v == val then
        return true
      else
        return contains(xs: rest, val: val)
      end
  end
end

/**
 * Left fold: reduces the list to a single value by applying f to each
 * element from left to right, threading an accumulator through.
 * fold_left(xs: [1,2,3], init: 0, f: add) computes f(f(f(0,1),2),3).
 * Tail-recursive; safe for arbitrarily long lists.
 */
export let fold_left = fn <T, U>(xs: [ T ], init: U, f: (acc: U, val: T) -> U) -> U do
  match xs do
    | [] -> return init
    | v :: rest ->
      let next = f(acc: init, val: v)
      return fold_left(xs: rest, init: next, f: f)
  end
end

export let map_rev_go = fn <T, U>(xs: [ T ], acc: [ U ], f: (val: T) -> U) -> [ U ] do
  match xs do
    | [] -> return acc
    | v :: rest ->
      let mapped = f(val: v)
      let next = mapped :: acc
      return map_rev_go(xs: rest, acc: next, f: f)
  end
end

/**
 * Maps f over the list, returning elements in reverse order.
 * Tail-recursive; useful when order doesn't matter or when
 * the caller will reverse anyway (see map).
 */
export let map_rev = fn <T, U>(xs: [ T ], f: (val: T) -> U) -> [ U ] do
  return map_rev_go(xs: xs, acc: [], f: f)
end

/**
 * Maps f over the list, preserving order.
 * Implemented as map_rev followed by reverse. This ensures the
 * recursive traversal is tail-recursive while still producing
 * output in the original order.
 */
export let map = fn <T, U>(xs: [ T ], f: (val: T) -> U) -> [ U ] do
  return reverse(xs: map_rev(xs: xs, f: f))
end
