/**
 * list: Singly-linked immutable list and common operations.
 *
 * Lists are the fundamental recursive data structure in Nexus. They are
 * defined as either Nil (empty) or Cons (a head element and a tail list).
 * Most operations are implemented as tail-recursive loops with an
 * accumulator, then reversed to preserve order.
 *
 * Higher-order operations (map, fold_left, map_rev) accept function
 * values as parameters. fold_left is the general-purpose reducer;
 * map is built on top of map_rev + reverse.
 */

/// Result of partitioning: elements matching the predicate and the rest.
pub type Partition<T> = Partition(matched: [ T ], rest: [ T ])

/// Returns an empty list.
pub let empty = fn <T>() -> [ T ] do
  return Nil
end

/// Prepends an element to the front of the list.
pub let cons = fn <T>(x: T, xs: [ T ]) -> [ T ] do
  return Cons(v: x, rest: xs)
end

/// Returns true if the list is empty.
pub let is_empty = fn <T>(xs: [ T ]) -> bool do
  match xs do
    case Nil -> return true
    case Cons(v: _, rest: _) -> return false
  end
end

/// Returns the number of elements in the list.
pub let length = fn <T>(xs: [ T ]) -> i64 do
  match xs do
    case Nil -> return 0
    case Cons(v: _, rest: rest) -> return 1 + length(xs: rest)
  end
end

/// Returns the first element. Diverges on empty list.
pub let head = fn <T>(xs: [ T ]) -> T do
  match xs do
    case Nil -> return head(xs: xs)
    case Cons(v: v, rest: _) -> return v
  end
end

/// Returns the list without its first element. Diverges on empty list.
pub let tail = fn <T>(xs: [ T ]) -> [ T ] do
  match xs do
    case Nil -> return tail(xs: xs)
    case Cons(v: _, rest: rest) -> return rest
  end
end

pub let reverse_go = fn <T>(xs: [ T ], acc: [ T ]) -> [ T ] do
  match xs do
    case Nil -> return acc
    case Cons(v: v, rest: rest) -> let next = Cons(v: v, rest: acc)
      return reverse_go(xs: rest, acc: next)
  end
end

/// Reverses the list.
pub let reverse = fn <T>(xs: [ T ]) -> [ T ] do
  return reverse_go(xs: xs, acc: Nil)
end

/**
 * Concatenates two lists (xs ++ ys).
 * Recursively rebuilds xs with ys as the tail. Not tail-recursive;
 * stack depth is proportional to the length of xs.
 */
pub let concat = fn <T>(xs: [ T ], ys: [ T ]) -> [ T ] do
  match xs do
    case Nil -> return ys
    case Cons(v: v, rest: rest) -> return Cons(v: v, rest: concat(xs: rest, ys: ys))
  end
end

/// Returns the last element. Diverges on empty list.
pub let last = fn <T>(xs: [ T ]) -> T do
  match xs do
    case Nil -> return last(xs: xs)
    case Cons(v: v, rest: rest) ->
      match rest do
        case Nil -> return v
        case Cons(v: _, rest: _) -> return last(xs: rest)
      end
  end
end

/// Returns the first n elements.
pub let take = fn <T>(xs: [ T ], n: i64) -> [ T ] do
  if n <= 0 then
    return Nil
  else
    match xs do
      case Nil -> return Nil
      case Cons(v: v, rest: rest) ->
        let next_n = n - 1
        let taken = take(xs: rest, n: next_n)
        return Cons(v: v, rest: taken)
    end
  end
end

/// Drops the first n elements.
pub let drop_n = fn <T>(xs: [ T ], n: i64) -> [ T ] do
  if n <= 0 then
    return xs
  else
    match xs do
      case Nil -> return Nil
      case Cons(v: _, rest: rest) -> let next_n = n - 1
        return drop_n(xs: rest, n: next_n)
    end
  end
end

/// Returns the element at index n (0-based). Diverges on out-of-bounds.
pub let nth = fn <T>(xs: [ T ], n: i64) -> T do
  if n < 0 then
    return nth(xs: xs, n: n)
  else
    match xs do
      case Nil -> return nth(xs: xs, n: n)
      case Cons(v: v, rest: rest) ->
        if n == 0 then
          return v
        else
          let next_n = n - 1
          return nth(xs: rest, n: next_n)
        end
    end
  end
end

/// Returns true if the i64 list contains the given value.
pub let contains = fn (xs: [ i64 ], val: i64) -> bool do
  match xs do
    case Nil -> return false
    case Cons(v: v, rest: rest) ->
      if v == val then
        return true
      else
        return contains(xs: rest, val: val)
      end
  end
end

/**
 * Left fold: reduces the list to a single value by applying f to each
 * element from left to right, threading an accumulator through.
 * fold_left(xs: [1,2,3], init: 0, f: add) computes f(f(f(0,1),2),3).
 * Tail-recursive; safe for arbitrarily long lists.
 */
pub let fold_left = fn <T, U>(xs: [ T ], init: U, f: (acc: U, val: T) -> U) -> U do
  match xs do
    case Nil -> return init
    case Cons(v: v, rest: rest) ->
      let next = f(acc: init, val: v)
      return fold_left(xs: rest, init: next, f: f)
  end
end

pub let map_rev_go = fn <T, U>(xs: [ T ], acc: [ U ], f: (val: T) -> U) -> [ U ] do
  match xs do
    case Nil -> return acc
    case Cons(v: v, rest: rest) ->
      let mapped = f(val: v)
      let next = Cons(v: mapped, rest: acc)
      return map_rev_go(xs: rest, acc: next, f: f)
  end
end

/**
 * Maps f over the list, returning elements in reverse order.
 * Tail-recursive; useful when order doesn't matter or when
 * the caller will reverse anyway (see map).
 */
pub let map_rev = fn <T, U>(xs: [ T ], f: (val: T) -> U) -> [ U ] do
  return map_rev_go(xs: xs, acc: Nil, f: f)
end

/**
 * Maps f over the list, preserving order.
 * Implemented as map_rev followed by reverse. This ensures the
 * recursive traversal is tail-recursive while still producing
 * output in the original order.
 */
pub let map = fn <T, U>(xs: [ T ], f: (val: T) -> U) -> [ U ] do
  return reverse(xs: map_rev(xs: xs, f: f))
end
