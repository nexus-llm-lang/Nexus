/**
 * list: Singly-linked immutable list and common operations.
 *
 * Lists are the fundamental recursive data structure in Nexus. They are
 * defined as either [] (empty) or Cons (a head element and a tail list).
 * Most operations are implemented as tail-recursive loops with an
 * accumulator, then reversed to preserve order.
 *
 * Higher-order operations (map, fold_left, map_rev) accept function
 * values as parameters. fold_left is the general-purpose reducer;
 * map is built on top of map_rev + reverse.
 */

/// Raised by head/tail/last on an empty list.
export exception EmptyList(op: string)

/// Raised by nth when the index is negative or beyond the list's length.
export exception IndexOutOfBounds(op: string, index: i64)

/// Result of partitioning: elements matching the predicate and the rest.
export type Partition<T> = Partition(matched: [ T ], rest: [ T ])

/// Returns an empty list.
export let empty = fn <T>() -> [ T ] do
  return []
end

/// Prepends an element to the front of the list.
export let cons = fn <T>(x: T, xs: [ T ]) -> [ T ] do
  return x :: xs
end

/// Returns true if the list is empty.
export let is_empty = fn <T>(xs: [ T ]) -> bool do
  match xs do
    | [] -> return true
    | _ :: _ -> return false
  end
end

let length_go = fn <T>(xs: [ T ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return length_go(xs: rest, acc: acc + 1)
  end
end

/// Returns the number of elements in the list.
export let length = fn <T>(xs: [ T ]) -> i64 do
  return length_go(xs, acc: 0)
end

/// Returns the first element. Raises EmptyList on empty list.
export let head = fn <T>(xs: [ T ]) -> T throws { Exn } do
  match xs do
    | [] -> raise EmptyList(op: "head")
    | v :: _ -> return v
  end
end

/// Returns the list without its first element. Raises EmptyList on empty list.
export let tail = fn <T>(xs: [ T ]) -> [ T ] throws { Exn } do
  match xs do
    | [] -> raise EmptyList(op: "tail")
    | _ :: rest -> return rest
  end
end

export let reverse_go = fn <T>(xs: [ T ], acc: [ T ]) -> [ T ] do
  match xs do
    | [] -> return acc
    | v :: rest -> let next = v :: acc
      return reverse_go(xs: rest, acc: next)
  end
end

/// Reverses the list.
export let reverse = fn <T>(xs: [ T ]) -> [ T ] do
  return reverse_go(xs, acc: [])
end

let concat_from_rev = fn <T>(rev_xs: [ T ], ys: [ T ]) -> [ T ] do
  match rev_xs do
    | [] -> return ys
    | v :: rest -> return concat_from_rev(rev_xs: rest, ys: v :: ys)
  end
end

/**
 * Concatenates two lists (xs ++ ys).
 * Tail-recursive: first reverses xs with an accumulator, then folds each
 * element onto ys via a second tail-recursive pass. Safe for arbitrarily
 * long xs; stack depth is O(1).
 */
export let concat = fn <T>(xs: [ T ], ys: [ T ]) -> [ T ] do
  return concat_from_rev(rev_xs: reverse_go(xs, acc: []), ys)
end

/// Returns the last element. Raises EmptyList on empty list.
export let last = fn <T>(xs: [ T ]) -> T throws { Exn } do
  match xs do
    | [] -> raise EmptyList(op: "last")
    | v :: rest ->
      match rest do
        | [] -> return v
        | _ :: _ -> return last(xs: rest)
      end
  end
end

let take_go = fn <T>(xs: [ T ], n: i64, acc: [ T ]) -> [ T ] do
  if n <= 0 then
    return reverse_go(xs: acc, acc: [])
  else
    match xs do
      | [] -> return reverse_go(xs: acc, acc: [])
      | v :: rest -> return take_go(xs: rest, n: n - 1, acc: v :: acc)
    end
  end
end

/// Returns the first n elements.
export let take = fn <T>(xs: [ T ], n: i64) -> [ T ] do
  return take_go(xs, n, acc: [])
end

/// Drops the first n elements.
export let drop_n = fn <T>(xs: [ T ], n: i64) -> [ T ] do
  if n <= 0 then
    return xs
  else
    match xs do
      | [] -> return []
      | _ :: rest -> let next_n = n - 1
        return drop_n(xs: rest, n: next_n)
    end
  end
end

/// Returns the element at index n (0-based). Raises IndexOutOfBounds on
/// negative index or when n is beyond the list's length.
export let nth = fn <T>(xs: [ T ], n: i64) -> T throws { Exn } do
  if n < 0 then
    raise IndexOutOfBounds(op: "nth", index: n)
  else
    match xs do
      | [] -> raise IndexOutOfBounds(op: "nth", index: n)
      | v :: rest ->
        if n == 0 then
          return v
        else
          let next_n = n - 1
          return nth(xs: rest, n: next_n)
        end
    end
  end
end

/// Returns true if the i64 list contains the given value.
export let contains = fn (xs: [ i64 ], val: i64) -> bool do
  match xs do
    | [] -> return false
    | v :: rest ->
      if v == val then
        return true
      else
        return contains(xs: rest, val)
      end
  end
end

/**
 * Left fold: reduces the list to a single value by applying f to each
 * element from left to right, threading an accumulator through.
 * fold_left(xs: [1,2,3], init: 0, f: add) computes f(f(f(0,1),2),3).
 * Tail-recursive; safe for arbitrarily long lists.
 */
export let fold_left = fn <T, U>(xs: [ T ], init: U, f: (acc: U, val: T) -> U) -> U do
  match xs do
    | [] -> return init
    | v :: rest ->
      let next = f(acc: init, val: v)
      return fold_left(xs: rest, init: next, f)
  end
end

export let map_rev_go = fn <T, U>(xs: [ T ], acc: [ U ], f: (val: T) -> U) -> [ U ] do
  match xs do
    | [] -> return acc
    | v :: rest ->
      let mapped = f(val: v)
      let next = mapped :: acc
      return map_rev_go(xs: rest, acc: next, f)
  end
end

/**
 * Maps f over the list, returning elements in reverse order.
 * Tail-recursive; useful when order doesn't matter or when
 * the caller will reverse anyway (see map).
 */
export let map_rev = fn <T, U>(xs: [ T ], f: (val: T) -> U) -> [ U ] do
  return map_rev_go(xs, acc: [], f)
end

/**
 * Maps f over the list, preserving order.
 * Implemented as map_rev followed by reverse. This ensures the
 * recursive traversal is tail-recursive while still producing
 * output in the original order.
 */
export let map = fn <T, U>(xs: [ T ], f: (val: T) -> U) -> [ U ] do
  return reverse(xs: map_rev(xs, f))
end

/**
 * Right fold: reduces the list to a single value by applying f to each
 * element from right to left, threading an accumulator through.
 * foldr(xs: [1,2,3], init: 0, f: add) computes f(1, f(2, f(3, 0))).
 *
 * STACK CONSTRAINT: foldr is NOT tail-recursive and consumes O(n) wasm
 * stack proportional to list length. The combiner f is applied on the way
 * back out of the recursion, so the call frames cannot be reused. An
 * accumulator-style rewrite (reverse + fold_left + arg-swapped combiner)
 * would bound the stack at the cost of an extra traversal; the
 * straightforward recursive form is retained for clarity.
 *
 * GUIDANCE:
 *   * For lists with n > ~2048 elements, prefer fold_left (tail-recursive)
 *     and reverse the list first if right-to-left order matters.
 *   * Calling foldr directly on lists of length 100k or more will overflow
 *     the wasm stack. The empirically-safe upper bound on the standard
 *     wasmtime configuration is around n=2048; see
 *     tests/runtime/list_foldr_stack_test.nx for the regression check.
 *   * foldr is retained primarily so the LIR optimiser can fire the
 *     build/foldr deforestation rule (`foldr(k, z, build(g))` -> `g(k, z)`
 *     for pure k); fused call sites never execute the recursive body.
 */
export let foldr = fn <T, U>(xs: [ T ], init: U, f: (val: T, acc: U) -> U) -> U do
  match xs do
    | [] -> return init
    | v :: rest ->
      let folded = foldr(xs: rest, init, f)
      return f(val: v, acc: folded)
  end
end

/**
 * Build: constructs a list from a generator that abstracts over the
 * cons/nil constructors. The generator g receives a pair (cons-equivalent,
 * nil-equivalent) and returns whatever the cons combiner produces; when
 * cons := (::) and nil := [] the call yields a concrete list.
 *
 * On its own, build(g) is just `g(:: , [])`; its purpose is to expose the
 * list construction recipe to the LIR optimiser. The fusion rule
 *
 *     foldr(k, z, build(g)) ≡ g(k, z)
 *
 * is sound for any pure k because foldr replaces the cons placeholder with
 * k and the nil placeholder with z — exactly what build's generator does
 * when supplied (k, z). The optimiser fires the rule only when k's effect
 * summary is pure (issue nexus-j5zi); impure k disables fusion.
 */
export let build = fn <T>(g: (cons: (val: T, rest: [ T ]) -> [ T ], nil: [ T ]) -> [ T ]) -> [ T ] do
  return g(cons: fn (val: T, rest: [ T ]) -> [ T ] do return val :: rest end, nil: [])
end

/**
 * build_k: build/foldr alternative entry whose generator uses non-shadowing
 * label names `k` (cons combiner) and `z` (nil seed). Used by stdlib's
 * `_b` helpers (filter_b/take_b/concat_b/map_b) which would otherwise
 * collide with the toplevel `cons` defined in this module: the resolver
 * picks the toplevel `cons` over a parameter named `cons`, so generators
 * cannot reach the abstract cons-combiner supplied by build. Renaming
 * the labels avoids that collision while remaining a thin wrapper over
 * `build`. The fusion rewriter keys off `build` only (see lir_opt.nx),
 * so callers of `build_k` do not benefit from deforestation; the fusion
 * rule must be extended to cover `build_k` separately if/when the inner
 * resolver bug is fixed and `build_k` is removed.
 */
export let build_k = fn <T>(g: (k: (val: T, rest: [ T ]) -> [ T ], z: [ T ]) -> [ T ]) -> [ T ] do
  return g(k: fn (val: T, rest: [ T ]) -> [ T ] do return val :: rest end, z: [])
end

/**
 * map_b: build/foldr-form of `map`. Equivalent to `map` but expressed as
 * build over a foldr-style generator, making the deforestation rule fire
 * when the result is consumed by another foldr in the same scope.
 *
 *   foldr(k, z, map_b(f, xs))
 *     = foldr(k, z, build(g))     where g(cons, nil) = foldr(xs, nil, fn (v, acc) -> cons(f(v), acc))
 *     ≡ g(k, z)                    [build/foldr fusion]
 *     = foldr(xs, z, fn (v, acc) -> k(f(v), acc))
 *
 * The intermediate `[U]` allocation that ordinary `map` produces is gone.
 */
export let map_b = fn <T, U>(xs: [ T ], f: (val: T) -> U) -> [ U ] do
  return build_k(g: fn (k: (val: U, rest: [ U ]) -> [ U ], z: [ U ]) -> [ U ] do
    return foldr(xs, init: z, f: fn (val: T, acc: [ U ]) -> [ U ] do
      return k(val: f(val), rest: acc)
    end)
  end)
end

/**
 * concat_b: build/foldr-form of `concat`. Both inputs flow through the
 * same abstract `cons` supplied by the consumer; the inner foldr seeds
 * the accumulator with `ys` already folded into the abstract nil, then
 * the outer foldr prepends each element of `xs`.
 *
 *   foldr(k, z, concat_b(xs, ys))
 *     ≡ foldr(xs, foldr(ys, z, k), k)        [build/foldr fusion]
 *
 * Stack depth is O(|xs| + |ys|) — foldr itself is non-tail-recursive.
 */
export let concat_b = fn <T>(xs: [ T ], ys: [ T ]) -> [ T ] do
  return build_k(g: fn (k: (val: T, rest: [ T ]) -> [ T ], z: [ T ]) -> [ T ] do
    let seeded = foldr(xs: ys, init: z, f: fn (val: T, acc: [ T ]) -> [ T ] do
      return k(val: val, rest: acc)
    end)
    return foldr(xs, init: seeded, f: fn (val: T, acc: [ T ]) -> [ T ] do
      return k(val: val, rest: acc)
    end)
  end)
end

/**
 * filter_b: build/foldr-form of `filter`. Threads the predicate `p`
 * through a foldr that conses elements for which `p(val)` is true and
 * skips others. As a build/foldr expression, fuses with a consuming
 * foldr per the `foldr(k, z, build(g)) ≡ g(k, z)` rule.
 *
 *   foldr(k, z, filter_b(xs, p))
 *     ≡ foldr(xs, z, fn (v, acc) -> if p(v) then k(v, acc) else acc)
 */
export let filter_b = fn <T>(xs: [ T ], p: (val: T) -> bool) -> [ T ] do
  return build_k(g: fn (k: (val: T, rest: [ T ]) -> [ T ], z: [ T ]) -> [ T ] do
    return foldr(xs, init: z, f: fn (val: T, acc: [ T ]) -> [ T ] do
      if p(val) then
        return k(val: val, rest: acc)
      else
        return acc
      end
    end)
  end)
end

/**
 * take_b: build/foldr-form of `take`. Uses a CPS-threaded function-typed
 * accumulator `(m: i64) -> [T]`: each step constructs a continuation that,
 * given the remaining count `m`, either stops (m <= 0) or conses the
 * current element and recurses on `m - 1`. The outer fold builds the full
 * continuation, which is then applied to `n`.
 *
 *   foldr(k, z, take_b(xs, n))
 *     ≡ <continuation-eta>            [build/foldr fusion via build's g]
 */
export let take_b = fn <T>(xs: [ T ], n: i64) -> [ T ] do
  return build_k(g: fn (k: (val: T, rest: [ T ]) -> [ T ], z: [ T ]) -> [ T ] do
    let base = fn (m: i64) -> [ T ] do return z end
    let step = fn (val: T, acc: (m: i64) -> [ T ]) -> (m: i64) -> [ T ] do
      return fn (m: i64) -> [ T ] do
        if m <= 0 then
          return z
        else
          return k(val: val, rest: acc(m: m - 1))
        end
      end
    end
    let cont = foldr(xs, init: base, f: step)
    return cont(m: n)
  end)
end

