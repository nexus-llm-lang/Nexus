pub type List<T> = Nil | Cons(v: T, rest: List<T>)

pub let empty = fn <T>() -> List<T> do
  return Nil()
endfn

pub let cons = fn <T>(x: T, xs: List<T>) -> List<T> do
  return Cons(v: x, rest: xs)
endfn

pub let is_empty = fn <T>(xs: List<T>) -> bool do
  match xs do
    case Nil() -> return true
    case Cons(v: _, rest: _) -> return false
  endmatch
endfn

pub let length = fn <T>(xs: List<T>) -> i64 do
  match xs do
    case Nil() -> return 0
    case Cons(v: _, rest: rest) -> return 1 + length(xs: rest)
  endmatch
endfn

pub let head = fn <T>(xs: List<T>) -> T do
  match xs do
    case Nil() -> return head(xs: xs)
    case Cons(v: v, rest: _) -> return v
  endmatch
endfn

pub let tail = fn <T>(xs: List<T>) -> List<T> do
  match xs do
    case Nil() -> return tail(xs: xs)
    case Cons(v: _, rest: rest) -> return rest
  endmatch
endfn

pub let reverse_go = fn <T>(xs: List<T>, acc: List<T>) -> List<T> do
  match xs do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) -> let next = Cons(v: v, rest: acc)
      return reverse_go(xs: rest, acc: next)
  endmatch
endfn

pub let reverse = fn <T>(xs: List<T>) -> List<T> do
  let acc = Nil()
  return reverse_go(xs: xs, acc: acc)
endfn

pub let concat = fn <T>(xs: List<T>, ys: List<T>) -> List<T> do
  match xs do
    case Nil() -> return ys
    case Cons(v: v, rest: rest) -> return Cons(v: v, rest: concat(xs: rest, ys: ys))
  endmatch
endfn

pub let last = fn <T>(xs: List<T>) -> T do
  match xs do
    case Nil() -> return last(xs: xs)
    case Cons(v: v, rest: rest) ->
      match rest do
        case Nil() -> return v
        case Cons(v: _, rest: _) -> return last(xs: rest)
      endmatch
  endmatch
endfn

pub let take = fn <T>(xs: List<T>, n: i64) -> List<T> do
  if n <= 0 then
    return Nil()
  else
    match xs do
      case Nil() -> return Nil()
      case Cons(v: v, rest: rest) ->
        let next_n = n - 1
        let taken = take(xs: rest, n: next_n)
        return Cons(v: v, rest: taken)
    endmatch
  endif
endfn

pub let drop_n = fn <T>(xs: List<T>, n: i64) -> List<T> do
  if n <= 0 then
    return xs
  else
    match xs do
      case Nil() -> return Nil()
      case Cons(v: _, rest: rest) -> let next_n = n - 1
        return drop_n(xs: rest, n: next_n)
    endmatch
  endif
endfn

pub let nth = fn <T>(xs: List<T>, n: i64) -> T do
  if n < 0 then
    return nth(xs: xs, n: n)
  else
    match xs do
      case Nil() -> return nth(xs: xs, n: n)
      case Cons(v: v, rest: rest) ->
        if n == 0 then
          return v
        else
          let next_n = n - 1
          return nth(xs: rest, n: next_n)
        endif
    endmatch
  endif
endfn

pub let contains = fn (xs: List<i64>, val: i64) -> bool do
  match xs do
    case Nil() -> return false
    case Cons(v: v, rest: rest) ->
      if v == val then
        return true
      else
        return contains(xs: rest, val: val)
      endif
  endmatch
endfn

pub let fold_left = fn <T, U>(xs: List<T>, init: U, f: (acc: U, val: T) -> U) -> U do
  match xs do
    case Nil() -> return init
    case Cons(v: v, rest: rest) ->
      let next = f(acc: init, val: v)
      return fold_left(xs: rest, init: next, f: f)
  endmatch
endfn

pub let map_rev_go = fn <T, U>(xs: List<T>, acc: List<U>, f: (val: T) -> U) -> List<U> do
  match xs do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) ->
      let mapped = f(val: v)
      let next = Cons(v: mapped, rest: acc)
      return map_rev_go(xs: rest, acc: next, f: f)
  endmatch
endfn

pub let map_rev = fn <T, U>(xs: List<T>, f: (val: T) -> U) -> List<U> do
  let acc = Nil()
  return map_rev_go(xs: xs, acc: acc, f: f)
endfn

pub let map = fn <T, U>(xs: List<T>, f: (val: T) -> U) -> List<U> do
  let mapped_rev = map_rev(xs: xs, f: f)
  return reverse(xs: mapped_rev)
endfn
