/**
 * task: two-step dispatch for `@`-thunks (sequential, inline).
 *
 * Two-step protocol:
 *
 *   host_spawn : <T>(@T) -> %Task<T>    // consumes the thunk, returns a handle
 *   host_join  : <T>(%Task<T>) -> T     // waits on the handle, returns the value
 *
 * Execution is inline and sequential: `host_spawn` records the thunk in the
 * handle but does NOT force it; `host_join` forces it (no OS thread is created
 * — `wasi.thread-spawn` is never imported). `Task<T>` is an opaque linear
 * wrapper around the runtime task pointer — the linearity checker rejects
 * spawn-without-join, and the phantom `T` keeps the FFI's type-erased i64
 * channel from being misused across the pair.
 *
 * Exception timing: because the thunk is forced at `host_join`, a thunk's
 * exception surfaces at the JOIN point (`docs/spec/lazy.md` §Exception
 * Semantics) — a `try`/`catch` around `host_join` observes it.
 *
 * Single `@x` force is also synchronous (a `call_indirect`); this module and
 * `std:lazy`'s `force_all` drive the multi-thunk paths. `race` / `cancel` /
 * `detach` in `std:lazy` are likewise sequential — true parallelism / cancel /
 * arbiter primitives do not exist on the host.
 *
 * This module imports no host threading primitive; the produced wasm runs on a
 * plain WASI preview1/2/3 runtime.
 */
import * as lz from "std:runtime/lazy"

/** A handle to a spawned thunk. Linear — must be drained by `host_join`. */
export opaque type Task<T> = Task(id: i64)

/**
Record a thunk in a linear handle that must be consumed by `host_join`. The
`@T` is consumed. The thunk is NOT forced here — `host_join` forces it — so a
thunk that throws raises its exception at `host_join`, not at `host_spawn`.
*/
export let host_spawn = fn <T>(a: @T) -> %Task<T> do
  let id = lz.lazy_spawn(a_thunk: a)
  let h = Task(id)
  let %lh = h
  return %lh
end

/**
Await a previously spawned thunk and return its forced value. Consumes the
linear handle. The thunk is forced HERE (inline), so if it throws, the
exception surfaces at this join point — a `try`/`catch` around `host_join`
observes it (`docs/spec/lazy.md` §Exception Semantics). The parameter is
named `handle` because `task` is a reserved keyword.
*/
export let host_join = fn <T>(handle: %Task<T>) -> T do
  let Task(id) = handle
  return lz.lazy_join(a_task: id)
end
