/**
 * Generator / `Yield` abstraction built on `with @k` (delimited continuations).
 *
 * A producer writes straight-line / looping code that `emit`s a value at each
 * step instead of folding a list by hand. An `inject collector ... end` frame
 * suspends at every `emit` (the cap call becomes a stack-switch suspend), the
 * `with @k` handler arm resumes the producer (`@k`), and the producer continues
 * to its next `emit`. This lets traversals with interleaved control flow
 * (early-stop flags, nested loops, conditional emit) be written as imperative
 * code that just emits, rather than as a `fold`/`map` over a pre-built list.
 *
 * LIMITATION (upstream wasmtime, nexus-twyov / bytecodealliance/wasmtime#13584):
 * a producer or handler that terminates via an UNCAUGHT EXCEPTION or a TRAP
 * *after* a resume aborts the whole process (a fiber-stack double-free in
 * wasmtime's experimental stack-switching impl). Keep generator code on the
 * normal exit-0 path; a `try`/`catch` that actually catches is fine.
 *
 * ── Cap is monomorphic over i64 ──────────────────────────────────────────────
 * `Yield` is fixed to `i64` for simplicity. Generic capabilities (`cap Yield<T>`)
 * now parse + type-check (nexus-qzq24), so a generic `Yield<T>` is possible; this
 * module is left monomorphic until there's a concrete need.
 *
 * ── Where the accumulated list lives ─────────────────────────────────────────
 * With this runtime the COLLECTOR HANDLER cannot itself build the list:
 *   - handler arms may not capture a mutable ref (E2001 "refs are stack-confined")
 *   - `@k` resumes with unit; there is no `@k(v)` to thread an accumulator
 *     through the continuation's return
 *   - the inject expression's value is the PRODUCER body's trailing value
 *     (out-of-band channel), not the handler arm's value
 *   - inline (in-function) handlers break cap-call name resolution, so handlers
 *     must be top-level and cannot close over a local accumulator
 * Therefore the producer accumulates into a `~`-mutable list that is declared
 * INSIDE the inject body and returned as that body's trailing value (the only
 * accumulation channel that survives the suspend/resume lift). The `Yield`
 * handler supplies the swappable resume policy and an around-advice point: code
 * in the arm BEFORE `@k` runs once per emit (see `tracing_collector`).
 *
 * ── One-shot only ────────────────────────────────────────────────────────────
 * Each `emit` suspends once and the handler resumes once. No multi-shot /
 * restartable generators (linearity forces `@k` one-shot).
 */
import { Console } from "std:stdio"

/** The generator capability: a producer calls `Yield.emit(v)` at each step. */
export cap Yield do
  fn emit(v: i64) -> unit
end

/**
 * Collector handler: resumes the producer at every `emit` with no side effect.
 * Inject this around a producer body that accumulates its own `~`-mutable list
 * and returns it as the inject's trailing value (see module docstring for why
 * the handler cannot own the list).
 */
export let collector = handler Yield do
  fn emit(v: i64) -> unit with @k do
    @k
  end
end

/**
 * Tracing collector: around-advice variant that prints each emitted value on
 * stdout BEFORE resuming. Demonstrates the `with @k` "around" form — the arm
 * observes the generator stream at each suspend point, then `@k` continues the
 * producer. Swap `collector` for `tracing_collector` at the inject site to make
 * a generator's progress observable without touching the producer.
 */
export let tracing_collector = handler Yield require { Console } do
  fn emit(v: i64) -> unit with @k do
    Console.println(val: "[yield] emit")
    @k
  end
end
