/**
 * lazy: Combinators for lazy (@) thunk evaluation.
 *
 * `force_all` forces every thunk sequentially and inline (the runtime has no
 * OS threads ‚Äî `wasi.thread-spawn` is never imported), then joins the results
 * in input order. A single `@x` force is also synchronous (a `call_indirect`);
 * for explicit per-thunk control use `std:task`'s `host_spawn` /
 * `host_join` directly. A thunk's exception surfaces at the join: it is
 * caught at spawn and re-thrown by `lazy_join` / `host_join`.
 *
 * Spec-vs-impl divergence: `docs/spec/lazy.md` gives `cancel` = "discard
 * without evaluating" and `race` = "loser is cancelled", which would need a
 * runtime drop primitive and a first-of-two arbiter. Neither host primitive
 * exists, so `cancel`/`detach`/`race` force their argument(s) synchronously
 * and dispose of any non-returned forced result through a caller-supplied
 * `drop: (v: T) -> unit` ‚Äî forcing (`@a`) discharges the `@T`, and `drop`
 * consumes the resulting `T`. `detach` is the honest fire-and-forget form.
 */
import * as lz from "std:runtime/lazy"
import * as list from "std:list"

/**
race(a, b, drop): Sequentially force `a` then `b`, returning `a`'s result;
the loser `b`'s forced value is disposed via `drop`.

Spec contract (`docs/spec/lazy.md` ¬ßrace): "Returns first to complete;
loser is cancelled". Without a runtime first-of-two arbiter, this
implementation always forces `a` first, then forces `b` and passes its
value to `drop`. Side effects of `b` are observable.

Operates on `@T` (lazy bindings), not `%Task<T>` handles ‚Äî orthogonal to
`std:task`'s `host_spawn` / `host_join`. A task-handle race requires a
runtime-side "first-of" primitive (not available).
*/
export let race = fn <T>(a: @T, b: @T, drop: (v: T) -> unit) -> T do
  let result = @a
  drop(v: @b)
  return result
end

/**
cancel(a, drop): Discharge a thunk's linearity by forcing it and disposing
the forced result through `drop`.

Spec contract (`docs/spec/lazy.md` ¬ßcancel): "Discard without evaluating".
The only way to consume a linear `@T` in this calculus is to force it
(`@a`); there is no force-free drop. So `cancel` forces `a` and hands the
resulting `T` to the caller-supplied `drop` ‚Äî observationally equivalent to
`detach`: the thunk's body runs and any side effects are observable.
*/
export let cancel = fn <T>(a: @T, drop: (v: T) -> unit) -> unit do
  drop(v: @a)
  return ()
end

/**
detach(a, drop): Force the thunk and dispose the result via `drop`.
Fire-and-forget semantics; useful when the effect of forcing is what
matters, not the value.
*/
export let detach = fn <T>(a: @T, drop: (v: T) -> unit) -> unit do
  drop(v: @a)
  return ()
end

/**
force_all(tasks): Force every thunk in the list sequentially and inline,
returning the results in input order. Forcing is deferred to the join phase:
`spawn_all` records all thunks, then `join_all` forces them left-to-right.
No OS threads exist. A thunk's exception surfaces from its join (inside
`lazy_join`).
*/
export let force_all = fn <T>(tasks: [ @T ]) -> [ T ] do
  let ids = spawn_all(tasks, acc: [])
  return join_all(ids, acc: [])
end

let spawn_all = fn <T>(tasks: [ @T ], acc: [ i64 ]) -> [ i64 ] do
  match tasks do
    | [] -> return list.reverse(xs: acc)
    | t :: rest -> return spawn_all(tasks: rest, acc: lz.lazy_spawn(a_thunk: t) :: acc)
  end
end

let join_all = fn <T>(ids: [ i64 ], acc: [ T ]) -> [ T ] do
  match ids do
    | [] -> return list.reverse(xs: acc)
    | id :: rest -> return join_all(ids: rest, acc: lz.lazy_join(a_task: id) :: acc)
  end
end
