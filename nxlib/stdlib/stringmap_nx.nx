/**
 * stringmap_nx: pure-Nexus string→i64 HashMap, parallel impl to `std:stringmap`.
 *
 * Storage is the open-addressed `std:collection_table` with KIND_STR
 * keys: the table interns each inserted key by copying its bytes
 * through `wasm_alloc.allocate` and storing a pack(ptr,len) in the
 * slot's key field.  Hashing is FNV-1a over the byte sequence.
 *
 * Surface mirrors `std:stringmap` exactly so callers can swap the
 * import.  Linear-handle threading (every consuming op returns
 * %StringMapNx, every read borrows &StringMapNx) matches the FFI variant.
 */
import * as ct from "std:collection_table"

/// An opaque string map handle (linear — must be freed).
export opaque type StringMapNx = StringMapNx(addr: i64)

/// Result of a key lookup: Found with a value, or Missing.
export type StringLookup = StrFound(value: i64) | StrMissing

/// Raised by `get_unchecked` when the queried key is not in the map.
/// Named distinct from `hashmap_nx.IntKeyNotFound` so a single
/// `try ... catch` block can disambiguate per-module.
export exception StrKeyNotFound(op: string, key: string)

// ─── Public API ───────────────────────────────────────────────────────

/// Creates an empty string map.
export let empty = fn () -> %StringMapNx throws { Exn } do
  let addr = ct.new_table(kind: ct.kind_str())
  let m = StringMapNx(addr)
  let %lm = m
  return %lm
end

/// Inserts or updates a key. Consumes and returns the map.  The key
/// bytes are copied into the table's bump-allocated key arena so the
/// caller's string can be freed independently.
export let put = fn (map: %StringMapNx, key: string, value: i64) -> %StringMapNx throws { Exn } do
  let StringMapNx(addr) = map
  let _ = ct.put_str(h: addr, key, val: value)
  let m = StringMapNx(addr)
  let %lm = m
  return %lm
end

/// Looks up a key, returning StrFound(value) or StrMissing.
export let get = fn (map: &StringMapNx, key: string) -> StringLookup throws { Exn } do
  let StringMapNx(addr) = map
  if ct.has_str(h: addr, key) then
    let v = ct.get_str_or(h: addr, key, default_val: 0)
    return StrFound(value: v)
  end
  return StrMissing
end

/// Looks up `key`, returning the value or `default` if missing.
export let get_or = fn (map: &StringMapNx, key: string, default: i64) -> i64 throws { Exn } do
  let StringMapNx(addr) = map
  return ct.get_str_or(h: addr, key, default_val: default)
end

/// Partial: looks up `key`, raising `StrKeyNotFound` when absent
/// (acceptance criterion 3).  Use the safe `get`/`get_or` paths
/// otherwise.
export let get_unchecked = fn (map: &StringMapNx, key: string) -> i64 throws { Exn } do
  let StringMapNx(addr) = map
  if ct.has_str(h: addr, key) then
    return ct.get_str_or(h: addr, key, default_val: 0)
  end
  raise StrKeyNotFound(op: "stringmap_nx.get_unchecked", key)
end

/// Returns true if the map contains the given key.
export let contains_key = fn (map: &StringMapNx, key: string) -> bool throws { Exn } do
  let StringMapNx(addr) = map
  return ct.has_str(h: addr, key)
end

/// Removes a key. Consumes and returns the map.
export let remove = fn (map: %StringMapNx, key: string) -> %StringMapNx throws { Exn } do
  let StringMapNx(addr) = map
  let _ = ct.remove_str(h: addr, key)
  let m = StringMapNx(addr)
  let %lm = m
  return %lm
end

/// Returns the number of entries.
export let size = fn (map: &StringMapNx) -> i64 do
  let StringMapNx(addr) = map
  return ct.table_size(h: addr)
end

// ─── Iteration ────────────────────────────────────────────────────────

let collect_keys_go = fn (addr: i64, slot_idx: i64, acc: [ string ]) -> [ string ] throws { Exn } do
  let capv = ct.table_cap(h: addr)
  let next = ct.iter_next(h: addr, slot_idx)
  if next >= capv then return acc end
  let k = ct.iter_key_str(h: addr, slot_idx: next)
  return collect_keys_go(addr, slot_idx: next + 1, acc: k :: acc)
end

let collect_vals_go = fn (addr: i64, slot_idx: i64, acc: [ i64 ]) -> [ i64 ] do
  let capv = ct.table_cap(h: addr)
  let next = ct.iter_next(h: addr, slot_idx)
  if next >= capv then return acc end
  let v = ct.iter_val(h: addr, slot_idx: next)
  return collect_vals_go(addr, slot_idx: next + 1, acc: v :: acc)
end

/// Returns a list of all keys (no defined order).
export let keys = fn (map: &StringMapNx) -> [ string ] throws { Exn } do
  let StringMapNx(addr) = map
  return collect_keys_go(addr, slot_idx: 0, acc: [])
end

/// Returns a list of all values (no defined order; parallel to `keys`).
export let values = fn (map: &StringMapNx) -> [ i64 ] do
  let StringMapNx(addr) = map
  return collect_vals_go(addr, slot_idx: 0, acc: [])
end

/// Frees the map. Consumes the linear handle.  Underlying bump
/// storage is reclaimed by the program-scope `wasm_alloc.mark/reset`.
export let free = fn (map: %StringMapNx) -> unit do
  let StringMapNx(addr) = map
  let _ = addr
  return ()
end
