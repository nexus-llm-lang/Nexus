/**
 * char: Character classification functions for Unicode codepoints.
 *
 * All functions take an i64 codepoint (from string.char_code) and return
 * a boolean. Covers ASCII classification needed for lexical analysis.
 */

/// Returns true if the codepoint is an ASCII uppercase letter (A-Z).
pub let is_upper = fn (c: i64) -> bool do
  return c >= 65 && c <= 90
end

/// Returns true if the codepoint is an ASCII lowercase letter (a-z).
pub let is_lower = fn (c: i64) -> bool do
  return c >= 97 && c <= 122
end

/// Returns true if the codepoint is an ASCII letter (a-z, A-Z).
pub let is_alpha = fn (c: i64) -> bool do
  return is_upper(c: c) || is_lower(c: c)
end

/// Returns true if the codepoint is an ASCII digit (0-9).
pub let is_digit = fn (c: i64) -> bool do
  return c >= 48 && c <= 57
end

/// Returns true if the codepoint is an ASCII letter or digit.
pub let is_alnum = fn (c: i64) -> bool do
  return is_alpha(c: c) || is_digit(c: c)
end

/// Returns true if the codepoint is an ASCII hexadecimal digit (0-9, a-f, A-F).
pub let is_hex_digit = fn (c: i64) -> bool do
  return is_digit(c: c) || (c >= 97 && c <= 102) || (c >= 65 && c <= 70)
end

/// Returns true if the codepoint is ASCII whitespace (space, tab, newline, carriage return).
pub let is_whitespace = fn (c: i64) -> bool do
  return c == 32 || c == 9 || c == 10 || c == 13
end

/// Returns true if the codepoint is a valid identifier start (letter or underscore).
pub let is_ident_start = fn (c: i64) -> bool do
  return is_alpha(c: c) || c == 95
end

/// Returns true if the codepoint is a valid identifier continuation (letter, digit, or underscore).
pub let is_ident_char = fn (c: i64) -> bool do
  return is_alnum(c: c) || c == 95
end

/// Returns true if the codepoint is a newline (LF or CR).
pub let is_newline = fn (c: i64) -> bool do
  return c == 10 || c == 13
end

/// Converts a digit codepoint (0-9) to its integer value. Returns -1 for non-digits.
pub let digit_value = fn (c: i64) -> i64 do
  if is_digit(c: c) then
    return c - 48
  else
    return 0 - 1
  end
end

/// Converts a hex digit codepoint to its integer value (0-15). Returns -1 for non-hex-digits.
pub let hex_digit_value = fn (c: i64) -> i64 do
  if is_digit(c: c) then
    return c - 48
  else
    if c >= 97 && c <= 102 then
      return c - 87
    else
      if c >= 65 && c <= 70 then
        return c - 55
      else
        return 0 - 1
      end
    end
  end
end
