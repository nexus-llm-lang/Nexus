/**
 * char: Character classification functions.
 *
 * All functions take a char and return a boolean.
 * Covers ASCII classification needed for lexical analysis.
 */
import external "stdlib/stdlib.wasm"

/// Returns the Unicode codepoint of a char as i64.
export external ord = "__nx_char_ord" : (c: char) -> i64

/// Returns true if the character is an ASCII uppercase letter (A-Z).
export let is_upper = fn (c: char) -> bool do
  return c >= 'A' && c <= 'Z'
end

/// Returns true if the character is an ASCII lowercase letter (a-z).
export let is_lower = fn (c: char) -> bool do
  return c >= 'a' && c <= 'z'
end

/// Returns true if the character is an ASCII letter (a-z, A-Z).
export let is_alpha = fn (c: char) -> bool do
  return is_upper(c: c) || is_lower(c: c)
end

/// Returns true if the character is an ASCII digit (0-9).
export let is_digit = fn (c: char) -> bool do
  return c >= '0' && c <= '9'
end

/// Returns true if the character is an ASCII letter or digit.
export let is_alnum = fn (c: char) -> bool do
  return is_alpha(c: c) || is_digit(c: c)
end

/// Returns true if the character is an ASCII hexadecimal digit (0-9, a-f, A-F).
export let is_hex_digit = fn (c: char) -> bool do
  return is_digit(c: c) || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')
end

/// Returns true if the character is ASCII whitespace (space, tab, newline, carriage return).
export let is_whitespace = fn (c: char) -> bool do
  return c == ' ' || c == '\t' || c == '\n' || c == '\r'
end

/// Returns true if the character is a valid identifier start (letter or underscore).
export let is_ident_start = fn (c: char) -> bool do
  return is_alpha(c: c) || c == '_'
end

/// Returns true if the character is a valid identifier continuation (letter, digit, or underscore).
export let is_ident_char = fn (c: char) -> bool do
  return is_alnum(c: c) || c == '_'
end

/// Returns true if the character is a newline (LF or CR).
export let is_newline = fn (c: char) -> bool do
  return c == '\n' || c == '\r'
end

/// Converts a digit character (0-9) to its integer value. Returns -1 for non-digits.
export let digit_value = fn (c: char) -> i64 do
  if is_digit(c: c) then
    return ord(c: c) - ord(c: '0')
  else
    return 0 - 1
  end
end

/// Converts a hex digit character to its integer value (0-15). Returns -1 for non-hex-digits.
export let hex_digit_value = fn (c: char) -> i64 do
  if is_digit(c: c) then
    return ord(c: c) - ord(c: '0')
  else if c >= 'a' && c <= 'f' then
    return ord(c: c) - ord(c: 'a') + 10
  else if c >= 'A' && c <= 'F' then
    return ord(c: c) - ord(c: 'A') + 10
  else
    return 0 - 1
  end
end
