/**
 * nexus/source_pos: shared (pos, line, col) triple for byte-level scanners.
 *
 * Used by the Nexus lexer's LexerState. `pos` is a byte offset; `line` and
 * `col` are 1-based. Distinct from `Span` in nexus/token, which carries the
 * same shape under different field names (offset, line, col) and lives at the
 * token boundary.
 */

/** Public type SourcePos. */
export type SourcePos = SourcePos(pos: i64, line: i64, col: i64)
