/**
 * nexus/type_expr: Type expression vocabulary for the Nexus parser.
 *
 * TypeExpr and its supporting types carry no dependency on parse trees
 * and are safe to import alongside std:nexus/ast.
 */

/** Public type NamedType. */
export type NamedType = NamedType(name: string, typ: TypeExpr)

/** Public type VariantField. */
export type VariantField = VariantField(name: Option<string>, typ: TypeExpr)

/** Public type TypeExpr. */
export type TypeExpr =
  TyI32 | TyI64 | TyF32 | TyF64 | TyBool | TyChar | TyString | TyUnit
  | TyIntLit | TyFloatLit
  | TyUserDefined(name: string, args: [ TypeExpr ])
  | TyVar(name: string)
  | TyArrow(params: [ NamedType ], ret: TypeExpr, requires: TypeExpr, throw_row: TypeExpr)
  | TyRef(inner: TypeExpr)
  | TyLinear(inner: TypeExpr)
  | TyLazy(inner: TypeExpr, require_row: TypeExpr, throw_row: TypeExpr)
  | TyBorrow(inner: TypeExpr)
  | TyArray(elem: TypeExpr)
  | TyList(elem: TypeExpr)
  | TyRecord(fields: [ NamedType ])
  | TyRow(types: [ TypeExpr ], rest: Option<TypeExpr>)
  | TyHandler(name: string, requires: TypeExpr)

/** Public type VariantDef. */
export type VariantDef = VariantDef(name: string, fields: [ VariantField ])

/** Public type EnumDef. */
export type EnumDef = EnumDef(
  name: string,
  is_public: bool,
  is_opaque: bool,
  type_params: [ string ],
  variants: [ VariantDef ]
)

/** Public type RecordDef. */
export type RecordDef = RecordDef(
  name: string,
  is_public: bool,
  type_params: [ string ],
  fields: [ NamedType ]
)
