/**
 * nexus/vocab: Lexical vocabulary types for the Nexus parser.
 *
 * These types carry no dependency on parse trees and are safe to use
 * directly alongside std:nexus/ast.
 */

/** Public type Sigil. */
export type Sigil =
  SigilImmutable
  | SigilMutable
  | SigilLinear
  | SigilBorrow
  | SigilLazy

/** Public type BinaryOp. */
export type BinaryOp =
  // Integer arithmetic
  OpAdd | OpSub | OpMul | OpDiv | OpMod
  // Float arithmetic
  | OpFAdd | OpFSub | OpFMul | OpFDiv
  // Integer comparisons
  | OpEq | OpNe | OpLt | OpLe | OpGt | OpGe
  // Float comparisons
  | OpFEq | OpFNe | OpFLt | OpFLe | OpFGt | OpFGe
  // Bitwise
  | OpBitAnd | OpBitOr | OpBitXor | OpShl | OpShr
  // Logical & string
  | OpAnd | OpOr | OpConcat

/** Public type UnaryOp. */
export type UnaryOp =
  OpNeg     // -x  (i64 negation)
  | OpFNeg  // -.x (f64 negation)
  | OpNot   // !x  (bool not)

/** Public type Literal. */
export type Literal =
  LitInt(val: i64)
  | LitFloat(val: string)
  | LitBool(val: bool)
  | LitChar(val: i64)
  | LitString(val: string)
  | LitUnit

/** Public type RdrName. */
export type RdrName =
  Unqual(name: string)
  | Qual(alias: string, name: string)
