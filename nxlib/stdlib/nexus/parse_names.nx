/**
 * nexus/parse_names: dotted-name parsing + classification helpers.
 */

import { SpannedToken } from "std:nexus/token"
import { NxUnexpectedToken, NxParseError } from "std:nexus/error"
import { ParsedIdent }, * as pcore from "std:nexus/parse_core"
import * as list from "std:list"
import * as str from "std:str"

// Accumulate dotted name segments in a reversed list, then join at the end.
let parse_dotted_segments = fn (
  toks: [ SpannedToken ],
  acc: [ string ]
) -> ParsedIdent throws { NxParseError } do
  match pcore.peek_token(toks) do
    | TkDot ->
      let r = pcore.skip(toks)
      match pcore.peek_token(toks: r) do
        | TkIdent(name: n) -> return parse_dotted_segments(toks: pcore.skip(toks: r), acc: n :: acc)
        | TkUident(name: n) -> return ParsedIdent(
          name: str.join(xs: list.reverse(xs: n :: acc), sep: "."),
          rest: pcore.skip(toks: r)
        )
        | _ -> return ParsedIdent(name: str.join(xs: list.reverse(xs: acc), sep: "."), rest: toks)
      end
    | _ -> return ParsedIdent(name: str.join(xs: list.reverse(xs: acc), sep: "."), rest: toks)
  end
end

/** Parse a dotted path starting from an already-consumed `prefix` segment. */
export let parse_dotted_name = fn (
  toks: [ SpannedToken ],
  prefix: string
) -> ParsedIdent throws { NxParseError } do
  return parse_dotted_segments(toks, acc: prefix :: [])
end

/** Check if last segment of a dotted name starts with uppercase (A-Z). */
export let dotted_name_ends_upper = fn (name: string) -> bool do
  let len = str.length(s: name)
  let idx = dotted_name_last_dot(name, i: len - 1)
  let ch = str.char_code(s: name, idx: idx + 1)
  return ch >= 65 && ch <= 90
end

let dotted_name_last_dot = fn (name: string, i: i64) -> i64 do
  if i < 0 then return -1 end
  if str.char_code(s: name, idx: i) == 46 then return i end
  return dotted_name_last_dot(name, i: i - 1)
end

/** Parse a dotted handler name (e.g. `Net.read`) used in `inject` arms. */
export let parse_handler_dotted = fn (toks: [ SpannedToken ]) -> ParsedIdent throws { NxParseError } do
  if let TkIdent(name) = pcore.peek_token(toks) then
    let r1 = pcore.skip(toks)
    match pcore.peek_token(toks: r1) do
      | TkDot ->
        let ParsedIdent(
          name: rest_name,
          rest: r2
        ) = parse_handler_dotted(toks: pcore.skip(toks: r1))
        return ParsedIdent(name: name ++ "." ++ rest_name, rest: r2)
      | _ -> return ParsedIdent(name, rest: r1)
    end
  else
    throw NxUnexpectedToken(
      expected: "handler name",
      got: pcore.token_tag(tok: pcore.peek_token(toks)),
      span: pcore.peek_span(toks)
    )
  end
end
