/**
 * nexus/span: Source-position primitive for the Nexus parser.
 *
 * Span records a byte offset plus 1-based line and column numbers.
 * It is attached to every AST node and diagnostic produced by
 * std:nexus/parse.
 */

/** Public type Span. */
export type Span = Span(offset: i64, line: i64, col: i64)
