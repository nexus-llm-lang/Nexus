/**
 * nexus/error: Parse-phase exception types for std:nexus/parse.
 *
 * This module defines only the exceptions raised by the Nexus parser
 * (E1xxx codes). It is intentionally separate from the compiler-internal
 * diagnostics table (src/diagnostics/error.nx), which covers all compiler
 * phases and is not stdlib-eligible.
 *
 * Exception mapping (mirrors compiler E-codes):
 *   NxUnexpectedToken    — E1001: unexpected token during parse
 *   NxUnexpectedEof      — E1002: unexpected end of input
 *   NxParseErrorsCollected — E1003/E1004: too many errors (recovery cap)
 *   NxDuplicateParamLabel  — E1005: duplicate parameter label
 *
 * ParseError group catches all four for a single `catch | ParseError` arm.
 *
 * NxDiagnostic is the structured diagnostic record returned by
 * parse_source_collect when you want every parse error in one pass
 * rather than stopping at the first one.
 */

import { Span } from "std:nexus/span"

/** Raised during parsing when an unexpected token is encountered. */
export exception NxUnexpectedToken(expected: string, got: string, span: Span)

/** Raised during parsing when the input ends unexpectedly. */
export exception NxUnexpectedEof(expected: string, span: Span)

/** Raised by parse_source_collect when the recovery cap is hit (too many errors). */
export exception NxParseErrorsCollected(count: i64)

/** Raised when a function or lambda has two parameters with the same label. */
export exception NxDuplicateParamLabel(name: string, span: Span)

/** Group covering all parse-phase exceptions. */
export exception group NxParseError =
  NxUnexpectedToken | NxUnexpectedEof | NxParseErrorsCollected | NxDuplicateParamLabel

/** Structured diagnostic record returned by parse_source_collect.
 *  `file` may be empty (pass "" when no filename is available).
 *  `line`/`column` are 1-based; both are 0 for spanless diagnostics.
 */
export type NxDiagnostic = NxDiagnostic(
  code: string,
  severity: string,
  file: string,
  line: i64,
  column: i64,
  message: string
)
