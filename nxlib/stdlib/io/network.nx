/** net: HTTP networking operations. */
import { length as str_length, substring, index_of, to_i64_raw } from "std:str"
import * as bb from "std:bytebuffer"
import { ByteBuffer } from "std:bytebuffer"
import { ssrf_is_blocked as _ssrf_is_blocked } from "std:io/network/ssrf"
import external "wasi_snapshot_preview1"

/** Raised when an HTTP request fails. */
export exception RequestError(url: string)

/** Raised when a server fails to bind to an address. */
export exception BindError(addr: string)

/** Raised when sending an HTTP response fails. */
export exception ResponseError(msg: string)

/**
Group covering every exception raised by network operations.
Members are RequestError, BindError, ResponseError. The group exists
so file-level callers route network errors through a stable group
name instead of the universal Exn. The cap Net and system_handler
keep their { Exn } rows: those are the public capability contract
and narrowing them ripples to every Net consumer.
*/
export exception group NetError = RequestError | BindError | ResponseError

/** An HTTP header with a name and value. */
export type Header = Header(name: string, value: string)

/** An HTTP response with a status code, headers, and body. */
export type Response = Response(status: i64, headers: string, body: string)

/** A running HTTP server handle (linear — must be stopped). */
export opaque type Server = Server(id: i64)

/** An incoming HTTP request (linear — must be answered with respond). */
export opaque type Request = Request(
  method: string,
  path: string,
  headers: string,
  body: string,
  req_id: i64
)

/**
A streaming response in progress (linear — must be terminated with
`respond_streaming_finish` after one or more `respond_streaming_write`
calls). Created by `respond_streaming_start`, which consumes the linear
`Request`.
*/
export opaque type RespondStream = RespondStream(req_id: i64)

/** Split-at-newline carrier: the head before the separator and the
 *  rest of the buffer after it. Used by the request-decoder pipeline to
 *  thread a single string through repeated `\n`-separated extractions
 *  without churning anonymous-record types at every step.
 */
type HeaderSplit = HeaderSplit(head: string, rest: string)

// In --p2-component builds with has_net=true, wasi_snapshot_preview1.http_request
// is satisfied by the p2net adapter module which bridges to wasi:http/outgoing-handler.
// In plain preview1 builds (no p2net), this import is unsatisfied and programs
// using Net will not instantiate. That is acceptable: Net is component-only.
/** HTTP GET/POST/etc via the p2net bridge (component-only). Params are method, url,
 *  headers, body; returns the raw encoded response string. In a normal preview1
 *  build (no p2net module) this import is unresolved and instantiation fails.
 */
external w_http_request = "http_request" : (
  a_method: string,
  b_url: string,
  c_headers: string,
  d_body: string
) -> string

let http_request = fn (method: string, url: string, headers: string, body: string) -> string do
  return w_http_request(a_method: method, b_url: url, c_headers: headers, d_body: body)
end

// In --p2-component builds with has_net=true, wasi_snapshot_preview1.http_listen/accept/respond/stop
// are satisfied by the p2sock bridge adapter module which bridges to wasi:sockets/tcp.
// In plain preview1 builds these imports are unsatisfied and programs using Net.listen/accept/respond/stop
// will not instantiate. That is acceptable: TCP server is component-only.
external w_http_listen = "http_listen" : (a_addr: string) -> i64
external w_http_accept = "http_accept" : (a_server_id: i64) -> string
external w_http_respond = "http_respond" : (
  a_req_id: i64,
  b_status: i64,
  c_headers: string,
  d_body: string
) -> bool
external w_http_stop = "http_stop" : (a_server_id: i64) -> bool

let http_listen = fn (addr: string) -> i64 do return w_http_listen(a_addr: addr) end
let http_accept = fn (server_id: i64) -> string do return w_http_accept(a_server_id: server_id) end
let http_respond = fn (
  req_id: i64,
  status: i64,
  headers: string,
  body: string
) -> bool do return w_http_respond(
  a_req_id: req_id,
  b_status: status,
  c_headers: headers,
  d_body: body
) end
let http_stop = fn (server_id: i64) -> bool do return w_http_stop(a_server_id: server_id) end
let http_respond_chunk_start = fn (
  req_id: i64,
  status: i64,
  headers: string
) -> bool do return false end
let http_respond_chunk_write = fn (req_id: i64, body_chunk: string) -> bool do return false end
let http_respond_chunk_finish = fn (req_id: i64) -> bool do return false end
let http_request_with_options = fn (
  method: string,
  url: string,
  headers: string,
  body: string,
  timeout_ms: i64
) -> string do return "" end
let http_cancel_accept = fn (server_id: i64) -> bool do return false end

// ── SSRF guard (implemented in network/ssrf.nx) ───────────────────────────────
// Re-exported here so `std:network` consumers (and tests) can import
// ssrf_is_blocked from this stable public path.

/** SSRF guard: returns true if the URL target host is blocked.
 *  Checks loopback, private, link-local, metadata, ULA, multicast,
 *  broadcast, and IPv4-mapped private ranges, plus well-known
 *  localhost/cloud-metadata hostnames.
 *  Exported for testability; not part of the Net capability surface.
 */
export let ssrf_is_blocked = fn (url: string) -> bool do
  return _ssrf_is_blocked(url)
end

// ── end SSRF guard ─────────────────────────────────────────────────────────────

/** Create a Header. */
export let header = fn (name: string, value: string) -> Header do
  return Header(name, value)
end

/**
Canonical bridge headers format: 'name:value\n' per header, no space
after the colon, single-`\n` terminator, no trailing blank line. The
host bridge converts to/from HTTP/1.1 wire form ('name: value\r\n')
only at the socket boundary. Spec note: a documented wire-format spec
belongs in docs/spec/net.md; that submodule is read-only from this
worktree, so the canonical form is pinned in source comments and
tests until a doc-update issue lands.
*/
let encode_headers_go = fn (buf: %ByteBuffer, headers: [ Header ]) -> %ByteBuffer do
  match headers do
    | [] -> return buf
    | Header(name, value) :: rest ->
      let %buf = bb.push_string(%buf, s: name)
      let %buf = bb.push_string(%buf, s: ":")
      let %buf = bb.push_string(%buf, s: value)
      let %buf = bb.push_string(%buf, s: "\n")
      return encode_headers_go(%buf, headers: rest)
  end
end

let encode_headers = fn (headers: [ Header ]) -> string do
  let buf = bb.empty()
  let %buf = encode_headers_go(%buf, headers)
  let result = bb.to_string(&buf)
  bb.free(%buf)
  return result
end

let decode_response = fn (raw: string) -> Response do
  let sep1 = index_of(s: raw, sub: "\n")
  if sep1 < 0 then
    return Response(status: 0, headers: "", body: raw)
  else
    let status_s = substring(s: raw, start: 0, len: sep1)
    let status = to_i64_raw(s: status_s)
    let rest1_start = sep1 + 1
    let rest1_len = str_length(s: raw) - rest1_start
    let rest1 = substring(s: raw, start: rest1_start, len: rest1_len)
    let sep2 = index_of(s: rest1, sub: "\n")
    if sep2 < 0 then
      return Response(status, headers: "", body: rest1)
    else
      let hlen_s = substring(s: rest1, start: 0, len: sep2)
      let hlen = to_i64_raw(s: hlen_s)
      let content_start = sep2 + 1
      let headers_s = substring(s: rest1, start: content_start, len: hlen)
      let body_start = content_start + hlen
      let body_len = str_length(s: rest1) - body_start
      let body_s = substring(s: rest1, start: body_start, len: body_len)
      return Response(status, headers: headers_s, body: body_s)
    end
  end
end

let split_at_newline = fn (s: string) -> HeaderSplit do
  let sep = index_of(s, sub: "\n")
  if sep < 0 then
    return HeaderSplit(head: s, rest: "")
  else
    let head = substring(s, start: 0, len: sep)
    let rest_start = sep + 1
    let rest_len = str_length(s) - rest_start
    let rest = substring(s, start: rest_start, len: rest_len)
    return HeaderSplit(head, rest)
  end
end

let decode_request = fn (raw: string) -> %Request do
  let HeaderSplit(head: req_id_s, rest: rest1) = split_at_newline(s: raw)
  if str_length(s: req_id_s) == 0 then
    let r = Request(method: "", path: "", headers: "", body: "", req_id: -1)
    let %lr = r
    return %lr
  end
  let req_id = to_i64_raw(s: req_id_s)
  let HeaderSplit(head: method, rest: rest2) = split_at_newline(s: rest1)
  let HeaderSplit(head: path, rest: rest3) = split_at_newline(s: rest2)
  let HeaderSplit(head: headers, rest: body) = split_at_newline(s: rest3)
  let r = Request(method, path, headers, body, req_id)
  let %lr = r
  return %lr
end

/** Extract the status code from a Response. */
let response_status = fn (res: Response) -> i64 do
  let Response(status, headers: _, body: _) = res
  return status
end

/** Extract the body from a Response. */
let response_body = fn (res: Response) -> string do
  let Response(status: _, headers: _, body) = res
  return body
end

/** Extract the method from a Request (borrowed). */
let request_method = fn (req: &Request) -> string do
  let Request(method: m, path: _, headers: _, body: _, req_id: _) = req
  return m
end

/** Extract the path from a Request (borrowed). */
let request_path = fn (req: &Request) -> string do
  let Request(method: _, path: p, headers: _, body: _, req_id: _) = req
  return p
end

/** HTTP GET request. Returns the response body. Raises on failure.
 *  SSRF guard: blocks private/loopback/link-local/metadata hosts before connecting.
 */
let get = fn (url: string) -> string throws { RequestError } do
  if ssrf_is_blocked(url) then
    throw RequestError(url)
  else
    let res = decode_response(raw: http_request(method: "GET", url, headers: "", body: ""))
    if response_status(res) == 0 then
      throw RequestError(url)
    else
      return response_body(res)
    end
  end
end

/** HTTP request with custom method and raw header string. Raises on failure.
 *  SSRF guard: blocks private/loopback/link-local/metadata hosts before connecting.
 */
let request_raw = fn (
  method: string,
  url: string,
  headers: string,
  body: string
) -> Response throws { RequestError } do
  if ssrf_is_blocked(url) then
    throw RequestError(url)
  else
    let res = decode_response(raw: http_request(method, url, headers, body))
    if response_status(res) == 0 then
      throw RequestError(url)
    else
      return res
    end
  end
end

/** HTTP request with typed headers. Raises on failure. */
let request = fn (
  method: string,
  url: string,
  headers: [ Header ],
  body: string
) -> Response throws { RequestError } do
  let encoded = encode_headers(headers)
  return request_raw(method, url, headers: encoded, body)
end

/** Start listening on the given address. Returns a linear server handle. Raises on failure. */
let listen = fn (addr: string) -> %Server throws { BindError } do
  let id = http_listen(addr)
  if id < 0 then
    throw BindError(addr)
  else
    let s = Server(id)
    let %ls = s
    return %ls
  end
end

/**
Accept an incoming request from a server (borrows server handle).
Returns a linear Request — caller must respond to release host-side resources.
*/
let accept = fn (server: &Server) -> %Request do
  let Server(id) = server
  let raw = http_accept(server_id: id)
  return decode_request(raw)
end

/** Respond to an incoming request. Consumes the linear Request. Raises on failure. */
let respond = fn (req: %Request, status: i64, body: string) -> unit throws { ResponseError } do
  let Request(method: _, path: _, headers: _, body: _, req_id: rid) = req
  let ok = http_respond(req_id: rid, status, headers: "", body)
  if ok then
    return ()
  else
    throw ResponseError(msg: "failed to send response")
  end
end

/** Respond to an incoming request with custom headers. Consumes the linear Request. Raises on failure. */
let respond_with_headers = fn (
  req: %Request,
  status: i64,
  headers: [ Header ],
  body: string
) -> unit throws { ResponseError } do
  let Request(method: _, path: _, headers: _, body: _, req_id: rid) = req
  let encoded = encode_headers(headers)
  let ok = http_respond(req_id: rid, status, headers: encoded, body)
  if ok then
    return ()
  else
    throw ResponseError(msg: "failed to send response")
  end
end

/** Stop a server (consumes the linear handle). */
let stop = fn (server: %Server) -> unit do
  let Server(id) = server
  http_stop(server_id: id)
  return ()
end

/**
Streaming response: open a chunked response on the wire and return a
linear `RespondStream` handle. Consumes the linear `Request`. Use
`respond_streaming_write` to append chunks (any number of times), then
`respond_streaming_finish` to terminate. Raises on failure.
*/
let respond_streaming_start = fn (
  req: %Request,
  status: i64,
  headers: [ Header ]
) -> %RespondStream throws { ResponseError } do
  let Request(method: _, path: _, headers: _, body: _, req_id: rid) = req
  let encoded = encode_headers(headers)
  let ok = http_respond_chunk_start(req_id: rid, status, headers: encoded)
  if ok then
    let s = RespondStream(req_id: rid)
    let %ls = s
    return %ls
  else
    throw ResponseError(msg: "failed to start streaming response")
  end
end

/**
Append a chunk to a streaming response (borrows the handle). Returns true
on success.
*/
let respond_streaming_write = fn (stream: &RespondStream, chunk: string) -> bool do
  let RespondStream(req_id: rid) = stream
  return http_respond_chunk_write(req_id: rid, body_chunk: chunk)
end

/**
Terminate a streaming response. Consumes the linear `RespondStream`.
Raises on failure.
*/
let respond_streaming_finish = fn (stream: %RespondStream) -> unit throws { ResponseError } do
  let RespondStream(req_id: rid) = stream
  let ok = http_respond_chunk_finish(req_id: rid)
  if ok then
    return ()
  else
    throw ResponseError(msg: "failed to finish streaming response")
  end
end

/**
HTTP request with custom method, headers, body, and a per-call
timeout (milliseconds). `timeout_ms = 0` ⇒ no timeout (identical to
`request`). Raises `RequestError` on failure (including timeout).
SSRF guard: blocks private/loopback/link-local/metadata hosts before connecting.
*/
let request_with_timeout = fn (
  method: string,
  url: string,
  headers: [ Header ],
  body: string,
  timeout_ms: i64
) -> Response throws { RequestError } do
  if ssrf_is_blocked(url) then
    throw RequestError(url)
  else
    let encoded = encode_headers(headers)
    let raw = http_request_with_options(method, url, headers: encoded, body, timeout_ms)
    let res = decode_response(raw)
    if response_status(res) == 0 then
      throw RequestError(url)
    else
      return res
    end
  end
end

/**
Cancel a running server's blocking `accept`. Borrows the server handle
(does not consume it; the linear `Server` must still be released by
`stop`). Idempotent. Returns true if the cancel was accepted.
*/
let cancel_accept = fn (server: &Server) -> bool do
  let Server(id) = server
  return http_cancel_accept(server_id: id)
end

export cap Net do
  fn get(url: string) -> string throws { RequestError }
  fn request(
    method: string,
    url: string,
    headers: [ Header ],
    body: string
  ) -> Response throws { RequestError }
  fn listen(addr: string) -> %Server throws { BindError }
  fn accept(server: &Server) -> %Request
  fn respond(req: %Request, status: i64, body: string) -> unit throws { ResponseError }
  fn respond_with_headers(
    req: %Request,
    status: i64,
    headers: [ Header ],
    body: string
  ) -> unit throws { ResponseError }
  fn stop(server: %Server) -> unit
  fn respond_streaming_start(
    req: %Request,
    status: i64,
    headers: [ Header ]
  ) -> %RespondStream throws { ResponseError }
  fn respond_streaming_write(stream: &RespondStream, chunk: string) -> bool
  fn respond_streaming_finish(stream: %RespondStream) -> unit throws { ResponseError }
  fn request_with_timeout(
    method: string,
    url: string,
    headers: [ Header ],
    body: string,
    timeout_ms: i64
  ) -> Response throws { RequestError }
  fn cancel_accept(server: &Server) -> bool
end

/** Default Net handler — delegates to direct-call API. */
export let system_handler = handler Net require { PermNet } do
  fn get(url: string) -> string throws { RequestError } do
    return get(url)
  end
  fn request(
    method: string,
    url: string,
    headers: [ Header ],
    body: string
  ) -> Response throws { RequestError } do
    return request(method, url, headers, body)
  end
  fn listen(addr: string) -> %Server throws { BindError } do
    return listen(addr)
  end
  fn accept(server: &Server) -> %Request do
    return accept(server)
  end
  fn respond(req: %Request, status: i64, body: string) -> unit throws { ResponseError } do
    return respond(req, status, body)
  end
  fn respond_with_headers(
    req: %Request,
    status: i64,
    headers: [ Header ],
    body: string
  ) -> unit throws { ResponseError } do
    return respond_with_headers(req, status, headers, body)
  end
  fn stop(server: %Server) -> unit do
    return stop(server)
  end
  fn respond_streaming_start(
    req: %Request,
    status: i64,
    headers: [ Header ]
  ) -> %RespondStream throws { ResponseError } do
    return respond_streaming_start(req, status, headers)
  end
  fn respond_streaming_write(stream: &RespondStream, chunk: string) -> bool do
    return respond_streaming_write(stream, chunk)
  end
  fn respond_streaming_finish(stream: %RespondStream) -> unit throws { ResponseError } do
    return respond_streaming_finish(stream)
  end
  fn request_with_timeout(
    method: string,
    url: string,
    headers: [ Header ],
    body: string,
    timeout_ms: i64
  ) -> Response throws { RequestError } do
    return request_with_timeout(method, url, headers, body, timeout_ms)
  end
  fn cancel_accept(server: &Server) -> bool do
    return cancel_accept(server)
  end
end
