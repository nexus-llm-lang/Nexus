/**
 * env: Environment variable operations.
 *
 * Provides Env cap with get and set operations.
 * get returns Option<string> — None when the variable is not set; Some("")
 * when it is set to an empty string.
 * Requires PermEnv capability.
 *
 * Reads consult an in-memory override table first (populated by `set`, since
 * WASI preview1 has no `setenv`), then fall back to WASI preview1
 * `environ_sizes_get` + `environ_get` (the whole environ block is re-fetched
 * per call). The override table head lives in the reserved low-memory cell at
 * offset 24; entries are `(name_ptr, name_len, val_ptr, val_len)` quadruples,
 * appended (or updated in place when the name already exists), never removed.
 */
import external "wasi_snapshot_preview1"
external w_environ_sizes_get = "environ_sizes_get" : (a_count_ptr: i32, b_size_ptr: i32) -> i32
external w_environ_get = "environ_get" : (a_environ_ptr: i32, b_buf_ptr: i32) -> i32

import external "nexus:intrinsic"
/** Type puns (pure passthrough — every Nexus value is an i64 at the WASM level). */
external pun_raw = "value_of_i64" : <T>(a_x: T) -> i64
external pun_str = "value_of_i64" : <T>(a_x: i64) -> T

import { Option } from "std:option"
import * as mem from "std:runtime/mem"
import * as cast from "std:runtime/cast"
import * as arena from "std:runtime/arena"

let two_pow_32 = 4294967296
let scratch = fn (n: i64) -> i64 do return arena.alloc_raw(size: n) end

let copy_bytes = fn (dst: i64, src: i64, count: i64) -> unit do return copy_bytes_go(dst, src, count, i: 0) end
let copy_bytes_go = fn (dst: i64, src: i64, count: i64, i: i64) -> unit do
  if i >= count then return () end
  let _ = mem.store_u8(addr: dst + i, val: mem.load_u8(addr: src + i))
  return copy_bytes_go(dst, src, count, i: i + 1)
end

let bytes_eq = fn (a: i64, b: i64, n: i64) -> bool do return bytes_eq_go(a, b, n, i: 0) end
let bytes_eq_go = fn (a: i64, b: i64, n: i64, i: i64) -> bool do
  if i >= n then return true end
  if mem.load_u8(addr: a + i) != mem.load_u8(addr: b + i) then return false end
  return bytes_eq_go(a, b, n, i: i + 1)
end

/** Byte offset of the first 0 byte at or after `p`. */
let strend = fn (p: i64) -> i64 do
  if mem.load_u8(addr: p) == 0 then return p end
  return strend(p: p + 1)
end

/**
Fetch the WASI environ string block: returns (buf_ptr << 32) | byte_size,
or 0 on error / empty. The block is `count` consecutive NUL-terminated
"KEY=VALUE" entries.
*/
let load_environ = fn () -> i64 do
  let sizes = scratch(n: 8)
  let rc = w_environ_sizes_get(a_count_ptr: cast.i32_of(x: sizes), b_size_ptr: cast.i32_of(x: sizes + 4))
  if cast.i64_of(x: rc) != 0 then return 0 end
  let count = mem.load_i32(addr: sizes) & 4294967295
  let bufsz = mem.load_i32(addr: sizes + 4) & 4294967295
  if count <= 0 || bufsz <= 0 then return 0 end
  let ptrs = scratch(n: count * 4)
  let buf = scratch(n: bufsz)
  let rc2 = w_environ_get(a_environ_ptr: cast.i32_of(x: ptrs), b_buf_ptr: cast.i32_of(x: buf))
  if cast.i64_of(x: rc2) != 0 then return 0 end
  return (buf * two_pow_32) + bufsz
end

/**
Scan the environ block for an entry "name=...": returns the byte offset of
the value (just past the '='), or -1 if not found.
*/
let env_find = fn (nb: i64, nlen: i64, cur: i64, endp: i64) -> i64 do
  if cur >= endp then return 0 - 1 end
  let entry_end = strend(p: cur)
  if entry_end - cur >= nlen + 1 && bytes_eq(a: cur, b: nb, n: nlen) && mem.load_u8(addr: cur + nlen) == 61 then
    return cur + nlen + 1
  end
  return env_find(nb, nlen, cur: entry_end + 1, endp)
end

/**
Look up env var `name`; checks the override table (populated by `set`)
first, then the WASI environ block. Returns its value as a packed string
i64, or 0 when unset / empty.
*/
let get_env = fn (a_name_ptr: i32, b_name_len: i32) -> i64 do
  let nlen = cast.i64_of(x: b_name_len)
  if nlen <= 0 then return 0 end
  let ov = env_override_lookup(nb: cast.i64_of(x: a_name_ptr), nlen)
  if ov >= 0 then return ov end
  let block = load_environ()
  if block == 0 then return 0 end
  let buf = (block >> 32) & 4294967295
  let bufsz = block & 4294967295
  let voff = env_find(nb: cast.i64_of(x: a_name_ptr), nlen, cur: buf, endp: buf + bufsz)
  if voff < 0 then return 0 end
  let vend = strend(p: voff)
  let vlen = vend - voff
  if vlen <= 0 then return 0 end
  let dst = scratch(n: vlen)
  let _ = copy_bytes(dst, src: voff, count: vlen)
  return (dst * two_pow_32) + vlen
end

/**
True iff env var `name` is set (to anything, including ""), in either the
override table or the WASI environ block.
*/
let has_env = fn (a_name_ptr: i32, b_name_len: i32) -> bool do
  let nlen = cast.i64_of(x: b_name_len)
  if nlen <= 0 then return false end
  if env_override_lookup(nb: cast.i64_of(x: a_name_ptr), nlen) >= 0 then return true end
  let block = load_environ()
  if block == 0 then return false end
  let buf = (block >> 32) & 4294967295
  let bufsz = block & 4294967295
  return env_find(nb: cast.i64_of(x: a_name_ptr), nlen, cur: buf, endp: buf + bufsz) >= 0
end

// --- environ override table (set/get round-trip; WASI preview1 has no setenv) ---

/**
Reserved low-memory cell holding the (lazily allocated) override-table
pointer. The table is `[count: i64, cap: i64, then cap*(name_ptr:i64,
name_len:i64, val_ptr:i64, val_len:i64)]`. 0 means "not yet allocated".
*/
let env_table_cell = 24
let env_entry_size = 32
let env_table_initial_capacity = 8
let et_count = fn (h: i64) -> i64 do return mem.load_i64(addr: h) end
let et_cap = fn (h: i64) -> i64 do return mem.load_i64(addr: h + 8) end
let et_set_count = fn (h: i64, v: i64) -> unit do return mem.store_i64(addr: h, val: v) end
let et_set_cap = fn (h: i64, v: i64) -> unit do return mem.store_i64(addr: h + 8, val: v) end
let et_entry = fn (h: i64, i: i64) -> i64 do return h + 16 + (i * env_entry_size) end

/** The override-table head (lazily allocated). */
let env_table = fn () -> i64 do
  let cur = mem.load_i64(addr: env_table_cell)
  if cur != 0 then return cur end
  let cp = env_table_initial_capacity
  let h = scratch(n: 16 + (cp * env_entry_size))
  let _ = et_set_count(h, v: 0)
  let _ = et_set_cap(h, v: cp)
  let _ = mem.store_i64(addr: env_table_cell, val: h)
  return h
end

/** Index of the entry whose name equals [nb, nb+nlen), or -1. */
let et_find = fn (h: i64, nb: i64, nlen: i64) -> i64 do return et_find_go(h, nb, nlen, i: 0, n: et_count(h)) end
let et_find_go = fn (h: i64, nb: i64, nlen: i64, i: i64, n: i64) -> i64 do
  if i >= n then return 0 - 1 end
  let e = et_entry(h, i)
  if mem.load_i64(addr: e + 8) == nlen && bytes_eq(a: mem.load_i64(addr: e), b: nb, n: nlen) then return i end
  return et_find_go(h, nb, nlen, i: i + 1, n)
end

/**
Look up `name` in the override table; returns the value as a packed string
i64 (ptr<<32|len), or -1 when not present (0 is a legitimate "" override).
*/
let env_override_lookup = fn (nb: i64, nlen: i64) -> i64 do
  if nlen <= 0 then return 0 - 1 end
  let cur = mem.load_i64(addr: env_table_cell)
  if cur == 0 then return 0 - 1 end
  let idx = et_find(h: cur, nb, nlen)
  if idx < 0 then return 0 - 1 end
  let e = et_entry(h: cur, i: idx)
  return (mem.load_i64(addr: e + 16) * two_pow_32) + mem.load_i64(addr: e + 24)
end

let et_grow = fn (h0: i64) -> i64 do
  let new_cap = et_cap(h0) * 2
  let cnt = et_count(h0)
  let h = scratch(n: 16 + (new_cap * env_entry_size))
  let _ = copy_bytes(dst: h, src: h0, count: 16 + (cnt * env_entry_size))
  let _ = et_set_cap(h, v: new_cap)
  let _ = mem.store_i64(addr: env_table_cell, val: h)
  return h
end

/** Copy `len` bytes from `src` into a fresh region; return its ptr (0 if len<=0). */
let copy_into = fn (src: i64, len: i64) -> i64 do
  if len <= 0 then return 0 end
  let p = scratch(n: len)
  let _ = copy_bytes(dst: p, src, count: len)
  return p
end

/**
set_env(name, value): record a private copy of `name`/`value` in the
override table; updates an existing entry for `name` or appends a new one.
wasm sig (i32 i32 i32 i32) -> ().
*/
let set_env = fn (a_name_ptr: i32, b_name_len: i32, c_value_ptr: i32, d_value_len: i32) -> unit do
  let nlen = cast.i64_of(x: b_name_len)
  if nlen <= 0 then return () end
  let vlen = cast.i64_of(x: d_value_len)
  let nb = copy_into(src: cast.i64_of(x: a_name_ptr), len: nlen)
  let vb = copy_into(src: cast.i64_of(x: c_value_ptr), len: vlen)
  let h0 = env_table()
  let existing = et_find(h: h0, nb, nlen)
  if existing >= 0 then
    let e = et_entry(h: h0, i: existing)
    let _ = mem.store_i64(addr: e + 16, val: vb)
    let _ = mem.store_i64(addr: e + 24, val: vlen)
    return ()
  end
  let h = if et_count(h0) < et_cap(h0) then h0 else et_grow(h0) end
  let n = et_count(h)
  let e = et_entry(h, i: n)
  let _ = mem.store_i64(addr: e, val: nb)
  let _ = mem.store_i64(addr: e + 8, val: nlen)
  let _ = mem.store_i64(addr: e + 16, val: vb)
  let _ = mem.store_i64(addr: e + 24, val: vlen)
  let _ = et_set_count(h, v: n + 1)
  return ()
end

let s_p = fn (s: string) -> i32 do return cast.i32_of(x: (pun_raw(a_x: s) >> 32) & 4294967295) end
let s_l = fn (s: string) -> i32 do return cast.i32_of(x: pun_raw(a_x: s) & 4294967295) end

let get_env_s = fn (key: string) -> string do return pun_str(a_x: get_env(a_name_ptr: s_p(s: key), b_name_len: s_l(s: key))) end
let has_env_s = fn (key: string) -> bool do return has_env(a_name_ptr: s_p(s: key), b_name_len: s_l(s: key)) end
let set_env_s = fn (key: string, value: string) -> unit do return set_env(a_name_ptr: s_p(s: key), b_name_len: s_l(s: key), c_value_ptr: s_p(s: value), d_value_len: s_l(s: value)) end

/**
Cap-free environment variable lookup. Returns `Some(value)` when the var is
set (including to the empty string), `None` when it is absent. Reads the
WASI environ block directly (override table included) without requiring the
`PermEnv` capability. Used by `std:rand` and `std:clock` for determinism
hooks (`NEXUS_SEED`, `NEXUS_FROZEN_CLOCK`).
*/
export let raw_get = fn (key: string) -> Option<string> do
  if has_env_s(key) then
    return Some(val: get_env_s(key))
  else
    return None
  end
end

export cap Env do
  fn get(key: string) -> Option<string>
  fn set(key: string, value: string) -> unit
end

export let system_handler = handler Env require { PermEnv } do
  fn get(key: string) -> Option<string> do
    if has_env_s(key) then
      return Some(val: get_env_s(key))
    else
      return None
    end
  end
  fn set(key: string, value: string) -> unit do
    return set_env_s(key, value)
  end
end
