/** net: HTTP networking operations. */
import external stdlib/stdlib.wasm
import { length, substring, index_of } from stdlib/string.nx

external to_i64 = "__nx_string_to_i64" : (s: string) -> i64

/// An HTTP header with a name and value.
export type Header = Header(name: string, value: string)

/// An HTTP response with a status code, headers, and body.
export type Response = Response(status: i64, headers: string, body: string)

/// A running HTTP server handle (linear — must be stopped).
export opaque type Server = Server(id: i64)

/// An incoming HTTP request.
export type Request = Request(method: string, path: string, headers: string, body: string, req_id: i64)

external __nx_http_request = "__nx_http_request" : (method: string, url: string, headers: string, body: string) -> string
external __nx_http_listen = "__nx_http_listen" : (addr: string) -> i64
external __nx_http_accept = "__nx_http_accept" : (server_id: i64) -> string
external __nx_http_respond = "__nx_http_respond" : (req_id: i64, status: i64, headers: string, body: string) -> bool
external __nx_http_stop = "__nx_http_stop" : (server_id: i64) -> bool

/// Create a Header.
export let header = fn (name: string, value: string) -> Header do
  return Header(name: name, value: value)
end

let encode_headers_go = fn (headers: [ Header ], acc: string) -> string do
  match headers do
    case Nil -> return acc
    case Cons(v: h, rest: rest) ->
      match h do
        case Header(name: name, value: value) ->
          let line = name ++ ":" ++ value ++ "\n"
          let next = acc ++ line
          return encode_headers_go(headers: rest, acc: next)
      end
  end
end

let encode_headers = fn (headers: [ Header ]) -> string do
  return encode_headers_go(headers: headers, acc: "")
end

let decode_response = fn (raw: string) -> Response do
  let sep1 = index_of(s: raw, sub: "\n")
  if sep1 < 0 then
    return Response(status: 0, headers: "", body: raw)
  else
    let status_s = substring(s: raw, start: 0, len: sep1)
    let status = to_i64(s: status_s)
    let rest1_start = sep1 + 1
    let rest1_len = length(s: raw) - rest1_start
    let rest1 = substring(s: raw, start: rest1_start, len: rest1_len)
    let sep2 = index_of(s: rest1, sub: "\n")
    if sep2 < 0 then
      return Response(status: status, headers: "", body: rest1)
    else
      let hlen_s = substring(s: rest1, start: 0, len: sep2)
      let hlen = to_i64(s: hlen_s)
      let content_start = sep2 + 1
      let headers_s = substring(s: rest1, start: content_start, len: hlen)
      let body_start = content_start + hlen
      let body_len = length(s: rest1) - body_start
      let body_s = substring(s: rest1, start: body_start, len: body_len)
      return Response(status: status, headers: headers_s, body: body_s)
    end
  end
end


let split_at_newline = fn (s: string) -> { head: string, rest: string } do
  let sep = index_of(s: s, sub: "\n")
  if sep < 0 then
    return { head: s, rest: "" }
  else
    let head = substring(s: s, start: 0, len: sep)
    let rest_start = sep + 1
    let rest_len = length(s: s) - rest_start
    let rest = substring(s: s, start: rest_start, len: rest_len)
    return { head: head, rest: rest }
  end
end

let decode_request = fn (raw: string) -> Request do
  let p1 = split_at_newline(s: raw)
  let req_id_s = p1.head
  if length(s: req_id_s) == 0 then
    return Request(method: "", path: "", headers: "", body: "", req_id: 0 - 1)
  else
    let req_id = to_i64(s: req_id_s)
    let p2 = split_at_newline(s: p1.rest)
    let method = p2.head
    let p3 = split_at_newline(s: p2.rest)
    let path = p3.head
    let p4 = split_at_newline(s: p3.rest)
    let headers = p4.head
    let body = p4.rest
    return Request(method: method, path: path, headers: headers, body: body, req_id: req_id)
  end
end

/// Extract the status code from a Response.
export let response_status = fn (res: Response) -> i64 do
  match res do
    case Response(status: status, headers: _, body: _) -> return status
  end
end

/// Extract the headers string from a Response.
export let response_headers = fn (res: Response) -> string do
  match res do
    case Response(status: _, headers: headers, body: _) -> return headers
  end
end

/// Extract the body from a Response.
export let response_body = fn (res: Response) -> string do
  match res do
    case Response(status: _, headers: _, body: body) -> return body
  end
end

/// Extract the method from a Request (borrowed).
export let request_method = fn (req: &Request) -> string do
  match req do case Request(method: m, path: _, headers: _, body: _, req_id: _) -> return m end
end

/// Extract the path from a Request (borrowed).
export let request_path = fn (req: &Request) -> string do
  match req do case Request(method: _, path: p, headers: _, body: _, req_id: _) -> return p end
end

/// Extract the body from a Request (borrowed).
export let request_body = fn (req: &Request) -> string do
  match req do case Request(method: _, path: _, headers: _, body: b, req_id: _) -> return b end
end

/// HTTP GET request. Returns the response body. Raises on failure.
export let get = fn (url: string) -> string require { PermNet } throws { Exn } do
  let res = decode_response(raw: __nx_http_request(method: "GET", url: url, headers: "", body: ""))
  if response_status(res: res) == 0 then
    raise RuntimeError(val: "net.get: request failed: " ++ url)
  else
    return response_body(res: res)
  end
end

/// HTTP POST request. Returns the response body. Raises on failure.
export let post = fn (url: string, body: string) -> string require { PermNet } throws { Exn } do
  let res = decode_response(raw: __nx_http_request(method: "POST", url: url, headers: "", body: body))
  if response_status(res: res) == 0 then
    raise RuntimeError(val: "net.post: request failed: " ++ url)
  else
    return response_body(res: res)
  end
end

/// HTTP request with custom method and raw header string. Raises on failure.
export let request_raw = fn (method: string, url: string, headers: string, body: string) -> Response require { PermNet } throws { Exn } do
  let res = decode_response(raw: __nx_http_request(method: method, url: url, headers: headers, body: body))
  if response_status(res: res) == 0 then
    raise RuntimeError(val: "net.request_raw: request failed: " ++ url)
  else
    return res
  end
end

/// HTTP request with typed headers. Raises on failure.
export let request = fn (method: string, url: string, headers: [ Header ], body: string) -> Response require { PermNet } throws { Exn } do
  let encoded = encode_headers(headers: headers)
  return request_raw(method: method, url: url, headers: encoded, body: body)
end

/// Start listening on the given address. Returns a linear server handle. Raises on failure.
export let listen = fn (addr: string) -> %Server require { PermNet } throws { Exn } do
  let id = __nx_http_listen(addr: addr)
  if id < 0 then
    raise RuntimeError(val: "net.listen: failed to bind: " ++ addr)
  else
    let s = Server(id: id)
    let %ls = s
    return %ls
  end
end

/// Accept an incoming request from a server (borrows server handle).
export let accept = fn (server: &Server) -> Request require { PermNet } do
  match server do case Server(id: id) ->
    let raw = __nx_http_accept(server_id: id)
    return decode_request(raw: raw)
  end
end

/// Respond to an incoming request. Raises on failure.
export let respond = fn (req: Request, status: i64, body: string) -> unit require { PermNet } throws { Exn } do
  match req do case Request(method: _, path: _, headers: _, body: _, req_id: rid) ->
    let ok = __nx_http_respond(req_id: rid, status: status, headers: "", body: body)
    if ok then
      return ()
    else
      raise RuntimeError(val: "net.respond: failed to send response")
    end
  end
end

/// Respond to an incoming request with custom headers. Raises on failure.
export let respond_with_headers = fn (req: Request, status: i64, headers: [ Header ], body: string) -> unit require { PermNet } throws { Exn } do
  match req do case Request(method: _, path: _, headers: _, body: _, req_id: rid) ->
    let encoded = encode_headers(headers: headers)
    let ok = __nx_http_respond(req_id: rid, status: status, headers: encoded, body: body)
    if ok then
      return ()
    else
      raise RuntimeError(val: "net.respond_with_headers: failed to send response")
    end
  end
end

/// Stop a server (consumes the linear handle).
export let stop = fn (server: %Server) -> unit require { PermNet } do
  match server do case Server(id: id) ->
    let _ = __nx_http_stop(server_id: id)
    return ()
  end
end

export port Net do
  fn get(url: string) -> string throws { Exn }
  fn request(method: string, url: string, headers: [ Header ], body: string) -> Response throws { Exn }
  fn listen(addr: string) -> %Server throws { Exn }
  fn accept(server: &Server) -> Request
  fn respond(req: Request, status: i64, body: string) -> unit throws { Exn }
  fn respond_with_headers(req: Request, status: i64, headers: [ Header ], body: string) -> unit throws { Exn }
  fn stop(server: %Server) -> unit
end

/// Default Net handler — delegates to direct-call API.
export let system_handler = handler Net require { PermNet } do
  fn get(url: string) -> string throws { Exn } do
    return get(url: url)
  end
  fn request(method: string, url: string, headers: [ Header ], body: string) -> Response throws { Exn } do
    return request(method: method, url: url, headers: headers, body: body)
  end
  fn listen(addr: string) -> %Server throws { Exn } do
    return listen(addr: addr)
  end
  fn accept(server: &Server) -> Request do
    return accept(server: server)
  end
  fn respond(req: Request, status: i64, body: string) -> unit throws { Exn } do
    return respond(req: req, status: status, body: body)
  end
  fn respond_with_headers(req: Request, status: i64, headers: [ Header ], body: string) -> unit throws { Exn } do
    return respond_with_headers(req: req, status: status, headers: headers, body: body)
  end
  fn stop(server: %Server) -> unit do
    return stop(server: server)
  end
end
