import external [=[nxlib/stdlib/net.wasm]=]

pub type Header = Header(name: string, value: string)
pub type Response = Response(status: i64, body: string)

let __nx_http_request = external [=[http_request]=] : (method: string, url: string, headers: string, body: string) -> string effect { Net }
let __nx_print = external [=[print]=] : (val: string) -> unit effect { IO }
let __nx_string_length = external [=[__nx_string_length]=] : (s: string) -> i64
let __nx_string_substring = external [=[__nx_string_substring]=] : (s: string, start: i64, len: i64) -> string
let __nx_string_index_of = external [=[__nx_string_index_of]=] : (s: string, sub: string) -> i64
let __nx_string_to_i64 = external [=[__nx_string_to_i64]=] : (s: string) -> i64

pub let header = fn (name: string, value: string) -> Header do
  return Header(name: name, value: value)
endfn

let encode_headers_go = fn (headers: List<Header>, acc: string) -> string do
  match headers do
    case Nil() -> return acc
    case Cons(v: h, rest: rest) ->
      match h do
        case Header(name: name, value: value) ->
          let line = name ++ [=[:]=] ++ value ++ [=[\n]=]
          let next = acc ++ line
          return encode_headers_go(headers: rest, acc: next)
      endmatch
  endmatch
endfn

let encode_headers = fn (headers: List<Header>) -> string do
  return encode_headers_go(headers: headers, acc: [=[]=])
endfn

let decode_response = fn (raw: string) -> Response do
  let sep = __nx_string_index_of(s: raw, sub: [=[\n]=])
  if sep < 0 then
    return Response(status: 0, body: raw)
  else
    let status_s = __nx_string_substring(s: raw, start: 0, len: sep)
    let raw_len = __nx_string_length(s: raw)
    let body_start = sep + 1
    let body_len = raw_len - body_start
    let body_s = __nx_string_substring(s: raw, start: body_start, len: body_len)
    let status = __nx_string_to_i64(s: status_s)
    return Response(status: status, body: body_s)
  endif
endfn

let decode_body_from_raw = fn (raw: string) -> string do
  let sep = __nx_string_index_of(s: raw, sub: [=[\n]=])
  if sep < 0 then
    return raw
  else
    let raw_len = __nx_string_length(s: raw)
    let body_start = sep + 1
    let body_len = raw_len - body_start
    return __nx_string_substring(s: raw, start: body_start, len: body_len)
  endif
endfn

pub let response_status = fn (res: Response) -> i64 do
  match res do
    case Response(status: status, body: _) -> return status
  endmatch
endfn

pub let response_body = fn (res: Response) -> string do
  match res do
    case Response(status: _, body: body) -> return body
  endmatch
endfn

pub let request_response = fn (method: string, url: string, headers: List<Header>, body: string) -> Response effect { Net } do
  let encoded = encode_headers(headers: headers)
  let raw = perform __nx_http_request(method: method, url: url, headers: encoded, body: body)
  return decode_response(raw: raw)
endfn

pub let request = fn (method: string, url: string, headers: List<Header>) -> string effect { Net } do
  let body = [=[]=]
  let res = perform request_response(method: method, url: url, headers: headers, body: body)
  return response_body(res: res)
endfn

pub let request_with_body = fn (method: string, url: string, headers: List<Header>, body: string) -> string effect { Net } do
  let res = perform request_response(method: method, url: url, headers: headers, body: body)
  return response_body(res: res)
endfn

pub let get = fn (url: string) -> string effect { Net } do
  let raw = perform __nx_http_request(method: [=[GET]=], url: url, headers: [=[]=], body: [=[]=])
  return decode_body_from_raw(raw: raw)
endfn

pub let print = fn (val: string) -> unit effect { IO } do
  return perform __nx_print(val: val)
endfn
