import external [=[nxlib/stdlib/string.wasm]=]

let __nx_string_length = external [=[__nx_string_length]=] : (s: string) -> i64
let __nx_string_contains = external [=[__nx_string_contains]=] : (s: string, sub: string) -> bool
let __nx_string_substring = external [=[__nx_string_substring]=] : (s: string, start: i64, len: i64) -> string
let __nx_string_index_of = external [=[__nx_string_index_of]=] : (s: string, sub: string) -> i64
let __nx_string_starts_with = external [=[__nx_string_starts_with]=] : (s: string, prefix: string) -> bool
let __nx_string_ends_with = external [=[__nx_string_ends_with]=] : (s: string, suffix: string) -> bool
let __nx_string_trim = external [=[__nx_string_trim]=] : (s: string) -> string
let __nx_string_to_upper = external [=[__nx_string_to_upper]=] : (s: string) -> string
let __nx_string_to_lower = external [=[__nx_string_to_lower]=] : (s: string) -> string
let __nx_string_replace = external [=[__nx_string_replace]=] : (s: string, from_str: string, to_str: string) -> string
let __nx_string_char_at = external [=[__nx_string_char_at]=] : (s: string, idx: i64) -> string

pub let string_length = fn (s: string) -> i64 do
  return __nx_string_length(s: s)
endfn

pub let string_contains = fn (s: string, sub: string) -> bool do
  return __nx_string_contains(s: s, sub: sub)
endfn

pub let string_substring = fn (s: string, start: i64, len: i64) -> string do
  return __nx_string_substring(s: s, start: start, len: len)
endfn

pub let string_index_of = fn (s: string, sub: string) -> i64 do
  return __nx_string_index_of(s: s, sub: sub)
endfn

pub let string_starts_with = fn (s: string, prefix: string) -> bool do
  return __nx_string_starts_with(s: s, prefix: prefix)
endfn

pub let string_ends_with = fn (s: string, suffix: string) -> bool do
  return __nx_string_ends_with(s: s, suffix: suffix)
endfn

pub let string_trim = fn (s: string) -> string do
  return __nx_string_trim(s: s)
endfn

pub let string_to_upper = fn (s: string) -> string do
  return __nx_string_to_upper(s: s)
endfn

pub let string_to_lower = fn (s: string) -> string do
  return __nx_string_to_lower(s: s)
endfn

pub let string_replace = fn (s: string, from_str: string, to_str: string) -> string do
  return __nx_string_replace(s: s, from_str: from_str, to_str: to_str)
endfn

let string_split_go = fn (s: string, sep: string) -> List<string> do
  let idx = __nx_string_index_of(s: s, sub: sep)
  if idx < 0 then
    return Cons(v: s, rest: Nil())
  else
    let head = __nx_string_substring(s: s, start: 0, len: idx)
    let sep_len = __nx_string_length(s: sep)
    let tail_start = idx + sep_len
    let tail_len = __nx_string_length(s: s) - tail_start
    let tail = __nx_string_substring(s: s, start: tail_start, len: tail_len)
    return Cons(v: head, rest: string_split_go(s: tail, sep: sep))
  endif
endfn

pub let string_split = fn (s: string, sep: string) -> List<string> do
  if __nx_string_length(s: sep) == 0 then
    return Cons(v: s, rest: Nil())
  else
    return string_split_go(s: s, sep: sep)
  endif
endfn

pub let string_char_at = fn (s: string, idx: i64) -> string do
  return __nx_string_char_at(s: s, idx: idx)
endfn
