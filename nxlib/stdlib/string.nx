/**
 * string: String inspection and manipulation functions.
 */
import external stdlib/stdlib.wasm

/// Returns the number of characters in the string.
pub external length = "__nx_string_length" : (s: string) -> i64

/// Returns true if s contains the substring sub.
pub external contains = "__nx_string_contains" : (s: string, sub: string) -> bool

/// Extracts a substring starting at start with the given length.
pub external substring = "__nx_string_substring" : (s: string, start: i64, len: i64) -> string

/// Returns the index of the first occurrence of sub in s, or -1 if not found.
pub external index_of = "__nx_string_index_of" : (s: string, sub: string) -> i64

/// Returns true if s starts with the given prefix.
pub external starts_with = "__nx_string_starts_with" : (s: string, prefix: string) -> bool

/// Returns true if s ends with the given suffix.
pub external ends_with = "__nx_string_ends_with" : (s: string, suffix: string) -> bool

/// Returns s with leading and trailing whitespace removed.
pub external trim = "__nx_string_trim" : (s: string) -> string

/// Returns s with all characters converted to uppercase.
pub external to_upper = "__nx_string_to_upper" : (s: string) -> string

/// Returns s with all characters converted to lowercase.
pub external to_lower = "__nx_string_to_lower" : (s: string) -> string

/// Replaces all occurrences of from_str with to_str in s.
pub external replace = "__nx_string_replace" : (s: string, from_str: string, to_str: string) -> string

/// Returns the character at the given index as a single-character string.
pub external char_at = "__nx_string_char_at" : (s: string, idx: i64) -> string

/// Converts an i64 integer to its string representation.
pub external from_i64 = "__nx_string_from_i64" : (val: i64) -> string

/// Converts a float to its string representation.
pub external from_float = "__nx_string_from_float" : (val: float) -> string

/// Converts a bool to "true" or "false".
pub external from_bool = "__nx_string_from_bool" : (val: bool) -> string

/// Raw FFI for string-to-i64 conversion (panics on invalid input).
external to_i64_raw = "__nx_string_to_i64" : (s: string) -> i64

/// Parses a string as an i64. Raises on invalid input.
let to_i64 = fn (s: string) -> i64 effect { Exn } do
  if is_valid_i64(s: s) then
    return to_i64_raw(s: s)
  else
    raise RuntimeError(val: "to_i64: invalid integer '" ++ s ++ "'")
  end
end

/// Returns true if the string is a valid i64.
external is_valid_i64 = "__nx_string_is_valid_i64" : (s: string) -> bool

let split_go = fn (s: string, sep: string) -> [ string ] do
  let idx = index_of(s: s, sub: sep)
  if idx < 0 then
    return Cons(v: s, rest: Nil())
  else
    let head = substring(s: s, start: 0, len: idx)
    let sep_len = length(s: sep)
    let tail_start = idx + sep_len
    let tail_len = length(s: s) - tail_start
    let tail = substring(s: s, start: tail_start, len: tail_len)
    return Cons(v: head, rest: split_go(s: tail, sep: sep))
  end
end

/**
 * Splits s by the given separator and returns a list of substrings.
 * Returns a single-element list if sep is empty or not found.
 * Implemented by recursively finding the next occurrence of sep via
 * index_of, extracting the head substring, and recurring on
 * the tail. Produces segments in left-to-right order.
 */
pub let split = fn (s: string, sep: string) -> [ string ] do
  if length(s: sep) == 0 then
    return Cons(v: s, rest: Nil())
  else
    return split_go(s: s, sep: sep)
  end
end

/// Returns the Unicode codepoint of the character at the given index, or -1 if out of bounds.
pub external char_code = "__nx_string_char_code" : (s: string, idx: i64) -> i64

/// Converts a Unicode codepoint to a single-character string. Returns "" on invalid codepoint.
pub external from_char_code = "__nx_string_from_char_code" : (code: i64) -> string

/// Parses a string as a float. Returns NaN on invalid input.
external to_f64_raw = "__nx_string_to_f64" : (s: string) -> f64

/// Returns true if the string is a valid f64.
external is_valid_f64 = "__nx_string_is_valid_f64" : (s: string) -> bool

/// Parses a string as an f64, returning None on failure.
pub let parse_f64 = fn (s: string) -> Option<f64> do
  if is_valid_f64(s: s) then
    return Some(val: to_f64_raw(s: s))
  else
    return None()
  end
end

/// Parses a string as an f64. Raises on invalid input.
pub let to_f64 = fn (s: string) -> f64 effect { Exn } do
  if is_valid_f64(s: s) then
    return to_f64_raw(s: s)
  else
    raise RuntimeError(val: "to_f64: invalid float '" ++ s ++ "'")
  end
end

/// Repeats the string s n times.
pub external repeat = "__nx_string_repeat" : (s: string, n: i64) -> string

/// Pads s on the left to width characters using fill as padding.
pub external pad_left = "__nx_string_pad_left" : (s: string, width: i64, fill: string) -> string

/// Pads s on the right to width characters using fill as padding.
pub external pad_right = "__nx_string_pad_right" : (s: string, width: i64, fill: string) -> string

/// Concatenates two strings. Equivalent to a ++ b.
pub let concat = fn (a: string, b: string) -> string do
  return a ++ b
end

/// Joins a list of strings with a separator between each element.
pub let join = fn (xs: [ string ], sep: string) -> string do
  match xs do
    case Nil() -> return ""
    case Cons(v: v, rest: rest) ->
      match rest do
        case Nil() -> return v
        case Cons(v: _, rest: _) -> return v ++ sep ++ join(xs: rest, sep: sep)
      end
  end
end

/// Parses a string as an i64, returning None on failure.
pub let parse_i64 = fn (s: string) -> Option<i64> do
  if is_valid_i64(s: s) then
    return Some(val: to_i64_raw(s: s))
  else
    return None()
  end
end
