/**
 * clock: Time and sleep operations.
 *
 * Provides Clock port with sleep and now operations.
 * Requires PermClock capability.
 *
 * `now` is CLOCK_REALTIME milliseconds since the UNIX epoch (via WASI
 * preview1 `clock_time_get`). `sleep` is a stub: WASI preview1 sleep is
 * `poll_oneoff` with a clock subscription, not worth the complexity here.
 */
import external "wasi_snapshot_preview1"
/// clock_time_get(clock_id, precision:i64, time_out_ptr) -> errno.
external w_clock_time_get = "clock_time_get" : (a_clock_id: i32, b_precision: i64, c_time_out_ptr: i32) -> i32

import * as mem from "std:runtime/mem"
import * as cast from "std:runtime/cast"
import * as arena from "std:runtime/arena"

let ns_per_ms = fn () -> i64 do return 1000000 end

/// Wall-clock milliseconds since the UNIX epoch (CLOCK_REALTIME, clock_id 0);
/// 0 on any WASI error. Exported so `std:rand`'s seed path can use it without
/// installing a Clock cap handler.
export let now_ms = fn () -> i64 do
  let p = arena.alloc_raw(size: 8)
  let rc = w_clock_time_get(a_clock_id: cast.i32_of(x: 0), b_precision: ns_per_ms(), c_time_out_ptr: cast.i32_of(x: p))
  if cast.i64_of(x: rc) != 0 then return 0 end
  let ns = mem.load_i64(addr: p)
  return ns / ns_per_ms()
end

/// Sleep stub: WASI preview1 has no simple sleep primitive. No-op.
let __nx_sleep = fn (ms: i64) -> unit do return () end

export cap Clock do
  fn sleep(ms: i64) -> unit
  fn now() -> i64
end

export let system_handler = handler Clock require { PermClock } do
  fn sleep(ms: i64) -> unit do
    return __nx_sleep(ms)
  end
  fn now() -> i64 do
    return now_ms()
  end
end
