/**
 * runtime/collection: HashMap / HashSet / StringMap runtime.
 *
 * Shared internal module backing `std:hashmap` (HashMap + HashSet) and
 * `std:stringmap` — one module rather than inline in each interface file
 * because hmap/hset/smap share the open-addressing core, the hashing, the
 * snapshot machinery and the 32-byte header layout. Each collection `id` is a
 * pointer to a header struct in linear memory; the buckets are arrays in
 * linear memory, all from the unified bump arena (`arena.alloc_raw`). Growth
 * leaks the old bucket array, which is fine for a bump allocator.
 *
 * Hash maps / sets are open-addressed (linear probing) with tombstones.
 * Header layout (32 bytes, four i64 words), shared by hmap / hset / smap:
 *   offset 0  : count     -- number of live entries
 *   offset 8  : capacity  -- number of bucket slots (a power of two)
 *   offset 16 : buckets   -- pointer to the slot array (0 when capacity==0)
 *   offset 24 : snapshot  -- pointer to a cached iteration snapshot, or 0 if
 *                            stale; invalidated (set to 0) on every mutation.
 *
 * hmap / hset slot = three i64 words: [key, value, state].
 * smap slot       = four  i64 words: [key_ptr, key_len, value, state].
 *   state: 0 = empty, 1 = occupied, 2 = tombstone.
 *
 * smap keys are copied into a fresh allocation on `put`, so the caller's
 * (possibly transient) string buffer need not outlive the call.
 *
 * The `_at` family returns the element at an iteration index. A snapshot of
 * the live entries is built lazily on the first `_at` after a mutation and
 * cached in the header's `snapshot` word, so a full enumeration is O(n) total.
 * Out-of-bounds / negative indices return 0.
 *
 * `hmap_keys` / `hmap_vals` / `hset_to_list` / `smap_vals`
 * return a newline-joined string of the decimal representations of the i64
 * elements; `smap_keys` returns the keys joined by
 * newline verbatim. A `string` return is the packed (ptr<<32)|len i64, 0 for
 * the empty string.
 *
 * Two ABI / codegen notes:
 *  - Nexus lays out wasm function params in alphabetical name order, but
 *    external callers (codegen) pass them positionally in external-decl
 *    declaration order (with each `string` param expanded to ptr,len). So
 *    every exported impl function prefixes its params a_, b_, c_, d_, ... in
 *    that order, so alphabetical == positional.
 *  - A call that MIXES positional and named arguments mis-binds in this
 *    compiler; every call in this file uses fully-named arguments.
 */
import * as mem from "std:runtime/mem"
import * as cast from "std:runtime/cast"
import * as arena from "std:runtime/arena"

/// 2^32, used to pack a (ptr, len) pair into a returned i64.
let two_pow_32 = 4294967296
/// Initial bucket count for a fresh map / set (power of two).
let initial_cap = 8
// Slot states.
let st_empty = 0
let st_full = 1
let st_tomb = 2
// --- header accessors (shared) ---

let hdr_count = fn (h: i64) -> i64 do return mem.load_i64(addr: h) end
let hdr_cp = fn (h: i64) -> i64 do return mem.load_i64(addr: h + 8) end
let hdr_buckets = fn (h: i64) -> i64 do return mem.load_i64(addr: h + 16) end
let hdr_snap = fn (h: i64) -> i64 do return mem.load_i64(addr: h + 24) end
let set_count = fn (h: i64, v: i64) -> unit do return mem.store_i64(addr: h, val: v) end
let set_cp = fn (h: i64, v: i64) -> unit do return mem.store_i64(addr: h + 8, val: v) end
let set_buckets = fn (h: i64, v: i64) -> unit do return mem.store_i64(addr: h + 16, val: v) end
let set_snap = fn (h: i64, v: i64) -> unit do return mem.store_i64(addr: h + 24, val: v) end

/// Mark the iteration snapshot stale (call after every mutation).
let invalidate = fn (h: i64) -> unit do return set_snap(h: h, v: 0) end

/// Allocate a zeroed i64 array of `nw` words; returns its byte pointer.
/// (arena.alloc_raw does not zero its result, so we clear it ourselves.)
let alloc_words = fn (nw: i64) -> i64 do
  let p = arena.alloc_raw(size: nw * 8)
  let _ = zero_words(p: p, i: 0, n: nw)
  return p
end

let zero_words = fn (p: i64, i: i64, n: i64) -> unit do
  if i >= n then return () end
  let _ = mem.store_i64(addr: p + (i * 8), val: 0)
  return zero_words(p: p, i: i + 1, n: n)
end

/// Copy `n` bytes from `src` to `dst` (forward).
let copy_bytes = fn (dst: i64, src: i64, n: i64, i: i64) -> unit do
  if i >= n then return () end
  let _ = mem.store_u8(addr: dst + i, val: mem.load_u8(addr: src + i))
  return copy_bytes(dst: dst, src: src, n: n, i: i + 1)
end

/// True if the byte range [p1, p1+n) equals [p2, p2+n).
let bytes_eq = fn (p1: i64, p2: i64, n: i64, i: i64) -> bool do
  if i >= n then return true end
  if mem.load_u8(addr: p1 + i) != mem.load_u8(addr: p2 + i) then return false end
  return bytes_eq(p1: p1, p2: p2, n: n, i: i + 1)
end

// --- hashing ---

/// (v >> n) treated as a logical (unsigned) shift, for 1 <= n <= 63.
let lshr = fn (v: i64, n: i64) -> i64 do
  return (v >> n) & ((1 << (64 - n)) - 1)
end

/// SplitMix64-style 64-bit mix of an i64 key. The big multiplier constants do
/// not fit in a positive i64 literal, so they are written as `0 - K`.
let mix64 = fn (x: i64) -> i64 do
  let z0 = x + (0 - 7046029254386353131)
  let z1 = (z0 ^ lshr(v: z0, n: 30)) * (0 - 4658895280553007687)
  let z2 = (z1 ^ lshr(v: z1, n: 27)) * (0 - 7723592293110705685)
  return z2 ^ lshr(v: z2, n: 31)
end

/// FNV-1a 64-bit hash over a byte range. The offset basis 14695981039346656037
/// does not fit a positive i64 literal, so it is written as `0 - 3750763034362895579`.
let fnv1a = fn (ptr: i64, len: i64) -> i64 do
  return fnv1a_go(ptr: ptr, len: len, i: 0, h: 0 - 3750763034362895579)
end

let fnv1a_go = fn (ptr: i64, len: i64, i: i64, h: i64) -> i64 do
  if i >= len then return h end
  let h2 = (h ^ mem.load_u8(addr: ptr + i)) * 1099511628211
  return fnv1a_go(ptr: ptr, len: len, i: i + 1, h: h2)
end

/// Reduce a (possibly negative) 64-bit hash to a slot index in [0, cp).
/// cp is a power of two; the bitwise AND keeps the (always non-negative) low bits.
let slot_of = fn (hash: i64, cp: i64) -> i64 do return hash & (cp - 1) end

let next_slot = fn (i: i64, cp: i64) -> i64 do return (i + 1) & (cp - 1) end

// =====================================================================
//  HashMap  (i64 key -> i64 value)
// =====================================================================
//
// hmap/hset slot i lives at  buckets + i*24 :  [key (0), value (8), state (16)].

let hm_key = fn (b: i64, i: i64) -> i64 do return mem.load_i64(addr: b + (i * 24)) end
let hm_val = fn (b: i64, i: i64) -> i64 do return mem.load_i64(addr: b + (i * 24) + 8) end
let hm_state = fn (b: i64, i: i64) -> i64 do return mem.load_i64(addr: b + (i * 24) + 16) end
let hm_put_key = fn (b: i64, i: i64, v: i64) -> unit do return mem.store_i64(addr: b + (i * 24), val: v) end
let hm_put_val = fn (b: i64, i: i64, v: i64) -> unit do return mem.store_i64(addr: b + (i * 24) + 8, val: v) end
let hm_put_state = fn (b: i64, i: i64, v: i64) -> unit do return mem.store_i64(addr: b + (i * 24) + 16, val: v) end

/// Allocate a header for a fresh, capacity-`initial_cap` hmap/hset.
let hm_mk = fn () -> i64 do
  let h = alloc_words(nw: 4)
  let cp = initial_cap
  let _ = set_count(h: h, v: 0)
  let _ = set_cp(h: h, v: cp)
  let _ = set_buckets(h: h, v: alloc_words(nw: cp * 3))
  let _ = set_snap(h: h, v: 0)
  return h
end

/// Index of the occupied slot holding `key` in bucket array `b` of size `cp`,
/// or -1 if absent.
let hm_find = fn (b: i64, cp: i64, key: i64) -> i64 do
  return hm_find_go(b: b, cp: cp, key: key, i: slot_of(hash: mix64(x: key), cp: cp), steps: 0)
end

let hm_find_go = fn (b: i64, cp: i64, key: i64, i: i64, steps: i64) -> i64 do
  if steps >= cp then return 0 - 1 end
  let s = hm_state(b: b, i: i)
  if s == st_empty then return 0 - 1 end
  if s == st_full && hm_key(b: b, i: i) == key then return i end
  return hm_find_go(b: b, cp: cp, key: key, i: next_slot(i: i, cp: cp), steps: steps + 1)
end

/// Insert `key`->`value` into bucket array `b` (size `cp`), which must have
/// room. Returns 1 if a new key was added, 0 if an existing key was updated.
let hm_insert = fn (b: i64, cp: i64, key: i64, value: i64) -> i64 do
  return hm_insert_go(b: b, cp: cp, key: key, value: value, i: slot_of(hash: mix64(x: key), cp: cp), first_tomb: 0 - 1, steps: 0)
end

let hm_insert_go = fn (b: i64, cp: i64, key: i64, value: i64, i: i64, first_tomb: i64, steps: i64) -> i64 do
  if steps >= cp then
    let _ = hm_put_key(b: b, i: first_tomb, v: key)
    let _ = hm_put_val(b: b, i: first_tomb, v: value)
    let _ = hm_put_state(b: b, i: first_tomb, v: st_full)
    return 1
  end
  let s = hm_state(b: b, i: i)
  if s == st_full then
    if hm_key(b: b, i: i) == key then
      let _ = hm_put_val(b: b, i: i, v: value)
      return 0
    end
    return hm_insert_go(b: b, cp: cp, key: key, value: value, i: next_slot(i: i, cp: cp), first_tomb: first_tomb, steps: steps + 1)
  end
  if s == st_tomb then
    let ft = if first_tomb == 0 - 1 then i else first_tomb end
    return hm_insert_go(b: b, cp: cp, key: key, value: value, i: next_slot(i: i, cp: cp), first_tomb: ft, steps: steps + 1)
  end
  let dest = if first_tomb == 0 - 1 then i else first_tomb end
  let _ = hm_put_key(b: b, i: dest, v: key)
  let _ = hm_put_val(b: b, i: dest, v: value)
  let _ = hm_put_state(b: b, i: dest, v: st_full)
  return 1
end

let hm_grow = fn (h: i64) -> unit do
  let old_b = hdr_buckets(h: h)
  let old_cp = hdr_cp(h: h)
  let new_cp = old_cp * 2
  let new_b = alloc_words(nw: new_cp * 3)
  let _ = hm_rehash(old_b: old_b, old_cp: old_cp, new_b: new_b, new_cp: new_cp, i: 0)
  let _ = set_cp(h: h, v: new_cp)
  return set_buckets(h: h, v: new_b)
end

let hm_rehash = fn (old_b: i64, old_cp: i64, new_b: i64, new_cp: i64, i: i64) -> unit do
  if i >= old_cp then return () end
  if hm_state(b: old_b, i: i) == st_full then
    let _ = hm_insert(b: new_b, cp: new_cp, key: hm_key(b: old_b, i: i), value: hm_val(b: old_b, i: i))
    return hm_rehash(old_b: old_b, old_cp: old_cp, new_b: new_b, new_cp: new_cp, i: i + 1)
  end
  return hm_rehash(old_b: old_b, old_cp: old_cp, new_b: new_b, new_cp: new_cp, i: i + 1)
end

/// Ensure room for one more entry (load factor < 3/4).
let hm_reserve_one = fn (h: i64) -> unit do
  if (hdr_count(h: h) + 1) * 4 < hdr_cp(h: h) * 3 then return () end
  return hm_grow(h: h)
end

/// Core put: returns 1 if a new key was added, else 0.
let hm_put = fn (h: i64, key: i64, value: i64) -> i64 do
  let _ = hm_reserve_one(h: h)
  let added = hm_insert(b: hdr_buckets(h: h), cp: hdr_cp(h: h), key: key, value: value)
  let _ = if added == 1 then set_count(h: h, v: hdr_count(h: h) + 1) else () end
  let _ = invalidate(h: h)
  return added
end

/// Core delete: returns true if the key was present and removed.
let hm_del = fn (h: i64, key: i64) -> bool do
  let b = hdr_buckets(h: h)
  let idx = hm_find(b: b, cp: hdr_cp(h: h), key: key)
  if idx == 0 - 1 then return false end
  let _ = hm_put_state(b: b, i: idx, v: st_tomb)
  let _ = set_count(h: h, v: hdr_count(h: h) - 1)
  let _ = invalidate(h: h)
  return true
end

// --- snapshot for hmap _at: [k0, v0, k1, v1, ...], count*2 words ---

let hm_ensure_snap = fn (h: i64) -> i64 do
  let cur = hdr_snap(h: h)
  if cur != 0 then return cur end
  let n = hdr_count(h: h)
  if n <= 0 then
    let p = alloc_words(nw: 1)
    let _ = set_snap(h: h, v: p)
    return p
  end
  let snap = alloc_words(nw: n * 2)
  let _ = hm_fill_snap(b: hdr_buckets(h: h), cp: hdr_cp(h: h), snap: snap, src_i: 0, dst: 0)
  let _ = set_snap(h: h, v: snap)
  return snap
end

let hm_fill_snap = fn (b: i64, cp: i64, snap: i64, src_i: i64, dst: i64) -> unit do
  if src_i >= cp then return () end
  if hm_state(b: b, i: src_i) == st_full then
    let _ = mem.store_i64(addr: snap + (dst * 16), val: hm_key(b: b, i: src_i))
    let _ = mem.store_i64(addr: snap + (dst * 16) + 8, val: hm_val(b: b, i: src_i))
    return hm_fill_snap(b: b, cp: cp, snap: snap, src_i: src_i + 1, dst: dst + 1)
  end
  return hm_fill_snap(b: b, cp: cp, snap: snap, src_i: src_i + 1, dst: dst)
end

let hm_key_at = fn (h: i64, idx: i64) -> i64 do
  if idx < 0 || idx >= hdr_count(h: h) then return 0 end
  return mem.load_i64(addr: hm_ensure_snap(h: h) + (idx * 16))
end

let hm_val_at = fn (h: i64, idx: i64) -> i64 do
  if idx < 0 || idx >= hdr_count(h: h) then return 0 end
  return mem.load_i64(addr: hm_ensure_snap(h: h) + (idx * 16) + 8)
end

// --- the hmap_* contract ---

/// Create an empty hash map; returns its header pointer (the opaque id).
export let hmap_new = fn () -> i64 do return hm_mk() end

/// Insert / update a key-value pair. Returns 0 (matching the Rust impl).
export let hmap_put = fn (a_id: i64, b_key: i64, c_value: i64) -> i64 do
  let _ = hm_put(h: a_id, key: b_key, value: c_value)
  return 0
end

/// Look up `b_key`; returns its value, or `c_default_val` if absent.
export let hmap_get = fn (a_id: i64, b_key: i64, c_default_val: i64) -> i64 do
  let idx = hm_find(b: hdr_buckets(h: a_id), cp: hdr_cp(h: a_id), key: b_key)
  if idx == 0 - 1 then return c_default_val end
  return hm_val(b: hdr_buckets(h: a_id), i: idx)
end

export let hmap_has = fn (a_id: i64, b_key: i64) -> bool do
  return hm_find(b: hdr_buckets(h: a_id), cp: hdr_cp(h: a_id), key: b_key) != 0 - 1
end

export let hmap_del = fn (a_id: i64, b_key: i64) -> bool do
  return hm_del(h: a_id, key: b_key)
end

export let hmap_size = fn (a_id: i64) -> i64 do return hdr_count(h: a_id) end

/// Key at iteration index `b_idx` (0 if out of bounds).
export let hmap_key_at = fn (a_id: i64, b_idx: i64) -> i64 do
  return hm_key_at(h: a_id, idx: b_idx)
end

/// Value at iteration index `b_idx` (0 if out of bounds).
export let hmap_val_at = fn (a_id: i64, b_idx: i64) -> i64 do
  return hm_val_at(h: a_id, idx: b_idx)
end

/// All keys, decimal, newline-joined (returns the packed string i64).
export let hmap_keys = fn (a_id: i64) -> i64 do
  return hm_join_i64(h: a_id, want_value: false)
end

/// All values, decimal, newline-joined (returns the packed string i64).
export let hmap_vals = fn (a_id: i64) -> i64 do
  return hm_join_i64(h: a_id, want_value: true)
end

export let hmap_free = fn (a_id: i64) -> bool do return true end

// =====================================================================
//  HashSet  (i64)  -- reuses the hmap machinery, value slot always 0
// =====================================================================

export let hset_new = fn () -> i64 do return hm_mk() end

/// Insert `b_val`; returns true if it was newly inserted.
export let hset_insert = fn (a_id: i64, b_val: i64) -> bool do
  return hm_put(h: a_id, key: b_val, value: 0) == 1
end

export let hset_contains = fn (a_id: i64, b_val: i64) -> bool do
  return hm_find(b: hdr_buckets(h: a_id), cp: hdr_cp(h: a_id), key: b_val) != 0 - 1
end

/// Remove `b_val`; returns true if it was present.
export let hset_remove = fn (a_id: i64, b_val: i64) -> bool do
  return hm_del(h: a_id, key: b_val)
end

export let hset_size = fn (a_id: i64) -> i64 do return hdr_count(h: a_id) end

/// All elements, decimal, newline-joined (returns the packed string i64).
export let hset_to_list = fn (a_id: i64) -> i64 do
  return hm_join_i64(h: a_id, want_value: false)
end

/// New set = union of the two given sets.
export let hset_union = fn (a_id_a: i64, b_id_b: i64) -> i64 do
  let r = hm_mk()
  let _ = hs_copy_all(dst: r, src: a_id_a)
  let _ = hs_copy_all(dst: r, src: b_id_b)
  return r
end

/// New set = intersection of the two given sets.
export let hset_intersection = fn (a_id_a: i64, b_id_b: i64) -> i64 do
  let r = hm_mk()
  let _ = hs_copy_if(dst: r, src: a_id_a, other: b_id_b, want_present: true)
  return r
end

/// New set = a \ b.
export let hset_difference = fn (a_id_a: i64, b_id_b: i64) -> i64 do
  let r = hm_mk()
  let _ = hs_copy_if(dst: r, src: a_id_a, other: b_id_b, want_present: false)
  return r
end

export let hset_free = fn (a_id: i64) -> bool do return true end

let hs_copy_all = fn (dst: i64, src: i64) -> unit do
  return hs_copy_all_go(dst: dst, b: hdr_buckets(h: src), cp: hdr_cp(h: src), i: 0)
end

let hs_copy_all_go = fn (dst: i64, b: i64, cp: i64, i: i64) -> unit do
  if i >= cp then return () end
  if hm_state(b: b, i: i) == st_full then
    let _ = hm_put(h: dst, key: hm_key(b: b, i: i), value: 0)
    return hs_copy_all_go(dst: dst, b: b, cp: cp, i: i + 1)
  end
  return hs_copy_all_go(dst: dst, b: b, cp: cp, i: i + 1)
end

let hs_copy_if = fn (dst: i64, src: i64, other: i64, want_present: bool) -> unit do
  return hs_copy_if_go(dst: dst, b: hdr_buckets(h: src), cp: hdr_cp(h: src), other: other, want_present: want_present, i: 0)
end

let hs_copy_if_go = fn (dst: i64, b: i64, cp: i64, other: i64, want_present: bool, i: i64) -> unit do
  if i >= cp then return () end
  if hm_state(b: b, i: i) == st_full then
    let k = hm_key(b: b, i: i)
    let present = hm_find(b: hdr_buckets(h: other), cp: hdr_cp(h: other), key: k) != 0 - 1
    let _ = if present == want_present then hm_put(h: dst, key: k, value: 0) else 0 end
    return hs_copy_if_go(dst: dst, b: b, cp: cp, other: other, want_present: want_present, i: i + 1)
  end
  return hs_copy_if_go(dst: dst, b: b, cp: cp, other: other, want_present: want_present, i: i + 1)
end

// =====================================================================
//  StringMap  (string key -> i64 value)
// =====================================================================
//
// smap slot i lives at  buckets + i*32 :  [key_ptr (0), key_len (8),
//                                          value (16), state (24)].

let sm_kptr = fn (b: i64, i: i64) -> i64 do return mem.load_i64(addr: b + (i * 32)) end
let sm_klen = fn (b: i64, i: i64) -> i64 do return mem.load_i64(addr: b + (i * 32) + 8) end
let sm_val = fn (b: i64, i: i64) -> i64 do return mem.load_i64(addr: b + (i * 32) + 16) end
let sm_state = fn (b: i64, i: i64) -> i64 do return mem.load_i64(addr: b + (i * 32) + 24) end
let sm_put_kptr = fn (b: i64, i: i64, v: i64) -> unit do return mem.store_i64(addr: b + (i * 32), val: v) end
let sm_put_klen = fn (b: i64, i: i64, v: i64) -> unit do return mem.store_i64(addr: b + (i * 32) + 8, val: v) end
let sm_put_val = fn (b: i64, i: i64, v: i64) -> unit do return mem.store_i64(addr: b + (i * 32) + 16, val: v) end
let sm_put_state = fn (b: i64, i: i64, v: i64) -> unit do return mem.store_i64(addr: b + (i * 32) + 24, val: v) end

let sm_mk = fn () -> i64 do
  let h = alloc_words(nw: 4)
  let cp = initial_cap
  let _ = set_count(h: h, v: 0)
  let _ = set_cp(h: h, v: cp)
  let _ = set_buckets(h: h, v: alloc_words(nw: cp * 4))
  let _ = set_snap(h: h, v: 0)
  return h
end

let sm_eq = fn (b: i64, i: i64, kptr: i64, klen: i64) -> bool do
  return sm_klen(b: b, i: i) == klen && bytes_eq(p1: sm_kptr(b: b, i: i), p2: kptr, n: klen, i: 0)
end

/// Index of the occupied slot holding key (kptr,klen), or -1.
let sm_find = fn (b: i64, cp: i64, kptr: i64, klen: i64) -> i64 do
  return sm_find_go(b: b, cp: cp, kptr: kptr, klen: klen, i: slot_of(hash: fnv1a(ptr: kptr, len: klen), cp: cp), steps: 0)
end

let sm_find_go = fn (b: i64, cp: i64, kptr: i64, klen: i64, i: i64, steps: i64) -> i64 do
  if steps >= cp then return 0 - 1 end
  let s = sm_state(b: b, i: i)
  if s == st_empty then return 0 - 1 end
  if s == st_full && sm_eq(b: b, i: i, kptr: kptr, klen: klen) then return i end
  return sm_find_go(b: b, cp: cp, kptr: kptr, klen: klen, i: next_slot(i: i, cp: cp), steps: steps + 1)
end

/// Insert key (kptr,klen)->value into `b` (cp, has room). `kptr` already
/// points at a stable copy of the key bytes. Returns 1 if a new key was added.
let sm_insert = fn (b: i64, cp: i64, kptr: i64, klen: i64, value: i64) -> i64 do
  return sm_insert_go(b: b, cp: cp, kptr: kptr, klen: klen, value: value, i: slot_of(hash: fnv1a(ptr: kptr, len: klen), cp: cp), first_tomb: 0 - 1, steps: 0)
end

let sm_insert_go = fn (b: i64, cp: i64, kptr: i64, klen: i64, value: i64, i: i64, first_tomb: i64, steps: i64) -> i64 do
  if steps >= cp then
    let _ = sm_put_kptr(b: b, i: first_tomb, v: kptr)
    let _ = sm_put_klen(b: b, i: first_tomb, v: klen)
    let _ = sm_put_val(b: b, i: first_tomb, v: value)
    let _ = sm_put_state(b: b, i: first_tomb, v: st_full)
    return 1
  end
  let s = sm_state(b: b, i: i)
  if s == st_full then
    if sm_eq(b: b, i: i, kptr: kptr, klen: klen) then
      let _ = sm_put_val(b: b, i: i, v: value)
      return 0
    end
    return sm_insert_go(b: b, cp: cp, kptr: kptr, klen: klen, value: value, i: next_slot(i: i, cp: cp), first_tomb: first_tomb, steps: steps + 1)
  end
  if s == st_tomb then
    let ft = if first_tomb == 0 - 1 then i else first_tomb end
    return sm_insert_go(b: b, cp: cp, kptr: kptr, klen: klen, value: value, i: next_slot(i: i, cp: cp), first_tomb: ft, steps: steps + 1)
  end
  let dest = if first_tomb == 0 - 1 then i else first_tomb end
  let _ = sm_put_kptr(b: b, i: dest, v: kptr)
  let _ = sm_put_klen(b: b, i: dest, v: klen)
  let _ = sm_put_val(b: b, i: dest, v: value)
  let _ = sm_put_state(b: b, i: dest, v: st_full)
  return 1
end

let sm_grow = fn (h: i64) -> unit do
  let old_b = hdr_buckets(h: h)
  let old_cp = hdr_cp(h: h)
  let new_cp = old_cp * 2
  let new_b = alloc_words(nw: new_cp * 4)
  let _ = sm_rehash(old_b: old_b, old_cp: old_cp, new_b: new_b, new_cp: new_cp, i: 0)
  let _ = set_cp(h: h, v: new_cp)
  return set_buckets(h: h, v: new_b)
end

let sm_rehash = fn (old_b: i64, old_cp: i64, new_b: i64, new_cp: i64, i: i64) -> unit do
  if i >= old_cp then return () end
  if sm_state(b: old_b, i: i) == st_full then
    let _ = sm_insert(b: new_b, cp: new_cp, kptr: sm_kptr(b: old_b, i: i), klen: sm_klen(b: old_b, i: i), value: sm_val(b: old_b, i: i))
    return sm_rehash(old_b: old_b, old_cp: old_cp, new_b: new_b, new_cp: new_cp, i: i + 1)
  end
  return sm_rehash(old_b: old_b, old_cp: old_cp, new_b: new_b, new_cp: new_cp, i: i + 1)
end

let sm_reserve_one = fn (h: i64) -> unit do
  if (hdr_count(h: h) + 1) * 4 < hdr_cp(h: h) * 3 then return () end
  return sm_grow(h: h)
end

let copy_key = fn (src: i64, len: i64) -> i64 do
  if len <= 0 then return 0 end
  let dst = arena.alloc_raw(size: len)
  let _ = copy_bytes(dst: dst, src: src, n: len, i: 0)
  return dst
end

/// Core put: copies the key bytes into a fresh allocation, then inserts.
/// Returns 1 if a new key was added, else 0.
let sm_put = fn (h: i64, kptr: i64, klen: i64, value: i64) -> i64 do
  let _ = sm_reserve_one(h: h)
  let existing = sm_find(b: hdr_buckets(h: h), cp: hdr_cp(h: h), kptr: kptr, klen: klen)
  if existing != 0 - 1 then
    let _ = sm_put_val(b: hdr_buckets(h: h), i: existing, v: value)
    let _ = invalidate(h: h)
    return 0
  end
  let added = sm_insert(b: hdr_buckets(h: h), cp: hdr_cp(h: h), kptr: copy_key(src: kptr, len: klen), klen: klen, value: value)
  let _ = if added == 1 then set_count(h: h, v: hdr_count(h: h) + 1) else () end
  let _ = invalidate(h: h)
  return added
end

let sm_del = fn (h: i64, kptr: i64, klen: i64) -> bool do
  let b = hdr_buckets(h: h)
  let idx = sm_find(b: b, cp: hdr_cp(h: h), kptr: kptr, klen: klen)
  if idx == 0 - 1 then return false end
  let _ = sm_put_state(b: b, i: idx, v: st_tomb)
  let _ = set_count(h: h, v: hdr_count(h: h) - 1)
  let _ = invalidate(h: h)
  return true
end

// --- snapshot for smap val_at: [v0, v1, ...], count words ---

let sm_ensure_vsnap = fn (h: i64) -> i64 do
  let cur = hdr_snap(h: h)
  if cur != 0 then return cur end
  let n = hdr_count(h: h)
  let snap = alloc_words(nw: if n <= 0 then 1 else n end)
  let _ = if n > 0 then sm_fill_vsnap(b: hdr_buckets(h: h), cp: hdr_cp(h: h), snap: snap, src_i: 0, dst: 0) else () end
  let _ = set_snap(h: h, v: snap)
  return snap
end

let sm_fill_vsnap = fn (b: i64, cp: i64, snap: i64, src_i: i64, dst: i64) -> unit do
  if src_i >= cp then return () end
  if sm_state(b: b, i: src_i) == st_full then
    let _ = mem.store_i64(addr: snap + (dst * 8), val: sm_val(b: b, i: src_i))
    return sm_fill_vsnap(b: b, cp: cp, snap: snap, src_i: src_i + 1, dst: dst + 1)
  end
  return sm_fill_vsnap(b: b, cp: cp, snap: snap, src_i: src_i + 1, dst: dst)
end

// --- the smap_* contract ---

export let smap_new = fn () -> i64 do return sm_mk() end

/// Insert / update `b_key` -> `d_value`. Returns 0 (matching the Rust impl).
export let smap_put = fn (a_id: i64, b_key_ptr: i32, c_key_len: i32, d_value: i64) -> i64 do
  let _ = sm_put(h: a_id, kptr: cast.i64_of(x: b_key_ptr), klen: cast.i64_of(x: c_key_len), value: d_value)
  return 0
end

/// Look up `b_key`; returns its value, or `d_default_val` if absent.
export let smap_get = fn (a_id: i64, b_key_ptr: i32, c_key_len: i32, d_default_val: i64) -> i64 do
  let idx = sm_find(b: hdr_buckets(h: a_id), cp: hdr_cp(h: a_id), kptr: cast.i64_of(x: b_key_ptr), klen: cast.i64_of(x: c_key_len))
  if idx == 0 - 1 then return d_default_val end
  return sm_val(b: hdr_buckets(h: a_id), i: idx)
end

export let smap_has = fn (a_id: i64, b_key_ptr: i32, c_key_len: i32) -> bool do
  return sm_find(b: hdr_buckets(h: a_id), cp: hdr_cp(h: a_id), kptr: cast.i64_of(x: b_key_ptr), klen: cast.i64_of(x: c_key_len)) != 0 - 1
end

export let smap_del = fn (a_id: i64, b_key_ptr: i32, c_key_len: i32) -> bool do
  return sm_del(h: a_id, kptr: cast.i64_of(x: b_key_ptr), klen: cast.i64_of(x: c_key_len))
end

export let smap_size = fn (a_id: i64) -> i64 do return hdr_count(h: a_id) end

/// All keys, joined by newline (returns the packed string i64; 0 if empty).
export let smap_keys = fn (a_id: i64) -> i64 do return sm_join_keys(h: a_id) end

/// All values, decimal, newline-joined (returns the packed string i64).
export let smap_vals = fn (a_id: i64) -> i64 do return sm_join_vals(h: a_id) end

export let smap_val_count = fn (a_id: i64) -> i64 do return hdr_count(h: a_id) end

/// Value at iteration index `b_idx` (0 if out of bounds).
export let smap_val_at = fn (a_id: i64, b_idx: i64) -> i64 do
  if b_idx < 0 || b_idx >= hdr_count(h: a_id) then return 0 end
  return mem.load_i64(addr: sm_ensure_vsnap(h: a_id) + (b_idx * 8))
end

export let smap_free = fn (a_id: i64) -> bool do return true end

// =====================================================================
//  Building newline-joined string results
// =====================================================================
//
// Strategy: compute the exact byte total first, allocate once, then fill.

/// Decimal-digit count of a non-negative i64 (>= 1).
let dec_digits = fn (n: i64) -> i64 do
  if n < 10 then return 1 end
  return 1 + dec_digits(n: n / 10)
end

/// Bytes needed to render i64 `v` in decimal (incl. a leading '-' if negative).
let i64_len = fn (v: i64) -> i64 do
  if v < 0 then return 1 + dec_digits(n: 0 - v) end
  return dec_digits(n: v)
end

/// Write `len` decimal digits of non-negative `v` right-aligned in [dst, dst+len).
let write_u64 = fn (dst: i64, v: i64, len: i64) -> unit do
  let _ = mem.store_u8(addr: dst + (len - 1), val: 48 + (v % 10))
  if len <= 1 then return () end
  return write_u64(dst: dst, v: v / 10, len: len - 1)
end

/// Write the decimal text of i64 `v` at `dst`; returns bytes written.
let write_i64 = fn (dst: i64, v: i64) -> i64 do
  if v < 0 then
    let _ = mem.store_u8(addr: dst, val: 45)
    let nd = dec_digits(n: 0 - v)
    let _ = write_u64(dst: dst + 1, v: 0 - v, len: nd)
    return 1 + nd
  end
  let nd = dec_digits(n: v)
  let _ = write_u64(dst: dst, v: v, len: nd)
  return nd
end

let put_sep = fn (dst: i64) -> i64 do
  let _ = mem.store_u8(addr: dst, val: 10)
  return 1
end

// --- hmap / hset element join (decimal, newline-separated) ---

let hm_join_size = fn (b: i64, cp: i64, want_value: bool, i: i64, acc: i64) -> i64 do
  if i >= cp then return acc end
  if hm_state(b: b, i: i) == st_full then
    let v = if want_value then hm_val(b: b, i: i) else hm_key(b: b, i: i) end
    return hm_join_size(b: b, cp: cp, want_value: want_value, i: i + 1, acc: acc + i64_len(v: v) + 1)
  end
  return hm_join_size(b: b, cp: cp, want_value: want_value, i: i + 1, acc: acc)
end

let hm_join_write = fn (dst: i64, b: i64, cp: i64, want_value: bool, i: i64, off: i64, first: bool) -> i64 do
  if i >= cp then return off end
  if hm_state(b: b, i: i) == st_full then
    let v = if want_value then hm_val(b: b, i: i) else hm_key(b: b, i: i) end
    let off1 = if first then off else off + put_sep(dst: dst + off) end
    let w = write_i64(dst: dst + off1, v: v)
    return hm_join_write(dst: dst, b: b, cp: cp, want_value: want_value, i: i + 1, off: off1 + w, first: false)
  end
  return hm_join_write(dst: dst, b: b, cp: cp, want_value: want_value, i: i + 1, off: off, first: first)
end

let hm_join_i64 = fn (h: i64, want_value: bool) -> i64 do
  let n = hdr_count(h: h)
  if n <= 0 then return 0 end
  let total = hm_join_size(b: hdr_buckets(h: h), cp: hdr_cp(h: h), want_value: want_value, i: 0, acc: 0) - 1
  let dst = arena.alloc_raw(size: total)
  let _ = hm_join_write(dst: dst, b: hdr_buckets(h: h), cp: hdr_cp(h: h), want_value: want_value, i: 0, off: 0, first: true)
  return (dst * two_pow_32) + total
end

// --- smap value join (decimal, newline-separated) ---

let sm_vsize = fn (b: i64, cp: i64, i: i64, acc: i64) -> i64 do
  if i >= cp then return acc end
  if sm_state(b: b, i: i) == st_full then
    return sm_vsize(b: b, cp: cp, i: i + 1, acc: acc + i64_len(v: sm_val(b: b, i: i)) + 1)
  end
  return sm_vsize(b: b, cp: cp, i: i + 1, acc: acc)
end

let sm_vwrite = fn (dst: i64, b: i64, cp: i64, i: i64, off: i64, first: bool) -> i64 do
  if i >= cp then return off end
  if sm_state(b: b, i: i) == st_full then
    let off1 = if first then off else off + put_sep(dst: dst + off) end
    let w = write_i64(dst: dst + off1, v: sm_val(b: b, i: i))
    return sm_vwrite(dst: dst, b: b, cp: cp, i: i + 1, off: off1 + w, first: false)
  end
  return sm_vwrite(dst: dst, b: b, cp: cp, i: i + 1, off: off, first: first)
end

let sm_join_vals = fn (h: i64) -> i64 do
  let n = hdr_count(h: h)
  if n <= 0 then return 0 end
  let total = sm_vsize(b: hdr_buckets(h: h), cp: hdr_cp(h: h), i: 0, acc: 0) - 1
  let dst = arena.alloc_raw(size: total)
  let _ = sm_vwrite(dst: dst, b: hdr_buckets(h: h), cp: hdr_cp(h: h), i: 0, off: 0, first: true)
  return (dst * two_pow_32) + total
end

// --- smap key join (raw key bytes, newline-separated) ---

let sm_ksize = fn (b: i64, cp: i64, i: i64, acc: i64) -> i64 do
  if i >= cp then return acc end
  if sm_state(b: b, i: i) == st_full then
    return sm_ksize(b: b, cp: cp, i: i + 1, acc: acc + sm_klen(b: b, i: i) + 1)
  end
  return sm_ksize(b: b, cp: cp, i: i + 1, acc: acc)
end

let sm_kwrite = fn (dst: i64, b: i64, cp: i64, i: i64, off: i64, first: bool) -> i64 do
  if i >= cp then return off end
  if sm_state(b: b, i: i) == st_full then
    let off1 = if first then off else off + put_sep(dst: dst + off) end
    let kl = sm_klen(b: b, i: i)
    let _ = copy_bytes(dst: dst + off1, src: sm_kptr(b: b, i: i), n: kl, i: 0)
    return sm_kwrite(dst: dst, b: b, cp: cp, i: i + 1, off: off1 + kl, first: false)
  end
  return sm_kwrite(dst: dst, b: b, cp: cp, i: i + 1, off: off, first: first)
end

let sm_join_keys = fn (h: i64) -> i64 do
  let n = hdr_count(h: h)
  if n <= 0 then return 0 end
  let total = sm_ksize(b: hdr_buckets(h: h), cp: hdr_cp(h: h), i: 0, acc: 0) - 1
  if total <= 0 then return 0 end
  let dst = arena.alloc_raw(size: total)
  let _ = sm_kwrite(dst: dst, b: hdr_buckets(h: h), cp: hdr_cp(h: h), i: 0, off: 0, first: true)
  return (dst * two_pow_32) + total
end

// =====================================================================
//  Tests (each returns one i64 to check via `wasmtime --invoke`)
// =====================================================================

/// Parse a packed (ptr<<32)|len string of newline-separated non-negative
/// decimal numbers, returning their sum.
let parse_lines_sum = fn (packed: i64) -> i64 do
  return parse_go(ptr: (packed >> 32) & 4294967295, len: packed & 4294967295, i: 0, cur: 0, acc: 0)
end

let parse_go = fn (ptr: i64, len: i64, i: i64, cur: i64, acc: i64) -> i64 do
  if i >= len then return acc + cur end
  let c = mem.load_u8(addr: ptr + i)
  if c == 10 then return parse_go(ptr: ptr, len: len, i: i + 1, cur: 0, acc: acc + cur) end
  return parse_go(ptr: ptr, len: len, i: i + 1, cur: (cur * 10) + (c - 48), acc: acc)
end

// === string-typed wrappers (the surface std:hashmap / std:stringmap use) =====
//
// Bridge a Nexus `string` (a packed i64 (ptr<<32)|len) to/from the raw
// (ptr,len) ABI of the smap impls and the packed-i64 string returns, via the
// `nexus:intrinsic` type-pun intrinsic (a no-op at the WASM level).

import external "nexus:intrinsic"
external pun_raw = "value_of_i64" : <T>(a_x: T) -> i64
external pun_str = "value_of_i64" : <T>(a_x: i64) -> T

let k_p = fn (s: string) -> i32 do return cast.i32_of(x: (pun_raw(a_x: s) / two_pow_32) & 4294967295) end
let k_l = fn (s: string) -> i32 do return cast.i32_of(x: pun_raw(a_x: s) & 4294967295) end

export let smap_put_str = fn (id: i64, key: string, value: i64) -> i64 do return smap_put(a_id: id, b_key_ptr: k_p(s: key), c_key_len: k_l(s: key), d_value: value) end
export let smap_get_str = fn (id: i64, key: string, default_val: i64) -> i64 do return smap_get(a_id: id, b_key_ptr: k_p(s: key), c_key_len: k_l(s: key), d_default_val: default_val) end
export let smap_has_str = fn (id: i64, key: string) -> bool do return smap_has(a_id: id, b_key_ptr: k_p(s: key), c_key_len: k_l(s: key)) end
export let smap_del_str = fn (id: i64, key: string) -> bool do return smap_del(a_id: id, b_key_ptr: k_p(s: key), c_key_len: k_l(s: key)) end
export let smap_keys_str = fn (id: i64) -> string do return pun_str(a_x: smap_keys(a_id: id)) end
