/**
 * runtime/collection: umbrella for HashMap / HashSet / StringMap runtime.
 * The implementations live under `runtime/collection/`:
 *   - `runtime/collection/core.nx`       shared open-addressing scaffolding
 *                                        (header, hashing, hmap insert/find/
 *                                        delete, snapshot, decimal-join).
 *   - `runtime/collection/hashmap.nx`    i64 -> i64 HashMap exports.
 *   - `runtime/collection/hashset.nx`    HashSet over i64 (set ops, joins).
 *   - `runtime/collection/stringmap.nx`  string -> i64 StringMap +
 *                                        string-typed wrappers.
 * This file is the stable import surface: `std:hashmap` and `std:stringmap`
 * continue to `import * as cm from "std:runtime/collection"` and pull names
 * via `cm.hmap_*` / `cm.hset_*` / `cm.smap_*`. Each export below forwards to
 * the implementation in its submodule.
 */
import * as hashmap from "std:runtime/collection/hashmap"
import * as hashset from "std:runtime/collection/hashset"
import * as stringmap from "std:runtime/collection/stringmap"

// === HashMap (i64 -> i64) ===================================================

export let hmap_new = fn () -> i64 do return hashmap.hmap_new() end
export let hmap_put = fn (
  a_id: i64,
  b_key: i64,
  c_value: i64
) -> i64 do return hashmap.hmap_put(a_id, b_key, c_value) end
export let hmap_get = fn (
  a_id: i64,
  b_key: i64,
  c_default_val: i64
) -> i64 do return hashmap.hmap_get(a_id, b_key, c_default_val) end
export let hmap_has = fn (a_id: i64, b_key: i64) -> bool do return hashmap.hmap_has(a_id, b_key) end
export let hmap_del = fn (a_id: i64, b_key: i64) -> bool do return hashmap.hmap_del(a_id, b_key) end
export let hmap_size = fn (a_id: i64) -> i64 do return hashmap.hmap_size(a_id) end
export let hmap_key_at = fn (
  a_id: i64,
  b_idx: i64
) -> i64 do return hashmap.hmap_key_at(a_id, b_idx) end
export let hmap_val_at = fn (
  a_id: i64,
  b_idx: i64
) -> i64 do return hashmap.hmap_val_at(a_id, b_idx) end
export let hmap_keys = fn (a_id: i64) -> i64 do return hashmap.hmap_keys(a_id) end
export let hmap_vals = fn (a_id: i64) -> i64 do return hashmap.hmap_vals(a_id) end
export let hmap_free = fn (a_id: i64) -> bool do return hashmap.hmap_free(a_id) end

// === HashSet ================================================================

export let hset_new = fn () -> i64 do return hashset.hset_new() end
export let hset_insert = fn (
  a_id: i64,
  b_val: i64
) -> bool do return hashset.hset_insert(a_id, b_val) end
export let hset_contains = fn (
  a_id: i64,
  b_val: i64
) -> bool do return hashset.hset_contains(a_id, b_val) end
export let hset_remove = fn (
  a_id: i64,
  b_val: i64
) -> bool do return hashset.hset_remove(a_id, b_val) end
export let hset_size = fn (a_id: i64) -> i64 do return hashset.hset_size(a_id) end
export let hset_to_list = fn (a_id: i64) -> i64 do return hashset.hset_to_list(a_id) end
export let hset_union = fn (
  a_id_a: i64,
  b_id_b: i64
) -> i64 do return hashset.hset_union(a_id_a, b_id_b) end
export let hset_intersection = fn (
  a_id_a: i64,
  b_id_b: i64
) -> i64 do return hashset.hset_intersection(a_id_a, b_id_b) end
export let hset_difference = fn (
  a_id_a: i64,
  b_id_b: i64
) -> i64 do return hashset.hset_difference(a_id_a, b_id_b) end
export let hset_free = fn (a_id: i64) -> bool do return hashset.hset_free(a_id) end

// === StringMap (string -> i64) ==============================================

export let smap_new = fn () -> i64 do return stringmap.smap_new() end
export let smap_put = fn (
  a_id: i64,
  b_key_ptr: i32,
  c_key_len: i32,
  d_value: i64
) -> i64 do return stringmap.smap_put(a_id, b_key_ptr, c_key_len, d_value) end
export let smap_get = fn (
  a_id: i64,
  b_key_ptr: i32,
  c_key_len: i32,
  d_default_val: i64
) -> i64 do return stringmap.smap_get(a_id, b_key_ptr, c_key_len, d_default_val) end
export let smap_has = fn (
  a_id: i64,
  b_key_ptr: i32,
  c_key_len: i32
) -> bool do return stringmap.smap_has(a_id, b_key_ptr, c_key_len) end
export let smap_del = fn (
  a_id: i64,
  b_key_ptr: i32,
  c_key_len: i32
) -> bool do return stringmap.smap_del(a_id, b_key_ptr, c_key_len) end
export let smap_size = fn (a_id: i64) -> i64 do return stringmap.smap_size(a_id) end
export let smap_keys = fn (a_id: i64) -> i64 do return stringmap.smap_keys(a_id) end
export let smap_vals = fn (a_id: i64) -> i64 do return stringmap.smap_vals(a_id) end
export let smap_val_count = fn (a_id: i64) -> i64 do return stringmap.smap_val_count(a_id) end
export let smap_val_at = fn (
  a_id: i64,
  b_idx: i64
) -> i64 do return stringmap.smap_val_at(a_id, b_idx) end
export let smap_free = fn (a_id: i64) -> bool do return stringmap.smap_free(a_id) end

// --- string-typed wrappers ---

export let smap_put_str = fn (
  id: i64,
  key: string,
  value: i64
) -> i64 do return stringmap.smap_put_str(id, key, value) end
export let smap_get_str = fn (
  id: i64,
  key: string,
  default_val: i64
) -> i64 do return stringmap.smap_get_str(id, key, default_val) end
export let smap_has_str = fn (
  id: i64,
  key: string
) -> bool do return stringmap.smap_has_str(id, key) end
export let smap_del_str = fn (
  id: i64,
  key: string
) -> bool do return stringmap.smap_del_str(id, key) end
export let smap_keys_str = fn (id: i64) -> string do return stringmap.smap_keys_str(id) end
