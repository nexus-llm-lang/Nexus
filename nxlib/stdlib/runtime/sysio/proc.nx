/**
 * runtime/sysio/proc: process runtime (exit, argv), backing `std:proc`.
 * Internal — re-exported by `runtime/sysio.nx`.
 */
import * as mem from "std:runtime/mem"
import * as core from "std:runtime/sysio/core"

// === exported: process (proc.nx) ============================================

/**
exit(code): terminate the instance. proc_exit does not return; the
`return ()` after is dead (Nexus has no `unreachable`). wasm sig (i64) -> ().
*/
export let exit = fn (a_status: i64) -> unit do
  core.w_proc_exit(a_code: core.i32of(x: a_status))
  return ()
end

/**
argv(): the program arguments joined with '\n' (arg0 = program name),
as a packed string -- the form proc.nx splits on. The WASI argv buffer is
already NUL-separated, so we just replace the NUL terminators with '\n' and
drop the trailing one (result len == argv_buf_size - 1). wasm sig () -> i64.
*/
export let argv = fn () -> i64 do
  let s = core.scratch()
  let argc_p = s + core.sl_argc
  let bufsz_p = s + core.sl_argbufsz
  if core.w_args_sizes_get(
    a_argc_ptr: core.i32of(x: argc_p),
    b_argv_buf_size_ptr: core.i32of(x: bufsz_p)
  ) != core.i32of(x: 0) then return 0 end
  let argc = mem.load_i32(addr: argc_p)
  let bufsz = mem.load_i32(addr: bufsz_p)
  if argc <= 0 || bufsz <= 1 then return 0 end
  let ptrs = core.alloc_bytes(n: argc * 4)
  let abuf = core.alloc_bytes(n: bufsz)
  if core.w_args_get(
    a_argv_ptr: core.i32of(x: ptrs),
    b_argv_buf_ptr: core.i32of(x: abuf)
  ) != core.i32of(x: 0) then return 0 end
  nul_to_nl(p: abuf, n: bufsz, i: 0)
  return core.pack(ptr: abuf, len: bufsz - 1)
end

let nul_to_nl = fn (p: i64, n: i64, i: i64) -> unit do
  if i >= n then return () end
  if mem.load_u8(addr: p + i) == 0 then mem.store_u8(addr: p + i, val: 10) end
  return nul_to_nl(p, n, i: i + 1)
end

// --- string-typed wrappers ---

export let exit_proc = fn (status: i64) -> unit do return exit(a_status: status) end
export let argv_str = fn () -> string do return core.pun_str(a_x: argv()) end
