/**
 * runtime/sysio/stdio: console (stdin/stdout/stderr) runtime, backing
 * `std:stdio`'s `print` / `eprint` / `getchar` / `read_line`. Internal —
 * the public surface is re-exported by `runtime/sysio.nx`.
 */
import * as mem from "std:runtime/mem"
import * as core from "std:runtime/sysio/core"

// === exported: console (stdio.nx) ===========================================

/** print(s): write s's bytes verbatim to fd 1. wasm sig (i32 i32) -> (). */
export let print = fn (a_s_ptr: i32, b_s_len: i32) -> unit do
  let _ = core.write_all(fd: 1, buf: core.i64of(x: a_s_ptr), len: core.i64of(x: b_s_len))
  return ()
end

/** eprint(s): write s's bytes verbatim to fd 2. wasm sig (i32 i32) -> (). */
export let eprint = fn (a_s_ptr: i32, b_s_len: i32) -> unit do
  let _ = core.write_all(fd: 2, buf: core.i64of(x: a_s_ptr), len: core.i64of(x: b_s_len))
  return ()
end

/**
getchar(): read one UTF-8 char from fd 0; return it as a packed string
(0 == empty string on EOF/error). Reads the lead byte, then the continuation
bytes its top bits imply (1..4 total). wasm sig () -> i64 (string).
*/
export let getchar = fn () -> i64 do
  let buf = core.alloc_bytes(n: 4)
  let n0 = read_n_exact(fd: 0, buf, off: 0, n: 1)
  if n0 < 1 then return 0 end
  let b0 = mem.load_u8(addr: buf)
  let width = if b0 < 128 then 1 else if b0 < 224 then 2 else if b0 < 240 then 3 else 4 end
  if width == 1 then return core.pack(ptr: buf, len: 1) end
  let _ = read_n_exact(fd: 0, buf, off: 1, n: width - 1)
  return core.pack(ptr: buf, len: width)
end

/**
Read exactly `n` bytes from `fd` into `buf+off` (best effort -- loops on
short reads). Returns the number actually read (< n on EOF/error).
*/
let read_n_exact = fn (fd: i64, buf: i64, off: i64, n: i64) -> i64 do
  if n <= 0 then return 0 end
  let s = core.scratch()
  let iov = s + core.sl_iovec
  let nr = s + core.sl_nrw
  let _ = mem.store_i32(addr: iov, val: buf + off)
  let _ = mem.store_i32(addr: iov + 4, val: n)
  let errno = core.w_fd_read(
    a_fd: core.i32of(x: fd),
    b_iovs_ptr: core.i32of(x: iov),
    c_iovs_len: core.i32of(x: 1),
    d_nread_ptr: core.i32of(x: nr)
  )
  if errno != core.i32of(x: 0) then return 0 end
  let got = mem.load_i32(addr: nr)
  if got <= 0 then return 0 end
  if got >= n then return n end
  return got + read_n_exact(fd, buf, off: off + got, n: n - got)
end

/**
read_line(): read fd 0 until '\n' or EOF; strip a trailing "\r\n" /
"\n"; return the line as a packed string. On immediate EOF (no bytes at all)
returns 0 (empty), matching the old Rust's Ok(0) -> empty. wasm sig () -> i64.
*/
export let read_line = fn () -> i64 do
  let cap0 = 256
  let buf = core.alloc_bytes(n: cap0)
  return read_line_go(buf, lim: cap0, len: 0)
end

/**
Read one more byte from fd 0; append to buf; stop on '\n' or EOF. Growth
allocates a fresh 2x buffer and copies (bump-allocator leak, fine).
*/
let read_line_go = fn (buf: i64, lim: i64, len: i64) -> i64 do
  if len >= lim then
    let ncap = lim * 2
    let nbuf = core.alloc_bytes(n: ncap)
    let _ = core.copy_bytes(dst: nbuf, src: buf, count: len)
    return read_line_go(buf: nbuf, lim: ncap, len)
  end
  let s = core.scratch()
  let iov = s + core.sl_iovec
  let nr = s + core.sl_nrw
  let _ = mem.store_i32(addr: iov, val: buf + len)
  let _ = mem.store_i32(addr: iov + 4, val: 1)
  let errno = core.w_fd_read(
    a_fd: core.i32of(x: 0),
    b_iovs_ptr: core.i32of(x: iov),
    c_iovs_len: core.i32of(x: 1),
    d_nread_ptr: core.i32of(x: nr)
  )
  if errno != core.i32of(x: 0) || mem.load_i32(addr: nr) <= 0 then
    return strip_eol(buf, len)
  end
  let b = mem.load_u8(addr: buf + len)
  if b == 10 then return strip_eol(buf, len: len + 1) end
  return read_line_go(buf, lim, len: len + 1)
end

/** Trim a trailing "\n" then a trailing "\r" from [buf, buf+len); pack. */
let strip_eol = fn (buf: i64, len: i64) -> i64 do
  let l1 = if len > 0 && mem.load_u8(addr: buf + len - 1) == 10 then len - 1 else len end
  let l2 = if l1 > 0 && mem.load_u8(addr: buf + l1 - 1) == 13 then l1 - 1 else l1 end
  return core.pack(ptr: buf, len: l2)
end

// --- string-typed wrappers ---

export let print_str = fn (s: string) -> unit do return print(
  a_s_ptr: core.s_p(s),
  b_s_len: core.s_l(s)
) end
export let eprint_str = fn (s: string) -> unit do return eprint(
  a_s_ptr: core.s_p(s),
  b_s_len: core.s_l(s)
) end
export let getchar_str = fn () -> string do return core.pun_str(a_x: getchar()) end
export let read_line_str = fn () -> string do return core.pun_str(a_x: read_line()) end
