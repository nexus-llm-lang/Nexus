/**
 * runtime/sysio/core: shared WASI preview1 imports, constants, scratch region,
 * path resolution, and fd read/write primitives backing every sub-module of
 * `runtime/sysio/`. Internal — consumers live under `runtime/sysio/`; the
 * public surface is re-exported by the `runtime/sysio.nx` umbrella.
 *
 * The implementations only CALL WASI preview1 imports (the host implements
 * them); see https://github.com/WebAssembly/WASI/blob/main/legacy/preview1.
 *
 * ABI note: Nexus lays out wasm function params in alphabetical name order,
 * but external callers (codegen) pass them positionally in external-decl
 * declaration order (each `string` expanded to <name>_ptr, <name>_len; a
 * `string` RETURN is the single packed (ptr<<32)|len i64). Every exported
 * impl in this hierarchy prefixes params a_, b_, c_, ... in declaration order,
 * and every WASI `external` decl below names its params a_, b_, ... in WASI
 * ABI order, so alphabetical == positional in both directions.
 *
 * Storage for returned strings + WASI out-param scratch comes from the
 * unified bump arena (`arena.alloc_raw`). A 512-byte scratch region is
 * lazily allocated and its pointer cached in linear-memory cell 8 (the
 * [8,16) slice of the reserved low memory — the bump cell only uses the
 * i64 at offset 0, so 8..16 is free). Reuse of one scratch region is fine
 * single-threaded; with wasi-threads concurrent fs/stdio calls would race
 * it — an accepted, documented caveat, the same as the allocator's reset
 * race.
 *
 * Path resolution: WASI path_* ops take a (preopen-dir fd, relative path) pair.
 * `resolve_path` walks the preopen table (fd 3, 4, 5, ...): a preopen named "."
 * becomes the cwd fallback; a preopen whose name is a path prefix (e.g. "/tmp")
 * is matched and the path made relative to it. Paths that match no preopen are
 * tried relative to the cwd preopen (or fd 3). Limitation: this handles
 * cwd-relative paths and paths under an explicit `--dir=` preopen; arbitrary
 * absolute paths with no covering preopen will fail.
 */
import external "wasi_snapshot_preview1"
import * as mem from "std:runtime/mem"
import * as cast from "std:runtime/cast"
import * as arena from "std:runtime/arena"

// === WASI preview1 imports (params named in ABI order) =======================

/** fd_write(fd, iovs_ptr, iovs_len, nwritten_ptr) -> errno. iovec = {buf:i32, buf_len:i32}. */
export external w_fd_write = "fd_write" : (a_fd: i32, b_iovs_ptr: i32, c_iovs_len: i32, d_nwritten_ptr: i32) -> i32
/** fd_read(fd, iovs_ptr, iovs_len, nread_ptr) -> errno. */
export external w_fd_read = "fd_read" : (a_fd: i32, b_iovs_ptr: i32, c_iovs_len: i32, d_nread_ptr: i32) -> i32
/** fd_close(fd) -> errno. */
export external w_fd_close = "fd_close" : (a_fd: i32) -> i32
/** fd_seek(fd, offset:i64, whence:i32, newoffset_ptr) -> errno. whence: 0=SET,1=CUR,2=END. */
export external w_fd_seek = "fd_seek" : (a_fd: i32, b_offset: i64, c_whence: i32, d_newoffset_ptr: i32) -> i32
/** fd_filestat_get(fd, filestat_ptr) -> errno. filestat: 64 bytes; filetype u8 @16, size u64 @32. */
export external w_fd_filestat_get = "fd_filestat_get" : (a_fd: i32, b_filestat_ptr: i32) -> i32
/** path_open(dirfd, dirflags, path_ptr, path_len, oflags, rights_base:i64, rights_inh:i64, fdflags, opened_fd_ptr) -> errno. */
export external w_path_open = "path_open" : (a_dirfd: i32, b_dirflags: i32, c_path_ptr: i32, d_path_len: i32, e_oflags: i32, f_rights_base: i64, g_rights_inh: i64, h_fdflags: i32, i_opened_fd_ptr: i32) -> i32
/** path_filestat_get(dirfd, flags, path_ptr, path_len, filestat_ptr) -> errno. */
export external w_path_filestat_get = "path_filestat_get" : (a_dirfd: i32, b_flags: i32, c_path_ptr: i32, d_path_len: i32, e_filestat_ptr: i32) -> i32
/** path_create_directory(dirfd, path_ptr, path_len) -> errno. */
export external w_path_create_directory = "path_create_directory" : (a_dirfd: i32, b_path_ptr: i32, c_path_len: i32) -> i32
/** path_unlink_file(dirfd, path_ptr, path_len) -> errno. */
export external w_path_unlink_file = "path_unlink_file" : (a_dirfd: i32, b_path_ptr: i32, c_path_len: i32) -> i32
/** fd_readdir(fd, buf_ptr, buf_len, cookie:i64, bufused_ptr) -> errno. dirent header = 24 bytes. */
export external w_fd_readdir = "fd_readdir" : (a_fd: i32, b_buf_ptr: i32, c_buf_len: i32, d_cookie: i64, e_bufused_ptr: i32) -> i32
/** fd_prestat_get(fd, prestat_ptr) -> errno. prestat: tag u8 @0, pr_name_len u32 @4. */
export external w_fd_prestat_get = "fd_prestat_get" : (a_fd: i32, b_prestat_ptr: i32) -> i32
/** fd_prestat_dir_name(fd, path_ptr, path_len) -> errno. */
export external w_fd_prestat_dir_name = "fd_prestat_dir_name" : (a_fd: i32, b_path_ptr: i32, c_path_len: i32) -> i32
/** proc_exit(code) -> unit (does not return -- traps/exits the instance). */
export external w_proc_exit = "proc_exit" : (a_code: i32) -> unit
/** args_sizes_get(argc_ptr, argv_buf_size_ptr) -> errno. */
export external w_args_sizes_get = "args_sizes_get" : (a_argc_ptr: i32, b_argv_buf_size_ptr: i32) -> i32
/** args_get(argv_ptr, argv_buf_ptr) -> errno. */
export external w_args_get = "args_get" : (a_argv_ptr: i32, b_argv_buf_ptr: i32) -> i32

// === constants ==============================================================

/** 2^32 -- multiplier to pack a (ptr, len) pair into a returned string i64. */
export let two_pow_32 = 4294967296
/** path_open oflags bits. */
let oflag_creat = 1
export let oflag_directory = 2
let oflag_trunc = 8
/** fdflags: append. */
let fdflag_append = 1
/** lookupflags: symlink_follow. */
export let lookup_symlink_follow = 1
/** filetype enum: regular file / directory. */
export let filetype_regular_file = 4
export let filetype_directory = 3
/** fd_seek whence: from start. */
let whence_set = 0
/**
Rights requested when opening a regular FILE for reading: fd_read(1<<1),
fd_seek(1<<2), fd_fdstat_set_flags(1<<3), fd_tell(1<<5), fd_advise(1<<7),
path_open(1<<13), path_readlink(1<<15), path_filestat_get(1<<18),
fd_filestat_get(1<<21) = 2 + 4 + 8 + 32 + 128 + 8192 + 32768 + 262144 +
2097152 = 2402430. Omits all write-ish rights.
*/
let rights_read = 2402430
/**
Rights requested when opening a DIRECTORY (for fd_readdir): just
fd_readdir(1<<14) | fd_filestat_get(1<<21) = 16384 + 2097152 = 2113536.
Requesting a broader set (fd_read, path_*, ...) on a directory makes
wasmtime's path_open return EISDIR (errno 31) -- this minimal set works.
*/
export let rights_dir = 2113536
/**
Rights requested for WRITE / append opens: a broad "all 29 rights bits" mask
(path_open intersects with the parent preopen's rights). Used only on file
paths the caller intends to write, so EISDIR-on-write correctly fails.
*/
let rights_write = 536870911
/**
Linear-memory cell holding the (lazily allocated) scratch-region pointer.
Lives in reserved low memory at offset 8 (the bump cell only uses the
i64 at offset 0). 0 means "not yet allocated".
*/
let scratch_cell = 8
/**
Scratch region size (bytes). Holds (at fixed offsets) an iovec, an
nwritten/nread i32, a seek out-param, args sizes, a (dirfd, rel_ptr, rel_len)
triple, an opened-fd i32, a prestat, a preopen dir-name buffer, a 64-byte
filestat, and the fd_readdir running state. 512 is comfortable.
*/
let scratch_size = 512
// --- fixed scratch-region slot offsets (all relative to scratch()) ---
export let sl_iovec = 0       // iovec {buf:i32, len:i32}, 8 bytes
export let sl_nrw = 8         // fd_read/fd_write n out (i32)
let sl_seek = 16       // fd_seek newoffset out (i64)
export let sl_argc = 24       // args_sizes_get argc out (i32)
export let sl_argbufsz = 28   // args_sizes_get bufsize out (i32)
export let sl_triple = 32     // resolve_path out: dirfd(8), rel_ptr(8), rel_len(8) -> 32..56
export let sl_opened = 56     // path_open opened-fd out (i32)
let sl_prestat = 64    // fd_prestat_get prestat out (8 bytes)
let sl_dirname = 72    // fd_prestat_dir_name name buffer (128 bytes) -> 72..200
let sl_filestat = 200  // filestat (64 bytes) -> 200..264
export let sl_dd_base = 264   // readdir: pairs-array base (i64)
export let sl_dd_cookie = 272 // readdir: last d_next cookie (i64)
export let sl_dd_cap = 280    // readdir: pairs-array capacity (i64)
export let sl_dd_used = 288   // readdir: fd_readdir bufused out (i32)
/** Largest preopen dir-name we accept (the sl_dirname slot is 128 bytes). */
let max_preopen_name = 128

// === low-level helpers ======================================================

export let i32of = fn (x: i64) -> i32 do return cast.i32_of(x) end
export let i64of = fn (x: i32) -> i64 do return cast.i64_of(x) end

/** Allocate `n` bytes; return the byte offset (0 when n <= 0). */
export let alloc_bytes = fn (n: i64) -> i64 do
  if n <= 0 then return 0 end
  return arena.alloc_raw(size: n)
end

/** Pack a (ptr, len) pair into the string return i64 (0 when len <= 0). */
export let pack = fn (ptr: i64, len: i64) -> i64 do
  if len <= 0 then return 0 end
  return (ptr * two_pow_32) + len
end

/** The (lazily allocated) scratch region pointer. */
export let scratch = fn () -> i64 do
  let cur = mem.load_i64(addr: scratch_cell)
  if cur != 0 then return cur end
  let p = alloc_bytes(n: scratch_size)
  let _ = mem.store_i64(addr: scratch_cell, val: p)
  return p
end

/** Copy `count` bytes from `src` to `dst` (forward; non-overlapping). */
export let copy_bytes = fn (dst: i64, src: i64, count: i64) -> unit do return copy_bytes_at(dst, src, count, i: 0) end
let copy_bytes_at = fn (dst: i64, src: i64, count: i64, i: i64) -> unit do
  if i >= count then return () end
  let _ = mem.store_u8(addr: dst + i, val: mem.load_u8(addr: src + i))
  return copy_bytes_at(dst, src, count, i: i + 1)
end

/** True iff [pa, pa+n) byte-equals [pb, pb+n). */
export let bytes_eq = fn (pa: i64, pb: i64, n: i64) -> bool do return bytes_eq_go(pa, pb, n, i: 0) end
let bytes_eq_go = fn (pa: i64, pb: i64, n: i64, i: i64) -> bool do
  if i >= n then return true end
  if mem.load_u8(addr: pa + i) != mem.load_u8(addr: pb + i) then return false end
  return bytes_eq_go(pa, pb, n, i: i + 1)
end

/** Lexicographic byte comparison of [pa, pa+la) vs [pb, pb+lb): <0, 0, >0. */
export let bytes_cmp = fn (pa: i64, la: i64, pb: i64, lb: i64) -> i64 do return bytes_cmp_go(pa, la, pb, lb, i: 0) end
let bytes_cmp_go = fn (pa: i64, la: i64, pb: i64, lb: i64, i: i64) -> i64 do
  if i >= la && i >= lb then return 0 end
  if i >= la then return 0 - 1 end
  if i >= lb then return 1 end
  let a = mem.load_u8(addr: pa + i)
  let b = mem.load_u8(addr: pb + i)
  if a < b then return 0 - 1 end
  if a > b then return 1 end
  return bytes_cmp_go(pa, la, pb, lb, i: i + 1)
end

// === path resolution ========================================================

/**
Strip a leading "./" (repeatedly) from [ptr, ptr+len); returns the new ptr;
the new len is `len - (returned_ptr - ptr)`.
*/
let strip_dot_slash = fn (ptr: i64, len: i64) -> i64 do
  if len >= 2 && mem.load_u8(addr: ptr) == 46 && mem.load_u8(addr: ptr + 1) == 47 then
    return strip_dot_slash(ptr: ptr + 2, len: len - 2)
  end
  return ptr
end

/**
Returns true iff [path, path+plen) starts with [pre, pre+prelen) followed by
either end-of-string or a '/'.
*/
let path_has_prefix = fn (path: i64, plen: i64, pre: i64, prelen: i64) -> bool do
  if prelen > plen then return false end
  if !bytes_eq(pa: path, pb: pre, n: prelen) then return false end
  if prelen == plen then return true end
  return mem.load_u8(addr: path + prelen) == 47
end

/**
Resolve a path to a (preopen dirfd, relative ptr, relative len) triple,
written as three i64 words into `out` (out+0=dirfd, out+8=rel_ptr,
out+16=rel_len). Callers pass `out = scratch() + sl_triple` and read the
dirfd/rel_ptr/rel_len back from there, then issue the WASI path_* call
before any other scratch use.
*/
export let resolve_path = fn (path_ptr: i64, path_len: i64, out: i64) -> unit do
  let p2 = strip_dot_slash(ptr: path_ptr, len: path_len)
  let l2 = path_len - (p2 - path_ptr)
  // Default: fd 3 (the conventional cwd preopen under wasmtime --dir=.), whole path.
  let _ = mem.store_i64(addr: out, val: 3)
  let _ = mem.store_i64(addr: out + 8, val: p2)
  let _ = mem.store_i64(addr: out + 16, val: l2)
  return resolve_walk(path_ptr: p2, path_len: l2, fd: 3, out)
end

let resolve_walk = fn (path_ptr: i64, path_len: i64, fd: i64, out: i64) -> unit do
  let s = scratch()
  let pre = s + sl_prestat
  let nm = s + sl_dirname
  if w_fd_prestat_get(a_fd: i32of(x: fd), b_prestat_ptr: i32of(x: pre)) != i32of(x: 0) then return () end
  // prestat tag (u8 @0) must be 0 (a directory preopen); name length is u32 @4.
  if mem.load_u8(addr: pre) != 0 then return resolve_walk(path_ptr, path_len, fd: fd + 1, out) end
  let nlen = mem.load_i32(addr: pre + 4)
  if nlen <= 0 || nlen > max_preopen_name then return resolve_walk(path_ptr, path_len, fd: fd + 1, out) end
  if w_fd_prestat_dir_name(a_fd: i32of(x: fd), b_path_ptr: i32of(x: nm), c_path_len: i32of(x: nlen)) != i32of(x: 0) then
    return resolve_walk(path_ptr, path_len, fd: fd + 1, out)
  end
  // preopen named "." -> a cwd preopen: record it (overrides the fd-3 default),
  // but keep walking in case a more-specific named preopen also matches.
  if nlen == 1 && mem.load_u8(addr: nm) == 46 then
    let _ = mem.store_i64(addr: out, val: fd)
    let _ = mem.store_i64(addr: out + 8, val: path_ptr)
    let _ = mem.store_i64(addr: out + 16, val: path_len)
    return resolve_walk(path_ptr, path_len, fd: fd + 1, out)
  end
  // preopen name is a path prefix -> match: open relative to this dir.
  if path_has_prefix(path: path_ptr, plen: path_len, pre: nm, prelen: nlen) then
    let _ = mem.store_i64(addr: out, val: fd)
    if nlen == path_len then
      // path == preopen name: relative path is ".". Reuse the dir-name slot
      // (now consumed) to hold a single '.' byte and point at it.
      let _ = mem.store_u8(addr: nm, val: 46)
      let _ = mem.store_i64(addr: out + 8, val: nm)
      let _ = mem.store_i64(addr: out + 16, val: 1)
    else
      // skip the prefix and the following '/'
      let _ = mem.store_i64(addr: out + 8, val: path_ptr + nlen + 1)
      let _ = mem.store_i64(addr: out + 16, val: path_len - nlen - 1)
    end
    return ()
  end
  return resolve_walk(path_ptr, path_len, fd: fd + 1, out)
end

/**
Open `path` (resolving preopens) with the given oflags/fdflags/rights.
Returns the opened fd (>= 0) on success, or -1 on any failure.
*/
let open_path_rights = fn (path_ptr: i64, path_len: i64, oflags: i64, fdflags: i64, rights: i64) -> i64 do
  if path_len <= 0 then return 0 - 1 end
  let s = scratch()
  let triple = s + sl_triple
  let _ = resolve_path(path_ptr, path_len, out: triple)
  let dirfd = mem.load_i64(addr: triple)
  let rp = mem.load_i64(addr: triple + 8)
  let rl = mem.load_i64(addr: triple + 16)
  if rl <= 0 then return 0 - 1 end
  let opened = s + sl_opened
  let errno = w_path_open(a_dirfd: i32of(x: dirfd),
                          b_dirflags: i32of(x: lookup_symlink_follow),
                          c_path_ptr: i32of(x: rp), d_path_len: i32of(x: rl),
                          e_oflags: i32of(x: oflags),
                          f_rights_base: rights, g_rights_inh: rights,
                          h_fdflags: i32of(x: fdflags),
                          i_opened_fd_ptr: i32of(x: opened))
  if errno != i32of(x: 0) then return 0 - 1 end
  return mem.load_i32(addr: opened)
end

/** Open `path` for reading (read rights, no oflags/fdflags). */
export let open_path_read = fn (path_ptr: i64, path_len: i64) -> i64 do
  return open_path_rights(path_ptr, path_len, oflags: 0, fdflags: 0, rights: rights_read)
end

/** Open `path` create+trunc for writing (broad write rights). */
export let open_path_write = fn (path_ptr: i64, path_len: i64) -> i64 do
  return open_path_rights(path_ptr, path_len, oflags: oflag_creat | oflag_trunc, fdflags: 0, rights: rights_write)
end

/** Open `path` create+append for writing (broad write rights, append fdflag). */
export let open_path_append = fn (path_ptr: i64, path_len: i64) -> i64 do
  return open_path_rights(path_ptr, path_len, oflags: oflag_creat, fdflags: fdflag_append, rights: rights_write)
end

/** The filestat scratch slot (64 bytes): filetype is u8 at +16, size is u64 at +32. */
export let filestat_slot = fn () -> i64 do return scratch() + sl_filestat end

/** path_filestat_get(path) into the filestat slot; returns errno (0 == ok). */
export let do_path_filestat = fn (path_ptr: i64, path_len: i64) -> i64 do
  if path_len <= 0 then return 0 - 1 end
  let s = scratch()
  let triple = s + sl_triple
  let _ = resolve_path(path_ptr, path_len, out: triple)
  let dirfd = mem.load_i64(addr: triple)
  let rp = mem.load_i64(addr: triple + 8)
  let rl = mem.load_i64(addr: triple + 16)
  if rl <= 0 then return 0 - 1 end
  let errno = w_path_filestat_get(a_dirfd: i32of(x: dirfd), b_flags: i32of(x: lookup_symlink_follow),
                                  c_path_ptr: i32of(x: rp), d_path_len: i32of(x: rl),
                                  e_filestat_ptr: i32of(x: filestat_slot()))
  return i64of(x: errno)
end

// === fd read/write primitives ===============================================

/**
Write all `len` bytes at `buf` to `fd` via repeated fd_write. Returns true
iff every byte went out.
*/
export let write_all = fn (fd: i64, buf: i64, len: i64) -> bool do
  if len <= 0 then return true end
  let s = scratch()
  let iov = s + sl_iovec
  let nw = s + sl_nrw
  let _ = mem.store_i32(addr: iov, val: buf)
  let _ = mem.store_i32(addr: iov + 4, val: len)
  let errno = w_fd_write(a_fd: i32of(x: fd), b_iovs_ptr: i32of(x: iov), c_iovs_len: i32of(x: 1), d_nwritten_ptr: i32of(x: nw))
  if errno != i32of(x: 0) then return false end
  let n = mem.load_i32(addr: nw)
  if n <= 0 then return false end
  if n >= len then return true end
  return write_all(fd, buf: buf + n, len: len - n)
end

/**
Read up to `lim` bytes from `fd` into `buf` via repeated fd_read until EOF
or `lim` reached. Returns the total byte count read (>= 0), or -1 on error.
*/
let read_fill = fn (fd: i64, buf: i64, lim: i64) -> i64 do return read_fill_go(fd, buf, lim, total: 0) end
let read_fill_go = fn (fd: i64, buf: i64, lim: i64, total: i64) -> i64 do
  if total >= lim then return total end
  let s = scratch()
  let iov = s + sl_iovec
  let nr = s + sl_nrw
  let _ = mem.store_i32(addr: iov, val: buf + total)
  let _ = mem.store_i32(addr: iov + 4, val: lim - total)
  let errno = w_fd_read(a_fd: i32of(x: fd), b_iovs_ptr: i32of(x: iov), c_iovs_len: i32of(x: 1), d_nread_ptr: i32of(x: nr))
  if errno != i32of(x: 0) then
    if total > 0 then return total end
    return 0 - 1
  end
  let n = mem.load_i32(addr: nr)
  if n <= 0 then return total end
  return read_fill_go(fd, buf, lim, total: total + n)
end

/**
Read the entire file at `fd` (seeks to 0 first), returning a packed string.
Uses fd_filestat_get to size the allocation; for a 0/unknown size it falls
back to a 1 MiB buffer (compiler source files are far smaller).
*/
export let read_whole_fd = fn (fd: i64) -> i64 do
  let s = scratch()
  let _ = w_fd_seek(a_fd: i32of(x: fd), b_offset: 0, c_whence: i32of(x: whence_set), d_newoffset_ptr: i32of(x: s + sl_seek))
  let st = filestat_slot()
  let have_stat = w_fd_filestat_get(a_fd: i32of(x: fd), b_filestat_ptr: i32of(x: st)) == i32of(x: 0)
  let sz = if have_stat then mem.load_i64(addr: st + 32) else 0 end
  if sz == 0 then
    let fb = alloc_bytes(n: 1048576)
    let g0 = read_fill(fd, buf: fb, lim: 1048576)
    if g0 <= 0 then return 0 end
    return pack(ptr: fb, len: g0)
  end
  let buf = alloc_bytes(n: sz)
  let got = read_fill(fd, buf, lim: sz)
  if got <= 0 then return 0 end
  return pack(ptr: buf, len: got)
end

// === string-pun helpers (used by every submodule's *_str wrappers) ==========

import external "nexus:intrinsic"
export external pun_raw = "value_of_i64" : <T>(a_x: T) -> i64
export external pun_str = "value_of_i64" : <T>(a_x: i64) -> T

/** (ptr<<32)|len string -> high i32 (ptr). */
export let s_p = fn (s: string) -> i32 do return cast.i32_of(x: (pun_raw(a_x: s) / two_pow_32) & 4294967295) end
/** (ptr<<32)|len string -> low i32 (len). */
export let s_l = fn (s: string) -> i32 do return cast.i32_of(x: pun_raw(a_x: s) & 4294967295) end
