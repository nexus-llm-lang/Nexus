/**
 * std:runtime/arena: Region-based memory management intrinsics.
 *
 * Everything that allocates — codegen-emitted heap objects, string concat,
 * the inlined stdlib's ByteBuffer/HashMap/string scratch — bumps a single
 * atomic i32 cell at linear-memory offset `wdefs.heap_ptr_cell` (initialised
 * to `heap_base` by a data segment). A "mark" is just that cell's current
 * value; reset stores a prior value back.
 *
 * heap_mark()        Atomic load of the bump cell, returned as i64.
 * heap_reset(mark)   Atomic store of `mark` back into the bump cell —
 *                    reclaims every allocation made after the mark in O(1).
 * heap_swap(base)    Atomic load + store: returns the prior value, installs
 *                    `base`. Use for double-buffer / generational schemes.
 *
 * Thread safety: under `-S threads`, the cell is shared linear memory and
 * every bump is `i32.atomic.rmw.add`, so cross-thread races on the allocator
 * itself can't corrupt it. Per-region reset is still the caller's
 * responsibility — calling reset while a worker thread is allocating into
 * the same region will reclaim that worker's allocations.
 */
import external "nexus:intrinsic"

export external heap_mark = "heap_mark" : () -> i64
export external heap_reset = "heap_reset" : (mark: i64) -> unit
export external heap_swap = "heap_swap" : (base: i64) -> i64

/** Raw bump allocation off the unified atomic heap cell. `size` is rounded up
 *  to a multiple of 8; the returned pointer is 8-aligned. Codegen emits this
 *  inline (kebab name `alloc-raw`) — it never becomes a real wasm import.
 */
export external alloc_raw = "alloc_raw" : (size: i64) -> i64
