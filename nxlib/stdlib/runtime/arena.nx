/**
 * std:runtime/arena: Region-based memory management intrinsics.
 *
 * Everything that allocates — codegen-emitted heap objects, string concat,
 * the inlined stdlib's ByteBuffer/HashMap/string scratch — bumps a single
 * atomic i32 cell at linear-memory offset `wdefs.heap_ptr_cell` (initialised
 * to `heap_base` by a data segment). A "mark" is just that cell's current
 * value; reset stores a prior value back.
 *
 * heap_mark()        Atomic load of the bump cell, returned as i64.
 * heap_reset(mark)   Atomic store of `mark` back into the bump cell —
 *                    reclaims every allocation made after the mark in O(1).
 * heap_swap(base)    Atomic load + store: returns the prior value, installs
 *                    `base`. Use for double-buffer / generational schemes.
 *
 * Thread safety: under `-S threads`, the cell is shared linear memory and
 * every bump is `i32.atomic.rmw.add`, so cross-thread races on the allocator
 * itself can't corrupt it. Per-region reset is still the caller's
 * responsibility — calling reset while a worker thread is allocating into
 * the same region will reclaim that worker's allocations.
 *
 * request_mark_cell (offset 8, i64): scratch slot for long-running servers to
 * bound per-request pipeline allocations.  `save_request_mark` snapshots the
 * current bump pointer into this cell; `reset_to_request_mark` resets the bump
 * pointer to the saved value, reclaiming every allocation made since the last
 * save.  The cell is initialised to 0 (no mark saved); callers must ensure all
 * live data allocated since the saved mark has been fully consumed (e.g.
 * serialised to the wire) before calling reset.  The slot at [8,16) is the
 * former sysio lazy-scratch-pointer slot which is no longer used by sysio.
 */
import external "nexus:intrinsic"
import * as mem from "std:runtime/mem"

export external heap_mark = "heap_mark" : () -> i64
export external heap_reset = "heap_reset" : (mark: i64) -> unit
export external heap_swap = "heap_swap" : (base: i64) -> i64

/** Raw bump allocation off the unified atomic heap cell. `size` is rounded up
 *  to a multiple of 8; the returned pointer is 8-aligned. Codegen emits this
 *  inline (kebab name `alloc-raw`) — it never becomes a real wasm import.
 */
export external alloc_raw = "alloc_raw" : (size: i64) -> i64

/** Linear-memory byte offset of the LSP-request scratch cell (i64, 8 bytes).
 *  Offset [8,16) was the former sysio lazy-scratch-pointer; now reserved for
 *  arena's per-LSP-request pipeline mark used by `publish_for_buffer`.
 */
let request_mark_cell = 8

/** Save the current bump-pointer into the LSP request-mark cell.  Call this
 *  after any persistent per-request state (document store cons-cells) has been
 *  allocated and before entering the expensive pipeline.  A subsequent call to
 *  `reset_to_request_mark` will reclaim all allocations made since this point.
 */
export let save_request_mark = fn () -> unit do
  return mem.store_i64(addr: request_mark_cell, val: heap_mark())
end

/** Reset the bump pointer to the value saved by `save_request_mark`, reclaiming
 *  the pipeline scratch in O(1).  Safe only when all data above the mark has been
 *  written to a wire transport.  No-op if no mark has been saved (cell == 0).
 */
export let reset_to_request_mark = fn () -> unit do
  let saved = mem.load_i64(addr: request_mark_cell)
  if saved != 0 then
    return heap_reset(mark: saved)
  end
  return ()
end
