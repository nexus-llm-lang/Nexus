/**
 * std:runtime/atomic: thread-atomic memory intrinsics (wasm threads proposal).
 *
 * Each operation lowers to a single 0xFE-prefixed wasm instruction — no host
 * call, no import entry (codegen inlines these and filters them out of the
 * import section, like `std:runtime/mem`). Addresses and values cross the
 * FFI boundary as `i64` and are wrapped to wasm `i32` internally.
 *
 * `wait32` / `notify` trap at runtime unless the linear memory is declared
 * `shared` (i.e. a threads build). `rmw_add` / `load` / `store` / `cmpxchg`
 * also operate on non-shared memory, just without cross-thread ordering
 * guarantees, so they are usable in any build.
 *
 * Natural alignment is enforced by the validator: every op here is i32-width
 * (4-byte aligned). Pass addresses that are 4-byte aligned.
 */
import external "nexus:intrinsic"

/**
Atomic read-modify-write add at `addr`. Returns the value held *before*
the add (the classic bump-pointer-allocator primitive).
*/
export external rmw_add_i32 = "atomic_rmw_add_i32" : (addr: i64, val: i64) -> i64

/** Atomic load of the i32 at `addr`. */
export external load_i32 = "atomic_load_i32" : (addr: i64) -> i64

/** Atomic store of `val` (low 32 bits) to `addr`. */
export external store_i32 = "atomic_store_i32" : (addr: i64, val: i64) -> unit

/**
Atomic compare-and-swap. Stores `replacement` at `addr` iff the current
value equals `expected`. Returns whatever value was at `addr` *before*
the attempt; the swap succeeded iff that returned value == `expected`.
*/
export external cmpxchg_i32 = "atomic_cmpxchg_i32" : (addr: i64, expected: i64, replacement: i64) -> i64

/**
Block the calling thread until `[addr] != expected`, until `notify` wakes
it, or until `timeout_ns` nanoseconds elapse (`-1` = wait forever).
Returns 0 = woken by `notify`, 1 = `[addr]` was already != `expected`,
2 = timed out. Traps unless the memory is `shared`.
*/
export external wait32 = "atomic_wait32" : (addr: i64, expected: i64, timeout_ns: i64) -> i64

/**
Wake up to `count` threads waiting on `addr` (use a large `count` to wake
all). Returns the number of threads actually woken.
*/
export external notify = "atomic_notify" : (addr: i64, count: i64) -> i64
