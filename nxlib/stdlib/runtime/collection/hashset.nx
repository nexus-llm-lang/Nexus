/**
 * runtime/collection/hashset: HashSet over i64 — reuses the hmap machinery
 * with value slot always 0. Backs `std:hashmap`'s HashSet. Internal —
 * re-exported by `runtime/collection.nx`.
 */
import * as core from "std:runtime/collection/core"

export let hset_new = fn () -> i64 do return core.hm_mk() end

/** Insert `b_val`; returns true if it was newly inserted. */
export let hset_insert = fn (a_id: i64, b_val: i64) -> bool do
  return core.hm_put(h: a_id, key: b_val, value: 0) == 1
end

export let hset_contains = fn (a_id: i64, b_val: i64) -> bool do
  return core.hm_find(b: core.hdr_buckets(h: a_id), cp: core.hdr_cp(h: a_id), key: b_val) != 0 - 1
end

/** Remove `b_val`; returns true if it was present. */
export let hset_remove = fn (a_id: i64, b_val: i64) -> bool do
  return core.hm_del(h: a_id, key: b_val)
end

export let hset_size = fn (a_id: i64) -> i64 do return core.hdr_count(h: a_id) end

/** All elements, decimal, newline-joined (returns the packed string i64). */
export let hset_to_list = fn (a_id: i64) -> i64 do
  return core.hm_join_i64(h: a_id, want_value: false)
end

/** New set = union of the two given sets. */
export let hset_union = fn (a_id_a: i64, b_id_b: i64) -> i64 do
  let r = core.hm_mk()
  let _ = hs_copy_all(dst: r, src: a_id_a)
  let _ = hs_copy_all(dst: r, src: b_id_b)
  return r
end

/** New set = intersection of the two given sets. */
export let hset_intersection = fn (a_id_a: i64, b_id_b: i64) -> i64 do
  let r = core.hm_mk()
  let _ = hs_copy_if(dst: r, src: a_id_a, other: b_id_b, want_present: true)
  return r
end

/** New set = a \ b. */
export let hset_difference = fn (a_id_a: i64, b_id_b: i64) -> i64 do
  let r = core.hm_mk()
  let _ = hs_copy_if(dst: r, src: a_id_a, other: b_id_b, want_present: false)
  return r
end

export let hset_free = fn (a_id: i64) -> bool do return true end

let hs_copy_all = fn (dst: i64, src: i64) -> unit do
  return hs_copy_all_go(dst, b: core.hdr_buckets(h: src), cp: core.hdr_cp(h: src), i: 0)
end

let hs_copy_all_go = fn (dst: i64, b: i64, cp: i64, i: i64) -> unit do
  if i >= cp then return () end
  if core.hm_state(b, i) == core.st_full then
    let _ = core.hm_put(h: dst, key: core.hm_key(b, i), value: 0)
    return hs_copy_all_go(dst, b, cp, i: i + 1)
  end
  return hs_copy_all_go(dst, b, cp, i: i + 1)
end

let hs_copy_if = fn (dst: i64, src: i64, other: i64, want_present: bool) -> unit do
  return hs_copy_if_go(
    dst,
    b: core.hdr_buckets(h: src),
    cp: core.hdr_cp(h: src),
    other,
    want_present,
    i: 0
  )
end

let hs_copy_if_go = fn (
  dst: i64,
  b: i64,
  cp: i64,
  other: i64,
  want_present: bool,
  i: i64
) -> unit do
  if i >= cp then return () end
  if core.hm_state(b, i) == core.st_full then
    let k = core.hm_key(b, i)
    let present = core.hm_find(
      b: core.hdr_buckets(h: other),
      cp: core.hdr_cp(h: other),
      key: k
    ) != 0 - 1
    let _ = if present == want_present then core.hm_put(h: dst, key: k, value: 0) else 0 end
    return hs_copy_if_go(dst, b, cp, other, want_present, i: i + 1)
  end
  return hs_copy_if_go(dst, b, cp, other, want_present, i: i + 1)
end
