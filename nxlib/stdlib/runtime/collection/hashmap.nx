/**
 * runtime/collection/hashmap: i64 -> i64 HashMap exports, backing
 * `std:hashmap`'s HashMap. Internal — re-exported by `runtime/collection.nx`.
 * The open-addressing machinery lives in `runtime/collection/core.nx`.
 */
import * as core from "std:runtime/collection/core"

/// Create an empty hash map; returns its header pointer (the opaque id).
export let hmap_new = fn () -> i64 do return core.hm_mk() end

/// Insert / update a key-value pair. Returns 0 (matching the Rust impl).
export let hmap_put = fn (a_id: i64, b_key: i64, c_value: i64) -> i64 do
  let _ = core.hm_put(h: a_id, key: b_key, value: c_value)
  return 0
end

/// Look up `b_key`; returns its value, or `c_default_val` if absent.
export let hmap_get = fn (a_id: i64, b_key: i64, c_default_val: i64) -> i64 do
  let idx = core.hm_find(b: core.hdr_buckets(h: a_id), cp: core.hdr_cp(h: a_id), key: b_key)
  if idx == 0 - 1 then return c_default_val end
  return core.hm_val(b: core.hdr_buckets(h: a_id), i: idx)
end

export let hmap_has = fn (a_id: i64, b_key: i64) -> bool do
  return core.hm_find(b: core.hdr_buckets(h: a_id), cp: core.hdr_cp(h: a_id), key: b_key) != 0 - 1
end

export let hmap_del = fn (a_id: i64, b_key: i64) -> bool do
  return core.hm_del(h: a_id, key: b_key)
end

export let hmap_size = fn (a_id: i64) -> i64 do return core.hdr_count(h: a_id) end

/// Key at iteration index `b_idx` (0 if out of bounds).
export let hmap_key_at = fn (a_id: i64, b_idx: i64) -> i64 do
  return core.hm_key_at(h: a_id, idx: b_idx)
end

/// Value at iteration index `b_idx` (0 if out of bounds).
export let hmap_val_at = fn (a_id: i64, b_idx: i64) -> i64 do
  return core.hm_val_at(h: a_id, idx: b_idx)
end

/// All keys, decimal, newline-joined (returns the packed string i64).
export let hmap_keys = fn (a_id: i64) -> i64 do
  return core.hm_join_i64(h: a_id, want_value: false)
end

/// All values, decimal, newline-joined (returns the packed string i64).
export let hmap_vals = fn (a_id: i64) -> i64 do
  return core.hm_join_i64(h: a_id, want_value: true)
end

export let hmap_free = fn (a_id: i64) -> bool do return true end
