/**
 * runtime/sysio: umbrella for the console + filesystem + process runtime
 * on raw WASI preview1. The implementations live under `runtime/sysio/`:
 *   - `runtime/sysio/core.nx`  shared WASI imports, scratch region, path
 *                              resolution, fd r/w primitives, string puns.
 *   - `runtime/sysio/stdio.nx` print / eprint / getchar / read_line.
 *   - `runtime/sysio/proc.nx`  exit / argv.
 *   - `runtime/sysio/fs.nx`    fs path ops + fd handles + raw byte-buffer
 *                              entry points.
 * This file is the stable import surface: `std:stdio`, `std:fs`, `std:proc`,
 * `std:bytebuffer` and friends continue to `import { ... } from
 * "std:runtime/sysio"`. Each export below is a thin forwarder to the
 * implementation in its submodule; duplicate WASI / intrinsic externals are
 * deduped by codegen so there is no per-submodule WASI import overhead.
 */
import * as stdio from "std:runtime/sysio/stdio"
import * as proc from "std:runtime/sysio/proc"
import * as fs from "std:runtime/sysio/fs"
import { Option } from "std:core/option"

// === console ================================================================

export let print = fn (
  a_s_ptr: i32,
  b_s_len: i32
) -> unit do return stdio.print(a_s_ptr, b_s_len) end
export let eprint = fn (
  a_s_ptr: i32,
  b_s_len: i32
) -> unit do return stdio.eprint(a_s_ptr, b_s_len) end
export let getchar = fn () -> i64 do return stdio.getchar() end
export let read_line = fn () -> i64 do return stdio.read_line() end
export let print_str = fn (s: string) -> unit do return stdio.print_str(s) end
export let eprint_str = fn (s: string) -> unit do return stdio.eprint_str(s) end
export let getchar_str = fn () -> string do return stdio.getchar_str() end
export let read_line_str = fn () -> string do return stdio.read_line_str() end
export let read_line_opt = fn () -> Option<string> do return stdio.read_line_opt() end

// === process ================================================================

export let exit = fn (a_status: i64) -> unit do return proc.exit(a_status) end
export let argv = fn () -> i64 do return proc.argv() end
export let exit_proc = fn (status: i64) -> unit do return proc.exit_proc(status) end
export let argv_str = fn () -> string do return proc.argv_str() end

// === filesystem: path ops ===================================================

export let exists = fn (
  a_path_ptr: i32,
  b_path_len: i32
) -> bool do return fs.exists(a_path_ptr, b_path_len) end
export let is_file = fn (
  a_path_ptr: i32,
  b_path_len: i32
) -> bool do return fs.is_file(a_path_ptr, b_path_len) end
export let read_to_string = fn (
  a_path_ptr: i32,
  b_path_len: i32
) -> i64 do return fs.read_to_string(a_path_ptr, b_path_len) end
export let write_string = fn (
  a_path_ptr: i32,
  b_path_len: i32,
  c_content_ptr: i32,
  d_content_len: i32
) -> bool do return fs.write_string(a_path_ptr, b_path_len, c_content_ptr, d_content_len) end
export let append_string = fn (
  a_path_ptr: i32,
  b_path_len: i32,
  c_content_ptr: i32,
  d_content_len: i32
) -> bool do return fs.append_string(a_path_ptr, b_path_len, c_content_ptr, d_content_len) end
export let remove_file = fn (
  a_path_ptr: i32,
  b_path_len: i32
) -> bool do return fs.remove_file(a_path_ptr, b_path_len) end
export let create_dir_all = fn (
  a_path_ptr: i32,
  b_path_len: i32
) -> bool do return fs.create_dir_all(a_path_ptr, b_path_len) end
export let read_dir = fn (
  a_path_ptr: i32,
  b_path_len: i32
) -> i64 do return fs.read_dir(a_path_ptr, b_path_len) end

export let exists_path = fn (path: string) -> bool do return fs.exists_path(path) end
export let is_file_path = fn (path: string) -> bool do return fs.is_file_path(path) end
export let read_to_string_path = fn (path: string) -> string do return fs.read_to_string_path(path) end
export let write_string_path = fn (
  path: string,
  content: string
) -> bool do return fs.write_string_path(path, content) end
export let append_string_path = fn (
  path: string,
  content: string
) -> bool do return fs.append_string_path(path, content) end
export let remove_file_path = fn (path: string) -> bool do return fs.remove_file_path(path) end
export let create_dir_all_path = fn (path: string) -> bool do return fs.create_dir_all_path(path) end
export let read_dir_path = fn (path: string) -> string do return fs.read_dir_path(path) end

// === filesystem: fd handles =================================================

export let fd_open_read = fn (
  a_path_ptr: i32,
  b_path_len: i32
) -> i64 do return fs.fd_open_read(a_path_ptr, b_path_len) end
export let fd_open_write = fn (
  a_path_ptr: i32,
  b_path_len: i32
) -> i64 do return fs.fd_open_write(a_path_ptr, b_path_len) end
export let fd_open_append = fn (
  a_path_ptr: i32,
  b_path_len: i32
) -> i64 do return fs.fd_open_append(a_path_ptr, b_path_len) end
export let fd_close = fn (a_fd: i64) -> bool do return fs.fd_close(a_fd) end
export let fd_read = fn (a_fd: i64) -> i64 do return fs.fd_read(a_fd) end
export let fd_write = fn (
  a_fd: i64,
  b_content_ptr: i32,
  c_content_len: i32
) -> bool do return fs.fd_write(a_fd, b_content_ptr, c_content_len) end
export let fd_path = fn (a_fd: i64) -> i64 do return fs.fd_path(a_fd) end

export let fd_open_read_path = fn (path: string) -> i64 do return fs.fd_open_read_path(path) end
export let fd_open_write_path = fn (path: string) -> i64 do return fs.fd_open_write_path(path) end
export let fd_open_append_path = fn (path: string) -> i64 do return fs.fd_open_append_path(path) end
export let fd_close_n = fn (fd: i64) -> bool do return fs.fd_close_n(fd) end
export let fd_read_n = fn (fd: i64) -> string do return fs.fd_read_n(fd) end
export let fd_write_n = fn (
  fd: i64,
  content: string
) -> bool do return fs.fd_write_n(fd, content) end
export let fd_path_n = fn (fd: i64) -> string do return fs.fd_path_n(fd) end

// === bytebuffer raw entry points ============================================

export let write_string_raw = fn (
  a_path_ptr: i32,
  b_path_len: i32,
  c_content_ptr: i32,
  d_content_len: i32
) -> bool do return fs.write_string_raw(a_path_ptr, b_path_len, c_content_ptr, d_content_len) end
export let read_to_string_raw = fn (
  a_path_ptr: i32,
  b_path_len: i32
) -> i64 do return fs.read_to_string_raw(a_path_ptr, b_path_len) end
export let read_fd_bytes_into = fn (
  a_fd: i64,
  b_dst: i64,
  c_cap: i64
) -> i64 do return fs.read_fd_bytes_into(a_fd, b_dst, c_cap) end
