/**
 * std:runtime/cast: integer width casts between Nexus `i64` and `i32`.
 *
 * Nexus arithmetic and literals are `i64`; raw FFI / WASI imports often need
 * exact `i32` arguments and return `i32`. These two intrinsics bridge the
 * gap — each lowers to a single wasm op (no host call, no import; filtered
 * out of the import section like `std:runtime/mem`):
 *   i32_of  →  i32.wrap_i64        (drops the high 32 bits)
 *   i64_of  →  i64.extend_i32_u    (zero-extends)
 *
 * `i64_of` zero-extends because the values it receives back from WASI
 * (errno codes, byte counts, file descriptors) are non-negative; if a
 * signed result is ever needed, mask/sign-extend explicitly at the call.
 */
import external "nexus:intrinsic"

/**
Truncate an `i64` to `i32` (low 32 bits). For passing addresses / lengths
/ fds to raw WASI imports declared with `i32` parameters.
*/
export external i32_of = "cast_to_i32" : (x: i64) -> i32

/**
Zero-extend an `i32` to `i64`. For consuming `i32` results from raw WASI
imports.
*/
export external i64_of = "cast_to_i64" : (x: i32) -> i64

/**
Widen a `char` to its `i64` codepoint. A `char` is a 32-bit code point, so
it lowers through the SAME `cast_to_i64` intrinsic as an `i32` (both are
`i32` in wasm) — this is the sound char→int path, distinct from `i64_of`
which strictly accepts `i32`. Canonical caller: `std:text/char.ord`.
*/
export external i64_of_char = "cast_to_i64" : (x: char) -> i64

/**
Reinterpret an `i32` code unit as a `char`. A `char` is a 32-bit code point
with the same wasm representation as `i32` (both lower to wasm `i32`), so the
value is unchanged. Lowered through the SAME `cast_to_i32` intrinsic as
`i32_of` — the low 32 bits the `i32.wrap_i64` keeps are exactly the code
unit — this is the sound int→char inverse of `i64_of_char`, distinct from
`i32_of` only in its declared `char` result. Canonical callers:
`std:text/str.byte_at` / `char_at`, whose raw `string_*` byte primitives
return the code unit as an `i32`.
*/
export external char_of_i32 = "cast_to_i32" : (x: i32) -> char
