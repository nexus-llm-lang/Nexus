/** fs: File system operations gated by the Fs port (capability).
  *
  * All operations — stateless path-level and stateful fd-based — are defined
  * in `port Fs` and dispatched via handler.
  * Use `inject fs_mod.system_handler do ... end` for real filesystem access,
  * or inject a mock handler for testing.
  *
  * Stateful fd operations use the consume-and-return pattern:
  *   fn read(handle: %Handle) -> { content: string, handle: %Handle }
  * The caller destructures the result to get the new handle.
  */

import external nxlib/stdlib/stdlib.wasm
import { length, substring, index_of } from stdlib/string.nx

/** Linear file handle backed by a real file descriptor.
 * Created by open_*, consumed by close.
 */
pub type Handle = Handle(id: i64)

// --- Raw FFI (internal, no require) ---

external __nx_exists = "__nx_exists" : (path: string) -> bool
external __nx_is_file = "__nx_is_file" : (path: string) -> bool
external __nx_read_to_string = "__nx_read_to_string" : (path: string) -> string
external __nx_write_string = "__nx_write_string" : (path: string, content: string) -> bool
external __nx_append_string = "__nx_append_string" : (path: string, content: string) -> bool
external __nx_remove_file = "__nx_remove_file" : (path: string) -> bool
external __nx_create_dir_all = "__nx_create_dir_all" : (path: string) -> bool
external __nx_read_dir = "__nx_read_dir" : (path: string) -> string

external __nx_fd_open_read = "__nx_fd_open_read" : (path: string) -> i64
external __nx_fd_open_write = "__nx_fd_open_write" : (path: string) -> i64
external __nx_fd_open_append = "__nx_fd_open_append" : (path: string) -> i64
external __nx_fd_close = "__nx_fd_close" : (fd: i64) -> bool
external __nx_fd_read = "__nx_fd_read" : (fd: i64) -> string
external __nx_fd_write = "__nx_fd_write" : (fd: i64, content: string) -> bool
external __nx_fd_path = "__nx_fd_path" : (fd: i64) -> string

// --- Helpers (pure, no require) ---

let reverse_go = fn <T>(xs: List<T>, acc: List<T>) -> List<T> do
  match xs do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) ->
      let next = Cons(v: v, rest: acc)
      return reverse_go(xs: rest, acc: next)
  end
end

let reverse = fn <T>(xs: List<T>) -> List<T> do
  let empty = Nil()
  return reverse_go(xs: xs, acc: empty)
end

let split_lines_rev = fn (s: string, acc: List<string>) -> List<string> do
  let idx = index_of(s: s, sub: "\n")
  if idx < 0 then
    let next = Cons(v: s, rest: acc)
    return next
  else
    let head = substring(s: s, start: 0, len: idx)
    let tail_start = idx + 1
    let tail_len = length(s: s) - tail_start
    let tail = substring(s: s, start: tail_start, len: tail_len)
    let next = Cons(v: head, rest: acc)
    return split_lines_rev(s: tail, acc: next)
  end
end

let decode_entries = fn (raw: string) -> List<string> do
  if length(s: raw) == 0 then
    return Nil()
  else
    let empty = Nil()
    let rev = split_lines_rev(s: raw, acc: empty)
    return reverse(xs: rev)
  end
end

let close_handles = fn (handles: List<Handle>) -> unit do
  match handles do
    case Nil() -> return ()
    case Cons(v: h, rest: rest) ->
      match h do case Handle(id: id) ->
        let _ = __nx_fd_close(fd: id)
        return close_handles(handles: rest)
      end
  end
end

let open_entries_rev = fn (names: List<string>, dir: string, acc: List<Handle>) -> List<Handle> do
  match names do
    case Nil() -> return acc
    case Cons(v: name, rest: rest) ->
      let full = dir ++ "/" ++ name
      let is_file = __nx_is_file(path: full)
      if is_file then
        let fd = __nx_fd_open_read(path: full)
        if fd < 0 then
          return open_entries_rev(names: rest, dir: dir, acc: acc)
        else
          let h = Handle(id: fd)
          let next = Cons(v: h, rest: acc)
          return open_entries_rev(names: rest, dir: dir, acc: next)
        end
      else
        return open_entries_rev(names: rest, dir: dir, acc: acc)
      end
  end
end

// --- Port definition: stateless + stateful operations ---

pub port Fs do
  fn exists(path: string) -> bool
  fn read_to_string(path: string) -> string effect { Exn }
  fn write_string(path: string, content: string) -> unit effect { Exn }
  fn append_string(path: string, content: string) -> unit effect { Exn }
  fn remove_file(path: string) -> unit effect { Exn }
  fn create_dir_all(path: string) -> unit effect { Exn }
  fn read_dir(path: string) -> List<Handle> effect { Exn }
  fn open_read(path: string) -> %Handle effect { Exn }
  fn open_write(path: string) -> %Handle effect { Exn }
  fn open_append(path: string) -> %Handle effect { Exn }
  fn read(handle: %Handle) -> { content: string, handle: %Handle }
  fn fd_write(handle: %Handle, content: string) -> { ok: bool, handle: %Handle }
  fn fd_path(handle: %Handle) -> { path: string, handle: %Handle }
  fn close(handle: %Handle) -> unit
end

/// Default Fs handler — real filesystem access via WASM FFI.
pub let system_handler = handler Fs require { PermFs } do
  fn exists(path: string) -> bool do
    return __nx_exists(path: path)
  end

  fn read_to_string(path: string) -> string effect { Exn } do
    let exists = __nx_exists(path: path)
    if exists then
      return __nx_read_to_string(path: path)
    else
      raise RuntimeError(val: "fs.read_to_string: file not found: " ++ path)
    end
  end

  fn write_string(path: string, content: string) -> unit effect { Exn } do
    let ok = __nx_write_string(path: path, content: content)
    if ok then
      return ()
    else
      raise RuntimeError(val: "fs.write_string: failed: " ++ path)
    end
  end

  fn append_string(path: string, content: string) -> unit effect { Exn } do
    let ok = __nx_append_string(path: path, content: content)
    if ok then
      return ()
    else
      raise RuntimeError(val: "fs.append_string: failed: " ++ path)
    end
  end

  fn remove_file(path: string) -> unit effect { Exn } do
    let ok = __nx_remove_file(path: path)
    if ok then
      return ()
    else
      raise RuntimeError(val: "fs.remove_file: failed: " ++ path)
    end
  end

  fn create_dir_all(path: string) -> unit effect { Exn } do
    let ok = __nx_create_dir_all(path: path)
    if ok then
      return ()
    else
      raise RuntimeError(val: "fs.create_dir_all: failed: " ++ path)
    end
  end

  fn read_dir(path: string) -> List<Handle> effect { Exn } do
    let exists = __nx_exists(path: path)
    if exists then
      let raw = __nx_read_dir(path: path)
      let names = decode_entries(raw: raw)
      let empty = Nil()
      let rev = open_entries_rev(names: names, dir: path, acc: empty)
      return reverse(xs: rev)
    else
      raise RuntimeError(val: "fs.read_dir: path not found: " ++ path)
    end
  end

  fn open_read(path: string) -> %Handle effect { Exn } do
    let fd = __nx_fd_open_read(path: path)
    if fd < 0 then
      raise RuntimeError(val: "fs.open_read: path not found: " ++ path)
    else
      let h = Handle(id: fd)
      let %lh = h
      return %lh
    end
  end

  fn open_write(path: string) -> %Handle effect { Exn } do
    let fd = __nx_fd_open_write(path: path)
    if fd < 0 then
      let msg = "fs.open_write: cannot open path: " ++ path
      raise RuntimeError(val: msg)
    else
      let h = Handle(id: fd)
      let %lh = h
      return %lh
    end
  end

  fn open_append(path: string) -> %Handle effect { Exn } do
    let fd = __nx_fd_open_append(path: path)
    if fd < 0 then
      let msg = "fs.open_append: cannot open path: " ++ path
      raise RuntimeError(val: msg)
    else
      let h = Handle(id: fd)
      let %lh = h
      return %lh
    end
  end

  fn read(handle: %Handle) -> { content: string, handle: %Handle } do
    match handle do case Handle(id: id) ->
      let c = __nx_fd_read(fd: id)
      let h = Handle(id: id)
      let %lh = h
      return { content: c, handle: %lh }
    end
  end

  fn fd_write(handle: %Handle, content: string) -> { ok: bool, handle: %Handle } do
    match handle do case Handle(id: id) ->
      let ok = __nx_fd_write(fd: id, content: content)
      let h = Handle(id: id)
      let %lh = h
      return { ok: ok, handle: %lh }
    end
  end

  fn fd_path(handle: %Handle) -> { path: string, handle: %Handle } do
    match handle do case Handle(id: id) ->
      let p = __nx_fd_path(fd: id)
      let h = Handle(id: id)
      let %lh = h
      return { path: p, handle: %lh }
    end
  end

  fn close(handle: %Handle) -> unit do
    match handle do case Handle(id: id) ->
      let _ = __nx_fd_close(fd: id)
      return ()
    end
  end
end
