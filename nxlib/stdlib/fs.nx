/** fs: File system operations. */

import { length as str_length, split as str_split } from "std:str"
import { reverse } from "std:list"
import * as sysio from "std:runtime/sysio"

/// Raised when a path does not exist.
export exception FileNotFound(path: string)

/// Raised when a write/append/create operation fails (write_string,
/// append_string, open_write, open_append, create_dir_all).
export exception WriteError(path: string)

/// Raised when a remove operation fails.
export exception RemoveError(path: string)

/// Group covering every exception raised by fs operations. The group exists
/// so callers route fs errors through a stable group name instead of the
/// universal Exn; prefer narrower rows (FileNotFound, WriteError, RemoveError)
/// when a function only raises one kind.
export exception group FsThrow = FileNotFound | WriteError | RemoveError

/// Linear file handle. Created by open_*, consumed by close.
export type Handle = Handle(id: i64)

let decode_entries = fn (raw: string) -> [ string ] do
  if str_length(s: raw) == 0 then
    return []
  else
    return str_split(s: raw, sep: "\n")
  end
end

let close_handles = fn (handles: [ Handle ]) -> unit do
  match handles do
    | [] -> return ()
    | Handle(id) :: rest ->
      sysio.fd_close_n(fd: id)
      return close_handles(handles: rest)
  end
end

let open_entries_rev = fn (names: [ string ], dir: string, acc: [ Handle ]) -> [ Handle ] do
  match names do
    | [] -> return acc
    | name :: rest ->
      let full = dir ++ "/" ++ name
      let fd = sysio.fd_open_read_path(path: full)
      if fd < 0 then
        return open_entries_rev(names: rest, dir, acc)
      else
        let h = Handle(id: fd)
        let next = h :: acc
        return open_entries_rev(names: rest, dir, acc: next)
      end
  end
end

/// Read a file's entire contents as a string. Raises on missing file.
let read_to_string = fn (path: string) -> string throws { FileNotFound } do
  let e = sysio.exists_path(path)
  if e then
    return sysio.read_to_string_path(path)
  else
    raise FileNotFound(path)
  end
end

/// Write a string to a file (creates or truncates). Raises on failure.
let write_string = fn (path: string, content: string) -> unit throws { WriteError } do
  let ok = sysio.write_string_path(path, content)
  if ok then return ()
  else raise WriteError(path)
  end
end

/// Append a string to a file (creates if missing). Raises on failure.
let append_string = fn (path: string, content: string) -> unit throws { WriteError } do
  let ok = sysio.append_string_path(path, content)
  if ok then return ()
  else raise WriteError(path)
  end
end

/// Remove a file. Raises on failure.
let remove_file = fn (path: string) -> unit throws { RemoveError } do
  let ok = sysio.remove_file_path(path)
  if ok then return ()
  else raise RemoveError(path)
  end
end

/// Create directories recursively. Raises on failure.
let create_dir_all = fn (path: string) -> unit throws { WriteError } do
  let ok = sysio.create_dir_all_path(path)
  if ok then return ()
  else raise WriteError(path)
  end
end

/// List directory entry names. Raises on missing path.
export let list_dir = fn (path: string) -> [ string ] throws { FileNotFound } do
  let e = sysio.exists_path(path)
  if e then
    let raw = sysio.read_dir_path(path)
    return decode_entries(raw)
  else
    raise FileNotFound(path)
  end
end

/// True iff `path` is a regular file. Companion to `Fs.exists`; required
/// because directory walks need to distinguish files from sub-directories
/// without having to consume the linear-handle `read_dir` API.
export let is_file = fn (path: string) -> bool do
  return sysio.is_file_path(path)
end

/// Open a file for reading. Returns a linear handle. Raises on failure.
let open_read = fn (path: string) -> %Handle throws { FileNotFound } do
  let fd = sysio.fd_open_read_path(path)
  if fd < 0 then
    raise FileNotFound(path)
  else
    let h = Handle(id: fd)
    let %lh = h
    return %lh
  end
end

/// Open a file for writing (truncate+create). Returns a linear handle. Raises on failure.
let open_write = fn (path: string) -> %Handle throws { WriteError } do
  let fd = sysio.fd_open_write_path(path)
  if fd < 0 then
    raise WriteError(path)
  else
    let h = Handle(id: fd)
    let %lh = h
    return %lh
  end
end

/// Open a file for appending (create if missing). Returns a linear handle. Raises on failure.
let open_append = fn (path: string) -> %Handle throws { WriteError } do
  let fd = sysio.fd_open_append_path(path)
  if fd < 0 then
    raise WriteError(path)
  else
    let h = Handle(id: fd)
    let %lh = h
    return %lh
  end
end

/// Read contents from a linear handle. Returns content and the handle.
let read = fn (handle: %Handle) -> { content: string, handle: %Handle } do
  let Handle(id) = handle
  let c = sysio.fd_read_n(fd: id)
  let h = Handle(id)
  let %lh = h
  return { content: c, handle: %lh }
end

/// Write content to a linear handle. Returns ok status and the handle.
let write = fn (handle: %Handle, content: string) -> { ok: bool, handle: %Handle } do
  let Handle(id) = handle
  let ok = sysio.fd_write_n(fd: id, content)
  let h = Handle(id)
  let %lh = h
  return { ok, handle: %lh }
end

/// Get the path of a linear handle. Returns path and the handle.
let handle_path = fn (handle: %Handle) -> { path: string, handle: %Handle } do
  let Handle(id) = handle
  let p = sysio.fd_path_n(fd: id)
  let h = Handle(id)
  let %lh = h
  return { path: p, handle: %lh }
end

/// Close a linear handle.
let close = fn (handle: %Handle) -> unit do
  let Handle(id) = handle
  sysio.fd_close_n(fd: id)
  return ()
end

export cap Fs do
  fn exists(path: string) -> bool
  fn is_file(path: string) -> bool
  fn list_dir(path: string) -> [ string ] throws { FileNotFound }
  fn read_to_string(path: string) -> string throws { FileNotFound }
  fn write_string(path: string, content: string) -> unit throws { WriteError }
  fn append_string(path: string, content: string) -> unit throws { WriteError }
  fn remove_file(path: string) -> unit throws { RemoveError }
  fn create_dir_all(path: string) -> unit throws { WriteError }
  fn read_dir(path: string) -> %[ Handle ] throws { FileNotFound }
  fn open_read(path: string) -> %Handle throws { FileNotFound }
  fn open_write(path: string) -> %Handle throws { WriteError }
  fn open_append(path: string) -> %Handle throws { WriteError }
  fn read(handle: %Handle) -> { content: string, handle: %Handle }
  fn write(handle: %Handle, content: string) -> { ok: bool, handle: %Handle }
  fn handle_path(handle: %Handle) -> { path: string, handle: %Handle }
  fn close(handle: %Handle) -> unit
end

/// Default Fs handler — delegates to direct-call API.
export let system_handler = handler Fs require { PermFs } do
  fn exists(path: string) -> bool do
    return sysio.exists_path(path)
  end
  fn is_file(path: string) -> bool do
    return sysio.is_file_path(path)
  end
  fn list_dir(path: string) -> [ string ] throws { FileNotFound } do
    return list_dir(path)
  end
  fn read_to_string(path: string) -> string throws { FileNotFound } do
    return read_to_string(path)
  end
  fn write_string(path: string, content: string) -> unit throws { WriteError } do
    return write_string(path, content)
  end
  fn append_string(path: string, content: string) -> unit throws { WriteError } do
    return append_string(path, content)
  end
  fn remove_file(path: string) -> unit throws { RemoveError } do
    return remove_file(path)
  end
  fn create_dir_all(path: string) -> unit throws { WriteError } do
    return create_dir_all(path)
  end
  fn read_dir(path: string) -> %[ Handle ] throws { FileNotFound } do
    let e = sysio.exists_path(path)
    if e then
      let names = decode_entries(raw: sysio.read_dir_path(path))
      let result = reverse(xs: open_entries_rev(names, dir: path, acc: []))
      let %linear_result = result
      return %linear_result
    else
      raise FileNotFound(path)
    end
  end
  fn open_read(path: string) -> %Handle throws { FileNotFound } do
    return open_read(path)
  end
  fn open_write(path: string) -> %Handle throws { WriteError } do
    return open_write(path)
  end
  fn open_append(path: string) -> %Handle throws { WriteError } do
    return open_append(path)
  end
  fn read(handle: %Handle) -> { content: string, handle: %Handle } do
    return read(handle)
  end
  fn write(handle: %Handle, content: string) -> { ok: bool, handle: %Handle } do
    return write(handle, content)
  end
  fn handle_path(handle: %Handle) -> { path: string, handle: %Handle } do
    return handle_path(handle)
  end
  fn close(handle: %Handle) -> unit do
    return close(handle)
  end
end
