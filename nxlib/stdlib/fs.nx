import external [=[nxlib/stdlib/fs.wasm]=]

pub type Closer = Closer(path: string, mode: i64)

pub let read_to_string = external [=[read_to_string]=] : (path: string) -> string effect { IO }
pub let write_string = external [=[write_string]=] : (path: string, content: string) -> bool effect { IO }
pub let append_string = external [=[append_string]=] : (path: string, content: string) -> bool effect { IO }
pub let exists = external [=[exists]=] : (path: string) -> bool effect { IO }
pub let remove_file = external [=[remove_file]=] : (path: string) -> bool effect { IO }
pub let create_dir_all = external [=[create_dir_all]=] : (path: string) -> bool effect { IO }
let __nx_read_dir = external [=[read_dir]=] : (path: string) -> string effect { IO }
let __nx_string_length = external [=[__nx_string_length]=] : (s: string) -> i64
let __nx_string_substring = external [=[__nx_string_substring]=] : (s: string, start: i64, len: i64) -> string
let __nx_string_index_of = external [=[__nx_string_index_of]=] : (s: string, sub: string) -> i64

pub let open_read = fn (path: string) -> %Closer effect { IO, Exn } do
  let ok = perform exists(path: path)
  if ok then
    let c = Closer(path: path, mode: 0)
    let %lc = c
    return %lc
  else
    let msg = [=[fs.open_read: path not found: ]=] ++ path
    raise RuntimeError(val: msg)
  endif
endfn

pub let open_write = fn (path: string) -> %Closer effect { IO, Exn } do
  let ok = perform write_string(path: path, content: [=[]=])
  if ok then
    let c = Closer(path: path, mode: 1)
    let %lc = c
    return %lc
  else
    let msg = [=[fs.open_write: cannot open path: ]=] ++ path
    raise RuntimeError(val: msg)
  endif
endfn

pub let open_append = fn (path: string) -> %Closer effect { IO, Exn } do
  let ok = perform append_string(path: path, content: [=[]=])
  if ok then
    let c = Closer(path: path, mode: 2)
    let %lc = c
    return %lc
  else
    let msg = [=[fs.open_append: cannot open path: ]=] ++ path
    raise RuntimeError(val: msg)
  endif
endfn

pub let close = fn (closer: %Closer) -> unit do
  drop closer
  return ()
endfn

let reverse_go = fn <T>(xs: List<T>, acc: List<T>) -> List<T> do
  match xs do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) ->
      let next = Cons(v: v, rest: acc)
      return reverse_go(xs: rest, acc: next)
  endmatch
endfn

let reverse = fn <T>(xs: List<T>) -> List<T> do
  let empty = Nil()
  return reverse_go(xs: xs, acc: empty)
endfn

let split_lines_rev = fn (s: string, acc: List<string>) -> List<string> do
  let idx = __nx_string_index_of(s: s, sub: [=[\n]=])
  if idx < 0 then
    let next = Cons(v: s, rest: acc)
    return next
  else
    let head = __nx_string_substring(s: s, start: 0, len: idx)
    let tail_start = idx + 1
    let tail_len = __nx_string_length(s: s) - tail_start
    let tail = __nx_string_substring(s: s, start: tail_start, len: tail_len)
    let next = Cons(v: head, rest: acc)
    return split_lines_rev(s: tail, acc: next)
  endif
endfn

let decode_entries = fn (raw: string) -> List<string> do
  if __nx_string_length(s: raw) == 0 then
    return Nil()
  else
    let empty = Nil()
    let rev = split_lines_rev(s: raw, acc: empty)
    return reverse(xs: rev)
  endif
endfn

pub let read_dir = fn (path: string) -> List<string> effect { IO } do
  let raw = perform __nx_read_dir(path: path)
  return decode_entries(raw: raw)
endfn
