/** fs: File system operations. */

import external stdlib/stdlib.wasm
import { length, split } from stdlib/string.nx
import { reverse } from stdlib/list.nx

/// Linear file handle. Created by open_*, consumed by close.
export type Handle = Handle(id: i64)

external __nx_exists = "__nx_exists" : (path: string) -> bool
external __nx_is_file = "__nx_is_file" : (path: string) -> bool
external __nx_read_to_string = "__nx_read_to_string" : (path: string) -> string
external __nx_write_string = "__nx_write_string" : (path: string, content: string) -> bool
external __nx_append_string = "__nx_append_string" : (path: string, content: string) -> bool
external __nx_remove_file = "__nx_remove_file" : (path: string) -> bool
external __nx_create_dir_all = "__nx_create_dir_all" : (path: string) -> bool
external __nx_read_dir = "__nx_read_dir" : (path: string) -> string

external __nx_fd_open_read = "__nx_fd_open_read" : (path: string) -> i64
external __nx_fd_open_write = "__nx_fd_open_write" : (path: string) -> i64
external __nx_fd_open_append = "__nx_fd_open_append" : (path: string) -> i64
external __nx_fd_close = "__nx_fd_close" : (fd: i64) -> bool
external __nx_fd_read = "__nx_fd_read" : (fd: i64) -> string
external __nx_fd_write = "__nx_fd_write" : (fd: i64, content: string) -> bool
external __nx_fd_path = "__nx_fd_path" : (fd: i64) -> string

let decode_entries = fn (raw: string) -> [ string ] do
  if length(s: raw) == 0 then
    return Nil
  else
    return split(s: raw, sep: "\n")
  end
end

let close_handles = fn (handles: [ Handle ]) -> unit do
  match handles do
    case Nil -> return ()
    case Handle(id: id) :: rest ->
      let _ = __nx_fd_close(fd: id)
      return close_handles(handles: rest)
  end
end

let open_entries_rev = fn (names: [ string ], dir: string, acc: [ Handle ]) -> [ Handle ] do
  match names do
    case Nil -> return acc
    case name :: rest ->
      let full = dir ++ "/" ++ name
      let fd = __nx_fd_open_read(path: full)
      if fd < 0 then
        return open_entries_rev(names: rest, dir: dir, acc: acc)
      else
        let h = Handle(id: fd)
        let next = Cons(v: h, rest: acc)
        return open_entries_rev(names: rest, dir: dir, acc: next)
      end
  end
end

/// Check if a path exists.
export let exists = fn (path: string) -> bool require { PermFs } do
  return __nx_exists(path: path)
end

/// Check if a path is a regular file.
export let is_file = fn (path: string) -> bool require { PermFs } do
  return __nx_is_file(path: path)
end

/// Read a file's entire contents as a string. Raises on missing file.
export let read_to_string = fn (path: string) -> string require { PermFs } throws { Exn } do
  let e = __nx_exists(path: path)
  if e then
    return __nx_read_to_string(path: path)
  else
    raise RuntimeError(val: "fs.read_to_string: not found: " ++ path)
  end
end

/// Write a string to a file (creates or truncates). Raises on failure.
export let write_string = fn (path: string, content: string) -> unit require { PermFs } throws { Exn } do
  let ok = __nx_write_string(path: path, content: content)
  if ok then return ()
  else raise RuntimeError(val: "fs.write_string: failed: " ++ path)
  end
end

/// Append a string to a file (creates if missing). Raises on failure.
export let append_string = fn (path: string, content: string) -> unit require { PermFs } throws { Exn } do
  let ok = __nx_append_string(path: path, content: content)
  if ok then return ()
  else raise RuntimeError(val: "fs.append_string: failed: " ++ path)
  end
end

/// Remove a file. Raises on failure.
export let remove_file = fn (path: string) -> unit require { PermFs } throws { Exn } do
  let ok = __nx_remove_file(path: path)
  if ok then return ()
  else raise RuntimeError(val: "fs.remove_file: failed: " ++ path)
  end
end

/// Create directories recursively. Raises on failure.
export let create_dir_all = fn (path: string) -> unit require { PermFs } throws { Exn } do
  let ok = __nx_create_dir_all(path: path)
  if ok then return ()
  else raise RuntimeError(val: "fs.create_dir_all: failed: " ++ path)
  end
end

/// Read directory entries as a raw newline-separated string.
export let read_dir_raw = fn (path: string) -> string require { PermFs } throws { Exn } do
  let e = __nx_exists(path: path)
  if e then
    return __nx_read_dir(path: path)
  else
    raise RuntimeError(val: "fs.read_dir_raw: not found: " ++ path)
  end
end

/// List directory entry names. Raises on missing path.
export let list_dir = fn (path: string) -> [ string ] require { PermFs } throws { Exn } do
  let e = __nx_exists(path: path)
  if e then
    let raw = __nx_read_dir(path: path)
    return decode_entries(raw: raw)
  else
    raise RuntimeError(val: "fs.list_dir: not found: " ++ path)
  end
end

/// Open a file for reading. Returns a linear handle. Raises on failure.
export let open_read = fn (path: string) -> %Handle require { PermFs } throws { Exn } do
  let fd = __nx_fd_open_read(path: path)
  if fd < 0 then
    raise RuntimeError(val: "fs.open_read: path not found: " ++ path)
  else
    let h = Handle(id: fd)
    let %lh = h
    return %lh
  end
end

/// Open a file for writing (truncate+create). Returns a linear handle. Raises on failure.
export let open_write = fn (path: string) -> %Handle require { PermFs } throws { Exn } do
  let fd = __nx_fd_open_write(path: path)
  if fd < 0 then
    raise RuntimeError(val: "fs.open_write: cannot open path: " ++ path)
  else
    let h = Handle(id: fd)
    let %lh = h
    return %lh
  end
end

/// Open a file for appending (create if missing). Returns a linear handle. Raises on failure.
export let open_append = fn (path: string) -> %Handle require { PermFs } throws { Exn } do
  let fd = __nx_fd_open_append(path: path)
  if fd < 0 then
    raise RuntimeError(val: "fs.open_append: cannot open path: " ++ path)
  else
    let h = Handle(id: fd)
    let %lh = h
    return %lh
  end
end

/// Read contents from a linear handle. Returns content and the handle.
export let read = fn (handle: %Handle) -> { content: string, handle: %Handle } require { PermFs } do
  let Handle(id: id) = handle
  let c = __nx_fd_read(fd: id)
  let h = Handle(id: id)
  let %lh = h
  return { content: c, handle: %lh }
end

/// Write content to a linear handle. Returns ok status and the handle.
export let write = fn (handle: %Handle, content: string) -> { ok: bool, handle: %Handle } require { PermFs } do
  let Handle(id: id) = handle
  let ok = __nx_fd_write(fd: id, content: content)
  let h = Handle(id: id)
  let %lh = h
  return { ok: ok, handle: %lh }
end

/// Get the path of a linear handle. Returns path and the handle.
export let handle_path = fn (handle: %Handle) -> { path: string, handle: %Handle } require { PermFs } do
  let Handle(id: id) = handle
  let p = __nx_fd_path(fd: id)
  let h = Handle(id: id)
  let %lh = h
  return { path: p, handle: %lh }
end

/// Close a linear handle.
export let close = fn (handle: %Handle) -> unit require { PermFs } do
  let Handle(id: id) = handle
  let _ = __nx_fd_close(fd: id)
  return ()
end

export port Fs do
  fn exists(path: string) -> bool
  fn read_to_string(path: string) -> string throws { Exn }
  fn write_string(path: string, content: string) -> unit throws { Exn }
  fn append_string(path: string, content: string) -> unit throws { Exn }
  fn remove_file(path: string) -> unit throws { Exn }
  fn create_dir_all(path: string) -> unit throws { Exn }
  fn read_dir(path: string) -> %[ Handle ] throws { Exn }
  fn open_read(path: string) -> %Handle throws { Exn }
  fn open_write(path: string) -> %Handle throws { Exn }
  fn open_append(path: string) -> %Handle throws { Exn }
  fn read(handle: %Handle) -> { content: string, handle: %Handle }
  fn write(handle: %Handle, content: string) -> { ok: bool, handle: %Handle }
  fn handle_path(handle: %Handle) -> { path: string, handle: %Handle }
  fn close(handle: %Handle) -> unit
end

/// Default Fs handler — delegates to direct-call API.
export let system_handler = handler Fs require { PermFs } do
  fn exists(path: string) -> bool do
    return __nx_exists(path: path)
  end
  fn read_to_string(path: string) -> string throws { Exn } do
    return read_to_string(path: path)
  end
  fn write_string(path: string, content: string) -> unit throws { Exn } do
    return write_string(path: path, content: content)
  end
  fn append_string(path: string, content: string) -> unit throws { Exn } do
    return append_string(path: path, content: content)
  end
  fn remove_file(path: string) -> unit throws { Exn } do
    return remove_file(path: path)
  end
  fn create_dir_all(path: string) -> unit throws { Exn } do
    return create_dir_all(path: path)
  end
  fn read_dir(path: string) -> %[ Handle ] throws { Exn } do
    let e = __nx_exists(path: path)
    if e then
      let names = decode_entries(raw: __nx_read_dir(path: path))
      let result = reverse(xs: open_entries_rev(names: names, dir: path, acc: Nil))
      let %linear_result = result
      return %linear_result
    else
      raise RuntimeError(val: "fs.read_dir: path not found: " ++ path)
    end
  end
  fn open_read(path: string) -> %Handle throws { Exn } do
    return open_read(path: path)
  end
  fn open_write(path: string) -> %Handle throws { Exn } do
    return open_write(path: path)
  end
  fn open_append(path: string) -> %Handle throws { Exn } do
    return open_append(path: path)
  end
  fn read(handle: %Handle) -> { content: string, handle: %Handle } do
    return read(handle: handle)
  end
  fn write(handle: %Handle, content: string) -> { ok: bool, handle: %Handle } do
    return write(handle: handle, content: content)
  end
  fn handle_path(handle: %Handle) -> { path: string, handle: %Handle } do
    return handle_path(handle: handle)
  end
  fn close(handle: %Handle) -> unit do
    return close(handle: handle)
  end
end
