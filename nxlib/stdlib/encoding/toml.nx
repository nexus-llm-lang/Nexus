/**
 * toml: TOML 1.0.0 parser and serializer.
 *
 * Pure Nexus implementation following the std:json module's shape.
 *
 * Algebra:
 *   TomlString(val: string)
 *   TomlInt(val: i64)
 *   TomlFloat(val: f64)
 *   TomlBool(val: bool)
 *   TomlDatetime(val: string)        // RFC 3339 kept as string
 *   TomlArray(items: [TomlValue])
 *   TomlTable(fields: [TomlField])   // root is always TomlTable
 *
 * parse(s) -> TomlValue  throws { TomlThrow }
 * serialize(v) -> string throws { TomlThrow }
 *
 * NaN/Infinity: parser accepts them as TomlFloat; serializer raises TomlError.
 * Mixed-type arrays: parser accepts; serializer raises TomlError.
 * Out of scope: streaming, TOML 0.x compatibility, Date type.
 */

import * as toml_parse from "std:encoding/toml/parse"
import * as toml_ser from "std:encoding/toml/serialize"
import { TomlError, TomlThrow, TomlField, TomlValue,
         TomlString, TomlInt, TomlFloat, TomlBool, TomlDatetime,
         TomlArray, TomlTable } from "std:encoding/toml/types"

// ─── Public exceptions ────────────────────────────────────────────────────────
// (defined in toml/types.nx; re-accessible here via import)

// ─── Public functions ─────────────────────────────────────────────────────────

/**
Parses a complete TOML document. Returns TomlTable with all top-level
key/value pairs and sections. Throws TomlError on malformed input.
*/
export let parse = fn (s: string) -> TomlValue throws { TomlThrow } do
  return toml_parse.parse(s)
end

/**
Serializes a TomlValue (which must be TomlTable at the root level) into a
TOML document string. Inline tables and arrays are supported as values.
Raises TomlError if NaN/Infinity appears in a float or if a mixed-type array
is encountered.
*/
export let serialize = fn (v: TomlValue) -> string throws { TomlThrow } do
  return toml_ser.serialize(v)
end
