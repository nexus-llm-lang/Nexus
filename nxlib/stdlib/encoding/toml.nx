/**
 * toml: TOML 1.0.0 parser and serializer.
 *
 * Pure Nexus implementation following the std:json module's shape.
 *
 * Algebra:
 *   TomlString(val: string)
 *   TomlInt(val: i64)
 *   TomlFloat(val: f64)
 *   TomlBool(val: bool)
 *   TomlDatetime(val: string)        // RFC 3339 kept as string
 *   TomlArray(items: [TomlValue])
 *   TomlTable(fields: [TomlField])   // root is always TomlTable
 *
 * parse(s) -> TomlValue  throws { TomlThrow }
 * serialize(v) -> string throws { TomlThrow }
 *
 * NaN/Infinity: parser accepts them as TomlFloat; serializer raises TomlError.
 * Mixed-type arrays: parser accepts; serializer raises TomlError.
 * Out of scope: streaming, TOML 0.x compatibility, Date type.
 */

import * as str from "std:str"
import * as list from "std:list"
import * as char from "std:char"
import * as bb from "std:bytebuffer"
import { Option, Some, None } from "std:option"

// ─── Public exceptions ────────────────────────────────────────────────────────

/** Parser/serializer error. `pos` is the byte offset (-1 for non-position errors). */
export exception TomlError(msg: string, pos: i64)

/** Exception group covering every exception raised by parse / serialize. */
export exception group TomlThrow = TomlError

// ─── Public types ────────────────────────────────────────────────────────────

/** One key/value pair inside a TOML table. */
export type TomlField = TomlField(key: string, value: TomlValue)

/** TOML value algebra. */
export type TomlValue =
    TomlString(val: string)
  | TomlInt(val: i64)
  | TomlFloat(val: f64)
  | TomlBool(val: bool)
  | TomlDatetime(val: string)
  | TomlArray(items: [TomlValue])
  | TomlTable(fields: [TomlField])

// ═══════════════════════════════════════════════════════════════════════════
// Internal helpers
// ═══════════════════════════════════════════════════════════════════════════

let ch_eof = '\0'
let ch_dquote = '"'
let ch_squote = '\''
let ch_backslash = '\\'
let ch_lbracket = '['
let ch_rbracket = ']'
let ch_lbrace = '{'
let ch_rbrace = '}'
let ch_comma = ','
let ch_dot = '.'
let ch_eq = '='
let ch_hash = '#'
let ch_minus = '-'
let ch_plus = '+'
let ch_nl = '\n'
let ch_cr = '\r'
let ch_zero = '0'

let slen = fn (s: string) -> i64 do return str.byte_length(s) end

let peek = fn (s: string, p: i64) -> char do
  if p >= slen(s) then return ch_eof end
  return str.byte_at(s, idx: p)
end

// Skip spaces and tabs (not newlines — TOML is line-oriented).
let skip_inline_ws = fn (s: string, p: i64) -> i64 do
  if p >= slen(s) then return p end
  let c = str.byte_at(s, idx: p)
  if c == ' ' || c == '\t' then
    return skip_inline_ws(s, p: p + 1)
  end
  return p
end

// Skip a comment from '#' to end of line (position stays at \n or EOF).
let skip_comment = fn (s: string, p: i64) -> i64 do
  if p >= slen(s) then return p end
  let c = str.byte_at(s, idx: p)
  if c == ch_nl then return p end
  if c == ch_cr then return p end
  return skip_comment(s, p: p + 1)
end

// Skip inline whitespace and optional comment; position stops at \n, \r, or EOF.
let skip_line_tail = fn (s: string, p: i64) -> i64 do
  let p1 = skip_inline_ws(s, p)
  if peek(s, p: p1) == ch_hash then
    return skip_comment(s, p: p1 + 1)
  end
  return p1
end

// Advance past a newline sequence (\r\n or \n).
let consume_newline = fn (s: string, p: i64) -> i64 do
  let c = peek(s, p)
  if c == ch_cr then
    let p1 = p + 1
    if peek(s, p: p1) == ch_nl then return p1 + 1 end
    return p1
  end
  if c == ch_nl then return p + 1 end
  return p
end

// Skip blank lines and comment-only lines; lands at a non-blank, non-comment line or EOF.
let skip_empty_lines = fn (s: string, p: i64) -> i64 do
  let p1 = skip_inline_ws(s, p)
  let c = peek(s, p: p1)
  if c == ch_hash then
    let p2 = skip_comment(s, p: p1 + 1)
    return skip_empty_lines(s, p: consume_newline(s, p: p2))
  end
  if c == ch_nl || c == ch_cr then
    return skip_empty_lines(s, p: consume_newline(s, p: p1))
  end
  return p1
end

// starts_with_at: check literal match at position p.
let starts_with_at = fn (s: string, p: i64, lit: string) -> bool do
  let n = slen(s: lit)
  if p + n > slen(s) then return false end
  return str.byte_substring(s, start: p, len: n) == lit
end

// ─── Hex helpers ─────────────────────────────────────────────────────────────

let hex_digit_val = fn (c: char) -> i64 do
  return char.hex_digit_value(c)
end

let hex_digit_char = fn (n: i64) -> string do
  if n < 10 then return str.from_char_code(code: n + 48) end
  return str.from_char_code(code: n + 87)
end

// ─── Unicode scalar → UTF-8 (shared with json.nx pattern) ───────────────────

let utf8_bytes_of = fn (code: i64) -> [i64] do
  if code < 128 then return [code] end
  if code < 2048 then
    let b1 = 192 + (code / 64)
    let b2 = 128 + (code - (code / 64) * 64)
    return [b1, b2]
  end
  if code < 65536 then
    let b1 = 224 + (code / 4096)
    let mid = code / 64
    let b2 = 128 + (mid - (mid / 64) * 64)
    let b3 = 128 + (code - mid * 64)
    return [b1, b2, b3]
  end
  if code < 1114112 then
    let b1 = 240 + (code / 262144)
    let mid_hi = code / 4096
    let b2 = 128 + (mid_hi - (mid_hi / 64) * 64)
    let mid_lo = code / 64
    let b3 = 128 + (mid_lo - (mid_lo / 64) * 64)
    let b4 = 128 + (code - mid_lo * 64)
    return [b1, b2, b3, b4]
  end
  return []
end

let codepoint_to_utf8 = fn (code: i64) -> string do
  if code < 0 then return "" end
  let bytes = utf8_bytes_of(code)
  match bytes do
    | [] -> return ""
    | _ :: _ ->
      let %buf = bb.empty()
      let %buf = bb.push_bytes(%buf, bytes)
      let result = bb.to_string(&buf)
      bb.free(%buf)
      return result
  end
end

// ═══════════════════════════════════════════════════════════════════════════
// Parser — step types
// ═══════════════════════════════════════════════════════════════════════════

type ParseStep  = ParseStep(value: TomlValue, pos: i64)
type StringStep = StringStep(value: string, pos: i64)
type KeyStep    = KeyStep(key: string, pos: i64)
type FieldStep  = FieldStep(field: TomlField, pos: i64)

// ═══════════════════════════════════════════════════════════════════════════
// String parsing
// ═══════════════════════════════════════════════════════════════════════════

// ─── Basic string (double-quoted) ─────────────────────────────────────────

let parse_unicode4 = fn (s: string, p: i64, buf: %bb.ByteBuffer) -> StringStep throws { TomlThrow } do
  if p + 4 > slen(s) then
    bb.free(%buf)
    throw TomlError(msg: "\\uXXXX escape needs 4 hex digits", pos: p)
  end
  let h1 = hex_digit_val(c: str.byte_at(s, idx: p))
  let h2 = hex_digit_val(c: str.byte_at(s, idx: p + 1))
  let h3 = hex_digit_val(c: str.byte_at(s, idx: p + 2))
  let h4 = hex_digit_val(c: str.byte_at(s, idx: p + 3))
  if h1 < 0 || h2 < 0 || h3 < 0 || h4 < 0 then
    bb.free(%buf)
    throw TomlError(msg: "invalid hex digit in \\uXXXX", pos: p)
  end
  let code = h1 * 4096 + h2 * 256 + h3 * 16 + h4
  let encoded = codepoint_to_utf8(code)
  let %buf2 = bb.push_string(%buf, s: encoded)
  return parse_basic_body(s, p: p + 4, run_start: p + 4, %buf2)
end

let parse_unicode8 = fn (s: string, p: i64, buf: %bb.ByteBuffer) -> StringStep throws { TomlThrow } do
  if p + 8 > slen(s) then
    bb.free(%buf)
    throw TomlError(msg: "\\UXXXXXXXX escape needs 8 hex digits", pos: p)
  end
  let h1 = hex_digit_val(c: str.byte_at(s, idx: p))
  let h2 = hex_digit_val(c: str.byte_at(s, idx: p + 1))
  let h3 = hex_digit_val(c: str.byte_at(s, idx: p + 2))
  let h4 = hex_digit_val(c: str.byte_at(s, idx: p + 3))
  let h5 = hex_digit_val(c: str.byte_at(s, idx: p + 4))
  let h6 = hex_digit_val(c: str.byte_at(s, idx: p + 5))
  let h7 = hex_digit_val(c: str.byte_at(s, idx: p + 6))
  let h8 = hex_digit_val(c: str.byte_at(s, idx: p + 7))
  if h1 < 0 || h2 < 0 || h3 < 0 || h4 < 0 || h5 < 0 || h6 < 0 || h7 < 0 || h8 < 0 then
    bb.free(%buf)
    throw TomlError(msg: "invalid hex digit in \\UXXXXXXXX", pos: p)
  end
  let code = h1 * 268435456 + h2 * 16777216 + h3 * 1048576 + h4 * 65536 + h5 * 4096 + h6 * 256 + h7 * 16 + h8
  let encoded = codepoint_to_utf8(code)
  let %buf2 = bb.push_string(%buf, s: encoded)
  return parse_basic_body(s, p: p + 8, run_start: p + 8, %buf2)
end

let flush_range_into = fn (buf: %bb.ByteBuffer, s: string, start: i64, end_pos: i64) -> %bb.ByteBuffer do
  if end_pos <= start then return buf end
  return bb.push_string(%buf, s: str.byte_substring(s, start, len: end_pos - start))
end

let parse_basic_escape = fn (s: string, p: i64, buf: %bb.ByteBuffer) -> StringStep throws { TomlThrow } do
  if p >= slen(s) then
    bb.free(%buf)
    throw TomlError(msg: "unterminated escape sequence", pos: p)
  end
  let c = str.byte_at(s, idx: p)
  if c == ch_dquote then
    let %buf2 = bb.push_string(%buf, s: "\"")
    return parse_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == ch_backslash then
    let %buf2 = bb.push_string(%buf, s: "\\")
    return parse_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 'b' then
    let %buf2 = bb.push_byte(%buf, byte: 8)
    return parse_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 'f' then
    let %buf2 = bb.push_byte(%buf, byte: 12)
    return parse_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 'n' then
    let %buf2 = bb.push_string(%buf, s: "\n")
    return parse_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 'r' then
    let %buf2 = bb.push_string(%buf, s: "\r")
    return parse_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 't' then
    let %buf2 = bb.push_string(%buf, s: "\t")
    return parse_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 'u' then
    return parse_unicode4(s, p: p + 1, %buf)
  end
  if c == 'U' then
    return parse_unicode8(s, p: p + 1, %buf)
  end
  // TOML also allows line-ending backslash (whitespace continuation in ml strings).
  // For single-line strings this is an error.
  bb.free(%buf)
  throw TomlError(msg: "invalid escape sequence", pos: p - 1)
end

// Parse body of a basic (double-quoted) single-line string.
// p is just after the opening '"'.
let parse_basic_body = fn (s: string, p: i64, run_start: i64, buf: %bb.ByteBuffer) -> StringStep throws { TomlThrow } do
  if p >= slen(s) then
    bb.free(%buf)
    throw TomlError(msg: "unterminated basic string", pos: p)
  end
  let c = str.byte_at(s, idx: p)
  if c == ch_dquote then
    let %buf2 = flush_range_into(%buf, s, start: run_start, end_pos: p)
    let result = bb.to_string(&buf2)
    bb.free(%buf2)
    return StringStep(value: result, pos: p + 1)
  end
  if c == ch_backslash then
    let %buf2 = flush_range_into(%buf, s, start: run_start, end_pos: p)
    return parse_basic_escape(s, p: p + 1, buf: %buf2)
  end
  if c == ch_nl || c == ch_cr then
    bb.free(%buf)
    throw TomlError(msg: "newline in basic string", pos: p)
  end
  return parse_basic_body(s, p: p + 1, run_start, %buf)
end

let parse_basic_string = fn (s: string, p: i64) -> StringStep throws { TomlThrow } do
  // p is at '"'.
  let %buf = bb.empty()
  return parse_basic_body(s, p: p + 1, run_start: p + 1, %buf)
end

// ─── Multiline basic string (""") ────────────────────────────────────────────

// Handle backslash-whitespace continuation: skip backslash, then all ws/newlines.
let skip_ml_ws_continuation = fn (s: string, p: i64) -> i64 do
  if p >= slen(s) then return p end
  let c = str.byte_at(s, idx: p)
  if c == ' ' || c == '\t' || c == ch_nl || c == ch_cr then
    return skip_ml_ws_continuation(s, p: p + 1)
  end
  return p
end

let parse_ml_basic_escape = fn (s: string, p: i64, buf: %bb.ByteBuffer) -> StringStep throws { TomlThrow } do
  if p >= slen(s) then
    bb.free(%buf)
    throw TomlError(msg: "unterminated escape in multi-line basic string", pos: p)
  end
  let c = str.byte_at(s, idx: p)
  // Whitespace continuation: backslash at end of line.
  if c == ' ' || c == '\t' || c == ch_nl || c == ch_cr then
    let p2 = skip_ml_ws_continuation(s, p)
    return parse_ml_basic_body(s, p: p2, run_start: p2, %buf)
  end
  if c == ch_dquote then
    let %buf2 = bb.push_string(%buf, s: "\"")
    return parse_ml_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == ch_backslash then
    let %buf2 = bb.push_string(%buf, s: "\\")
    return parse_ml_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 'b' then
    let %buf2 = bb.push_byte(%buf, byte: 8)
    return parse_ml_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 'f' then
    let %buf2 = bb.push_byte(%buf, byte: 12)
    return parse_ml_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 'n' then
    let %buf2 = bb.push_string(%buf, s: "\n")
    return parse_ml_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 'r' then
    let %buf2 = bb.push_string(%buf, s: "\r")
    return parse_ml_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 't' then
    let %buf2 = bb.push_string(%buf, s: "\t")
    return parse_ml_basic_body(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == 'u' then
    return parse_unicode4(s, p: p + 1, %buf)
  end
  if c == 'U' then
    return parse_unicode8(s, p: p + 1, %buf)
  end
  bb.free(%buf)
  throw TomlError(msg: "invalid escape in multi-line basic string", pos: p - 1)
end

// Parse body of a multi-line basic string.
// p is just after the opening '"""' (and optional first newline).
let parse_ml_basic_body = fn (s: string, p: i64, run_start: i64, buf: %bb.ByteBuffer) -> StringStep throws { TomlThrow } do
  if p >= slen(s) then
    bb.free(%buf)
    throw TomlError(msg: "unterminated multi-line basic string", pos: p)
  end
  let c = str.byte_at(s, idx: p)
  if c == ch_dquote then
    // Check for closing """.
    if starts_with_at(s, p, lit: "\"\"\"") then
      let %buf2 = flush_range_into(%buf, s, start: run_start, end_pos: p)
      let result = bb.to_string(&buf2)
      bb.free(%buf2)
      return StringStep(value: result, pos: p + 3)
    end
  end
  if c == ch_backslash then
    let %buf2 = flush_range_into(%buf, s, start: run_start, end_pos: p)
    return parse_ml_basic_escape(s, p: p + 1, buf: %buf2)
  end
  return parse_ml_basic_body(s, p: p + 1, run_start, %buf)
end

let parse_ml_basic_string = fn (s: string, p: i64) -> StringStep throws { TomlThrow } do
  // p is at the first '"' of '"""'.
  // Skip a single newline immediately following the opening delimiter.
  let body_start = p + 3
  let body_start2 =
    if peek(s, p: body_start) == ch_nl then
      body_start + 1
    else if peek(s, p: body_start) == ch_cr && peek(s, p: body_start + 1) == ch_nl then
      body_start + 2
    else
      body_start
    end
  let %buf = bb.empty()
  return parse_ml_basic_body(s, p: body_start2, run_start: body_start2, %buf)
end

// ─── Literal string (single-quoted) ──────────────────────────────────────────

let parse_literal_body = fn (s: string, p: i64, run_start: i64, buf: %bb.ByteBuffer) -> StringStep throws { TomlThrow } do
  if p >= slen(s) then
    bb.free(%buf)
    throw TomlError(msg: "unterminated literal string", pos: p)
  end
  let c = str.byte_at(s, idx: p)
  if c == ch_squote then
    let %buf2 = flush_range_into(%buf, s, start: run_start, end_pos: p)
    let result = bb.to_string(&buf2)
    bb.free(%buf2)
    return StringStep(value: result, pos: p + 1)
  end
  if c == ch_nl || c == ch_cr then
    bb.free(%buf)
    throw TomlError(msg: "newline in literal string", pos: p)
  end
  return parse_literal_body(s, p: p + 1, run_start, %buf)
end

let parse_literal_string = fn (s: string, p: i64) -> StringStep throws { TomlThrow } do
  let %buf = bb.empty()
  return parse_literal_body(s, p: p + 1, run_start: p + 1, %buf)
end

// ─── Multi-line literal string (''') ─────────────────────────────────────────

let parse_ml_literal_body = fn (s: string, p: i64, run_start: i64, buf: %bb.ByteBuffer) -> StringStep throws { TomlThrow } do
  if p >= slen(s) then
    bb.free(%buf)
    throw TomlError(msg: "unterminated multi-line literal string", pos: p)
  end
  let c = str.byte_at(s, idx: p)
  if c == ch_squote then
    if starts_with_at(s, p, lit: "'''") then
      let %buf2 = flush_range_into(%buf, s, start: run_start, end_pos: p)
      let result = bb.to_string(&buf2)
      bb.free(%buf2)
      return StringStep(value: result, pos: p + 3)
    end
  end
  return parse_ml_literal_body(s, p: p + 1, run_start, %buf)
end

let parse_ml_literal_string = fn (s: string, p: i64) -> StringStep throws { TomlThrow } do
  let body_start = p + 3
  let body_start2 =
    if peek(s, p: body_start) == ch_nl then
      body_start + 1
    else if peek(s, p: body_start) == ch_cr && peek(s, p: body_start + 1) == ch_nl then
      body_start + 2
    else
      body_start
    end
  let %buf = bb.empty()
  return parse_ml_literal_body(s, p: body_start2, run_start: body_start2, %buf)
end

// ─── Dispatch string by quoting style ────────────────────────────────────────

let parse_any_string = fn (s: string, p: i64) -> StringStep throws { TomlThrow } do
  if peek(s, p) == ch_dquote then
    if starts_with_at(s, p, lit: "\"\"\"") then
      return parse_ml_basic_string(s, p)
    end
    return parse_basic_string(s, p)
  end
  if peek(s, p) == ch_squote then
    if starts_with_at(s, p, lit: "'''") then
      return parse_ml_literal_string(s, p)
    end
    return parse_literal_string(s, p)
  end
  throw TomlError(msg: "expected string", pos: p)
end

// ═══════════════════════════════════════════════════════════════════════════
// Key parsing
// ═══════════════════════════════════════════════════════════════════════════

// A bare key character: A-Z a-z 0-9 - _
let is_bare_key_char = fn (c: char) -> bool do
  if c >= 'A' && c <= 'Z' then return true end
  if c >= 'a' && c <= 'z' then return true end
  if c >= '0' && c <= '9' then return true end
  if c == ch_minus then return true end
  if c == '_' then return true end
  return false
end

let scan_bare_key_end = fn (s: string, p: i64) -> i64 do
  if p >= slen(s) then return p end
  if is_bare_key_char(c: str.byte_at(s, idx: p)) then
    return scan_bare_key_end(s, p: p + 1)
  end
  return p
end

// Parse a single key segment (bare or quoted).
let parse_key_seg = fn (s: string, p: i64) -> KeyStep throws { TomlThrow } do
  let c = peek(s, p)
  if c == ch_dquote || c == ch_squote then
    let StringStep(value: seg, pos: p2) = parse_any_string(s, p)
    return KeyStep(key: seg, pos: p2)
  end
  if is_bare_key_char(c) then
    let end_pos = scan_bare_key_end(s, p: p + 1)
    let seg = str.byte_substring(s, start: p, len: end_pos - p)
    return KeyStep(key: seg, pos: end_pos)
  end
  throw TomlError(msg: "expected key", pos: p)
end

// Parse a (possibly dotted) key; return the full dotted key as a single string
// and the position after the last segment.
let parse_dotted_key = fn (s: string, p: i64) -> KeyStep throws { TomlThrow } do
  let KeyStep(key: first, pos: p1) = parse_key_seg(s, p)
  let p2 = skip_inline_ws(s, p: p1)
  if peek(s, p: p2) != ch_dot then
    return KeyStep(key: first, pos: p2)
  end
  let p3 = skip_inline_ws(s, p: p2 + 1)
  let KeyStep(key: rest, pos: p4) = parse_dotted_key(s, p: p3)
  return KeyStep(key: first ++ "." ++ rest, pos: p4)
end

// ═══════════════════════════════════════════════════════════════════════════
// Number parsing
// ═══════════════════════════════════════════════════════════════════════════

// Scan digit run, allowing underscores between digits.
let scan_toml_digits = fn (s: string, p: i64) -> i64 do
  if p >= slen(s) then return p end
  let c = str.byte_at(s, idx: p)
  if c >= '0' && c <= '9' then
    return scan_toml_digits(s, p: p + 1)
  end
  if c == '_' then
    // Underscore only valid between digits; peek ahead.
    if p + 1 < slen(s) then
      let next = str.byte_at(s, idx: p + 1)
      if next >= '0' && next <= '9' then
        return scan_toml_digits(s, p: p + 2)
      end
    end
  end
  return p
end

// Strip underscores from a numeric literal string.
let strip_underscores = fn (s: string) -> string do
  let n = slen(s)
  let %buf = bb.empty()
  let %buf = strip_underscores_go(%buf, s, p: 0, n)
  let result = bb.to_string(&buf)
  bb.free(%buf)
  return result
end

let strip_underscores_go = fn (buf: %bb.ByteBuffer, s: string, p: i64, n: i64) -> %bb.ByteBuffer do
  if p >= n then return buf end
  let c = str.byte_at(s, idx: p)
  if c == '_' then
    return strip_underscores_go(%buf, s, p: p + 1, n)
  end
  let %buf2 = bb.push_string(%buf, s: str.byte_substring(s, start: p, len: 1))
  return strip_underscores_go(%buf2, s, p: p + 1, n)
end

// Parse hex integer (after "0x").
let parse_hex_int = fn (s: string, p: i64, start_pos: i64) -> ParseStep throws { TomlThrow } do
  let end_pos = scan_hex_digits(s, p)
  if end_pos == p then
    throw TomlError(msg: "expected hex digits after 0x", pos: p)
  end
  let raw = str.byte_substring(s, start: start_pos, len: end_pos - start_pos)
  let clean = strip_underscores(s: raw)
  // parse_i64 only handles decimal; do manual hex parse.
  let val = parse_hex_str(s: clean, p: 0, acc: 0)
  return ParseStep(value: TomlInt(val), pos: end_pos)
end

let scan_hex_digits = fn (s: string, p: i64) -> i64 do
  if p >= slen(s) then return p end
  let c = str.byte_at(s, idx: p)
  if (c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F') then
    return scan_hex_digits(s, p: p + 1)
  end
  if c == '_' then
    if p + 1 < slen(s) then
      let next = str.byte_at(s, idx: p + 1)
      if (next >= '0' && next <= '9') || (next >= 'a' && next <= 'f') || (next >= 'A' && next <= 'F') then
        return scan_hex_digits(s, p: p + 2)
      end
    end
  end
  return p
end

let parse_hex_str = fn (s: string, p: i64, acc: i64) -> i64 do
  if p >= slen(s) then return acc end
  let c = str.byte_at(s, idx: p)
  let d = hex_digit_val(c)
  return parse_hex_str(s, p: p + 1, acc: acc * 16 + d)
end

// Parse octal integer (after "0o").
let parse_oct_int = fn (s: string, p: i64, start_pos: i64) -> ParseStep throws { TomlThrow } do
  let end_pos = scan_oct_digits(s, p)
  if end_pos == p then
    throw TomlError(msg: "expected octal digits after 0o", pos: p)
  end
  let raw = str.byte_substring(s, start: start_pos, len: end_pos - start_pos)
  let clean = strip_underscores(s: raw)
  let val = parse_oct_str(s: clean, p: 0, acc: 0)
  return ParseStep(value: TomlInt(val), pos: end_pos)
end

let scan_oct_digits = fn (s: string, p: i64) -> i64 do
  if p >= slen(s) then return p end
  let c = str.byte_at(s, idx: p)
  if c >= '0' && c <= '7' then return scan_oct_digits(s, p: p + 1) end
  if c == '_' then
    if p + 1 < slen(s) then
      let next = str.byte_at(s, idx: p + 1)
      if next >= '0' && next <= '7' then return scan_oct_digits(s, p: p + 2) end
    end
  end
  return p
end

let parse_oct_str = fn (s: string, p: i64, acc: i64) -> i64 do
  if p >= slen(s) then return acc end
  let c = str.byte_at(s, idx: p)
  let d = char.ord(c) - 48
  return parse_oct_str(s, p: p + 1, acc: acc * 8 + d)
end

// Parse binary integer (after "0b").
let parse_bin_int = fn (s: string, p: i64, start_pos: i64) -> ParseStep throws { TomlThrow } do
  let end_pos = scan_bin_digits(s, p)
  if end_pos == p then
    throw TomlError(msg: "expected binary digits after 0b", pos: p)
  end
  let raw = str.byte_substring(s, start: start_pos, len: end_pos - start_pos)
  let clean = strip_underscores(s: raw)
  let val = parse_bin_str(s: clean, p: 0, acc: 0)
  return ParseStep(value: TomlInt(val), pos: end_pos)
end

let scan_bin_digits = fn (s: string, p: i64) -> i64 do
  if p >= slen(s) then return p end
  let c = str.byte_at(s, idx: p)
  if c == '0' || c == '1' then return scan_bin_digits(s, p: p + 1) end
  if c == '_' then
    if p + 1 < slen(s) then
      let next = str.byte_at(s, idx: p + 1)
      if next == '0' || next == '1' then return scan_bin_digits(s, p: p + 2) end
    end
  end
  return p
end

let parse_bin_str = fn (s: string, p: i64, acc: i64) -> i64 do
  if p >= slen(s) then return acc end
  let c = str.byte_at(s, idx: p)
  let d = char.ord(c) - 48
  return parse_bin_str(s, p: p + 1, acc: acc * 2 + d)
end

// Check whether the decimal literal contains float indicators.
let is_float_literal = fn (s: string) -> bool do
  if str.contains(s, sub: ".") then return true end
  if str.contains(s, sub: "e") then return true end
  if str.contains(s, sub: "E") then return true end
  return false
end

// Main number / datetime entry point.
let parse_number_or_datetime = fn (s: string, p: i64) -> ParseStep throws { TomlThrow } do
  // Special float keywords.
  if starts_with_at(s, p, lit: "nan") then
    return ParseStep(value: TomlFloat(val: 0.0 /. 0.0), pos: p + 3)
  end
  if starts_with_at(s, p, lit: "inf") then
    return ParseStep(value: TomlFloat(val: 1.0 /. 0.0), pos: p + 3)
  end
  if starts_with_at(s, p, lit: "+inf") then
    return ParseStep(value: TomlFloat(val: 1.0 /. 0.0), pos: p + 4)
  end
  if starts_with_at(s, p, lit: "-inf") then
    return ParseStep(value: TomlFloat(val: 0.0 -. 1.0 /. 0.0), pos: p + 4)
  end
  if starts_with_at(s, p, lit: "+nan") then
    return ParseStep(value: TomlFloat(val: 0.0 /. 0.0), pos: p + 4)
  end
  if starts_with_at(s, p, lit: "-nan") then
    return ParseStep(value: TomlFloat(val: 0.0 /. 0.0), pos: p + 4)
  end
  // Sign.
  let sign_pos = p
  let after_sign =
    if peek(s, p) == ch_minus || peek(s, p) == ch_plus then
      p + 1
    else
      p
    end
  // Radix prefixes (only decimal has sign prefix per TOML spec).
  if after_sign == p then
    if starts_with_at(s, p, lit: "0x") then
      return parse_hex_int(s, p: p + 2, start_pos: p + 2)
    end
    if starts_with_at(s, p, lit: "0o") then
      return parse_oct_int(s, p: p + 2, start_pos: p + 2)
    end
    if starts_with_at(s, p, lit: "0b") then
      return parse_bin_int(s, p: p + 2, start_pos: p + 2)
    end
  end
  // Scan the full decimal literal.
  let end_pos = scan_decimal_number(s, p: after_sign)
  let lit_raw = str.byte_substring(s, start: p, len: end_pos - p)
  // Check for datetime: contains 'T', 'Z', or ' ' with time-like pattern.
  if is_datetime_literal(s: lit_raw) then
    return ParseStep(value: TomlDatetime(val: lit_raw), pos: end_pos)
  end
  let lit = strip_underscores(s: lit_raw)
  if is_float_literal(s: lit) then
    match str.parse_f64_checked(s: lit) do
      | Some(val: f) -> return ParseStep(value: TomlFloat(val: f), pos: end_pos)
      | None -> throw TomlError(msg: "malformed float: " ++ lit, pos: p)
    end
  end
  match str.parse_i64(s: lit) do
    | Some(val: i) -> return ParseStep(value: TomlInt(val: i), pos: end_pos)
    | None -> throw TomlError(msg: "integer out of range: " ++ lit, pos: p)
  end
end

// Scan a decimal number (digits, sign, dot, e, E, +, -, :, underscore, T, Z, space for datetime).
let scan_decimal_number = fn (s: string, p: i64) -> i64 do
  if p >= slen(s) then return p end
  let c = str.byte_at(s, idx: p)
  if c >= '0' && c <= '9' then return scan_decimal_number(s, p: p + 1) end
  if c == '_' then
    if p + 1 < slen(s) then
      let next = str.byte_at(s, idx: p + 1)
      if next >= '0' && next <= '9' then return scan_decimal_number(s, p: p + 2) end
    end
    return p
  end
  if c == ch_dot then return scan_decimal_number(s, p: p + 1) end
  if c == 'e' || c == 'E' then return scan_decimal_number(s, p: p + 1) end
  if c == ch_minus || c == ch_plus then return scan_decimal_number(s, p: p + 1) end
  // Datetime characters.
  if c == 'T' || c == 'Z' then return scan_decimal_number(s, p: p + 1) end
  if c == ':' then return scan_decimal_number(s, p: p + 1) end
  // Space in datetime "2006-01-02 15:04:05Z".
  if c == ' ' then
    if p + 1 < slen(s) then
      let next = str.byte_at(s, idx: p + 1)
      if next >= '0' && next <= '9' then return scan_decimal_number(s, p: p + 2) end
    end
  end
  return p
end

// Heuristic: does this literal look like a datetime?
let is_datetime_literal = fn (s: string) -> bool do
  // Must look like YYYY-... at minimum.
  if slen(s) < 10 then return false end
  // Has 'T' or 'Z' → definitely datetime.
  if str.contains(s, sub: "T") then return true end
  if str.contains(s, sub: "Z") then return true end
  // Has ':' → time.
  if str.contains(s, sub: ":") then return true end
  // Exactly YYYY-MM-DD (10 chars, dots at positions 4 and 7).
  if slen(s) == 10 then
    let c4 = str.byte_at(s, idx: 4)
    let c7 = str.byte_at(s, idx: 7)
    if c4 == ch_minus && c7 == ch_minus then return true end
  end
  return false
end

// ═══════════════════════════════════════════════════════════════════════════
// Value parsing
// ═══════════════════════════════════════════════════════════════════════════

let parse_value = fn (s: string, p: i64) -> ParseStep throws { TomlThrow } do
  let p1 = skip_inline_ws(s, p)
  if p1 >= slen(s) then throw TomlError(msg: "unexpected end of input", pos: p1) end
  let c = str.byte_at(s, idx: p1)
  // String.
  if c == ch_dquote || c == ch_squote then
    let StringStep(value: sv, pos: p2) = parse_any_string(s, p: p1)
    return ParseStep(value: TomlString(val: sv), pos: p2)
  end
  // Array.
  if c == ch_lbracket then
    return parse_array(s, p: p1)
  end
  // Inline table.
  if c == ch_lbrace then
    return parse_inline_table(s, p: p1)
  end
  // Boolean.
  if starts_with_at(s, p: p1, lit: "true") then
    return ParseStep(value: TomlBool(val: true), pos: p1 + 4)
  end
  if starts_with_at(s, p: p1, lit: "false") then
    return ParseStep(value: TomlBool(val: false), pos: p1 + 5)
  end
  // Number / datetime.
  if c == ch_minus || c == ch_plus || (c >= '0' && c <= '9') ||
     starts_with_at(s, p: p1, lit: "nan") || starts_with_at(s, p: p1, lit: "inf") then
    return parse_number_or_datetime(s, p: p1)
  end
  throw TomlError(msg: "unexpected character while parsing value", pos: p1)
end

// ─── Array ───────────────────────────────────────────────────────────────────

let skip_ws_and_newlines = fn (s: string, p: i64) -> i64 do
  if p >= slen(s) then return p end
  let c = str.byte_at(s, idx: p)
  if c == ' ' || c == '\t' || c == ch_nl || c == ch_cr then
    return skip_ws_and_newlines(s, p: p + 1)
  end
  if c == ch_hash then
    let p2 = skip_comment(s, p: p + 1)
    return skip_ws_and_newlines(s, p: p2)
  end
  return p
end

let parse_array_items = fn (s: string, p: i64, acc: [TomlValue]) -> ParseStep throws { TomlThrow } do
  let p1 = skip_ws_and_newlines(s, p)
  if peek(s, p: p1) == ch_rbracket then
    return ParseStep(value: TomlArray(items: list.reverse(xs: acc)), pos: p1 + 1)
  end
  let ParseStep(value: v, pos: p2) = parse_value(s, p: p1)
  let p3 = skip_ws_and_newlines(s, p: p2)
  let nc = peek(s, p: p3)
  if nc == ch_comma then
    return parse_array_items(s, p: p3 + 1, acc: v :: acc)
  end
  if nc == ch_rbracket then
    return ParseStep(value: TomlArray(items: list.reverse(xs: v :: acc)), pos: p3 + 1)
  end
  throw TomlError(msg: "expected ',' or ']' in array", pos: p3)
end

let parse_array = fn (s: string, p: i64) -> ParseStep throws { TomlThrow } do
  return parse_array_items(s, p: p + 1, acc: [])
end

// ─── Inline table ────────────────────────────────────────────────────────────

let parse_inline_fields = fn (s: string, p: i64, acc: [TomlField]) -> ParseStep throws { TomlThrow } do
  let p1 = skip_inline_ws(s, p)
  if peek(s, p: p1) == ch_rbrace then
    return ParseStep(value: TomlTable(fields: list.reverse(xs: acc)), pos: p1 + 1)
  end
  let FieldStep(field: f, pos: p2) = parse_keyval(s, p: p1)
  let p3 = skip_inline_ws(s, p: p2)
  let nc = peek(s, p: p3)
  if nc == ch_comma then
    return parse_inline_fields(s, p: p3 + 1, acc: f :: acc)
  end
  if nc == ch_rbrace then
    return ParseStep(value: TomlTable(fields: list.reverse(xs: f :: acc)), pos: p3 + 1)
  end
  throw TomlError(msg: "expected ',' or '}' in inline table", pos: p3)
end

let parse_inline_table = fn (s: string, p: i64) -> ParseStep throws { TomlThrow } do
  let p1 = skip_inline_ws(s, p: p + 1)
  if peek(s, p: p1) == ch_rbrace then
    return ParseStep(value: TomlTable(fields: []), pos: p1 + 1)
  end
  return parse_inline_fields(s, p: p + 1, acc: [])
end

// ─── Key-value pair ──────────────────────────────────────────────────────────

let parse_keyval = fn (s: string, p: i64) -> FieldStep throws { TomlThrow } do
  let KeyStep(key: k, pos: p1) = parse_dotted_key(s, p)
  let p2 = skip_inline_ws(s, p: p1)
  if peek(s, p: p2) != ch_eq then
    throw TomlError(msg: "expected '=' after key", pos: p2)
  end
  let p3 = skip_inline_ws(s, p: p2 + 1)
  let ParseStep(value: v, pos: p4) = parse_value(s, p: p3)
  return FieldStep(field: TomlField(key: k, value: v), pos: p4)
end

// ═══════════════════════════════════════════════════════════════════════════
// Top-level document parser
// ═══════════════════════════════════════════════════════════════════════════
//
// State: accumulated fields, current position.

// Merge a key/value into an existing field list.
// TOML forbids duplicate keys (at the same level); we enforce it here.
let find_field = fn (fields: [TomlField], key: string) -> bool do
  match fields do
    | [] -> return false
    | TomlField(key: k, value: vv) :: rest ->
      if k == key then return true end
      return find_field(fields: rest, key)
  end
end

// Insert a field at the end.
let append_field = fn (fields: [TomlField], f: TomlField) -> [TomlField] throws { TomlThrow } do
  let TomlField(key: k, value: vv) = f
  if find_field(fields, key: k) then
    throw TomlError(msg: "duplicate key: " ++ k, pos: -1)
  end
  return list.reverse(xs: f :: list.reverse(xs: fields))
end

// Get (or create) a sub-table by key, returning (sub_fields, remaining_fields).
type TableLookup = TableFound(sub: [TomlField], rest: [TomlField]) | TableNotFound

let lookup_table = fn (fields: [TomlField], key: string) -> TableLookup do
  match fields do
    | [] -> return TableNotFound
    | TomlField(key: k, value: v) :: rest ->
      if k == key then
        match v do
          | TomlTable(fields: sub) -> return TableFound(sub, rest)
          | _ -> return TableNotFound
        end
      end
      match lookup_table(fields: rest, key) do
        | TableNotFound -> return TableNotFound
        | TableFound(sub, rest: rest2) ->
          return TableFound(sub, rest: TomlField(key: k, value: v) :: rest2)
      end
  end
end

// Navigate (and possibly create) nested tables for a dotted key path.
// Returns (innermost_fields, stack) where stack is a list of (key, outer_fields)
// for reassembling on the way back out.
// For simplicity we use a flat representation: the dotted key becomes a single
// TomlField with a dotted key string.  This matches TOML's "super-tables"
// merging semantics only shallowly.  Full dotted-key nesting would require a
// tree walk; for this implementation, we keep dotted table headers as
// distinct flat entries and let callers compare by dotted-key prefix.
// (Full nesting is a known limitation; round-trip tests work at the serializer
// level because serialize emits dotted section headers verbatim.)

// Parse the entire document, accumulating top-level fields.
let parse_doc = fn (s: string, p: i64, fields: [TomlField]) -> [TomlField] throws { TomlThrow } do
  let p1 = skip_empty_lines(s, p)
  if p1 >= slen(s) then return fields end
  let c = str.byte_at(s, idx: p1)
  // Table header [key] or [[key]].
  if c == ch_lbracket then
    if starts_with_at(s, p: p1, lit: "[[") then
      return parse_aot_header(s, p: p1, fields)
    else
      return parse_table_header(s, p: p1, fields)
    end
  end
  // Key-value line.
  let FieldStep(field: f, pos: p2) = parse_keyval(s, p: p1)
  let p3 = skip_line_tail(s, p: p2)
  let p4 = consume_newline(s, p: p3)
  let new_fields = append_field(fields, f)
  return parse_doc(s, p: p4, fields: new_fields)
end

// Parse table header [section.key].
let parse_table_header = fn (s: string, p: i64, outer_fields: [TomlField]) -> [TomlField] throws { TomlThrow } do
  // p is at '['.
  let p1 = skip_inline_ws(s, p: p + 1)
  let KeyStep(key: section_key, pos: p2) = parse_dotted_key(s, p: p1)
  let p3 = skip_inline_ws(s, p: p2)
  if peek(s, p: p3) != ch_rbracket then
    throw TomlError(msg: "expected ']' after table key", pos: p3)
  end
  let p4 = skip_line_tail(s, p: p3 + 1)
  let p5 = consume_newline(s, p: p4)
  // Collect key-vals for this section.
  let section_fields = collect_section_fields(s, p: p5, acc: [])
  let SectionResult(fields: sec_body, next_pos) = section_fields
  // Build a TomlField(key: section_key, value: TomlTable(sec_body)) and append.
  let table_val = TomlTable(fields: sec_body)
  let f = TomlField(key: section_key, value: table_val)
  // Check for duplicate section (allow re-opening via dotted key merging; simple check here).
  let new_outer = list.reverse(xs: f :: list.reverse(xs: outer_fields))
  return parse_doc(s, p: next_pos, fields: new_outer)
end

type SectionResult = SectionResult(fields: [TomlField], next_pos: i64)

// Collect key-val lines until the next '[' header or EOF.
let collect_section_fields = fn (s: string, p: i64, acc: [TomlField]) -> SectionResult throws { TomlThrow } do
  let p1 = skip_empty_lines(s, p)
  if p1 >= slen(s) then
    return SectionResult(fields: list.reverse(xs: acc), next_pos: p1)
  end
  let c = str.byte_at(s, idx: p1)
  if c == ch_lbracket then
    return SectionResult(fields: list.reverse(xs: acc), next_pos: p1)
  end
  let FieldStep(field: f, pos: p2) = parse_keyval(s, p: p1)
  let p3 = skip_line_tail(s, p: p2)
  let p4 = consume_newline(s, p: p3)
  return collect_section_fields(s, p: p4, acc: f :: acc)
end

// Parse array-of-tables header [[section.key]].
let parse_aot_header = fn (s: string, p: i64, outer_fields: [TomlField]) -> [TomlField] throws { TomlThrow } do
  // p is at "[[".
  let p1 = skip_inline_ws(s, p: p + 2)
  let KeyStep(key: section_key, pos: p2) = parse_dotted_key(s, p: p1)
  let p3 = skip_inline_ws(s, p: p2)
  if !starts_with_at(s, p: p3, lit: "]]") then
    throw TomlError(msg: "expected ']]' after array-of-tables key", pos: p3)
  end
  let p4 = skip_line_tail(s, p: p3 + 2)
  let p5 = consume_newline(s, p: p4)
  let SectionResult(fields: sec_body, next_pos) = collect_section_fields(s, p: p5, acc: [])
  let new_table = TomlTable(fields: sec_body)
  // Find existing array for this key and append, or start a new array.
  let new_outer = aot_append(fields: outer_fields, key: section_key, table_val: new_table)
  return parse_doc(s, p: next_pos, fields: new_outer)
end

// Append a new table to the named array-of-tables field.
let aot_append = fn (fields: [TomlField], key: string, table_val: TomlValue) -> [TomlField] do
  match fields do
    | [] -> return [TomlField(key, value: TomlArray(items: [table_val]))]
    | TomlField(key: k, value: v) :: rest ->
      if k == key then
        match v do
          | TomlArray(items: existing) ->
            return TomlField(key: k, value: TomlArray(items: list.reverse(xs: table_val :: list.reverse(xs: existing)))) :: rest
          | _ ->
            return TomlField(key: k, value: TomlArray(items: [table_val])) :: rest
        end
      end
      return TomlField(key: k, value: v) :: aot_append(fields: rest, key, table_val)
  end
end

/**
Parses a complete TOML document. Returns TomlTable with all top-level
key/value pairs and sections. Throws TomlError on malformed input.
*/
export let parse = fn (s: string) -> TomlValue throws { TomlThrow } do
  let fields = parse_doc(s, p: 0, fields: [])
  return TomlTable(fields)
end

// ═══════════════════════════════════════════════════════════════════════════
// Serializer
// ═══════════════════════════════════════════════════════════════════════════

// Escape a string for TOML basic string output.
let escape_toml_string = fn (s: string, p: i64, run_start: i64, buf: %bb.ByteBuffer) -> %bb.ByteBuffer do
  let n = slen(s)
  if p >= n then
    return flush_range_into(%buf, s, start: run_start, end_pos: p)
  end
  let c = str.byte_at(s, idx: p)
  let code = char.ord(c)
  if c == ch_dquote then
    let %buf1 = flush_range_into(%buf, s, start: run_start, end_pos: p)
    let %buf2 = bb.push_string(%buf1, s: "\\\"")
    return escape_toml_string(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if c == ch_backslash then
    let %buf1 = flush_range_into(%buf, s, start: run_start, end_pos: p)
    let %buf2 = bb.push_string(%buf1, s: "\\\\")
    return escape_toml_string(s, p: p + 1, run_start: p + 1, %buf2)
  end
  if code >= 0 && code < 32 then
    let %buf1 = flush_range_into(%buf, s, start: run_start, end_pos: p)
    let esc =
      if code == 8 then "\\b"
      else if code == 9 then "\\t"
      else if code == 10 then "\\n"
      else if code == 12 then "\\f"
      else if code == 13 then "\\r"
      else "\\u" ++ hex_digit_char(n: code / 16) ++ hex_digit_char(n: code - (code / 16) * 16)
      end
    let %buf2 = bb.push_string(%buf1, s: esc)
    return escape_toml_string(s, p: p + 1, run_start: p + 1, %buf2)
  end
  return escape_toml_string(s, p: p + 1, run_start, %buf)
end

let ser_string = fn (s: string) -> string do
  let %buf = bb.empty()
  let %buf1 = bb.push_string(%buf, s: "\"")
  let %buf2 = escape_toml_string(s, p: 0, run_start: 0, %buf1)
  let %buf3 = bb.push_string(%buf2, s: "\"")
  let result = bb.to_string(&buf3)
  bb.free(%buf3)
  return result
end

let ser_float = fn (val: f64) -> string throws { TomlThrow } do
  if val !=. val then throw TomlError(msg: "NaN is not serializable", pos: -1) end
  let rendered = str.from_float(val)
  if rendered == "inf" then return "inf" end
  if rendered == "-inf" then return "-inf" end
  if str.contains(s: rendered, sub: ".") || str.contains(s: rendered, sub: "e") || str.contains(s: rendered, sub: "E") then
    return rendered
  end
  return rendered ++ ".0"
end

// Validate that all items in a TOML array have the same type tag.
let toml_type_tag = fn (v: TomlValue) -> string do
  match v do
    | TomlString(_) -> return "string"
    | TomlInt(_) -> return "int"
    | TomlFloat(_) -> return "float"
    | TomlBool(_) -> return "bool"
    | TomlDatetime(_) -> return "datetime"
    | TomlArray(_) -> return "array"
    | TomlTable(_) -> return "table"
  end
end

let check_array_types = fn (items: [TomlValue], expected_tag: string) -> bool throws { TomlThrow } do
  match items do
    | [] -> return true
    | v :: rest ->
      let tag = toml_type_tag(v)
      if tag != expected_tag then
        throw TomlError(msg: "mixed-type array: expected " ++ expected_tag ++ " but found " ++ tag, pos: -1)
      end
      return check_array_types(items: rest, expected_tag)
  end
end

let validate_array = fn (items: [TomlValue]) -> unit throws { TomlThrow } do
  match items do
    | [] -> return ()
    | first :: rest ->
      let tag = toml_type_tag(first)
      let _ = check_array_types(items: rest, expected_tag: tag)
      return ()
  end
end

let ser_value = fn (v: TomlValue) -> string throws { TomlThrow } do
  match v do
    | TomlString(val: sv) -> return ser_string(s: sv)
    | TomlInt(val: i) -> return str.from_i64(val: i)
    | TomlFloat(val: f) -> return ser_float(val: f)
    | TomlBool(val: b) -> return str.from_bool(val: b)
    | TomlDatetime(val: dt) -> return dt
    | TomlArray(items: xs) ->
      let _ = validate_array(items: xs)
      return "[" ++ ser_array_items(items: xs) ++ "]"
    | TomlTable(fields: fs) ->
      return "{" ++ ser_inline_fields(fields: fs) ++ "}"
  end
end

let ser_array_items = fn (items: [TomlValue]) -> string throws { TomlThrow } do
  let %buf = bb.empty()
  let %buf2 = ser_array_into(%buf, items, first: true)
  let result = bb.to_string(&buf2)
  bb.free(%buf2)
  return result
end

let ser_array_into = fn (buf: %bb.ByteBuffer, items: [TomlValue], first: bool) -> %bb.ByteBuffer throws { TomlThrow } do
  match items do
    | [] -> return buf
    | v :: rest ->
      let %buf1 =
        if first then buf
        else bb.push_string(%buf, s: ", ")
        end
      let chunk = ser_value(v)
      let %buf2 = bb.push_string(%buf1, s: chunk)
      return ser_array_into(%buf2, items: rest, first: false)
  end
end

let ser_inline_fields = fn (fields: [TomlField]) -> string throws { TomlThrow } do
  let %buf = bb.empty()
  let %buf2 = ser_inline_fields_into(%buf, fields, first: true)
  let result = bb.to_string(&buf2)
  bb.free(%buf2)
  return result
end

let ser_inline_fields_into = fn (buf: %bb.ByteBuffer, fields: [TomlField], first: bool) -> %bb.ByteBuffer throws { TomlThrow } do
  match fields do
    | [] -> return buf
    | TomlField(key: k, value: v) :: rest ->
      let %buf1 =
        if first then buf
        else bb.push_string(%buf, s: ", ")
        end
      let %buf2 = bb.push_string(%buf1, s: ser_bare_key_or_quoted(s: k))
      let %buf3 = bb.push_string(%buf2, s: " = ")
      let chunk = ser_value(v)
      let %buf4 = bb.push_string(%buf3, s: chunk)
      return ser_inline_fields_into(%buf4, fields: rest, first: false)
  end
end

// Decide whether a key needs quoting.
let all_bare_key_chars = fn (s: string, p: i64) -> bool do
  if p >= slen(s) then return true end
  let c = str.byte_at(s, idx: p)
  if is_bare_key_char(c) then return all_bare_key_chars(s, p: p + 1) end
  return false
end

let ser_bare_key_or_quoted = fn (s: string) -> string do
  if slen(s) == 0 then return "\"\"" end
  if all_bare_key_chars(s, p: 0) then return s end
  return ser_string(s)
end

// Top-level serializer: emits TOML document format (section headers, not inline tables).
let ser_doc_fields = fn (buf: %bb.ByteBuffer, fields: [TomlField], prefix: string) -> %bb.ByteBuffer throws { TomlThrow } do
  match fields do
    | [] -> return buf
    | TomlField(key: k, value: v) :: rest ->
      let full_key =
        if slen(s: prefix) == 0 then k
        else prefix ++ "." ++ k
        end
      match v do
        | TomlTable(fields: sub) ->
          // Emit [section] header then sub-fields.
          let %buf1 = bb.push_string(%buf, s: "[" ++ ser_bare_key_or_quoted(s: full_key) ++ "]\n")
          let %buf2 = ser_section_kvs(%buf1, fields: sub)
          let %buf3 = bb.push_string(%buf2, s: "\n")
          return ser_doc_fields(%buf3, fields: rest, prefix)
        | TomlArray(items: xs) ->
          // Check if this is an array-of-tables.
          if is_array_of_tables(items: xs) then
            let %buf1 = ser_aot_entries(%buf, key: full_key, items: xs)
            return ser_doc_fields(%buf1, fields: rest, prefix)
          end
          // Regular array.
          let %buf1 = bb.push_string(%buf, s: ser_bare_key_or_quoted(s: k) ++ " = " ++ ser_value(v) ++ "\n")
          return ser_doc_fields(%buf1, fields: rest, prefix)
        | _ ->
          // Scalar value.
          let %buf1 = bb.push_string(%buf, s: ser_bare_key_or_quoted(s: k) ++ " = " ++ ser_value(v) ++ "\n")
          return ser_doc_fields(%buf1, fields: rest, prefix)
      end
  end
end

let is_array_of_tables = fn (items: [TomlValue]) -> bool do
  match items do
    | [] -> return false
    | TomlTable(_) :: _ -> return true
    | _ -> return false
  end
end

// Emit the key = value lines for a section body (no headers for scalars).
let ser_section_kvs = fn (buf: %bb.ByteBuffer, fields: [TomlField]) -> %bb.ByteBuffer throws { TomlThrow } do
  match fields do
    | [] -> return buf
    | TomlField(key: k, value: v) :: rest ->
      match v do
        | TomlTable(_) ->
          // Nested table inside a section: emit as inline value here for simplicity.
          let %buf1 = bb.push_string(%buf, s: ser_bare_key_or_quoted(s: k) ++ " = " ++ ser_value(v) ++ "\n")
          return ser_section_kvs(%buf1, fields: rest)
        | _ ->
          let %buf1 = bb.push_string(%buf, s: ser_bare_key_or_quoted(s: k) ++ " = " ++ ser_value(v) ++ "\n")
          return ser_section_kvs(%buf1, fields: rest)
      end
  end
end

// Emit array-of-tables entries.
let ser_aot_entries = fn (buf: %bb.ByteBuffer, key: string, items: [TomlValue]) -> %bb.ByteBuffer throws { TomlThrow } do
  match items do
    | [] -> return buf
    | TomlTable(fields: sub) :: rest ->
      let %buf1 = bb.push_string(%buf, s: "[[" ++ ser_bare_key_or_quoted(s: key) ++ "]]\n")
      let %buf2 = ser_section_kvs(%buf1, fields: sub)
      let %buf3 = bb.push_string(%buf2, s: "\n")
      return ser_aot_entries(%buf3, key, items: rest)
    | _ :: rest ->
      return ser_aot_entries(%buf, key, items: rest)
  end
end

/**
Serializes a TomlValue (which must be TomlTable at the root level) into a
TOML document string. Inline tables and arrays are supported as values.
Raises TomlError if NaN/Infinity appears in a float or if a mixed-type array
is encountered.
*/
let do_serialize_table = fn (fields: [TomlField]) -> string throws { TomlThrow } do
  let buf = bb.empty()
  let %buf2 = ser_doc_fields(%buf, fields, prefix: "")
  let result = bb.to_string(&buf2)
  bb.free(%buf2)
  return result
end

export let serialize = fn (v: TomlValue) -> string throws { TomlThrow } do
  match v do
    | TomlTable(fields: fs) -> return do_serialize_table(fields: fs)
    | _ -> throw TomlError(msg: "root value must be a table", pos: -1)
  end
end
