/**
 * json/types: public ADT + exception definitions for the JSON module.
 */

// ─── Public exceptions ────────────────────────────────────────────────────────

/**
Parser/serializer error. `pos` is the byte offset (or -1 for serializer
errors that aren't tied to an input position).
*/
export exception JsonError(msg: string, pos: i64)

/**
Group covering every exception raised by parse / serialize helpers.
Single-member: JsonError. The group exists so cross-module callers
route errors through a stable group name instead of the universal Exn.
*/
export exception group JsonThrow = JsonError

// ─── Public types ─────────────────────────────────────────────────────────────

/**
One key/value pair inside a JSON object. Stored as a plain list to
preserve insertion order — duplicate keys are kept verbatim, callers that
need uniqueness should normalize after parsing.
*/
export type JsonField = JsonField(key: string, value: JsonValue)

/** JSON value algebra. Recursive via [JsonValue] / [JsonField]. */
export type JsonValue =
    JsonNull
  | JsonBool(val: bool)
  | JsonInt(val: i64)
  | JsonFloat(val: f64)
  | JsonString(val: string)
  | JsonArray(items: [ JsonValue ])
  | JsonObject(fields: [ JsonField ])
