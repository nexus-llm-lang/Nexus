/**
 * hcl: HCL2 native-syntax structural decoder.
 *
 * Supported subset (structural decode):
 *   - Blocks:      block_type "label" { ... }  (zero or more string labels)
 *   - Attributes:  name = value
 *   - Values:      quoted strings, heredocs (<<EOF and <<-EOF), numbers,
 *                  true/false/null, list literals [...], object expressions
 *                  { key = value, ... }
 *   - Comments:    hash (#), double-slash (//), and block (slash-star ... star-slash)
 *   - ${...} interpolations are captured verbatim as HTemplate (not evaluated)
 *
 * Out of scope: expression evaluation, function calls, arithmetic,
 * conditionals, for-expressions.  These produce a parse error unless they
 * appear inside a ${...} interpolation inside a quoted string.
 *
 * Usage:
 *   import * as hcl from "std:encoding/hcl"
 *   let body = hcl.parse(s: my_source)  // throws { HclThrow }
 *
 * API:
 *   parse(s) -> HclBody   throws { HclThrow }
 */

import * as hcl_parse from "std:encoding/hcl/parse"
import * as _types from "std:encoding/hcl/types"

/**
Parse a complete HCL native-syntax document.
Returns an HclBody containing the top-level items in source order.
Throws HclError on any syntax error.
*/
export let parse = fn (s: string) -> HclBody throws { HclThrow } do
  return hcl_parse.parse(s)
end
