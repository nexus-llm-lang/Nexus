/**
 * hcl/types: public ADT + exception definitions for the HCL module.
 *
 * Supported subset: HCL2 native syntax — blocks, attributes, primitive
 * values, lists, objects/maps, comments.  Expression interpolation
 * (${...}), function calls, arithmetic, conditionals, and for-expressions
 * are NOT evaluated; interpolated strings are captured as raw HTemplate
 * values containing the source text.
 */

// ─── Public exceptions ────────────────────────────────────────────────────────

/** Parser error. `pos` is the byte offset into the source string (-1 for
non-position errors). */
export exception HclError(msg: string, pos: i64)

/** Exception group covering every exception raised by parse. */
export exception group HclThrow = HclError

// ─── Public types ─────────────────────────────────────────────────────────────

/**
One attribute inside an HCL body: `key = value`.
*/
export type HclAttr = HclAttr(name: string, value: HclValue)

/**
One item inside an HCL body: either an attribute assignment or a block.
*/
export type HclItem =
    Attribute(attr: HclAttr)
  | Block(block_type: string, labels: [ string ], body: HclBody)

/**
A sequence of HclItems — the parsed content of `{ ... }` or the top level.
Fields are in source order.
*/
export type HclBody = HclBody(items: [ HclItem ])

/**
HCL value algebra.

  HString  — quoted string literal (escape-decoded)
  HNumber  — numeric literal stored as f64 (covers both integers and floats)
  HBool    — true / false
  HNull    — null
  HList    — `[ v, v, ... ]`
  HObject  — `{ key = value, ... }` (object expression)
  HTemplate — raw source text of an expression that starts with `${` or that
              could not be decoded as a primitive; callers that need expression
              evaluation should layer their own evaluator on top.
*/
export type HclValue =
    HString(val: string)
  | HNumber(val: f64)
  | HBool(val: bool)
  | HNull
  | HList(items: [ HclValue ])
  | HObject(fields: [ HclAttr ])
  | HTemplate(raw: string)
