/**
 * jsonrpc: JSON-RPC 2.0 framing for two stdio transports.
 *
 * Two wire formats live here because LSP and MCP made different framing
 * choices and both clients are first-class:
 *
 *   LSP-style — Content-Length-headed frames (per JSON-RPC 2.0 base
 *   protocol §6):
 *     Content-Length: <n>\r\n
 *     [Content-Type: application/vscode-jsonrpc; charset=utf-8\r\n]
 *     \r\n
 *     <n bytes of UTF-8 JSON body>
 *   API: frame_message / unframe_one (pure), read_message /
 *   read_message_pipelined / write_message (I/O).
 *
 *   MCP-style — newline-delimited JSON (NDJSON) per the MCP stdio
 *   transport spec: one compact JSON object per message, terminated by
 *   a single `\n`. Messages MUST NOT contain embedded newlines.
 *   API: unframe_ndjson_one (pure), read_ndjson_message_pipelined /
 *   write_ndjson_message (I/O).
 *
 * Both transports share classify / response_ok / response_error /
 * IncomingMessage downstream.
 *
 * Dispatch model: synchronous, single-threaded. Per LSP spec the server
 * reads one message, computes a response (for requests) or runs the side
 * effect (for notifications), writes the response, and loops. No
 * concurrency; cancellation is observed only at message boundaries (the
 * `$/cancelRequest` notification protocol is layered on top by the user).
 *
 * Error semantics:
 *   - A malformed Content-Length header raises `JsonRpcFrameError`. The
 *     dispatch loop catches it, logs to stderr, and continues with the
 *     next read attempt — a single garbled frame must not bring down the
 *     server.
 *   - A body that fails to parse as JSON propagates as `JsonError` from
 *     `nxlib/stdlib/json`. The dispatch loop catches it and routes a
 *     ParseError JSON-RPC response back to the client when the failed
 *     message had an id, otherwise logs and continues.
 *   - The handler closure may throw; the loop wraps any exception into an
 *     InternalError response (request) or logs it (notification).
 */

import { JsonValue, JsonField, JsonNull, JsonInt, JsonString,
         JsonObject, JsonError,
         parse, serialize, get_field } from "std:json"
import { Option, Some, None } from "std:option"
import { Pair } from "std:tuple"
import { Console } from "std:stdio"
import { ByteBuffer }, * as bb from "std:bytebuffer"
import * as str from "std:str"
import * as char from "std:char"
import { Coop } from "std:concurrency/coop"
import { sched_runq_nonempty } from "std:runtime/sched"
import { stdin_wait_readable, stdin_read_available } from "std:io/poll"

// ─── Exceptions ──────────────────────────────────────────────────────────────

/**
Wire-level framing failure: missing or non-numeric Content-Length, header
without trailing CRLF CRLF, body shorter than the declared length, etc.
*/
export exception JsonRpcFrameError(msg: string)

/**
Internal: signaled when the input stream reaches EOF before a complete
header block has been read. The dispatch loop treats this as a graceful
shutdown rather than an error.
*/
export exception JsonRpcEof

/**
Group covering every exception raised by jsonrpc operations: the
module's own JsonRpcFrameError / JsonRpcEof plus the JsonError chain
that frame_message / unframe_one propagate via parse / serialize.
*/
export exception group JsonRpcError =
  JsonRpcFrameError | JsonRpcEof | JsonError

// ─── JSON-RPC error codes (per spec §5.1) ────────────────────────────────────

export let invalid_request = -32600
export let method_not_found = -32601
export let invalid_params = -32602
export let internal_error = -32603
// ═══════════════════════════════════════════════════════════════════════════
// Pure framing layer
// ═══════════════════════════════════════════════════════════════════════════

/**
Encode `value` into a complete LSP-framed JSON-RPC message. The output is
a Nexus string; UTF-8 bytes flow through `serialize` unchanged. The body
length advertised in the header is the byte length of the JSON
serialisation, so multi-byte characters in payload strings count
correctly.
*/
export let frame_message = fn (value: JsonValue) -> string throws { JsonRpcError } do
  let body = serialize(v: value)
  let n = str.byte_length(s: body)
  let header = "Content-Length: " ++ str.from_i64(val: n) ++ "\r\n\r\n"
  return header ++ body
end

/**
Outcome of pulling one message off the front of an input buffer.
  `UnframedOk(value, rest)` — message parsed, `rest` is the unconsumed
    suffix (next read can re-enter `unframe_one` against it).
  `UnframedNeedMore` — input ends mid-frame; caller reads more bytes
    and retries with the concatenated buffer.
*/
export type UnframedStep =
    UnframedOk(value: JsonValue, rest: string)
  | UnframedNeedMore

let ch_cr = '\r'
let ch_lf = '\n'
let ch_space = ' '
let ch_tab = '\t'

let byte_length_of = fn (s: string) -> i64 do
  return str.byte_length(s)
end

// Walk the input looking for the CRLF CRLF that terminates the header block.
// Returns the offset just past the empty line, or -1 if not found.
let find_header_end = fn (s: string, p: i64) -> i64 do
  let n = byte_length_of(s)
  if p + 3 >= n then return -1 end
  let b0 = str.byte_at(s, idx: p)
  let b1 = str.byte_at(s, idx: p + 1)
  let b2 = str.byte_at(s, idx: p + 2)
  let b3 = str.byte_at(s, idx: p + 3)
  if b0 == ch_cr && b1 == ch_lf && b2 == ch_cr && b3 == ch_lf then
    return p + 4
  end
  return find_header_end(s, p: p + 1)
end

// Locate the next CRLF starting at `p`. Returns the offset of the CR, or -1.
let find_crlf = fn (s: string, p: i64) -> i64 do
  let n = byte_length_of(s)
  if p + 1 >= n then return -1 end
  let b0 = str.byte_at(s, idx: p)
  let b1 = str.byte_at(s, idx: p + 1)
  if b0 == ch_cr && b1 == ch_lf then return p end
  return find_crlf(s, p: p + 1)
end

let trim_leading_ws = fn (s: string, p: i64, end_pos: i64) -> i64 do
  if p >= end_pos then return p end
  let c = str.byte_at(s, idx: p)
  if c == ch_space || c == ch_tab then
    return trim_leading_ws(s, p: p + 1, end_pos)
  end
  return p
end

let trim_trailing_ws = fn (s: string, start: i64, p: i64) -> i64 do
  if p <= start then return p end
  let c = str.byte_at(s, idx: p - 1)
  if c == ch_space || c == ch_tab then
    return trim_trailing_ws(s, start, p: p - 1)
  end
  return p
end

let lower_code = fn (code: i64) -> i64 do
  if code >= 65 && code <= 90 then return code + 32 end
  return code
end

// Header field-name compare is case-insensitive per RFC 7230. We only need
// to recognise "Content-Length", so a byte-by-byte ASCII lower-case compare
// against a constant lowered-once string is enough. Compare via char codes
// (i64) so we don't depend on `char` arithmetic.
let bytes_equal_ci_at = fn (s: string, p: i64, lit_lower: string, idx: i64, lit_len: i64) -> bool do
  if idx >= lit_len then return true end
  let bs = lower_code(code: char.ord(c: str.byte_at(s, idx: p + idx)))
  let bl = char.ord(c: str.byte_at(s: lit_lower, idx))
  if bs != bl then return false end
  return bytes_equal_ci_at(s, p, lit_lower, idx: idx + 1, lit_len)
end

let header_starts_with_ci = fn (s: string, p: i64, lit_lower: string) -> bool do
  let lit_len = str.byte_length(s: lit_lower)
  let n = byte_length_of(s)
  if p + lit_len > n then return false end
  return bytes_equal_ci_at(s, p, lit_lower, idx: 0, lit_len)
end

// Walk the header block (between `p` and `header_end`) and pull out the
// integer value of the `Content-Length` line. Raises JsonRpcFrameError on
// malformed input. The lookup is line-by-line so we don't depend on header
// ordering. `header_end` points just past the empty CRLF that closes the
// block; `header_end - 2` is the offset of the empty line's CR byte.
let scan_content_length = fn (s: string, p: i64, header_end: i64) -> i64 throws { JsonRpcError } do
  let empty_line = header_end - 2
  if p >= empty_line then
    // Walked through every header without finding Content-Length.
    throw JsonRpcFrameError(msg: "missing Content-Length header")
  end
  let line_end = find_crlf(s, p)
  if line_end < 0 || line_end > empty_line then
    throw JsonRpcFrameError(msg: "malformed header line")
  end
  if header_starts_with_ci(s, p, lit_lower: "content-length:") then
    let after_colon = p + str.byte_length(s: "content-length:")
    let value_start = trim_leading_ws(s, p: after_colon, end_pos: line_end)
    let value_end = trim_trailing_ws(s, start: value_start, p: line_end)
    let lit = str.byte_substring(s, start: value_start, len: value_end - value_start)
    match str.parse_i64(s: lit) do
      | Some(val: n) ->
        if n < 0 then
          throw JsonRpcFrameError(msg: "negative Content-Length")
        end
        return n
      | None ->
        throw JsonRpcFrameError(msg: "Content-Length is not a non-negative integer")
    end
  end
  // Skip this header line and continue scanning. `line_end + 2` skips CRLF.
  return scan_content_length(s, p: line_end + 2, header_end)
end

/**
Pull at most one framed message off the front of `input`. Returns
`UnframedNeedMore` when the buffer ends mid-frame (no header terminator,
or body shorter than `Content-Length`). Raises JsonRpcFrameError on a
header that is structurally present but invalid (non-numeric length,
missing Content-Length, etc.).

The `rest` field of `UnframedOk` is the unconsumed suffix after the
parsed frame — callers must thread it back into the next `unframe_one`
call to correctly handle two frames delivered in one TCP segment.
*/
export let unframe_one = fn (input: string) -> UnframedStep throws { JsonRpcError } do
  let n = byte_length_of(s: input)
  if n == 0 then return UnframedNeedMore end
  let header_end = find_header_end(s: input, p: 0)
  if header_end < 0 then return UnframedNeedMore end
  let content_length = scan_content_length(s: input, p: 0, header_end)
  if header_end + content_length > n then
    return UnframedNeedMore
  end
  let body = str.byte_substring(s: input, start: header_end, len: content_length)
  let value = parse(s: body)
  let rest_start = header_end + content_length
  let rest = str.byte_substring(s: input, start: rest_start, len: n - rest_start)
  return UnframedOk(value, rest)
end

// ═══════════════════════════════════════════════════════════════════════════
// I/O layer (Console capability)
// ═══════════════════════════════════════════════════════════════════════════
//
// Reads bytes one chunk at a time via `Console.read_bytes`, accumulating
// into a string until enough has arrived to satisfy `unframe_one`. The
// chunk size is small (64 bytes) — LSP traffic is bursty and headers are
// tiny, so a streaming approach avoids over-reading into the next message.

let read_chunk_size = 1
// Append a freshly-read ByteBuffer's bytes onto a string and free it. The
// buffer's `to_string` view is UTF-8: header bytes are pure ASCII and body
// bytes are RFC-8259 UTF-8 — both round-trip through `to_string`.
let consume_buf = fn (buf: %ByteBuffer) -> string do
  let s = bb.to_string(&buf)
  bb.free(%buf)
  return s
end

// Try to extract a frame from `acc`. If we need more bytes, read one chunk
// and recurse. Raises JsonRpcEof when stdin closes mid-frame.
let drain_until_frame = fn (acc: string) -> UnframedStep require { Console } throws { JsonRpcError } do
  match unframe_one(input: acc) do
    | UnframedOk(value, rest) -> return UnframedOk(value, rest)
    | UnframedNeedMore ->
      let %buf = Console.read_bytes(n: read_chunk_size)
      let chunk = consume_buf(%buf)
      if str.byte_length(s: chunk) == 0 then
        // EOF on stdin. If `acc` is empty, this is a clean shutdown; if we
        // had partial header/body bytes, the stream was truncated.
        if str.byte_length(s: acc) == 0 then
          throw JsonRpcEof
        end
        throw JsonRpcFrameError(msg: "unexpected EOF mid-frame")
      end
      return drain_until_frame(acc: acc ++ chunk)
  end
end

/**
Read one complete JSON-RPC message from the Console. Returns `None` on a
clean EOF (no bytes pending), `Some(value)` on a successful frame. Raises
`JsonRpcFrameError` when the wire bytes form a structurally invalid frame
— the dispatch loop catches it and routes to the configured error path.

Surplus bytes after the parsed message are dropped. Use
`read_message_pipelined` when pipelining is required (e.g. two frames
arriving in one TCP segment).
*/
export let read_message = fn () -> Option<JsonValue> require { Console } throws { JsonRpcError } do
  try
    match drain_until_frame(acc: "") do
      | UnframedOk(value, rest: _) -> return Some(val: value)
      | UnframedNeedMore -> throw JsonRpcFrameError(msg: "unframe stalled despite EOF guard")
    end
  catch
    | JsonRpcEof -> return None
  end
end

/**
Pipelined variant of `read_message`. Accepts `leftover` bytes from the
previous call (initially `""`) and returns a `Pair` of:
  - `left`: `None` on clean EOF, `Some(value)` on a successful frame.
  - `right`: the unconsumed suffix bytes to pass as `leftover` on the
    next call.

When two frames arrive in one TCP segment the second frame is preserved
in `right` rather than discarded, so the dispatch loop can process it
without a stalling `Console.read_bytes` call.
*/
export let read_message_pipelined = fn (leftover: string) -> Pair<Option<JsonValue>, string> require { Console } throws { JsonRpcError } do
  try
    match drain_until_frame(acc: leftover) do
      | UnframedOk(value, rest) -> return Pair(left: Some(val: value), right: rest)
      | UnframedNeedMore -> throw JsonRpcFrameError(msg: "unframe stalled despite EOF guard")
    end
  catch
    | JsonRpcEof -> return Pair(left: None, right: "")
  end
end

// ─── Cooperative (poll-gated) byte source ────────────────────────────────────
//
// The blocking drains above call `Console.read_bytes`, which parks the whole
// wasm instance in `fd_read` until a byte arrives. Under the cooperative
// scheduler that starves every spawned fiber (e.g. an LSP diagnostics task) that
// is sitting on the run queue. The cooperative pull below replaces the blocking
// read with a poll-gated event loop:
//
//   * Run queue NON-EMPTY  → `Coop.yield()` runs one round of pending fibers,
//     then `stdin_read_available()` non-blockingly grabs any bytes that arrived
//     in the meantime. No blocking: pending work keeps making progress.
//   * Run queue EMPTY      → nothing else to do, so `stdin_wait_readable()`
//     parks in `poll_oneoff` until fd 0 is read-ready (no busy-spin), then a
//     non-blocking `stdin_read_available()` grabs the bytes.
//
// EOF is concluded ONLY on the poll-block path: after `poll_oneoff` reports fd 0
// readable, a 0-byte read is a genuine end of stream. On the yield path a 0-byte
// read just means "no bytes yet" — loop and yield again. A `CoopPull` carries the
// freshly-read chunk plus whether the read observed EOF, so the per-transport
// drains can apply the same empty-buffer EOF guard the blocking drains use.

type CoopPull = CoopPull(chunk: string, at_eof: bool)

// One cooperative byte-source step. Yields to pending fibers when the run queue
// is non-empty (then non-blocking-reads), otherwise poll-blocks until fd 0 is
// read-ready (then reads). Returns the bytes read and whether EOF was observed.
let coop_pull_bytes = fn () -> CoopPull require { Coop } do
  if sched_runq_nonempty() then
    Coop.yield()
    let chunk = stdin_read_available()
    return CoopPull(chunk, at_eof: false)
  end
  stdin_wait_readable()
  let chunk = stdin_read_available()
  return CoopPull(chunk, at_eof: str.byte_length(s: chunk) == 0)
end

// Cooperative analogue of `drain_until_frame` (LSP Content-Length framing).
// Loops pulling bytes via the poll-gated source until a complete frame is in
// `acc`. Raises `JsonRpcEof` on a clean EOF with an empty `acc`, or
// `JsonRpcFrameError` on truncation mid-frame.
let drain_until_frame_cooperative = fn (acc: string) -> UnframedStep require { Coop } throws { JsonRpcError } do
  match unframe_one(input: acc) do
    | UnframedOk(value, rest) -> return UnframedOk(value, rest)
    | UnframedNeedMore ->
      let CoopPull(chunk, at_eof) = coop_pull_bytes()
      if at_eof then
        if str.byte_length(s: acc) == 0 then
          throw JsonRpcEof
        end
        throw JsonRpcFrameError(msg: "unexpected EOF mid-frame")
      end
      return drain_until_frame_cooperative(acc: acc ++ chunk)
  end
end

/**
Cooperative variant of `read_message_pipelined`. Identical framing contract —
same `Pair(left, right)` result, same `JsonRpcError` throws, `None` on clean EOF
— but the byte source is the poll-gated cooperative event loop above, so spawned
fibers run during the idle wait for the next frame instead of starving behind a
blocking `fd_read`. Must be called inside a `scheduler` inject (it uses `Coop`).

Frame assembly is identical to the blocking read: with input already buffered
(piped stream, empty run queue) the poll returns immediately ready and the
non-blocking read drains the buffered bytes; complete frames are assembled byte-
for-byte the same way `drain_until_frame` does.
*/
export let read_message_cooperative = fn (leftover: string) -> Pair<Option<JsonValue>, string> require { Coop } throws { JsonRpcError } do
  try
    match drain_until_frame_cooperative(acc: leftover) do
      | UnframedOk(value, rest) -> return Pair(left: Some(val: value), right: rest)
      | UnframedNeedMore -> throw JsonRpcFrameError(msg: "unframe stalled despite EOF guard")
    end
  catch
    | JsonRpcEof -> return Pair(left: None, right: "")
  end
end

/**
Write one framed JSON-RPC message to the Console. Always flushes a
complete header + body in a single `Console.print` call so partial frames
never leak even if the host runtime line-buffers stdout.
*/
export let write_message = fn (value: JsonValue) -> unit require { Console } throws { JsonRpcError } do
  let framed = frame_message(value)
  Console.print(val: framed)
  return ()
end

// ═══════════════════════════════════════════════════════════════════════════
// NDJSON transport (MCP stdio)
// ═══════════════════════════════════════════════════════════════════════════
//
// Per MCP 2024-11-05 stdio spec: one compact JSON object per message,
// terminated by `\n`. No Content-Length headers, no embedded newlines in
// the body. We tolerate optional `\r` before `\n` so Windows clients that
// emit CRLF aren't rejected, but the canonical separator is LF.

let strip_trailing_cr = fn (s: string) -> string do
  let n = str.byte_length(s)
  if n == 0 then return s end
  let last = str.byte_at(s, idx: n - 1)
  if last == ch_cr then
    return str.byte_substring(s, start: 0, len: n - 1)
  end
  return s
end

/**
Pull at most one newline-delimited JSON message off the front of `input`.
Returns `UnframedNeedMore` when the buffer does not yet contain a `\n`.
The body before the terminator is parsed as JSON; a malformed body raises
`JsonError` (caught by the dispatch loop and routed back as ParseError).

The `rest` field of `UnframedOk` is the unconsumed suffix after the
terminating `\n` — callers thread it back into the next call to handle
multiple frames delivered in one read.
*/
export let unframe_ndjson_one = fn (input: string) -> UnframedStep throws { JsonRpcError } do
  let n = byte_length_of(s: input)
  if n == 0 then return UnframedNeedMore end
  let nl_idx = str.find_byte(s: input, start: 0, ch: ch_lf)
  if nl_idx < 0 then return UnframedNeedMore end
  let body_raw = str.byte_substring(s: input, start: 0, len: nl_idx)
  let body = strip_trailing_cr(s: body_raw)
  let value = parse(s: body)
  let rest_start = nl_idx + 1
  let rest = str.byte_substring(s: input, start: rest_start, len: n - rest_start)
  return UnframedOk(value, rest)
end

let drain_until_ndjson_frame = fn (acc: string) -> UnframedStep require { Console } throws { JsonRpcError } do
  match unframe_ndjson_one(input: acc) do
    | UnframedOk(value, rest) -> return UnframedOk(value, rest)
    | UnframedNeedMore ->
      let %buf = Console.read_bytes(n: read_chunk_size)
      let chunk = consume_buf(%buf)
      if str.byte_length(s: chunk) == 0 then
        if str.byte_length(s: acc) == 0 then
          throw JsonRpcEof
        end
        throw JsonRpcFrameError(msg: "unexpected EOF mid-ndjson-frame")
      end
      return drain_until_ndjson_frame(acc: acc ++ chunk)
  end
end

/**
Pipelined NDJSON read. Accepts leftover bytes from the previous call
(initially `""`) and returns `Pair(left: None, right: "")` on clean EOF,
or `Pair(left: Some(value), right: rest)` on a successful frame.
*/
export let read_ndjson_message_pipelined = fn (leftover: string) -> Pair<Option<JsonValue>, string> require { Console } throws { JsonRpcError } do
  try
    match drain_until_ndjson_frame(acc: leftover) do
      | UnframedOk(value, rest) -> return Pair(left: Some(val: value), right: rest)
      | UnframedNeedMore -> throw JsonRpcFrameError(msg: "ndjson unframe stalled despite EOF guard")
    end
  catch
    | JsonRpcEof -> return Pair(left: None, right: "")
  end
end

// Cooperative analogue of `drain_until_ndjson_frame` (MCP NDJSON framing). Same
// poll-gated byte source as `drain_until_frame_cooperative`.
let drain_until_ndjson_frame_cooperative = fn (acc: string) -> UnframedStep require { Coop } throws { JsonRpcError } do
  match unframe_ndjson_one(input: acc) do
    | UnframedOk(value, rest) -> return UnframedOk(value, rest)
    | UnframedNeedMore ->
      let CoopPull(chunk, at_eof) = coop_pull_bytes()
      if at_eof then
        if str.byte_length(s: acc) == 0 then
          throw JsonRpcEof
        end
        throw JsonRpcFrameError(msg: "unexpected EOF mid-ndjson-frame")
      end
      return drain_until_ndjson_frame_cooperative(acc: acc ++ chunk)
  end
end

/**
Cooperative variant of `read_ndjson_message_pipelined`. Same framing contract,
same `JsonRpcError` throws, `None` on clean EOF — but the byte source is the
poll-gated cooperative event loop, so spawned fibers run during the idle wait
instead of starving behind a blocking `fd_read`. Must be called inside a
`scheduler` inject.
*/
export let read_ndjson_message_cooperative = fn (leftover: string) -> Pair<Option<JsonValue>, string> require { Coop } throws { JsonRpcError } do
  try
    match drain_until_ndjson_frame_cooperative(acc: leftover) do
      | UnframedOk(value, rest) -> return Pair(left: Some(val: value), right: rest)
      | UnframedNeedMore -> throw JsonRpcFrameError(msg: "ndjson unframe stalled despite EOF guard")
    end
  catch
    | JsonRpcEof -> return Pair(left: None, right: "")
  end
end

/**
Write one NDJSON-framed JSON-RPC message to the Console. `serialize`
emits compact output with no raw newlines, so a single `print` of
`<body>\n` produces a spec-compliant frame and keeps it atomic against
line-buffered stdout.
*/
export let write_ndjson_message = fn (value: JsonValue) -> unit require { Console } throws { JsonRpcError } do
  let body = serialize(v: value)
  Console.print(val: body ++ "\n")
  return ()
end

// ─── Response helpers ────────────────────────────────────────────────────────

/** Build a JSON-RPC 2.0 success response. */
export let response_ok = fn (id: JsonValue, result: JsonValue) -> JsonValue do
  return JsonObject(fields: [
    JsonField(key: "jsonrpc", value: JsonString(val: "2.0")),
    JsonField(key: "id", value: id),
    JsonField(key: "result", value: result)
  ])
end

/** Build a JSON-RPC 2.0 error response. */
export let response_error = fn (id: JsonValue, code: i64, message: string) -> JsonValue do
  let err = JsonObject(fields: [
    JsonField(key: "code", value: JsonInt(val: code)),
    JsonField(key: "message", value: JsonString(val: message))
  ])
  return JsonObject(fields: [
    JsonField(key: "jsonrpc", value: JsonString(val: "2.0")),
    JsonField(key: "id", value: id),
    JsonField(key: "error", value: err)
  ])
end

// ─── Message classification ──────────────────────────────────────────────────

/**
Classification of an inbound JSON-RPC message. The dispatch loop matches
on this to decide whether to invoke the request branch (and write back a
response) or the notification branch (and discard the return value).
*/
export type IncomingMessage =
    Request(id: JsonValue, method: string, params: JsonValue)
  | Notification(method: string, params: JsonValue)
  | Malformed(reason: string)

/**
Inspect `value` and tag it as Request / Notification / Malformed. A message
is a Request iff it has both `method` and `id`; a Notification has `method`
but no `id`; anything else is Malformed.
*/
export let classify = fn (value: JsonValue) -> IncomingMessage do
  let method_v = get_field(obj: value, key: "method")
  match method_v do
    | None -> return Malformed(reason: "missing 'method' field")
    | Some(val: m_v) ->
      match m_v do
        | JsonString(val: m) ->
          let params = match get_field(obj: value, key: "params") do
            | None -> JsonNull
            | Some(val: p) -> p
          end
          match get_field(obj: value, key: "id") do
            | None -> return Notification(method: m, params)
            | Some(val: id_v) -> return Request(id: id_v, method: m, params)
          end
        | _ -> return Malformed(reason: "'method' is not a string")
      end
  end
end

// ─── Dispatch loop ───────────────────────────────────────────────────────────
//
// The `dispatch_fn` parameter is a function taking `(IncomingMessage)` and
// returning `Option<JsonValue>`:
//   - Request → Some(response_value) gets written; None is treated as
//     InternalError and an error response is sent back.
//   - Notification → return value is ignored (always None in well-behaved
//     callers; non-None is silently dropped, matching server convention
//     that notifications have no reply).
//
// `max_iters` bounds the loop for tests that supply a finite stream;
// production code passes -1 for unbounded. The loop returns the number of
// successfully processed frames.

/**
Single-step dispatch: read one message, classify, invoke dispatch_fn, emit
response if appropriate. Returns true if a message was processed, false
on clean EOF.
*/
let dispatch_step = fn (
  dispatch_fn: (msg: IncomingMessage) -> Option<JsonValue>
) -> bool require { Console } throws { JsonRpcError } do
  match read_message() do
    | None -> return false
    | Some(val: value) ->
      let classified = classify(value)
      match classified do
        | Request(id, method: _, params: _) ->
          let reply = dispatch_fn(msg: classified)
          let response_value = match reply do
            | Some(val: r) -> r
            | None -> response_error(id, code: internal_error,
                        message: "handler returned no response")
          end
          write_message(value: response_value)
          return true
        | Notification(method: _, params: _) ->
          dispatch_fn(msg: classified)
          return true
        | Malformed(reason) ->
          // Malformed inbound — write back a parse-error response with null
          // id (LSP spec §3.1) and continue. Surplus state on `value` is
          // discarded.
          write_message(value: response_error(id: JsonNull,
            code: invalid_request, message: reason))
          return true
      end
  end
end
