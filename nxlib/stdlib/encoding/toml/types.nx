/**
 * toml/types: public ADT + exception definitions for the TOML module.
 */

// ─── Public exceptions ────────────────────────────────────────────────────────

/** Parser/serializer error. `pos` is the byte offset (-1 for non-position errors). */
export exception TomlError(msg: string, pos: i64)

/** Exception group covering every exception raised by parse / serialize. */
export exception group TomlThrow = TomlError

// ─── Public types ────────────────────────────────────────────────────────────

/** One key/value pair inside a TOML table. */
export type TomlField = TomlField(key: string, value: TomlValue)

/** TOML value algebra. */
export type TomlValue =
    TomlString(val: string)
  | TomlInt(val: i64)
  | TomlFloat(val: f64)
  | TomlBool(val: bool)
  | TomlDatetime(val: string)
  | TomlArray(items: [TomlValue])
  | TomlTable(fields: [TomlField])
