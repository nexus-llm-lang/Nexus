/**
 * toml/serialize: TOML 1.0.0 serializer — emit TOML document format.
 */

import * as str from "std:str"
import * as char from "std:char"
import * as bb from "std:bytebuffer"
import { TomlError, TomlThrow, TomlField, TomlValue,
         TomlString, TomlInt, TomlFloat, TomlBool, TomlDatetime,
         TomlArray, TomlTable } from "std:encoding/toml/types"

let ch_dquote = '"'
let ch_backslash = '\\'
let ch_minus = '-'

let slen = fn (s: string) -> i64 do return str.byte_length(s) end

let hex_digit_char = fn (n: i64) -> string do
  if n < 10 then return str.from_char_code(code: n + 48) end
  return str.from_char_code(code: n + 87)
end

// A bare key character: A-Z a-z 0-9 - _
let is_bare_key_char = fn (c: char) -> bool do
  if c >= 'A' && c <= 'Z' then return true end
  if c >= 'a' && c <= 'z' then return true end
  if c >= '0' && c <= '9' then return true end
  if c == ch_minus then return true end
  if c == '_' then return true end
  return false
end

// Escape a string for TOML basic string output.
let escape_toml_string = fn (
  s: string,
  p: i64,
  run_start: i64,
  buf: %bb.ByteBuffer
) -> %bb.ByteBuffer do
  let n = slen(s)
  if p >= n then
    return flush_range_into(%buf, s, start: run_start, end_pos: p)
  end
  let c = str.byte_at(s, idx: p)
  let code = char.ord(c)
  if c == ch_dquote then
    let %buf1 = flush_range_into(%buf, s, start: run_start, end_pos: p)
    let %buf2 = bb.push_string(buf: %buf1, s: "\\\"")
    return escape_toml_string(s, p: p + 1, run_start: p + 1, buf: %buf2)
  end
  if c == ch_backslash then
    let %buf1 = flush_range_into(%buf, s, start: run_start, end_pos: p)
    let %buf2 = bb.push_string(buf: %buf1, s: "\\\\")
    return escape_toml_string(s, p: p + 1, run_start: p + 1, buf: %buf2)
  end
  if code >= 0 && code < 32 then
    let %buf1 = flush_range_into(%buf, s, start: run_start, end_pos: p)
    let esc =
      if code == 8 then "\\b"
      else if code == 9 then "\\t"
      else if code == 10 then "\\n"
      else if code == 12 then "\\f"
      else if code == 13 then "\\r"
      else "\\u" ++ hex_digit_char(n: code / 16) ++ hex_digit_char(n: code - (code / 16) * 16)
      end
    let %buf2 = bb.push_string(buf: %buf1, s: esc)
    return escape_toml_string(s, p: p + 1, run_start: p + 1, buf: %buf2)
  end
  return escape_toml_string(s, p: p + 1, run_start, buf: %buf)
end

let flush_range_into = fn (
  buf: %bb.ByteBuffer,
  s: string,
  start: i64,
  end_pos: i64
) -> %bb.ByteBuffer do
  if end_pos <= start then return buf end
  return bb.push_string(%buf, s: str.byte_substring(s, start, len: end_pos - start))
end

let ser_string = fn (s: string) -> string do
  let %buf = bb.empty()
  let %buf = bb.push_string(buf: %buf, s: "\"")
  let %buf = escape_toml_string(s, p: 0, run_start: 0, buf: %buf)
  let %buf = bb.push_string(buf: %buf, s: "\"")
  let result = bb.to_string(&buf)
  bb.free(%buf)
  return result
end

let ser_float = fn (val: f64) -> string throws { TomlThrow } do
  if val !=. val then throw TomlError(msg: "NaN is not serializable", pos: -1) end
  let rendered = str.from_float(val)
  if rendered == "inf" then return "inf" end
  if rendered == "-inf" then return "-inf" end
  if str.contains(
    s: rendered,
    sub: "."
  ) || str.contains(s: rendered, sub: "e") || str.contains(s: rendered, sub: "E") then
    return rendered
  end
  return rendered ++ ".0"
end

// Validate that all items in a TOML array have the same type tag.
let toml_type_tag = fn (v: TomlValue) -> string do
  match v do
    | TomlString(_) -> return "string"
    | TomlInt(_) -> return "int"
    | TomlFloat(_) -> return "float"
    | TomlBool(_) -> return "bool"
    | TomlDatetime(_) -> return "datetime"
    | TomlArray(_) -> return "array"
    | TomlTable(_) -> return "table"
  end
end

let check_array_types = fn (
  items: [ TomlValue ],
  expected_tag: string
) -> bool throws { TomlThrow } do
  match items do
    | [] -> return true
    | v :: rest ->
      let tag = toml_type_tag(v)
      if tag != expected_tag then
        throw TomlError(
          msg: "mixed-type array: expected " ++ expected_tag ++ " but found " ++ tag,
          pos: -1
        )
      end
      return check_array_types(items: rest, expected_tag)
  end
end

let validate_array = fn (items: [ TomlValue ]) -> unit throws { TomlThrow } do
  match items do
    | [] -> return ()
    | first :: rest ->
      let tag = toml_type_tag(v: first)
      check_array_types(items: rest, expected_tag: tag)
      return ()
  end
end

let ser_value = fn (v: TomlValue) -> string throws { TomlThrow } do
  match v do
    | TomlString(val: sv) -> return ser_string(s: sv)
    | TomlInt(val: i) -> return str.from_i64(val: i)
    | TomlFloat(val: f) -> return ser_float(val: f)
    | TomlBool(val: b) -> return str.from_bool(val: b)
    | TomlDatetime(val: dt) -> return dt
    | TomlArray(items: xs) ->
      validate_array(items: xs)
      return "[" ++ ser_array_items(items: xs) ++ "]"
    | TomlTable(fields: fs) ->
      return "{" ++ ser_inline_fields(fields: fs) ++ "}"
  end
end

let ser_array_items = fn (items: [ TomlValue ]) -> string throws { TomlThrow } do
  let %buf = ser_array_into(buf: bb.empty(), items, first: true)
  let result = bb.to_string(&buf)
  bb.free(%buf)
  return result
end

let ser_array_into = fn (
  buf: %bb.ByteBuffer,
  items: [ TomlValue ],
  first: bool
) -> %bb.ByteBuffer throws { TomlThrow } do
  match items do
    | [] -> return buf
    | v :: rest ->
      let %b1 =
        if first then buf
        else bb.push_string(%buf, s: ", ")
        end
      let chunk = ser_value(v)
      let %buf = bb.push_string(buf: %b1, s: chunk)
      return ser_array_into(buf: %buf, items: rest, first: false)
  end
end

let ser_inline_fields = fn (fields: [ TomlField ]) -> string throws { TomlThrow } do
  let %buf = ser_inline_fields_into(buf: bb.empty(), fields, first: true)
  let result = bb.to_string(&buf)
  bb.free(%buf)
  return result
end

let ser_inline_fields_into = fn (
  buf: %bb.ByteBuffer,
  fields: [ TomlField ],
  first: bool
) -> %bb.ByteBuffer throws { TomlThrow } do
  match fields do
    | [] -> return buf
    | TomlField(key: k, value: v) :: rest ->
      let %b1 =
        if first then buf
        else bb.push_string(%buf, s: ", ")
        end
      let %b2 = bb.push_string(buf: %b1, s: ser_bare_key_or_quoted(s: k))
      let %b3 = bb.push_string(buf: %b2, s: " = ")
      let chunk = ser_value(v)
      let %buf = bb.push_string(buf: %b3, s: chunk)
      return ser_inline_fields_into(buf: %buf, fields: rest, first: false)
  end
end

// Decide whether a key needs quoting.
let all_bare_key_chars = fn (s: string, p: i64) -> bool do
  if p >= slen(s) then return true end
  let c = str.byte_at(s, idx: p)
  if is_bare_key_char(c) then return all_bare_key_chars(s, p: p + 1) end
  return false
end

let ser_bare_key_or_quoted = fn (s: string) -> string do
  if slen(s) == 0 then return "\"\"" end
  if all_bare_key_chars(s, p: 0) then return s end
  return ser_string(s)
end

// Serialize a key path (e.g. "a.b.c") quoting each segment individually.
// The path is a dot-joined string; each segment is quoted only if it contains
// non-bare-key characters.
let ser_key_path = fn (path: string) -> string do
  let segs = str.split(s: path, sep: ".")
  return ser_key_path_segs(segs)
end

let ser_key_path_segs = fn (segs: [ string ]) -> string do
  match segs do
    | [] -> return ""
    | seg :: [] -> return ser_bare_key_or_quoted(s: seg)
    | seg :: rest ->
      return ser_bare_key_or_quoted(s: seg) ++ "." ++ ser_key_path_segs(segs: rest)
  end
end

// Top-level serializer: emits TOML document format (section headers, not inline tables).
// Scalars are emitted first (after the section header), then nested tables follow
// as their own [subsection] headers, so the output stays in TOML standard form.
let ser_doc_fields = fn (
  buf: %bb.ByteBuffer,
  fields: [ TomlField ],
  prefix: string
) -> %bb.ByteBuffer throws { TomlThrow } do
  // First pass: emit all scalar/array/aot entries (no nested-table headers yet).
  let %b1 = ser_doc_scalars(buf: %buf, fields, prefix)
  // Second pass: emit [section] headers for nested tables.
  return ser_doc_tables(buf: %b1, fields, prefix)
end

// Emit scalar, inline-array, and array-of-tables entries for this level.
let ser_doc_scalars = fn (
  buf: %bb.ByteBuffer,
  fields: [ TomlField ],
  prefix: string
) -> %bb.ByteBuffer throws { TomlThrow } do
  match fields do
    | [] -> return buf
    | TomlField(key: k, value: v) :: rest ->
      match v do
        | TomlTable(_) ->
          // Nested tables are emitted in the second pass; skip here.
          return ser_doc_scalars(buf: %buf, fields: rest, prefix)
        | TomlArray(items: xs) ->
          if is_array_of_tables(items: xs) then
            // AOT entries are emitted in the second pass.
            return ser_doc_scalars(buf: %buf, fields: rest, prefix)
          end
          let %b1 = bb.push_string(
            buf: %buf,
            s: ser_bare_key_or_quoted(s: k) ++ " = " ++ ser_value(v) ++ "\n"
          )
          return ser_doc_scalars(buf: %b1, fields: rest, prefix)
        | _ ->
          let %b1 = bb.push_string(
            buf: %buf,
            s: ser_bare_key_or_quoted(s: k) ++ " = " ++ ser_value(v) ++ "\n"
          )
          return ser_doc_scalars(buf: %b1, fields: rest, prefix)
      end
  end
end

// Emit [section] headers for nested TomlTable fields and [[aot]] headers for
// array-of-tables fields.  Recurses so deeply-nested tables work.
let ser_doc_tables = fn (
  buf: %bb.ByteBuffer,
  fields: [ TomlField ],
  prefix: string
) -> %bb.ByteBuffer throws { TomlThrow } do
  match fields do
    | [] -> return buf
    | TomlField(key: k, value: v) :: rest ->
      let full_key =
        if slen(s: prefix) == 0 then k
        else prefix ++ "." ++ k
        end
      match v do
        | TomlTable(fields: sub) ->
          // Only emit the [section] header when the sub has at least one scalar
          // (non-table, non-aot) field.  Pure-container tables (only sub-tables)
          // are represented naturally via [a.b], [a.c] without a parent [a] header.
          let has_scalars = fields_have_scalars(fields: sub)
          let %b1 =
            if has_scalars then
              let %bh = bb.push_string(buf: %buf, s: "[" ++ ser_key_path(path: full_key) ++ "]\n")
              let %bh2 = ser_doc_scalars(buf: %bh, fields: sub, prefix: full_key)
              bb.push_string(buf: %bh2, s: "\n")
            else
              buf
            end
          let %b2 = ser_doc_tables(buf: %b1, fields: sub, prefix: full_key)
          return ser_doc_tables(buf: %b2, fields: rest, prefix)
        | TomlArray(items: xs) ->
          if is_array_of_tables(items: xs) then
            let %b1 = ser_aot_entries(buf: %buf, key: full_key, items: xs)
            return ser_doc_tables(buf: %b1, fields: rest, prefix)
          end
          return ser_doc_tables(buf: %buf, fields: rest, prefix)
        | _ ->
          return ser_doc_tables(buf: %buf, fields: rest, prefix)
      end
  end
end

// Returns true when `fields` contains at least one scalar (or non-aot array)
// entry — used to decide whether to emit a [section] header.
let fields_have_scalars = fn (fields: [ TomlField ]) -> bool do
  match fields do
    | [] -> return false
    | TomlField(key: _, value: v) :: rest ->
      match v do
        | TomlTable(_) -> return fields_have_scalars(fields: rest)
        | TomlArray(items: xs) ->
          if is_array_of_tables(items: xs) then
            return fields_have_scalars(fields: rest)
          end
          return true
        | _ -> return true
      end
  end
end

let is_array_of_tables = fn (items: [ TomlValue ]) -> bool do
  match items do
    | [] -> return false
    | TomlTable(_) :: _ -> return true
    | _ -> return false
  end
end

// Emit the key = value lines for a section body (no headers for scalars).
let ser_section_kvs = fn (
  buf: %bb.ByteBuffer,
  fields: [ TomlField ]
) -> %bb.ByteBuffer throws { TomlThrow } do
  match fields do
    | [] -> return buf
    | TomlField(key: k, value: v) :: rest ->
      match v do
        | TomlTable(_) ->
          // Nested table inside a section: emit as inline value here for simplicity.
          let %buf = bb.push_string(
            buf: %buf,
            s: ser_bare_key_or_quoted(s: k) ++ " = " ++ ser_value(v) ++ "\n"
          )
          return ser_section_kvs(buf: %buf, fields: rest)
        | _ ->
          let %buf = bb.push_string(
            buf: %buf,
            s: ser_bare_key_or_quoted(s: k) ++ " = " ++ ser_value(v) ++ "\n"
          )
          return ser_section_kvs(buf: %buf, fields: rest)
      end
  end
end

// Emit array-of-tables entries.
let ser_aot_entries = fn (
  buf: %bb.ByteBuffer,
  key: string,
  items: [ TomlValue ]
) -> %bb.ByteBuffer throws { TomlThrow } do
  match items do
    | [] -> return buf
    | TomlTable(fields: sub) :: rest ->
      let %b1 = bb.push_string(buf: %buf, s: "[[" ++ ser_key_path(path: key) ++ "]]\n")
      let %b2 = ser_section_kvs(buf: %b1, fields: sub)
      let %buf = bb.push_string(buf: %b2, s: "\n")
      return ser_aot_entries(buf: %buf, key, items: rest)
    | _ :: rest ->
      return ser_aot_entries(buf: %buf, key, items: rest)
  end
end

/**
Serializes a TomlValue (which must be TomlTable at the root level) into a
TOML document string. Inline tables and arrays are supported as values.
Raises TomlError if NaN/Infinity appears in a float or if a mixed-type array
is encountered.
*/
let do_serialize_table = fn (fields: [ TomlField ]) -> string throws { TomlThrow } do
  let %buf = ser_doc_fields(buf: bb.empty(), fields, prefix: "")
  let result = bb.to_string(&buf)
  bb.free(%buf)
  return result
end

export let serialize = fn (v: TomlValue) -> string throws { TomlThrow } do
  match v do
    | TomlTable(fields: fs) -> return do_serialize_table(fields: fs)
    | _ -> throw TomlError(msg: "root value must be a table", pos: -1)
  end
end
