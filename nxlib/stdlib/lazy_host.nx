/**
 * lazy_host: real-thread dispatch for `@`-thunks (WASI threads).
 *
 * Two-step protocol:
 *
 *   host_spawn : <T>(@T) -> %Task<T>    // consumes the thunk, returns a handle
 *   host_join  : <T>(%Task<T>) -> T     // waits on the handle, returns the value
 *
 * `host_spawn` starts an OS thread (via `wasi.thread-spawn`) that forces the
 * thunk against the same shared linear memory the caller sees; `host_join`
 * parks on the task's ready flag and reads the forced value. `Task<T>` is an
 * opaque linear wrapper around the runtime task pointer — the linearity
 * checker rejects spawn-without-join, and the phantom `T` keeps the FFI's
 * type-erased i64 channel from being misused across the pair.
 *
 * Single `@x` force is still synchronous (a `call_indirect`); this module and
 * `std:lazy`'s `force_all` are the parallel paths. `race` / `cancel` / `detach`
 * in `std:lazy` remain sequential — they would need host-side cancel/arbiter
 * primitives that do not exist.
 *
 * Importing this module pulls the `wasi.thread-spawn` import into the produced
 * wasm; run it via the bundled `nexus` launcher (or `wasmtime -S threads`).
 */
import * as lz from "std:runtime/lazy"

/// A handle to a spawned thunk. Linear — must be drained by `host_join`.
export opaque type Task<T> = Task(id: i64)

/// Dispatch a thunk to a worker thread; returns a linear handle that must be
/// consumed by `host_join`. The `@T` is consumed.
export let host_spawn = fn <T>(a: @T) -> %Task<T> do
  let id = lz.lazy_spawn(a_thunk: a)
  let h = Task(id)
  let %lh = h
  return %lh
end

/// Await a previously spawned thunk and return its forced value. Consumes the
/// linear handle. The parameter is named `handle` because `task` is a reserved
/// keyword.
export let host_join = fn <T>(handle: %Task<T>) -> T do
  let Task(id) = handle
  return lz.lazy_join(a_task: id)
end
