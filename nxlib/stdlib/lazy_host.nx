/**
 * lazy_host: Runtime-backed lazy thunk dispatch (`nexus:runtime/lazy`).
 *
 * Two-step protocol against the host interface (Rust `__nx_lazy_spawn` /
 * `__nx_lazy_join`):
 *
 *   host_spawn : <T>(@T) -> %Task<T>    // consumes thunk, returns linear handle
 *   host_join  : <T>(%Task<T>) -> T     // waits on handle, returns forced value
 *
 * `Task<T>` is an opaque linear wrapper around the runtime's raw i64 task
 * id. The linearity checker statically rejects spawn-without-join (the
 * entry in the runtime's tasks map and, for threaded thunks, the Rust
 * `JoinHandle` would otherwise leak for the lifetime of the wasm
 * instance).
 *
 * Zero-capture thunks run on a worker thread; non-zero-capture thunks
 * fall back to inline on the caller thread and the "task id" encodes the
 * inline result directly. The encoding is private to the runtime —
 * callers must always pair spawn with join.
 *
 * Split out from `std:lazy` (issue nexus-qhms) so that fixtures importing
 * only the pure-Nexus combinators (race / cancel / detach / force_all)
 * do not pull `nexus:runtime/lazy` host externals into the produced wasm.
 * Importing this module marks the consumer as needing the runtime host
 * shim, which is provided when the wasm is run via the bundled `nexus`
 * polyglot launcher.
 */
import external "nexus:runtime/lazy"
external __nx_lazy_spawn = "__nx_lazy_spawn" : <T>(thunk: @T, num_captures: i32) -> i64
external __nx_lazy_join = "__nx_lazy_join" : <T>(task_id: i64) -> T

/// A handle to a spawned thunk. Linear — must be consumed by `host_join`.
/// Phantom T threads the thunk's element type from host_spawn to host_join
/// so the FFI's type-erased i64 channel cannot be misused across the pair.
export opaque type Task<T> = Task(id: i64)

/// host_spawn(a): Dispatch a thunk to the runtime. The @T is consumed and
/// a linear %Task<T> is returned that must be drained by host_join.
///
/// num_captures is passed to the runtime as a hint about whether the
/// thunk reads captures. The shared-memory runtime threads every thunk
/// regardless (worker reads captures through the same SharedMemory the
/// caller writes to), so the value is effectively ignored there. The
/// non-shared-memory path uses a positive value to force the inline
/// fallback, since a worker Store would see zero-initialised memory and
/// silently produce wrong values for capture-bearing thunks.
export let host_spawn = fn <T>(a: @T) -> %Task<T> do
  let id = __nx_lazy_spawn(thunk: a, num_captures: 1)
  let t = Task(id)
  let %lt = t
  return %lt
end

/// host_join(handle): Await a previously spawned thunk and return its
/// forced value. Consumes the linear handle.
///
/// Parameter is named `handle` (not `task`) because `task` is a reserved
/// keyword in Nexus.
export let host_join = fn <T>(handle: %Task<T>) -> T do
  let Task(id) = handle
  return __nx_lazy_join(task_id: id)
end

/// host_force(a): Convenience composition of spawn + join. Semantically
/// equivalent to `@a`, but routes the evaluation through the runtime so
/// any future cross-thunk parallelism surfaces here.
export let host_force = fn <T>(a: @T) -> T do
  return host_join(handle: host_spawn(a))
end
