/**
 * regexp: Thompson-NFA regular expressions over byte-indexed strings.
 *
 * Pure Nexus, no host functions. The implementation is the canonical
 * Pike/Cox VM:
 *
 *   parse → AST → compile → bytecode → NFA simulation
 *
 * The simulator is a parallel thread set with two epoch-marked occupancy
 * arrays, so a program of m instructions runs against an n-byte input in
 * O(n × m) time with no backtracking and no exponential blowup on
 * pathological patterns (e.g. `(a|a)*b` against `aaaa…ac`).
 *
 * Surface is the ERE subset described in:
 *
 *   literals, `.`, `\d \w \s \D \W \S`
 *   character classes `[abc]`, `[^abc]`, `[a-z]` (range)
 *   anchors `^` `$`
 *   quantifiers `*` `+` `?` `{n}` `{n,}` `{n,m}` (greedy only)
 *   alternation `a|b`, concatenation, groups `(...)` / `(?:...)`
 *   escapes `\.` `\\` `\(` etc.
 *
 * Capture text is sliced from the input by byte offset, so captures inherit
 * the input's UTF-8 representation verbatim. Anchors, classes, and `.` all
 * operate on bytes — multi-byte UTF-8 codepoints match `.` as a sequence of
 * single-byte iterations, the same policy std:str uses. No Unicode-aware
 * matching is implemented.
 *
 * Unsupported features (backreferences `\1`, lookaround `(?=...)`, Unicode
 * property `\p{...}`, named groups `(?<name>...)`) are rejected at parse
 * time with InvalidRegexp.
 *
 * Implementation is split across sub-files:
 *   regexp/types.nx    — shared types, opcodes, bit-set helpers, char classes
 *   regexp/parse.nx    — recursive-descent parser and bytecode compiler
 *   regexp/exec.nx     — NFA simulation and match API
 *   regexp/replace.nx  — template replacement and split
 * This file is the stable import surface: `std:regexp`.
 */

import { Option } from "std:option"
import * as _types   from "std:text/regexp/types"
import { from_string as _from_string } from "std:text/regexp/parse"
import { test as _test, find as _find, find_all as _find_all } from "std:text/regexp/exec"
import {
  sub as _sub,
  gsub as _gsub,
  gsub_with as _gsub_with,
  split as _split
} from "std:text/regexp/replace"

/**
Compile a regular-expression pattern. Throws `InvalidRegexp` (with the
failing byte offset embedded in the message) on a parse error. The
returned value is safe to share — there is no per-match mutable state.
*/
export let from_string = fn (src: string) -> Regexp throws { RegexpThrow } do
  return _from_string(src)
end

/**
Returns true if `re` matches anywhere inside `s` (substring containment
semantics, like `Regexp.is_match` in most languages).
*/
export let test = fn (re: Regexp, s: string) -> bool do
  return _test(re, s)
end

/**
Find the leftmost match of `re` in `s`. Returns the match record or
`None`. Greedy semantics: among all matches starting at the leftmost
position, the longest is returned.
*/
export let find = fn (re: Regexp, s: string) -> Option<Match> do
  return _find(re, s)
end

/**
Return every non-overlapping match of `re` in `s`, left-to-right. Empty
matches are emitted but do not stall progress — the search position
advances by at least one byte after a zero-width hit.
*/
export let find_all = fn (re: Regexp, s: string) -> [ Match ] do
  return _find_all(re, s)
end

/**
Replace only the first match in `s`. `repl` supports `$&` (whole match),
`$1..$9` (group captures), and `$$` (literal `$`). Other `$X` sequences
pass through verbatim.
*/
export let sub = fn (re: Regexp, s: string, repl: string) -> string do
  return _sub(re, s, repl)
end

/**
Replace every non-overlapping match in `s`. Zero-width matches consume
one byte each (copied verbatim) so the loop always makes progress.
*/
export let gsub = fn (re: Regexp, s: string, repl: string) -> string do
  return _gsub(re, s, repl)
end

/**
Functional variant of `gsub`: each match is fed to the user-supplied
callback whose return value becomes the replacement. Useful for context-
sensitive replacements that cannot be expressed as a template.
*/
export let gsub_with = fn (re: Regexp, s: string, f: (m: Match) -> string) -> string do
  return _gsub_with(re, s, f)
end

/**
Split `s` on every non-overlapping match of `re`. The separator text is
dropped; the surrounding substrings (possibly empty) are returned in
order. An empty pattern returns the input as a single element to avoid
emitting one entry per character (which the literal `std:str.split` also
does for an empty separator).
*/
export let split = fn (re: Regexp, s: string) -> [ string ] do
  return _split(re, s)
end
