/**
 * str/float: f64 <-> string conversion.
 *
 * These avoid f64 *literals* on purpose: float literals are themselves encoded
 * at compile time via `bb.push_f64_str_le` -> `string_to_f64`, so the
 * seed compiler that builds this file must not depend on a working float-literal
 * path here. All constants are materialised via `i64_to_float`.
 */
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"
import * as cast from "std:runtime/cast"
import { i64_to_float, float_to_i64 } from "std:math"
import { pow5_hi, pow5_lo, pow5_qmin, pow5_qmax } from "std:text/str/pow5_table"
import {
  byte_at_addr,
  alloc_bytes,
  pack,
  copy_bytes,
  is_ws,
  skip_ws_go,
  count_digits,
  write_digits_pos,
  store_at,
  string_from_i64
} from "std:text/str/core"

/** f64 +0.0 (built from bits, not a literal). */
let f0 = fn () -> float do return i64_to_float(val: 0) end
/** f64 1.0. */
let f1 = fn () -> float do return i64_to_float(val: 1) end
/** f64 10.0. */
let f10 = fn () -> float do return i64_to_float(val: 10) end
/** f64 NaN, written as the canonical quiet-NaN bit pattern. */
let fnan = fn () -> float do return reinterpret_to_f64(bits: 9221120237041090560) end

/** Reinterpret the 64 bits of `bits` as an f64 (round-trips via linear memory). */
let reinterpret_to_f64 = fn (bits: i64) -> float do
  let p = arena.alloc_raw(size: 8)
  mem.store_i64(addr: p, val: bits)
  return mem.load_f64(addr: p)
end
/** Reinterpret the 64 bits of `x` as an i64. */
let reinterpret_to_i64 = fn (x: float) -> i64 do
  let p = arena.alloc_raw(size: 8)
  mem.store_f64(addr: p, val: x)
  return mem.load_i64(addr: p)
end

/** 10^n as an i64 for 0 <= n <= 18 (exact). */
let int_pow10 = fn (n: i64) -> i64 do return int_pow10_go(n, acc: 1) end
let int_pow10_go = fn (n: i64, acc: i64) -> i64 do
  if n <= 0 then return acc end
  return int_pow10_go(n: n - 1, acc: acc * 10)
end

/** 10^n as an f64 for n >= 0 (exact for n <= 22; a few ulps beyond). */
let pow10_pos = fn (n: i64) -> float do
  if n <= 0 then return f1() end
  if n <= 18 then return i64_to_float(val: int_pow10(n)) end
  return i64_to_float(val: int_pow10(n: 18)) *. pow10_pos(n: n - 18)
end
/** 10^n as an f64 for any n (1 ulp from the divide when n < 0). */
let pow10 = fn (n: i64) -> float do
  if n >= 0 then return pow10_pos(n) end
  return f1() /. pow10_pos(n: 0 - n)
end

/** Lowercase a single ASCII byte. */
let lc = fn (b: i64) -> i64 do if b >= 65 && b <= 90 then return b + 32 else return b end end

/**
f64-string scan state, stored in a 5-word scratch block:
  w0: pos (current byte offset, absolute)
  w1: sign (0 or 1)
  w2: mantissa (i64, accumulated, capped at 18 digits)
  w3: decexp (i64, the base-10 exponent adjustment so far)
  w4: flags: bit0 = saw at least one mantissa digit; bit1 = malformed
*/
let st_alloc = fn () -> i64 do return arena.alloc_raw(size: 40) end
let st_pos = fn (s: i64) -> i64 do return mem.load_i64(addr: s) end
let st_set_pos = fn (s: i64, v: i64) -> unit do return mem.store_i64(addr: s, val: v) end
let st_sign = fn (s: i64) -> i64 do return mem.load_i64(addr: s + 8) end
let st_set_sign = fn (s: i64, v: i64) -> unit do return mem.store_i64(addr: s + 8, val: v) end
let st_mant = fn (s: i64) -> i64 do return mem.load_i64(addr: s + 16) end
let st_set_mant = fn (s: i64, v: i64) -> unit do return mem.store_i64(addr: s + 16, val: v) end
let st_dexp = fn (s: i64) -> i64 do return mem.load_i64(addr: s + 24) end
let st_set_dexp = fn (s: i64, v: i64) -> unit do return mem.store_i64(addr: s + 24, val: v) end
let st_flags = fn (s: i64) -> i64 do return mem.load_i64(addr: s + 32) end
let st_set_flags = fn (s: i64, v: i64) -> unit do return mem.store_i64(addr: s + 32, val: v) end
let st_saw_digit = fn (s: i64) -> bool do return (st_flags(s) & 1) != 0 end
let st_mark_digit = fn (s: i64) -> unit do return st_set_flags(s, v: st_flags(s) | 1) end
let st_bad = fn (s: i64) -> bool do return (st_flags(s) & 2) != 0 end
let st_mark_bad = fn (s: i64) -> unit do return st_set_flags(s, v: st_flags(s) | 2) end

/**
Accumulate one decimal digit `d` (0..9) into the mantissa, but stop growing
it past 18 digits -- excess integer digits bump `decexp` instead. `in_frac`
indicates we are past the '.', so accepted fraction digits lower `decexp`.
*/
let acc_digit = fn (s: i64, d: i64, in_frac: bool) -> unit do
  st_mark_digit(s)
  let m = st_mant(s)
  // 10^18 < 2^63 < 10^19; accept up to 18 digits into the mantissa.
  if m < 100000000000000000 then
    st_set_mant(s, v: (m * 10) + d)
    if in_frac then st_set_dexp(s, v: st_dexp(s) - 1) end
    return ()
  end
  // mantissa full: a dropped integer digit raises decexp; a dropped fraction
  // digit is simply ignored (its place value is already absorbed by mantissa).
  if !in_frac then st_set_dexp(s, v: st_dexp(s) + 1) end
  return ()
end

/** Scan the sign at `s.pos` over [base, base+len): sets st_sign, advances pos. */
let scan_sign = fn (s: i64, base: i64, len: i64) -> unit do
  let p = st_pos(s)
  if p >= len then return () end
  let c = byte_at_addr(base, i: p)
  if c == 45 then st_set_sign(s, v: 1) end
  if c == 45 || c == 43 then st_set_pos(s, v: p + 1) end
  return ()
end

/** Scan a run of digits from `s.pos`, feeding each to acc_digit(in_frac). */
let scan_digit_run = fn (s: i64, base: i64, len: i64, in_frac: bool) -> unit do
  let p = st_pos(s)
  if p >= len then return () end
  let c = byte_at_addr(base, i: p)
  if c < 48 || c > 57 then return () end
  acc_digit(s, d: c - 48, in_frac)
  st_set_pos(s, v: p + 1)
  return scan_digit_run(s, base, len, in_frac)
end

/**
Scan a plain (unsigned) decimal int from `s.pos` into `acc`; advance pos.
Returns the value; sets `saw` via the out word at `s + 32` is too coarse,
so callers check whether pos advanced. Caps the magnitude (exponent values
far past +-9999 are clamped to keep this i64).
*/
let scan_uint = fn (s: i64, base: i64, len: i64, acc: i64) -> i64 do
  let p = st_pos(s)
  if p >= len then return acc end
  let c = byte_at_addr(base, i: p)
  if c < 48 || c > 57 then return acc end
  st_set_pos(s, v: p + 1)
  let nacc = if acc > 100000 then acc else (acc * 10) + (c - 48) end
  return scan_uint(s, base, len, acc: nacc)
end

/** Skip trailing ASCII whitespace from `s.pos`. */
let skip_trailing_ws = fn (s: i64, base: i64, len: i64) -> unit do
  let p = st_pos(s)
  if p >= len then return () end
  if !is_ws(b: byte_at_addr(base, i: p)) then return () end
  st_set_pos(s, v: p + 1)
  return skip_trailing_ws(s, base, len)
end

/** True iff the 3 bytes at [base+p, base+p+3) are an ASCII match for "inf"/"nan". */
let three_eq = fn (base: i64, p: i64, len: i64, a: i64, b: i64, c: i64) -> bool do
  if p + 3 > len then return false end
  return lc(b: byte_at_addr(base, i: p)) == a && lc(b: byte_at_addr(base, i: p + 1)) == b && lc(b: byte_at_addr(base, i: p + 2)) == c
end

/**
Run the shared scan over [base, base+len): skips leading ws, sign, the
mantissa (digits, optional '.', digits), the optional exponent, then trailing
ws. Recognises "inf"/"nan" (case-insensitive) after the sign as a whole-token
match. Returns the scratch state `s`; the caller inspects st_bad / the final
pos (== len means well-formed). When "inf"/"nan" matched, mantissa is left 0
and a sentinel flag is encoded by setting decexp to a huge value (inf) -- but
to keep the contract simple, callers use `scan_special` separately.
*/
let run_scan = fn (base: i64, len: i64) -> i64 do
  let s = st_alloc()
  st_set_pos(s, v: 0)
  st_set_sign(s, v: 0)
  st_set_mant(s, v: 0)
  st_set_dexp(s, v: 0)
  st_set_flags(s, v: 0)
  // leading ws
  st_set_pos(s, v: skip_ws_go(base, len, i: 0))
  scan_sign(s, base, len)
  // int digits, optional '.', frac digits
  scan_digit_run(s, base, len, in_frac: false)
  let p0 = st_pos(s)
  if p0 < len && byte_at_addr(base, i: p0) == 46 then
    st_set_pos(s, v: p0 + 1)
    scan_digit_run(s, base, len, in_frac: true)
  end
  if !st_saw_digit(s) then st_mark_bad(s) end
  // optional exponent
  let pe = st_pos(s)
  if pe < len && (byte_at_addr(base, i: pe) == 101 || byte_at_addr(base, i: pe) == 69) then
    st_set_pos(s, v: pe + 1)
    // exponent sign
    let pe2 = st_pos(s)
    let esign = if pe2 < len && byte_at_addr(base, i: pe2) == 45 then 1 else 0 end
    if pe2 < len && (byte_at_addr(base, i: pe2) == 45 || byte_at_addr(base, i: pe2) == 43) then
      st_set_pos(s, v: pe2 + 1)
    end
    let pe3 = st_pos(s)
    let eval = scan_uint(s, base, len, acc: 0)
    if st_pos(s) == pe3 then
      // 'e' with no digits after -> malformed
      st_mark_bad(s)
    else
      let signed_e = if esign == 1 then 0 - eval else eval end
      st_set_dexp(s, v: st_dexp(s) + signed_e)
    end
  end
  skip_trailing_ws(s, base, len)
  return s
end

/**
Detect a leading [+-]? "inf"/"infinity"/"nan" token (case-insensitive),
possibly surrounded by whitespace. Returns: 0 = not special, 1 = +inf,
2 = -inf, 3 = nan. Anything trailing the token (other than ws) -> 0.
*/
let scan_special = fn (base: i64, len: i64) -> i64 do
  let p0 = skip_ws_go(base, len, i: 0)
  let sign = if p0 < len && byte_at_addr(base, i: p0) == 45 then 1 else 0 end
  let p1 = if p0 < len && (byte_at_addr(base, i: p0) == 45 || byte_at_addr(base, i: p0) == 43) then p0 + 1 else p0 end
  // "inf" (optionally "inity")
  if three_eq(base, p: p1, len, a: 105, b: 110, c: 102) then
    let after = if p1 + 8 <= len && lc(b: byte_at_addr(base, i: p1 + 3)) == 105 && lc(b: byte_at_addr(base, i: p1 + 4)) == 110 && lc(b: byte_at_addr(base, i: p1 + 5)) == 105 && lc(b: byte_at_addr(base, i: p1 + 6)) == 116 && lc(b: byte_at_addr(base, i: p1 + 7)) == 121 then p1 + 8 else p1 + 3 end
    let tail = skip_ws_go(base, len, i: after)
    if tail != len then return 0 end
    return if sign == 1 then 2 else 1 end
  end
  // "nan"
  if three_eq(base, p: p1, len, a: 110, b: 97, c: 110) then
    let tail = skip_ws_go(base, len, i: p1 + 3)
    if tail != len then return 0 end
    return 3
  end
  return 0
end

// --- Eisel-Lemire: correctly-rounded decimal-significand -> f64 ---
//
// The scanner hands us an integer significand `w` (st_mant, up to 18 decimal
// digits, so w < 10^18 < 2^60) and a base-10 exponent `q` (st_dexp). The naive
// `i64_to_float(w) *. pow10(q)` path truncates w's dropped low bits AND inherits
// pow10's per-exponent reciprocal error, so 17-digit inputs land 1-2 ULP off.
//
// Eisel-Lemire instead multiplies the normalised 64-bit significand by a
// precomputed 128-bit approximation of 10^q (the pow5_table module) using a
// 64x64->128 multiply, reads the rounded mantissa straight out of the high
// limb, and returns the bit-exact round-to-nearest-even result -- or a sentinel
// (-1) for the small set of genuinely-ambiguous halfway / out-of-range inputs,
// where we fall back to the legacy multiply path (preserving its behaviour, so
// no previously-correct value can regress).

/** Logical (zero-filling) right shift by n in [0, 63]. */
let lshr = fn (v: i64, n: i64) -> i64 do
  if n == 0 then return v end
  let shifted = v >> n
  let mask = (1 << (63 - n)) - 1 + (1 << (63 - n))
  return shifted & mask
end

/** Unsigned high 64 bits of a*b (a, b read as unsigned 64-bit bit patterns). */
let umulh = fn (a: i64, b: i64) -> i64 do
  let m32 = (1 << 32) - 1
  let a_lo = a & m32
  let a_hi = lshr(v: a, n: 32)
  let b_lo = b & m32
  let b_hi = lshr(v: b, n: 32)
  let ll = a_lo * b_lo
  let lh = a_lo * b_hi
  let hl = a_hi * b_lo
  let hh = a_hi * b_hi
  let ll_hi = lshr(v: ll, n: 32)
  let cross = (lh & m32) + (hl & m32) + ll_hi
  let cross_hi = lshr(v: cross, n: 32)
  return hh + lshr(v: lh, n: 32) + lshr(v: hl, n: 32) + cross_hi
end

/** Unsigned a <u b for i64 bit patterns (flip the sign bit, compare signed). */
let ult = fn (a: i64, b: i64) -> bool do
  let mn = 1 << 63
  return (a + mn) < (b + mn)
end

/** Leading-zero count of a non-zero unsigned 64-bit value. */
let clz64 = fn (w: i64) -> i64 do return clz64_go(w, i: 63, n: 0) end
let clz64_go = fn (w: i64, i: i64, n: i64) -> i64 do
  if i < 0 then return n end
  if (lshr(v: w, n: i) & 1) == 1 then return n end
  return clz64_go(w, i: i - 1, n: n + 1)
end

/** Sentinel returned by `eisel_lemire` to request the legacy fallback path.
 * Safe because every real EL result is a positive f64 magnitude in [0, 2^63). */
let el_fallback = fn () -> i64 do return 0 - 1 end

/**
Eisel-Lemire decimal->f64. `w0` is the integer significand (unsigned, < 2^63),
`q` the base-10 exponent. Returns the IEEE-754 bit pattern of the
correctly-rounded *positive* magnitude `w0 * 10^q`, or `el_fallback()` (-1) for
underflow/overflow/halfway-ambiguous inputs the caller must handle via the
legacy path. (Subnormal results -> fallback; the legacy path's subnormal
handling is a separate, pre-existing limitation, out of scope here.)
*/
let eisel_lemire = fn (w0: i64, q: i64) -> i64 do
  if w0 == 0 then return 0 end
  if q < pow5_qmin() then return 0 end
  if q > pow5_qmax() then return el_fallback() end
  let lz = clz64(w: w0)
  let w = w0 << lz
  let power2 = ((217706 * q) >> 16) + 1086 - lz
  let hi_t = pow5_hi(q)
  let lo_t = pow5_lo(q)
  let hi1 = umulh(a: w, b: hi_t)
  let lo1 = w * hi_t
  // The product's low 9 bits being all-ones means the second 64-bit limb of the
  // 10^q approximation could perturb the rounding boundary; fold it in.
  let need2 = (hi1 & 511) == 511
  let hi2p = if need2 then umulh(a: w, b: lo_t) else 0 end
  let merged_lo = if need2 then lo1 + hi2p else lo1 end
  let carry = if need2 && ult(a: merged_lo, b: lo1) then 1 else 0 end
  let hi = hi1 + carry
  let lo = merged_lo
  let lo2 = if need2 then w * lo_t else 0 end
  // Truly ambiguous (both limbs saturate): defer to the slow path.
  let ambiguous = need2 && (hi & 511) == 511 && lo == (0 - 1) && lo2 == (0 - 1)
  if ambiguous then return el_fallback() end
  let upperbit = lshr(v: hi, n: 63)
  let mantissa0 = lshr(v: hi, n: upperbit + 9)
  let p2 = power2 + upperbit
  if p2 <= 0 then return el_fallback() end
  if p2 >= 2047 then return el_fallback() end
  // Exact halfway (round-to-even): low limb zero, dropped high bits zero, and the
  // kept mantissa is odd -- the legacy/slow path resolves the tie.
  let low_mask = (1 << (upperbit + 9)) - 1
  let halfway = lo == 0 && (hi & low_mask) == 0 && (mantissa0 & 3) == 1
  if halfway then return el_fallback() end
  let mantissa1 = mantissa0 + (mantissa0 & 1)
  let mantissa2 = lshr(v: mantissa1, n: 1)
  let two53 = 1 << 53
  let mantissa3 = if mantissa2 >= two53 then (1 << 52) else mantissa2 end
  let p2b = if mantissa2 >= two53 then p2 + 1 else p2 end
  if p2b >= 2047 then return el_fallback() end
  let mant52 = mantissa3 & ((1 << 52) - 1)
  return (p2b << 52) + mant52
end

/**
Legacy fallback: i64_to_float(w) *. pow10(q). Truncates w's low bits and
inherits pow10 rounding error, so it is only correct for inputs Eisel-Lemire
declines (out-of-range / ambiguous halfway); kept verbatim so no value that
previously parsed correctly through this path can change.
*/
let assemble_legacy = fn (s: i64) -> float do
  let mant_f = i64_to_float(val: st_mant(s))
  let scaled = mant_f *. pow10(n: st_dexp(s))
  if st_sign(s) == 1 then return f0() -. scaled else return scaled end
end

/** Combine a scan-state into an f64 (Eisel-Lemire, legacy fallback on -1). */
let assemble_f64 = fn (s: i64) -> float do
  let bits = eisel_lemire(w0: st_mant(s), q: st_dexp(s))
  if bits == el_fallback() then return assemble_legacy(s) end
  let mag = reinterpret_to_f64(bits)
  if st_sign(s) == 1 then return f0() -. mag else return mag end
end

/**
Parse [a_s_ptr, a_s_ptr+b_s_len) as an f64. Whitespace-tolerant; accepts
the usual `[+-]?(digits('.'digits?)?|'.'digits)([eE][+-]?digits)?` grammar
plus case-insensitive `inf`/`infinity`/`nan`. Returns 0.0 on a malformed
string (callers gate with `string_is_valid_f64`).
*/
export let string_to_f64 = fn (a_s_ptr: i32, b_s_len: i32) -> float do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  if len <= 0 then return f0() end
  let sp = scan_special(base, len)
  if sp == 1 then return pow10_pos(n: 400) end
  if sp == 2 then return f0() -. pow10_pos(n: 400) end
  if sp == 3 then return fnan() end
  let s = run_scan(base, len)
  if st_bad(s) || st_pos(s) != len then return f0() end
  return assemble_f64(s)
end

/**
True iff [a_s_ptr, a_s_ptr+b_s_len) is a syntactically valid f64 literal
(per the grammar above, including `inf`/`nan`).
*/
export let string_is_valid_f64 = fn (a_s_ptr: i32, b_s_len: i32) -> bool do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  if len <= 0 then return false end
  if scan_special(base, len) != 0 then return true end
  let s = run_scan(base, len)
  return !st_bad(s) && st_pos(s) == len && st_saw_digit(s)
end

// --- dtoa: f64 -> shortest-ish decimal string ---
//
// Not a Grisu/Ryu shortest-representation algorithm: extracts ~17 significant
// decimal digits, trims trailing zeros, and picks fixed vs. scientific notation
// by the decimal exponent. Round-trips for the values that matter; the textual
// form may differ from Rust's `f64::to_string` for some inputs.

/** IEEE-754 field accessors on an f64's bit pattern. */
let f_sign_bit = fn (bits: i64) -> i64 do
  // logical >> 63
  let sh = bits >> 63
  return sh & 1
end
let f_raw_exp = fn (bits: i64) -> i64 do return (bits >> 52) & 2047 end
let f_frac = fn (bits: i64) -> i64 do return bits & ((1 << 52) - 1) end

/**
ln(2) and ln(10), as f64 (built bit-wise via to_f64 of their text -- but
that recurses through this module; instead use the literal mantissa form).
*/
let ln10_f = fn () -> float do
  // 2.302585092994046 = 2302585092994046 * 10^-15
  return i64_to_float(val: 2302585092994046) *. pow10(n: 0 - 15)
end
let ln2_f = fn () -> float do
  // 0.6931471805599453 = 6931471805599453 * 10^-16
  return i64_to_float(val: 6931471805599453) *. pow10(n: 0 - 16)
end
let sqrt2_f = fn () -> float do
  return i64_to_float(val: 14142135623730951) *. pow10(n: 0 - 16)
end

/** floor(x) for f64, via truncation toward zero adjusted for negatives. */
let floorf = fn (x: float) -> float do
  let t = i64_to_float(val: float_to_i64(val: x))
  if t >. x then return t -. f1() else return t end
end

/** ln(x) for x > 0 (atanh series after the m*2^k decomposition). */
let lnf = fn (x: float) -> float do
  if x <=. f0() then return f0() end
  let bits = reinterpret_to_i64(x)
  let k0 = f_raw_exp(bits) - 1023
  let m_bits = f_frac(bits) | (1023 << 52)
  let m0 = reinterpret_to_f64(bits: m_bits)
  let split = m0 >. sqrt2_f()
  let m = if split then m0 /. i64_to_float(val: 2) else m0 end
  let k = if split then k0 + 1 else k0 end
  let t = (m -. f1()) /. (m +. f1())
  let t2 = t *. t
  let t3 = t2 *. t
  let t5 = t3 *. t2
  let t7 = t5 *. t2
  let t9 = t7 *. t2
  let series = t +. (t3 /. i64_to_float(val: 3)) +. (t5 /. i64_to_float(val: 5)) +. (t7 /. i64_to_float(val: 7)) +. (t9 /. i64_to_float(val: 9))
  return (i64_to_float(val: k) *. ln2_f()) +. (i64_to_float(val: 2) *. series)
end
/** log10(x) for x > 0. */
let log10f = fn (x: float) -> float do return lnf(x) /. ln10_f() end

/**
Write up to 17 significant decimal digits of `m` (m in [1, 10)) into the
byte buffer `dst`; returns the count of digits written (always 17). The
last digit may be slightly off; trailing zeros are trimmed by the caller.
*/
let extract_digits = fn (m: float, dst: i64, i: i64, n: i64) -> i64 do
  if i >= n then return n end
  let d = float_to_i64(val: floorf(x: m))
  let dd = if d < 0 then 0 else if d > 9 then 9 else d end
  mem.store_u8(addr: dst + i, val: 48 + dd)
  let m2 = (m -. i64_to_float(val: dd)) *. f10()
  return extract_digits(m: m2, dst, i: i + 1, n)
end

/** Find the last index in [0, n) that is non-'0' in [dst, dst+n); -1 if all '0'. */
let last_nonzero = fn (dst: i64, n: i64, i: i64) -> i64 do
  if i < 0 then return 0 - 1 end
  if mem.load_u8(addr: dst + i) != 48 then return i end
  return last_nonzero(dst, n, i: i - 1)
end

/**
Round the digit string at [dst, dst+nd): `next_digit` is the ASCII byte of
the first dropped digit ('0'..'9'). Rounds half-up; a carry may propagate
past the most significant digit, in which case the digits become "100..0"
and the returned exponent is `exp + 1` (else `exp` unchanged).
*/
let round_digits = fn (dst: i64, nd: i64, next_digit: i64, exp: i64) -> i64 do
  if next_digit < 53 then return exp end
  return round_carry(dst, i: nd - 1, exp)
end
let round_carry = fn (dst: i64, i: i64, exp: i64) -> i64 do
  if i < 0 then
    // carry past the most significant digit: shift right, leading '1'.
    mem.store_u8(addr: dst, val: 49)
    return exp + 1
  end
  let v = mem.load_u8(addr: dst + i)
  if v == 57 then
    mem.store_u8(addr: dst + i, val: 48)
    return round_carry(dst, i: i - 1, exp)
  end
  mem.store_u8(addr: dst + i, val: v + 1)
  return exp
end

/** Write n '0' bytes at dst. */
let fill_zeros = fn (dst: i64, n: i64) -> unit do
  if n <= 0 then return () end
  mem.store_u8(addr: dst, val: 48)
  return fill_zeros(dst: dst + 1, n: n - 1)
end

/** If `neg`, write '-' at p[0] and return 1; else return 0. */
let neg_prefix = fn (p: i64, neg: bool) -> i64 do
  if neg then
    mem.store_u8(addr: p, val: 45)
    return 1
  end
  return 0
end

/** Write the decimal digits of v (>= 0) to dst, MSD first; return the count. */
let write_uint_digits = fn (v: i64, dst: i64) -> i64 do
  if v == 0 then
    mem.store_u8(addr: dst, val: 48)
    return 1
  end
  let nd = count_digits(v, n: 0)
  write_digits_pos(v, dst, i: nd - 1)
  return nd
end

/** Body length of a fixed-notation rendering of `nd` digits at exponent `e`. */
let fixed_body_len = fn (nd: i64, e: i64) -> i64 do
  if e >= 0 then
    if e + 1 >= nd then return e + 1 end
    return nd + 1
  end
  return 2 + (0 - e - 1) + nd
end

/**
Emit a fixed-notation rendering of `nd` digits at `digs` with decimal
exponent `e` (value = D[0].D[1..] * 10^e); return packed (ptr<<32)|len.
e >= 0 puts the point inside or after the digits (zero-padding past nd);
e < 0 renders "0." then (-e-1) zeros then the digits. `neg` prepends '-'.
*/
let render_fixed = fn (digs: i64, nd: i64, e: i64, neg: bool) -> i64 do
  let body_len = fixed_body_len(nd, e)
  let total = if neg then body_len + 1 else body_len end
  let p = alloc_bytes(n: total)
  let off0 = neg_prefix(p, neg)
  if e >= 0 then
    if e + 1 >= nd then
      copy_bytes(dst: p + off0, src: digs, count: nd)
      fill_zeros(dst: p + off0 + nd, n: e + 1 - nd)
      return pack(ptr: p, len: total)
    end
    copy_bytes(dst: p + off0, src: digs, count: e + 1)
    mem.store_u8(addr: p + off0 + e + 1, val: 46)
    copy_bytes(dst: p + off0 + e + 2, src: digs + e + 1, count: nd - e - 1)
    return pack(ptr: p, len: total)
  end
  mem.store_u8(addr: p + off0, val: 48)
  mem.store_u8(addr: p + off0 + 1, val: 46)
  let nz = 0 - e - 1
  fill_zeros(dst: p + off0 + 2, n: nz)
  copy_bytes(dst: p + off0 + 2 + nz, src: digs, count: nd)
  return pack(ptr: p, len: total)
end

/** Emit scientific notation: ('-')? D[0] ('.' D[1..])? 'e' ('-')? exp-digits. */
let render_sci = fn (digs: i64, nd: i64, e: i64, neg: bool) -> i64 do
  let eabs = if e < 0 then 0 - e else e end
  let edigs_p = alloc_bytes(n: 8)
  let en = write_uint_digits(v: eabs, dst: edigs_p)
  let frac_n = nd - 1
  let dot_part = if frac_n > 0 then 1 + frac_n else 0 end
  let esign_part = if e < 0 then 1 else 0 end
  let body_len = 1 + dot_part + 1 + esign_part + en
  let total = if neg then body_len + 1 else body_len end
  let p = alloc_bytes(n: total)
  let off0 = neg_prefix(p, neg)
  mem.store_u8(addr: p + off0, val: mem.load_u8(addr: digs))
  let after_d = render_sci_frac(p, at: off0 + 1, digs, frac_n)
  mem.store_u8(addr: p + after_d, val: 101)
  let after_e = render_sci_esign(p, at: after_d + 1, e)
  copy_bytes(dst: p + after_e, src: edigs_p, count: en)
  return pack(ptr: p, len: total)
end
/** Write ('.' digs[1..frac_n+1])? at p+at; return the offset just past it. */
let render_sci_frac = fn (p: i64, at: i64, digs: i64, frac_n: i64) -> i64 do
  if frac_n <= 0 then return at end
  mem.store_u8(addr: p + at, val: 46)
  copy_bytes(dst: p + at + 1, src: digs + 1, count: frac_n)
  return at + 1 + frac_n
end
/** Write ('-')? at p+at when e < 0; return the offset just past it. */
let render_sci_esign = fn (p: i64, at: i64, e: i64) -> i64 do
  if e >= 0 then return at end
  mem.store_u8(addr: p + at, val: 45)
  return at + 1
end

/**
Write the bytes of the literal `txt` (a sequence of byte values) into a
fresh n-byte allocation; return packed. Used for the nan/inf/0 names.
*/
let small_str3 = fn (a: i64, b: i64, c: i64) -> i64 do
  let p = alloc_bytes(n: 3)
  store_at(a: p, v: a)
  store_at(a: p + 1, v: b)
  store_at(a: p + 2, v: c)
  return pack(ptr: p, len: 3)
end

/** Parse the first `k` decimal digits at [digs, digs+k) as an i64. */
let digits_to_int = fn (
  digs: i64,
  k: i64
) -> i64 do return digits_to_int_go(digs, k, i: 0, acc: 0) end
let digits_to_int_go = fn (digs: i64, k: i64, i: i64, acc: i64) -> i64 do
  if i >= k then return acc end
  return digits_to_int_go(digs, k, i: i + 1, acc: (acc * 10) + (mem.load_u8(addr: digs + i) - 48))
end

/**
Reconstruct the f64 magnitude denoted by the integer significand `m_int`
(>= 0, < 2^63) scaled by `10^q`, and compare it bit-exactly to `mag`.

This mirrors the PARSE side: `string_to_f64` of the decimal "m_int * 10^q"
produces exactly `eisel_lemire(m_int, q)` (or the legacy multiply when EL
declines). So formatting round-trips iff this reconstruction equals `mag`'s
bits. Using Eisel-Lemire here -- instead of the legacy `i64_to_float * pow10`
-- is what makes low-magnitude normals (down to DBL_MIN) round-trip: the
reciprocal `pow10(q)` for very negative q accumulates several ULPs, so the
float-multiply reconstruction never matched `mag` and the shortest-prefix
search fell through to an inaccurate 17-digit path. We keep the legacy
multiply as the comparison only when EL returns its sentinel, so no value
that previously matched can regress.
*/
let recon_bits = fn (m_int: i64, q: i64) -> i64 do
  let el = eisel_lemire(w0: m_int, q)
  if el != el_fallback() then return el end
  // EL declined (out-of-range / ambiguous): mirror assemble_legacy's recipe.
  let recon = i64_to_float(val: m_int) *. pow10(n: q)
  return reinterpret_to_i64(x: recon)
end
/** True iff `m_int * 10^q` reconstructs bit-exactly to the magnitude `mag`. */
let recon_eq_mag = fn (m_int: i64, q: i64, mag: float) -> bool do
  return recon_bits(m_int, q) == reinterpret_to_i64(x: mag)
end
/** |x| for f64. */
let absf = fn (x: float) -> float do if x <. f0() then return f0() -. x else return x end end

/**
Correct a 17-digit decimal significand so it round-trips to `mag` bit-exactly,
choosing the *canonical* (nearest-to-the-true-value) significand among those
that round-trip.

The initial significand `m0` comes from extracting digits of `m = mag/pow10(e)`,
whose scaling `pow10(e)` is a few ULPs off for very negative `e`; `m0` can be a
handful of units from the value that actually round-trips (observed up to ~10
near DBL_MIN). The significands `c` whose Eisel-Lemire reconstruction `c*10^q`
equals `mag`'s bits form a contiguous run; the one we want is the one nearest the
real value of `mag` (so f64::MAX prints 17976931348623157, not ...158, even
though both round-trip). We scan a bounded window around `m0`, keep every
round-tripping candidate, and pick the one minimising the legacy-product distance
|i64_to_float(c)*pow10(q) - mag| (ties -> smaller c). That product is itself
imprecise, but only ever has to discriminate between adjacent integer
significands, whose true values differ by a full 10^q -- far above the product's
error -- so the choice is reliable; near DBL_MIN, where the product underflows to
0, only a single candidate round-trips anyway. Returns the chosen significand, or
`el_fallback()` (-1) when none in the window round-trips (caller keeps legacy).
*/
let correct_significand = fn (m0: i64, q: i64, mag: float) -> i64 do
  let target = reinterpret_to_i64(x: mag)
  return correct_search(m0, q, target, mag, d: 0, best: el_fallback(), best_dist: f0())
end
let correct_search = fn (
  m0: i64,
  q: i64,
  target: i64,
  mag: float,
  d: i64,
  best: i64,
  best_dist: float
) -> i64 do
  if d > 64 then return best end
  // Consider m0-d (when d>0) then m0+d; smaller-c first so ties favour it.
  let lo = m0 - d
  let s1 = if d > 0 && lo > 0 && eisel_lemire(w0: lo, q) == target then consider(c: lo, q, mag, best, best_dist) else pack_best(best, best_dist) end
  let b1 = unpack_c(s1)
  let bd1 = unpack_d(s1)
  let hi = m0 + d
  let s2 = if eisel_lemire(w0: hi, q) == target then consider(c: hi, q, mag, best: b1, best_dist: bd1) else pack_best(b1, bd1) end
  return correct_search(m0, q, target, mag, d: d + 1, best: unpack_c(s2), best_dist: unpack_d(s2))
end
// Helpers to thread (best_c, best_dist) through the scan via a 16-byte scratch
// block, since Nexus `let` bindings can't return a tuple here.
let consider = fn (c: i64, q: i64, mag: float, best: i64, best_dist: float) -> i64 do
  let dist = absf(x: (i64_to_float(val: c) *. pow10(n: q)) -. mag)
  if best == el_fallback() || dist <. best_dist then return pack_best(c, dist) end
  return pack_best(best, best_dist)
end
let scratch_bc = fn () -> i64 do return arena.alloc_raw(size: 16) end
let pack_best = fn (c: i64, dist: float) -> i64 do
  let p = scratch_bc()
  mem.store_i64(addr: p, val: c)
  mem.store_f64(addr: p + 8, val: dist)
  return p
end
let unpack_c = fn (p: i64) -> i64 do return mem.load_i64(addr: p) end
let unpack_d = fn (p: i64) -> float do return mem.load_f64(addr: p + 8) end

/**
Safety clamp for the 17-digit fallback path: if the nd-digit string at `digs`
with decimal exponent `e_after` reconstructs to a value strictly greater than
`mag`, decrement the last non-zero digit and retry.
This handles the case where accumulated pow10 rounding error inflates `m` and
pushes the 17th digit one (or two) too high -- ensuring `from_float(finite x)`
never formats to a string that reparses to +inf or to a larger value.
Returns the adjusted exponent (may increase by 1 if clamp triggers a carry-off,
but in practice the carry cannot push a finite value to a larger exponent here).
*/
let clamp_digits_to_mag = fn (digs: i64, nd: i64, e_after: i64, mag: float) -> i64 do
  // Reconstruct the value: digits_to_int(digs, nd) * 10^(e_after - (nd-1))
  let m_int = digits_to_int(digs, k: nd)
  let recon = i64_to_float(val: m_int) *. pow10(n: e_after - (nd - 1))
  // If reconstruction is <= mag, digits are fine (common case).
  if !(recon >. mag) then return e_after end
  // Reconstruction exceeds mag: decrement the last non-zero digit.
  // Walk from the rightmost digit backwards to find the first non-'0'.
  return clamp_decrement(digs, nd, e_after, mag, i: nd - 1)
end
let clamp_decrement = fn (digs: i64, nd: i64, e_after: i64, mag: float, i: i64) -> i64 do
  if i < 0 then
    // All digits are '0' after decrement -- shouldn't happen for a finite mag > 0.
    return e_after
  end
  let v = mem.load_u8(addr: digs + i)
  if v == 48 then
    // This digit is '0'; skip it and try the next one left.
    return clamp_decrement(digs, nd, e_after, mag, i: i - 1)
  end
  if v == 49 then
    // Decrement '1' -> '0': zero out this digit, trim nd by 1 (the last 0 will
    // be dropped by last_nonzero later), and recurse to re-check.
    mem.store_u8(addr: digs + i, val: 48)
    return clamp_digits_to_mag(digs, nd: i, e_after, mag)
  end
  // Decrement safely: v in '2'..'9' -> v-1.
  mem.store_u8(addr: digs + i, val: v - 1)
  return clamp_digits_to_mag(digs, nd, e_after, mag)
end

/**
Find the fewest leading digits (1..maxk, maxk <= 15) whose value, rounded
at the next digit, reconstructs `mag` bit-exactly (using the same
i64_to_float * pow10 recipe `assemble_f64` uses for parsing). Writes the
chosen digits into `out` (which may pick up a rounding carry, shifting the
exponent), and returns the (count << 8) | (1 if the exponent grew) -- the
caller adds the bump to `e`. Returns 0 if nothing in range matched.
*/
let shortest_digits = fn (digs: i64, e: i64, mag: float, out: i64) -> i64 do
  return shortest_go(digs, e, mag, out, k: 1)
end
let shortest_go = fn (digs: i64, e: i64, mag: float, out: i64, k: i64) -> i64 do
  if k > 15 then return 0 end
  // copy first k digits to out, round at digit[k]
  copy_bytes(dst: out, src: digs, count: k)
  let next_d = mem.load_u8(addr: digs + k)
  let e_bumped = round_digits(dst: out, nd: k, next_digit: next_d, exp: 0)
  let m_int = digits_to_int(digs: out, k)
  // reconstruct: m_int has k digits, value = m_int * 10^(e + e_bumped - (k-1))
  if recon_eq_mag(m_int, q: e + e_bumped - (k - 1), mag) then return (k * 256) + e_bumped end
  return shortest_go(digs, e, mag, out, k: k + 1)
end

/**
Write the `nd` decimal digits of `v` (>= 0, having exactly `nd` digits) MSD-first
into [dst, dst+nd).
*/
let write_n_digits = fn (v: i64, dst: i64, nd: i64) -> unit do
  write_digits_pos(v, dst, i: nd - 1)
  return ()
end

/**
Restore a 17-digit significand `v` into `raw[0..17)` (used to undo an
over-eager legacy clamp that broke round-trip); return the unchanged exponent.
`v` is the pre-clamp 17-digit integer (digit count exactly 17), so a fixed
17-digit write reinstates the original digits.
*/
let restore_pre_clamp = fn (raw: i64, v: i64, e: i64) -> i64 do
  write_n_digits(v, dst: raw, nd: 17)
  return e
end

/**
Snap the 18-digit estimate at `raw` onto the significand that round-trips to
`mag`, rewriting `raw` in place; return the adjusted decimal exponent `e`.

`raw[0..18)` holds the digits of `m = mag/pow10(e)` (value ~ raw * 10^(e-17)).
We form the rounded 17-digit significand `m17` (value m17 * 10^(e-16)), correct
it via Eisel-Lemire (`correct_significand`), then re-lay the corrected digits
back into `raw` so the downstream shortest-prefix / 17-digit paths operate on a
round-tripping digit string. If the corrector declines (window miss / EL out of
range) `raw` and `e` are left untouched so the legacy clamp path still applies.
*/
let correct_raw_digits = fn (raw: i64, e: i64, mag: float) -> i64 do
  // Round the 17-digit significand at digit[17].
  let base17 = digits_to_int(digs: raw, k: 17)
  let m17 = if mem.load_u8(addr: raw + 17) >= 53 then base17 + 1 else base17 end
  // value(m17) = m17 * 10^(e - 16)
  let q = e - 16
  // If m17 already round-trips, leave the digits untouched: the extraction is
  // accurate at mid/high magnitudes, so m17 is the good estimate the downstream
  // shortest-prefix search and (round-trip-aware) legacy clamp expect. We only
  // snap when m17 fails to round-trip -- the low-magnitude regime where pow10's
  // reciprocal error pushed the estimate off the value entirely (e.g. DBL_MIN,
  // whose legacy rendering reparsed to 0).
  if recon_eq_mag(m_int: m17, q, mag) then return e end
  // Snap to the nearest round-tripping significand (canonical among the few that
  // round-trip here). Declines (-1) leave raw/e for the legacy path.
  let cand = correct_significand(m0: m17, q, mag)
  if cand == el_fallback() then return e end
  // Re-lay `cand` (which has 17 digits, or 18 after a 99..9 -> 10..0 carry) into
  // raw. nc = digit count of cand; the MSD sits at decimal exponent e+(nc-17).
  let nc = count_digits(v: cand, n: 0)
  let enew = e + (nc - 17)
  // Write up to 18 digits of cand; pad the rest of the 18-slot buffer with '0'.
  let wn = if nc > 18 then 18 else nc end
  write_n_digits(v: cand, dst: raw, nd: wn)
  fill_zeros(dst: raw + wn, n: 18 - wn)
  return enew
end

/**
Render an f64 to a decimal string. `0.0` -> "0"; `-0.0` -> "-0" (the IEEE
sign is preserved). NaN -> "nan"; +-inf -> "inf"/"-inf". Exact integers
below 2^53 print without a decimal point. Otherwise: the shortest leading
digit string (<= 15 digits) that round-trips is used when one exists, else
a 17-digit extraction with trailing zeros trimmed. Fixed notation for
decimal exponents in [-4, 17), scientific notation outside.
*/
export let string_from_float = fn (a_val: float) -> i64 do
  let bits = reinterpret_to_i64(x: a_val)
  let neg = f_sign_bit(bits) == 1
  let raw_e = f_raw_exp(bits)
  if raw_e == 2047 then
    if f_frac(bits) != 0 then return small_str3(a: 110, b: 97, c: 110) end
    if neg then
      let p = alloc_bytes(n: 4)
      store_at(a: p, v: 45)
      store_at(a: p + 1, v: 105)
      store_at(a: p + 2, v: 110)
      store_at(a: p + 3, v: 102)
      return pack(ptr: p, len: 4)
    end
    return small_str3(a: 105, b: 110, c: 102)
  end
  if raw_e == 0 && f_frac(bits) == 0 then
    if neg then
      let p = alloc_bytes(n: 2)
      store_at(a: p, v: 45)
      store_at(a: p + 1, v: 48)
      return pack(ptr: p, len: 2)
    end
    let p = alloc_bytes(n: 1)
    store_at(a: p, v: 48)
    return pack(ptr: p, len: 1)
  end
  let mag = if neg then f0() -. a_val else a_val end
  // Exact integer? Print without a decimal point via from_i64.
  // Guard raw_e < 1086 (unbiased exp < 63) to ensure mag < 2^63 fits in i64;
  // the round-trip i64_to_float(as_int)==mag then catches all exact integers
  // in that range (including values >= 2^53 where ulp >= 1).
  if raw_e < 1086 then
    let as_int = float_to_i64(val: mag)
    if i64_to_float(val: as_int) ==. mag then
      if neg then return string_from_i64(a_val: 0 - as_int) end
      return string_from_i64(a_val: as_int)
    end
  end
  // Decimal exponent estimate, then up to two 1-step corrections so the
  // normalised mantissa lands in [1, 10).
  let e0 = float_to_i64(val: floorf(x: log10f(x: mag)))
  let m0 = mag /. pow10(n: e0)
  let e1 = if m0 >=. f10() then e0 + 1 else if m0 <. f1() then e0 - 1 else e0 end
  let m1 = mag /. pow10(n: e1)
  let e = if m1 >=. f10() then e1 + 1 else if m1 <. f1() then e1 - 1 else e1 end
  let m = mag /. pow10(n: e)
  // Extract 18 digits.
  let raw = alloc_bytes(n: 24)
  extract_digits(m, dst: raw, i: 0, n: 18)
  // The digit-extraction scaling pow10(e) is a few ULPs off for very negative e,
  // so the raw significand can be several units away from the value that actually
  // round-trips (notably near DBL_MIN, where the legacy path emitted a string the
  // parser maps to 0). Snap the 17-digit significand onto the exact round-tripping
  // value via Eisel-Lemire before the shortest-prefix search runs on those digits.
  let e2 = correct_raw_digits(raw, e, mag)
  let e = e2
  // Try the shortest round-tripping prefix; fall back to a rounded 17 digits.
  let chosen = alloc_bytes(n: 24)
  let sh = shortest_digits(digs: raw, e, mag, out: chosen)
  if sh != 0 then
    let k = sh / 256
    let e_after = e + (sh & 255)
    let lnz = last_nonzero(dst: chosen, n: k, i: k - 1)
    let nd = if lnz < 0 then 1 else lnz + 1 end
    if e_after >= 0 - 4 && e_after < 17 then return render_fixed(
      digs: chosen,
      nd,
      e: e_after,
      neg
    ) end
    return render_sci(digs: chosen, nd, e: e_after, neg)
  end
  let next_digit = mem.load_u8(addr: raw + 17)
  let e_after0 = round_digits(dst: raw, nd: 17, next_digit, exp: e)
  // Safety clamp: if pow10 accumulated rounding error inflated the 17th digit
  // so that the formatted value would exceed `mag` (e.g. f64::MAX → "...159e308"
  // which reparses to +inf), decrement the last digit until recon <= mag. The
  // clamp's legacy i64_to_float*pow10 comparison is itself imprecise, so it can
  // over-decrement a significand that was already exact (breaking round-trip at
  // mid magnitudes / near DBL_MIN). Snapshot the pre-clamp significand, run the
  // clamp, and only keep its result if the clamped digits still round-trip
  // bit-exactly; otherwise restore the pre-clamp digits.
  let pre_clamp = digits_to_int(digs: raw, k: 17)
  let pre_clamp_rt = recon_eq_mag(m_int: pre_clamp, q: e_after0 - 16, mag)
  let e_clamped = clamp_digits_to_mag(digs: raw, nd: 17, e_after: e_after0, mag)
  let clamped = digits_to_int(digs: raw, k: 17)
  let clamp_rt = recon_eq_mag(m_int: clamped, q: e_clamped - 16, mag)
  // Restore the pre-clamp digits only when the clamp turned a round-tripping
  // significand into a non-round-tripping one (its imprecise comparison misfired).
  let revert = pre_clamp_rt && !clamp_rt
  let e_after = if revert then restore_pre_clamp(raw, v: pre_clamp, e: e_after0) else e_clamped end
  let lnz = last_nonzero(dst: raw, n: 17, i: 16)
  let nd = if lnz < 0 then 1 else lnz + 1 end
  if e_after >= 0 - 4 && e_after < 17 then return render_fixed(digs: raw, nd, e: e_after, neg) end
  return render_sci(digs: raw, nd, e: e_after, neg)
end

/**
Return the raw 8-byte IEEE-754 bit pattern of the f64 parsed from
[a_s_ptr, a_s_ptr+b_s_len) as an i64 (used by bytebuffer's push_f64_str_le).
*/
export let f64_str_bits = fn (a_s_ptr: i32, b_s_len: i32) -> i64 do
  return reinterpret_to_i64(x: string_to_f64(a_s_ptr, b_s_len))
end
