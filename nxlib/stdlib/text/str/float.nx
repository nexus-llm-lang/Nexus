/**
 * str/float: f64 <-> string conversion (import façade).
 *
 * The implementation is split into two domain-orthogonal halves over a shared
 * core:
 *   - `text/str/float_core`   -- bit-pattern constants, the `pow10` family, and
 *                                the Eisel-Lemire decimal->f64 core (both halves
 *                                depend on it).
 *   - `text/str/float_parse`  -- string -> f64 (scanner + assembly).
 *   - `text/str/float_render` -- f64 -> string (dtoa).
 *
 * This module re-exports the public surface so `text/str/float` stays the
 * single import façade for the string<->f64 conversions.
 */
import {
  string_to_f64 as _string_to_f64,
  string_is_valid_f64 as _string_is_valid_f64,
  f64_str_bits as _f64_str_bits
} from "std:text/str/float_parse"
import { string_from_float as _string_from_float } from "std:text/str/float_render"

/**
Parse [a_s_ptr, a_s_ptr+b_s_len) as an f64. Whitespace-tolerant; accepts
the usual `[+-]?(digits('.'digits?)?|'.'digits)([eE][+-]?digits)?` grammar
plus case-insensitive `inf`/`infinity`/`nan`. Returns 0.0 on a malformed
string (callers gate with `string_is_valid_f64`).
*/
export let string_to_f64 = fn (a_s_ptr: i32, b_s_len: i32) -> float do
  return _string_to_f64(a_s_ptr, b_s_len)
end

/**
True iff [a_s_ptr, a_s_ptr+b_s_len) is a syntactically valid f64 literal
(per the grammar above, including `inf`/`nan`).
*/
export let string_is_valid_f64 = fn (a_s_ptr: i32, b_s_len: i32) -> bool do
  return _string_is_valid_f64(a_s_ptr, b_s_len)
end

/**
Render an f64 to a decimal string. `0.0` -> "0"; `-0.0` -> "-0" (the IEEE
sign is preserved). NaN -> "nan"; +-inf -> "inf"/"-inf". Exact integers
below 2^53 print without a decimal point. Otherwise: the shortest leading
digit string (<= 15 digits) that round-trips is used when one exists, else
a 17-digit extraction with trailing zeros trimmed. Fixed notation for
decimal exponents in [-4, 17), scientific notation outside.
*/
export let string_from_float = fn (a_val: float) -> i64 do
  return _string_from_float(a_val)
end

/**
Return the raw 8-byte IEEE-754 bit pattern of the f64 parsed from
[a_s_ptr, a_s_ptr+b_s_len) as an i64 (used by bytebuffer's push_f64_str_le).
*/
export let f64_str_bits = fn (a_s_ptr: i32, b_s_len: i32) -> i64 do
  return _f64_str_bits(a_s_ptr, b_s_len)
end
