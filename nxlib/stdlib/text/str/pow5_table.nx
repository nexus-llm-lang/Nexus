/**
 * str/pow5_table: 128-bit power-of-ten lookup for Eisel-Lemire f64 parsing.
 *
 * Auto-generated (do not hand-edit). Entry for decimal exponent q in
 * [-342, 308] holds the top 128 significant bits of 10^q, normalised so
 * bit 127 is set, as two i64 limbs (hi, lo). These are unsigned 64-bit bit
 * patterns stored in signed i64 slots (two's-complement wrap); Eisel-Lemire
 * only uses them as bit vectors in a 64x64->128 multiply, so the signed
 * interpretation is irrelevant.
 *
 * The 651 entries (16 bytes each) are materialised once into a heap block
 * on first lookup and the base pointer is cached in a fixed low-memory cell
 * (page 14, offset 917504) — the same lazy-init-in-reserved-page scheme
 * std:numeric/rand uses (page 15). Entry q lives at base + 16*(q - qmin),
 * hi at +0, lo at +8.
 */
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"

/** Smallest tabulated decimal exponent. */
export let pow5_qmin = fn () -> i64 do return 0 - 342 end
/** Largest tabulated decimal exponent. */
export let pow5_qmax = fn () -> i64 do return 308 end

/** Cache cell: base pointer of the built table (i64 at this offset). */
let cache_ptr_cell = 917504
/** Cache cell: init flag (i64 at this offset; 0 = not yet built). */
let cache_flag_cell = 917512

/** Store one (hi, lo) entry at base + 16*idx. */
let put = fn (base: i64, idx: i64, hi: i64, lo: i64) -> unit do
  mem.store_i64(addr: base + (idx * 16), val: hi)
  mem.store_i64(addr: base + (idx * 16) + 8, val: lo)
  return ()
end

