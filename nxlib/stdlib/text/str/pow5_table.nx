/** Return the table base pointer, building+caching it on first call. */
let table_base = fn () -> i64 do
  let flag = mem.load_i64(addr: cache_flag_cell)
  if flag != 0 then return mem.load_i64(addr: cache_ptr_cell) end
  let base = build_table()
  mem.store_i64(addr: cache_ptr_cell, val: base)
  mem.store_i64(addr: cache_flag_cell, val: 1)
  return base
end

/** High 64-bit limb of 10^q (q in [qmin, qmax]); bit pattern. */
export let pow5_hi = fn (q: i64) -> i64 do
  return mem.load_i64(addr: table_base() + ((q + 342) * 16))
end
/** Low 64-bit limb of 10^q (q in [qmin, qmax]); bit pattern. */
export let pow5_lo = fn (q: i64) -> i64 do
  return mem.load_i64(addr: table_base() + ((q + 342) * 16) + 8)
end
