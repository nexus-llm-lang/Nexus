/** option: Optional value type. */

/// An optional value: either Some with a value, or None.
pub type Option<T> = Some(val: T) | None

/// Returns true if the option contains a value.
pub let is_some = fn <T>(opt: Option<T>) -> bool do
  match opt do
    case Some(val: _) -> return true
    case None -> return false
  end
end

/// Returns true if the option is empty.
pub let is_none = fn <T>(opt: Option<T>) -> bool do
  match opt do
    case Some(val: _) -> return false
    case None -> return true
  end
end

/// Returns the contained value, or the default if None.
pub let unwrap_or = fn <T>(opt: Option<T>, default: T) -> T do
  match opt do
    case Some(val: v) -> return v
    case None -> return default
  end
end

/// Transforms the contained value using f, or returns None.
pub let map = fn <T, U>(opt: Option<T>, f: (val: T) -> U) -> Option<U> do
  match opt do
    case Some(val: v) -> return Some(val: f(val: v))
    case None -> return None
  end
end

/// Chains a fallible operation on the contained value (monadic bind).
pub let and_then = fn <T, U>(opt: Option<T>, f: (val: T) -> Option<U>) -> Option<U> do
  match opt do
    case Some(val: v) -> return f(val: v)
    case None -> return None
  end
end

/// Returns the option if Some, otherwise returns other.
pub let or_else = fn <T>(opt: Option<T>, other: Option<T>) -> Option<T> do
  match opt do
    case Some(val: v) -> return Some(val: v)
    case None -> return other
  end
end

/// Unwraps the option or raises a RuntimeError.
pub let unwrap = fn <T>(opt: Option<T>) -> T throws { Exn } do
  match opt do
    case Some(val: v) -> return v
    case None -> raise RuntimeError(val: "Option.unwrap called on None")
  end
end

/// Unwraps the option or raises a RuntimeError with a custom message.
pub let expect = fn <T>(opt: Option<T>, msg: string) -> T throws { Exn } do
  match opt do
    case Some(val: v) -> return v
    case None -> raise RuntimeError(val: msg)
  end
end
