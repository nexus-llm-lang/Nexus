/**
 * arena: Region-based memory management intrinsics.
 *
 * heap_mark()        saves the current heap state (G0 bump pointer + stdlib
 *                    allocator's outstanding count, packed into a single i64).
 * heap_reset(mark)   restores both: rewinds G0 and LIFO-frees every stdlib
 *                    allocation made after the mark. Strings, objects,
 *                    closures, and FFI return values produced via the routed
 *                    stdlib `allocate` are all reclaimed.
 * heap_swap(base)    pivots G0 only — does not touch stdlib bookkeeping.
 *                    Use for double-buffer / generational schemes where
 *                    string-domain allocations live elsewhere.
 *
 * Caveats:
 * - Cross-stdlib-crate FFI return values (fs/net/proc/etc. string returns)
 *   land in user-component memory via the canonical-ABI `cabi_realloc`
 *   lowering and ARE reclaimed by `heap_reset`'s G0 rewind. Per-iteration
 *   wrapping is the recommended pattern for HTTP / fs-heavy long-lived
 *   programs (see `bootstrap/tests/stdlib/arena.rs`
 *   `arena_cross_crate_fs_string_workload_bounded_with_reset`).
 * - Component-model targets do not import `__nx_alloc_mark`/`__nx_alloc_reset`
 *   (each component owns its memory). `heap_reset` falls back to the G0
 *   rewind only — string concat results in component mode go through
 *   `cabi_realloc` which bumps G0 and is reclaimed.
 * - Shared-memory threading mode (LazyRuntime::with_shared_memory): the
 *   host-side AtomicI32 bump pointer is the only allocator, and heap_mark /
 *   heap_reset bind to its (alloc-mark, alloc-reset) pair instead of the
 *   stdlib allocator. The mark is the bump-pointer value itself; reset
 *   stores it back atomically. Caller is responsible for ordering reset
 *   after every join — calling reset while a worker is still allocating
 *   races on the same address range.
 */
import external "nexus:runtime/arena"

export external heap_mark = "__nx_heap_mark" : () -> i64
export external heap_reset = "__nx_heap_reset" : (mark: i64) -> unit
export external heap_swap = "__nx_heap_swap" : (base: i64) -> i64
