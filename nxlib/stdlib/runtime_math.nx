/**
 * runtime_math: f64 unary intrinsics emitted as inline WASM ops.
 *
 * The compiler (codegen.nx) recognises `nexus:runtime/math` externals and
 * inline-emits the corresponding f64.* unary opcode, so these declarations
 * carry no host call overhead.
 *
 * Distinct from `std:math`, which routes through host imports and offers a
 * broader (mixed-precision, integer, conversion) API. Use `runtime_math`
 * when the call site must compile to a single wasm instruction.
 */
import external "nexus:runtime/math"

/// Square root: f64.sqrt. NaN for negative inputs.
export external sqrt = "__nx_f64_sqrt" : (val: float) -> float

/// Floor: f64.floor (round toward -inf).
export external floor = "__nx_f64_floor" : (val: float) -> float

/// Ceiling: f64.ceil (round toward +inf).
export external ceil = "__nx_f64_ceil" : (val: float) -> float

/// Absolute value: f64.abs (clears the sign bit).
export external abs = "__nx_f64_abs" : (val: float) -> float
