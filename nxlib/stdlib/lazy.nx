/**
 * lazy: Combinators for lazy (@) thunk evaluation.
 *
 * `force_all` runs in parallel: every thunk is dispatched onto its own OS
 * thread (via `std:lazy_host` / WASI threads), then the results are joined in
 * input order. A single `@x` force is still synchronous (a `call_indirect`);
 * for explicit per-thunk control use `std:lazy_host`'s `host_spawn` /
 * `host_join` directly.
 *
 * Spec-vs-impl divergence (issue nexus-qhms): `cancel` and `race` carry
 * surface-level semantics in `docs/spec/lazy.md` (cancel = "discard without
 * evaluating"; race = "loser is cancelled") that require a runtime drop
 * primitive and a first-of-two arbiter respectively. Neither host primitive
 * exists, so both `race` and `cancel` below run their argument(s)
 * synchronously and document the force-and-discard fallback. `detach` is the
 * honest fire-and-forget form.
 */
import * as lz from "std:runtime/lazy"

/// race(a, b): Sequentially force `a` then `b`, returning `a`'s result.
///
/// Spec contract (`docs/spec/lazy.md:154-156`): "Returns first to complete;
/// loser is cancelled". Without a runtime first-of-two arbiter, this
/// implementation always runs `a` first, then runs `b` and discards its
/// value. Side effects of `b` are observable. A parallel reimplementation
/// would cancel `b`'s continuation once `a` resolves, but that requires a
/// host primitive not currently provided.
///
/// Operates on `@T` (lazy bindings), not `%Task<T>` handles â€” orthogonal to
/// `std:lazy_host`'s `host_spawn` / `host_join`. A task-handle race would
/// require a runtime-side "first-of" primitive and is not yet provided.
export let race = fn <T>(a: @T, b: @T) -> T do
  let result = @a
  let _ = @b
  return result
end

/// cancel(a): Discharge a thunk's linearity by forcing it and discarding
/// the result.
///
/// Spec contract (`docs/spec/lazy.md:86,157`): "Discard without
/// evaluating". The only way to consume a linear `@T` in this calculus is
/// to force it â€” there is no "drop without force" form (a statement-level
/// `let _ = a` rebinds the linear obligation to the name `_` instead of
/// releasing it). Until such a primitive exists, this implementation is
/// observationally equivalent to `detach`: the thunk's body runs and any
/// side effects are observable.
export let cancel = fn <T>(a: @T) -> unit do
  let _ = @a
  return ()
end

/// detach(a): Force the thunk and discard the result.
/// Fire-and-forget semantics; useful when the effect of forcing is what
/// matters, not the value.
export let detach = fn <T>(a: @T) -> unit do
  let _ = @a
  return ()
end

/// force_all(tasks): Force every thunk in the list in parallel, returning
/// the results in input order. Each thunk is dispatched onto its own OS
/// thread; the forces all run concurrently and are joined left-to-right.
export let force_all = fn <T>(tasks: [ @T ]) -> [ T ] do
  let ids = spawn_all(tasks, acc: [])
  return join_all(ids, acc: [])
end

let spawn_all = fn <T>(tasks: [ @T ], acc: [ i64 ]) -> [ i64 ] do
  match tasks do
    | [] -> return reverse_i64(xs: acc, out: [])
    | t :: rest -> return spawn_all(tasks: rest, acc: lz.lazy_spawn(a_thunk: t) :: acc)
  end
end

let join_all = fn <T>(ids: [ i64 ], acc: [ T ]) -> [ T ] do
  match ids do
    | [] -> return reverse_list(xs: acc, out: [])
    | id :: rest -> return join_all(ids: rest, acc: lz.lazy_join(a_task: id) :: acc)
  end
end

let reverse_i64 = fn (xs: [ i64 ], out: [ i64 ]) -> [ i64 ] do
  match xs do
    | [] -> return out
    | x :: rest -> return reverse_i64(xs: rest, out: x :: out)
  end
end

let reverse_list = fn <T>(xs: [ T ], out: [ T ]) -> [ T ] do
  match xs do
    | [] -> return out
    | x :: rest -> return reverse_list(xs: rest, out: x :: out)
  end
end
