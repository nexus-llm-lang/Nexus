/**
 * lazy: Combinators for lazy (@) thunk evaluation.
 *
 * Only the @ sigil is built into the language. These combinators provide
 * higher-level operations backed by runtime host functions.
 *
 * Note: functions use i64 internally because all nexus values are i64 at WASM level.
 * The type-safe @T signatures are enforced at the call site by the typechecker.
 */
import external "nexus:runtime/lazy"

external __nx_lazy_spawn = "__nx_lazy_spawn" : (thunk: i64, num_captures: i32) -> i64
external __nx_lazy_join = "__nx_lazy_join" : (task_id: i64) -> i64

/// race(a, b): Force two thunks in parallel, return the first to complete.
/// The losing thunk's result is discarded. Both thunks are consumed.
export let race = fn (a: i64, b: i64) -> i64 do
  let tid_a = __nx_lazy_spawn(thunk: a, num_captures: 0)
  let tid_b = __nx_lazy_spawn(thunk: b, num_captures: 0)
  let result_a = __nx_lazy_join(task_id: tid_a)
  let _ = __nx_lazy_join(task_id: tid_b)
  return result_a
end

/// cancel(thunk): Consume a lazy thunk without evaluating it.
/// Satisfies linearity — the thunk is discarded. No-op at runtime.
export let cancel = fn (thunk: i64) -> unit do
  let _ = thunk
  return ()
end

/// detach(thunk): Start evaluating the thunk but don't wait for the result.
/// The thunk runs in the background; the result is discarded when it completes.
export let detach = fn (thunk: i64) -> unit do
  let _ = __nx_lazy_spawn(thunk: thunk, num_captures: 0)
  return ()
end

/// force_all(tasks): Spawn all thunks in parallel, then join results in order.
let spawn_all = fn (tasks: [i64], tids: [i64]) -> [i64] do
  match tasks do
    | [] -> return tids
    | thunk :: rest ->
      let tid = __nx_lazy_spawn(thunk: thunk, num_captures: 0)
      return spawn_all(tasks: rest, tids: tid :: tids)
  end
end

let join_all = fn (tids: [i64], results: [i64]) -> [i64] do
  match tids do
    | [] -> return results
    | tid :: rest ->
      let result = __nx_lazy_join(task_id: tid)
      return join_all(tids: rest, results: result :: results)
  end
end

export let force_all = fn (tasks: [i64]) -> [i64] do
  let tids = spawn_all(tasks: tasks, tids: [])
  return join_all(tids: tids, results: [])
end
