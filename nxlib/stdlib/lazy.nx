/**
 * lazy: Combinators for lazy (@) thunk evaluation.
 *
 * Sequential implementation. Each combinator forces thunks in source order
 * using the @ sigil directly, so no host imports are required. A future
 * parallel runtime (epic nexus-dtq5 Phase 2 / nexus-zxm) can reimplement
 * these with true DAG parallelism under the same API contract.
 */

/// race(a, b): Force both thunks, returning `a`'s result.
/// Sequential semantics only — both thunks always run to completion.
/// A parallel reimplementation would cancel the loser after the winner
/// resolves, but under sequential execution there is no loser to cancel.
export let race = fn <T>(a: @T, b: @T) -> T do
  let result = @a
  let _ = @b
  return result
end

/// cancel(a): Consume a thunk without forcing it.
/// Explicit `let _ = a` drop to satisfy the callee-side linearity rule
/// (each @T parameter must be referenced exactly once in the function body —
/// `let _ = a` is the "drop without force" form).
export let cancel = fn <T>(a: @T) -> unit do
  let _ = a
  return ()
end

/// detach(a): Force the thunk and discard the result.
/// Fire-and-forget semantics; useful when the effect of forcing is what
/// matters, not the value.
export let detach = fn <T>(a: @T) -> unit do
  let _ = @a
  return ()
end

// ─── Host-runtime path ──────────────────────────────────────────────────────
//
// Two-step protocol against the nexus:runtime/lazy host interface
// (Rust __nx_lazy_spawn / __nx_lazy_join):
//
//   host_spawn : <T>(@T) -> i64      // consumes thunk, returns task handle
//   host_join  : <T>(i64) -> T       // waits on handle, returns forced value
//
// Zero-capture thunks run on a worker thread; non-zero-capture thunks fall
// back to inline on the caller thread and the "task handle" encodes the
// inline result directly. The encoding is private to the runtime — callers
// must always pair spawn with join.
import external "nexus:runtime/lazy"
external __nx_lazy_spawn = "__nx_lazy_spawn" : <T>(thunk: @T, num_captures: i32) -> i64
external __nx_lazy_join = "__nx_lazy_join" : <T>(task_id: i64) -> T

/// host_spawn(a): Dispatch a thunk to the runtime. The @T is consumed;
/// the returned i64 is an opaque task handle that must be passed to
/// host_join to retrieve the forced value.
///
/// num_captures is conservatively set to 1 so the runtime always takes the
/// inline-fallback path. Without compiler support to thread the actual
/// capture count of `a` here, hardcoding 0 would route capture-bearing
/// thunks to a worker thread whose Store has zero-initialised memory and
/// silently produce wrong values. host_force already documents sequential
/// semantics, so the inline path is a correctness-preserving choice.
export let host_spawn = fn <T>(a: @T) -> i64 do
  return __nx_lazy_spawn(thunk: a, num_captures: 1)
end

/// host_join(task_id): Await a previously spawned thunk and return its
/// forced value. The T must match the element type of the thunk handed
/// to host_spawn; the runtime erases types at the FFI boundary so this
/// is the caller's obligation.
export let host_join = fn <T>(task_id: i64) -> T do
  return __nx_lazy_join(task_id: task_id)
end

/// host_force(a): Convenience composition of spawn + join. Semantically
/// equivalent to `@a`, but routes the evaluation through the runtime so
/// any future cross-thunk parallelism surfaces here.
export let host_force = fn <T>(a: @T) -> T do
  return host_join(task_id: host_spawn(a: a))
end
