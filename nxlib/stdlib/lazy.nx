/**
 * lazy: Combinators for lazy (@) thunk evaluation.
 *
 * Sequential implementation. Each combinator forces thunks in source order
 * using the @ sigil directly, so no host imports are required. The same
 * API contract admits a parallel reimplementation (DAG-driven force) once
 * combinators consume the spawn/join host pair from `std:lazy_host`.
 *
 * Spec-vs-impl divergence (issue nexus-qhms): `cancel` and `race` carry
 * surface-level semantics in `docs/spec/lazy.md` (cancel = "discard without
 * evaluating"; race = "loser is cancelled") that require a runtime drop
 * primitive and a first-of-two arbiter respectively. Neither host primitive
 * exists; both are absent from the runtime/lazy host module (only
 * `__nx_lazy_spawn` and `__nx_lazy_join` are provided, in `std:lazy_host`).
 * The combinators
 * below preserve the spec's *type signatures* but document the sequential
 * force-and-discard fallback. Programs depending on the spec's no-evaluate
 * / cancel-loser semantics will observe both arms running in source order.
 *
 * The host-runtime path (`Task<T>`, `host_spawn`, `host_join`) lives in
 * `std:lazy_host` so that a fixture importing only the pure combinators
 * here does not pull `nexus:runtime/lazy` host externals into its
 * produced wasm.
 */

/// race(a, b): Sequentially force `a` then `b`, returning `a`'s result.
///
/// Spec contract (`docs/spec/lazy.md:154-156`): "Returns first to complete;
/// loser is cancelled". Without a runtime first-of-two arbiter, this
/// implementation always runs `a` first, then runs `b` and discards its
/// value. Side effects of `b` are observable. A parallel reimplementation
/// would cancel `b`'s continuation once `a` resolves, but that requires a
/// host primitive not currently provided.
///
/// Operates on `@T` (lazy bindings), not `%Task<T>` handles — orthogonal to
/// `std:lazy_host`'s `host_spawn` / `host_join`. A task-handle race would
/// require a runtime-side "first-of" primitive and is not yet provided.
export let race = fn <T>(a: @T, b: @T) -> T do
  let result = @a
  let _ = @b
  return result
end

/// cancel(a): Discharge a thunk's linearity by forcing it and discarding
/// the result.
///
/// Spec contract (`docs/spec/lazy.md:86,157`): "Discard without
/// evaluating". The only way to consume a linear `@T` in this calculus is
/// to force it — there is no "drop without force" form (a statement-level
/// `let _ = a` rebinds the linear obligation to the name `_` instead of
/// releasing it), and the runtime/lazy host module exposes no `__nx_lazy_drop`.
/// Until such a primitive exists, this implementation is observationally
/// equivalent to `detach`: the thunk's body runs and any side effects are
/// observable.
export let cancel = fn <T>(a: @T) -> unit do
  let _ = @a
  return ()
end

/// detach(a): Force the thunk and discard the result.
/// Fire-and-forget semantics; useful when the effect of forcing is what
/// matters, not the value.
export let detach = fn <T>(a: @T) -> unit do
  let _ = @a
  return ()
end

/// force_all(tasks): Force every thunk in the list left-to-right, returning
/// the results in input order.
///
/// Spec contract (`docs/spec/lazy.md:159`): "Force every thunk; collect
/// results in order". A parallel implementation would dispatch all thunks
/// concurrently and join in input order; the sequential fallback walks the
/// list, forcing each `@T` element as it is unpacked.
export let force_all = fn <T>(tasks: [ @T ]) -> [ T ] do
  return force_all_go(tasks, acc: [])
end

let force_all_go = fn <T>(tasks: [ @T ], acc: [ T ]) -> [ T ] do
  match tasks do
    | [] -> return reverse_list(xs: acc, out: [])
    | t :: rest -> return force_all_go(tasks: rest, acc: @t :: acc)
  end
end

let reverse_list = fn <T>(xs: [ T ], out: [ T ]) -> [ T ] do
  match xs do
    | [] -> return out
    | x :: rest -> return reverse_list(xs: rest, out: x :: out)
  end
end
