/**
 * lazy: Combinators for lazy (@) thunk evaluation.
 *
 * Sequential implementation. Each combinator forces thunks in source order
 * using the @ sigil directly, so no host imports are required. A future
 * parallel runtime (epic nexus-dtq5 Phase 2 / nexus-zxm) can reimplement
 * these with true DAG parallelism under the same API contract.
 */

/// race(a, b): Force both thunks, returning `a`'s result.
/// Sequential semantics only — both thunks always run to completion.
/// A parallel reimplementation would cancel the loser after the winner
/// resolves, but under sequential execution there is no loser to cancel.
export let race = fn <T>(a: @T, b: @T) -> T do
  let result = @a
  let _ = @b
  return result
end

/// cancel(a): Consume a thunk without forcing it.
/// Explicit `let _ = a` drop to satisfy the callee-side linearity rule
/// (each @T parameter must be referenced exactly once in the function body —
/// `let _ = a` is the "drop without force" form).
export let cancel = fn <T>(a: @T) -> unit do
  let _ = a
  return ()
end

/// detach(a): Force the thunk and discard the result.
/// Fire-and-forget semantics; useful when the effect of forcing is what
/// matters, not the value.
export let detach = fn <T>(a: @T) -> unit do
  let _ = @a
  return ()
end

// ─── Host-runtime path ──────────────────────────────────────────────────────
//
// host_force forces a thunk via the nexus:runtime/lazy host function
// (Rust __nx_lazy_spawn). Today the host calls the thunk inline and
// returns the forced value as the task_id. A future parallel runtime
// (nexus-zxm Phase 2) will spawn a thread and have the caller wait via
// __nx_lazy_join — this signature stays the same.
import external "nexus:runtime/lazy"
external __nx_lazy_spawn = "__nx_lazy_spawn" : <T>(thunk: @T, num_captures: i32) -> T

/// host_force(a): Force a thunk via the runtime host function.
/// Semantically equivalent to `@a`, but routes through the Rust
/// runtime so it's the target for a future threaded rewrite.
export let host_force = fn <T>(a: @T) -> T do
  return __nx_lazy_spawn(thunk: a, num_captures: 0)
end
