/**
 * lazy: Combinators for lazy (@) thunk evaluation.
 *
 * Sequential implementation. Each combinator forces thunks in source order
 * using the @ sigil directly, so no host imports are required. A future
 * parallel runtime (epic nexus-dtq5 Phase 2 / nexus-zxm) can reimplement
 * these with true DAG parallelism under the same API contract.
 */

/// race(a, b): Force both thunks, returning `a`'s result.
/// Sequential semantics only — both thunks always run to completion.
/// A parallel reimplementation would cancel the loser after the winner
/// resolves, but under sequential execution there is no loser to cancel.
///
/// Operates on @T (lazy bindings), not %Task<T> handles — orthogonal to
/// host_spawn / host_join. A task-handle race would require a runtime-side
/// "first-of" primitive and is not yet provided.
export let race = fn <T>(a: @T, b: @T) -> T do
  let result = @a
  let _ = @b
  return result
end

/// cancel(a): Discharge a thunk's linearity by forcing it and discarding
/// the result. Despite the name, the only way to consume a linear @T in
/// this calculus is to force it — there is no "drop without force" form
/// (a statement-level `let _ = a` rebinds the linear obligation to the
/// name `_` instead of releasing it). For sequential semantics this is
/// indistinguishable from `detach`; the name survives for symmetry with
/// future parallel runtimes that may add a true cancellation primitive.
export let cancel = fn <T>(a: @T) -> unit do
  let _ = @a
  return ()
end

/// detach(a): Force the thunk and discard the result.
/// Fire-and-forget semantics; useful when the effect of forcing is what
/// matters, not the value.
export let detach = fn <T>(a: @T) -> unit do
  let _ = @a
  return ()
end

// ─── Host-runtime path ──────────────────────────────────────────────────────
//
// Two-step protocol against the nexus:runtime/lazy host interface
// (Rust __nx_lazy_spawn / __nx_lazy_join):
//
//   host_spawn : <T>(@T) -> %Task<T>    // consumes thunk, returns linear handle
//   host_join  : <T>(%Task<T>) -> T     // waits on handle, returns forced value
//
// Task<T> is an opaque linear wrapper around the runtime's raw i64 task id.
// The linearity checker statically rejects spawn-without-join (the entry in
// the runtime's tasks map and, for threaded thunks, the Rust JoinHandle would
// otherwise leak for the lifetime of the wasm instance).
//
// Zero-capture thunks run on a worker thread; non-zero-capture thunks fall
// back to inline on the caller thread and the "task id" encodes the inline
// result directly. The encoding is private to the runtime — callers must
// always pair spawn with join.
import external "nexus:runtime/lazy"
external __nx_lazy_spawn = "__nx_lazy_spawn" : <T>(thunk: @T, num_captures: i32) -> i64
external __nx_lazy_join = "__nx_lazy_join" : <T>(task_id: i64) -> T

/// A handle to a spawned thunk. Linear — must be consumed by `host_join`.
/// Phantom T threads the thunk's element type from host_spawn to host_join
/// so the FFI's type-erased i64 channel cannot be misused across the pair.
export opaque type Task<T> = Task(id: i64)

/// host_spawn(a): Dispatch a thunk to the runtime. The @T is consumed and
/// a linear %Task<T> is returned that must be drained by host_join.
///
/// num_captures is conservatively set to 1 so the runtime always takes the
/// inline-fallback path. Without compiler support to thread the actual
/// capture count of `a` here, hardcoding 0 would route capture-bearing
/// thunks to a worker thread whose Store has zero-initialised memory and
/// silently produce wrong values. host_force already documents sequential
/// semantics, so the inline path is a correctness-preserving choice.
export let host_spawn = fn <T>(a: @T) -> %Task<T> do
  let id = __nx_lazy_spawn(thunk: a, num_captures: 1)
  let t = Task(id)
  let %lt = t
  return %lt
end

/// host_join(handle): Await a previously spawned thunk and return its
/// forced value. Consumes the linear handle.
///
/// Parameter is named `handle` (not `task`) because `task` is a reserved
/// keyword in Nexus.
export let host_join = fn <T>(handle: %Task<T>) -> T do
  let Task(id) = handle
  return __nx_lazy_join(task_id: id)
end

/// host_force(a): Convenience composition of spawn + join. Semantically
/// equivalent to `@a`, but routes the evaluation through the runtime so
/// any future cross-thunk parallelism surfaces here.
export let host_force = fn <T>(a: @T) -> T do
  return host_join(handle: host_spawn(a))
end
