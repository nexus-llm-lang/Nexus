/** array: Fixed-size mutable array operations via borrow references. */

import external "nxlib/stdlib/stdlib.wasm"
import { Pair, Partition } from "stdlib/core.nx"

/// Returns the number of elements in an array (via borrow).
export external length = "__nx_array_length" : <T>(arr: &[| T |]) -> i64

let reverse_go = fn <T>(xs: [ T ], acc: [ T ]) -> [ T ] do
  match xs do
    case [] -> return acc
    case v :: rest ->
      let next = Cons(v: v, rest: acc)
      return reverse_go(xs: rest, acc: next)
  end
end

let reverse = fn <T>(xs: [ T ]) -> [ T ] do
  return reverse_go(xs: xs, acc: Nil)
end

/// Returns true if the array has no elements.
export let is_empty = fn <T>(arr: &[| T |]) -> bool do
  return length(arr: arr) == 0
end

/// Returns the element at the given index.
export let get = fn <T>(arr: &[| T |], idx: i64) -> T do
  return arr[idx]
end

/// Sets the element at the given index (mutates in place).
export let set = fn <T>(arr: &[| T |], idx: i64, val: T) -> unit do
  arr[idx] <- val
  return ()
end

/// Returns the first element.
export let head = fn <T>(arr: &[| T |]) -> T do
  return get(arr: arr, idx: 0)
end

/// Returns the last element.
export let last = fn <T>(arr: &[| T |]) -> T do
  return get(arr: arr, idx: length(arr: arr) - 1)
end

export let fold_left_go = fn <T, U>(arr: &[| T |], idx: i64, len: i64, acc: U, f: (acc: U, val: T) -> U) -> U do
  if idx >= len then
    return acc
  else
    let v = get(arr: arr, idx: idx)
    let next = f(acc: acc, val: v)
    let next_idx = idx + 1
    return fold_left_go(arr: arr, idx: next_idx, len: len, acc: next, f: f)
  end
end

/**
 * Left fold over the array with an initial accumulator and combining function.
 * Iterates index 0..length-1, threading the accumulator through f at each step.
 * Tail-recursive via fold_left_go; safe for large arrays.
 */
export let fold_left = fn <T, U>(arr: &[| T |], init: U, f: (acc: U, val: T) -> U) -> U do
  return fold_left_go(arr: arr, idx: 0, len: length(arr: arr), acc: init, f: f)
end

export let any_go = fn <T>(arr: &[| T |], idx: i64, len: i64, pred: (val: T) -> bool) -> bool do
  if idx >= len then
    return false
  else
    let v = get(arr: arr, idx: idx)
    if pred(val: v) then
      return true
    else
      let next_idx = idx + 1
      return any_go(arr: arr, idx: next_idx, len: len, pred: pred)
    end
  end
end

/// Returns true if any element satisfies the predicate.
export let any = fn <T>(arr: &[| T |], pred: (val: T) -> bool) -> bool do
  return any_go(arr: arr, idx: 0, len: length(arr: arr), pred: pred)
end

export let all_go = fn <T>(arr: &[| T |], idx: i64, len: i64, pred: (val: T) -> bool) -> bool do
  if idx >= len then
    return true
  else
    let v = get(arr: arr, idx: idx)
    if pred(val: v) then
      let next_idx = idx + 1
      return all_go(arr: arr, idx: next_idx, len: len, pred: pred)
    else
      return false
    end
  end
end

/// Returns true if all elements satisfy the predicate.
export let all = fn <T>(arr: &[| T |], pred: (val: T) -> bool) -> bool do
  return all_go(arr: arr, idx: 0, len: length(arr: arr), pred: pred)
end

export let find_index_go = fn <T>(arr: &[| T |], idx: i64, len: i64, pred: (val: T) -> bool) -> i64 do
  if idx >= len then
    return -1
  else
    let v = get(arr: arr, idx: idx)
    if pred(val: v) then
      return idx
    else
      let next_idx = idx + 1
      return find_index_go(arr: arr, idx: next_idx, len: len, pred: pred)
    end
  end
end

/// Returns the index of the first element satisfying the predicate, or -1.
export let find_index = fn <T>(arr: &[| T |], pred: (val: T) -> bool) -> i64 do
  return find_index_go(arr: arr, idx: 0, len: length(arr: arr), pred: pred)
end

export let for_each_go = fn <T>(arr: &[| T |], idx: i64, len: i64, f: (val: T) -> unit) -> unit do
  if idx >= len then
    return ()
  else
    let v = get(arr: arr, idx: idx)
    f(val: v)
    let next_idx = idx + 1
    return for_each_go(arr: arr, idx: next_idx, len: len, f: f)
  end
end

/// Applies f to each element of the array for side effects.
export let for_each = fn <T>(arr: &[| T |], f: (val: T) -> unit) -> unit do
  return for_each_go(arr: arr, idx: 0, len: length(arr: arr), f: f)
end

export let map_in_place_go = fn <T>(arr: &[| T |], idx: i64, len: i64, f: (val: T) -> T) -> unit do
  if idx >= len then
    return ()
  else
    let v = get(arr: arr, idx: idx)
    let mapped = f(val: v)
    set(arr: arr, idx: idx, val: mapped)
    let next_idx = idx + 1
    return map_in_place_go(arr: arr, idx: next_idx, len: len, f: f)
  end
end

/// Applies f to each element, writing the result back in place.
export let map_in_place = fn <T>(arr: &[| T |], f: (val: T) -> T) -> unit do
  return map_in_place_go(arr: arr, idx: 0, len: length(arr: arr), f: f)
end

export let filter_go = fn <T>(arr: &[| T |], idx: i64, len: i64, pred: (val: T) -> bool, acc: [ T ]) -> [ T ] do
  if idx >= len then
    return acc
  else
    let v = get(arr: arr, idx: idx)
    let next_idx = idx + 1
    if pred(val: v) then
      let next = Cons(v: v, rest: acc)
      return filter_go(arr: arr, idx: next_idx, len: len, pred: pred, acc: next)
    else
      return filter_go(arr: arr, idx: next_idx, len: len, pred: pred, acc: acc)
    end
  end
end

/**
 * Returns a list of elements satisfying the predicate, preserving order.
 * Collects matching elements in reverse during a single pass, then
 * reverses the accumulator to restore the original order.
 */
export let filter = fn <T>(arr: &[| T |], pred: (val: T) -> bool) -> [ T ] do
  return reverse(xs: filter_go(arr: arr, idx: 0, len: length(arr: arr), pred: pred, acc: Nil))
end

export let partition_go = fn <T>(arr: &[| T |], idx: i64, len: i64, pred: (val: T) -> bool, matched_acc: [ T ], rest_acc: [ T ]) -> Partition<T> do
  if idx >= len then
    let matched = reverse(xs: matched_acc)
    let rest = reverse(xs: rest_acc)
    return Partition(matched: matched, rest: rest)
  else
    let v = get(arr: arr, idx: idx)
    let next_idx = idx + 1
    if pred(val: v) then
      let next = Cons(v: v, rest: matched_acc)
      return partition_go(arr: arr, idx: next_idx, len: len, pred: pred, matched_acc: next, rest_acc: rest_acc)
    else
      let next = Cons(v: v, rest: rest_acc)
      return partition_go(arr: arr, idx: next_idx, len: len, pred: pred, matched_acc: matched_acc, rest_acc: next)
    end
  end
end

/**
 * Splits elements into matched/rest lists based on the predicate.
 * A single pass collects elements into two accumulators (matched and rest),
 * then both are reversed to preserve the original order. Returns a
 * Partition<T> record containing both lists.
 */
export let partition = fn <T>(arr: &[| T |], pred: (val: T) -> bool) -> Partition<T> do
  return partition_go(arr: arr, idx: 0, len: length(arr: arr), pred: pred, matched_acc: Nil, rest_acc: Nil)
end

let min_i64 = fn (a: i64, b: i64) -> i64 do
  if a < b then
    return a
  else
    return b
  end
end

export let zip_with_go = fn <A, B, C>(left: &[| A |], right: &[| B |], idx: i64, len: i64, f: (left: A, right: B) -> C, acc: [ C ]) -> [ C ] do
  if idx >= len then
    return acc
  else
    let l = get(arr: left, idx: idx)
    let r = get(arr: right, idx: idx)
    let mapped = f(left: l, right: r)
    let next = Cons(v: mapped, rest: acc)
    let next_idx = idx + 1
    return zip_with_go(left: left, right: right, idx: next_idx, len: len, f: f, acc: next)
  end
end

/**
 * Combines two arrays element-wise using f, returning a list.
 * Iterates up to the shorter array's length. Each pair (left[i], right[i])
 * is passed to f and the results are collected in order.
 */
export let zip_with = fn <A, B, C>(left: &[| A |], right: &[| B |], f: (left: A, right: B) -> C) -> [ C ] do
  let len = min_i64(a: length(arr: left), b: length(arr: right))
  return reverse(xs: zip_with_go(left: left, right: right, idx: 0, len: len, f: f, acc: Nil))
end

export let zip_go = fn <A, B>(left: &[| A |], right: &[| B |], idx: i64, len: i64, acc: [ Pair<A, B > ]) -> [ Pair<A, B> ] do
  if idx >= len then
    return acc
  else
    let l = get(arr: left, idx: idx)
    let r = get(arr: right, idx: idx)
    let pair = Pair(left: l, right: r)
    let next = Cons(v: pair, rest: acc)
    let next_idx = idx + 1
    return zip_go(left: left, right: right, idx: next_idx, len: len, acc: next)
  end
end

/// Pairs elements from two arrays positionally, returning a list of Pairs.
export let zip = fn <A, B>(left: &[| A |], right: &[| B |]) -> [ Pair<A, B> ] do
  let len = min_i64(a: length(arr: left), b: length(arr: right))
  return reverse(xs: zip_go(left: left, right: right, idx: 0, len: len, acc: Nil))
end

let consume_go = fn <T>(arr: &[| T |], idx: i64, len: i64, f: (val: %T) -> unit) -> unit do
  if idx >= len then
    return ()
  else
    let v = arr[idx]
    f(val: v)
    let next_idx = idx + 1
    return consume_go(arr: arr, idx: next_idx, len: len, f: f)
  end
end

/**
 * Consumes a linear array by applying f to each element, transferring ownership.
 * The array is borrowed internally for indexed access, but each element is
 * handed to f as a linear (%T) value. After this call the array is consumed
 * and cannot be used again. f must consume each element exactly once.
 */
export let consume = fn <T>(%arr: [| T |], f: (val: %T) -> unit) -> unit do
  let arr_ref = &%arr
  let n = length(arr: arr_ref)
  consume_go(arr: arr_ref, idx: 0, len: n, f: f)
  return ()
end
