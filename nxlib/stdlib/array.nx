pub type Pair<A, B> = Pair(left: A, right: B)
pub type Partition<T> = Partition(matched: List<T>, rest: List<T>)

let reverse_go = fn <T>(xs: List<T>, acc: List<T>) -> List<T> do
  match xs do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) ->
      let next = Cons(v: v, rest: acc)
      return reverse_go(xs: rest, acc: next)
  endmatch
endfn

let reverse = fn <T>(xs: List<T>) -> List<T> do
  let acc = Nil()
  return reverse_go(xs: xs, acc: acc)
endfn

pub let length = fn <T>(arr: &[| T |]) -> i64 do
  let arr_ref = borrow arr
  return array_length(arr: arr_ref)
endfn

pub let is_empty = fn <T>(arr: &[| T |]) -> bool do
  return length(arr: arr) == 0
endfn

pub let get = fn <T>(arr: &[| T |], idx: i64) -> T do
  return arr[idx]
endfn

pub let set = fn <T>(arr: &[| T |], idx: i64, val: T) -> unit do
  arr[idx] <- val
  return ()
endfn

pub let head = fn <T>(arr: &[| T |]) -> T do
  return get(arr: arr, idx: 0)
endfn

pub let last = fn <T>(arr: &[| T |]) -> T do
  let n = length(arr: arr)
  let idx = n - 1
  return get(arr: arr, idx: idx)
endfn

pub let fold_left_go = fn <T, U>(arr: &[| T |], idx: i64, len: i64, acc: U, f: (acc: U, val: T) -> U) -> U do
  if idx >= len then
    return acc
  else
    let v = get(arr: arr, idx: idx)
    let next = f(acc: acc, val: v)
    let next_idx = idx + 1
    return fold_left_go(arr: arr, idx: next_idx, len: len, acc: next, f: f)
  endif
endfn

pub let fold_left = fn <T, U>(arr: &[| T |], init: U, f: (acc: U, val: T) -> U) -> U do
  let n = length(arr: arr)
  return fold_left_go(arr: arr, idx: 0, len: n, acc: init, f: f)
endfn

pub let any_go = fn <T>(arr: &[| T |], idx: i64, len: i64, pred: (val: T) -> bool) -> bool do
  if idx >= len then
    return false
  else
    let v = get(arr: arr, idx: idx)
    if pred(val: v) then
      return true
    else
      let next_idx = idx + 1
      return any_go(arr: arr, idx: next_idx, len: len, pred: pred)
    endif
  endif
endfn

pub let any = fn <T>(arr: &[| T |], pred: (val: T) -> bool) -> bool do
  let n = length(arr: arr)
  return any_go(arr: arr, idx: 0, len: n, pred: pred)
endfn

pub let all_go = fn <T>(arr: &[| T |], idx: i64, len: i64, pred: (val: T) -> bool) -> bool do
  if idx >= len then
    return true
  else
    let v = get(arr: arr, idx: idx)
    if pred(val: v) then
      let next_idx = idx + 1
      return all_go(arr: arr, idx: next_idx, len: len, pred: pred)
    else
      return false
    endif
  endif
endfn

pub let all = fn <T>(arr: &[| T |], pred: (val: T) -> bool) -> bool do
  let n = length(arr: arr)
  return all_go(arr: arr, idx: 0, len: n, pred: pred)
endfn

pub let find_index_go = fn <T>(arr: &[| T |], idx: i64, len: i64, pred: (val: T) -> bool) -> i64 do
  if idx >= len then
    return -1
  else
    let v = get(arr: arr, idx: idx)
    if pred(val: v) then
      return idx
    else
      let next_idx = idx + 1
      return find_index_go(arr: arr, idx: next_idx, len: len, pred: pred)
    endif
  endif
endfn

pub let find_index = fn <T>(arr: &[| T |], pred: (val: T) -> bool) -> i64 do
  let n = length(arr: arr)
  return find_index_go(arr: arr, idx: 0, len: n, pred: pred)
endfn

pub let for_each_go = fn <T>(arr: &[| T |], idx: i64, len: i64, f: (val: T) -> unit) -> unit do
  if idx >= len then
    return ()
  else
    let v = get(arr: arr, idx: idx)
    f(val: v)
    let next_idx = idx + 1
    return for_each_go(arr: arr, idx: next_idx, len: len, f: f)
  endif
endfn

pub let for_each = fn <T>(arr: &[| T |], f: (val: T) -> unit) -> unit do
  let n = length(arr: arr)
  return for_each_go(arr: arr, idx: 0, len: n, f: f)
endfn

pub let map_in_place_go = fn <T>(arr: &[| T |], idx: i64, len: i64, f: (val: T) -> T) -> unit do
  if idx >= len then
    return ()
  else
    let v = get(arr: arr, idx: idx)
    let mapped = f(val: v)
    set(arr: arr, idx: idx, val: mapped)
    let next_idx = idx + 1
    return map_in_place_go(arr: arr, idx: next_idx, len: len, f: f)
  endif
endfn

pub let map_in_place = fn <T>(arr: &[| T |], f: (val: T) -> T) -> unit do
  let n = length(arr: arr)
  return map_in_place_go(arr: arr, idx: 0, len: n, f: f)
endfn

pub let filter_go = fn <T>(arr: &[| T |], idx: i64, len: i64, pred: (val: T) -> bool, acc: List<T>) -> List<T> do
  if idx >= len then
    return acc
  else
    let v = get(arr: arr, idx: idx)
    let next_idx = idx + 1
    if pred(val: v) then
      let next = Cons(v: v, rest: acc)
      return filter_go(arr: arr, idx: next_idx, len: len, pred: pred, acc: next)
    else
      return filter_go(arr: arr, idx: next_idx, len: len, pred: pred, acc: acc)
    endif
  endif
endfn

pub let filter = fn <T>(arr: &[| T |], pred: (val: T) -> bool) -> List<T> do
  let n = length(arr: arr)
  let empty = Nil()
  let rev = filter_go(arr: arr, idx: 0, len: n, pred: pred, acc: empty)
  return reverse(xs: rev)
endfn

pub let partition_go = fn <T>(arr: &[| T |], idx: i64, len: i64, pred: (val: T) -> bool, matched_acc: List<T>, rest_acc: List<T>) -> Partition<T> do
  if idx >= len then
    let matched = reverse(xs: matched_acc)
    let rest = reverse(xs: rest_acc)
    return Partition(matched: matched, rest: rest)
  else
    let v = get(arr: arr, idx: idx)
    let next_idx = idx + 1
    if pred(val: v) then
      let next = Cons(v: v, rest: matched_acc)
      return partition_go(arr: arr, idx: next_idx, len: len, pred: pred, matched_acc: next, rest_acc: rest_acc)
    else
      let next = Cons(v: v, rest: rest_acc)
      return partition_go(arr: arr, idx: next_idx, len: len, pred: pred, matched_acc: matched_acc, rest_acc: next)
    endif
  endif
endfn

pub let partition = fn <T>(arr: &[| T |], pred: (val: T) -> bool) -> Partition<T> do
  let matched = Nil()
  let rest = Nil()
  let n = length(arr: arr)
  return partition_go(arr: arr, idx: 0, len: n, pred: pred, matched_acc: matched, rest_acc: rest)
endfn

let min_i64 = fn (a: i64, b: i64) -> i64 do
  if a < b then
    return a
  else
    return b
  endif
endfn

pub let zip_with_go = fn <A, B, C>(left: &[| A |], right: &[| B |], idx: i64, len: i64, f: (left: A, right: B) -> C, acc: List<C>) -> List<C> do
  if idx >= len then
    return acc
  else
    let l = get(arr: left, idx: idx)
    let r = get(arr: right, idx: idx)
    let mapped = f(left: l, right: r)
    let next = Cons(v: mapped, rest: acc)
    let next_idx = idx + 1
    return zip_with_go(left: left, right: right, idx: next_idx, len: len, f: f, acc: next)
  endif
endfn

pub let zip_with = fn <A, B, C>(left: &[| A |], right: &[| B |], f: (left: A, right: B) -> C) -> List<C> do
  let len_left = length(arr: left)
  let len_right = length(arr: right)
  let len = min_i64(a: len_left, b: len_right)
  let empty = Nil()
  let rev = zip_with_go(left: left, right: right, idx: 0, len: len, f: f, acc: empty)
  return reverse(xs: rev)
endfn

pub let zip_go = fn <A, B>(left: &[| A |], right: &[| B |], idx: i64, len: i64, acc: List<Pair<A, B>>) -> List<Pair<A, B>> do
  if idx >= len then
    return acc
  else
    let l = get(arr: left, idx: idx)
    let r = get(arr: right, idx: idx)
    let pair = Pair(left: l, right: r)
    let next = Cons(v: pair, rest: acc)
    let next_idx = idx + 1
    return zip_go(left: left, right: right, idx: next_idx, len: len, acc: next)
  endif
endfn

pub let zip = fn <A, B>(left: &[| A |], right: &[| B |]) -> List<Pair<A, B>> do
  let len_left = length(arr: left)
  let len_right = length(arr: right)
  let len = min_i64(a: len_left, b: len_right)
  let empty = Nil()
  let rev = zip_go(left: left, right: right, idx: 0, len: len, acc: empty)
  return reverse(xs: rev)
endfn
