/**
 * result: Result type for explicit error handling without effects.
 *
 * Result<T, E> represents either a successful value Ok(val) or a failure
 * Err(err). This enables pure, composable error handling via map, map_err,
 * and and_then (monadic bind). The from_exn / to_exn pair bridges between
 * Result and the Exn throws system.
 */

/// A value that is either Ok (success) or Err (failure).
export type Result<T, E> = Ok(val: T) | Err(err: E)

/// Returns true if the result is Ok.
export let is_ok = fn <T, E>(res: Result<T, E>) -> bool do
  match res do
    | Ok(_) -> return true
    | Err(_) -> return false
  end
end

/// Returns true if the result is Err.
export let is_err = fn <T, E>(res: Result<T, E>) -> bool do
  match res do
    | Ok(_) -> return false
    | Err(_) -> return true
  end
end

/// Returns the Ok value, or the default if Err.
export let unwrap_or = fn <T, E>(res: Result<T, E>, default: T) -> T do
  match res do
    | Ok(val: v) -> return v
    | Err(_) -> return default
  end
end

/// Transforms the Ok value using f, leaving Err unchanged.
export let map = fn <T, U, E>(res: Result<T, E>, f: (val: T) -> U) -> Result<U, E> do
  match res do
    | Ok(val: v) -> return Ok(val: f(val: v))
    | Err(err: e) -> return Err(err: e)
  end
end

/// Transforms the Err value using f, leaving Ok unchanged.
export let map_err = fn <T, E, F>(res: Result<T, E>, f: (val: E) -> F) -> Result<T, F> do
  match res do
    | Ok(val: v) -> return Ok(val: v)
    | Err(err: e) -> return Err(err: f(val: e))
  end
end

/**
 * Chains a fallible operation on the Ok value (monadic bind).
 * If res is Ok, applies f to the value and returns its result.
 * If res is Err, propagates the error unchanged.
 * Enables flat composition: and_then(parse(s), validate) avoids
 * nested Result<Result<T, E>, E>.
 */
export let and_then = fn <T, U, E>(res: Result<T, E>, f: (val: T) -> Result<U, E>) -> Result<U, E> do
  match res do
    | Ok(val: v) -> return f(val: v)
    | Err(err: e) -> return Err(err: e)
  end
end

/// Wraps a caught exception as Err.
export let from_exn = fn <T>(exn: Exn) -> Result<T, Exn> do
  return Err(err: exn)
end

/// Unwraps Ok or re-raises the Exn error.
export let to_exn = fn <T>(res: Result<T, Exn>) -> T throws { Exn } do
  match res do
    | Ok(val: v) -> return v
    | Err(err: e) -> raise e
  end
end
