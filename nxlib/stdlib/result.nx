pub type Result<T, E> = Ok(val: T) | Err(err: E)

pub let is_ok = fn <T, E>(res: Result<T, E>) -> bool do
  match res do
    case Ok(val: _) -> return true
    case Err(err: _) -> return false
  endmatch
endfn

pub let is_err = fn <T, E>(res: Result<T, E>) -> bool do
  match res do
    case Ok(val: _) -> return false
    case Err(err: _) -> return true
  endmatch
endfn

pub let unwrap_or = fn <T, E>(res: Result<T, E>, default: T) -> T do
  match res do
    case Ok(val: v) -> return v
    case Err(err: _) -> return default
  endmatch
endfn

pub let map = fn <T, U, E>(res: Result<T, E>, f: (val: T) -> U) -> Result<U, E> do
  match res do
    case Ok(val: v) ->
      let mapped = f(val: v)
      return Ok(val: mapped)
    case Err(err: e) -> return Err(err: e)
  endmatch
endfn

pub let map_err = fn <T, E, F>(res: Result<T, E>, f: (val: E) -> F) -> Result<T, F> do
  match res do
    case Ok(val: v) -> return Ok(val: v)
    case Err(err: e) ->
      let mapped = f(val: e)
      return Err(err: mapped)
  endmatch
endfn

pub let and_then = fn <T, U, E>(res: Result<T, E>, f: (val: T) -> Result<U, E>) -> Result<U, E> do
  match res do
    case Ok(val: v) -> return f(val: v)
    case Err(err: e) -> return Err(err: e)
  endmatch
endfn

pub let from_exn = fn <T>(exn: Exn) -> Result<T, Exn> do
  return Err(err: exn)
endfn

pub let to_exn = fn <T>(res: Result<T, Exn>) -> T effect { Exn } do
  match res do
    case Ok(val: v) -> return v
    case Err(err: e) -> raise e
  endmatch
endfn
