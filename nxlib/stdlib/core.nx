/**
 * core: Prelude — utility types and functions.
 *
 * Canonical locations: Pair in tuple.nx, Partition in list.nx,
 * negate in math.nx.  core.nx keeps copies for backwards compatibility.
 */

import external stdlib/stdlib.wasm

/// A pair of two values.
pub type Pair<A, B> = Pair(left: A, right: B)

/// Returns the first element of a pair.
pub let fst = fn <A, B>(p: Pair<A, B>) -> A do
  match p do
    case Pair(left: l, _) -> return l
  end
end

/// Returns the second element of a pair.
pub let snd = fn <A, B>(p: Pair<A, B>) -> B do
  match p do
    case Pair(right: r, _) -> return r
  end
end

/// Result of partitioning: elements matching the predicate and the rest.
pub type Partition<T> = Partition(matched: [ T ], rest: [ T ])

/// Negates a boolean value.
pub let negate = fn (val: bool) -> bool do
  if val then
    return false
  else
    return true
  end
end

/// Identity function: returns its argument unchanged.
pub let id = fn <T>(val: T) -> T do
  return val
end
