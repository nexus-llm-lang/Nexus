/**
 * simd: 128-bit fixed-width SIMD primitives + an autovectorized array-add.
 *
 * The compiler (codegen.nx) recognises `nexus:runtime/simd` externals and
 * inline-emits the corresponding WASM SIMD op sequence (v128.load → lane-op →
 * v128.store), so these declarations carry no import-section overhead.
 *
 * Lane shapes covered: `f32x4` (four 32-bit floats per quad), `f64x2` (two
 * 64-bit floats), `i32x4` (four 32-bit ints), `i64x2` (two 64-bit ints).
 * Each `_add` / `_mul` primitive operates on one quad at a time and writes
 * 16 bytes to `dst_addr`. Pointers are i64 across the FFI boundary, truncated
 * to i32 inside the intrinsic.
 *
 * Autovectorize: `f32x4_add_array(a, b, dst, n)` expands to a SIMD loop that
 * processes `n` quads of 4 floats each — the vectorized form of the scalar
 * loop `for i in 0..(n*4): dst[i] = a[i] + b[i]`. Use this primitive in place
 * of a hand-written scalar loop when the source/dest are 16-byte aligned and
 * the element count is a multiple of 4.
 *
 * Alignment: `v128.load` / `v128.store` accept any address but emit align=4
 * (16-byte). Mis-aligned access is well-defined per the SIMD spec but may
 * be slower on engines that fast-path aligned cases.
 *
 * Target gating: WebAssembly SIMD is part of the WebAssembly 2.0 baseline
 * and is enabled by default in wasmtime 13+. Engines lacking simd128 will
 * reject the produced module at validation time — there is no runtime
 * feature probe. For environments without simd128, use the `scalar_*_array`
 * helpers below as the explicit non-SIMD fallback for the integer lane
 * shapes (no inline-WASM dispatch; runs as an ordinary Nexus loop through
 * `std:runtime/mem`). The compiler also rewrites `scalar_*_array` calls to
 * the matching SIMD intrinsic when both are in scope (see the autovectorize
 * pass in `src/ir/lir_opt.nx`), so source code can be written against the
 * scalar shape and still emit SIMD bytes.
 */
import external "nexus:runtime/simd"
import * as mem from "std:runtime/mem"

// ─── 1-quad lane-wise primitives ────────────────────────────────────────────
// Each takes three i64 addresses and writes 16 bytes to `dst_addr`. Reads of
// `a_addr` / `b_addr` are 16 bytes each. Returns unit; the side-effect is the
// store to `dst_addr`.

/// Lane-wise f32 add over four 32-bit floats: dst[0..16] = a[0..16] + b[0..16]
/// interpreted as four f32 lanes.
export external f32x4_add = "__nx_simd_f32x4_add"
  : (a_addr: i64, b_addr: i64, dst_addr: i64) -> unit

/// Lane-wise f32 mul over four 32-bit floats.
export external f32x4_mul = "__nx_simd_f32x4_mul"
  : (a_addr: i64, b_addr: i64, dst_addr: i64) -> unit

/// Lane-wise f64 add over two 64-bit floats.
export external f64x2_add = "__nx_simd_f64x2_add"
  : (a_addr: i64, b_addr: i64, dst_addr: i64) -> unit

/// Lane-wise f64 mul over two 64-bit floats.
export external f64x2_mul = "__nx_simd_f64x2_mul"
  : (a_addr: i64, b_addr: i64, dst_addr: i64) -> unit

/// Lane-wise i32 add over four 32-bit integers (wrapping arithmetic).
export external i32x4_add = "__nx_simd_i32x4_add"
  : (a_addr: i64, b_addr: i64, dst_addr: i64) -> unit

/// Lane-wise i32 mul over four 32-bit integers (wrapping arithmetic).
export external i32x4_mul = "__nx_simd_i32x4_mul"
  : (a_addr: i64, b_addr: i64, dst_addr: i64) -> unit

/// Lane-wise i64 add over two 64-bit integers (wrapping arithmetic).
export external i64x2_add = "__nx_simd_i64x2_add"
  : (a_addr: i64, b_addr: i64, dst_addr: i64) -> unit

/// Lane-wise i64 mul over two 64-bit integers (wrapping arithmetic).
export external i64x2_mul = "__nx_simd_i64x2_mul"
  : (a_addr: i64, b_addr: i64, dst_addr: i64) -> unit

// ─── Autovectorized array primitives ────────────────────────────────────────
// Each array intrinsic expands to a wasm loop that processes one quad per
// turn with the named lane-op — equivalent to the scalar loop
//   for i in 0..(n_quads * lanes_per_quad): dst[i] = a[i] OP b[i]
// but emits a single SIMD instruction per quad.
//
// `div` is float-only: WebAssembly SIMD lacks a per-lane integer division
// opcode (`i32x4.div_*` / `i64x2.div_*` do not exist in the proposal), so
// `i32x4_div_array` / `i64x2_div_array` are not provided. Callers needing
// per-lane integer division must scalarize.

/// Autovectorized element-wise f32 add: `n_quads` × 4 floats per region.
export external f32x4_add_array = "__nx_simd_f32x4_add_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise f32 mul.
export external f32x4_mul_array = "__nx_simd_f32x4_mul_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise f32 sub: dst[i] = a[i] - b[i].
export external f32x4_sub_array = "__nx_simd_f32x4_sub_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise f32 div: dst[i] = a[i] / b[i] (IEEE 754).
export external f32x4_div_array = "__nx_simd_f32x4_div_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise f64 add: `n_quads` × 2 doubles per region.
export external f64x2_add_array = "__nx_simd_f64x2_add_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise f64 mul: `n_quads` × 2 doubles per region.
export external f64x2_mul_array = "__nx_simd_f64x2_mul_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise f64 sub.
export external f64x2_sub_array = "__nx_simd_f64x2_sub_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise f64 div (IEEE 754).
export external f64x2_div_array = "__nx_simd_f64x2_div_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise i32 add over `n_quads` × 4 lanes — pair with
/// `scalar_i32_add_array` as the byte-equal reference when validating SIMD
/// output against the non-SIMD fallback.
export external i32x4_add_array = "__nx_simd_i32x4_add_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise i32 mul (wrapping arithmetic).
export external i32x4_mul_array = "__nx_simd_i32x4_mul_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise i32 sub (wrapping arithmetic).
export external i32x4_sub_array = "__nx_simd_i32x4_sub_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise i64 add (wrapping arithmetic).
export external i64x2_add_array = "__nx_simd_i64x2_add_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise i64 mul (wrapping arithmetic).
export external i64x2_mul_array = "__nx_simd_i64x2_mul_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

/// Autovectorized element-wise i64 sub (wrapping arithmetic).
export external i64x2_sub_array = "__nx_simd_i64x2_sub_array"
  : (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit

// ─── Scalar fallbacks ───────────────────────────────────────────────────────
// Each `scalar_*_array` helper is the non-SIMD reference for the matching
// `*x*_*_array` SIMD primitive. They walk `n_quads * lanes_per_quad` integer
// lanes via plain `std:runtime/mem` ops and never emit 0xFD-prefixed bytes.
// Two purposes:
//   (a) explicit non-SIMD path for engines lacking simd128
//   (b) byte-equal reference for validating the SIMD output
//
// The autovectorize pass in `src/ir/lir_opt.nx` substitutes `scalar_*_array`
// calls with their SIMD twin when the SIMD external is in scope, so source
// code can be written against the scalar shape and still emit SIMD bytes.
//
// Float (f32 / f64) scalar fallbacks are not provided: the stdlib lacks
// `mem.load_f32` / `store_f32` primitives, so a bitwise-identical f32 / f64
// reference loop cannot be expressed here without new mem ops. Callers
// needing f32 / f64 fallback must route through `std:math` (host-side f64)
// or stay on the SIMD path and let the engine reject the module if simd128
// is missing.

let scalar_i32_add_step = fn (a_addr: i64, b_addr: i64, d_addr: i64, count: i64) -> unit do
  if count <= 0 then return () end
  let av = mem.load_i32(addr: a_addr)
  let bv = mem.load_i32(addr: b_addr)
  let _ = mem.store_i32(addr: d_addr, val: av + bv)
  return scalar_i32_add_step(a_addr: a_addr + 4, b_addr: b_addr + 4, d_addr: d_addr + 4, count: count - 1)
end

/// Scalar (non-SIMD) fallback for `i32x4_add` over an array. Walks
/// `n_quads * 4` 32-bit ints via plain `std:runtime/mem` ops; never emits
/// 0xFD-prefixed bytes. Caller is responsible for choosing this over the
/// SIMD primitive when the engine lacks simd128.
export let scalar_i32_add_array = fn (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit do
  return scalar_i32_add_step(a_addr, b_addr, d_addr: dst_addr, count: n_quads * 4)
end

let scalar_i32_mul_step = fn (a_addr: i64, b_addr: i64, d_addr: i64, count: i64) -> unit do
  if count <= 0 then return () end
  let av = mem.load_i32(addr: a_addr)
  let bv = mem.load_i32(addr: b_addr)
  let _ = mem.store_i32(addr: d_addr, val: av * bv)
  return scalar_i32_mul_step(a_addr: a_addr + 4, b_addr: b_addr + 4, d_addr: d_addr + 4, count: count - 1)
end

/// Scalar fallback for `i32x4_mul_array`. dst[i] = a[i] * b[i], wrapping
/// arithmetic over `n_quads * 4` 32-bit lanes.
export let scalar_i32_mul_array = fn (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit do
  return scalar_i32_mul_step(a_addr, b_addr, d_addr: dst_addr, count: n_quads * 4)
end

let scalar_i32_sub_step = fn (a_addr: i64, b_addr: i64, d_addr: i64, count: i64) -> unit do
  if count <= 0 then return () end
  let av = mem.load_i32(addr: a_addr)
  let bv = mem.load_i32(addr: b_addr)
  let _ = mem.store_i32(addr: d_addr, val: av - bv)
  return scalar_i32_sub_step(a_addr: a_addr + 4, b_addr: b_addr + 4, d_addr: d_addr + 4, count: count - 1)
end

/// Scalar fallback for `i32x4_sub_array`. dst[i] = a[i] - b[i], wrapping
/// arithmetic over `n_quads * 4` 32-bit lanes.
export let scalar_i32_sub_array = fn (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit do
  return scalar_i32_sub_step(a_addr, b_addr, d_addr: dst_addr, count: n_quads * 4)
end

let scalar_i64_add_step = fn (a_addr: i64, b_addr: i64, d_addr: i64, count: i64) -> unit do
  if count <= 0 then return () end
  let av = mem.load_i64(addr: a_addr)
  let bv = mem.load_i64(addr: b_addr)
  let _ = mem.store_i64(addr: d_addr, val: av + bv)
  return scalar_i64_add_step(a_addr: a_addr + 8, b_addr: b_addr + 8, d_addr: d_addr + 8, count: count - 1)
end

/// Scalar fallback for `i64x2_add_array`. dst[i] = a[i] + b[i], wrapping
/// arithmetic over `n_quads * 2` 64-bit lanes.
export let scalar_i64_add_array = fn (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit do
  return scalar_i64_add_step(a_addr, b_addr, d_addr: dst_addr, count: n_quads * 2)
end

let scalar_i64_mul_step = fn (a_addr: i64, b_addr: i64, d_addr: i64, count: i64) -> unit do
  if count <= 0 then return () end
  let av = mem.load_i64(addr: a_addr)
  let bv = mem.load_i64(addr: b_addr)
  let _ = mem.store_i64(addr: d_addr, val: av * bv)
  return scalar_i64_mul_step(a_addr: a_addr + 8, b_addr: b_addr + 8, d_addr: d_addr + 8, count: count - 1)
end

/// Scalar fallback for `i64x2_mul_array`. dst[i] = a[i] * b[i], wrapping
/// arithmetic over `n_quads * 2` 64-bit lanes.
export let scalar_i64_mul_array = fn (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit do
  return scalar_i64_mul_step(a_addr, b_addr, d_addr: dst_addr, count: n_quads * 2)
end

let scalar_i64_sub_step = fn (a_addr: i64, b_addr: i64, d_addr: i64, count: i64) -> unit do
  if count <= 0 then return () end
  let av = mem.load_i64(addr: a_addr)
  let bv = mem.load_i64(addr: b_addr)
  let _ = mem.store_i64(addr: d_addr, val: av - bv)
  return scalar_i64_sub_step(a_addr: a_addr + 8, b_addr: b_addr + 8, d_addr: d_addr + 8, count: count - 1)
end

/// Scalar fallback for `i64x2_sub_array`. dst[i] = a[i] - b[i], wrapping
/// arithmetic over `n_quads * 2` 64-bit lanes.
export let scalar_i64_sub_array = fn (a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64) -> unit do
  return scalar_i64_sub_step(a_addr, b_addr, d_addr: dst_addr, count: n_quads * 2)
end
