/**
 * proc: Process lifecycle, arguments, and subprocess execution.
 *
 * Provides Proc port with exit, argv, and exec operations.
 * Requires PermProc capability.
 *
 * For environment variable operations, use nxlib/stdlib/env.nx.
 */
import external "std:proc"
import { split as str_split } from "std:str"
import * as bb from "std:bytebuffer"
import { ByteBuffer } from "std:bytebuffer"

external __nx_exit = "__nx_exit" : (status: i64) -> unit
external __nx_argv = "__nx_argv" : () -> string
external __nx_exec = "__nx_exec" : (cmd: string, args: string) -> i64
external __nx_exec_exit_code = "__nx_exec_exit_code" : (id: i64) -> i64
external __nx_exec_stdout = "__nx_exec_stdout" : (id: i64) -> string
external __nx_exec_stderr = "__nx_exec_stderr" : (id: i64) -> string
external __nx_exec_free = "__nx_exec_free" : (id: i64) -> bool

/// Result of a subprocess execution.
export type ExecResult = ExecResult(exit_code: i64, stdout: string, stderr: string)

/// Terminates the process with the given exit code.
export let exit = fn (status: i64) -> unit do
  return __nx_exit(status)
end

/// Returns the command-line arguments as a list of strings.
/// Exported: used by compiler for main(args) desugaring.
export let argv = fn () -> [ string ] do
  return str_split(s: __nx_argv(), sep: "\n")
end

/// Pushes the tail of an arg list into the buffer, prefixing each element
/// with a newline separator. Caller must have already pushed the head.
let join_args_tail = fn (buf: %ByteBuffer, args: [ string ]) -> %ByteBuffer do
  match args do
    | [] -> return buf
    | v :: rest ->
      let %buf = bb.push_string(%buf, s: "\n")
      let %buf = bb.push_string(%buf, s: v)
      return join_args_tail(buf: %buf, args: rest)
  end
end

/// Joins a list of strings with newlines for passing to __nx_exec.
let join_args = fn (args: [ string ]) -> string do
  match args do
    | [] -> return ""
    | v :: rest ->
      let buf = bb.empty()
      let %buf = bb.push_string(%buf, s: v)
      let %buf = join_args_tail(buf: %buf, args: rest)
      let result = bb.to_string(&buf)
      bb.free(%buf)
      return result
  end
end

/// Executes a command with arguments. Returns an ExecResult.
export let exec = fn (cmd: string, args: [ string ]) -> ExecResult do
  let args_str = join_args(args)
  let id = __nx_exec(cmd, args: args_str)
  let code = __nx_exec_exit_code(id)
  let out = __nx_exec_stdout(id)
  let err = __nx_exec_stderr(id)
  let _ = __nx_exec_free(id)
  return ExecResult(exit_code: code, stdout: out, stderr: err)
end

export cap Proc do
  fn exit(status: i64) -> unit
  fn argv() -> [ string ]
  fn exec(cmd: string, args: [ string ]) -> ExecResult
end

export let system_handler = handler Proc require { PermProc } do
  fn exit(status: i64) -> unit do
    return __nx_exit(status)
  end
  fn argv() -> [ string ] do
    return argv()
  end
  fn exec(cmd: string, args: [ string ]) -> ExecResult do
    return exec(cmd, args)
  end
end
