/**
 * proc: Process lifecycle, arguments, and subprocess execution.
 *
 * Provides Proc port with exit, argv, and exec operations.
 * Requires PermProc capability.
 *
 * For environment variable operations, use nxlib/stdlib/env.nx.
 */
import external stdlib/stdlib.wasm
import { split, length } from stdlib/string.nx

external __nx_exit = "__nx_exit" : (status: i64) -> unit
external __nx_argv = "__nx_argv" : () -> string
external __nx_exec = "__nx_exec" : (cmd: string, args: string) -> i64
external __nx_exec_exit_code = "__nx_exec_exit_code" : (id: i64) -> i64
external __nx_exec_stdout = "__nx_exec_stdout" : (id: i64) -> string
external __nx_exec_stderr = "__nx_exec_stderr" : (id: i64) -> string
external __nx_exec_free = "__nx_exec_free" : (id: i64) -> i64

/// Result of a subprocess execution.
pub type ExecResult = ExecResult(exit_code: i64, stdout: string, stderr: string)

/// Terminates the process with the given exit code.
pub let exit = fn (status: i64) -> unit require { PermProc } do
  return __nx_exit(status: status)
end

/// Returns the command-line arguments as a list of strings.
pub let argv = fn () -> [ string ] require { PermProc } do
  let raw = __nx_argv()
  return split(s: raw, sep: "\n")
end

/// Joins a list of strings with newlines for passing to __nx_exec.
let join_args = fn (args: [ string ], acc: string) -> string do
  match args do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) ->
      if length(s: acc) == 0 then
        return join_args(args: rest, acc: v)
      else
        return join_args(args: rest, acc: acc ++ "\n" ++ v)
      end
  end
end

/// Executes a command with arguments. Returns an ExecResult.
pub let exec = fn (cmd: string, args: [ string ]) -> ExecResult require { PermProc } do
  let args_str = join_args(args: args, acc: "")
  let id = __nx_exec(cmd: cmd, args: args_str)
  let code = __nx_exec_exit_code(id: id)
  let out = __nx_exec_stdout(id: id)
  let err = __nx_exec_stderr(id: id)
  let _ = __nx_exec_free(id: id)
  return ExecResult(exit_code: code, stdout: out, stderr: err)
end

pub port Proc do
  fn exit(status: i64) -> unit
  fn argv() -> [ string ]
  fn exec(cmd: string, args: [ string ]) -> ExecResult
end

pub let system_handler = handler Proc require { PermProc } do
  fn exit(status: i64) -> unit do
    return __nx_exit(status: status)
  end
  fn argv() -> [ string ] do
    return argv()
  end
  fn exec(cmd: string, args: [ string ]) -> ExecResult do
    return exec(cmd: cmd, args: args)
  end
end
