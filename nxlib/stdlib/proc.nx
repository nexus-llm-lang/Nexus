/**
 * proc: Process lifecycle, arguments, and subprocess execution.
 *
 * Provides Proc port with exit, argv, and exec operations.
 * Requires PermProc capability.
 *
 * For environment variable operations, use nxlib/stdlib/env.nx.
 *
 * Subprocess (`exec`): WASI preview1 (forced here by `-S threads`) provides no
 * subprocess-spawn API, so this cannot be implemented at this layer; it needs
 * a preview2 runtime path or a host embedder. The `exec_*` primitives
 * return the error sentinel (-1 / empty / false), so `Proc.exec` surfaces a
 * clean error (an `ExecResult` with exit_code -1, empty stdout/stderr) rather
 * than trapping.
 */
import { split as str_split } from "std:str"
import * as bb from "std:bytebuffer"
import { ByteBuffer } from "std:bytebuffer"
import { exit_proc, argv_str } from "std:runtime/sysio"

/// Result of a subprocess execution.
export type ExecResult = ExecResult(exit_code: i64, stdout: string, stderr: string)

// --- subprocess: unimplementable on WASI preview1 ---
// WASI preview1 (forced by `-S threads`) has no subprocess-spawn API; a real
// impl needs a preview2 runtime path or a host embedder. These return the
// error sentinel so `Proc.exec` surfaces a clean error.
let exec_impl = fn (cmd: string, args: string) -> i64 do return 0 - 1 end
let exec_exit_code = fn (id: i64) -> i64 do return 0 - 1 end
let exec_stdout = fn (id: i64) -> string do return "" end
let exec_stderr = fn (id: i64) -> string do return "" end
let exec_free = fn (id: i64) -> bool do return false end

/// Terminates the process with the given exit code.
export let exit = fn (status: i64) -> unit do
  return exit_proc(status)
end

/// Returns the command-line arguments as a list of strings.
/// Exported: used by compiler for main(args) desugaring.
export let argv = fn () -> [ string ] do
  return str_split(s: argv_str(), sep: "\n")
end

/// Pushes the tail of an arg list into the buffer, prefixing each element
/// with a newline separator. Caller must have already pushed the head.
let join_args_tail = fn (buf: %ByteBuffer, args: [ string ]) -> %ByteBuffer do
  match args do
    | [] -> return buf
    | v :: rest ->
      let %buf = bb.push_string(%buf, s: "\n")
      let %buf = bb.push_string(%buf, s: v)
      return join_args_tail(%buf, args: rest)
  end
end

/// Joins a list of strings with newlines for passing to exec_impl.
let join_args = fn (args: [ string ]) -> string do
  match args do
    | [] -> return ""
    | v :: rest ->
      let buf = bb.empty()
      let %buf = bb.push_string(%buf, s: v)
      let %buf = join_args_tail(%buf, args: rest)
      let result = bb.to_string(&buf)
      bb.free(%buf)
      return result
  end
end

/// Executes a command with arguments. Returns an ExecResult.
export let exec = fn (cmd: string, args: [ string ]) -> ExecResult do
  let args_str = join_args(args)
  let id = exec_impl(cmd, args: args_str)
  let code = exec_exit_code(id)
  let out = exec_stdout(id)
  let err = exec_stderr(id)
  let _ = exec_free(id)
  return ExecResult(exit_code: code, stdout: out, stderr: err)
end

export cap Proc do
  fn exit(status: i64) -> unit
  fn argv() -> [ string ]
  fn exec(cmd: string, args: [ string ]) -> ExecResult
end

export let system_handler = handler Proc require { PermProc } do
  fn exit(status: i64) -> unit do
    return exit_proc(status)
  end
  fn argv() -> [ string ] do
    return argv()
  end
  fn exec(cmd: string, args: [ string ]) -> ExecResult do
    return exec(cmd, args)
  end
end
