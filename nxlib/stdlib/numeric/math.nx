/**
 * math: Integer and floating-point math operations.
 *
 * Integer ops (abs, max, min, mod_i64) are pure-Nexus implementations using
 * only the language's primitive operators — they emit a handful of inline
 * wasm instructions per call rather than crossing the host FFI boundary.
 * Float unary ops (sqrt, floor, ceil) delegate to runtime_math,
 * which the codegen recognises as `nexus:intrinsic` intrinsics and
 * inline-emits the corresponding f64 opcode.
 *
 * `i64`<->`float` conversions are implemented here by manual IEEE-754 bit
 * twiddling (truncation, no round-to-nearest-even): the wasm convert opcodes
 * are not exposed as `nexus:intrinsic` intrinsics. `pow` is a pure-Nexus
 * implementation: exact exponentiation-by-squaring for integer exponents,
 * exp(exp*ln(base)) via polynomial series for fractional ones (wasm has no
 * `f64.pow` opcode).
 */
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"
import * as fmath from "std:runtime/math"

/**
Raised by partial integer math operations on degenerate inputs (mod_i64
with divisor 0). `op` names the failing operation.
*/
export exception DivisionByZero(op: string)

/**
Returns the absolute value of an integer. For `i64::MIN`,
the unique fixed point of negation, returns `i64::MIN`
(matches Rust `i64::wrapping_abs` semantics).
*/
export let abs = fn (val: i64) -> i64 do
  if val < 0 then
    return 0 - val
  else
    return val
  end
end

/** Returns the larger of two integers. */
export let max = fn (a: i64, b: i64) -> i64 do
  if a >= b then
    return a
  else
    return b
  end
end

/** Returns the smaller of two integers. */
export let min = fn (a: i64, b: i64) -> i64 do
  if a <= b then
    return a
  else
    return b
  end
end

/**
Returns the remainder of integer division (a mod b).
Raises `DivisionByZero` when `b == 0`.
*/
export let mod_i64 = fn (a: i64, b: i64) -> i64 throws { DivisionByZero } do
  if b == 0 then
    throw DivisionByZero(op: "mod_i64")
  end
  return a % b
end

/** Returns the square root of a float. NaN for negative inputs. */
export let sqrt = fn (val: float) -> float do
  return fmath.sqrt(val)
end

/** Returns the largest integer not greater than the given float (round toward -inf). */
export let floor = fn (val: float) -> float do
  return fmath.floor(val)
end

/** Returns the smallest integer not less than the given float (round toward +inf). */
export let ceil = fn (val: float) -> float do
  return fmath.ceil(val)
end

/** i64::MIN, written as a parenthesised negation of a positive literal. */
let i64_min = (0 - 9223372036854775807) - 1
/** Reinterpret the 64 bits of `bits` as an f64 (round-trips via linear memory). */
let i64_bits_to_f64 = fn (bits: i64) -> float do
  let p = arena.alloc_raw(size: 8)
  mem.store_i64(addr: p, val: bits)
  return mem.load_f64(addr: p)
end

/** Reinterpret the 64 bits of `x` as an i64. */
let f64_to_i64_bits = fn (x: float) -> i64 do
  let p = arena.alloc_raw(size: 8)
  mem.store_f64(addr: p, val: x)
  return mem.load_i64(addr: p)
end

/** Logical (zero-filling) right shift by `n` (0 <= n < 64). */
let lshr = fn (v: i64, n: i64) -> i64 do
  if n == 0 then return v end
  let shifted = v >> n
  let mask = (1 << (63 - n)) - 1 + (1 << (63 - n))
  return shifted & mask
end

/** Position (0..63) of the highest set bit of `m` (m > 0). */
let high_bit = fn (m: i64) -> i64 do return high_bit_go(m, i: 63) end
let high_bit_go = fn (m: i64, i: i64) -> i64 do
  if i < 0 then return 0 end
  if lshr(v: m, n: i) & 1 == 1 then return i end
  return high_bit_go(m, i: i - 1)
end

/**
Converts an i64 to a float. Truncates dropped low mantissa bits toward zero
(no round-to-nearest-even); i64::MIN is handled as exactly -2^63.
*/
export let i64_to_float = fn (val: i64) -> float do
  if val == 0 then return 0.0 end
  if val == i64_min then
    // -2^63 = -9223372036854775808.0, whose f64 bit pattern is
    // 0xC3E0000000000000 (sign=1, biased exp=1086, mantissa=0). As a signed
    // i64 that bit pattern is -4332462841530417152. Feeding i64_min's own
    // pattern (0x8000000000000000) here would instead yield f64 -0.0.
    return i64_bits_to_f64(bits: (0 - 4332462841530417152))
  end
  let neg = val < 0
  let mag = if neg then 0 - val else val end
  let p = high_bit(m: mag)
  let mant = if p >= 52 then lshr(v: mag, n: p - 52) else mag << (52 - p) end
  let mant52 = mant & ((1 << 52) - 1)
  let biased = (1023 + p) << 52
  let sign = if neg then (1 << 63) else 0 end
  return i64_bits_to_f64(bits: sign + biased + mant52)
end

/**
Converts a float to an i64 (truncates toward zero). Best-effort for
NaN/inf/out-of-range (NaN -> 0; |x| beyond i64 range -> a large value,
not necessarily the saturated bound).
*/
export let float_to_i64 = fn (val: float) -> i64 do
  let bits = f64_to_i64_bits(x: val)
  let neg = lshr(v: bits, n: 63) & 1 == 1
  let biased = lshr(v: bits, n: 52) & 2047
  let frac = bits & ((1 << 52) - 1)
  if biased == 2047 then return 0 end
  if biased == 0 then return 0 end
  let unbiased = biased - 1023
  if unbiased < 0 then return 0 end
  let mant = frac + (1 << 52)
  let mag = if unbiased >= 52 then mant << (unbiased - 52) else lshr(v: mant, n: 52 - unbiased) end
  return if neg then 0 - mag else mag end
end

// --- pow: exact integer exponents by squaring; fractional via exp(exp*ln(base)) ---

/** ln(2), to f64 precision. */
let ln2 = 0.6931471805599453
/** 1/ln(2). */
let inv_ln2 = 1.4426950408889634
/** sqrt(2), the split point that keeps the ln series argument small. */
let sqrt2 = 1.4142135623730951
/** Logical right shift of `bits` by `n` (0 <= n < 64), reusing `lshr`. */
let bits_shr = fn (bits: i64, n: i64) -> i64 do return lshr(v: bits, n) end

/**
pow(b, n) for integer n >= 0 by exponentiation by squaring. Exact for
values that stay in range; sloppy on overflow (returns inf).
*/
let pow_int = fn (b: float, n: i64) -> float do
  if n == 0 then return 1.0 end
  if (n & 1) == 0 then
    let h = pow_int(b: b *. b, n: n / 2)
    return h
  else
    let h = pow_int(b: b *. b, n: (n - 1) / 2)
    return b *. h
  end
end

/** floor for f64 via truncation toward zero, adjusting down for negatives. */
let floor_f = fn (x: float) -> float do
  let t = i64_to_float(val: float_to_i64(val: x))
  if t >. x then return t -. 1.0 else return t end
end

/**
ln(x) for x > 0. Decomposes x = m * 2^k with m in [sqrt(1/2), sqrt(2)),
then ln(m) via the atanh series ln((1+t)/(1-t)) = 2(t + t^3/3 + ...).
*/
let ln_f = fn (x: float) -> float do
  if x <=. 0.0 then return 0.0 end
  let bits = f64_to_i64_bits(x)
  let raw_exp = bits_shr(bits, n: 52) & 2047
  let k0 = raw_exp - 1023
  let mant_bits = (bits & ((1 << 52) - 1)) | (1023 << 52)
  let m0 = i64_bits_to_f64(bits: mant_bits)
  let split = m0 >. sqrt2
  let m = if split then m0 /. 2.0 else m0 end
  let k = if split then k0 + 1 else k0 end
  let t = (m -. 1.0) /. (m +. 1.0)
  let t2 = t *. t
  let t3 = t2 *. t
  let t5 = t3 *. t2
  let t7 = t5 *. t2
  let t9 = t7 *. t2
  let t11 = t9 *. t2
  let series = t +. (t3 /. 3.0) +. (t5 /. 5.0) +. (t7 /. 7.0) +. (t9 /. 9.0) +. (t11 /. 11.0)
  let ln_m = 2.0 *. series
  return (i64_to_float(val: k) *. ln2) +. ln_m
end

/**
exp(y) for finite y. Range-reduces y = k*ln2 + r with |r| <= ln2/2, then
exp(r) by Taylor series, then scales by 2^k via direct bit construction.
*/
let exp_f = fn (y: float) -> float do
  let kf = floor_f(x: (y *. inv_ln2) +. 0.5)
  let k = float_to_i64(val: kf)
  let r = y -. (kf *. ln2)
  let r2 = r *. r
  let r3 = r2 *. r
  let r4 = r2 *. r2
  let r5 = r4 *. r
  let r6 = r4 *. r2
  let r7 = r6 *. r
  let exp_r = 1.0 +. r +. (r2 /. 2.0) +. (r3 /. 6.0) +. (r4 /. 24.0)
              +. (r5 /. 120.0) +. (r6 /. 720.0) +. (r7 /. 5040.0)
  let biased = k + 1023
  if biased <= 0 then return 0.0 end
  if biased >= 2047 then return exp_r *. 1.0e308 *. 1.0e308 end
  let two_k = i64_bits_to_f64(bits: biased << 52)
  return exp_r *. two_k
end

/**
Returns base raised to the power of exp. Integer exponents are computed
exactly by exponentiation by squaring; fractional exponents go through
exp(exp * ln(base)) using polynomial approximations of ln and exp (so
accurate to roughly f64 precision, not bit-exact). Negative bases are
only meaningful for integer exponents (sign follows parity); a negative
base with a fractional exponent returns 0.0.
*/
let pow = fn (base: float, exp: float) -> float do
  if exp ==. 0.0 then return 1.0 end
  if base ==. 1.0 then return 1.0 end
  if base ==. 0.0 then return 0.0 end
  if base <. 0.0 then
    let n = float_to_i64(val: exp)
    let is_int = i64_to_float(val: n) ==. exp
    if !is_int then return 0.0 end
    let r = pow(base: 0.0 -. base, exp)
    if (n & 1) != 0 then return 0.0 -. r else return r end
  end
  // base > 0
  let n = float_to_i64(val: exp)
  let is_int = i64_to_float(val: n) ==. exp
  if is_int then
    if n >= 0 then return pow_int(b: base, n) end
    return 1.0 /. pow_int(b: base, n: 0 - n)
  end
  return exp_f(y: exp *. ln_f(x: base))
end

/** Negates a boolean value. */
export let negate = fn (val: bool) -> bool do
  if val then
    return false
  else
    return true
  end
end
