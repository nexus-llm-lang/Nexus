/**
 * env: Environment variable operations.
 *
 * Provides Env port with get and set operations.
 * get returns Option<string> — None when the variable is not set; Some("")
 * when it is set to an empty string.
 * Requires PermEnv capability.
 */
import external "stdlib/stdlib.wasm"
import { Option } from "stdlib/option.nx"

external __nx_get_env = "__nx_get_env" : (key: string) -> string
external __nx_has_env = "__nx_has_env" : (key: string) -> bool
external __nx_set_env = "__nx_set_env" : (key: string, value: string) -> unit

export cap Env do
  fn get(key: string) -> Option<string>
  fn set(key: string, value: string) -> unit
end

export let system_handler = handler Env require { PermEnv } do
  fn get(key: string) -> Option<string> do
    if __nx_has_env(key: key) then
      return Some(val: __nx_get_env(key: key))
    else
      return None
    end
  end
  fn set(key: string, value: string) -> unit do
    return __nx_set_env(key: key, value: value)
  end
end
