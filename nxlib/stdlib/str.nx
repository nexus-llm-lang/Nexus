/**
 * string: String inspection and manipulation functions.
 *
 * The `string_*` byte-level primitives are implemented here directly
 * (UTF-8 aware, ASCII-fast). They keep the historical `(ptr, len) -> packed`
 * shape internally; the public surface wraps them, decomposing a Nexus
 * `string` (a packed i64 `(ptr << 32) | len`) at the call boundary via the
 * `nexus:intrinsic` type-pun intrinsic and re-tagging packed results.
 *
 * Caveats:
 *   - to_lower/to_upper: ASCII only (no Unicode case folding).
 *   - trim: ASCII whitespace (space, tab, \n, \r) only.
 *   - pad_left/pad_right: fill is cycled byte-by-byte; exact only when fill is
 *     ASCII (the universal case). Pad amount is computed in characters.
 *   - from_char/from_char_code: no surrogate/range validation -- encodes the
 *     low bits as UTF-8; negative inputs return "".
 *   - from_float: extracts ~17 significant digits (not a shortest-repr dtoa),
 *     trims trailing zeros, fixed notation for exponents in [-4, 17) else
 *     scientific. Round-trips, but the text may differ from Rust's Display.
 *   - to_f64 / is_valid_f64: full `[+-]?(d('.'d?)?|'.'d)([eE][+-]?d)?` grammar
 *     plus case-insensitive inf/infinity/nan; scaling via repeated *10 so the
 *     last ulp or two can be off for extreme exponents.
 */
import * as mem from "std:runtime/mem"
import * as cast from "std:runtime/cast"
import * as arena from "std:runtime/arena"
import { i64_to_float, float_to_i64 } from "std:math"
import external "nexus:intrinsic"

/**
Raised when `to_i64` is given a string that does not parse as an i64.
`s` is the rejected input.
*/
export exception InvalidI64(s: string)

/** Raised when `to_f64` is given a string that does not parse as an f64. */
export exception InvalidF64(s: string)

/** Group covering both string-number parse failures. */
export exception group StringParseError = InvalidI64 | InvalidF64

/** Type puns (pure passthrough at the WASM level — every Nexus value is an i64). */
external pun_i64 = "value_of_i64" : <T>(a_x: T) -> i64
external pun_val = "value_of_i64" : <T>(a_x: i64) -> T

/** 2^32 -- multiplier to pack a (ptr, len) pair into a returned string i64. */
let two_pow_32 = 4294967296
let s_ptr = fn (s: string) -> i32 do return cast.i32_of(x: (pun_i64(a_x: s) / two_pow_32) & 4294967295) end
let s_len = fn (s: string) -> i32 do return cast.i32_of(x: pun_i64(a_x: s) & 4294967295) end
let to_str = fn (packed: i64) -> string do return pun_val(a_x: packed) end

// --- byte helpers ---

let byte_at_addr = fn (base: i64, i: i64) -> i64 do return mem.load_u8(addr: base + i) end
let load_at = fn (a: i64) -> i64 do return mem.load_u8(addr: a) end
let store_at = fn (a: i64, v: i64) -> unit do return mem.store_u8(addr: a, val: v & 255) end
let put_byte = fn (base: i64, i: i64, v: i64) -> unit do return mem.store_u8(addr: base + i, val: v & 255) end

let copy_bytes = fn (dst: i64, src: i64, count: i64) -> unit do return copy_bytes_at(dst, src, count, i: 0) end
let copy_bytes_at = fn (dst: i64, src: i64, count: i64, i: i64) -> unit do
  if i >= count then return () end
  let _ = mem.store_u8(addr: dst + i, val: mem.load_u8(addr: src + i))
  return copy_bytes_at(dst, src, count, i: i + 1)
end

/** Allocate `n` bytes; return the byte offset (0 when n <= 0 -- empty result). */
let alloc_bytes = fn (n: i64) -> i64 do
  if n <= 0 then return 0 end
  return arena.alloc_raw(size: n)
end

/** Pack a (ptr, len) pair into the string return i64. */
let pack = fn (ptr: i64, len: i64) -> i64 do
  if len <= 0 then return 0 end
  return (ptr * two_pow_32) + len
end

/** Allocate and copy `len` bytes from `src` into a fresh region; return packed. */
let make_string = fn (src: i64, len: i64) -> i64 do
  if len <= 0 then return 0 end
  let p = alloc_bytes(n: len)
  let _ = copy_bytes(dst: p, src, count: len)
  return pack(ptr: p, len)
end

// --- UTF-8 helpers ---

/** UTF-8 sequence length implied by lead byte `b` (1..4). */
let seq_len = fn (b: i64) -> i64 do
  if b < 128 then return 1 end
  if b < 224 then return 2 end
  if b < 240 then return 3 end
  return 4
end

/** Count characters in [base, base+len): bytes whose top two bits != 10. */
let char_count = fn (base: i64, len: i64) -> i64 do return char_count_go(base, len, i: 0, n: 0) end
let char_count_go = fn (base: i64, len: i64, i: i64, n: i64) -> i64 do
  if i >= len then return n end
  let b = byte_at_addr(base, i)
  let add = if (b & 192) != 128 then 1 else 0 end
  return char_count_go(base, len, i: i + 1, n: n + add)
end

/**
Byte offset of character index `ci` (clamped to [0, len]). If `ci` is past
the end, returns `len`.
*/
let char_to_byte = fn (base: i64, len: i64, ci: i64) -> i64 do
  if ci <= 0 then return 0 end
  return char_to_byte_go(base, len, remaining: ci, i: 0)
end
let char_to_byte_go = fn (base: i64, len: i64, remaining: i64, i: i64) -> i64 do
  if i >= len then return len end
  if remaining <= 0 then return i end
  let step = seq_len(b: byte_at_addr(base, i))
  return char_to_byte_go(base, len, remaining: remaining - 1, i: i + step)
end

/**
Decode the codepoint of the UTF-8 sequence starting at byte offset `i`
(assumes `i` is a valid lead-byte position and the sequence fits).
*/
let decode_cp = fn (base: i64, i: i64) -> i64 do
  let b0 = byte_at_addr(base, i)
  if b0 < 128 then return b0 end
  let b1 = byte_at_addr(base, i: i + 1) & 63
  if b0 < 224 then return ((b0 & 31) * 64) + b1 end
  let b2 = byte_at_addr(base, i: i + 2) & 63
  if b0 < 240 then return ((b0 & 15) * 4096) + (b1 * 64) + b2 end
  let b3 = byte_at_addr(base, i: i + 3) & 63
  return ((b0 & 7) * 262144) + (b1 * 4096) + (b2 * 64) + b3
end

/** Number of UTF-8 bytes needed to encode codepoint `cp` (cp >= 0). */
let enc_len = fn (cp: i64) -> i64 do
  if cp < 128 then return 1 end
  if cp < 2048 then return 2 end
  if cp < 65536 then return 3 end
  return 4
end

/** Encode codepoint `cp` as UTF-8 into [base, base+enc_len(cp)). */
let encode_cp = fn (base: i64, cp: i64) -> unit do
  if cp < 128 then return put_byte(base, i: 0, v: cp) end
  if cp < 2048 then
    let _ = put_byte(base, i: 0, v: 192 + (cp / 64))
    return put_byte(base, i: 1, v: 128 + (cp & 63))
  end
  if cp < 65536 then
    let _ = put_byte(base, i: 0, v: 224 + (cp / 4096))
    let _ = put_byte(base, i: 1, v: 128 + ((cp / 64) & 63))
    return put_byte(base, i: 2, v: 128 + (cp & 63))
  end
  let _ = put_byte(base, i: 0, v: 240 + (cp / 262144))
  let _ = put_byte(base, i: 1, v: 128 + ((cp / 4096) & 63))
  let _ = put_byte(base, i: 2, v: 128 + ((cp / 64) & 63))
  return put_byte(base, i: 3, v: 128 + (cp & 63))
end

// --- ASCII predicates ---

let is_ws = fn (b: i64) -> bool do return b == 32 || b == 9 || b == 10 || b == 13 end
let is_digit_byte = fn (b: i64) -> bool do return b >= 48 && b <= 57 end
let is_alpha_byte = fn (b: i64) -> bool do return (b >= 65 && b <= 90) || (b >= 97 && b <= 122) end
let is_ident_byte = fn (b: i64) -> bool do return is_alpha_byte(b) || is_digit_byte(b) || b == 95 end

let to_lower_byte = fn (b: i64) -> i64 do if b >= 65 && b <= 90 then return b + 32 else return b end end
let to_upper_byte = fn (b: i64) -> i64 do if b >= 97 && b <= 122 then return b - 32 else return b end end

/** Clamp `v` to [0, hi]. */
let clamp = fn (v: i64, hi: i64) -> i64 do
  let lo = if v < 0 then 0 else v end
  return if lo > hi then hi else lo end
end

// --- substring search (byte-level, naive) ---

let mem_eq_at = fn (base: i64, at: i64, sb: i64, slen: i64) -> bool do return mem_eq_at_go(base, at, sb, slen, i: 0) end
let mem_eq_at_go = fn (base: i64, at: i64, sb: i64, slen: i64, i: i64) -> bool do
  if i >= slen then return true end
  if load_at(a: base + at + i) != load_at(a: sb + i) then return false end
  return mem_eq_at_go(base, at, sb, slen, i: i + 1)
end

let find_sub = fn (base: i64, len: i64, sb: i64, slen: i64, start_at: i64) -> i64 do
  if slen <= 0 then return start_at end
  return find_sub_go(base, len, sb, slen, i: start_at)
end
let find_sub_go = fn (base: i64, len: i64, sb: i64, slen: i64, i: i64) -> i64 do
  if i + slen > len then return 0 - 1 end
  if mem_eq_at(base, at: i, sb, slen) then return i end
  return find_sub_go(base, len, sb, slen, i: i + 1)
end

// === byte-level primitives (internal; (ptr,len,...) -> i64/bool/i32) ===

let string_length = fn (a_s_ptr: i32, b_s_len: i32) -> i64 do
  return char_count(base: cast.i64_of(x: a_s_ptr), len: cast.i64_of(x: b_s_len))
end

let string_byte_length = fn (a_s_ptr: i32, b_s_len: i32) -> i64 do
  return cast.i64_of(x: b_s_len)
end

let string_byte_at = fn (a_s_ptr: i32, b_s_len: i32, c_idx: i64) -> i32 do
  let len = cast.i64_of(x: b_s_len)
  if c_idx < 0 || c_idx >= len then return cast.i32_of(x: 0) end
  return cast.i32_of(x: byte_at_addr(base: cast.i64_of(x: a_s_ptr), i: c_idx))
end

let string_char_at = fn (a_s_ptr: i32, b_s_len: i32, c_idx: i64) -> i32 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  if c_idx < 0 then return cast.i32_of(x: 0) end
  let off = char_to_byte(base, len, ci: c_idx)
  if off >= len then return cast.i32_of(x: 0) end
  return cast.i32_of(x: decode_cp(base, i: off))
end

let string_char_code = fn (a_s_ptr: i32, b_s_len: i32, c_idx: i64) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  if c_idx < 0 then return 0 - 1 end
  let off = char_to_byte(base, len, ci: c_idx)
  if off >= len then return 0 - 1 end
  return decode_cp(base, i: off)
end

let string_byte_substring = fn (a_s_ptr: i32, b_s_len: i32, c_start: i64, d_len: i64) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  let start = clamp(v: c_start, hi: len)
  let want = if d_len < 0 then 0 else d_len end
  let avail = len - start
  let n = if want > avail then avail else want end
  return make_string(src: base + start, len: n)
end

let string_substring = fn (a_s_ptr: i32, b_s_len: i32, c_start: i64, d_len: i64) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  let s_off = char_to_byte(base, len, ci: if c_start < 0 then 0 else c_start end)
  let nchars = if d_len < 0 then 0 else d_len end
  let e_off = char_to_byte_go(base, len, remaining: nchars, i: s_off)
  return make_string(src: base + s_off, len: e_off - s_off)
end

let string_from_char = fn (a_c: i32) -> i64 do
  let cp = cast.i64_of(x: a_c)
  if cp < 0 then return 0 end
  let n = enc_len(cp)
  let p = alloc_bytes(n)
  let _ = encode_cp(base: p, cp)
  return pack(ptr: p, len: n)
end

let string_from_char_code = fn (a_code: i64) -> i64 do
  if a_code < 0 then return 0 end
  let n = enc_len(cp: a_code)
  let p = alloc_bytes(n)
  let _ = encode_cp(base: p, cp: a_code)
  return pack(ptr: p, len: n)
end

let string_contains = fn (a_s_ptr: i32, b_s_len: i32, c_sub_ptr: i32, d_sub_len: i32) -> bool do
  return find_sub(base: cast.i64_of(x: a_s_ptr), len: cast.i64_of(x: b_s_len),
                  sb: cast.i64_of(x: c_sub_ptr), slen: cast.i64_of(x: d_sub_len), start_at: 0) >= 0
end

let string_starts_with = fn (a_s_ptr: i32, b_s_len: i32, c_prefix_ptr: i32, d_prefix_len: i32) -> bool do
  let plen = cast.i64_of(x: d_prefix_len)
  if plen > cast.i64_of(x: b_s_len) then return false end
  return mem_eq_at(base: cast.i64_of(x: a_s_ptr), at: 0, sb: cast.i64_of(x: c_prefix_ptr), slen: plen)
end

let string_ends_with = fn (a_s_ptr: i32, b_s_len: i32, c_suffix_ptr: i32, d_suffix_len: i32) -> bool do
  let len = cast.i64_of(x: b_s_len)
  let slen = cast.i64_of(x: d_suffix_len)
  if slen > len then return false end
  return mem_eq_at(base: cast.i64_of(x: a_s_ptr), at: len - slen, sb: cast.i64_of(x: c_suffix_ptr), slen)
end

let string_index_of = fn (a_s_ptr: i32, b_s_len: i32, c_sub_ptr: i32, d_sub_len: i32) -> i64 do
  return find_sub(base: cast.i64_of(x: a_s_ptr), len: cast.i64_of(x: b_s_len),
                  sb: cast.i64_of(x: c_sub_ptr), slen: cast.i64_of(x: d_sub_len), start_at: 0)
end

let string_find_byte = fn (a_s_ptr: i32, b_s_len: i32, c_start: i64, d_ch: i32) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  let start = clamp(v: c_start, hi: len)
  return find_byte_go(base, len, target: cast.i64_of(x: d_ch) & 255, i: start)
end
let find_byte_go = fn (base: i64, len: i64, target: i64, i: i64) -> i64 do
  if i >= len then return 0 - 1 end
  if byte_at_addr(base, i) == target then return i end
  return find_byte_go(base, len, target, i: i + 1)
end

let string_count_newlines_in = fn (a_s_ptr: i32, b_s_len: i32, c_start: i64, d_end_pos: i64) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  let start = clamp(v: c_start, hi: len)
  let endp = clamp(v: d_end_pos, hi: len)
  return count_nl_go(base, endp, i: start, n: 0)
end
let count_nl_go = fn (base: i64, endp: i64, i: i64, n: i64) -> i64 do
  if i >= endp then return n end
  let add = if byte_at_addr(base, i) == 10 then 1 else 0 end
  return count_nl_go(base, endp, i: i + 1, n: n + add)
end

let string_last_newline_in = fn (a_s_ptr: i32, b_s_len: i32, c_start: i64, d_end_pos: i64) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  let start = clamp(v: c_start, hi: len)
  let endp = clamp(v: d_end_pos, hi: len)
  return last_nl_go(base, start, i: endp - 1)
end
let last_nl_go = fn (base: i64, start: i64, i: i64) -> i64 do
  if i < start then return 0 - 1 end
  if byte_at_addr(base, i) == 10 then return i end
  return last_nl_go(base, start, i: i - 1)
end

let string_scan_ident = fn (a_s_ptr: i32, b_s_len: i32, c_start: i64) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  return scan_ident_go(base, len, i: clamp(v: c_start, hi: len))
end
let scan_ident_go = fn (base: i64, len: i64, i: i64) -> i64 do
  if i >= len then return len end
  if !is_ident_byte(b: byte_at_addr(base, i)) then return i end
  return scan_ident_go(base, len, i: i + 1)
end

let string_scan_digits = fn (a_s_ptr: i32, b_s_len: i32, c_start: i64) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  return scan_digits_go(base, len, i: clamp(v: c_start, hi: len))
end
let scan_digits_go = fn (base: i64, len: i64, i: i64) -> i64 do
  if i >= len then return len end
  if !is_digit_byte(b: byte_at_addr(base, i)) then return i end
  return scan_digits_go(base, len, i: i + 1)
end

let string_skip_ws = fn (a_s_ptr: i32, b_s_len: i32, c_start: i64) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  return skip_ws_go(base, len, i: clamp(v: c_start, hi: len))
end
let skip_ws_go = fn (base: i64, len: i64, i: i64) -> i64 do
  if i >= len then return len end
  if !is_ws(b: byte_at_addr(base, i)) then return i end
  return skip_ws_go(base, len, i: i + 1)
end

let string_to_lower = fn (a_s_ptr: i32, b_s_len: i32) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  if len <= 0 then return 0 end
  let p = alloc_bytes(n: len)
  let _ = case_map_go(src: base, dst: p, len, i: 0, upper: false)
  return pack(ptr: p, len)
end

let string_to_upper = fn (a_s_ptr: i32, b_s_len: i32) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  if len <= 0 then return 0 end
  let p = alloc_bytes(n: len)
  let _ = case_map_go(src: base, dst: p, len, i: 0, upper: true)
  return pack(ptr: p, len)
end
let case_map_go = fn (src: i64, dst: i64, len: i64, i: i64, upper: bool) -> unit do
  if i >= len then return () end
  let b = load_at(a: src + i)
  let m = if upper then to_upper_byte(b) else to_lower_byte(b) end
  let _ = store_at(a: dst + i, v: m)
  return case_map_go(src, dst, len, i: i + 1, upper)
end

let string_trim = fn (a_s_ptr: i32, b_s_len: i32) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  let lo = trim_lo(base, len, i: 0)
  let hi = trim_hi(base, i: len - 1)
  if hi < lo then return 0 end
  return make_string(src: base + lo, len: (hi - lo) + 1)
end
let trim_lo = fn (base: i64, len: i64, i: i64) -> i64 do
  if i >= len then return len end
  if !is_ws(b: byte_at_addr(base, i)) then return i end
  return trim_lo(base, len, i: i + 1)
end
let trim_hi = fn (base: i64, i: i64) -> i64 do
  if i < 0 then return 0 - 1 end
  if !is_ws(b: byte_at_addr(base, i)) then return i end
  return trim_hi(base, i: i - 1)
end

let string_replace = fn (a_s_ptr: i32, b_s_len: i32, c_from_ptr: i32, d_from_len: i32, e_to_ptr: i32, f_to_len: i32) -> i64 do
  let sb = cast.i64_of(x: a_s_ptr)
  let slen = cast.i64_of(x: b_s_len)
  let fb = cast.i64_of(x: c_from_ptr)
  let flen = cast.i64_of(x: d_from_len)
  let tb = cast.i64_of(x: e_to_ptr)
  let tlen = cast.i64_of(x: f_to_len)
  if flen <= 0 || slen <= 0 then return make_string(src: sb, len: slen) end
  let occ = count_occ(sb, slen, fb, flen, start_at: 0, n: 0)
  if occ == 0 then return make_string(src: sb, len: slen) end
  let out_len = (slen - (occ * flen)) + (occ * tlen)
  if out_len <= 0 then return 0 end
  let p = alloc_bytes(n: out_len)
  let _ = replace_go(sb, slen, fb, flen, tb, tlen, si: 0, dst: p, di: 0)
  return pack(ptr: p, len: out_len)
end
let count_occ = fn (sb: i64, slen: i64, fb: i64, flen: i64, start_at: i64, n: i64) -> i64 do
  let hit = find_sub_go(base: sb, len: slen, sb: fb, slen: flen, i: start_at)
  if hit < 0 then return n end
  return count_occ(sb, slen, fb, flen, start_at: hit + flen, n: n + 1)
end
let replace_go = fn (sb: i64, slen: i64, fb: i64, flen: i64, tb: i64, tlen: i64, si: i64, dst: i64, di: i64) -> unit do
  let hit = find_sub_go(base: sb, len: slen, sb: fb, slen: flen, i: si)
  if hit < 0 then
    return copy_bytes(dst: dst + di, src: sb + si, count: slen - si)
  end
  let _ = copy_bytes(dst: dst + di, src: sb + si, count: hit - si)
  let _ = copy_bytes(dst: dst + di + (hit - si), src: tb, count: tlen)
  return replace_go(sb, slen, fb, flen, tb, tlen, si: hit + flen, dst, di: di + (hit - si) + tlen)
end

let string_repeat = fn (a_s_ptr: i32, b_s_len: i32, c_n: i64) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  let count = if c_n < 0 then 0 else c_n end
  let out_len = len * count
  if out_len <= 0 then return 0 end
  let p = alloc_bytes(n: out_len)
  let _ = repeat_go(src: base, len, dst: p, remaining: count, off: 0)
  return pack(ptr: p, len: out_len)
end
let repeat_go = fn (src: i64, len: i64, dst: i64, remaining: i64, off: i64) -> unit do
  if remaining <= 0 then return () end
  let _ = copy_bytes(dst: dst + off, src, count: len)
  return repeat_go(src, len, dst, remaining: remaining - 1, off: off + len)
end

let string_pad_left = fn (a_s_ptr: i32, b_s_len: i32, c_width: i64, d_fill_ptr: i32, e_fill_len: i32) -> i64 do
  return do_pad(sb: cast.i64_of(x: a_s_ptr), slen: cast.i64_of(x: b_s_len), width: c_width,
                fb: cast.i64_of(x: d_fill_ptr), flen: cast.i64_of(x: e_fill_len), left: true)
end

let string_pad_right = fn (a_s_ptr: i32, b_s_len: i32, c_width: i64, d_fill_ptr: i32, e_fill_len: i32) -> i64 do
  return do_pad(sb: cast.i64_of(x: a_s_ptr), slen: cast.i64_of(x: b_s_len), width: c_width,
                fb: cast.i64_of(x: d_fill_ptr), flen: cast.i64_of(x: e_fill_len), left: false)
end
let do_pad = fn (sb: i64, slen: i64, width: i64, fb: i64, flen: i64, left: bool) -> i64 do
  let w = if width < 0 then 0 else width end
  let cc = char_count(base: sb, len: slen)
  if cc >= w || flen <= 0 then return make_string(src: sb, len: slen) end
  let pad_chars = w - cc
  let out_len = slen + pad_chars
  let p = alloc_bytes(n: out_len)
  if left then
    let _ = fill_cycle(dst: p, off: 0, fb, flen, remaining: pad_chars)
    let _ = copy_bytes(dst: p + pad_chars, src: sb, count: slen)
  else
    let _ = copy_bytes(dst: p, src: sb, count: slen)
    let _ = fill_cycle(dst: p, off: slen, fb, flen, remaining: pad_chars)
  end
  return pack(ptr: p, len: out_len)
end
let fill_cycle = fn (dst: i64, off: i64, fb: i64, flen: i64, remaining: i64) -> unit do
  if remaining <= 0 then return () end
  let _ = mem.store_u8(addr: dst + off, val: load_at(a: fb + (off % flen)))
  return fill_cycle(dst, off: off + 1, fb, flen, remaining: remaining - 1)
end

let string_is_valid_i64 = fn (a_s_ptr: i32, b_s_len: i32) -> bool do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  let lo = trim_lo(base, len, i: 0)
  let hi = trim_hi(base, i: len - 1)
  if hi < lo then return false end
  let first = load_at(a: base + lo)
  let dstart = if first == 45 || first == 43 then lo + 1 else lo end
  if dstart > hi then return false end
  return all_digits(base, i: dstart, hi)
end
let all_digits = fn (base: i64, i: i64, hi: i64) -> bool do
  if i > hi then return true end
  if !is_digit_byte(b: byte_at_addr(base, i)) then return false end
  return all_digits(base, i: i + 1, hi)
end

let string_to_i64 = fn (a_s_ptr: i32, b_s_len: i32) -> i64 do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  let lo = trim_lo(base, len, i: 0)
  let hi = trim_hi(base, i: len - 1)
  if hi < lo then return 0 end
  let first = load_at(a: base + lo)
  let neg = first == 45
  let dstart = if first == 45 || first == 43 then lo + 1 else lo end
  let mag = parse_digits(base, i: dstart, hi, acc: 0)
  return if neg then 0 - mag else mag end
end
let parse_digits = fn (base: i64, i: i64, hi: i64, acc: i64) -> i64 do
  if i > hi then return acc end
  let d = byte_at_addr(base, i) - 48
  return parse_digits(base, i: i + 1, hi, acc: (acc * 10) + d)
end

let string_from_i64 = fn (a_val: i64) -> i64 do
  if a_val == 0 then
    let p = alloc_bytes(n: 1)
    let _ = store_at(a: p, v: 48)
    return pack(ptr: p, len: 1)
  end
  let neg = a_val < 0
  let nd = count_digits(v: a_val, n: 0)
  let total = if neg then nd + 1 else nd end
  let p = alloc_bytes(n: total)
  if neg then
    let _ = store_at(a: p, v: 45)
    let _ = write_digits_neg(v: a_val, dst: p, i: total - 1)
  else
    let _ = write_digits_pos(v: a_val, dst: p, i: total - 1)
  end
  return pack(ptr: p, len: total)
end
let count_digits = fn (v: i64, n: i64) -> i64 do
  if v == 0 then return n end
  return count_digits(v: v / 10, n: n + 1)
end
let write_digits_pos = fn (v: i64, dst: i64, i: i64) -> unit do
  if v == 0 then return () end
  let _ = store_at(a: dst + i, v: 48 + (v % 10))
  return write_digits_pos(v: v / 10, dst, i: i - 1)
end
let write_digits_neg = fn (v: i64, dst: i64, i: i64) -> unit do
  if v == 0 then return () end
  let _ = store_at(a: dst + i, v: 48 + (0 - (v % 10)))
  return write_digits_neg(v: v / 10, dst, i: i - 1)
end

let string_from_bool = fn (a_val: bool) -> i64 do
  if a_val then
    let p = alloc_bytes(n: 4)
    let _ = store_at(a: p, v: 116)
    let _ = store_at(a: p + 1, v: 114)
    let _ = store_at(a: p + 2, v: 117)
    let _ = store_at(a: p + 3, v: 101)
    return pack(ptr: p, len: 4)
  end
  let p = alloc_bytes(n: 5)
  let _ = store_at(a: p, v: 102)
  let _ = store_at(a: p + 1, v: 97)
  let _ = store_at(a: p + 2, v: 108)
  let _ = store_at(a: p + 3, v: 115)
  let _ = store_at(a: p + 4, v: 101)
  return pack(ptr: p, len: 5)
end

// === f64 <-> string ==========================================================
//
// These avoid f64 *literals* on purpose: float literals are themselves encoded
// at compile time via `bb.push_f64_str_le` -> `string_to_f64`, so the
// seed compiler that builds this file must not depend on a working float-literal
// path here. All constants are materialised via `i64_to_float`.

/** f64 +0.0 (built from bits, not a literal). */
let f0 = fn () -> float do return i64_to_float(val: 0) end
/** f64 1.0. */
let f1 = fn () -> float do return i64_to_float(val: 1) end
/** f64 10.0. */
let f10 = fn () -> float do return i64_to_float(val: 10) end
/** f64 NaN, written as the canonical quiet-NaN bit pattern. */
let fnan = fn () -> float do return reinterpret_to_f64(bits: 9221120237041090560) end

/** Reinterpret the 64 bits of `bits` as an f64 (round-trips via linear memory). */
let reinterpret_to_f64 = fn (bits: i64) -> float do
  let p = arena.alloc_raw(size: 8)
  let _ = mem.store_i64(addr: p, val: bits)
  return mem.load_f64(addr: p)
end
/** Reinterpret the 64 bits of `x` as an i64. */
let reinterpret_to_i64 = fn (x: float) -> i64 do
  let p = arena.alloc_raw(size: 8)
  let _ = mem.store_f64(addr: p, val: x)
  return mem.load_i64(addr: p)
end

/** 10^n as an i64 for 0 <= n <= 18 (exact). */
let int_pow10 = fn (n: i64) -> i64 do return int_pow10_go(n, acc: 1) end
let int_pow10_go = fn (n: i64, acc: i64) -> i64 do
  if n <= 0 then return acc end
  return int_pow10_go(n: n - 1, acc: acc * 10)
end

/** 10^n as an f64 for n >= 0 (exact for n <= 22; a few ulps beyond). */
let pow10_pos = fn (n: i64) -> float do
  if n <= 0 then return f1() end
  if n <= 18 then return i64_to_float(val: int_pow10(n)) end
  return i64_to_float(val: int_pow10(n: 18)) *. pow10_pos(n: n - 18)
end
/** 10^n as an f64 for any n (1 ulp from the divide when n < 0). */
let pow10 = fn (n: i64) -> float do
  if n >= 0 then return pow10_pos(n) end
  return f1() /. pow10_pos(n: 0 - n)
end

/** Lowercase a single ASCII byte. */
let lc = fn (b: i64) -> i64 do if b >= 65 && b <= 90 then return b + 32 else return b end end

/**
f64-string scan state, stored in a 5-word scratch block:
  w0: pos (current byte offset, absolute)
  w1: sign (0 or 1)
  w2: mantissa (i64, accumulated, capped at 18 digits)
  w3: decexp (i64, the base-10 exponent adjustment so far)
  w4: flags: bit0 = saw at least one mantissa digit; bit1 = malformed
*/
let st_alloc = fn () -> i64 do return arena.alloc_raw(size: 40) end
let st_pos = fn (s: i64) -> i64 do return mem.load_i64(addr: s) end
let st_set_pos = fn (s: i64, v: i64) -> unit do return mem.store_i64(addr: s, val: v) end
let st_sign = fn (s: i64) -> i64 do return mem.load_i64(addr: s + 8) end
let st_set_sign = fn (s: i64, v: i64) -> unit do return mem.store_i64(addr: s + 8, val: v) end
let st_mant = fn (s: i64) -> i64 do return mem.load_i64(addr: s + 16) end
let st_set_mant = fn (s: i64, v: i64) -> unit do return mem.store_i64(addr: s + 16, val: v) end
let st_dexp = fn (s: i64) -> i64 do return mem.load_i64(addr: s + 24) end
let st_set_dexp = fn (s: i64, v: i64) -> unit do return mem.store_i64(addr: s + 24, val: v) end
let st_flags = fn (s: i64) -> i64 do return mem.load_i64(addr: s + 32) end
let st_set_flags = fn (s: i64, v: i64) -> unit do return mem.store_i64(addr: s + 32, val: v) end
let st_saw_digit = fn (s: i64) -> bool do return (st_flags(s) & 1) != 0 end
let st_mark_digit = fn (s: i64) -> unit do return st_set_flags(s, v: st_flags(s) | 1) end
let st_bad = fn (s: i64) -> bool do return (st_flags(s) & 2) != 0 end
let st_mark_bad = fn (s: i64) -> unit do return st_set_flags(s, v: st_flags(s) | 2) end

/**
Accumulate one decimal digit `d` (0..9) into the mantissa, but stop growing
it past 18 digits -- excess integer digits bump `decexp` instead. `in_frac`
indicates we are past the '.', so accepted fraction digits lower `decexp`.
*/
let acc_digit = fn (s: i64, d: i64, in_frac: bool) -> unit do
  let _ = st_mark_digit(s)
  let m = st_mant(s)
  // 10^18 < 2^63 < 10^19; accept up to 18 digits into the mantissa.
  if m < 100000000000000000 then
    let _ = st_set_mant(s, v: (m * 10) + d)
    if in_frac then let _ = st_set_dexp(s, v: st_dexp(s) - 1) end
    return ()
  end
  // mantissa full: a dropped integer digit raises decexp; a dropped fraction
  // digit is simply ignored (its place value is already absorbed by mantissa).
  if !in_frac then let _ = st_set_dexp(s, v: st_dexp(s) + 1) end
  return ()
end

/** Scan the sign at `s.pos` over [base, base+len): sets st_sign, advances pos. */
let scan_sign = fn (s: i64, base: i64, len: i64) -> unit do
  let p = st_pos(s)
  if p >= len then return () end
  let c = byte_at_addr(base, i: p)
  if c == 45 then let _ = st_set_sign(s, v: 1) end
  if c == 45 || c == 43 then let _ = st_set_pos(s, v: p + 1) end
  return ()
end

/** Scan a run of digits from `s.pos`, feeding each to acc_digit(in_frac). */
let scan_digit_run = fn (s: i64, base: i64, len: i64, in_frac: bool) -> unit do
  let p = st_pos(s)
  if p >= len then return () end
  let c = byte_at_addr(base, i: p)
  if c < 48 || c > 57 then return () end
  let _ = acc_digit(s, d: c - 48, in_frac)
  let _ = st_set_pos(s, v: p + 1)
  return scan_digit_run(s, base, len, in_frac)
end

/**
Scan a plain (unsigned) decimal int from `s.pos` into `acc`; advance pos.
Returns the value; sets `saw` via the out word at `s + 32` is too coarse,
so callers check whether pos advanced. Caps the magnitude (exponent values
far past +-9999 are clamped to keep this i64).
*/
let scan_uint = fn (s: i64, base: i64, len: i64, acc: i64) -> i64 do
  let p = st_pos(s)
  if p >= len then return acc end
  let c = byte_at_addr(base, i: p)
  if c < 48 || c > 57 then return acc end
  let _ = st_set_pos(s, v: p + 1)
  let nacc = if acc > 100000 then acc else (acc * 10) + (c - 48) end
  return scan_uint(s, base, len, acc: nacc)
end

/** Skip trailing ASCII whitespace from `s.pos`. */
let skip_trailing_ws = fn (s: i64, base: i64, len: i64) -> unit do
  let p = st_pos(s)
  if p >= len then return () end
  if !is_ws(b: byte_at_addr(base, i: p)) then return () end
  let _ = st_set_pos(s, v: p + 1)
  return skip_trailing_ws(s, base, len)
end

/** True iff the 3 bytes at [base+p, base+p+3) are an ASCII match for "inf"/"nan". */
let three_eq = fn (base: i64, p: i64, len: i64, a: i64, b: i64, c: i64) -> bool do
  if p + 3 > len then return false end
  return lc(b: byte_at_addr(base, i: p)) == a && lc(b: byte_at_addr(base, i: p + 1)) == b && lc(b: byte_at_addr(base, i: p + 2)) == c
end

/**
Run the shared scan over [base, base+len): skips leading ws, sign, the
mantissa (digits, optional '.', digits), the optional exponent, then trailing
ws. Recognises "inf"/"nan" (case-insensitive) after the sign as a whole-token
match. Returns the scratch state `s`; the caller inspects st_bad / the final
pos (== len means well-formed). When "inf"/"nan" matched, mantissa is left 0
and a sentinel flag is encoded by setting decexp to a huge value (inf) -- but
to keep the contract simple, callers use `scan_special` separately.
*/
let run_scan = fn (base: i64, len: i64) -> i64 do
  let s = st_alloc()
  let _ = st_set_pos(s, v: 0)
  let _ = st_set_sign(s, v: 0)
  let _ = st_set_mant(s, v: 0)
  let _ = st_set_dexp(s, v: 0)
  let _ = st_set_flags(s, v: 0)
  // leading ws
  let _ = st_set_pos(s, v: skip_ws_go(base, len, i: 0))
  let _ = scan_sign(s, base, len)
  // int digits, optional '.', frac digits
  let _ = scan_digit_run(s, base, len, in_frac: false)
  let p0 = st_pos(s)
  if p0 < len && byte_at_addr(base, i: p0) == 46 then
    let _ = st_set_pos(s, v: p0 + 1)
    let _ = scan_digit_run(s, base, len, in_frac: true)
  end
  if !st_saw_digit(s) then let _ = st_mark_bad(s) end
  // optional exponent
  let pe = st_pos(s)
  if pe < len && (byte_at_addr(base, i: pe) == 101 || byte_at_addr(base, i: pe) == 69) then
    let _ = st_set_pos(s, v: pe + 1)
    // exponent sign
    let pe2 = st_pos(s)
    let esign = if pe2 < len && byte_at_addr(base, i: pe2) == 45 then 1 else 0 end
    if pe2 < len && (byte_at_addr(base, i: pe2) == 45 || byte_at_addr(base, i: pe2) == 43) then
      let _ = st_set_pos(s, v: pe2 + 1)
    end
    let pe3 = st_pos(s)
    let eval = scan_uint(s, base, len, acc: 0)
    if st_pos(s) == pe3 then
      // 'e' with no digits after -> malformed
      let _ = st_mark_bad(s)
    else
      let signed_e = if esign == 1 then 0 - eval else eval end
      let _ = st_set_dexp(s, v: st_dexp(s) + signed_e)
    end
  end
  let _ = skip_trailing_ws(s, base, len)
  return s
end

/**
Detect a leading [+-]? "inf"/"infinity"/"nan" token (case-insensitive),
possibly surrounded by whitespace. Returns: 0 = not special, 1 = +inf,
2 = -inf, 3 = nan. Anything trailing the token (other than ws) -> 0.
*/
let scan_special = fn (base: i64, len: i64) -> i64 do
  let p0 = skip_ws_go(base, len, i: 0)
  let sign = if p0 < len && byte_at_addr(base, i: p0) == 45 then 1 else 0 end
  let p1 = if p0 < len && (byte_at_addr(base, i: p0) == 45 || byte_at_addr(base, i: p0) == 43) then p0 + 1 else p0 end
  // "inf" (optionally "inity")
  if three_eq(base, p: p1, len, a: 105, b: 110, c: 102) then
    let after = if p1 + 8 <= len && lc(b: byte_at_addr(base, i: p1 + 3)) == 105 && lc(b: byte_at_addr(base, i: p1 + 4)) == 110 && lc(b: byte_at_addr(base, i: p1 + 5)) == 105 && lc(b: byte_at_addr(base, i: p1 + 6)) == 116 && lc(b: byte_at_addr(base, i: p1 + 7)) == 121 then p1 + 8 else p1 + 3 end
    let tail = skip_ws_go(base, len, i: after)
    if tail != len then return 0 end
    return if sign == 1 then 2 else 1 end
  end
  // "nan"
  if three_eq(base, p: p1, len, a: 110, b: 97, c: 110) then
    let tail = skip_ws_go(base, len, i: p1 + 3)
    if tail != len then return 0 end
    return 3
  end
  return 0
end

/** Combine a scan-state into an f64. */
let assemble_f64 = fn (s: i64) -> float do
  let mant_f = i64_to_float(val: st_mant(s))
  let scaled = mant_f *. pow10(n: st_dexp(s))
  if st_sign(s) == 1 then return f0() -. scaled else return scaled end
end

/**
Parse [a_s_ptr, a_s_ptr+b_s_len) as an f64. Whitespace-tolerant; accepts
the usual `[+-]?(digits('.'digits?)?|'.'digits)([eE][+-]?digits)?` grammar
plus case-insensitive `inf`/`infinity`/`nan`. Returns 0.0 on a malformed
string (callers gate with `string_is_valid_f64`).
*/
let string_to_f64 = fn (a_s_ptr: i32, b_s_len: i32) -> float do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  if len <= 0 then return f0() end
  let sp = scan_special(base, len)
  if sp == 1 then return pow10_pos(n: 400) end
  if sp == 2 then return f0() -. pow10_pos(n: 400) end
  if sp == 3 then return fnan() end
  let s = run_scan(base, len)
  if st_bad(s) || st_pos(s) != len then return f0() end
  return assemble_f64(s)
end

/**
True iff [a_s_ptr, a_s_ptr+b_s_len) is a syntactically valid f64 literal
(per the grammar above, including `inf`/`nan`).
*/
let string_is_valid_f64 = fn (a_s_ptr: i32, b_s_len: i32) -> bool do
  let base = cast.i64_of(x: a_s_ptr)
  let len = cast.i64_of(x: b_s_len)
  if len <= 0 then return false end
  if scan_special(base, len) != 0 then return true end
  let s = run_scan(base, len)
  return !st_bad(s) && st_pos(s) == len && st_saw_digit(s)
end

// --- dtoa: f64 -> shortest-ish decimal string ---
//
// Not a Grisu/Ryu shortest-representation algorithm: extracts ~17 significant
// decimal digits, trims trailing zeros, and picks fixed vs. scientific notation
// by the decimal exponent. Round-trips for the values that matter; the textual
// form may differ from Rust's `f64::to_string` for some inputs.

/** IEEE-754 field accessors on an f64's bit pattern. */
let f_sign_bit = fn (bits: i64) -> i64 do
  // logical >> 63
  let sh = bits >> 63
  return sh & 1
end
let f_raw_exp = fn (bits: i64) -> i64 do return (bits >> 52) & 2047 end
let f_frac = fn (bits: i64) -> i64 do return bits & ((1 << 52) - 1) end

/**
ln(2) and ln(10), as f64 (built bit-wise via to_f64 of their text -- but
that recurses through this module; instead use the literal mantissa form).
*/
let ln10_f = fn () -> float do
  // 2.302585092994046 = 2302585092994046 * 10^-15
  return i64_to_float(val: 2302585092994046) *. pow10(n: 0 - 15)
end
let ln2_f = fn () -> float do
  // 0.6931471805599453 = 6931471805599453 * 10^-16
  return i64_to_float(val: 6931471805599453) *. pow10(n: 0 - 16)
end
let sqrt2_f = fn () -> float do
  return i64_to_float(val: 14142135623730951) *. pow10(n: 0 - 16)
end

/** floor(x) for f64, via truncation toward zero adjusted for negatives. */
let floorf = fn (x: float) -> float do
  let t = i64_to_float(val: float_to_i64(val: x))
  if t >. x then return t -. f1() else return t end
end

/** ln(x) for x > 0 (atanh series after the m*2^k decomposition). */
let lnf = fn (x: float) -> float do
  if x <=. f0() then return f0() end
  let bits = reinterpret_to_i64(x)
  let k0 = f_raw_exp(bits) - 1023
  let m_bits = f_frac(bits) | (1023 << 52)
  let m0 = reinterpret_to_f64(bits: m_bits)
  let split = m0 >. sqrt2_f()
  let m = if split then m0 /. i64_to_float(val: 2) else m0 end
  let k = if split then k0 + 1 else k0 end
  let t = (m -. f1()) /. (m +. f1())
  let t2 = t *. t
  let t3 = t2 *. t
  let t5 = t3 *. t2
  let t7 = t5 *. t2
  let t9 = t7 *. t2
  let series = t +. (t3 /. i64_to_float(val: 3)) +. (t5 /. i64_to_float(val: 5)) +. (t7 /. i64_to_float(val: 7)) +. (t9 /. i64_to_float(val: 9))
  return (i64_to_float(val: k) *. ln2_f()) +. (i64_to_float(val: 2) *. series)
end
/** log10(x) for x > 0. */
let log10f = fn (x: float) -> float do return lnf(x) /. ln10_f() end

/**
Write up to 17 significant decimal digits of `m` (m in [1, 10)) into the
byte buffer `dst`; returns the count of digits written (always 17). The
last digit may be slightly off; trailing zeros are trimmed by the caller.
*/
let extract_digits = fn (m: float, dst: i64, i: i64, n: i64) -> i64 do
  if i >= n then return n end
  let d = float_to_i64(val: floorf(x: m))
  let dd = if d < 0 then 0 else if d > 9 then 9 else d end
  let _ = mem.store_u8(addr: dst + i, val: 48 + dd)
  let m2 = (m -. i64_to_float(val: dd)) *. f10()
  return extract_digits(m: m2, dst, i: i + 1, n)
end

/** Find the last index in [0, n) that is non-'0' in [dst, dst+n); -1 if all '0'. */
let last_nonzero = fn (dst: i64, n: i64, i: i64) -> i64 do
  if i < 0 then return 0 - 1 end
  if mem.load_u8(addr: dst + i) != 48 then return i end
  return last_nonzero(dst, n, i: i - 1)
end

/**
Round the digit string at [dst, dst+nd): `next_digit` is the ASCII byte of
the first dropped digit ('0'..'9'). Rounds half-up; a carry may propagate
past the most significant digit, in which case the digits become "100..0"
and the returned exponent is `exp + 1` (else `exp` unchanged).
*/
let round_digits = fn (dst: i64, nd: i64, next_digit: i64, exp: i64) -> i64 do
  if next_digit < 53 then return exp end
  return round_carry(dst, i: nd - 1, exp)
end
let round_carry = fn (dst: i64, i: i64, exp: i64) -> i64 do
  if i < 0 then
    // carry past the most significant digit: shift right, leading '1'.
    let _ = mem.store_u8(addr: dst, val: 49)
    return exp + 1
  end
  let v = mem.load_u8(addr: dst + i)
  if v == 57 then
    let _ = mem.store_u8(addr: dst + i, val: 48)
    return round_carry(dst, i: i - 1, exp)
  end
  let _ = mem.store_u8(addr: dst + i, val: v + 1)
  return exp
end

/** Write n '0' bytes at dst. */
let fill_zeros = fn (dst: i64, n: i64) -> unit do
  if n <= 0 then return () end
  let _ = mem.store_u8(addr: dst, val: 48)
  return fill_zeros(dst: dst + 1, n: n - 1)
end

/** If `neg`, write '-' at p[0] and return 1; else return 0. */
let neg_prefix = fn (p: i64, neg: bool) -> i64 do
  if neg then
    let _ = mem.store_u8(addr: p, val: 45)
    return 1
  end
  return 0
end

/** Write the decimal digits of v (>= 0) to dst, MSD first; return the count. */
let write_uint_digits = fn (v: i64, dst: i64) -> i64 do
  if v == 0 then
    let _ = mem.store_u8(addr: dst, val: 48)
    return 1
  end
  let nd = count_digits(v, n: 0)
  let _ = write_digits_pos(v, dst, i: nd - 1)
  return nd
end

/** Body length of a fixed-notation rendering of `nd` digits at exponent `e`. */
let fixed_body_len = fn (nd: i64, e: i64) -> i64 do
  if e >= 0 then
    if e + 1 >= nd then return e + 1 end
    return nd + 1
  end
  return 2 + (0 - e - 1) + nd
end

/**
Emit a fixed-notation rendering of `nd` digits at `digs` with decimal
exponent `e` (value = D[0].D[1..] * 10^e); return packed (ptr<<32)|len.
e >= 0 puts the point inside or after the digits (zero-padding past nd);
e < 0 renders "0." then (-e-1) zeros then the digits. `neg` prepends '-'.
*/
let render_fixed = fn (digs: i64, nd: i64, e: i64, neg: bool) -> i64 do
  let body_len = fixed_body_len(nd, e)
  let total = if neg then body_len + 1 else body_len end
  let p = alloc_bytes(n: total)
  let off0 = neg_prefix(p, neg)
  if e >= 0 then
    if e + 1 >= nd then
      let _ = copy_bytes(dst: p + off0, src: digs, count: nd)
      let _ = fill_zeros(dst: p + off0 + nd, n: e + 1 - nd)
      return pack(ptr: p, len: total)
    end
    let _ = copy_bytes(dst: p + off0, src: digs, count: e + 1)
    let _ = mem.store_u8(addr: p + off0 + e + 1, val: 46)
    let _ = copy_bytes(dst: p + off0 + e + 2, src: digs + e + 1, count: nd - e - 1)
    return pack(ptr: p, len: total)
  end
  let _ = mem.store_u8(addr: p + off0, val: 48)
  let _ = mem.store_u8(addr: p + off0 + 1, val: 46)
  let nz = 0 - e - 1
  let _ = fill_zeros(dst: p + off0 + 2, n: nz)
  let _ = copy_bytes(dst: p + off0 + 2 + nz, src: digs, count: nd)
  return pack(ptr: p, len: total)
end

/** Emit scientific notation: ('-')? D[0] ('.' D[1..])? 'e' ('-')? exp-digits. */
let render_sci = fn (digs: i64, nd: i64, e: i64, neg: bool) -> i64 do
  let eabs = if e < 0 then 0 - e else e end
  let edigs_p = alloc_bytes(n: 8)
  let en = write_uint_digits(v: eabs, dst: edigs_p)
  let frac_n = nd - 1
  let dot_part = if frac_n > 0 then 1 + frac_n else 0 end
  let esign_part = if e < 0 then 1 else 0 end
  let body_len = 1 + dot_part + 1 + esign_part + en
  let total = if neg then body_len + 1 else body_len end
  let p = alloc_bytes(n: total)
  let off0 = neg_prefix(p, neg)
  let _ = mem.store_u8(addr: p + off0, val: mem.load_u8(addr: digs))
  let after_d = render_sci_frac(p, at: off0 + 1, digs, frac_n)
  let _ = mem.store_u8(addr: p + after_d, val: 101)
  let after_e = render_sci_esign(p, at: after_d + 1, e)
  let _ = copy_bytes(dst: p + after_e, src: edigs_p, count: en)
  return pack(ptr: p, len: total)
end
/** Write ('.' digs[1..frac_n+1])? at p+at; return the offset just past it. */
let render_sci_frac = fn (p: i64, at: i64, digs: i64, frac_n: i64) -> i64 do
  if frac_n <= 0 then return at end
  let _ = mem.store_u8(addr: p + at, val: 46)
  let _ = copy_bytes(dst: p + at + 1, src: digs + 1, count: frac_n)
  return at + 1 + frac_n
end
/** Write ('-')? at p+at when e < 0; return the offset just past it. */
let render_sci_esign = fn (p: i64, at: i64, e: i64) -> i64 do
  if e >= 0 then return at end
  let _ = mem.store_u8(addr: p + at, val: 45)
  return at + 1
end

/**
Write the bytes of the literal `txt` (a sequence of byte values) into a
fresh n-byte allocation; return packed. Used for the nan/inf/0 names.
*/
let small_str3 = fn (a: i64, b: i64, c: i64) -> i64 do
  let p = alloc_bytes(n: 3)
  let _ = store_at(a: p, v: a)
  let _ = store_at(a: p + 1, v: b)
  let _ = store_at(a: p + 2, v: c)
  return pack(ptr: p, len: 3)
end

/** Parse the first `k` decimal digits at [digs, digs+k) as an i64. */
let digits_to_int = fn (digs: i64, k: i64) -> i64 do return digits_to_int_go(digs, k, i: 0, acc: 0) end
let digits_to_int_go = fn (digs: i64, k: i64, i: i64, acc: i64) -> i64 do
  if i >= k then return acc end
  return digits_to_int_go(digs, k, i: i + 1, acc: (acc * 10) + (mem.load_u8(addr: digs + i) - 48))
end

/**
Find the fewest leading digits (1..maxk, maxk <= 15) whose value, rounded
at the next digit, reconstructs `mag` bit-exactly (using the same
i64_to_float * pow10 recipe `assemble_f64` uses for parsing). Writes the
chosen digits into `out` (which may pick up a rounding carry, shifting the
exponent), and returns the (count << 8) | (1 if the exponent grew) -- the
caller adds the bump to `e`. Returns 0 if nothing in range matched.
*/
let shortest_digits = fn (digs: i64, e: i64, mag: float, out: i64) -> i64 do
  return shortest_go(digs, e, mag, out, k: 1)
end
let shortest_go = fn (digs: i64, e: i64, mag: float, out: i64, k: i64) -> i64 do
  if k > 15 then return 0 end
  // copy first k digits to out, round at digit[k]
  let _ = copy_bytes(dst: out, src: digs, count: k)
  let next_d = mem.load_u8(addr: digs + k)
  let e_bumped = round_digits(dst: out, nd: k, next_digit: next_d, exp: 0)
  let m_int = digits_to_int(digs: out, k)
  // reconstruct: m_int has k digits, value = m_int * 10^(e + e_bumped - (k-1))
  let recon = i64_to_float(val: m_int) *. pow10(n: e + e_bumped - (k - 1))
  if recon ==. mag then return (k * 256) + e_bumped end
  return shortest_go(digs, e, mag, out, k: k + 1)
end

/**
Render an f64 to a decimal string. `0.0` -> "0"; `-0.0` -> "-0" (the IEEE
sign is preserved). NaN -> "nan"; +-inf -> "inf"/"-inf". Exact integers
below 2^53 print without a decimal point. Otherwise: the shortest leading
digit string (<= 15 digits) that round-trips is used when one exists, else
a 17-digit extraction with trailing zeros trimmed. Fixed notation for
decimal exponents in [-4, 17), scientific notation outside.
*/
let string_from_float = fn (a_val: float) -> i64 do
  let bits = reinterpret_to_i64(x: a_val)
  let neg = f_sign_bit(bits) == 1
  let raw_e = f_raw_exp(bits)
  if raw_e == 2047 then
    if f_frac(bits) != 0 then return small_str3(a: 110, b: 97, c: 110) end
    if neg then
      let p = alloc_bytes(n: 4)
      let _ = store_at(a: p, v: 45)
      let _ = store_at(a: p + 1, v: 105)
      let _ = store_at(a: p + 2, v: 110)
      let _ = store_at(a: p + 3, v: 102)
      return pack(ptr: p, len: 4)
    end
    return small_str3(a: 105, b: 110, c: 102)
  end
  if raw_e == 0 && f_frac(bits) == 0 then
    if neg then
      let p = alloc_bytes(n: 2)
      let _ = store_at(a: p, v: 45)
      let _ = store_at(a: p + 1, v: 48)
      return pack(ptr: p, len: 2)
    end
    let p = alloc_bytes(n: 1)
    let _ = store_at(a: p, v: 48)
    return pack(ptr: p, len: 1)
  end
  let mag = if neg then f0() -. a_val else a_val end
  // Exact small integer? Print without a decimal point via from_i64.
  let as_int = float_to_i64(val: mag)
  if as_int < 9007199254740992 && i64_to_float(val: as_int) ==. mag then
    if neg then return string_from_i64(a_val: 0 - as_int) end
    return string_from_i64(a_val: as_int)
  end
  // Decimal exponent estimate, then up to two 1-step corrections so the
  // normalised mantissa lands in [1, 10).
  let e0 = float_to_i64(val: floorf(x: log10f(x: mag)))
  let m0 = mag /. pow10(n: e0)
  let e1 = if m0 >=. f10() then e0 + 1 else if m0 <. f1() then e0 - 1 else e0 end
  let m1 = mag /. pow10(n: e1)
  let e = if m1 >=. f10() then e1 + 1 else if m1 <. f1() then e1 - 1 else e1 end
  let m = mag /. pow10(n: e)
  // Extract 18 digits.
  let raw = alloc_bytes(n: 24)
  let _ = extract_digits(m, dst: raw, i: 0, n: 18)
  // Try the shortest round-tripping prefix; fall back to a rounded 17 digits.
  let chosen = alloc_bytes(n: 24)
  let sh = shortest_digits(digs: raw, e, mag, out: chosen)
  if sh != 0 then
    let k = sh / 256
    let e_after = e + (sh & 255)
    let lnz = last_nonzero(dst: chosen, n: k, i: k - 1)
    let nd = if lnz < 0 then 1 else lnz + 1 end
    if e_after >= 0 - 4 && e_after < 17 then return render_fixed(digs: chosen, nd, e: e_after, neg) end
    return render_sci(digs: chosen, nd, e: e_after, neg)
  end
  let next_digit = mem.load_u8(addr: raw + 17)
  let e_after = round_digits(dst: raw, nd: 17, next_digit, exp: e)
  let lnz = last_nonzero(dst: raw, n: 17, i: 16)
  let nd = if lnz < 0 then 1 else lnz + 1 end
  if e_after >= 0 - 4 && e_after < 17 then return render_fixed(digs: raw, nd, e: e_after, neg) end
  return render_sci(digs: raw, nd, e: e_after, neg)
end

/**
Return the raw 8-byte IEEE-754 bit pattern of the f64 parsed from
[a_s_ptr, a_s_ptr+b_s_len) as an i64 (used by bytebuffer's push_f64_str_le).
*/
export let f64_str_bits = fn (a_s_ptr: i32, b_s_len: i32) -> i64 do
  return reinterpret_to_i64(x: string_to_f64(a_s_ptr, b_s_len))
end

// === public surface ===

/** Returns the number of characters in the string. */
export let length = fn (s: string) -> i64 do return string_length(a_s_ptr: s_ptr(s), b_s_len: s_len(s)) end

/** Returns the number of UTF-8 bytes in the string. */
export let byte_length = fn (s: string) -> i64 do return string_byte_length(a_s_ptr: s_ptr(s), b_s_len: s_len(s)) end

/** Returns the raw byte at the given byte position as a char. O(1). '\0' if oob. */
export let byte_at = fn (s: string, idx: i64) -> char do return string_byte_at(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_idx: idx) end

/** Scans from start while characters are ident chars (a-z, A-Z, 0-9, _). Returns end position. */
export let scan_ident = fn (s: string, start: i64) -> i64 do return string_scan_ident(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_start: start) end

/** Scans from start while characters are digits (0-9). Returns end position. */
export let scan_digits = fn (s: string, start: i64) -> i64 do return string_scan_digits(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_start: start) end

/** Skips ASCII whitespace (space, tab, \n, \r) from start. Returns end position. */
export let skip_ws = fn (s: string, start: i64) -> i64 do return string_skip_ws(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_start: start) end

/** Counts newlines (\n) in byte range [start, end). */
export let count_newlines_in = fn (s: string, start: i64, end_pos: i64) -> i64 do return string_count_newlines_in(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_start: start, d_end_pos: end_pos) end

/** Returns position of last newline (\n) in range [start, end), or -1. */
export let last_newline_in = fn (s: string, start: i64, end_pos: i64) -> i64 do return string_last_newline_in(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_start: start, d_end_pos: end_pos) end

/** Finds first occurrence of byte ch from start. Returns position or -1. */
export let find_byte = fn (s: string, start: i64, ch: char) -> i64 do return string_find_byte(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_start: start, d_ch: cast.i32_of(x: cast.i64_of(x: ch))) end

/** Extracts substring by byte offset and byte length. O(len). */
export let byte_substring = fn (s: string, start: i64, len: i64) -> string do return to_str(packed: string_byte_substring(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_start: start, d_len: len)) end

/** Returns true if s contains the substring sub. */
export let contains = fn (s: string, sub: string) -> bool do return string_contains(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_sub_ptr: s_ptr(s: sub), d_sub_len: s_len(s: sub)) end

/** Extracts a substring starting at start with the given length. */
export let substring = fn (s: string, start: i64, len: i64) -> string do return to_str(packed: string_substring(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_start: start, d_len: len)) end

/** Returns the index of the first occurrence of sub in s, or -1 if not found. */
export let index_of = fn (s: string, sub: string) -> i64 do return string_index_of(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_sub_ptr: s_ptr(s: sub), d_sub_len: s_len(s: sub)) end

/** Returns true if s starts with the given prefix. */
export let starts_with = fn (s: string, prefix: string) -> bool do return string_starts_with(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_prefix_ptr: s_ptr(s: prefix), d_prefix_len: s_len(s: prefix)) end

/** Returns true if s ends with the given suffix. */
export let ends_with = fn (s: string, suffix: string) -> bool do return string_ends_with(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_suffix_ptr: s_ptr(s: suffix), d_suffix_len: s_len(s: suffix)) end

/** Returns s with leading and trailing whitespace removed. */
export let trim = fn (s: string) -> string do return to_str(packed: string_trim(a_s_ptr: s_ptr(s), b_s_len: s_len(s))) end

/** Returns s with all characters converted to uppercase. */
let to_upper = fn (s: string) -> string do return to_str(packed: string_to_upper(a_s_ptr: s_ptr(s), b_s_len: s_len(s))) end

/** Returns s with all characters converted to lowercase. */
export let to_lower = fn (s: string) -> string do return to_str(packed: string_to_lower(a_s_ptr: s_ptr(s), b_s_len: s_len(s))) end

/** Replaces all occurrences of from_str with to_str in s. */
export let replace = fn (s: string, from_str: string, to_str: string) -> string do
  return pun_val(a_x: string_replace(a_s_ptr: s_ptr(s), b_s_len: s_len(s),
    c_from_ptr: s_ptr(s: from_str), d_from_len: s_len(s: from_str),
    e_to_ptr: s_ptr(s: to_str), f_to_len: s_len(s: to_str)))
end

/** Returns the character at the given index. */
export let char_at = fn (s: string, idx: i64) -> char do return string_char_at(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_idx: idx) end

/** Converts a char to its UTF-8 encoded string (1-4 bytes). Negative inputs yield "". */
export let from_char = fn (c: char) -> string do return to_str(packed: string_from_char(a_c: cast.i32_of(x: cast.i64_of(x: c)))) end

/** Converts an i64 integer to its string representation. */
export let from_i64 = fn (val: i64) -> string do return to_str(packed: string_from_i64(a_val: val)) end

/**
Converts a float to its string representation (~17 significant digits, no
trailing zeros; fixed notation for moderate exponents, else scientific).
*/
export let from_float = fn (val: float) -> string do return to_str(packed: string_from_float(a_val: val)) end

/** Converts a bool to "true" or "false". */
export let from_bool = fn (val: bool) -> string do return to_str(packed: string_from_bool(a_val: val)) end

/** Raw string-to-i64 conversion (returns 0 on invalid input; callers gate with is_valid_i64). */
export let to_i64_raw = fn (s: string) -> i64 do return string_to_i64(a_s_ptr: s_ptr(s), b_s_len: s_len(s)) end

/** Parses a string as an i64. Raises InvalidI64 on invalid input. */
let to_i64 = fn (s: string) -> i64 throws { InvalidI64 } do
  if is_valid_i64(s) then
    return to_i64_raw(s)
  else
    raise InvalidI64(s)
  end
end

/** Returns true if the string is a valid i64. */
let is_valid_i64 = fn (s: string) -> bool do return string_is_valid_i64(a_s_ptr: s_ptr(s), b_s_len: s_len(s)) end

let rev_string_list = fn (xs: [ string ], acc: [ string ]) -> [ string ] do
  match xs do
    | [] -> return acc
    | v :: rest -> return rev_string_list(xs: rest, acc: v :: acc)
  end
end

let split_go = fn (s: string, sep: string, acc: [ string ]) -> [ string ] do
  let idx = index_of(s, sub: sep)
  if idx < 0 then
    return rev_string_list(xs: s :: acc, acc: [])
  else
    let head = substring(s, start: 0, len: idx)
    let sep_len = length(s: sep)
    let tail_start = idx + sep_len
    let tail_len = length(s) - tail_start
    let tail = substring(s, start: tail_start, len: tail_len)
    return split_go(s: tail, sep, acc: head :: acc)
  end
end

/**
 * Splits s by the given separator and returns a list of substrings.
 * Returns a single-element list if sep is empty or not found.
 */
export let split = fn (s: string, sep: string) -> [ string ] do
  if length(s: sep) == 0 then
    return s :: []
  else
    return split_go(s, sep, acc: [])
  end
end

/** Returns the Unicode codepoint of the character at the given index, or -1 if out of bounds. */
export let char_code = fn (s: string, idx: i64) -> i64 do return string_char_code(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_idx: idx) end

/** Encodes a Unicode codepoint as a UTF-8 string (1-4 bytes). Negative inputs yield "". */
export let from_char_code = fn (code: i64) -> string do return to_str(packed: string_from_char_code(a_code: code)) end

/**
Parses a string as a float (returns 0.0 on malformed input; callers gate
with is_valid_f64).
*/
let to_f64_raw = fn (s: string) -> f64 do return string_to_f64(a_s_ptr: s_ptr(s), b_s_len: s_len(s)) end

/** Returns true if the string is a syntactically valid f64 literal. */
let is_valid_f64 = fn (s: string) -> bool do return string_is_valid_f64(a_s_ptr: s_ptr(s), b_s_len: s_len(s)) end

/** Parses a string as an f64. Returns None on invalid input. */
export let parse_f64_checked = fn (s: string) -> Option<f64> do
  if is_valid_f64(s) then
    return Some(val: to_f64_raw(s))
  else
    return None
  end
end

/** Parses a string as an f64. Raises InvalidF64 on invalid input. */
export let to_f64 = fn (s: string) -> f64 throws { InvalidF64 } do
  if is_valid_f64(s) then
    return to_f64_raw(s)
  else
    raise InvalidF64(s)
  end
end

/** Repeats the string s n times. */
export let repeat = fn (s: string, n: i64) -> string do return to_str(packed: string_repeat(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_n: n)) end

/** Pads s on the left to width characters using fill as padding. */
export let pad_left = fn (s: string, width: i64, fill: string) -> string do return to_str(packed: string_pad_left(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_width: width, d_fill_ptr: s_ptr(s: fill), e_fill_len: s_len(s: fill))) end

/** Pads s on the right to width characters using fill as padding. */
export let pad_right = fn (s: string, width: i64, fill: string) -> string do return to_str(packed: string_pad_right(a_s_ptr: s_ptr(s), b_s_len: s_len(s), c_width: width, d_fill_ptr: s_ptr(s: fill), e_fill_len: s_len(s: fill))) end

/** Concatenates two strings. Equivalent to a ++ b. */
export let concat = fn (a: string, b: string) -> string do
  return a ++ b
end

let join_go = fn (xs: [ string ], sep: string, acc: string) -> string do
  match xs do
    | [] -> return acc
    | v :: rest ->
      match rest do
        | [] -> return acc ++ v
        | _ :: _ -> return join_go(xs: rest, sep, acc: acc ++ v ++ sep)
      end
  end
end

/** Joins a list of strings with a separator between each element. */
export let join = fn (xs: [ string ], sep: string) -> string do
  return join_go(xs, sep, acc: "")
end

/** Parses a string as an i64, returning None on failure. */
export let parse_i64 = fn (s: string) -> Option<i64> do
  if is_valid_i64(s) then
    return Some(val: to_i64_raw(s))
  else
    return None
  end
end
