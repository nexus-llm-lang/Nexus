/**
 * argparse: Declarative CLI argument parsing for nexus tools.
 *
 * Replaces the hand-rolled strip_X_flag / parse_args_go walkers in
 * src/main.nx and src/tools. The module is pure
 * (no I/O, no raises): parse() returns a ParseResult carrying the
 * resolved values plus a Diagnostic list — callers throw/print as they
 * see fit. Usage strings are rendered from the same spec list so help
 * cannot drift from parse.
 *
 * Design:
 *   - ArgSpec declares one flag/option/positional/subcommand entry.
 *   - parse(args, specs) walks the argv exactly once, classifying
 *     tokens against the spec list, and returns:
 *     - a list of ParsedArg(name, value) keyed by ArgSpec.name
 *     - the leftover `remaining` tokens after a `--` cutoff (or empty)
 *     - a Diagnostic list for unknown flags / missing values /
 *       disallowed values (caller maps to InvalidUsage as needed).
 *   - Lookup helpers get_flag / get_opt / get_positional /
 *     get_positional_all read out values without dictionary-ish
 *     primitives the stdlib doesn't have.
 *   - render_usage(prog_name, summary, specs) builds the consolidated
 *     usage string deterministically from the spec list. Drives
 *     print_usage in main.nx.
 *
 * Subcommand dispatch lives one level above: detect_subcommand(args, name)
 * peels the program-name token plus a single keyword. Order-sensitive
 * routing (repl short-circuits before --output parsing) stays in the
 * driver — argparse only provides the primitive.
 *
 * Implementation is split into sub-modules:
 *   argparse/spec.nx   — ArgKind, ArgSpec types + builder helpers
 *   argparse/parse.nx  — parse / parse_permissive / get_* / detect_subcommand
 *   argparse/help.nx   — render_usage / render_subcommand_help / render_subcommand_overview
 */

import * as specmod from "std:argparse/spec"
import * as parsemod from "std:argparse/parse"
import * as helpmod from "std:argparse/help"

// ─── Spec builders (delegates to spec) ─────────────────────────────────────

export let spec_flag = fn (name: string, short: string, long: string, help: string) -> ArgSpec do
  return specmod.spec_flag(name, short, long, help)
end

export let spec_opt = fn (name: string, short: string, long: string, required: bool, help: string) -> ArgSpec do
  return specmod.spec_opt(name, short, long, required, help)
end

export let spec_positional = fn (name: string, required: bool, help: string) -> ArgSpec do
  return specmod.spec_positional(name, required, help)
end

export let spec_subcommand = fn (name: string, help: string) -> ArgSpec do
  return specmod.spec_subcommand(name, help)
end

// ─── Core parse (delegates to parsemod) ────────────────────────────────────

export let parse = fn (args: [string], specs: [ArgSpec]) -> ParseResult do
  return parsemod.parse(args, specs)
end

export let parse_permissive = fn (args: [string], specs: [ArgSpec]) -> ParseResult do
  return parsemod.parse_permissive(args, specs)
end

// ─── Lookup helpers (delegates to parsemod) ────────────────────────────────

export let get_flag = fn (result: ParseResult, name: string) -> bool do
  return parsemod.get_flag(result, name)
end

export let get_opt = fn (result: ParseResult, name: string) -> Option<string> do
  return parsemod.get_opt(result, name)
end

export let get_positional = fn (result: ParseResult, name: string) -> [string] do
  return parsemod.get_positional(result, name)
end

export let get_positionals_all = fn (result: ParseResult) -> [string] do
  return parsemod.get_positionals_all(result)
end

export let get_remaining = fn (result: ParseResult) -> [string] do
  return parsemod.get_remaining(result)
end

export let get_diags = fn (result: ParseResult) -> [Diagnostic] do
  return parsemod.get_diags(result)
end

export let is_ok = fn (result: ParseResult) -> bool do
  return parsemod.is_ok(result)
end

export let first_error = fn (result: ParseResult) -> string do
  return parsemod.first_error(result)
end

// ─── Subcommand detection (delegates to parsemod) ──────────────────────────

export let detect_subcommand = fn (args: [string], kw: string) -> SubcommandHit do
  return parsemod.detect_subcommand(args, kw)
end

// ─── Usage rendering (delegates to help) ───────────────────────────────────

export let render_usage = fn (summary: string, specs: [ArgSpec]) -> string do
  return helpmod.render_usage(summary, specs)
end

export let category_label = fn (c: SubcommandCategory) -> string do
  return helpmod.category_label(c)
end

export let subspec = fn (
  name: string,
  synopsis: string,
  description: string,
  flags: [ArgSpec],
  examples: [Example],
  see_also: [string],
  exit_codes: [ExitCode],
  category: SubcommandCategory
) -> SubcommandSpec do
  return helpmod.subspec(name, synopsis, description, flags, examples, see_also, exit_codes, category)
end

export let example = fn (command: string, comment: string) -> Example do
  return helpmod.example(command, comment)
end

export let exit_code = fn (code: i64, meaning: string) -> ExitCode do
  return helpmod.exit_code(code, meaning)
end

export let render_subcommand_help = fn (prog: string, spec: SubcommandSpec) -> string do
  return helpmod.render_subcommand_help(prog, spec)
end

export let render_subcommand_overview = fn (summary: string, subs: [SubcommandSpec], globals: [ArgSpec]) -> string do
  return helpmod.render_subcommand_overview(summary, subs, globals)
end
