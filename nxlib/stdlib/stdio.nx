/**
 * stdio: Standard I/O operations for console output.
 *
 * Provides print (no newline) and println (with newline) for writing
 * strings to stdout. Both require the Console effect.
 */
import external nxlib/stdlib/stdio.wasm

/// Prints a string to stdout (no trailing newline).
pub external print = [=[__nx_print]=] : (val: string) -> unit effect { Console }

/// Prints a string to stdout followed by a newline.
pub let println = fn (val: string) -> unit effect { Console } do
  let msg = val ++ [=[\n]=]
  return print(val: msg)
endfn
