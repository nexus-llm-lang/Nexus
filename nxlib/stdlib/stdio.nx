/** stdio: Standard I/O operations for console I/O. */
import external "stdlib/stdlib.wasm"

external __nx_print = "__nx_print" : (val: string) -> unit
external __nx_eprint = "__nx_eprint" : (val: string) -> unit
external __nx_read_line = "__nx_read_line" : () -> string
external __nx_getchar = "__nx_getchar" : () -> string

/// Print a string without newline.
let print = fn (val: string) -> unit require { PermConsole } do
  return __nx_print(val: val)
end

/// Print a string with newline.
let println = fn (val: string) -> unit require { PermConsole } do
  let msg = val ++ "\n"
  return __nx_print(val: msg)
end

/// Print a string to stderr without newline.
let eprint = fn (val: string) -> unit require { PermConsole } do
  return __nx_eprint(val: val)
end

/// Print a string to stderr with newline.
let eprintln = fn (val: string) -> unit require { PermConsole } do
  let msg = val ++ "\n"
  return __nx_eprint(val: msg)
end

/// Read a line from "stdin."
let read_line = fn () -> string require { PermConsole } do
  return __nx_read_line()
end

/// Read a single character from "stdin."
let getchar = fn () -> string require { PermConsole } do
  return __nx_getchar()
end

export port Console do
  fn print(val: string) -> unit
  fn println(val: string) -> unit
  fn eprint(val: string) -> unit
  fn eprintln(val: string) -> unit
  fn read_line() -> string
  fn getchar() -> string
end

/// Default Console handler — delegates to direct-call API.
export let system_handler = handler Console require { PermConsole } do
  fn print(val: string) -> unit do
    return print(val: val)
  end
  fn println(val: string) -> unit do
    return println(val: val)
  end
  fn eprint(val: string) -> unit do
    return eprint(val: val)
  end
  fn eprintln(val: string) -> unit do
    return eprintln(val: val)
  end
  fn read_line() -> string do
    return read_line()
  end
  fn getchar() -> string do
    return getchar()
  end
end
