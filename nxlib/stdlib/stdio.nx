/** stdio: Standard I/O operations for console I/O. */
import external stdlib/stdlib.wasm

external __nx_print = "__nx_print" : (val: string) -> unit
external __nx_read_line = "__nx_read_line" : () -> string
external __nx_getchar = "__nx_getchar" : () -> string

/// Print a string without newline.
pub let print = fn (val: string) -> unit require { PermConsole } do
  return __nx_print(val: val)
end

/// Print a string with newline.
pub let println = fn (val: string) -> unit require { PermConsole } do
  let msg = val ++ "\n"
  return __nx_print(val: msg)
end

/// Read a line from stdin.
pub let read_line = fn () -> string require { PermConsole } do
  return __nx_read_line()
end

/// Read a single character from stdin.
pub let getchar = fn () -> string require { PermConsole } do
  return __nx_getchar()
end

pub port Console do
  fn print(val: string) -> unit
  fn println(val: string) -> unit
  fn read_line() -> string
  fn getchar() -> string
end

/// Default Console handler — delegates to direct-call API.
pub let system_handler = handler Console require { PermConsole } do
  fn print(val: string) -> unit do
    return print(val: val)
  end
  fn println(val: string) -> unit do
    return println(val: val)
  end
  fn read_line() -> string do
    return read_line()
  end
  fn getchar() -> string do
    return getchar()
  end
end
