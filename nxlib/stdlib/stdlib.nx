import external nxlib/stdlib/stdlib.wasm

external __nx_i64_to_string : (val: i64) -> string = "i64_to_string"
external __nx_float_to_string : (val: float) -> string = "float_to_string"
external __nx_bool_to_string : (val: bool) -> string = "bool_to_string"
external __nx_array_length : (arr: &[| T |]) -> i64 = "array_length"

pub fn i64_to_string(val: i64) -> string do
  return __nx_i64_to_string(val: val)
endfn

pub fn float_to_string(val: float) -> string do
  return __nx_float_to_string(val: val)
endfn

pub fn bool_to_string(val: bool) -> string do
  return __nx_bool_to_string(val: val)
endfn

pub fn array_length<T>(arr: &[| T |]) -> i64 do
  return __nx_array_length(arr: arr)
endfn
