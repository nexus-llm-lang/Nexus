import external [=[nxlib/stdlib/random.wasm]=]

let __nx_random_i64 = external [=[__nx_random_i64]=] : () -> i64 effect { IO }
let __nx_random_range = external [=[__nx_random_range]=] : (min: i64, max: i64) -> i64 effect { IO }

pub let next_i64 = fn () -> i64 effect { IO } do
  return perform __nx_random_i64()
endfn

pub let range = fn (min: i64, max: i64) -> i64 effect { IO } do
  return perform __nx_random_range(min: min, max: max)
endfn

pub let next_bool = fn () -> bool effect { IO } do
  let n = perform range(min: 0, max: 2)
  return n == 1
endfn
