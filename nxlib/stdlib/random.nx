/**
 * random: Pseudo-random number generation.
 *
 * Delegates to a native WASM PRNG via FFI. The Console effect is
 * required because random number generation is an observable side
 * effect. next_i64 returns a full-range value; range returns a value
 * in [min, max); next_bool is derived from range.
 */
import external nxlib/stdlib/random.wasm

/// Returns a random i64 value.
pub external next_i64 = [=[__nx_random_i64]=] : () -> i64 effect { Console }

/// Returns a random i64 in the half-open range [min, max).
pub external range = [=[__nx_random_range]=] : (min: i64, max: i64) -> i64 effect { Console }

/// Returns a random boolean value.
pub let next_bool = fn () -> bool effect { Console } do
  let n = range(min: 0, max: 2)
  return n == 1
endfn
