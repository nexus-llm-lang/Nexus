/**
 * stringmap: hash map from string keys to i64 values.
 *
 * Open-addressed (linear probing); keys are copied on put. See
 * std:runtime/collection for the implementation. Uses opaque linear
 * handles — each map must be freed after use. Suitable for symbol tables,
 * environments, and other string-keyed lookups.
 */
import { length as str_length, substring, index_of } from "std:str"
import { smap_put_str, smap_get_str, smap_has_str, smap_del_str, smap_keys_str } from "std:runtime/collection"
import { __nx_smap_new, __nx_smap_size, __nx_smap_val_count, __nx_smap_val_at, __nx_smap_free } from "std:runtime/collection"

/// An opaque string map handle (linear — must be freed).
export opaque type StringMap = StringMap(id: i64)

/// Result of a key lookup: Found with a value, or Missing.
export type Lookup = Found(value: i64) | Missing


// --- Helpers ---

let split_lines_go = fn (s: string, acc: [ string ]) -> [ string ] do
  if str_length(s) == 0 then
    return acc
  else
    let idx = index_of(s, sub: "\n")
    if idx < 0 then
      return s :: acc
    else
      let head = substring(s, start: 0, len: idx)
      let tail_start = idx + 1
      let tail_len = str_length(s) - tail_start
      let tail = substring(s, start: tail_start, len: tail_len)
      return split_lines_go(s: tail, acc: head :: acc)
    end
  end
end

let reverse_go = fn <T>(xs: [ T ], acc: [ T ]) -> [ T ] do
  match xs do
    | [] -> return acc
    | v :: rest ->
      return reverse_go(xs: rest, acc: v :: acc)
  end
end

let split_lines = fn (s: string) -> [ string ] do
  let rev = split_lines_go(s, acc: [])
  return reverse_go(xs: rev, acc: [])
end

let collect_vals = fn (id: i64, idx: i64, count: i64, acc: [ i64 ]) -> [ i64 ] do
  if idx >= count then
    return acc
  else
    let v = __nx_smap_val_at(a_id: id, b_idx: idx)
    return collect_vals(id, idx: idx + 1, count, acc: v :: acc)
  end
end

// --- Public API ---

/// Creates an empty string map.
export let empty = fn () -> %StringMap do
  let id = __nx_smap_new()
  let m = StringMap(id)
  let %lm = m
  return %lm
end

/// Inserts or updates a key-value pair. Consumes and returns the map.
export let put = fn (map: %StringMap, key: string, value: i64) -> %StringMap do
  let StringMap(id) = map
  let _ = smap_put_str(id, key, value)
  let m = StringMap(id)
  let %lm = m
  return %lm
end

/// Looks up a key, returning Found(value) or Missing.
export let get = fn (map: &StringMap, key: string) -> Lookup do
  let StringMap(id) = map
  let found = smap_has_str(id, key)
  if found then
    let v = smap_get_str(id, key, default_val: 0)
    return Found(value: v)
  else
    return Missing
  end
end

/// Looks up a key, returning the value or a default if missing.
export let get_or = fn (map: &StringMap, key: string, default: i64) -> i64 do
  let StringMap(id) = map
  return smap_get_str(id, key, default_val: default)
end

/// Returns true if the map contains the given key.
export let contains_key = fn (map: &StringMap, key: string) -> bool do
  let StringMap(id) = map
  return smap_has_str(id, key)
end

/// Removes a key from the map. Consumes and returns the map.
export let remove = fn (map: %StringMap, key: string) -> %StringMap do
  let StringMap(id) = map
  let _ = smap_del_str(id, key)
  let m = StringMap(id)
  let %lm = m
  return %lm
end

/// Returns the number of entries in the map.
export let size = fn (map: &StringMap) -> i64 do
  let StringMap(id) = map
  return __nx_smap_size(a_id: id)
end

/// Returns a list of all keys in the map.
export let keys = fn (map: &StringMap) -> [ string ] do
  let StringMap(id) = map
  let raw = smap_keys_str(id)
  if str_length(s: raw) == 0 then
    return []
  else
    return split_lines(s: raw)
  end
end

/// Returns a list of all values in the map.
export let values = fn (map: &StringMap) -> [ i64 ] do
  let StringMap(id) = map
  let count = __nx_smap_val_count(a_id: id)
  let rev = collect_vals(id, idx: 0, count, acc: [])
  return reverse_go(xs: rev, acc: [])
end

/// Frees the string map. Consumes the linear handle.
export let free = fn (map: %StringMap) -> unit do
  let StringMap(id) = map
  let _ = __nx_smap_free(a_id: id)
  return ()
end
