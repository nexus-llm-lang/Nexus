/**
 * stringmap: FFI-backed hash map from string keys to i64 values.
 *
 * Backed by Rust std::collections::HashMap<String, i64> via WASM FFI.
 * Uses opaque linear handles — each map must be freed after use.
 * Suitable for symbol tables, environments, and other string-keyed lookups.
 */
import external "stdlib/stdlib.wasm"
import { length as str_length, substring, index_of } from "stdlib/string_ops.nx"

/// An opaque string map handle (linear — must be freed).
export opaque type StringMap = StringMap(id: i64)

/// Result of a key lookup: Found with a value, or Missing.
export type Lookup = Found(value: i64) | Missing

external __nx_smap_new = "__nx_smap_new" : () -> i64
external __nx_smap_put = "__nx_smap_put" : (id: i64, key: string, value: i64) -> i64
external __nx_smap_get = "__nx_smap_get" : (id: i64, key: string, default_val: i64) -> i64
external __nx_smap_has = "__nx_smap_has" : (id: i64, key: string) -> bool
external __nx_smap_del = "__nx_smap_del" : (id: i64, key: string) -> bool
external __nx_smap_size = "__nx_smap_size" : (id: i64) -> i64
external __nx_smap_keys = "__nx_smap_keys" : (id: i64) -> string
external __nx_smap_val_count = "__nx_smap_val_count" : (id: i64) -> i64
external __nx_smap_val_at = "__nx_smap_val_at" : (id: i64, idx: i64) -> i64
external __nx_smap_free = "__nx_smap_free" : (id: i64) -> bool

// --- Helpers ---

let split_lines_go = fn (s: string, acc: [ string ]) -> [ string ] do
  if str_length(s: s) == 0 then
    return acc
  else
    let idx = index_of(s: s, sub: "\n")
    if idx < 0 then
      return s :: acc
    else
      let head = substring(s: s, start: 0, len: idx)
      let tail_start = idx + 1
      let tail_len = str_length(s: s) - tail_start
      let tail = substring(s: s, start: tail_start, len: tail_len)
      return split_lines_go(s: tail, acc: head :: acc)
    end
  end
end

let reverse_go = fn <T>(xs: [ T ], acc: [ T ]) -> [ T ] do
  match xs do
    case [] -> return acc
    case v :: rest ->
      return reverse_go(xs: rest, acc: v :: acc)
  end
end

let split_lines = fn (s: string) -> [ string ] do
  let rev = split_lines_go(s: s, acc: [])
  return reverse_go(xs: rev, acc: [])
end

let collect_vals = fn (id: i64, idx: i64, count: i64, acc: [ i64 ]) -> [ i64 ] do
  if idx >= count then
    return acc
  else
    let v = __nx_smap_val_at(id: id, idx: idx)
    return collect_vals(id: id, idx: idx + 1, count: count, acc: v :: acc)
  end
end

// --- Public API ---

/// Creates an empty string map.
export let empty = fn () -> %StringMap do
  let id = __nx_smap_new()
  let m = StringMap(id: id)
  let %lm = m
  return %lm
end

/// Inserts or updates a key-value pair. Consumes and returns the map.
export let put = fn (map: %StringMap, key: string, value: i64) -> %StringMap do
  let StringMap(id: id) = map
  let _ = __nx_smap_put(id: id, key: key, value: value)
  let m = StringMap(id: id)
  let %lm = m
  return %lm
end

/// Looks up a key, returning Found(value) or Missing.
export let get = fn (map: &StringMap, key: string) -> Lookup do
  let StringMap(id: id) = map
  let found = __nx_smap_has(id: id, key: key)
  if found then
    let v = __nx_smap_get(id: id, key: key, default_val: 0)
    return Found(value: v)
  else
    return Missing
  end
end

/// Looks up a key, returning the value or a default if missing.
export let get_or = fn (map: &StringMap, key: string, default: i64) -> i64 do
  let StringMap(id: id) = map
  return __nx_smap_get(id: id, key: key, default_val: default)
end

/// Returns true if the map contains the given key.
export let contains_key = fn (map: &StringMap, key: string) -> bool do
  let StringMap(id: id) = map
  return __nx_smap_has(id: id, key: key)
end

/// Removes a key from the map. Consumes and returns the map.
export let remove = fn (map: %StringMap, key: string) -> %StringMap do
  let StringMap(id: id) = map
  let _ = __nx_smap_del(id: id, key: key)
  let m = StringMap(id: id)
  let %lm = m
  return %lm
end

/// Returns the number of entries in the map.
export let size = fn (map: &StringMap) -> i64 do
  let StringMap(id: id) = map
  return __nx_smap_size(id: id)
end

/// Returns a list of all keys in the map.
export let keys = fn (map: &StringMap) -> [ string ] do
  let StringMap(id: id) = map
  let raw = __nx_smap_keys(id: id)
  if str_length(s: raw) == 0 then
    return []
  else
    return split_lines(s: raw)
  end
end

/// Returns a list of all values in the map.
export let values = fn (map: &StringMap) -> [ i64 ] do
  let StringMap(id: id) = map
  let count = __nx_smap_val_count(id: id)
  let rev = collect_vals(id: id, idx: 0, count: count, acc: [])
  return reverse_go(xs: rev, acc: [])
end

/// Frees the string map. Consumes the linear handle.
export let free = fn (map: %StringMap) -> unit do
  let StringMap(id: id) = map
  let _ = __nx_smap_free(id: id)
  return ()
end
