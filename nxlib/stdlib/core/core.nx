/**
 * core: polymorphic identity function.
 *
 * The identity function lives here because it is genuinely module-agnostic
 * (no list, tuple, math, or i/o context is appropriate).  Other utilities
 * have canonical homes:
 *   Pair, fst, snd     -> std:tuple
 *   Partition          -> std:list
 *   negate             -> std:math
 */

/** Identity function: returns its argument unchanged. */
export let id = fn <T>(val: T) -> T do
  return val
end
