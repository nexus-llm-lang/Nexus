/**
 * exn: Exception utilities.
 */
import { from_i64, InvalidI64, InvalidF64 } from "std:str"
import { EmptyOption } from "std:option"
import { DivisionByZero } from "std:math"
import external "nexus:intrinsic"

/**
Raised by `todo()` to signal an unimplemented program point. The `msg`
field carries a caller-supplied description; `todo()` with no argument
supplies a generic placeholder. Mirrors Rust `todo!()` / Haskell
`undefined` for incremental authoring.
*/
export exception NotImplemented(msg: string)

// Backtrace primitives (V1). Codegen-inlines these to direct
// reads from page 18 of linear memory:
//   bt_depth() -> i64  : saved depth at the last throw (snapshot)
//   bt_frame(idx)      : packed (ptr<<32)|len for ring slot `(idx & 63)`,
//                        the function name pushed at depth `idx`.
// Function prologues push their name at `depth++ & 63` for every
// can_throw function (EffectMap-driven). Pure functions are not
// instrumented, so they do not appear in the backtrace.
external bt_depth = "bt_depth" : () -> i64
external bt_frame = "bt_frame" : (idx: i64) -> string

export let to_string = fn (exn: Exn) -> string do
  match exn do
    | RuntimeError(val: msg) -> return "RuntimeError: " ++ msg
    | InvalidIndex(val: i) -> return "InvalidIndex: " ++ from_i64(val: i)
    | InvalidUnicode(code: c) -> return "InvalidUnicode: " ++ from_i64(val: c)
    | EmptyOption(op: o) -> return "EmptyOption: " ++ o
    | DivisionByZero(op: o) -> return "DivisionByZero: " ++ o
    | InvalidI64(s) -> return "InvalidI64: '" ++ s ++ "'"
    | InvalidF64(s) -> return "InvalidF64: '" ++ s ++ "'"
    | NotImplemented(msg: m) -> return "NotImplemented: " ++ m
    | _ -> return "<exception>"
  end
end

/**
A polymorphic "not implemented" marker for incomplete programs.

Typechecks anywhere — the return type is a free type variable, so a call
site such as `return todo()` unifies with whatever the surrounding context
expects. At runtime it always raises `NotImplemented`.

Caveat: no call-site source-position is captured. V1 wires
function-name-only backtraces (via `bt_depth` / `bt_frame` above) but
source spans require sourcemap/DWARF emission (V2, follow-up issue
i6fj.1). The `todo()` message stays a fixed placeholder until then.

Usage:
  import { todo } from "std:exn"
  let f = fn (n: i64) -> i64 throws { NotImplemented } do
    return todo()
  end
*/
export let todo = fn <T>() -> T throws { NotImplemented } do
  throw NotImplemented(msg: "not yet implemented")
end

let bt_collect = fn (i: i64, acc: [string]) -> [string] do
  if i < 0 then return acc end
  let name = bt_frame(idx: i)
  return bt_collect(i: i - 1, acc: name :: acc)
end

/**
Returns the call stack captured at the point where the exception was raised.
Each entry is a function name. Order: outermost frame first (index 0),
innermost (raising frame) last — i.e. `[main, f, g, h]` for a throw from
`h` called by `g` called by `f` called by `main`.

Only `can_throw` functions are instrumented (EffectMap-driven
V1), so pure helpers do not appear. Depth is capped at the 64-slot ring
buffer in page 18; under very deep stacks the oldest frames are lost.
*/
export let backtrace = fn (exn: Exn) -> [string] do
  let _ = exn
  let depth = bt_depth()
  return bt_collect(i: depth - 1, acc: [])
end
