/**
 * chan: One-shot linear channels (Phase 1 of nexus-5ldt).
 *
 * `oneshot()` returns a paired sender/receiver. Each end is opaque and
 * linear: `send` consumes the sender exactly once, `recv` consumes the
 * receiver exactly once. The Nexus linearity checker enforces both halves
 * statically; the runtime traps on ABI misuse only.
 *
 * Single-threaded execution model (no scheduler yet): `send` must lexically
 * precede `recv` in evaluation order. Recv-on-empty traps. Phase 3
 * replaces the trap with a yield to the cooperative scheduler — the API
 * surface is forward-compatible.
 *
 * Values cross the FFI boundary as i64. Generic over T for the public API;
 * the runtime stores the raw i64 representation. Heap-typed Ts (strings,
 * records) reach the runtime as pointers; their backing memory must outlive
 * the recv. In single-threaded use this holds trivially because send and
 * recv run in the same store.
 */
import external "nexus:runtime/chan"

external __nx_chan_oneshot = "__nx_chan_oneshot" : () -> i64
external __nx_chan_send = "__nx_chan_send" : <T>(id: i64, val: T) -> unit
external __nx_chan_recv = "__nx_chan_recv" : <T>(id: i64) -> T

/// Sender end. Linear — must be passed to `send` exactly once.
export opaque type Tx<T> = Tx(id: i64)

/// Receiver end. Linear — must be passed to `recv` exactly once.
export opaque type Rx<T> = Rx(id: i64)

/// A paired sender/receiver returned by `oneshot()`. The pair itself is a
/// plain value; the two fields are linear and must each be consumed.
/// Named `ChanPair` (not `Pair`) to avoid colliding with `core.Pair` /
/// `tuple.Pair` in the global type registry.
export type ChanPair<T> = ChanPair(tx: %Tx<T>, rx: %Rx<T>)

/// Allocate a fresh one-shot channel and return its sender/receiver pair.
/// The two ends share a runtime cell that holds at most one value.
export let oneshot = fn <T>() -> ChanPair<T> do
  let id = __nx_chan_oneshot()
  let tx = Tx(id)
  let rx = Rx(id)
  let %ltx = tx
  let %lrx = rx
  return ChanPair(tx: %ltx, rx: %lrx)
end

/// Deposit a value into the channel. Consumes the sender end.
export let send = fn <T>(tx: %Tx<T>, val: T) -> unit do
  let Tx(id) = tx
  __nx_chan_send(id, val)
end

/// Read the value out of the channel. Consumes the receiver end.
/// Traps if no sender has run yet (single-threaded model).
export let recv = fn <T>(rx: %Rx<T>) -> T do
  let Rx(id) = rx
  return __nx_chan_recv(id)
end
