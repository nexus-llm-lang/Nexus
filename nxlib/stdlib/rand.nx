/**
 * random: Pseudo-random number generation.
 *
 * Provides Random port with next_i64, range, and next_bool operations.
 * Requires PermRandom capability.
 */
import external "std:rand"

external __nx_random_i64 = "__nx_random_i64" : () -> i64
external __nx_random_range = "__nx_random_range" : (min: i64, max: i64) -> i64

export cap Random do
  fn next_i64() -> i64
  fn range(min: i64, max: i64) -> i64
  fn next_bool() -> bool
end

export let system_handler = handler Random require { PermRandom } do
  fn next_i64() -> i64 do
    return __nx_random_i64()
  end
  fn range(min: i64, max: i64) -> i64 do
    return __nx_random_range(min, max)
  end
  fn next_bool() -> bool do
    return __nx_random_range(min: 0, max: 2) == 1
  end
end
