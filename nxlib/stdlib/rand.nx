/**
 * rand: Pseudo-random number generation.
 *
 * Provides Random port with next_i64, range, and next_bool operations.
 * Requires PermRandom capability.
 *
 * ── Algorithm ────────────────────────────────────────────────────────────
 * Linear congruential generator (PCG / Lehmer family):
 *
 *   state' = state * 6364136223846793005 + 1442695040888963407   (mod 2^64)
 *
 * The output is `state' & 0x7FFFFFFFFFFFFFFF` (top bit cleared) so the
 * returned i64 is always non-negative. There is no XSH-RR output
 * permutation: raw new state is the output. This is intentionally a
 * low-grade PRNG and NOT suitable for cryptography, sampling, or anything
 * where correlation between successive outputs matters.
 *
 * ── State cell layout ────────────────────────────────────────────────────
 * 16 bytes reserved at fixed offset RAND_STATE_OFFSET = 983040
 * (= 15 * 65536, start of page 15 of linear memory).
 *
 *   offset + 0..7   : i64 state (PCG internal)
 *   offset + 8..15  : i64 init flag (0 = uninitialized, 1 = seeded)
 *
 * Why page 15 specifically: the program's data segments and bump heap live
 * well above it, and pages 0..15 are zero-initialised empty real estate that
 * no other allocator touches (only [0,16) is reserved, for the bump cell and
 * the sysio scratch pointer), which is required for the lazy-init flag to be
 * observable as 0 on the very first call regardless of program.
 *
 * ── Lazy-init protocol ───────────────────────────────────────────────────
 * On first `next_i64()`/`range()`/`next_bool()` call:
 *   1. Load init flag at offset+8.
 *   2. If 0: derive a fresh seed by mixing now() (millisecond clock)
 *      with a fixed mixer constant; store at offset+0; set init flag = 1.
 *   3. If non-zero: state already valid, skip seed step.
 *
 * Seed source is `std:clock.now_ms` (CLOCK_REALTIME milliseconds).
 * Sequences from independent program runs that happen to launch within the
 * same wall-clock millisecond will share a seed — acceptable for the
 * "low-grade PRNG" contract above.
 *
 * Determinism contract: given the same internal state at offset+0 and the
 * same init flag value at offset+8, calls to `next_i64()` produce
 * identical byte sequences across runs. Tests cover both directions
 * (same seed → identical sequence, different seeds → divergent sequences).
 */
import * as mem from "std:runtime/mem"
import { now_ms as now } from "std:clock"

// ─── State cell layout (constants) ──────────────────────────────────────────

/** Offset of the i64 state word. */
let state_addr = 983040
/** Offset of the i64 init-flag word (0 = needs seed, 1 = ready). */
let flag_addr = 983048
// ─── PCG step constants ─────────────────────────────────────────────────────

let pcg_multiplier = 6364136223846793005
let pcg_increment = 1442695040888963407
// ─── Seed-mix constants ─────────────────────────────────────────────────────
//
// Both fit in signed i64 (< 2^63). The fallback-seed value is used when
// now() XOR mixer collapses to 0; that should be extremely rare under
// real wall-clock input but we still guard against it so the LCG is never
// stuck at 0 (state=0 is a fixed point: 0 * MUL + 0 = 0).
let seed_mixer = 2305843009213693951
let fallback_seed = 1234567890123456789
// ─── PCG step ───────────────────────────────────────────────────────────────

/**
Advance the PCG state by one step.
`state * MUL + INC` wraps mod 2^64 via wasm's i64.mul/add semantics.
*/
let pcg_step = fn (state: i64) -> i64 do
  return state * pcg_multiplier + pcg_increment
end

// ─── Lazy seed init ─────────────────────────────────────────────────────────

/**
First-call seed install. No-op if the init flag is already set.
Seeds with `now() XOR seed_mixer`, falling back to a fixed nonzero
constant when the mix collapses to 0.
*/
let ensure_seeded = fn () -> unit do
  let flag = mem.load_i64(addr: flag_addr)
  if flag != 0 then return () end
  let now = now()
  let mixed = now ^ seed_mixer
  let seed = if mixed == 0 then fallback_seed else mixed end
  mem.store_i64(addr: state_addr, val: seed)
  mem.store_i64(addr: flag_addr, val: 1)
  return ()
end

/** Advance the state cell by one PCG step and return the new state. */
let advance = fn () -> i64 do
  ensure_seeded()
  let cur = mem.load_i64(addr: state_addr)
  let nxt = pcg_step(state: cur)
  mem.store_i64(addr: state_addr, val: nxt)
  return nxt
end

// ─── Public Random cap ──────────────────────────────────────────────────────

export cap Random do
  fn next_i64() -> i64
  fn range(min: i64, max: i64) -> i64
  fn next_bool() -> bool
end

/** Produce a non-negative i64. Top bit cleared so the result is in [0, 2^63 - 1]. */
let next_i64_raw = fn () -> i64 do
  let n = advance()
  return n & 9223372036854775807
end

/**
Bounded range [min, max). Returns `min` for empty/inverted intervals
rather than raising — safe-fallback contract.
*/
let range_raw = fn (min: i64, max: i64) -> i64 do
  if max <= min then return min end
  let span = max - min
  let n = next_i64_raw()
  return min + (n % span)
end

export let system_handler = handler Random require { PermRandom } do
  fn next_i64() -> i64 do
    return next_i64_raw()
  end
  fn range(min: i64, max: i64) -> i64 do
    return range_raw(min, max)
  end
  fn next_bool() -> bool do
    return range_raw(min: 0, max: 2) == 1
  end
end

// ─── Test/diagnostic surface ────────────────────────────────────────────────
//
// `seed_with` is an escape hatch for the determinism tests
// (`tests/stdlib/stdlib_rand_determinism_pcg_test.nx`). It bypasses the
// lazy-init path so a test can install a known seed and observe a
// byte-equal output sequence on every run. Production code should never
// call it — using it defeats the cap-based isolation that `system_handler`
// provides.

/**
Install an explicit seed and mark the state cell initialised. Used by
determinism tests that need byte-equal sequences across runs.
*/
export let seed_with = fn (seed: i64) -> unit do
  let actual = if seed == 0 then fallback_seed else seed end
  mem.store_i64(addr: state_addr, val: actual)
  mem.store_i64(addr: flag_addr, val: 1)
  return ()
end

/**
Reset the init flag so the next `next_i64()` call re-runs lazy seeding.
Used by tests that need a clean slate between cases within a single
wasm instance.
*/
export let reset = fn () -> unit do
  mem.store_i64(addr: state_addr, val: 0)
  mem.store_i64(addr: flag_addr, val: 0)
  return ()
end
