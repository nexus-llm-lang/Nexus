/**
 * bytebuffer: mutable byte buffer for binary data construction.
 *
 * Uses opaque linear handles. Provides LEB128 encoding, little-endian integer
 * writes, and raw byte/string/buffer append operations. Essential for
 * generating binary formats such as WASM modules.
 *
 * A ByteBuffer `id` is a pointer to a 24-byte header in linear memory, three
 * i64 words: offset 0 = len, offset 8 = cap, offset 16 = data_ptr (0 when
 * cap == 0). Storage comes from the unified bump arena (`arena.alloc_raw`);
 * growth leaks the old data region, which is fine for a bump allocator.
 *
 * `push_f64_str_le` parses its argument as an f64 (via `std:str`'s parser --
 * this is also the path codegen uses to encode f64 literals) and appends the
 * 8 IEEE-754 bytes little-endian. `read_stdin_bytes` reads from fd 0 over WASI
 * `fd_read` in chunks until EOF or the requested byte count.
 */
import * as mem from "std:runtime/mem"
import * as cast from "std:runtime/cast"
import * as arena from "std:runtime/arena"
import { FileNotFound } from "std:fs"
import { write_string_raw as fs_write_string_raw, read_to_string_raw as fs_read_to_string_raw, read_fd_bytes_into } from "std:runtime/sysio"
import { f64_str_bits } from "std:str"
import external "nexus:intrinsic"

/** Type puns (pure passthrough — every Nexus value is an i64 at the WASM level). */
external pun_val = "value_of_i64" : <T>(a_x: i64) -> T
external pun_raw = "value_of_i64" : <T>(a_x: T) -> i64

/** An opaque byte buffer handle (linear — must be freed). */
export opaque type ByteBuffer = ByteBuffer(id: i64)

/**
Mask that turns an arithmetic (signed) i64 >> 7 into a logical one:
(1 << 57) - 1, i.e. clears the top 7 bits after the shift.
*/
let shr7_logical_mask = 144115188075855871
/** 2^32, the multiplier used to pack a (ptr, len) pair into a returned i64. */
let two_pow_32 = 4294967296
// --- header accessors ---

let hdr_len = fn (h: i64) -> i64 do return mem.load_i64(addr: h) end
let hdr_cap = fn (h: i64) -> i64 do return mem.load_i64(addr: h + 8) end
let hdr_data = fn (h: i64) -> i64 do return mem.load_i64(addr: h + 16) end
let set_len = fn (h: i64, v: i64) -> unit do return mem.store_i64(addr: h, val: v) end
let set_cap = fn (h: i64, v: i64) -> unit do return mem.store_i64(addr: h + 8, val: v) end
let set_data = fn (h: i64, v: i64) -> unit do return mem.store_i64(addr: h + 16, val: v) end

// --- low-level helpers ---

let copy_bytes = fn (dst: i64, src: i64, count: i64) -> unit do
  return copy_bytes_at(dst, src, count, i: 0)
end
let copy_bytes_at = fn (dst: i64, src: i64, count: i64, i: i64) -> unit do
  if i >= count then return () end
  let _ = mem.store_u8(addr: dst + i, val: mem.load_u8(addr: src + i))
  return copy_bytes_at(dst, src, count, i: i + 1)
end

/** Pick a new capacity >= `need`: start at max(8, old_cp*2), double until it fits. */
let grow_cap_to = fn (old_cp: i64, need: i64) -> i64 do
  let start = if old_cp * 2 > 8 then old_cp * 2 else 8 end
  return grow_cap_loop(c: start, need)
end
let grow_cap_loop = fn (c: i64, need: i64) -> i64 do
  if c >= need then return c end
  return grow_cap_loop(c: c * 2, need)
end

/** Make sure the buffer at `h` can hold `need` more bytes. */
let ensure_cap = fn (h: i64, need: i64) -> unit do
  let len = hdr_len(h)
  let cur_cp = hdr_cap(h)
  if len + need <= cur_cp then return () end
  let new_cap = grow_cap_to(old_cp: cur_cp, need: len + need)
  let new_data = arena.alloc_raw(size: new_cap)
  let _ = copy_bytes(dst: new_data, src: hdr_data(h), count: len)
  let _ = set_cap(h, v: new_cap)
  return set_data(h, v: new_data)
end

/** Append one byte (low 8 bits) to the buffer at `h`. */
let bput = fn (h: i64, byte: i64) -> unit do
  let _ = ensure_cap(h, need: 1)
  let len = hdr_len(h)
  let _ = mem.store_u8(addr: hdr_data(h) + len, val: byte & 255)
  return set_len(h, v: len + 1)
end

/** Append `count` bytes read from `src` to the buffer at `h`. */
let bput_range = fn (h: i64, src: i64, count: i64) -> unit do
  if count <= 0 then return () end
  let _ = ensure_cap(h, need: count)
  let len = hdr_len(h)
  let _ = copy_bytes(dst: hdr_data(h) + len, src, count)
  return set_len(h, v: len + count)
end

// --- the buf_* primitives (internal) ---

let buf_new = fn () -> i64 do
  let h = arena.alloc_raw(size: 24)
  let _ = set_len(h, v: 0)
  let _ = set_cap(h, v: 0)
  let _ = set_data(h, v: 0)
  return h
end

let buf_push_byte = fn (a_id: i64, b_byte: i64) -> unit do
  return bput(h: a_id, byte: b_byte)
end

let buf_push_i32_le = fn (a_id: i64, b_val: i64) -> unit do
  let _ = bput(h: a_id, byte: b_val & 255)
  let _ = bput(h: a_id, byte: (b_val >> 8) & 255)
  let _ = bput(h: a_id, byte: (b_val >> 16) & 255)
  return bput(h: a_id, byte: (b_val >> 24) & 255)
end

/**
Parse (b_s_ptr, c_s_len) as an f64 and append its 8 IEEE-754 bytes,
little-endian. (This is the path codegen uses to encode f64 literals.)
*/
let buf_push_f64_str_le = fn (a_id: i64, b_s_ptr: i32, c_s_len: i32) -> unit do
  let bits = f64_str_bits(a_s_ptr: b_s_ptr, b_s_len: c_s_len)
  let _ = bput(h: a_id, byte: bits & 255)
  let _ = bput(h: a_id, byte: (bits >> 8) & 255)
  let _ = bput(h: a_id, byte: (bits >> 16) & 255)
  let _ = bput(h: a_id, byte: (bits >> 24) & 255)
  let _ = bput(h: a_id, byte: (bits >> 32) & 255)
  let _ = bput(h: a_id, byte: (bits >> 40) & 255)
  let _ = bput(h: a_id, byte: (bits >> 48) & 255)
  return bput(h: a_id, byte: (bits >> 56) & 255)
end

let buf_push_leb128_u = fn (a_id: i64, b_val: i64) -> unit do
  return leb128_u_go(h: a_id, v: b_val)
end
let leb128_u_go = fn (h: i64, v: i64) -> unit do
  let byte = v & 127
  let rest = (v >> 7) & shr7_logical_mask
  if rest == 0 then return bput(h, byte) end
  let _ = bput(h, byte: byte | 128)
  return leb128_u_go(h, v: rest)
end

let buf_push_leb128_s = fn (a_id: i64, b_val: i64) -> unit do
  return leb128_s_go(h: a_id, v: b_val)
end
let leb128_s_go = fn (h: i64, v: i64) -> unit do
  let byte = v & 127
  let rest = v >> 7
  let done = (rest == 0 && (byte & 64) == 0) || (rest == 0 - 1 && (byte & 64) != 0)
  if done then return bput(h, byte) end
  let _ = bput(h, byte: byte | 128)
  return leb128_s_go(h, v: rest)
end

let buf_push_string = fn (a_id: i64, b_s_ptr: i32, c_s_len: i32) -> unit do
  return bput_range(h: a_id, src: cast.i64_of(x: b_s_ptr), count: cast.i64_of(x: c_s_len))
end

let buf_push_buf = fn (a_dst_id: i64, b_src_id: i64) -> unit do
  return bput_range(h: a_dst_id, src: hdr_data(h: b_src_id), count: hdr_len(h: b_src_id))
end

let buf_length = fn (a_id: i64) -> i64 do
  return hdr_len(h: a_id)
end

let buf_get_byte = fn (a_id: i64, b_idx: i64) -> i64 do
  if b_idx < 0 || b_idx >= hdr_len(h: a_id) then return 0 - 1 end
  return mem.load_u8(addr: hdr_data(h: a_id) + b_idx)
end

/** Buffer contents as a string: allocate a fresh region, copy, return packed. */
let buf_to_string = fn (a_id: i64) -> i64 do
  let len = hdr_len(h: a_id)
  if len <= 0 then return 0 end
  let dst = arena.alloc_raw(size: len)
  let _ = copy_bytes(dst, src: hdr_data(h: a_id), count: len)
  return (dst * two_pow_32) + len
end

/** Write the buffer's bytes to the path at (b_path_ptr, c_path_len) over WASI. */
let buf_write_file = fn (a_id: i64, b_path_ptr: i32, c_path_len: i32) -> bool do
  return fs_write_string_raw(a_path_ptr: b_path_ptr, b_path_len: c_path_len,
    c_content_ptr: cast.i32_of(x: hdr_data(h: a_id)), d_content_len: cast.i32_of(x: hdr_len(h: a_id)))
end

/** Free is a no-op under the bump allocator (arena reset is the reclaim path). */
let buf_free = fn (a_id: i64) -> bool do
  return true
end

let buf_truncate = fn (a_id: i64, b_len: i64) -> unit do
  let cur = hdr_len(h: a_id)
  let n = if b_len < cur then b_len else cur end
  let n2 = if n < 0 then 0 else n end
  return set_len(h: a_id, v: n2)
end

let buf_copy_range = fn (a_dst_id: i64, b_src_id: i64, c_start: i64, d_end_pos: i64) -> unit do
  let src_len = hdr_len(h: b_src_id)
  let start = if c_start < 0 then 0 else c_start end
  let endp = if d_end_pos > src_len then src_len else d_end_pos end
  if endp <= start then return () end
  return bput_range(h: a_dst_id, src: hdr_data(h: b_src_id) + start, count: endp - start)
end

/**
Read the file at (a_path_ptr, b_path_len) into a new buffer; returns its
id, or -1 on error. An empty file also reads as -1 (read returns 0 for both).
*/
let buf_read_file = fn (a_path_ptr: i32, b_path_len: i32) -> i64 do
  let packed = fs_read_to_string_raw(a_path_ptr, b_path_len)
  if packed == 0 then return 0 - 1 end
  let h = buf_new()
  let _ = bput_range(h, src: packed >> 32, count: packed & 4294967295)
  return h
end

/**
Read up to `a_n` bytes from stdin (fd 0) into a fresh buffer; return its id.
Reads in chunks via WASI fd_read until EOF or `a_n` bytes; a non-positive
`a_n` yields an empty buffer (length 0, which callers treat as EOF/closed).
*/
let buf_read_stdin = fn (a_n: i64) -> i64 do
  let h = buf_new()
  if a_n <= 0 then return h end
  return read_stdin_chunks(h, want: a_n)
end
let read_stdin_chunks = fn (h: i64, want: i64) -> i64 do
  let len = hdr_len(h)
  if len >= want then return h end
  let chunk = if want - len < 65536 then want - len else 65536 end
  let _ = ensure_cap(h, need: chunk)
  let got = read_fd_bytes_into(a_fd: 0, b_dst: hdr_data(h) + len, c_cap: chunk)
  if got <= 0 then return h end
  let _ = set_len(h, v: len + got)
  return read_stdin_chunks(h, want)
end

// --- Public API ---

/** Creates an empty byte buffer. */
export let empty = fn () -> %ByteBuffer do
  let id = buf_new()
  let %lb = ByteBuffer(id)
  return %lb
end

/** Appends a single byte (0-255). Consumes and returns the buffer. */
export let push_byte = fn (buf: %ByteBuffer, byte: i64) -> %ByteBuffer do
  let ByteBuffer(id) = buf
  buf_push_byte(a_id: id, b_byte: byte)
  let %lb = ByteBuffer(id)
  return %lb
end

/** Appends a sequence of bytes in order. Consumes and returns the buffer. */
export let push_bytes = fn (buf: %ByteBuffer, bytes: [i64]) -> %ByteBuffer do
  match bytes do
    | [] -> return buf
    | b :: rest ->
      let %buf2 = push_byte(%buf, byte: b)
      return push_bytes(buf: %buf2, bytes: rest)
  end
end

/** Appends a 32-bit integer in little-endian. Consumes and returns the buffer. */
export let push_i32_le = fn (buf: %ByteBuffer, val: i64) -> %ByteBuffer do
  let ByteBuffer(id) = buf
  buf_push_i32_le(a_id: id, b_val: val)
  let %lb = ByteBuffer(id)
  return %lb
end

/** Appends an f64 (parsed from string) as 8 IEEE 754 LE bytes. Consumes and returns the buffer. */
export let push_f64_str_le = fn (buf: %ByteBuffer, s: string) -> %ByteBuffer do
  match buf do | ByteBuffer(id) ->
    let raw = pun_raw(a_x: s)
    buf_push_f64_str_le(a_id: id, b_s_ptr: cast.i32_of(x: (raw / two_pow_32) & 4294967295), c_s_len: cast.i32_of(x: raw & 4294967295))
    let %lb = ByteBuffer(id)
    return %lb
  end
end

/** Appends an unsigned LEB128-encoded integer. Consumes and returns the buffer. */
export let push_uleb128 = fn (buf: %ByteBuffer, val: i64) -> %ByteBuffer do
  let ByteBuffer(id) = buf
  buf_push_leb128_u(a_id: id, b_val: val)
  let %lb = ByteBuffer(id)
  return %lb
end

/** Appends a signed LEB128-encoded integer. Consumes and returns the buffer. */
export let push_sleb128 = fn (buf: %ByteBuffer, val: i64) -> %ByteBuffer do
  let ByteBuffer(id) = buf
  buf_push_leb128_s(a_id: id, b_val: val)
  let %lb = ByteBuffer(id)
  return %lb
end

/** Appends raw string bytes. Consumes and returns the buffer. */
export let push_string = fn (buf: %ByteBuffer, s: string) -> %ByteBuffer do
  let ByteBuffer(id) = buf
  let _ = push_string_at(id, s)
  let %lb = ByteBuffer(id)
  return %lb
end
/** Internal: append the raw UTF-8 bytes of `s` to the buffer header `id`. */
let push_string_at = fn (id: i64, s: string) -> unit do
  let raw = pun_raw(a_x: s)
  return bput_range(h: id, src: (raw / two_pow_32) & 4294967295, count: raw & 4294967295)
end

/** Appends all bytes from src buffer (borrowed). Consumes and returns dst. */
export let push_buf = fn (dst: %ByteBuffer, src: &ByteBuffer) -> %ByteBuffer do
  let ByteBuffer(id: dst_id) = dst
  let ByteBuffer(id: src_id) = src
  buf_push_buf(a_dst_id: dst_id, b_src_id: src_id)
  let %lb = ByteBuffer(id: dst_id)
  return %lb
end

/** Returns the number of bytes in the buffer. */
export let length = fn (buf: &ByteBuffer) -> i64 do
  let ByteBuffer(id) = buf
  return buf_length(a_id: id)
end

/** Returns the byte at the given index, or -1 if out of bounds. */
export let get_byte = fn (buf: &ByteBuffer, idx: i64) -> i64 do
  let ByteBuffer(id) = buf
  return buf_get_byte(a_id: id, b_idx: idx)
end

/** Interprets buffer contents as UTF-8 string. */
export let to_string = fn (buf: &ByteBuffer) -> string do
  let ByteBuffer(id) = buf
  return pun_val(a_x: buf_to_string(a_id: id))
end

/** Writes buffer contents to a file. Returns true on success. */
export let write_file = fn (buf: &ByteBuffer, path: string) -> bool do
  let ByteBuffer(id) = buf
  let raw = pun_raw(a_x: path)
  return buf_write_file(a_id: id, b_path_ptr: cast.i32_of(x: (raw / two_pow_32) & 4294967295), c_path_len: cast.i32_of(x: raw & 4294967295))
end

/** Frees the byte buffer. Consumes the linear handle. */
export let free = fn (buf: %ByteBuffer) -> unit do
  let ByteBuffer(id) = buf
  buf_free(a_id: id)
  return ()
end

/** Copies bytes [start..end_pos) from src buffer to dst in one bulk operation. */
export let copy_range = fn (dst: %ByteBuffer, src: &ByteBuffer, start: i64, end_pos: i64) -> %ByteBuffer do
  let ByteBuffer(id: dst_id) = dst
  let ByteBuffer(id: src_id) = src
  buf_copy_range(a_dst_id: dst_id, b_src_id: src_id, c_start: start, d_end_pos: end_pos)
  let %lb = ByteBuffer(id: dst_id)
  return %lb
end

/** Truncates the buffer to `len` bytes, preserving allocated capacity. */
export let truncate = fn (buf: %ByteBuffer, len: i64) -> %ByteBuffer do
  let ByteBuffer(id) = buf
  buf_truncate(a_id: id, b_len: len)
  let %lb = ByteBuffer(id)
  return %lb
end

/** Reads a binary file into a new ByteBuffer. Raises FileNotFound on error. */
export let read_binary_file = fn (path: string) -> %ByteBuffer throws { FileNotFound } do
  let raw = pun_raw(a_x: path)
  let id = buf_read_file(a_path_ptr: cast.i32_of(x: (raw / two_pow_32) & 4294967295), b_path_len: cast.i32_of(x: raw & 4294967295))
  if id < 0 then
    raise FileNotFound(path)
  end
  let %lb = ByteBuffer(id)
  return %lb
end

/**
Reads up to n bytes from stdin (fd 0) into a new ByteBuffer, stopping at
EOF. A non-positive n (or immediate EOF) yields an empty buffer.
*/
export let read_stdin_bytes = fn (n: i64) -> %ByteBuffer do
  let id = buf_read_stdin(a_n: n)
  let %lb = ByteBuffer(id)
  return %lb
end

/** Concatenates a linear list of strings via ByteBuffer. */
let concat_go = fn (buf: %ByteBuffer, parts: %[string]) -> %ByteBuffer do
  match parts do
    | [] -> return buf
    | s :: rest ->
      let %buf2 = push_string(%buf, s)
      let %linear_rest = rest
      return concat_go(buf: %buf2, parts: %linear_rest)
  end
end

export let concat = fn (parts: %[string]) -> string do
  let buf = empty()
  let buf = concat_go(%buf, %parts)
  let result = to_string(&buf)
  free(%buf)
  return result
end
