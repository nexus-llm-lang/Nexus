/**
 * bytebuffer: FFI-backed mutable byte buffer for binary data construction.
 *
 * Backed by Rust Vec<u8> via WASM FFI. Uses opaque linear handles.
 * Provides LEB128 encoding, little-endian integer writes, and
 * raw byte/string/buffer append operations. Essential for generating
 * binary formats such as WASM modules.
 */
import external stdlib/stdlib.wasm

/// An opaque byte buffer handle (linear — must be freed).
export opaque type ByteBuffer = ByteBuffer(id: i64)

// --- FFI externals ---

external __nx_buf_new = "__nx_buf_new" : () -> i64
external __nx_buf_push_byte = "__nx_buf_push_byte" : (id: i64, byte: i64) -> unit
external __nx_buf_push_i32_le = "__nx_buf_push_i32_le" : (id: i64, val: i64) -> unit
external __nx_buf_push_i64_le = "__nx_buf_push_i64_le" : (id: i64, val: i64) -> unit
external __nx_buf_push_leb128_u = "__nx_buf_push_leb128_u" : (id: i64, val: i64) -> unit
external __nx_buf_push_leb128_s = "__nx_buf_push_leb128_s" : (id: i64, val: i64) -> unit
external __nx_buf_push_string = "__nx_buf_push_string" : (id: i64, s: string) -> unit
external __nx_buf_push_buf = "__nx_buf_push_buf" : (dst_id: i64, src_id: i64) -> unit
external __nx_buf_length = "__nx_buf_length" : (id: i64) -> i64
external __nx_buf_get_byte = "__nx_buf_get_byte" : (id: i64, idx: i64) -> i64
external __nx_buf_to_string = "__nx_buf_to_string" : (id: i64) -> string
external __nx_buf_write_file = "__nx_buf_write_file" : (id: i64, path: string) -> bool
external __nx_buf_free = "__nx_buf_free" : (id: i64) -> bool

// --- Public API ---

/// Creates an empty byte buffer.
export let empty = fn () -> %ByteBuffer do
  let id = __nx_buf_new()
  let b = ByteBuffer(id: id)
  let %lb = b
  return %lb
end

/// Appends a single byte (0-255). Consumes and returns the buffer.
export let push_byte = fn (buf: %ByteBuffer, byte: i64) -> %ByteBuffer do
  match buf do case ByteBuffer(id: id) ->
    __nx_buf_push_byte(id: id, byte: byte)
    let b = ByteBuffer(id: id)
    let %lb = b
    return %lb
  end
end

/// Appends a 32-bit integer in little-endian. Consumes and returns the buffer.
export let push_i32_le = fn (buf: %ByteBuffer, val: i64) -> %ByteBuffer do
  match buf do case ByteBuffer(id: id) ->
    __nx_buf_push_i32_le(id: id, val: val)
    let b = ByteBuffer(id: id)
    let %lb = b
    return %lb
  end
end

/// Appends a 64-bit integer in little-endian. Consumes and returns the buffer.
export let push_i64_le = fn (buf: %ByteBuffer, val: i64) -> %ByteBuffer do
  match buf do case ByteBuffer(id: id) ->
    __nx_buf_push_i64_le(id: id, val: val)
    let b = ByteBuffer(id: id)
    let %lb = b
    return %lb
  end
end

/// Appends an unsigned LEB128-encoded integer. Consumes and returns the buffer.
export let push_uleb128 = fn (buf: %ByteBuffer, val: i64) -> %ByteBuffer do
  match buf do case ByteBuffer(id: id) ->
    __nx_buf_push_leb128_u(id: id, val: val)
    let b = ByteBuffer(id: id)
    let %lb = b
    return %lb
  end
end

/// Appends a signed LEB128-encoded integer. Consumes and returns the buffer.
export let push_sleb128 = fn (buf: %ByteBuffer, val: i64) -> %ByteBuffer do
  match buf do case ByteBuffer(id: id) ->
    __nx_buf_push_leb128_s(id: id, val: val)
    let b = ByteBuffer(id: id)
    let %lb = b
    return %lb
  end
end

/// Appends raw string bytes. Consumes and returns the buffer.
export let push_string = fn (buf: %ByteBuffer, s: string) -> %ByteBuffer do
  match buf do case ByteBuffer(id: id) ->
    __nx_buf_push_string(id: id, s: s)
    let b = ByteBuffer(id: id)
    let %lb = b
    return %lb
  end
end

/// Appends all bytes from src buffer (borrowed). Consumes and returns dst.
export let push_buf = fn (dst: %ByteBuffer, src: &ByteBuffer) -> %ByteBuffer do
  match dst do case ByteBuffer(id: dst_id) ->
    match src do case ByteBuffer(id: src_id) ->
      __nx_buf_push_buf(dst_id: dst_id, src_id: src_id)
      let b = ByteBuffer(id: dst_id)
      let %lb = b
      return %lb
    end
  end
end

/// Returns the number of bytes in the buffer.
export let length = fn (buf: &ByteBuffer) -> i64 do
  match buf do case ByteBuffer(id: id) ->
    return __nx_buf_length(id: id)
  end
end

/// Returns the byte at the given index, or -1 if out of bounds.
export let get_byte = fn (buf: &ByteBuffer, idx: i64) -> i64 do
  match buf do case ByteBuffer(id: id) ->
    return __nx_buf_get_byte(id: id, idx: idx)
  end
end

/// Interprets buffer contents as UTF-8 string.
export let to_string = fn (buf: &ByteBuffer) -> string do
  match buf do case ByteBuffer(id: id) ->
    return __nx_buf_to_string(id: id)
  end
end

/// Writes buffer contents to a file. Returns true on success.
export let write_file = fn (buf: &ByteBuffer, path: string) -> bool require { PermFs } do
  match buf do case ByteBuffer(id: id) ->
    return __nx_buf_write_file(id: id, path: path)
  end
end

/// Frees the byte buffer. Consumes the linear handle.
export let free = fn (buf: %ByteBuffer) -> unit do
  match buf do case ByteBuffer(id: id) ->
    let _ = __nx_buf_free(id: id)
    return ()
  end
end
