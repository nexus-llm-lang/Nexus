/**
 * exn: Exception utilities.
 */
import { from_i64 } from "std:str"
import external "nexus:intrinsic"

// WASM cannot introspect its own call stack without a host, so these are
// codegen-inlined to constants (see src/backend/codegen.nx::emit_intrinsic):
// `bt-depth` -> i64.const 0, `bt-frame` -> drop idx, i64.const 0 (empty
// packed string). The result: backtrace(exn) is always [] — `raise` works,
// you just don't get a stack trace.
external bt_depth = "bt_depth" : () -> i64
external bt_frame = "bt_frame" : (idx: i64) -> string

export let to_string = fn (exn: Exn) -> string do
  match exn do
    | RuntimeError(val: msg) -> return "RuntimeError: " ++ msg
    | InvalidIndex(val: i) -> return "InvalidIndex: " ++ from_i64(val: i)
    | InvalidUnicode(code: c) -> return "InvalidUnicode: " ++ from_i64(val: c)
    | _ -> return "<exception>"
  end
end

let bt_collect = fn (i: i64, acc: [string]) -> [string] do
  if i < 0 then return acc end
  let name = bt_frame(idx: i)
  return bt_collect(i: i - 1, acc: name :: acc)
end

/// Returns the call stack captured at the point where the exception was raised.
/// Each entry is a function name, most recent call first.
export let backtrace = fn (exn: Exn) -> [string] do
  let depth = bt_depth()
  return bt_collect(i: depth - 1, acc: [])
end
