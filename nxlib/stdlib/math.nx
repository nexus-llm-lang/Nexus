/**
 * math: Integer and floating-point math operations.
 *
 * All functions delegate to native WASM implementations via FFI.
 * Integer operations (abs, max, min, mod_i64) work on i64 values.
 * Floating-point operations (sqrt, floor, ceil, pow, abs_float) work
 * on f64. Conversion functions bridge between i64, float, and string.
 */
import external stdlib/stdlib.wasm

/// Returns the absolute value of an integer.
export external abs = "__nx_abs_i64" : (val: i64) -> i64

/// Returns the larger of two integers.
export external max = "__nx_max_i64" : (a: i64, b: i64) -> i64

/// Returns the smaller of two integers.
export external min = "__nx_min_i64" : (a: i64, b: i64) -> i64

/// Returns the remainder of integer division (a mod b).
export external mod_i64 = "__nx_mod_i64" : (a: i64, b: i64) -> i64

/// Returns the absolute value of a float.
export external abs_float = "__nx_abs_float" : (val: float) -> float

/// Returns the square root of a float.
export external sqrt = "__nx_sqrt" : (val: float) -> float

/// Returns the largest integer not greater than the given float.
export external floor = "__nx_floor" : (val: float) -> float

/// Returns the smallest integer not less than the given float.
export external ceil = "__nx_ceil" : (val: float) -> float

/// Returns base raised to the power of exp.
export external pow = "__nx_pow" : (base: float, exp: float) -> float

/// Converts an i64 to a float.
export external i64_to_float = "__nx_i64_to_float" : (val: i64) -> float

/// Converts a float to an i64 (truncates toward zero).
export external float_to_i64 = "__nx_float_to_i64" : (val: float) -> i64

/// Negates a boolean value.
export let negate = fn (val: bool) -> bool do
  if val then
    return false
  else
    return true
  end
end
