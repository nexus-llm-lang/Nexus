import external [=[nxlib/stdlib/math.wasm]=]

let __nx_abs_i64 = external [=[__nx_abs_i64]=] : (val: i64) -> i64
let __nx_max_i64 = external [=[__nx_max_i64]=] : (a: i64, b: i64) -> i64
let __nx_min_i64 = external [=[__nx_min_i64]=] : (a: i64, b: i64) -> i64
let __nx_mod_i64 = external [=[__nx_mod_i64]=] : (a: i64, b: i64) -> i64
let __nx_abs_float = external [=[__nx_abs_float]=] : (val: float) -> float
let __nx_sqrt = external [=[__nx_sqrt]=] : (val: float) -> float
let __nx_floor = external [=[__nx_floor]=] : (val: float) -> float
let __nx_ceil = external [=[__nx_ceil]=] : (val: float) -> float
let __nx_pow = external [=[__nx_pow]=] : (base: float, exp: float) -> float
let __nx_i64_to_float = external [=[__nx_i64_to_float]=] : (val: i64) -> float
let __nx_float_to_i64 = external [=[__nx_float_to_i64]=] : (val: float) -> i64
let __nx_string_to_i64 = external [=[__nx_string_to_i64]=] : (s: string) -> i64

pub let abs = fn (val: i64) -> i64 do
  return __nx_abs_i64(val: val)
endfn

pub let max = fn (a: i64, b: i64) -> i64 do
  return __nx_max_i64(a: a, b: b)
endfn

pub let min = fn (a: i64, b: i64) -> i64 do
  return __nx_min_i64(a: a, b: b)
endfn

pub let mod_i64 = fn (a: i64, b: i64) -> i64 do
  return __nx_mod_i64(a: a, b: b)
endfn

pub let abs_float = fn (val: float) -> float do
  return __nx_abs_float(val: val)
endfn

pub let sqrt = fn (val: float) -> float do
  return __nx_sqrt(val: val)
endfn

pub let floor = fn (val: float) -> float do
  return __nx_floor(val: val)
endfn

pub let ceil = fn (val: float) -> float do
  return __nx_ceil(val: val)
endfn

pub let pow = fn (base: float, exp: float) -> float do
  return __nx_pow(base: base, exp: exp)
endfn

pub let i64_to_float = fn (val: i64) -> float do
  return __nx_i64_to_float(val: val)
endfn

pub let float_to_i64 = fn (val: float) -> i64 do
  return __nx_float_to_i64(val: val)
endfn

pub let string_to_i64 = fn (s: string) -> i64 do
  return __nx_string_to_i64(s: s)
endfn
