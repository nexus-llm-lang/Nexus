/**
 * math: Integer and floating-point math operations.
 *
 * Integer ops (abs, max, min, mod_i64) are pure-Nexus implementations using
 * only the language's primitive operators — they emit a handful of inline
 * wasm instructions per call rather than crossing the host FFI boundary.
 * Float unary ops (sqrt, floor, ceil, abs_float) delegate to runtime_math,
 * which the codegen recognises as `nexus:runtime/math` intrinsics and
 * inline-emits the corresponding f64 opcode.
 *
 * Operations whose wasm encoding is not yet exposed as a runtime
 * intrinsic (`pow`, `i64`<->`float` conversions) bind to the host
 * `std:math` symbols.
 */
import external "std:math"
import * as fmath from "std:runtime_math"

/// Returns the absolute value of an integer. For `i64::MIN`,
/// the unique fixed point of negation, returns `i64::MIN`
/// (matches Rust `i64::wrapping_abs` semantics).
export let abs = fn (val: i64) -> i64 do
  if val < 0 then
    return 0 - val
  else
    return val
  end
end

/// Returns the larger of two integers.
export let max = fn (a: i64, b: i64) -> i64 do
  if a >= b then
    return a
  else
    return b
  end
end

/// Returns the smaller of two integers.
export let min = fn (a: i64, b: i64) -> i64 do
  if a <= b then
    return a
  else
    return b
  end
end

/// Returns the remainder of integer division (a mod b).
/// Raises `RuntimeError` when `b == 0`.
export let mod_i64 = fn (a: i64, b: i64) -> i64 throws { Exn } do
  if b == 0 then
    raise RuntimeError(val: "mod_i64: division by zero")
  end
  return a % b
end

/// Returns the absolute value of a float.
export let abs_float = fn (val: float) -> float do
  return fmath.abs(val: val)
end

/// Returns the square root of a float. NaN for negative inputs.
export let sqrt = fn (val: float) -> float do
  return fmath.sqrt(val: val)
end

/// Returns the largest integer not greater than the given float (round toward -inf).
export let floor = fn (val: float) -> float do
  return fmath.floor(val: val)
end

/// Returns the smallest integer not less than the given float (round toward +inf).
export let ceil = fn (val: float) -> float do
  return fmath.ceil(val: val)
end

/// Returns base raised to the power of exp. Routed through the host
/// `__nx_pow` (libm `pow`); `f64.pow` is not a wasm primitive.
export external pow = "__nx_pow" : (base: float, exp: float) -> float

/// Converts an i64 to a float. Routed through the host `__nx_i64_to_float`
/// (`f64.convert_i64_s`); the Nexus codegen does not expose this wasm op
/// as a `nexus:runtime/math` intrinsic.
export external i64_to_float = "__nx_i64_to_float" : (val: i64) -> float

/// Converts a float to an i64 (truncates toward zero). Routed through
/// the host `__nx_float_to_i64` (`i64.trunc_f64_s`); the Nexus codegen
/// does not expose this wasm op as a `nexus:runtime/math` intrinsic.
export external float_to_i64 = "__nx_float_to_i64" : (val: float) -> i64

/// Negates a boolean value.
export let negate = fn (val: bool) -> bool do
  if val then
    return false
  else
    return true
  end
end
