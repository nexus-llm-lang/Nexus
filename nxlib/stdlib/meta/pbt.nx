/**
 * pbt: Unified property-based testing infrastructure.
 *
 * Merges the prior `std:pbt` (effectful forall runner) and `std:test/prop`
 * (pure property runner with richer PropResult) into one module.
 *
 * Surface summary:
 *
 *   Gen<T>          — seedable generator: run + shrink + render
 *   Shrinker<T>     — standalone shrinker export
 *   TestResult<T>   — typed outcome of `forall`: Pass | Fail(witness: T, shrunk: T)
 *   PropOpts        — trial-count + seed knobs for `property`
 *   PropOutcome<T>  — richer outcome used by `property`
 *   PropResult<T>   — full result record from `property`
 *
 *   forall(g, prop, n) -> TestResult<T> require { Console }
 *       Draw n samples; on first failure shrink greedily; print a line;
 *       return Fail(witness: original_T, shrunk: min_T).
 *
 *   property(name, gen, prop, opts) -> PropResult<T>
 *       Pure runner; no I/O. Returns PropFail with typed counterexample.
 *
 * ── PRNG ────────────────────────────────────────────────────────────────────
 * Pure xorshift64 (Marsaglia 13/7/17). Seed is threaded through every step
 * by value — no module-level state cell — so a given start seed produces an
 * identical sequence on every run regardless of host clock or process
 * lifetime.
 *
 * ── Gen<T> shape ────────────────────────────────────────────────────────────
 * A `Gen<T>` bundles three closures:
 *
 *   * `run    : (seed: i64) -> Pair<T, i64>` — draws one value, returns the
 *                                              next seed.
 *   * `shrink : (val: T) -> [T]`             — proposes "smaller" candidates
 *                                              for greedy shrinking.
 *   * `render : (val: T) -> string`          — renders a value for display.
 *
 * ── Forall protocol ─────────────────────────────────────────────────────────
 *   1. Draw `n` samples with the supplied generator, threading the seed.
 *   2. On the first sample for which `prop` returns false, capture it as
 *      the witness and stop drawing.
 *   3. Shrink greedily via the generator's bundled shrinker until no
 *      smaller candidate still fails.
 *   4. Print one line to Console with the original and shrunk witnesses
 *      (so test runners always have a paper trail) and return
 *      `Fail(witness: original_typed, shrunk: min_typed)`.
 *
 * Console is the only effect — it is declared on `forall` and propagates to
 * the caller's `require` set.
 */

import { Console } from "std:stdio"
import { Pair } from "std:tuple"
import { Option, Some, None } from "std:option"
import * as list from "std:list"
import * as str from "std:str"

// ─── PRNG (pure xorshift64) ─────────────────────────────────────────────────
//
// xorshift64 with state==0 is a fixed point, so we re-mix a zero seed with
// a fixed nonzero constant before stepping.

let xor_fixup = 2685821657736338717

let next_state = fn (s: i64) -> i64 do
  let s0 = if s == 0 then xor_fixup else s end
  let s1 = s0 ^ (s0 << 13)
  let s2 = s1 ^ (s1 >> 7)
  let s3 = s2 ^ (s2 << 17)
  return s3
end

let abs_i64 = fn (n: i64) -> i64 do
  if n < 0 then return 0 - n end
  return n
end

// ─── Core types ─────────────────────────────────────────────────────────────

/**
A seedable generator. `run(seed)` produces a value and the next seed so the
PRNG stays purely functional. `shrink` proposes smaller candidates for the
runner's greedy shrink pass. `render` is a printer for display in test output.
*/
export type Gen<T> = Gen(
  run: (seed: i64) -> Pair<T, i64>,
  shrink: (val: T) -> [ T ],
  render: (val: T) -> string
)

/**
A shrinker is a function from a value to a finite list of "smaller"
candidates. "Smaller" is per-type: i64 toward 0, list by length, etc.
Returning `[]` signals no further shrinking is possible.
*/
export type Shrinker<T> = Shrinker(shrink: (val: T) -> [ T ])

/**
The outcome of a `forall` property run.

  - `Pass` — every trial satisfied the property.
  - `Fail(witness, shrunk)` — at least one trial failed.
    `witness` is the original typed counterexample; `shrunk` is
    the minimum typed counterexample after greedy shrinking.
*/
export type TestResult<T> = Pass | Fail(witness: T, shrunk: T)

// ─── Generic combinators ────────────────────────────────────────────────────

/** Lift a constant into a generator. No shrinking; renders the constant
via the supplied `show`. */
export let pure = fn <T>(x: T, show: (val: T) -> string) -> Gen<T> do
  let run = fn (seed: i64) -> Pair<T, i64> do
    return Pair(left: x, right: seed)
  end
  let shrink = fn (v: T) -> [ T ] do return [] end
  return Gen(run, shrink, render: show)
end

/**
Map a function over a generator's output. The shrinker bundled on the
returned `Gen<B>` is empty — there is no general way to lift a shrinker
through an arbitrary `A -> B`; callers needing post-map shrinking should
attach a custom `Shrinker<B>` at the call site. `show` is the renderer
for the mapped type.
*/
export let map = fn <A, B>(g: Gen<A>, f: (a: A) -> B, show: (val: B) -> string) -> Gen<B> do
  let Gen(run: g_run, shrink: _, render: _) = g
  let run = fn (seed: i64) -> Pair<B, i64> do
    let Pair(left: a, right: s1) = g_run(seed)
    return Pair(left: f(a), right: s1)
  end
  let shrink = fn (v: B) -> [ B ] do return [] end
  return Gen(run, shrink, render: show)
end

/**
Monadic bind: the second generator may depend on the first sample. The
inner generator runs against the *next* seed, so the bind preserves the
seed-threading invariant. The bundled shrinker is empty (same reason as
`map`); the renderer is the inner generator's.
*/
export let bind = fn <A, B>(g: Gen<A>, f: (a: A) -> Gen<B>) -> Gen<B> do
  let Gen(run: g_run, shrink: _, render: _) = g
  let run = fn (seed: i64) -> Pair<B, i64> do
    let Pair(left: a, right: s1) = g_run(seed)
    let g2 = f(a)
    let Gen(run: g2_run, shrink: _, render: _) = g2
    return g2_run(s1)
  end
  let shrink = fn (v: B) -> [ B ] do return [] end
  // Renderer for B is unknown at this layer; we use a placeholder that
  // returns "<bound>". Callers wanting a real renderer should rebuild the
  // generator with `Gen(run, shrink, render)` directly.
  let show = fn (v: B) -> string do return "<bound>" end
  return Gen(run, shrink, render: show)
end

let nth_or_first = fn <T>(xs: [ T ], n: i64, fallback: T) -> T do
  match xs do
    | [] -> return fallback
    | v :: rest ->
      if n <= 0 then
        return v
      else
        return nth_or_first(xs: rest, n: n - 1, fallback: fallback)
      end
  end
end

/**
Uniformly pick and run one of the supplied generators (non-empty list,
list.head variant). Caller must supply a non-empty list; the runtime
falls back to the first generator if the index calculation degenerates.
The shrinker/renderer of the *first* generator is used for the resulting
`Gen<T>` (assumes all sub-generators share the same render/shrink
contracts — true for the homogeneous-type `Gen<T>` shape we expose).
*/
export let oneOf = fn <T>(gs: [ Gen<T> ]) -> Gen<T> throws { list.ListError } do
  let head_gen = list.head(xs: gs)
  let Gen(run: _, shrink: head_shrink, render: head_render) = head_gen
  let n = list.length(xs: gs)
  let run = fn (seed: i64) -> Pair<T, i64> do
    let s1 = next_state(seed)
    let idx = abs_i64(s1) % (if n <= 0 then 1 else n end)
    let chosen = nth_or_first(xs: gs, n: idx, fallback: head_gen)
    let Gen(run: g_run, shrink: _, render: _) = chosen
    return g_run(s1)
  end
  return Gen(run, shrink: head_shrink, render: head_render)
end

/**
Uniformly pick and run one of the supplied generators (total variant
with explicit default). Falls back to `default_gen` when `gens` is empty.
The shrinker is empty (per-element shrinking would require equality).
*/
export let oneof = fn <T>(gens: [ Gen<T> ], default_gen: Gen<T>) -> Gen<T> do
  let Gen(run: d_run, shrink: _, render: d_render) = default_gen
  let n = list.length(xs: gens)
  let run = fn (seed: i64) -> Pair<T, i64> do
    let s1 = next_state(seed)
    if n <= 0 then
      return d_run(s1)
    end
    let idx = abs_i64(s1) % n
    let g = nth_or_first(xs: gens, n: idx, fallback: default_gen)
    let Gen(run: g_run, shrink: _, render: _) = g
    return g_run(s1)
  end
  let shrink = fn (v: T) -> [ T ] do return [] end
  return Gen(run, shrink, render: d_render)
end

/**
Pick one element of `options` uniformly. The caller-supplied `default`
is returned when `options` is empty so the signature stays total.
Shrinker on the result is empty.
*/
export let choose = fn <T>(options: [ T ], default: T, show: (val: T) -> string) -> Gen<T> do
  let n = list.length(xs: options)
  let run = fn (seed: i64) -> Pair<T, i64> do
    let s1 = next_state(seed)
    if n <= 0 then
      return Pair(left: default, right: s1)
    end
    let idx = abs_i64(s1) % n
    return Pair(left: nth_or_first(xs: options, n: idx, fallback: default), right: s1)
  end
  let shrink = fn (v: T) -> [ T ] do return [] end
  return Gen(run, shrink, render: show)
end

let filter_retry_cap = 100

let filter_loop = fn <T>(
  g_run: (seed: i64) -> Pair<T,
  i64>,
  pred: (val: T) -> bool,
  seed: i64,
  tries: i64
) -> Pair<T, i64> do
  let Pair(left: v, right: s1) = g_run(seed)
  if pred(val: v) then return Pair(left: v, right: s1) end
  if tries <= 0 then
    return Pair(left: v, right: s1)
  end
  return filter_loop(g_run: g_run, pred: pred, seed: s1, tries: tries - 1)
end

/**
Reject samples failing `pred`; retries up to a fixed cap and bails out
(returning the last sample regardless) if no satisfying value is found.
Shrinker inherits the underlying generator's shrinker filtered by `pred`.
*/
export let filter = fn <T>(g: Gen<T>, pred: (val: T) -> bool) -> Gen<T> do
  let Gen(run: g_run, shrink: g_shrink, render: g_render) = g
  let run = fn (seed: i64) -> Pair<T, i64> do
    return filter_loop(g_run: g_run, pred: pred, seed: seed, tries: filter_retry_cap)
  end
  let shrink = fn (v: T) -> [ T ] do
    let cands = g_shrink(v)
    return filter_list(xs: cands, pred: pred)
  end
  return Gen(run, shrink, render: g_render)
end

let filter_list = fn <T>(xs: [ T ], pred: (val: T) -> bool) -> [ T ] do
  return filter_list_go(xs: xs, pred: pred, acc: [])
end

let filter_list_go = fn <T>(xs: [ T ], pred: (val: T) -> bool, acc: [ T ]) -> [ T ] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | v :: rest ->
      if pred(val: v) then
        return filter_list_go(xs: rest, pred: pred, acc: v :: acc)
      else
        return filter_list_go(xs: rest, pred: pred, acc: acc)
      end
  end
end

/** Run a generator at a seed; returns the value and the next seed. */
export let sample = fn <T>(g: Gen<T>, seed: i64) -> Pair<T, i64> do
  let Gen(run, _, _) = g
  return run(seed)
end

// ─── Primitive generators ───────────────────────────────────────────────────

let small_int_lo = 0 - 100
let small_int_hi = 100
let small_int_span = small_int_hi - small_int_lo + 1

let shrink_int_candidates = fn (v: i64) -> [ i64 ] do
  if v == 0 then return [] end
  let half = v / 2
  if v == half then return [0] end
  if v < 0 then
    let neg_half = 0 - (abs_i64(v) / 2)
    if neg_half == v then
      return [0]
    end
    return [0, neg_half]
  end
  return [0, half]
end

let render_i64 = fn (v: i64) -> string do
  return str.from_i64(val: v)
end

/**
Uniform i64 in [-100, 100]. Small enough that shrinking terminates
quickly; large enough to surface off-by-one and sign bugs. Shrinker is
`shrink_int` (toward zero, halving).
*/
export let small_int : Gen<i64> = Gen(
  run: fn (seed: i64) -> Pair<i64, i64> do
    let s1 = next_state(seed)
    let raw = abs_i64(s1)
    let v = small_int_lo + (raw % small_int_span)
    return Pair(left: v, right: s1)
  end,
  shrink: shrink_int_candidates,
  render: render_i64
)

let shrink_bool = fn (v: bool) -> [ bool ] do
  if v then return [false] end
  return []
end

let render_bool = fn (v: bool) -> string do
  return str.from_bool(val: v)
end

/** Uniform `bool`. Shrinker collapses `true -> false`. */
export let bool_gen : Gen<bool> = Gen(
  run: fn (seed: i64) -> Pair<bool, i64> do
    let s1 = next_state(seed)
    let v = (abs_i64(s1) % 2) == 1
    return Pair(left: v, right: s1)
  end,
  shrink: shrink_bool,
  render: render_bool
)

let printable_lo = 32
let printable_hi = 126
let printable_span = printable_hi - printable_lo + 1
let string_gen_max_len = 16

let gen_string_chars = fn (n: i64, seed: i64, acc: [ string ]) -> Pair<[ string ], i64> do
  if n <= 0 then
    return Pair(left: list.reverse(xs: acc), right: seed)
  else
    let s1 = next_state(seed)
    let code = printable_lo + (abs_i64(s1) % printable_span)
    let ch = str.from_char_code(code)
    return gen_string_chars(n: n - 1, seed: s1, acc: ch :: acc)
  end
end

let shrink_string = fn (s: string) -> [ string ] do
  let n = str.length(s)
  if n <= 0 then return [] end
  let half = n / 2
  if half == n - 1 then
    return [str.byte_substring(s, start: 0, len: n - 1)]
  end
  if half == 0 then
    return [str.byte_substring(s, start: 0, len: n - 1)]
  end
  return [ str.byte_substring(s, start: 0, len: half), str.byte_substring(s, start: 0, len: n - 1) ]
end

let render_string = fn (s: string) -> string do
  return "\"" ++ s ++ "\""
end

/**
Printable-ASCII string of length [0, 16]. Length is drawn first; each
character is then drawn independently. Shrinker drops one or many
characters at a time (length-halving + tail-trim).
*/
export let string_gen : Gen<string> = Gen(
  run: fn (seed: i64) -> Pair<string, i64> do
    let s1 = next_state(seed)
    let len = abs_i64(s1) % (string_gen_max_len + 1)
    let Pair(left: chars, right: s2) = gen_string_chars(n: len, seed: s1, acc: [])
    return Pair(left: str.join(xs: chars, sep: ""), right: s2)
  end,
  shrink: shrink_string,
  render: render_string
)

let gen_list_elems = fn <T>(n: i64, elem: Gen<T>, seed: i64, acc: [ T ]) -> Pair<[ T ], i64> do
  if n <= 0 then
    return Pair(left: list.reverse(xs: acc), right: seed)
  else
    let Gen(run: e_run, shrink: _, render: _) = elem
    let Pair(left: v, right: s1) = e_run(seed)
    return gen_list_elems(n: n - 1, elem: elem, seed: s1, acc: v :: acc)
  end
end

let render_list_elems = fn <T>(xs: [ T ], elem_render: (val: T) -> string) -> string do
  let go = fn (acc: string, x: T) -> string do
    if str.length(s: acc) == 0 then
      return elem_render(x)
    end
    return acc ++ "," ++ elem_render(x)
  end
  return "[" ++ list.fold_left(xs, init: "", f: go) ++ "]"
end

/**
List of length [0, max]; elements come from the supplied `g`. Length is
drawn uniformly. The bundled shrinker proposes dropping the last element
(length-1 prefix).
*/
export let bounded_list = fn <T>(g: Gen<T>, max: i64) -> Gen<[ T ]> do
  let limit = if max < 0 then 0 else max end
  let Gen(run: _, shrink: _, render: elem_render) = g
  let run = fn (seed: i64) -> Pair<[ T ], i64> do
    let s1 = next_state(seed)
    let len = abs_i64(s1) % (limit + 1)
    return gen_list_elems(n: len, elem: g, seed: s1, acc: [])
  end
  let shrink = fn (xs: [ T ]) -> [ [ T ] ] do
    let n = list.length(xs)
    if n <= 0 then return [] end
    return [list.take(xs, n: n - 1)]
  end
  let render = fn (xs: [ T ]) -> string do
    return render_list_elems(xs, elem_render)
  end
  return Gen(run, shrink, render)
end

// ─── Primitive generators (prop-compatible API) ──────────────────────────────

let shrink_i64_toward = fn (v: i64, target: i64) -> [ i64 ] do
  if v == target then return [] end
  let half = target + (v - target) / 2
  if half == v then return [target] end
  if half == target then return [target] end
  return [target, half]
end

/**
Uniform i64 in [min, max] (inclusive). If max < min, treated as min.
Shrinker biases toward 0 by halving.
*/
export let gen_i64 = fn (min: i64, max: i64) -> Gen<i64> do
  let lo = min
  let hi = if max < min then min else max end
  let span = hi - lo + 1
  let run = fn (seed: i64) -> Pair<i64, i64> do
    let s1 = next_state(seed)
    let raw = abs_i64(s1)
    let v = lo + (raw % span)
    return Pair(left: v, right: s1)
  end
  let shrink = fn (v: i64) -> [ i64 ] do
    return shrink_i64_toward(v, target: 0)
  end
  return Gen(run, shrink, render: render_i64)
end

/** `true` / `false` with equal weight. Shrinker collapses `true -> false`. */
export let gen_bool = fn () -> Gen<bool> do
  let run = fn (seed: i64) -> Pair<bool, i64> do
    let s1 = next_state(seed)
    let v = (abs_i64(s1) % 2) == 1
    return Pair(left: v, right: s1)
  end
  let shrink = fn (v: bool) -> [ bool ] do
    if v then return [false] end
    return []
  end
  return Gen(run, shrink, render: render_bool)
end

/**
Printable-ASCII string of length [0, max_len]. Shrinker drops characters
from the head (smaller-by-length).
*/
export let gen_string = fn (max_len: i64) -> Gen<string> do
  let limit = if max_len < 0 then 0 else max_len end
  let run = fn (seed: i64) -> Pair<string, i64> do
    let s1 = next_state(seed)
    let len = abs_i64(s1) % (limit + 1)
    let Pair(left: chars, right: s2) = gen_string_chars(n: len, seed: s1, acc: [])
    return Pair(left: str.join(xs: chars, sep: ""), right: s2)
  end
  let shrink = fn (v: string) -> [ string ] do
    return shrink_string(v)
  end
  return Gen(run, shrink, render: render_string)
end

let shrink_list_elems = fn <T>(xs: [ T ]) -> [ [ T ] ] do
  let n = list.length(xs)
  if n <= 0 then return [] end
  let half = n / 2
  if half == n - 1 then
    return [list.take(xs, n: n - 1)]
  end
  if half == 0 then
    return [list.take(xs, n: n - 1)]
  end
  return [list.take(xs, n: half), list.take(xs, n: n - 1)]
end

/**
List of length [0, max_len]; element generator is the supplied `elem`.
Shrinker shrinks by dropping the tail (one element off the end) and
also tries the head-half slice.
*/
export let gen_list = fn <T>(elem: Gen<T>, max_len: i64) -> Gen<[ T ]> do
  let limit = if max_len < 0 then 0 else max_len end
  let Gen(run: _, shrink: _, render: elem_render) = elem
  let run = fn (seed: i64) -> Pair<[ T ], i64> do
    let s1 = next_state(seed)
    let len = abs_i64(s1) % (limit + 1)
    return gen_list_elems(n: len, elem: elem, seed: s1, acc: [])
  end
  let shrink = fn (xs: [ T ]) -> [ [ T ] ] do
    return shrink_list_elems(xs)
  end
  let render = fn (xs: [ T ]) -> string do
    return render_list_elems(xs, elem_render)
  end
  return Gen(run, shrink, render)
end

// ─── Shrinkers ──────────────────────────────────────────────────────────────

/**
Integer shrinker biased toward zero. Each step proposes `[0, v/2]` (or
just `[0]` near the limits), so greedy shrinking converges in
O(log |v|) iterations. Exported as a `Shrinker<i64>` so callers can
build custom `Gen<i64>` values reusing the same strategy.
*/
export let shrink_int : Shrinker<i64> = Shrinker(shrink: shrink_int_candidates)

// ─── Forall runner ──────────────────────────────────────────────────────────

let default_seed = 42

let find_failing_seed = fn <T>(
  g: Gen<T>,
  prop: (x: T) -> bool,
  trials_left: i64,
  seed: i64
) -> Option<T> do
  if trials_left <= 0 then return None end
  let Gen(run: g_run, shrink: _, render: _) = g
  let Pair(left: v, right: s1) = g_run(seed)
  if prop(v) then
    return find_failing_seed(g, prop, trials_left: trials_left - 1, seed: s1)
  end
  return Some(val: v)
end

let find_failing_cand = fn <T>(xs: [ T ], prop: (x: T) -> bool) -> Option<T> do
  match xs do
    | [] -> return None
    | v :: rest ->
      if prop(v) then
        return find_failing_cand(xs: rest, prop)
      end
      return Some(val: v)
  end
end

let shrink_loop = fn <T>(cur: T, shrink_fn: (val: T) -> [ T ], prop: (x: T) -> bool) -> T do
  let candidates = shrink_fn(cur)
  match find_failing_cand(xs: candidates, prop) do
    | None -> return cur
    | Some(val: smaller) -> return shrink_loop(cur: smaller, shrink_fn, prop)
  end
end

/**
Run a property: draw up to `n` samples from `g`; on the first failing
sample, shrink it greedily via the generator's bundled shrinker and
return `Fail(witness: original, shrunk: minimum)` with the typed values.
On all-pass, return `Pass`.

The `Console` effect is used to print a one-line report on failure so
test runners always see the counterexample. Callers must propagate the
requirement through their own `require { Console }` and `inject
stdio.system_handler` boundaries.
*/
export let forall = fn <T>(
  g: Gen<T>,
  prop: (x: T) -> bool,
  n: i64
) -> TestResult<T> require { Console } do
  match find_failing_seed(g, prop, trials_left: n, seed: default_seed) do
    | None -> return Pass
    | Some(val: original) ->
      let Gen(run: _, shrink: shrink_fn, render: render_fn) = g
      let shrunk = shrink_loop(cur: original, shrink_fn, prop)
      let w_orig = render_fn(original)
      let w_min = render_fn(shrunk)
      Console.println(val: "pbt: forall FAIL witness=" ++ w_orig ++ " shrunk=" ++ w_min)
      return Fail(witness: original, shrunk: shrunk)
  end
end

// ─── Pure property runner (from std:test/prop) ──────────────────────────────

/**
Trial-count + seed knobs. `trials <= 0` is normalised to the default
(100). `seed = None` picks a deterministic default seed (42) so a
fixture's "no opts" path is still reproducible.
*/
export type PropOpts = PropOpts(trials: i64, seed: Option<i64>)

let default_trials = 100

/** Build a PropOpts with default trials/seed. */
export let default_opts = fn () -> PropOpts do
  return PropOpts(trials: default_trials, seed: None)
end

/**
Result of a property run.

  - `name`: the property's caller-supplied label.
  - `trials_run`: how many samples were drawn before we returned.
  - `outcome`: PropPass or PropFail(min_counterexample, original_counterexample, shrinks_applied).
  - `seed`: the seed that was actually used (so failures replay exactly).
*/
export type PropOutcome<T> =
    PropPass
  | PropFail(counterexample: T, original: T, shrinks_applied: i64)

export type PropResult<T> = PropResult(
  name: string,
  trials_run: i64,
  outcome: PropOutcome<T>,
  seed: i64
)

/** True iff the run completed without finding a counterexample. */
export let passed = fn <T>(r: PropResult<T>) -> bool do
  match r do
    | PropResult(name: _, trials_run: _, outcome: PropPass, seed: _) -> return true
    | PropResult(name: _, trials_run: _, outcome: PropFail(_), seed: _) -> return false
  end
end

/** Extract the shrunk counterexample (if any). */
export let counterexample = fn <T>(r: PropResult<T>) -> Option<T> do
  match r do
    | PropResult(name: _, trials_run: _, outcome: PropPass, seed: _) -> return None
    | PropResult(
      name: _,
      trials_run: _,
      outcome: PropFail(counterexample: c, original: _, shrinks_applied: _),
      seed: _
    ) ->
      return Some(val: c)
  end
end

let resolve_opts = fn (opts: PropOpts) -> PropOpts do
  let PropOpts(trials, seed) = opts
  let t = if trials <= 0 then default_trials else trials end
  let s = match seed do
    | Some(val: v) -> Some(val: v)
    | None -> Some(val: default_seed)
  end
  return PropOpts(trials: t, seed: s)
end

let unwrap_seed = fn (s: Option<i64>) -> i64 do
  match s do
    | Some(val: v) -> return v
    | None -> return default_seed
  end
end

/**
Run a property: draw up to `opts.trials` samples, return on the first
failure (after shrinking). On every-trial PASS, returns PropPass.
Pure — no I/O effect.
*/
export let property = fn <T>(
  name: string,
  gen: Gen<T>,
  prop: (val: T) -> bool,
  opts: PropOpts
) -> PropResult<T> do
  let PropOpts(trials, seed: seed_opt) = resolve_opts(opts)
  let start_seed = unwrap_seed(seed_opt)
  return prop_trial_loop(
    name: name,
    gen: gen,
    prop: prop,
    trials_left: trials,
    trials_total: trials,
    seed: start_seed,
    start_seed: start_seed
  )
end

let prop_trial_loop = fn <T>(
  name: string,
  gen: Gen<T>,
  prop: (val: T) -> bool,
  trials_left: i64,
  trials_total: i64,
  seed: i64,
  start_seed: i64
) -> PropResult<T> do
  if trials_left <= 0 then
    return PropResult(name, trials_run: trials_total, outcome: PropPass, seed: start_seed)
  end
  let Pair(left: v, right: s1) = sample(g: gen, seed)
  if prop(val: v) then
    return prop_trial_loop(
      name: name,
      gen: gen,
      prop: prop,
      trials_left: trials_left - 1,
      trials_total: trials_total,
      seed: s1,
      start_seed: start_seed
    )
  end
  // Failing sample: shrink greedily.
  let Gen(run: _, shrink: g_shrink, render: _) = gen
  let Pair(
    left: shrunk,
    right: shrinks_applied
  ) = prop_shrink_loop(cur: v, g_shrink: g_shrink, prop: prop, shrinks: 0)
  let trials_run = trials_total - trials_left + 1
  return PropResult(
    name,
    trials_run,
    outcome: PropFail(counterexample: shrunk, original: v, shrinks_applied),
    seed: start_seed
  )
end

let prop_shrink_loop = fn <T>(
  cur: T,
  g_shrink: (val: T) -> [ T ],
  prop: (val: T) -> bool,
  shrinks: i64
) -> Pair<T, i64> do
  let candidates = g_shrink(cur)
  match prop_find_failing(xs: candidates, prop: prop) do
    | None -> return Pair(left: cur, right: shrinks)
    | Some(val: smaller) -> return prop_shrink_loop(
      cur: smaller,
      g_shrink: g_shrink,
      prop: prop,
      shrinks: shrinks + 1
    )
  end
end

let prop_find_failing = fn <T>(xs: [ T ], prop: (val: T) -> bool) -> Option<T> do
  match xs do
    | [] -> return None
    | v :: rest ->
      if prop(val: v) then
        return prop_find_failing(xs: rest, prop: prop)
      end
      return Some(val: v)
  end
end

// ─── Result rendering helpers ────────────────────────────────────────────────

/**
Render a PropResult summary line.
*/
export let render_summary = fn <T>(r: PropResult<T>) -> string do
  match r do
    | PropResult(name, trials_run, outcome: PropPass, seed) ->
      return "property " ++ name ++ " PASS (" ++ str.from_i64(val: trials_run)
        ++ " trials, seed=" ++ str.from_i64(val: seed) ++ ")"
    | PropResult(name, trials_run, outcome: PropFail(_, _, shrinks_applied), seed) ->
      return "property " ++ name ++ " FAIL after " ++ str.from_i64(val: trials_run)
        ++ " trial(s), " ++ str.from_i64(val: shrinks_applied)
        ++ " shrink(s), seed=" ++ str.from_i64(val: seed)
  end
end
