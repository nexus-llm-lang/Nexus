/**
 * hashmap: FFI-backed hash map from i64 keys to i64 values.
 *
 * Backed by Rust std::collections::HashMap via WASM FFI.
 * Uses opaque linear handles — each map must be freed after use.
 */
import external stdlib/stdlib.wasm
import { length, substring, index_of } from stdlib/string.nx

external to_i64 = "__nx_string_to_i64" : (s: string) -> i64

/// An opaque hash map handle (linear — must be freed).
pub opaque type HashMap = HashMap(id: i64)

/// Result of a key lookup: Found with a value, or Missing.
pub type Lookup = Found(value: i64) | Missing

// --- FFI externals ---

external __nx_hmap_new = "__nx_hmap_new" : () -> i64
external __nx_hmap_put = "__nx_hmap_put" : (id: i64, key: i64, value: i64) -> i64
external __nx_hmap_get = "__nx_hmap_get" : (id: i64, key: i64, default_val: i64) -> i64
external __nx_hmap_has = "__nx_hmap_has" : (id: i64, key: i64) -> bool
external __nx_hmap_del = "__nx_hmap_del" : (id: i64, key: i64) -> bool
external __nx_hmap_size = "__nx_hmap_size" : (id: i64) -> i64
external __nx_hmap_keys = "__nx_hmap_keys" : (id: i64) -> string
external __nx_hmap_vals = "__nx_hmap_vals" : (id: i64) -> string
external __nx_hmap_free = "__nx_hmap_free" : (id: i64) -> bool

// --- Helpers ---

let parse_i64_list_go = fn (s: string, acc: [ i64 ]) -> [ i64 ] do
  if length(s: s) == 0 then
    return acc
  else
    let idx = index_of(s: s, sub: "\n")
    if idx < 0 then
      let v = to_i64(s: s)
      let next = Cons(v: v, rest: acc)
      return next
    else
      let head = substring(s: s, start: 0, len: idx)
      let v = to_i64(s: head)
      let tail_start = idx + 1
      let tail_len = length(s: s) - tail_start
      let tail = substring(s: s, start: tail_start, len: tail_len)
      let next = Cons(v: v, rest: acc)
      return parse_i64_list_go(s: tail, acc: next)
    end
  end
end

let reverse_go = fn <T>(xs: [ T ], acc: [ T ]) -> [ T ] do
  match xs do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) ->
      let next = Cons(v: v, rest: acc)
      return reverse_go(xs: rest, acc: next)
  end
end

let parse_i64_list = fn (s: string) -> [ i64 ] do
  let empty = Nil()
  let rev = parse_i64_list_go(s: s, acc: empty)
  let empty2 = Nil()
  return reverse_go(xs: rev, acc: empty2)
end

// --- Public API ---

/// Creates an empty hash map.
pub let empty = fn () -> %HashMap do
  let id = __nx_hmap_new()
  let m = HashMap(id: id)
  let %lm = m
  return %lm
end

/// Inserts or updates a key-value pair. Consumes and returns the map.
pub let put = fn (map: %HashMap, key: i64, value: i64) -> %HashMap do
  match map do case HashMap(id: id) ->
    let _ = __nx_hmap_put(id: id, key: key, value: value)
    let m = HashMap(id: id)
    let %lm = m
    return %lm
  end
end

/// Looks up a key, returning Found(value) or Missing.
pub let get = fn (map: &HashMap, key: i64) -> Lookup do
  match map do case HashMap(id: id) ->
    let found = __nx_hmap_has(id: id, key: key)
    if found then
      let v = __nx_hmap_get(id: id, key: key, default_val: 0)
      return Found(value: v)
    else
      return Missing()
    end
  end
end

/// Looks up a key, returning the value or a default if missing.
pub let get_or = fn (map: &HashMap, key: i64, default: i64) -> i64 do
  match map do case HashMap(id: id) ->
    return __nx_hmap_get(id: id, key: key, default_val: default)
  end
end

/// Returns true if the map contains the given key.
pub let contains_key = fn (map: &HashMap, key: i64) -> bool do
  match map do case HashMap(id: id) ->
    return __nx_hmap_has(id: id, key: key)
  end
end

/// Removes a key from the map. Consumes and returns the map.
pub let remove = fn (map: %HashMap, key: i64) -> %HashMap do
  match map do case HashMap(id: id) ->
    let _ = __nx_hmap_del(id: id, key: key)
    let m = HashMap(id: id)
    let %lm = m
    return %lm
  end
end

/// Returns the number of entries in the map.
pub let size = fn (map: &HashMap) -> i64 do
  match map do case HashMap(id: id) ->
    return __nx_hmap_size(id: id)
  end
end

/// Returns a list of all keys in the map.
pub let keys = fn (map: &HashMap) -> [ i64 ] do
  match map do case HashMap(id: id) ->
    let raw = __nx_hmap_keys(id: id)
    return parse_i64_list(s: raw)
  end
end

/// Returns a list of all values in the map.
pub let values = fn (map: &HashMap) -> [ i64 ] do
  match map do case HashMap(id: id) ->
    let raw = __nx_hmap_vals(id: id)
    return parse_i64_list(s: raw)
  end
end

/// Frees the hash map. Consumes the linear handle.
pub let free = fn (map: %HashMap) -> unit do
  match map do case HashMap(id: id) ->
    let _ = __nx_hmap_free(id: id)
    return ()
  end
end
