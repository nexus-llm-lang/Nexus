/**
 * hashmap: Hash-based key-value map using equality and hash function dictionaries.
 *
 * Keys are compared via a user-supplied KeyOps dictionary that bundles an
 * equality function and a hash function. This allows any type to be used as
 * a key without requiring a built-in equality operator.
 *
 * Internally the map stores entries in a flat List<Entry<K, V>>. Lookups,
 * insertions, and removals are O(n) in the number of entries. This is
 * adequate for small maps; larger workloads should consider a bucketed
 * implementation.
 */

/// Equality comparison dictionary for map keys.
pub type Eq<K> = Eq(eq: (left: K, right: K) -> bool)

/// Hash function dictionary for map keys.
pub type Hash<K> = Hash(hash: (key: K) -> i64)

/// Combined key operations (equality + hash) for a map.
pub type KeyOps<K> = KeyOps(eq: Eq<K>, hash: Hash<K>)

/// Internal entry storing precomputed hash, key, and value.
pub type Entry<K, V> = Entry(hash: i64, key: K, value: V)

/// A hash map from keys to values, parameterized by key operations.
pub type HashMap<K, V> = HashMap(key_ops: KeyOps<K>, entries: List<Entry<K, V>>)

/// Result of a key lookup: Found with a value, or Missing.
pub type Lookup<V> = Found(value: V) | Missing

/// Creates key operations from an equality function and a hash function.
pub let make_key_ops = fn <K>(eq: (left: K, right: K) -> bool, hash: (key: K) -> i64) -> KeyOps<K> do
  let eq_dict = Eq(eq: eq)
  let hash_dict = Hash(hash: hash)
  return KeyOps(eq: eq_dict, hash: hash_dict)
endfn

let i64_eq = fn (left: i64, right: i64) -> bool do
  return left == right
endfn

let i64_hash = fn (key: i64) -> i64 do
  if key < 0 then
    return 0 - key
  else
    return key
  endif
endfn

/// Returns key operations for i64 keys.
pub let i64_key_ops = fn () -> KeyOps<i64> do
  return make_key_ops(eq: i64_eq, hash: i64_hash)
endfn

let key_eq = fn <K>(key_ops: KeyOps<K>, left: K, right: K) -> bool do
  match key_ops do
    case KeyOps(eq: eq_dict, hash: _) ->
      match eq_dict do
        case Eq(eq: eq_fn) -> return eq_fn(left: left, right: right)
      endmatch
  endmatch
endfn

let key_hash = fn <K>(key_ops: KeyOps<K>, key: K) -> i64 do
  match key_ops do
    case KeyOps(eq: _, hash: hash_dict) ->
      match hash_dict do
        case Hash(hash: hash_fn) -> return hash_fn(key: key)
      endmatch
  endmatch
endfn

let reverse_go = fn <T>(xs: List<T>, acc: List<T>) -> List<T> do
  match xs do
    case Nil() -> return acc
    case Cons(v: v, rest: rest) ->
      let next = Cons(v: v, rest: acc)
      return reverse_go(xs: rest, acc: next)
  endmatch
endfn

let reverse = fn <T>(xs: List<T>) -> List<T> do
  let empty = Nil()
  return reverse_go(xs: xs, acc: empty)
endfn

let map_key_ops = fn <K, V>(map: HashMap<K, V>) -> KeyOps<K> do
  match map do
    case HashMap(key_ops: key_ops, entries: _) -> return key_ops
  endmatch
endfn

let map_entries = fn <K, V>(map: HashMap<K, V>) -> List<Entry<K, V>> do
  match map do
    case HashMap(key_ops: _, entries: entries) -> return entries
  endmatch
endfn

/// Creates an empty hash map with the given key operations.
pub let empty = fn <K, V>(key_ops: KeyOps<K>) -> HashMap<K, V> do
  let empty_entries = Nil()
  return HashMap(key_ops: key_ops, entries: empty_entries)
endfn

/// Creates a hash map from a list of entries.
pub let from_entries = fn <K, V>(key_ops: KeyOps<K>, entries: List<Entry<K, V>>) -> HashMap<K, V> do
  return HashMap(key_ops: key_ops, entries: entries)
endfn

/// Returns the list of entries in the map.
pub let entries = fn <K, V>(map: HashMap<K, V>) -> List<Entry<K, V>> do
  return map_entries(map: map)
endfn

let size_go = fn <T>(xs: List<T>, acc: i64) -> i64 do
  match xs do
    case Nil() -> return acc
    case Cons(v: _, rest: rest) ->
      let next = acc + 1
      return size_go(xs: rest, acc: next)
  endmatch
endfn

/// Returns the number of entries in the map.
pub let size = fn <K, V>(map: HashMap<K, V>) -> i64 do
  let xs = map_entries(map: map)
  return size_go(xs: xs, acc: 0)
endfn

let contains_key_go = fn <K, V>(xs: List<Entry<K, V>>, key_ops: KeyOps<K>, target_hash: i64, target_key: K) -> bool do
  match xs do
    case Nil() -> return false
    case Cons(v: entry, rest: rest) ->
      match entry do
        case Entry(hash: h, key: key, value: _) ->
          if h == target_hash then
            if key_eq(key_ops: key_ops, left: key, right: target_key) then
              return true
            else
              return contains_key_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key)
            endif
          else
            return contains_key_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key)
          endif
      endmatch
  endmatch
endfn

/// Returns true if the map contains the given key.
pub let contains_key = fn <K, V>(map: HashMap<K, V>, key: K) -> bool do
  let ops = map_key_ops(map: map)
  let h = key_hash(key_ops: ops, key: key)
  let xs = map_entries(map: map)
  return contains_key_go(xs: xs, key_ops: ops, target_hash: h, target_key: key)
endfn

let get_go = fn <K, V>(xs: List<Entry<K, V>>, key_ops: KeyOps<K>, target_hash: i64, target_key: K) -> Lookup<V> do
  match xs do
    case Nil() -> return Missing()
    case Cons(v: entry, rest: rest) ->
      match entry do
        case Entry(hash: h, key: key, value: value) ->
          if h == target_hash then
            if key_eq(key_ops: key_ops, left: key, right: target_key) then
              return Found(value: value)
            else
              return get_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key)
            endif
          else
            return get_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key)
          endif
      endmatch
  endmatch
endfn

/**
 * Looks up a key, returning Found(value) or Missing.
 * Computes the hash once, then walks the entry list comparing hashes
 * first (cheap i64 equality) and keys second (user-supplied eq).
 */
pub let get = fn <K, V>(map: HashMap<K, V>, key: K) -> Lookup<V> do
  let ops = map_key_ops(map: map)
  let h = key_hash(key_ops: ops, key: key)
  let xs = map_entries(map: map)
  return get_go(xs: xs, key_ops: ops, target_hash: h, target_key: key)
endfn

/// Looks up a key, returning the value or a default if missing.
pub let get_or = fn <K, V>(map: HashMap<K, V>, key: K, default: V) -> V do
  let got = get(map: map, key: key)
  match got do
    case Found(value: value) -> return value
    case Missing() -> return default
  endmatch
endfn

let remove_go = fn <K, V>(xs: List<Entry<K, V>>, key_ops: KeyOps<K>, target_hash: i64, target_key: K, acc: List<Entry<K, V>>) -> List<Entry<K, V>> do
  match xs do
    case Nil() -> return reverse(xs: acc)
    case Cons(v: entry, rest: rest) ->
      match entry do
        case Entry(hash: h, key: key, value: value) ->
          if h == target_hash then
            if key_eq(key_ops: key_ops, left: key, right: target_key) then
              return remove_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key, acc: acc)
            else
              let keep = Entry(hash: h, key: key, value: value)
              let next = Cons(v: keep, rest: acc)
              return remove_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key, acc: next)
            endif
          else
            let keep = Entry(hash: h, key: key, value: value)
            let next = Cons(v: keep, rest: acc)
            return remove_go(xs: rest, key_ops: key_ops, target_hash: target_hash, target_key: target_key, acc: next)
          endif
      endmatch
  endmatch
endfn

/**
 * Removes a key from the map, returning the updated map.
 * Walks the entry list, skipping entries that match the target key,
 * and rebuilds the list in original order via reverse.
 */
pub let remove = fn <K, V>(map: HashMap<K, V>, key: K) -> HashMap<K, V> do
  let ops = map_key_ops(map: map)
  let h = key_hash(key_ops: ops, key: key)
  let xs = map_entries(map: map)
  let empty_entries = Nil()
  let next = remove_go(xs: xs, key_ops: ops, target_hash: h, target_key: key, acc: empty_entries)
  return HashMap(key_ops: ops, entries: next)
endfn

/**
 * Inserts or updates a key-value pair in the map.
 * First removes any existing entry for the key, then prepends a new
 * entry with the precomputed hash. This ensures at most one entry per key.
 */
pub let put = fn <K, V>(map: HashMap<K, V>, key: K, value: V) -> HashMap<K, V> do
  let ops = map_key_ops(map: map)
  let h = key_hash(key_ops: ops, key: key)
  let removed = remove(map: map, key: key)
  let xs = map_entries(map: removed)
  let head = Entry(hash: h, key: key, value: value)
  let next = Cons(v: head, rest: xs)
  return HashMap(key_ops: ops, entries: next)
endfn

let keys_go = fn <K, V>(xs: List<Entry<K, V>>, acc: List<K>) -> List<K> do
  match xs do
    case Nil() -> return reverse(xs: acc)
    case Cons(v: entry, rest: rest) ->
      match entry do
        case Entry(hash: _, key: key, value: _) ->
          let next = Cons(v: key, rest: acc)
          return keys_go(xs: rest, acc: next)
      endmatch
  endmatch
endfn

/// Returns a list of all keys in the map.
pub let keys = fn <K, V>(map: HashMap<K, V>) -> List<K> do
  let xs = map_entries(map: map)
  let empty_keys = Nil()
  return keys_go(xs: xs, acc: empty_keys)
endfn

let values_go = fn <K, V>(xs: List<Entry<K, V>>, acc: List<V>) -> List<V> do
  match xs do
    case Nil() -> return reverse(xs: acc)
    case Cons(v: entry, rest: rest) ->
      match entry do
        case Entry(hash: _, key: _, value: value) ->
          let next = Cons(v: value, rest: acc)
          return values_go(xs: rest, acc: next)
      endmatch
  endmatch
endfn

/// Returns a list of all values in the map.
pub let values = fn <K, V>(map: HashMap<K, V>) -> List<V> do
  let xs = map_entries(map: map)
  let empty_values = Nil()
  return values_go(xs: xs, acc: empty_values)
endfn
