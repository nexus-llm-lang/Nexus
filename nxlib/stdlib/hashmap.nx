/**
 * hashmap: FFI-backed hash map from i64 keys to i64 values.
 *
 * Backed by Rust std::collections::HashMap via WASM FFI.
 * Uses opaque linear handles — each map must be freed after use.
 */
import external "std:collections"

/// An opaque hash map handle (linear — must be freed).
export opaque type HashMap = HashMap(id: i64)

/// Result of a key lookup: Found with a value, or Missing.
export type Lookup = Found(value: i64) | Missing

external __nx_hmap_new = "__nx_hmap_new" : () -> i64
external __nx_hmap_put = "__nx_hmap_put" : (id: i64, key: i64, value: i64) -> i64
external __nx_hmap_get = "__nx_hmap_get" : (id: i64, key: i64, default_val: i64) -> i64
external __nx_hmap_has = "__nx_hmap_has" : (id: i64, key: i64) -> bool
external __nx_hmap_del = "__nx_hmap_del" : (id: i64, key: i64) -> bool
external __nx_hmap_size = "__nx_hmap_size" : (id: i64) -> i64
external __nx_hmap_key_at = "__nx_hmap_key_at" : (id: i64, idx: i64) -> i64
external __nx_hmap_val_at = "__nx_hmap_val_at" : (id: i64, idx: i64) -> i64
external __nx_hmap_free = "__nx_hmap_free" : (id: i64) -> bool

// --- Helpers ---

let reverse_go = fn <T>(xs: [ T ], acc: [ T ]) -> [ T ] do
  match xs do
    | [] -> return acc
    | v :: rest ->
      return reverse_go(xs: rest, acc: v :: acc)
  end
end

let collect_keys = fn (id: i64, idx: i64, count: i64, acc: [ i64 ]) -> [ i64 ] do
  if idx >= count then
    return acc
  else
    let v = __nx_hmap_key_at(id, idx)
    return collect_keys(id, idx: idx + 1, count, acc: v :: acc)
  end
end

let collect_vals = fn (id: i64, idx: i64, count: i64, acc: [ i64 ]) -> [ i64 ] do
  if idx >= count then
    return acc
  else
    let v = __nx_hmap_val_at(id, idx)
    return collect_vals(id, idx: idx + 1, count, acc: v :: acc)
  end
end

// --- Public API ---

/// Creates an empty hash map.
export let empty = fn () -> %HashMap do
  let id = __nx_hmap_new()
  let m = HashMap(id)
  let %lm = m
  return %lm
end

/// Inserts or updates a key-value pair. Consumes and returns the map.
export let put = fn (map: %HashMap, key: i64, value: i64) -> %HashMap do
  let HashMap(id) = map
  let _ = __nx_hmap_put(id, key, value)
  let m = HashMap(id)
  let %lm = m
  return %lm
end

/// Looks up a key, returning Found(value) or Missing.
export let get = fn (map: &HashMap, key: i64) -> Lookup do
  let HashMap(id) = map
  let found = __nx_hmap_has(id, key)
  if found then
    let v = __nx_hmap_get(id, key, default_val: 0)
    return Found(value: v)
  else
    return Missing
  end
end

/// Looks up a key, returning the value or a default if missing.
export let get_or = fn (map: &HashMap, key: i64, default: i64) -> i64 do
  let HashMap(id) = map
  return __nx_hmap_get(id, key, default_val: default)
end

/// Returns true if the map contains the given key.
export let contains_key = fn (map: &HashMap, key: i64) -> bool do
  let HashMap(id) = map
  return __nx_hmap_has(id, key)
end

/// Removes a key from the map. Consumes and returns the map.
export let remove = fn (map: %HashMap, key: i64) -> %HashMap do
  let HashMap(id) = map
  let _ = __nx_hmap_del(id, key)
  let m = HashMap(id)
  let %lm = m
  return %lm
end

/// Returns the number of entries in the map.
export let size = fn (map: &HashMap) -> i64 do
  let HashMap(id) = map
  return __nx_hmap_size(id)
end

/// Returns a list of all keys in the map.
export let keys = fn (map: &HashMap) -> [ i64 ] do
  let HashMap(id) = map
  let count = __nx_hmap_size(id)
  let rev = collect_keys(id, idx: 0, count, acc: [])
  return reverse_go(xs: rev, acc: [])
end

/// Returns a list of all values in the map.
export let values = fn (map: &HashMap) -> [ i64 ] do
  let HashMap(id) = map
  let count = __nx_hmap_size(id)
  let rev = collect_vals(id, idx: 0, count, acc: [])
  return reverse_go(xs: rev, acc: [])
end

/// Frees the hash map. Consumes the linear handle.
export let free = fn (map: %HashMap) -> unit do
  let HashMap(id) = map
  let _ = __nx_hmap_free(id)
  return ()
end
