// Smoke fixture for `nexus test`: every assertion succeeds and `main`
// returns cleanly. Used by the runner's discovery + parallel sequencing
// tests as a known-PASS reference.
//
// Pattern matches the *_test.nx convention enforced by discover_tests.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: 1 + 1, expected: 2, label: "arithmetic")
  test_assert.assert_true(cond: true, label: "tautology")
  test_assert.assert_eq_string(actual: "hello", expected: "hello", label: "strings")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  // Trap (divide-by-zero) when an exception escaped — propagates as a
  // non-zero wasmtime exit so the runner reports FAIL.
  let _ = 1 / ok
  return ()
end
