// Issue nexus-x49o: textDocument/completion — keyword baseline.
//
// At top-level scope (cursor on an empty line after a let), the candidate
// list must contain the core keyword set. We assert two specific keywords
// (`let`, `fn`) are present.
import * as compl from "src/lsp/handlers/completion.nx"
import * as test_assert from "std:test/assert"
import { CompletionList, CompletionItem } from "src/lsp/protocol.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "let x = 1\n"
      ++ "\n"
end

let has_label = fn (items: [CompletionItem], label: string) -> bool do
  match items do
    | [] -> return false
    | CompletionItem(label: l, kind: _, detail: _, documentation: _) :: rest ->
      if l == label then return true end
      return has_label(items: rest, label)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // Cursor at line 1 (the empty second line), character 0.
  let cl = compl.resolve_completion(
    text: buffer_text(),
    file_uri: "buffer://x49o_keyword.nx",
    line: 1,
    character: 0
  )
  match cl do | CompletionList(is_incomplete, items) ->
    test_assert.assert_eq_bool(actual: is_incomplete, expected: false,
      label: "isIncomplete is false for MVP")
    test_assert.assert_eq_bool(actual: has_label(items, label: "let"),
      expected: true, label: "candidate list contains 'let' keyword")
    test_assert.assert_eq_bool(actual: has_label(items, label: "fn"),
      expected: true, label: "candidate list contains 'fn' keyword")
    test_assert.assert_eq_bool(actual: has_label(items, label: "match"),
      expected: true, label: "candidate list contains 'match' keyword")
  end
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
