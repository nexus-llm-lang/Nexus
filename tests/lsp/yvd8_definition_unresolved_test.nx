// Issue nexus-yvd8: textDocument/definition resolver — None paths.
//
// Asserts:
//   1. Cursor on whitespace returns None (no identifier under caret).
//   2. Cursor on a literal (`42`) returns None.
//   3. Cursor on an identifier that doesn't resolve to any top-level def
//      (a built-in like `i64`, or a typo) returns None — the resolver must
//      not crash and must not invent a Location.
import * as defn from "src/lsp/definition.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "let f = fn (x: i64) -> i64 do\n"
      ++ "  return x + 42\n"
      ++ "end\n"
end

let assert_none = fn (
  text: string, line: i64, character: i64, label: string
) -> unit require { Fs, Console } throws { Exn } do
  let loc_opt = defn.resolve_definition(
    text,
    file_uri: "buffer://yvd8_unresolved.nx",
    line,
    character
  )
  match loc_opt do
    | None -> return ()
    | Some(val: _) -> raise RuntimeError(val: "expected None for " ++ label)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let txt = buffer_text()
  // Whitespace inside `  return x + 42` (line 1, character 2 → leading
  // space inside the indent).
  assert_none(text: txt, line: 1, character: 0, label: "whitespace at line start")
  // Literal `42` (line 1, character 13).
  assert_none(text: txt, line: 1, character: 13, label: "integer literal '42'")
  // Past end of file (no token covers).
  assert_none(text: txt, line: 99, character: 99, label: "out-of-range cursor")
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
