// hover Phase 4: enum variant constructor hover in call-expression and pattern position.
//
// Tests that `resolve_hover` returns the parent enum definition (name, variants)
// as markdown when the cursor sits on an enum variant constructor.
//
// Pins:
//   1. Cursor on a variant constructor used as an expression (`Green(val: 1)`)
//      returns the enum definition markdown.
//   2. Cursor on a no-field variant used as an expression (`Red`)
//      returns the same enum definition markdown.
//   3. Cursor on a variant constructor in a match-arm pattern (`| Green(val: v)`)
//      returns the enum definition markdown (same token shape, same lookup path).
//   4. Cursor on a lowercase identifier still resolves via the fn-signature path
//      and is unaffected by the enum path.

import * as hover from "src/lsp/handlers/hover.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

// Source: a local enum + a function that uses each variant both in expression
// and pattern position.
//
// Line 0: "type Color = Red | Green(val: i64) | Blue"
// Line 1: "let make_green = fn (v: i64) -> Color do return Green(val: v) end"
//   Green starts at character 48.
// Line 2: "let check = fn (c: Color) -> i64 do match c do | Green(val: v) -> v | _ -> 0 end end"
//   Green in pattern starts at character 49.
// Line 3: "let main = fn () -> unit require { PermConsole } do return () end"
let source_enum = fn () -> string do
  return "type Color = Red | Green(val: i64) | Blue\n"
      ++ "let make_green = fn (v: i64) -> Color do return Green(val: v) end\n"
      ++ "let check = fn (c: Color) -> i64 do match c do | Green(val: v) -> v | _ -> 0 end end\n"
      ++ "let main = fn () -> unit require { PermConsole } do return () end\n"
end

// Expected markdown for the Color enum (3 variants: Red, Green(val: i64), Blue).
let expected_color_md = fn () -> string do
  return "**Color** (enum)\nvariants:\n  - Red\n  - Green(val: i64)\n  - Blue"
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let uri = "buffer://hover_enum_ctor_test.nx"
  let src = source_enum()

  // (1) Cursor on `Green` in expression position (line 1, char 48).
  // "let make_green = fn (v: i64) -> Color do return Green(val: v) end"
  // Prefix: "let make_green = fn (v: i64) -> Color do return " = 48 chars.
  let r1 = hover.resolve_hover(
    text: src,
    file_uri: uri,
    line: 1,
    character: 48
  )
  match r1 do
    | None -> throw RuntimeError(val: "hover on Green expr: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == expected_color_md() then 1 else 0 end,
        expected: 1,
        label: "hover on Green constructor expr returns Color enum markdown"
      )
  end

  // (2) Cursor on `Red` in expression position (line 0, char 13).
  // "type Color = Red | ..."
  // Prefix: "type Color = " = 13 chars.
  // Actually `Red` in line 0 is in the type definition itself — cursor here
  // lands on the variant def token inside the type decl. That is still a
  // TkUident and should resolve.
  // Alternatively we can use it in an expression: add a line that returns Red.
  // For simplicity we check character 13 on line 0 (the type definition line);
  // `Red` is the first variant name there.
  let r2 = hover.resolve_hover(
    text: src,
    file_uri: uri,
    line: 0,
    character: 13
  )
  match r2 do
    | None -> throw RuntimeError(val: "hover on Red variant: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == expected_color_md() then 1 else 0 end,
        expected: 1,
        label: "hover on Red variant returns Color enum markdown"
      )
  end

  // (3) Cursor on `Green` in pattern position inside match arm (line 2, char 49).
  // "let check = fn (c: Color) -> i64 do match c do | Green(val: v) -> v | _ -> 0 end end"
  // Prefix: "let check = fn (c: Color) -> i64 do match c do | " = 49 chars.
  let r3 = hover.resolve_hover(
    text: src,
    file_uri: uri,
    line: 2,
    character: 49
  )
  match r3 do
    | None -> throw RuntimeError(val: "hover on Green pattern: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == expected_color_md() then 1 else 0 end,
        expected: 1,
        label: "hover on Green constructor in match pattern returns Color enum markdown"
      )
  end

  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
