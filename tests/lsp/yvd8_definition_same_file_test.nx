// Issue nexus-yvd8: textDocument/definition resolver — same-file case.
//
// Buffer defines `f` at line 0 (1-based: line 1) and references it inside
// `g`'s body at LSP line 4. Cursor on the call site (line 4, character 9 →
// the 'f' in `  return f(x)`) must resolve to the `let` keyword span of
// `f` at LSP coordinates (0, 0).
import * as defn from "src/lsp/definition.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Location, Range, Position } from "nxlib/lsp/protocol.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "let f = fn (x: i64) -> i64 do\n"
      ++ "  return x + 1\n"
      ++ "end\n"
      ++ "let g = fn (x: i64) -> i64 do\n"
      ++ "  return f(x)\n"
      ++ "end\n"
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let loc_opt = defn.resolve_definition(
    text: buffer_text(),
    file_uri: "buffer://yvd8_same.nx",
    line: 4,
    character: 9
  )
  match loc_opt do
    | None -> raise RuntimeError(val: "expected Some(Location), got None")
    | Some(val: Location(uri, range: Range(start: Position(line, character), end_: _))) ->
      test_assert.assert_eq_string(actual: uri, expected: "buffer://yvd8_same.nx",
        label: "same-file URI")
      test_assert.assert_eq_i64(actual: line, expected: 0,
        label: "definition start line (let f keyword)")
      test_assert.assert_eq_i64(actual: character, expected: 0,
        label: "definition start character")
  end
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
