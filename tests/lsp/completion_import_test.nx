// Issue nexus-x49o: textDocument/completion — imported names.
//
// Buffer imports `g` (named) and `* as other` (alias) from
// tests/lsp/fixtures/other_yvd8.nx. Both `g` and `other` must surface as
// completion candidates regardless of cursor position.
import * as compl from "src/lsp/handlers/completion.nx"
import * as test_assert from "std:test/assert"
import { CompletionList, CompletionItem } from "src/lsp/protocol.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "import { g } from \"tests/lsp/fixtures/other_yvd8.nx\"\n"
      ++ "import * as other from \"tests/lsp/fixtures/other_yvd8.nx\"\n"
      ++ "\n"
end

let has_label = fn (items: [CompletionItem], label: string) -> bool do
  match items do
    | [] -> return false
    | CompletionItem(label: l, kind: _, detail: _, documentation: _) :: rest ->
      if l == label then return true end
      return has_label(items: rest, label)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // Cursor on line 2 (the trailing empty line), character 0.
  let cl = compl.resolve_completion(
    text: buffer_text(),
    file_uri: "buffer://x49o_import.nx",
    line: 2,
    character: 0
  )
  match cl do | CompletionList(is_incomplete: _, items) ->
    test_assert.assert_eq_bool(actual: has_label(items, label: "g"),
      expected: true, label: "named import 'g' is a completion candidate")
    test_assert.assert_eq_bool(actual: has_label(items, label: "other"),
      expected: true, label: "import alias 'other' is a completion candidate")
    test_assert.assert_eq_bool(actual: has_label(items, label: "fn"),
      expected: true, label: "keyword 'fn' still present alongside imports")
  end
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
