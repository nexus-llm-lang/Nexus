// nexus-xf2u: hover handler Phase 2 — let binding hover shows inferred type.
//
// Tests that `resolve_hover` returns the declared type annotation for a
// non-lambda top-level `let` binding, and `<inferred>` when none is declared.
//
// Pins:
//   1. Top-level `let x: i64 = 42` → `**x**: i64`.
//   2. Top-level `let x = 42` (no annotation) → `**x**: <inferred>`.

import * as hover from "src/lsp/handlers/hover.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let uri = "buffer://xf2u_let.nx"

  // (1) Annotated let binding: `let answer: i64 = 42`.
  // We reference it in main so the rename map picks it up.
  // Line 1: "let main = fn () -> unit require { PermConsole } do answer return () end"
  // `answer` starts at character 52.
  let source_ann = "let answer: i64 = 42\n"
      ++ "let main = fn () -> unit require { PermConsole } do answer return () end\n"
  let r1 = hover.resolve_hover(text: source_ann, file_uri: uri, line: 1, character: 52)
  match r1 do
    | None -> throw RuntimeError(val: "hover on answer: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == "**answer**: i64" then 1 else 0 end,
        expected: 1,
        label: "hover on annotated let binding returns declared type"
      )
  end

  // (2) Un-annotated let binding: `let answer = 42`.
  // Same position: character 52.
  let source_unann = "let answer = 42\n"
      ++ "let main = fn () -> unit require { PermConsole } do answer return () end\n"
  let r2 = hover.resolve_hover(text: source_unann, file_uri: uri, line: 1, character: 52)
  match r2 do
    | None -> throw RuntimeError(val: "hover on unannotated answer: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == "**answer**: <inferred>" then 1 else 0 end,
        expected: 1,
        label: "hover on unannotated let binding returns <inferred>"
      )
  end

  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
