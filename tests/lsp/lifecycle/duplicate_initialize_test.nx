// nexus-zejw: a second `initialize` request after the server is running must
// return InvalidRequest (-32600), not be processed again.
//
// Per LSP base spec §3.4, `initialize` is only valid as the first request.
// Re-sending it after the handshake completed is invalid.
//
// Pins:
//   1. A second `initialize` request returns StepContinue with an error
//      response whose JSON-RPC `error.code` is -32600.
//   2. State is unchanged (lifecycle remains LifecycleRunning).

import { dispatch_message } from "src/tools/lsp/handlers.nx"
import { StepContinue, StepExit } from "src/tools/lsp/handlers.nx"
import {
  ServerState,
  empty_state,
  with_lifecycle_running
} from "src/tools/lsp/state/server_state.nx"
import { Request } from "std:jsonrpc"
import {
  JsonValue, JsonNull, JsonObject, JsonField, JsonString, JsonInt, JsonArray,
  get_field
} from "std:json"
import { Option, Some, None } from "std:option"
import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"
import { scheduler } from "std:concurrency/coop"

// A post-initialize (running) state.
let running_state = fn () -> ServerState do
  return with_lifecycle_running(state: empty_state())
end

let make_initialize_params = fn () -> JsonValue do
  return JsonObject(fields: [
    JsonField(key: "processId", value: JsonNull),
    JsonField(key: "rootUri",   value: JsonNull),
    JsonField(key: "capabilities", value: JsonObject(fields: []))
  ])
end

let extract_error_code = fn (resp: JsonValue) -> Option<i64> do
  match get_field(obj: resp, key: "error") do
    | None -> return None
    | Some(val: err_obj) ->
      match get_field(obj: err_obj, key: "code") do
        | None -> return None
        | Some(val: code_val) ->
          match code_val do
            | JsonInt(val: n) -> return Some(val: n)
            | _ -> return None
          end
      end
  end
end

let body = fn () -> unit require { Fs, Console, Coop } throws { Exn } do
  // Send a second `initialize` to a running server.
  let init_msg = Request(
    id: JsonInt(val: 1),
    method: "initialize",
    params: make_initialize_params()
  )
  let step = dispatch_message(state: running_state(), msg: init_msg)
  match step do
    | StepExit(_) -> throw RuntimeError(val: "second initialize must not exit")
    | StepContinue(state: _, response, notifications: _) ->
      match response do
        | None -> throw RuntimeError(val: "second initialize must produce a response")
        | Some(val: resp) ->
          match extract_error_code(resp) do
            | None -> throw RuntimeError(val: "second initialize response must have error.code")
            | Some(val: code) ->
              test_assert.assert_eq_i64(
                actual: code,
                expected: -32600,
                label: "second initialize returns InvalidRequest (-32600)"
              )
          end
      end
  end

  return ()
end

let safe_run = fn () -> i64 require { Fs, Console, Coop } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler, scheduler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
