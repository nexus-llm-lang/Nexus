// Issue nexus-g0gd subset: textDocument/formatting handler.
//
// Drives `compute_formatting_edits` with a buffered document that needs
// reformatting (trailing whitespace, tabs-as-indent, no trailing newline)
// and asserts the returned `TextEdit` carries the hand-formatted golden as
// `new_text`, covering the full buffer range. A second case asserts the
// "already formatted" path returns an empty edit list.

import {
  compute_formatting_edits,
  end_of_document_position
} from "src/tools/lsp/handlers/formatting.nx"
import * as test_assert from "std:test/assert"
import { Option, Some, None } from "std:option"
import { DocumentRecord } from "src/tools/lsp/state/server_state.nx"
import { TextEdit, Range, Position } from "src/tools/lsp/protocol/text_doc.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

// Unformatted source: tab-indented body, trailing whitespace on line 2,
// missing trailing newline. After fmt: 2-space indent, no trailing ws,
// single trailing newline.
let unformatted_text = fn () -> string do
  return "let f = fn () -> i64 do\n"
      ++ "\treturn 1   \n"
      ++ "end"
end

let formatted_text = fn () -> string do
  return "let f = fn () -> i64 do\n"
      ++ "  return 1\n"
      ++ "end\n"
end

let make_record = fn (text: string) -> DocumentRecord do
  return DocumentRecord(uri: "buffer://g0gd_test.nx", text, version: 1)
end

let count_edits = fn (xs: [ TextEdit ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_edits(xs: rest, acc: acc + 1)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // ── Case 1: no buffer cached for the URI ────────────────────────────────
  // Handler must produce an empty edit list — the LSP "no edits" reply.
  let edits_no_buf = compute_formatting_edits(doc_opt: None)
  test_assert.assert_eq_i64(actual: count_edits(xs: edits_no_buf, acc: 0),
    expected: 0, label: "no buffer cached → no edits")

  // ── Case 2: already-formatted buffer ────────────────────────────────────
  // format_source(text) == text → empty edit list (don't dirty the client
  // when nothing changed).
  let edits_clean = compute_formatting_edits(doc_opt: Some(val: make_record(text: formatted_text())))
  test_assert.assert_eq_i64(actual: count_edits(xs: edits_clean, acc: 0),
    expected: 0, label: "already formatted → no edits")

  // ── Case 3: unformatted buffer → single full-document edit ──────────────
  let edits = compute_formatting_edits(doc_opt: Some(val: make_record(text: unformatted_text())))
  test_assert.assert_eq_i64(actual: count_edits(xs: edits, acc: 0),
    expected: 1, label: "unformatted buffer → exactly one TextEdit")

  match edits do
    | [] -> throw RuntimeError(val: "expected one TextEdit, got empty list")
    | e :: _ ->
      match e do | TextEdit(range, new_text) ->
        // newText is the fmt-pipeline golden.
        test_assert.assert_eq_string(actual: new_text,
          expected: formatted_text(),
          label: "TextEdit.new_text matches fmt golden")

        // Range starts at (0, 0).
        match range do | Range(start, end_) ->
          match start do | Position(line: sl, character: sc) ->
            test_assert.assert_eq_i64(actual: sl, expected: 0,
              label: "TextEdit.range.start.line")
            test_assert.assert_eq_i64(actual: sc, expected: 0,
              label: "TextEdit.range.start.character")
          end
          // End is (line_count, last_line_char_count). The unformatted
          // text is:
          //   "let f = fn () -> i64 do\n"
          //   "\treturn 1   \n"
          //   "end"
          // Two newlines → end line = 2. Last line is "end" (3 chars) with
          // no trailing newline → end character = 3.
          match end_ do | Position(line: el, character: ec) ->
            test_assert.assert_eq_i64(actual: el, expected: 2,
              label: "TextEdit.range.end.line (line count past last `\\n`)")
            test_assert.assert_eq_i64(actual: ec, expected: 3,
              label: "TextEdit.range.end.character (length of trailing line)")
          end
        end
      end
  end

  // ── Case 4: end_of_document_position edge cases ─────────────────────────
  // Empty buffer → (0, 0).
  let p_empty = end_of_document_position(text: "")
  match p_empty do | Position(line: l, character: c) ->
    test_assert.assert_eq_i64(actual: l, expected: 0,
      label: "empty buffer end line == 0")
    test_assert.assert_eq_i64(actual: c, expected: 0,
      label: "empty buffer end char == 0")
  end

  // Buffer ending in `\n` → (line_count, 0).
  let p_trail_nl = end_of_document_position(text: "a\nb\n")
  match p_trail_nl do | Position(line: l, character: c) ->
    test_assert.assert_eq_i64(actual: l, expected: 2,
      label: "buffer ending in `\\n` end line == newline count")
    test_assert.assert_eq_i64(actual: c, expected: 0,
      label: "buffer ending in `\\n` end char == 0")
  end

  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
