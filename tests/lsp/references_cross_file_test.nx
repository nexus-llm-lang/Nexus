// Issue nexus-5pg8: textDocument/references — cross-file case.
//
// Importer buffer pulls `g` from tests/lsp/fixtures/_5pg8_other.nx and
// calls `g` once. The fixture itself uses `g` recursively inside its own
// body and once more inside `helper`. References to `g` must therefore
// surface BOTH the importer's call site AND the fixture's two call sites.
//
// Assertion: includeDeclaration=false → 3 use sites
//            includeDeclaration=true  → 4 entries (def + 3 uses)
import * as refs from "src/lsp/handlers/references.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Location, Range, Position } from "src/lsp/protocol/text_doc.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "import { g } from \"tests/lsp/fixtures/_5pg8_other.nx\"\n"
      ++ "let h = fn (x: i64) -> i64 do\n"
      ++ "  return g(x)\n"
      ++ "end\n"
end

let count_locs = fn (xs: [ Location ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_locs(xs: rest, acc: acc + 1)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // Cursor on the importer's call site `g` at line 2 character 9.
  let without_decl = refs.find_references(
    text: buffer_text(),
    file_uri: "buffer://5pg8_importer.nx",
    line: 2, character: 9,
    include_declaration: false
  )
  test_assert.assert_eq_i64(actual: count_locs(xs: without_decl, acc: 0),
    expected: 3, label: "cross-file use-site count without declaration")

  let with_decl = refs.find_references(
    text: buffer_text(),
    file_uri: "buffer://5pg8_importer.nx",
    line: 2, character: 9,
    include_declaration: true
  )
  test_assert.assert_eq_i64(actual: count_locs(xs: with_decl, acc: 0),
    expected: 4, label: "cross-file ref count with declaration")
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
