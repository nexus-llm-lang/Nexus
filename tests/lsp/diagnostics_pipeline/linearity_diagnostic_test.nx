// Regression guard for nexus-ptyz: LSP/MCP diagnostics must run the linearity
// passes so E2007 (LinearUnused) and E2009 (LinearMismatch) surface in the
// editor, not just via `nexus build`.
//
// Pre-fix: `enumerate_diagnostics` called only `tcwf.check_program_wf_rows`
// and `check_program`; it never invoked `linearity.check_program` (HIR lazy
// pass) or `tc_linearity.check_program` (post-typecheck linear pass).
// A buffer containing an unconsumed %T linear binding passed through the LSP
// pipeline with zero diagnostics even though `nexus typecheck` rejected it.
//
// Fix: `enumerate_diagnostics` now calls both linearity passes in the same
// order as `src/main.nx` does, so E2007/E2009/E2005/etc. reach the editor.
import * as pipeline from "src/tools/lsp/state/diagnostics_pipeline.nx"
import { DiagEntry } from "src/tools/lsp/state/diagnostics.nx"
import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let count_diags = fn (xs: [ DiagEntry ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_diags(xs: rest, acc: acc + 1)
  end
end

let first_code = fn (xs: [ DiagEntry ]) -> string do
  match xs do
    | [] -> return ""
    | DiagEntry(file: _, range: _, severity: _, code, message: _) :: _ -> return code
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // A buffer with an unconsumed linear binding: `%b` is bound but never used.
  // `nexus typecheck` rejects this with E2007; the LSP pipeline must too.
  let src = "type Box = Box(val: i64)\nlet main = fn () -> unit do\n  let %b = Box(val: 1)\n  return ()\nend\n"
  let diags = pipeline.compute_diagnostics_for_buffer(
    text: src,
    file: "buffer://ptyz_linear_unused.nx"
  )
  test_assert.assert_eq_i64(
    actual: count_diags(xs: diags, acc: 0),
    expected: 1,
    label: "linear-unused buffer yields exactly one diagnostic (nexus-ptyz)"
  )
  test_assert.assert_eq_string(
    actual: first_code(xs: diags),
    expected: "E2007",
    label: "linear-unused diagnostic carries code E2007 (nexus-ptyz)"
  )
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
