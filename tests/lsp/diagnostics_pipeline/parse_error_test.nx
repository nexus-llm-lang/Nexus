// Issue nexus-byiw subset: targeted coverage for
// `src/lsp/diagnostics_pipeline.nx::compute_diagnostics_for_buffer`.
//
// Edge case: SOURCE WITH A LEX/PARSE ERROR. `parse_source` throws on the
// first malformed token (the pipeline does NOT use `parse_source_collect`
// — see diagnostics_pipeline.nx line 169). The outer `try` catches the
// ParseError and surfaces a single origin-anchored diagnostic via
// `make_origin_error_diagnostic`:
//
//   - file == the buffer URI
//   - range == (1, 1)..(1, 1)
//   - code == "" (empty — origin diagnostics carry no E-code)
//   - message == "lsp: failed to lex or parse source"
//
// A regression that let ParseError propagate out of the pipeline (instead of
// catching it) would crash the LSP loop. A regression that emitted the wrong
// message would break the editor surface contract.
import * as pipeline from "src/lsp/state/diagnostics_pipeline.nx"
import { DiagEntry } from "src/lsp/state/diagnostics.nx"
import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let count_diags = fn (xs: [ DiagEntry ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_diags(xs: rest, acc: acc + 1)
  end
end

// `let x =` with no RHS is an unambiguous syntactic error: the parser
// expects an expression after `=` and runs into EOF / a top-level keyword.
let broken_source = fn () -> string do
  return "let x =\n"
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let diags = pipeline.compute_diagnostics_for_buffer(
    text: broken_source(),
    file: "buffer://byiw_parse_err.nx"
  )
  // Pipeline catches ParseError → emits exactly one origin diagnostic.
  test_assert.assert_eq_i64(
    actual: count_diags(xs: diags, acc: 0),
    expected: 1,
    label: "parse error yields exactly one (origin-anchored) diagnostic"
  )
  // Inspect that single diagnostic: file, code, message, range.
  match diags do
    | [] -> throw RuntimeError(val: "unreachable: count asserted 1")
    | DiagEntry(file, range: _, severity: _, code, message) :: _ ->
      test_assert.assert_eq_string(
        actual: file,
        expected: "buffer://byiw_parse_err.nx",
        label: "origin diagnostic carries the buffer URI"
      )
      test_assert.assert_eq_string(
        actual: code,
        expected: "",
        label: "parse-origin diagnostic has empty code (no E-code)"
      )
      test_assert.assert_eq_string(
        actual: message,
        expected: "lsp: failed to lex or parse source",
        label: "parse-origin diagnostic carries the fixed lex/parse message"
      )
  end
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
