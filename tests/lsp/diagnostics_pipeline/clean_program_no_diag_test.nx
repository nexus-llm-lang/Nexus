// Issue nexus-d850 regression guard.
// Pre-fix: `compute_diagnostics_for_buffer` called `hir.process_defs(defs,
// all_entries, accum, source_file, is_defining: 1)` — `all_entries` becomes a positional pun
// CallArg(label="all_entries") that does NOT match `entries`. LIR's
// alphabetical-by-label sort then routes the rename-entry list into the
// `defs` slot, process_defs produces zero HIR functions, and EVERY well-formed
// buffer is falsely flagged with MissingMain (E2002).
//
// Fix: add the `entries:` label at the call site.
//
// This fixture pins the fix by feeding a buffer that DOES declare main and
// asserting zero diagnostics come back.
import * as pipeline from "src/lsp/diagnostics_pipeline.nx"
import { DiagEntry } from "src/lsp/diagnostics.nx"
import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let count_diags = fn (xs: [DiagEntry], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_diags(xs: rest, acc: acc + 1)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let src = "let main = fn () -> unit do\n  return ()\nend\n"
  let diags = pipeline.compute_diagnostics_for_buffer(
    text: src,
    file: "buffer://d850_clean.nx"
  )
  test_assert.assert_eq_i64(
    actual: count_diags(xs: diags, acc: 0),
    expected: 0,
    label: "well-formed buffer with main yields zero diagnostics"
  )
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
