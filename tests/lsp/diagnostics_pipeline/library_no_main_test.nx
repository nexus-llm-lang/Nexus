// Issue nexus-k7x0: LSP diagnostics must not emit E2002 for library .nx files.
//
// Pre-fix: `compute_diagnostics_for_buffer` passed `require_main: true`, so
// opening any .nx file without a `main` binding triggered a spurious E2002
// (MissingMain) diagnostic in the editor.
//
// Fix: pass `require_main: false` from the LSP path.
//
// This fixture verifies that a well-formed library file (exports a pure
// function, no `main`) yields exactly ZERO diagnostics.
import * as pipeline from "src/lsp/state/diagnostics_pipeline.nx"
import { DiagEntry } from "src/lsp/state/diagnostics.nx"
import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let count_diags = fn (xs: [ DiagEntry ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_diags(xs: rest, acc: acc + 1)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // A typical library file: exports a helper function, no `main`.
  let src = "export let add = fn (a: i64, b: i64) -> i64 do\n  return a + b\nend\n"
  let diags = pipeline.compute_diagnostics_for_buffer(text: src, file: "buffer://k7x0_library.nx")
  // Library file without main must yield zero diagnostics (no spurious E2002).
  test_assert.assert_eq_i64(
    actual: count_diags(xs: diags, acc: 0),
    expected: 0,
    label: "library file without main yields zero diagnostics from LSP pipeline (nexus-k7x0)"
  )
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
