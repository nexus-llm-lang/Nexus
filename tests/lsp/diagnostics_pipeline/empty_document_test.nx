// Issue nexus-k7x0 regression guard.
// Pre-fix: `compute_diagnostics_for_buffer` passed `require_main: true` to
// `enumerate_diagnostics`, causing every library .nx file opened in the
// editor to receive a spurious E2002 (MissingMain) diagnostic.
//
// Fix: pass `require_main: false` from the LSP path. Only `nexus build` (the
// CLI entry path) requires a main binding.
//
// This fixture pins the fix: an empty buffer (no main) must yield ZERO
// diagnostics from the LSP pipeline — not E2002.
import * as pipeline from "src/tools/lsp/state/diagnostics_pipeline.nx"
import { DiagEntry } from "src/tools/lsp/state/diagnostics.nx"
import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let count_diags = fn (xs: [ DiagEntry ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_diags(xs: rest, acc: acc + 1)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let diags = pipeline.compute_diagnostics_for_buffer(text: "", file: "buffer://k7x0_empty.nx")
  // Empty buffer (no main) → zero diagnostics from the LSP path.
  // E2002 (MissingMain) must NOT fire here; library files legitimately lack main.
  test_assert.assert_eq_i64(
    actual: count_diags(xs: diags, acc: 0),
    expected: 0,
    label: "empty buffer (no main) yields zero diagnostics from LSP pipeline (nexus-k7x0)"
  )
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
