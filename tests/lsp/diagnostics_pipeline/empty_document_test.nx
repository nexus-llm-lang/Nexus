// Issue nexus-byiw subset: targeted coverage for
// `src/lsp/diagnostics_pipeline.nx::compute_diagnostics_for_buffer`.
//
// Edge case: EMPTY DOCUMENT. The editor sends an empty buffer (a fresh `.nx`
// the user is about to start typing into). The pipeline must:
//   1. Parse "" → empty Program (no parse error).
//   2. Resolve imports (vacuous; no imports in an empty Program).
//   3. HIR-build (no funcs).
//   4. Typecheck → throw `MissingMain` because no `main` binding exists.
//   5. enumerate_diagnostics catches the throw and emits exactly ONE
//      DiagEntry with code "E2002" (the MissingMain code in
//      diagnostics.nx::diagnostic_from_error).
//
// A regression that suppressed MissingMain in the LSP path (e.g. by passing
// `require_main: false` to check_program from the LSP) would surface as zero
// diagnostics and break the editor's "you need a main" hint.
import * as pipeline from "src/lsp/state/diagnostics_pipeline.nx"
import { DiagEntry } from "src/lsp/state/diagnostics.nx"
import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let count_diags = fn (xs: [DiagEntry], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_diags(xs: rest, acc: acc + 1)
  end
end

let first_code = fn (xs: [DiagEntry]) -> string do
  match xs do
    | [] -> return ""
    | DiagEntry(file: _, range: _, severity: _, code, message: _) :: _ -> return code
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let diags = pipeline.compute_diagnostics_for_buffer(
    text: "",
    file: "buffer://byiw_empty.nx"
  )
  // Empty buffer → exactly one MissingMain diagnostic.
  test_assert.assert_eq_i64(
    actual: count_diags(xs: diags, acc: 0),
    expected: 1,
    label: "empty buffer yields exactly one diagnostic (MissingMain)"
  )
  test_assert.assert_eq_string(
    actual: first_code(xs: diags),
    expected: "E2002",
    label: "MissingMain code is E2002"
  )
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
