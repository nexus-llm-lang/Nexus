// nexus-jrtt: hover Phase 3 — cap definition summary on cap name and cap method.
//
// Tests that `resolve_hover` returns a cap definition summary (cap name +
// method list) when the cursor sits on a cap name or a cap method reference.
//
// Source layout (8 lines, 0-based):
//   line 0: "export cap MyApi do"                      — MyApi at col 11
//   line 1: "  fn fetch(url: string) -> string"        — fetch at col 5
//   line 2: "  fn ping() -> bool"
//   line 3: "end"
//   line 4: "let main = fn () -> unit require { MyApi } do"  — MyApi at col 35
//   line 5: "  let _ = MyApi.fetch(url: \"x\")"        — MyApi at col 10, fetch at col 16
//   line 6: "  return ()"
//   line 7: "end"
//
// Pins:
//   1. Cursor on the cap name in `require { MyApi }` (line 4, col 35) →
//      markdown with "**MyApi** (capability)" header and method list.
//   2. Cursor on `MyApi` in `MyApi.fetch(...)` (line 5, col 10) →
//      same cap summary (cap-name side of the dotted ref).
//   3. Cursor on `fetch` in `MyApi.fetch(...)` (line 5, col 16) →
//      same cap summary (method-name side of the dotted ref).
//   4. Cursor on whitespace (line 6, col 0) → None.

import * as hover from "src/lsp/handlers/hover.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let source_cap = fn () -> string do
  return "export cap MyApi do\n"
      ++ "  fn fetch(url: string) -> string\n"
      ++ "  fn ping() -> bool\n"
      ++ "end\n"
      ++ "let main = fn () -> unit require { MyApi } do\n"
      ++ "  let _ = MyApi.fetch(url: \"x\")\n"
      ++ "  return ()\n"
      ++ "end\n"
end

let expected_md = fn () -> string do
  return "**MyApi** (capability)\nmethods:\n  - fetch(url: string) -> string\n  - ping() -> bool"
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let uri = "buffer://jrtt_cap.nx"

  // (1) Cursor on cap name in `require { MyApi }`: line 4, col 35.
  let r1 = hover.resolve_hover(
    text: source_cap(),
    file_uri: uri,
    line: 4,
    character: 35
  )
  match r1 do
    | None -> throw RuntimeError(val: "hover on cap name: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == expected_md() then 1 else 0 end,
        expected: 1,
        label: "hover on cap name returns cap summary"
      )
  end

  // (2) Cursor on `MyApi` in `MyApi.fetch(...)`: line 5, col 10 (cap-name side).
  let r2 = hover.resolve_hover(
    text: source_cap(),
    file_uri: uri,
    line: 5,
    character: 10
  )
  match r2 do
    | None -> throw RuntimeError(val: "hover on MyApi in method call: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == expected_md() then 1 else 0 end,
        expected: 1,
        label: "hover on cap name in dotted call returns cap summary"
      )
  end

  // (3) Cursor on `fetch` in `MyApi.fetch(...)`: line 5, col 16 (method-name side).
  let r3 = hover.resolve_hover(
    text: source_cap(),
    file_uri: uri,
    line: 5,
    character: 16
  )
  match r3 do
    | None -> throw RuntimeError(val: "hover on fetch method: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == expected_md() then 1 else 0 end,
        expected: 1,
        label: "hover on cap method name returns cap summary"
      )
  end

  // (4) Cursor on whitespace (return statement): line 6, col 0 → None.
  let r4 = hover.resolve_hover(
    text: source_cap(),
    file_uri: uri,
    line: 6,
    character: 0
  )
  match r4 do
    | None -> let _ = 0
    | Some(val: _) -> throw RuntimeError(val: "hover on whitespace: expected None, got Some")
  end

  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
