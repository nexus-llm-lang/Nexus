// hover Phase 3: cap/port definition summary on hover.
//
// Tests that `resolve_hover` returns the cap definition (name, methods) as
// markdown when the cursor sits on a cap name or a cap.method qualified ref.
//
// Pins:
//   1. Cursor on the cap name in its definition line (`cap Api do`) returns
//      the cap summary with all methods.
//   2. Cursor on the cap name inside `require { Api }` returns the same
//      cap summary (bare uppercase name, resolved via rename map).
//   3. Cursor on the cap name in a `Api.fetch(...)` call (LHS of dot) returns
//      the cap summary.
//   4. Cursor on the method name `fetch` in `Api.fetch(...)` (RHS of dot)
//      also returns the cap summary.

import * as hover from "src/lsp/handlers/hover.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

// Source layout (0-based lines):
// Line 0: "cap Api do"
// Line 1: "  fn fetch(url: string) -> string"
// Line 2: "  fn send(url: string, body: string) -> i64"
// Line 3: "end"
// Line 4: "let use_api = fn () -> string require { Api } do return Api.fetch(url: \"x\") end"
// Line 5: "let main = fn () -> unit require { PermConsole } do return () end"
let source_cap = fn () -> string do
  return "cap Api do\n"
      ++ "  fn fetch(url: string) -> string\n"
      ++ "  fn send(url: string, body: string) -> i64\n"
      ++ "end\n"
      ++ "let use_api = fn () -> string require { Api } do return Api.fetch(url: \"x\") end\n"
      ++ "let main = fn () -> unit require { PermConsole } do return () end\n"
end

// Expected markdown: cap name + methods list.
// FunctionSig renders as: "name(param: type, ...) -> ret".
let expected_api_md = fn () -> string do
  return "**Api** (cap)\nmethods:\n  - fetch(url: string) -> string\n  - send(url: string, body: string) -> i64"
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let uri = "buffer://hover_cap_test.nx"
  let src = source_cap()

  // (1) Cursor on `Api` in cap definition line (line 0, char 4).
  // "cap Api do" — prefix "cap " = 4 chars, so `Api` starts at char 4.
  let r1 = hover.resolve_hover(text: src, file_uri: uri, line: 0, character: 4)
  match r1 do
    | None -> throw RuntimeError(val: "hover on cap name in def: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == expected_api_md() then 1 else 0 end,
        expected: 1,
        label: "hover on cap name in definition returns cap summary"
      )
  end

  // (2) Cursor on `Api` inside `require { Api }` (line 4, char 40).
  // "let use_api = fn () -> string require { Api } do ..."
  // Prefix "let use_api = fn () -> string require { " = 40 chars.
  let r2 = hover.resolve_hover(text: src, file_uri: uri, line: 4, character: 40)
  match r2 do
    | None -> throw RuntimeError(val: "hover on cap name in require row: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == expected_api_md() then 1 else 0 end,
        expected: 1,
        label: "hover on cap name in require row returns cap summary"
      )
  end

  // (3) Cursor on `Api` in `Api.fetch(...)` call (line 4, char 56).
  // "let use_api = fn () -> string require { Api } do return Api.fetch..."
  // Prefix through "return " = 56 chars to reach the `Api` token.
  let r3 = hover.resolve_hover(text: src, file_uri: uri, line: 4, character: 56)
  match r3 do
    | None -> throw RuntimeError(val: "hover on cap qualifier in call: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == expected_api_md() then 1 else 0 end,
        expected: 1,
        label: "hover on cap name in cap.method call returns cap summary"
      )
  end

  // (4) Cursor on `fetch` in `Api.fetch(...)` (line 4, char 60).
  // "Api.fetch" — `fetch` starts 4 chars after `Api` (len("Api.") = 4), so char 60.
  let r4 = hover.resolve_hover(text: src, file_uri: uri, line: 4, character: 60)
  match r4 do
    | None -> throw RuntimeError(val: "hover on cap method name: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == expected_api_md() then 1 else 0 end,
        expected: 1,
        label: "hover on method name in cap.method call returns cap summary"
      )
  end

  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
