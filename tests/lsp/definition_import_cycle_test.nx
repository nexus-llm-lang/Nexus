// Issue nexus-yvd8: textDocument/definition — import-resolution failure
// must not crash. The resolver wraps the build pipeline in `try` and
// returns None on any failure (cycle, missing file, parse error in import).
//
// We exercise the missing-file branch: importing a path the resolver will
// fail to read. The cycle path uses identical try/catch wiring, so a
// passing missing-file test exercises the same recovery edge.
import * as defn from "src/lsp/handlers/definition.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  // Import a file that doesn't exist on disk — process_imports raises
  // FileNotFound (via Fs), which the resolver must catch -> None.
  return "import { f } from \"tests/lsp/fixtures/yvd8_does_not_exist.nx\"\n"
      ++ "let g = fn (x: i64) -> i64 do\n"
      ++ "  return f(x)\n"
      ++ "end\n"
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // Cursor on `f` call (line 2, character 9). Import resolution fails;
  // resolver must return None instead of propagating the exception.
  let loc_opt = defn.resolve_definition(
    text: buffer_text(),
    file_uri: "buffer://yvd8_cycle.nx",
    line: 2,
    character: 9
  )
  match loc_opt do
    | None -> return ()
    | Some(val: _) -> throw RuntimeError(val: "expected None when imports fail to resolve")
  end
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
