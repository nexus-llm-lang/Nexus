// Issue nexus-w2um: textDocument/signatureHelp — alias-qualified call.
//
// Importer pulls a multi-arg function via `import * as alias` and calls it
// as `alias.mul(<cursor>)`. The resolver must follow the alias through the
// import cache, find the lambda in the imported file, and report its
// parameter names + types. This is the canonical "method-on-cap"-shaped
// path: a qualified call site whose callee lives in another file.
import * as sig from "src/lsp/signature_help.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { SignatureHelp, SignatureInformation, ParameterInformation } from "src/lsp/protocol.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "import * as other from \"tests/lsp/fixtures/w2um_other.nx\"\n"
      ++ "let caller = fn () -> i64 do\n"
      ++ "  return other.mul(a: 1, b: 2)\n"
      ++ "end\n"
end

let count_params = fn (xs: [ParameterInformation], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_params(xs: rest, acc: acc + 1)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // Source line 2 (LSP 0-based): `  return other.mul(a: 1, b: 2)`.
  // Cursor at char 23 — just after the first comma, inside `b:` arg:
  //   `  return other.mul(a: 1, b`
  //    0   2     8 .  m u l ( a :   1 ,   b
  //    0   4     8     12   17   21
  // 23 is between the `,` and `b`. activeParameter should be 1.
  let help_opt = sig.resolve_signature_help(
    text: buffer_text(),
    file_uri: "buffer://w2um_alias.nx",
    line: 2,
    character: 25
  )
  match help_opt do
    | None -> raise RuntimeError(val: "expected Some(SignatureHelp) at alias.mul call, got None")
    | Some(val: SignatureHelp(signatures, active_signature: _, active_parameter)) ->
      // After the first `,` the active parameter is index 1.
      match active_parameter do
        | Some(val: idx) ->
          test_assert.assert_eq_i64(actual: idx, expected: 1,
            label: "activeParameter is 1 (cursor after first comma)")
        | None -> raise RuntimeError(val: "expected Some(active_parameter)")
      end
      match signatures do
        | [] -> raise RuntimeError(val: "expected one signature, got zero")
        | SignatureInformation(label, documentation: _, parameters, active_parameter: _) :: _ ->
          // Local name `mul` (not `other.mul`) — the renderer always emits
          // the post-`#` canonical name, mirroring the def-side display.
          test_assert.assert_eq_string(actual: label,
            expected: "mul(a: i64, b: i64)",
            label: "alias-qualified call resolves to imported lambda's signature")
          test_assert.assert_eq_i64(actual: count_params(xs: parameters, acc: 0),
            expected: 2, label: "parameter count = 2 from imported lambda")
      end
  end
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
