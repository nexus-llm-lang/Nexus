// Issue nexus-5pg8: textDocument/references resolver — same-file case.
//
// Buffer defines `f` once and references it from THREE call sites inside
// `g` / `h`. Cursor on the def-site `f` (line 0, character 4 — the 'f' in
// `let f = ...`):
//   - includeDeclaration=false  →  3 use sites
//   - includeDeclaration=true   →  4 entries (def + 3 uses)
import * as refs from "src/lsp/handlers/references.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Location, Range, Position } from "src/lsp/protocol/text_doc.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "let f = fn (x: i64) -> i64 do\n"
      ++ "  return x + 1\n"
      ++ "end\n"
      ++ "let g = fn (x: i64) -> i64 do\n"
      ++ "  return f(x) + f(x: x + 1)\n"
      ++ "end\n"
      ++ "let h = fn (x: i64) -> i64 do\n"
      ++ "  return f(x) + 7\n"
      ++ "end\n"
end

let count_locs = fn (xs: [ Location ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_locs(xs: rest, acc: acc + 1)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // Cursor on def-site 'f' at (0, 4) — the 'f' in `let f = ...`.
  let without_decl = refs.find_references(
    text: buffer_text(),
    file_uri: "buffer://5pg8_same.nx",
    line: 0, character: 4,
    include_declaration: false
  )
  test_assert.assert_eq_i64(actual: count_locs(xs: without_decl, acc: 0),
    expected: 3, label: "use-site count without declaration")

  let with_decl = refs.find_references(
    text: buffer_text(),
    file_uri: "buffer://5pg8_same.nx",
    line: 0, character: 4,
    include_declaration: true
  )
  test_assert.assert_eq_i64(actual: count_locs(xs: with_decl, acc: 0),
    expected: 4, label: "ref count with declaration")

  // Cursor on a USE site (`f(x)` in g, line 4 char 9) yields the
  // same canonical and so the same set of references.
  let from_use = refs.find_references(
    text: buffer_text(),
    file_uri: "buffer://5pg8_same.nx",
    line: 4, character: 9,
    include_declaration: false
  )
  test_assert.assert_eq_i64(actual: count_locs(xs: from_use, acc: 0),
    expected: 3, label: "use-site count from cursor on a use site")

  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
