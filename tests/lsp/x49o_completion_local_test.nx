// Issue nexus-x49o: textDocument/completion — local-scope identifier.
//
// Cursor sits inside a function body, after a `let foo = 42`. The completion
// list must include `foo` (recently-bound local), the parameter `n`, and the
// surrounding top-level def `outer`.
import * as compl from "src/lsp/completion.nx"
import * as test_assert from "std:test/assert"
import { CompletionList, CompletionItem } from "nxlib/lsp/protocol.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "let outer = fn (n: i64) -> i64 do\n"
      ++ "  let foo = 42\n"
      ++ "  return n\n"
      ++ "end\n"
end

let has_label = fn (items: [CompletionItem], label: string) -> bool do
  match items do
    | [] -> return false
    | CompletionItem(label: l, kind: _, detail: _, documentation: _) :: rest ->
      if l == label then return true end
      return has_label(items: rest, label)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // Cursor on line 2 (LSP 0-based), character 9 — just after `return n` →
  // wait, we want cursor *after* the let foo line so foo is in scope. Use
  // line 2 character 0 (the `  return n` indent area, before any token on
  // that line — lexically `foo` is bound on the previous line).
  let cl = compl.resolve_completion(
    text: buffer_text(),
    file_uri: "buffer://x49o_local.nx",
    line: 2,
    character: 0
  )
  match cl do | CompletionList(is_incomplete: _, items) ->
    test_assert.assert_eq_bool(actual: has_label(items, label: "foo"),
      expected: true, label: "local 'foo' visible after its let-binding")
    test_assert.assert_eq_bool(actual: has_label(items, label: "n"),
      expected: true, label: "param 'n' visible inside lambda body")
    test_assert.assert_eq_bool(actual: has_label(items, label: "outer"),
      expected: true, label: "enclosing top-level 'outer' visible")
    test_assert.assert_eq_bool(actual: has_label(items, label: "let"),
      expected: true, label: "keyword 'let' present in local scope too")
  end
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
