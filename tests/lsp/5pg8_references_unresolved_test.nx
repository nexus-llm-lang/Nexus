// Issue nexus-5pg8: textDocument/references — unresolved / non-identifier
// cursor must yield an empty list (no crash, no synthetic Locations).
//
// Asserts:
//   1. Whitespace                  → []
//   2. Integer literal              → []
//   3. Out-of-range cursor (line 99) → []
import * as refs from "src/lsp/references.nx"
import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"
import { Location } from "src/lsp/protocol.nx"

let buffer_text = fn () -> string do
  return "let f = fn (x: i64) -> i64 do\n"
      ++ "  return x + 42\n"
      ++ "end\n"
end

let count_locs = fn (xs: [Location], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_locs(xs: rest, acc: acc + 1)
  end
end

let assert_empty = fn (
  text: string, line: i64, character: i64, label: string
) -> unit require { Fs, Console } throws { Exn } do
  let locs = refs.find_references(
    text, file_uri: "buffer://5pg8_unresolved.nx",
    line, character, include_declaration: true
  )
  test_assert.assert_eq_i64(actual: count_locs(xs: locs, acc: 0), expected: 0, label)
  return ()
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let txt = buffer_text()
  assert_empty(text: txt, line: 1, character: 0, label: "whitespace at line start → []")
  assert_empty(text: txt, line: 1, character: 13, label: "integer literal '42' → []")
  assert_empty(text: txt, line: 99, character: 99, label: "out-of-range cursor → []")
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
