// Issue nexus-w2um: textDocument/signatureHelp — nested call.
//
// Buffer defines two functions `outer` and `inner`. The caller writes
// `outer(x: inner(<cursor>))`. The cursor is inside `inner`'s args; the
// returned SignatureHelp must describe `inner`'s signature, not `outer`'s
// (we surface the *innermost* open paren-frame at the cursor).
import * as sig from "src/lsp/handlers/signature_help.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { SignatureHelp, SignatureInformation } from "src/lsp/protocol.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "let inner = fn (n: i64) -> i64 do\n"
      ++ "  return n + 1\n"
      ++ "end\n"
      ++ "let outer = fn (x: i64) -> i64 do\n"
      ++ "  return x + 2\n"
      ++ "end\n"
      ++ "let caller = fn (a: i64) -> i64 do\n"
      ++ "  return outer(x: inner(n: a))\n"
      ++ "end\n"
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // Source line 7 (LSP 0-based), the `  return outer(x: inner(n: a))` line.
  // 0-based char idx:
  //   0-1 = leading spaces
  //   2-7 = "return"
  //   8 = space
  //   9-13 = "outer"
  //   14 = "("
  //   15 = "x"
  //   16 = ":"
  //   17 = " "
  //   18-22 = "inner"
  //   23 = "("
  //   24 = "n"
  //   25 = ":"
  //   26 = " "
  //   27 = "a"
  //   28 = ")"
  //   29 = ")"
  // Place cursor at character 24 — between the inner `(` and `n`.
  // Innermost open paren at that point is `inner(`.
  let help_opt = sig.resolve_signature_help(
    text: buffer_text(),
    file_uri: "buffer://w2um_nested.nx",
    line: 7,
    character: 24
  )
  match help_opt do
    | None -> throw RuntimeError(val: "expected Some(SignatureHelp) at inner-call cursor, got None")
    | Some(val: SignatureHelp(signatures, active_signature: _, active_parameter: _)) ->
      match signatures do
        | [] -> throw RuntimeError(val: "expected one signature, got zero")
        | SignatureInformation(label, documentation: _, parameters: _, active_parameter: _) :: _ ->
          // The label MUST be the inner function's signature, not outer's.
          test_assert.assert_eq_string(actual: label,
            expected: "inner(n: i64)",
            label: "inner-call signature wins over enclosing outer call")
      end
  end
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
