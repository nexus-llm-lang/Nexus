// Issue nexus-w2um: textDocument/signatureHelp — bare call, cursor inside arg 0.
//
// Buffer defines `add(x: i64, y: i64)` and references it inside `caller`.
// Cursor sits inside the call's first argument: `add(<cursor>)`.
// Expected: SignatureHelp with one signature labeled `add(x: i64, y: i64)`,
// two parameters, activeParameter = 0.
import * as sig from "src/lsp/handlers/signature_help.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import {
  SignatureHelp,
  SignatureInformation,
  ParameterInformation
} from "src/lsp/protocol/completion.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "let add = fn (x: i64, y: i64) -> i64 do\n"
      ++ "  return x + y\n"
      ++ "end\n"
      ++ "let caller = fn (a: i64) -> i64 do\n"
      ++ "  return add(x: a)\n"
      ++ "end\n"
end

let count_params = fn (xs: [ ParameterInformation ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_params(xs: rest, acc: acc + 1)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // Cursor at line 4 (LSP 0-based), character 13 — inside `  return add(|)`.
  // The `add(` starts at column 9 (0-based: `r=2,e=3,t=4,u=5,r=6,n=7, =8,a=9,d=10,d=11,(=12`),
  // cursor at character 13 (just after `(`).
  let help_opt = sig.resolve_signature_help(
    text: buffer_text(),
    file_uri: "buffer://w2um_bare.nx",
    line: 4,
    character: 13
  )
  match help_opt do
    | None -> throw RuntimeError(val: "expected Some(SignatureHelp), got None")
    | Some(val: SignatureHelp(signatures, active_signature, active_parameter)) ->
      match active_signature do
        | Some(val: idx) ->
          test_assert.assert_eq_i64(actual: idx, expected: 0,
            label: "activeSignature is 0")
        | None -> throw RuntimeError(val: "expected Some(active_signature)")
      end
      match active_parameter do
        | Some(val: idx) ->
          test_assert.assert_eq_i64(actual: idx, expected: 0,
            label: "activeParameter is 0 (cursor inside first arg)")
        | None -> throw RuntimeError(val: "expected Some(active_parameter)")
      end
      match signatures do
        | [] -> throw RuntimeError(val: "expected one signature, got zero")
        | SignatureInformation(label, documentation: _, parameters, active_parameter: _) :: _ ->
          test_assert.assert_eq_string(actual: label,
            expected: "add(x: i64, y: i64)",
            label: "signature label renders param names + types")
          test_assert.assert_eq_i64(actual: count_params(xs: parameters, acc: 0),
            expected: 2, label: "parameter count = 2")
          match parameters do
            | [] -> throw RuntimeError(val: "expected 2 params, got zero")
            | ParameterInformation(label: p0, documentation: _) :: rest ->
              test_assert.assert_eq_string(actual: p0,
                expected: "x: i64",
                label: "first parameter label is 'x: i64'")
              match rest do
                | [] -> throw RuntimeError(val: "expected 2 params, got one")
                | ParameterInformation(label: p1, documentation: _) :: _ ->
                  test_assert.assert_eq_string(actual: p1,
                    expected: "y: i64",
                    label: "second parameter label is 'y: i64'")
              end
          end
      end
  end
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
