// nexus-xf2u: hover handler Phase 1 — identifier hover shows function type.
//
// Tests that `resolve_hover` returns the full function signature as markdown
// when the cursor sits on a top-level function identifier.
//
// Pins:
//   1. Cursor on a call to a top-level `let f = fn (...) -> T` returns
//      `**f**: fn(x: i64) -> i64` (no require, no throws).
//   2. Cursor on a function with `require { Console }` includes the require row.
//   3. Cursor on a function with `throws { LspProtocolError }` includes throws.
//   4. Cursor on a non-identifier position (whitespace) returns None.

import * as hover from "src/lsp/handlers/hover.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

// Source: a simple function with no require/throws, referenced in main.
let source_simple = fn () -> string do
  return "let add = fn (x: i64, y: i64) -> i64 do return x + y end\n"
      ++ "let main = fn () -> unit require { PermConsole } do\n"
      ++ "  add(x: 1, y: 2)\n"
      ++ "  return ()\n"
      ++ "end\n"
end

// Cursor at line 2, character 2 — on the `add` in `  add(x: 1, y: 2)`.
let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let uri = "buffer://xf2u_ident.nx"

  // (1) Cursor on `add` call site — should hover-resolve to the function sig.
  let r1 = hover.resolve_hover(text: source_simple(), file_uri: uri, line: 2, character: 2)
  match r1 do
    | None -> throw RuntimeError(val: "hover on add call: expected Some, got None")
    | Some(val: md) ->
      // Should contain the function name and param types.
      test_assert.assert_eq_i64(
        actual: if md == "**add**: fn(x: i64, y: i64) -> i64" then 1 else 0 end,
        expected: 1,
        label: "hover on add returns full signature"
      )
  end

  // (2) Cursor on whitespace — should return None.
  let r2 = hover.resolve_hover(text: source_simple(), file_uri: uri, line: 2, character: 0)
  match r2 do
    | None -> ()
    | Some(val: _) -> throw RuntimeError(val: "hover on whitespace: expected None, got Some")
  end

  // (3) Source with require row.
  // Line 1: "let main = fn () -> unit require { PermConsole } do greet(name: \"hi\") return () end"
  // `greet` starts at character 52.
  let source_req = "let greet = fn (name: string) -> string require { Console } do return name end\n"
      ++ "let main = fn () -> unit require { PermConsole } do greet(name: \"hi\") return () end\n"
  let r3 = hover.resolve_hover(text: source_req, file_uri: uri, line: 1, character: 52)
  match r3 do
    | None -> throw RuntimeError(val: "hover on greet call: expected Some, got None")
    | Some(val: md) ->
      test_assert.assert_eq_i64(
        actual: if md == "**greet**: fn(name: string) -> string require { Console }" then 1 else 0 end,
        expected: 1,
        label: "hover on greet includes require row"
      )
  end

  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
