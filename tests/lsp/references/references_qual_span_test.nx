// nexus-s6cu: textDocument/references — qualified call span must cover the
// callee name, not start at the alias token.
//
// Buffer: import * as m from "tests/lsp/fixtures/_s6cu_other.nx"
//         let f = fn () -> unit do
//           m.bar()
//         end
//
// Cursor on 'bar' at (line=2, character=4). The returned Location for the
// call site must have:
//   range.start.character = 4   (start of 'bar', not start of 'm')
//   range.end.character   = 7   (4 + len("bar"))
//
// Pre-fix this returns start.character=2, end.character=5 (highlights 'm.b').
import * as refs from "src/tools/lsp/handlers/references.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Location, Range, Position } from "src/tools/lsp/protocol/text_doc.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "import * as m from \"tests/lsp/fixtures/_s6cu_other.nx\"\n"
      ++ "let f = fn () -> unit do\n"
      ++ "  m.bar()\n"
      ++ "end\n"
end

// Return the first Location in the list, or a sentinel with character=-1.
let first_loc = fn (xs: [ Location ]) -> Location do
  match xs do
    | [] ->
      let sentinel = Position(line: -1, character: -1)
      return Location(uri: "", range: Range(start: sentinel, end_: sentinel))
    | loc :: _ -> return loc
  end
end

let count_locs = fn (xs: [ Location ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | _ :: rest -> return count_locs(xs: rest, acc: acc + 1)
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // Cursor on 'bar' (line 2, character 4 — the 'b' in 'm.bar()').
  let locs = refs.find_references(
    text: buffer_text(),
    file_uri: "buffer://s6cu_importer.nx",
    line: 2, character: 4,
    include_declaration: false
  )

  // Must find exactly one use site (the m.bar() call on line 2).
  test_assert.assert_eq_i64(actual: count_locs(xs: locs, acc: 0),
    expected: 1, label: "qual-call reference count")

  // The location must cover 'bar', not 'm.b'.
  let loc = first_loc(xs: locs)
  match loc do | Location(
    uri: _,
    range: Range(
      start: Position(line: _, character: start_char),
      end_: Position(line: _, character: end_char)
    )
  ) ->
    test_assert.assert_eq_i64(actual: start_char, expected: 4,
      label: "qual-call span start.character = col of 'bar'")
    test_assert.assert_eq_i64(actual: end_char, expected: 7,
      label: "qual-call span end.character = col after 'bar'")
  end
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
