// Issue nexus-yvd8: textDocument/definition resolver — cross-file case.
//
// Importer buffer pulls `g` from tests/lsp/fixtures/other_yvd8.nx. Cursor on
// the call site to `g` must resolve to the `let g = fn ...` line in
// other_yvd8.nx (file path mirrors the import path string verbatim — no
// file:// prefix manufactured here, matching the diagnostics path's
// origin-file convention).
import * as defn from "src/lsp/handlers/definition.nx"
import * as test_assert from "std:test/assert"
import { Some, None } from "std:option"
import { Location, Range, Position } from "src/lsp/protocol/text_doc.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let buffer_text = fn () -> string do
  return "import { g } from \"tests/lsp/fixtures/other_yvd8.nx\"\n"
      ++ "let h = fn (x: i64) -> i64 do\n"
      ++ "  return g(x)\n"
      ++ "end\n"
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  // Line 2 (0-based), `  return g(x)` — cursor on 'g' at character 9.
  let loc_opt = defn.resolve_definition(
    text: buffer_text(),
    file_uri: "buffer://yvd8_importer.nx",
    line: 2,
    character: 9
  )
  match loc_opt do
    | None -> throw RuntimeError(val: "expected Some(Location), got None")
    | Some(val: loc) ->
      match loc do | Location(uri, range) ->
        // The Location URI mirrors the resolver's `physical` path — for a
        // bare path import that's the import string itself.
        test_assert.assert_eq_string(actual: uri,
          expected: "tests/lsp/fixtures/other_yvd8.nx",
          label: "cross-file URI matches imported path")
        match range do | Range(start, end_: _) ->
          match start do | Position(line, character) ->
            // other_yvd8.nx lines 1-3 are `// ...` comments. The
            // `export let g = fn ...` keyword sits on AST line 4 (1-based)
            // → LSP line 3 (0-based). The parser consumes `export` first
            // and anchors the SpannedTopLevel span at `let`, which is at
            // 1-based column 8 → LSP character 7.
            test_assert.assert_eq_i64(actual: line, expected: 3,
              label: "imported def start line (export let g)")
            test_assert.assert_eq_i64(actual: character, expected: 7,
              label: "imported def start character (let after export)")
          end
        end
      end
  end
  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
