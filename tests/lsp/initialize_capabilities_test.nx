// nexus-obew: initialize response must advertise textDocumentSync as an object
// with save: true, not the bare integer shorthand.
//
// Per LSP spec §3.17.2, integer `textDocumentSync: 1` is shorthand for
// `change` mode only. To opt-in for `didSave`, the server must use the object
// form `{ change: 1, save: true }`. Compliant clients (VS Code 1.82+) ignore
// `didSave` if the server only sends the integer shorthand.
//
// Pins:
//   1. The initialize response `result.capabilities.textDocumentSync` is a JSON
//      object, not an integer.
//   2. The object has `change: 1` (TdsFull).
//   3. The object has `save: true`.

import { dispatch_message } from "src/lsp/handlers.nx"
import { StepContinue, StepExit } from "src/lsp/handlers.nx"
import { ServerState, empty_state } from "src/lsp/state/server_state.nx"
import { Request } from "std:jsonrpc"
import {
  JsonValue, JsonNull, JsonObject, JsonField, JsonString, JsonInt, JsonBool,
  JsonArray, get_field
} from "std:json"
import { Option, Some, None } from "std:option"
import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

let make_initialize_params = fn () -> JsonValue do
  return JsonObject(fields: [
    JsonField(key: "processId",   value: JsonNull),
    JsonField(key: "rootUri",     value: JsonNull),
    JsonField(key: "capabilities", value: JsonObject(fields: []))
  ])
end

// Navigate into result.capabilities.textDocumentSync from an initialize
// response envelope.
let extract_tds = fn (resp: JsonValue) -> Option<JsonValue> do
  match get_field(obj: resp, key: "result") do
    | None -> return None
    | Some(val: result) ->
      match get_field(obj: result, key: "capabilities") do
        | None -> return None
        | Some(val: caps) ->
          return get_field(obj: caps, key: "textDocumentSync")
      end
  end
end

let body = fn () -> unit require { Fs, Console } throws { Exn } do
  let init_msg = Request(
    id: JsonInt(val: 1),
    method: "initialize",
    params: make_initialize_params()
  )
  let step = dispatch_message(state: empty_state(), msg: init_msg)
  let resp = match step do
    | StepExit(_) -> throw RuntimeError(val: "initialize must not exit")
    | StepContinue(state: _, response, notifications: _) ->
      match response do
        | None -> throw RuntimeError(val: "initialize must produce a response")
        | Some(val: r) -> r
      end
  end

  // Pin 1: textDocumentSync is a JSON object, not an integer.
  let tds = match extract_tds(resp) do
    | None -> throw RuntimeError(val: "capabilities.textDocumentSync must be present")
    | Some(val: v) -> v
  end
  match tds do
    | JsonInt(val: _) ->
      throw RuntimeError(val: "textDocumentSync must be an object, not an integer shorthand")
    | JsonObject(fields: _) -> ()
    | _ ->
      throw RuntimeError(val: "textDocumentSync must be an object")
  end

  // Pin 2: change == 1 (TdsFull).
  let change_val = match get_field(obj: tds, key: "change") do
    | None -> throw RuntimeError(val: "textDocumentSync.change must be present")
    | Some(val: v) -> v
  end
  match change_val do
    | JsonInt(val: n) ->
      test_assert.assert_eq_i64(
        actual: n,
        expected: 1,
        label: "textDocumentSync.change == 1 (TdsFull)"
      )
    | _ ->
      throw RuntimeError(val: "textDocumentSync.change must be an integer")
  end

  // Pin 3: save == true.
  let save_val = match get_field(obj: tds, key: "save") do
    | None -> throw RuntimeError(val: "textDocumentSync.save must be present")
    | Some(val: v) -> v
  end
  match save_val do
    | JsonBool(val: b) ->
      test_assert.assert_eq_bool(actual: b, expected: true, label: "textDocumentSync.save == true")
    | _ ->
      throw RuntimeError(val: "textDocumentSync.save must be a boolean")
  end

  return ()
end

let safe_run = fn () -> i64 require { Fs, Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs, PermConsole } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
