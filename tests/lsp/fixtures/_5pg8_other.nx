// Fixture for tests/lsp/5pg8_references_cross_file_test.nx — provides
// exported `g` plus an internal use site (`g(x: x - 1)` inside `helper`).
// The references walker must surface BOTH the importer's call site AND
// this internal recursive site when asked for references to `g`.
export let g = fn (x: i64) -> i64 do
  if x <= 0 then return 0 end
  return g(x: x - 1) + 1
end

export let helper = fn (x: i64) -> i64 do
  return g(x) + 2
end
