// Fixture for tests/lsp/w2um_signature_help_alias_test.nx.
//
// Exports `mul` with a multi-arg signature so the alias-qualified call
// `alias.mul(...)` in the importer resolves through the rename map to this
// file's lambda and the signature-help resolver reports its parameter
// names + types.
export let mul = fn (a: i64, b: i64) -> i64 do
  return a * b
end
