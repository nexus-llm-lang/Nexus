import { Span } from nxc/token.nx
import { Literal, TypeExpr, Sigil, BinaryOp, EnumDef } from nxc/ast.nx
import { HirExpr, HirStmt, HirCallArg, HirParam, HirFunction,
         HirPort, HirPortMethod, HirExternal, HirHandlerBinding,
         HirHandlerBindingEntry, HirProgram,
         HirNamedExpr } from nxc/hir.nx
import { MirProgram, MirFunction, MirExpr, MirStmt, MirParam, MirExternal,
         MirCallArg, MirMatchCase, MirPattern,
         lower_hir_to_mir } from nxc/mir.nx
import { LirProgram, LirFunction, LirStmt, LirExpr, LirAtom,
         lower_mir_to_lir } from nxc/lir.nx

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let dummy_span = fn () -> Span do return Span(offset: 0, line: 0, col: 0) end

// ─── Test 1: Basic function lowering ─────────────────────────────────────────

let test_basic = fn () -> unit throws { Exn } do
  // Build a simple MIR function: main() -> return 42
  let body = Cons(
    v: MirStmtReturn(expr: MirLiteral(lit: LitInt(val: 42))),
    rest: Nil()
  )
  let func = MirFunction(
    name: "main",
    params: Nil(),
    ret_type: TyUnit,
    body: body,
    span: dummy_span()
  )
  let mir = MirProgram(functions: Cons(v: func, rest: Nil()), externals: Nil())
  let lir = lower_mir_to_lir(mir: mir, enum_defs: Nil())
  match lir do case LirProgram(functions: fs, externals: _) ->
    match fs do
      case Cons(v: f, rest: _) ->
        match f do case LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) ->
          assert(cond: n == "main", msg: "basic: function name is main")
        end
      case Nil() -> raise RuntimeError(val: "basic: no functions")
    end
  end
end

// ─── Test 2: Let binding ANF ─────────────────────────────────────────────────

let test_let_binding = fn () -> unit throws { Exn } do
  // let x = 1 + 2; return x
  let body = Cons(
    v: MirStmtLet(name: "x", typ: TyInt,
      expr: MirBinaryOp(left: MirLiteral(lit: LitInt(val: 1)), op: OpAdd,
                         right: MirLiteral(lit: LitInt(val: 2)))),
    rest: Cons(
      v: MirStmtReturn(expr: MirVariable(name: "x")),
      rest: Nil()
    )
  )
  let func = MirFunction(name: "test", params: Nil(), ret_type: TyInt, body: body, span: dummy_span())
  let mir = MirProgram(functions: Cons(v: func, rest: Nil()), externals: Nil())
  let lir = lower_mir_to_lir(mir: mir, enum_defs: Nil())
  match lir do case LirProgram(functions: fs, externals: _) ->
    match fs do
      case Cons(v: f, rest: _) ->
        match f do case LirFunction(name: _, params: _, ret_type: _, body: stmts, ret: _, span: _) ->
          // Body should have: let __t0 = 1 + 2, let x = __t0
          match stmts do
            case Cons(v: s1, rest: _) ->
              match s1 do
                case LirStmtLet(name: _, typ: _, expr: e) ->
                  match e do
                    case LirExprBinary(op: _, lhs: _, rhs: _, typ: _) ->
                      assert(cond: true, msg: "let_binding: binary expr found")
                    case _ -> assert(cond: true, msg: "let_binding: some expr found")
                  end
                case _ -> raise RuntimeError(val: "let_binding: expected let stmt")
              end
            case Nil() -> raise RuntimeError(val: "let_binding: empty body")
          end
        end
      case Nil() -> raise RuntimeError(val: "let_binding: no functions")
    end
  end
end

// ─── Test 3: Full pipeline HIR→MIR→LIR ──────────────────────────────────────

let test_full_pipeline = fn () -> unit throws { Exn } do
  let body = Cons(
    v: HirStmtReturn(expr: HirLiteral(lit: LitInt(val: 99))),
    rest: Nil()
  )
  let func = HirFunction(name: "main", params: Nil(), ret_type: TyUnit,
    body: body, span: dummy_span())
  let hir = HirProgram(
    ports: Nil(), functions: Cons(v: func, rest: Nil()),
    externals: Nil(), handler_bindings: Nil(), enum_defs: Nil()
  )
  let mir = lower_hir_to_mir(hir: hir)
  match mir do case MirProgram(functions: _, externals: _) ->
    let lir = lower_mir_to_lir(mir: mir, enum_defs: Nil())
    match lir do case LirProgram(functions: fs, externals: _) ->
      match fs do
        case Cons(v: f, rest: _) ->
          match f do case LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) ->
            assert(cond: n == "main", msg: "full_pipeline: function name is main")
          end
        case Nil() -> raise RuntimeError(val: "full_pipeline: no functions")
      end
    end
  end
end

let main = fn () -> unit throws { Exn } do
  test_basic()
  test_let_binding()
  test_full_pipeline()
end
