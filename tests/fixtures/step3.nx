pub fn test_match(x: i64) -> i64 do
  match x do
    case 0 -> return 0
    case val -> return val
  endmatch
endfn

pub fn test_ctor(r: Result<i64, str>) -> i64 do
  match r do
    case Ok(v) -> return v
    case Err(e) -> return -1
  endmatch
endfn

pub fn test_sigil(r: Result<unit, unit>) -> unit do
  match r do
    case Ok(%x) -> return %x
    case Err(~y) -> return ()
  endmatch
endfn
