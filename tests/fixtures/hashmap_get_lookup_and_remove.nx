import * as hashmap from stdlib/hashmap.nx

let main = fn () -> unit do
  let m0 = hashmap.empty()
  let m1 = hashmap.put(map: m0, key: 7, value: 70)
  let m2 = hashmap.put(map: m1, key: 8, value: 80)
  let got = hashmap.get(map: &m2, key: 7)
  let m3 = hashmap.remove(map: m2, key: 8)
  let sz = hashmap.size(map: &m3)
  hashmap.free(map: m3)
  match got do
    case Found(value: v) ->
      let result = v + sz
      if result != 71 then raise RuntimeError(val: "expected 71") end
    case Missing -> raise RuntimeError(val: "expected Found, got Missing")
  end
  return ()
end
