
    import * as array from "stdlib/array.nx"

    let add = fn (acc: i64, val: i64) -> i64 do
      return acc + val
    end

    let main = fn () -> i64 do
      let %arr = [| 1, 2, 3, 4 |]
      let arr_ref = &%arr
      let sum = array.fold_left(arr: arr_ref, init: 0, f: add)
      match %arr do case _ -> () end
      return sum
    end
    