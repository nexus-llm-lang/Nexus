import * as set from "stdlib/set.nx"

let main = fn () -> i64 do
  let s0 = set.empty()
  let s1 = set.insert(set: s0, val: 1)
  let s2 = set.insert(set: s1, val: 2)
  let s3 = set.insert(set: s2, val: 2)
  let has1 = set.contains(set: &s3, val: 1)
  let has3 = set.contains(set: &s3, val: 3)
  let sz = set.size(set: &s3)
  set.free(set: s3)
  if has1 then
    if has3 then
      return 0 - 1
    else
      return sz
    end
  else
    return 0 - 1
  end
end
