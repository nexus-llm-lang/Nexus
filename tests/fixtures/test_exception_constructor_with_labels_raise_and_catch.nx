
    exception Boom(code: i64)

    let main = fn () -> i64 do
      try
        let err = Boom(code: 42)
        raise err
      catch
        case Boom(code: c) -> return c
        case RuntimeError(val: _) -> return -1
        case InvalidIndex(val: _) -> return -2
      end
      return 0
    end
    