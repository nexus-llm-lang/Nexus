import { LirProgram, LirFunction, LirStmt, LirExpr, LirAtom, LirParam,
         LirExternal, LirCallArg, LirNamedAtom } from "nxc/ir/lir_types.nx"
import { compile_lir_to_wasm } from "nxc/backend/codegen.nx"
import { ByteBuffer, length, get_byte, free } from "stdlib/bytebuffer.nx"
import { Span } from "nxc/common/token.nx"

let main = fn () -> unit throws { Exn } do
  // Build a minimal LIR program: fn main() -> unit { return () }
  let func = LirFunction(
    name: "main",
    params: Nil,
    ret_type: TyUnit,
    body: Nil,
    ret: LirAtomUnit,
    span: Span(offset: 0, line: 0, col: 0)
  )
  let program = LirProgram(functions: Cons(v: func, rest: Nil), externals: Nil)
  let %wasm = compile_lir_to_wasm(program: program)

  // Verify WASM magic number: 0 97 115 109  (0x00 0x61 0x73 0x6D)
  let b0 = get_byte(buf: &wasm, idx: 0)
  let b1 = get_byte(buf: &wasm, idx: 1)
  let b2 = get_byte(buf: &wasm, idx: 2)
  let b3 = get_byte(buf: &wasm, idx: 3)
  if b0 != 0 || b1 != 97 || b2 != 115 || b3 != 109 then
    raise RuntimeError(val: "WASM magic number mismatch")
  end

  // Verify version: 1 0 0 0
  let v0 = get_byte(buf: &wasm, idx: 4)
  if v0 != 1 then
    raise RuntimeError(val: "WASM version mismatch")
  end

  // Verify non-trivial size (should have type, function, export, code sections)
  let wasm_len = length(buf: &wasm)
  if wasm_len < 20 then
    raise RuntimeError(val: "WASM too small")
  end

  free(buf: %wasm)
  return ()
end
