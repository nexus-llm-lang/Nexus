import { Token, Span, SpannedToken, keyword_lookup } from "nxc/common/token.nx"
import { tokenize } from "nxc/frontend/lexer.nx"
import * as str from "stdlib/string.nx"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let assert_eq = fn (a: i64, b: i64, msg: string) -> unit throws { Exn } do
  if a == b then return ()
  else raise RuntimeError(val: msg ++ ": expected " ++ str.from_i64(val: b) ++ " got " ++ str.from_i64(val: a))
  end
end

let main = fn () -> unit throws { Exn } do
  // Test keywords
  let tokens = tokenize(src: "let fn do end if")
  match tokens do
    case SpannedToken(token: tk1, _) :: SpannedToken(token: tk2, _) :: SpannedToken(token: tk3, _) :: SpannedToken(token: tk4, _) :: SpannedToken(token: tk5, _) :: _ ->
      match tk1 do case TkLet -> () case _ -> raise RuntimeError(val: "expected TkLet") end
      match tk2 do case TkFn -> () case _ -> raise RuntimeError(val: "expected TkFn") end
      match tk3 do case TkDo -> () case _ -> raise RuntimeError(val: "expected TkDo") end
      match tk4 do case TkEnd -> () case _ -> raise RuntimeError(val: "expected TkEnd") end
      match tk5 do case TkIf -> () case _ -> raise RuntimeError(val: "expected TkIf") end
    case _ -> raise RuntimeError(val: "expected 5+ tokens")
  end

  // Test identifier
  let tokens2 = tokenize(src: "foo")
  match tokens2 do
    case SpannedToken(token: tk, _) :: _ ->
      match tk do
        case TkIdent(name: n) ->
          assert(cond: n == "foo", msg: "expected ident foo")
        case _ -> raise RuntimeError(val: "expected TkIdent")
      end
    case _ -> raise RuntimeError(val: "expected tokens")
  end

  // Test uppercase ident
  let tokens3 = tokenize(src: "Foo")
  match tokens3 do
    case SpannedToken(token: tk, _) :: _ ->
      match tk do
        case TkUident(name: n) ->
          assert(cond: n == "Foo", msg: "expected uident Foo")
        case _ -> raise RuntimeError(val: "expected TkUident")
      end
    case _ -> raise RuntimeError(val: "expected tokens")
  end

  // Test integer
  let tokens4 = tokenize(src: "42")
  match tokens4 do
    case SpannedToken(token: tk, _) :: _ ->
      match tk do
        case TkInt(val: v) -> assert_eq(a: v, b: 42, msg: "int value")
        case _ -> raise RuntimeError(val: "expected TkInt")
      end
    case _ -> raise RuntimeError(val: "expected tokens")
  end

  // Test string
  let tokens5 = tokenize(src: [=["hello"]=])
  match tokens5 do
    case SpannedToken(token: tk, _) :: _ ->
      match tk do
        case TkString(val: v) ->
          assert(cond: v == "hello", msg: "expected string hello")
        case _ -> raise RuntimeError(val: "expected TkString")
      end
    case _ -> raise RuntimeError(val: "expected tokens")
  end

  // Test operators
  let tokens6 = tokenize(src: "++ -> == !=")
  match tokens6 do
    case SpannedToken(token: tk1, _) :: SpannedToken(token: tk2, _) :: SpannedToken(token: tk3, _) :: SpannedToken(token: tk4, _) :: _ ->
      match tk1 do case TkPlusPlus -> () case _ -> raise RuntimeError(val: "expected TkPlusPlus") end
      match tk2 do case TkArrow -> () case _ -> raise RuntimeError(val: "expected TkArrow") end
      match tk3 do case TkEqEq -> () case _ -> raise RuntimeError(val: "expected TkEqEq") end
      match tk4 do case TkBangEq -> () case _ -> raise RuntimeError(val: "expected TkBangEq") end
    case _ -> raise RuntimeError(val: "expected 4+ tokens")
  end

  // Test comments are skipped
  let tokens7 = tokenize(src: "// comment\nlet")
  match tokens7 do
    case SpannedToken(token: tk, _) :: _ ->
      match tk do case TkLet -> () case _ -> raise RuntimeError(val: "expected TkLet after comment") end
    case _ -> raise RuntimeError(val: "expected tokens")
  end

  return ()
end
