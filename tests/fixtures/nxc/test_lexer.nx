import { Token, Span, SpannedToken, keyword_lookup } from nxc/token.nx
import { tokenize } from nxc/lexer.nx
import as str from stdlib/string.nx

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let assert_eq = fn (a: i64, b: i64, msg: string) -> unit throws { Exn } do
  if a == b then return ()
  else raise RuntimeError(val: msg ++ ": expected " ++ str.from_i64(val: b) ++ " got " ++ str.from_i64(val: a))
  end
end

let main = fn () -> unit throws { Exn } do
  // Test keywords
  let tokens = tokenize(src: "let fn do end if")
  match tokens do
    case Cons(v: t1, rest: Cons(v: t2, rest: Cons(v: t3, rest: Cons(v: t4, rest: Cons(v: t5, rest: _))))) ->
      match t1 do case SpannedToken(token: tk, _) -> match tk do case TkLet -> () case _ -> raise RuntimeError(val: "expected TkLet") end end
      match t2 do case SpannedToken(token: tk, _) -> match tk do case TkFn -> () case _ -> raise RuntimeError(val: "expected TkFn") end end
      match t3 do case SpannedToken(token: tk, _) -> match tk do case TkDo -> () case _ -> raise RuntimeError(val: "expected TkDo") end end
      match t4 do case SpannedToken(token: tk, _) -> match tk do case TkEnd -> () case _ -> raise RuntimeError(val: "expected TkEnd") end end
      match t5 do case SpannedToken(token: tk, _) -> match tk do case TkIf -> () case _ -> raise RuntimeError(val: "expected TkIf") end end
    case _ -> raise RuntimeError(val: "expected 5+ tokens")
  end

  // Test identifier
  let tokens2 = tokenize(src: "foo")
  match tokens2 do
    case Cons(v: t1, rest: _) ->
      match t1 do
        case SpannedToken(token: tk, _) ->
          match tk do
            case TkIdent(name: n) ->
              assert(cond: n == "foo", msg: "expected ident foo")
            case _ -> raise RuntimeError(val: "expected TkIdent")
          end
      end
    case _ -> raise RuntimeError(val: "expected tokens")
  end

  // Test uppercase ident
  let tokens3 = tokenize(src: "Foo")
  match tokens3 do
    case Cons(v: t1, rest: _) ->
      match t1 do
        case SpannedToken(token: tk, _) ->
          match tk do
            case TkUident(name: n) ->
              assert(cond: n == "Foo", msg: "expected uident Foo")
            case _ -> raise RuntimeError(val: "expected TkUident")
          end
      end
    case _ -> raise RuntimeError(val: "expected tokens")
  end

  // Test integer
  let tokens4 = tokenize(src: "42")
  match tokens4 do
    case Cons(v: t1, rest: _) ->
      match t1 do
        case SpannedToken(token: tk, _) ->
          match tk do
            case TkInt(val: v) -> assert_eq(a: v, b: 42, msg: "int value")
            case _ -> raise RuntimeError(val: "expected TkInt")
          end
      end
    case _ -> raise RuntimeError(val: "expected tokens")
  end

  // Test string
  let tokens5 = tokenize(src: [=["hello"]=])
  match tokens5 do
    case Cons(v: t1, rest: _) ->
      match t1 do
        case SpannedToken(token: tk, _) ->
          match tk do
            case TkString(val: v) ->
              assert(cond: v == "hello", msg: "expected string hello")
            case _ -> raise RuntimeError(val: "expected TkString")
          end
      end
    case _ -> raise RuntimeError(val: "expected tokens")
  end

  // Test operators
  let tokens6 = tokenize(src: "++ -> == !=")
  match tokens6 do
    case Cons(v: t1, rest: Cons(v: t2, rest: Cons(v: t3, rest: Cons(v: t4, rest: _)))) ->
      match t1 do case SpannedToken(token: tk, _) -> match tk do case TkPlusPlus -> () case _ -> raise RuntimeError(val: "expected TkPlusPlus") end end
      match t2 do case SpannedToken(token: tk, _) -> match tk do case TkArrow -> () case _ -> raise RuntimeError(val: "expected TkArrow") end end
      match t3 do case SpannedToken(token: tk, _) -> match tk do case TkEqEq -> () case _ -> raise RuntimeError(val: "expected TkEqEq") end end
      match t4 do case SpannedToken(token: tk, _) -> match tk do case TkBangEq -> () case _ -> raise RuntimeError(val: "expected TkBangEq") end end
    case _ -> raise RuntimeError(val: "expected 4+ tokens")
  end

  // Test comments are skipped
  let tokens7 = tokenize(src: "// comment\nlet")
  match tokens7 do
    case Cons(v: t1, rest: _) ->
      match t1 do case SpannedToken(token: tk, _) -> match tk do case TkLet -> () case _ -> raise RuntimeError(val: "expected TkLet after comment") end end
    case _ -> raise RuntimeError(val: "expected tokens")
  end

  return ()
end
