import { Token, SpannedToken } from nxc/common/token.nx
import { tokenize } from nxc/frontend/lexer.nx
import { parse } from nxc/frontend/parser.nx
import { Program } from nxc/common/ast.nx

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  let src = "let x = 1\n"
  let tokens = tokenize(src: src)
  let prog = parse(tokens: tokens)
  match prog do
    case Program(definitions: defs) ->
      match defs do
        case Cons(v: _, rest: Nil) -> ()
        case _ -> raise RuntimeError(val: "expected exactly 1 definition")
      end
  end
  return ()
end
