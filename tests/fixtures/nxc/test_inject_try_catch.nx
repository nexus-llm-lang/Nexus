/// Regression fixture: nxc/driver.nx's main has the shape
///   inject ... do try ... catch e -> ... end end
/// Stage 1 (nxc-compiled-by-Rust) emits wasm that fails validation for
/// func 2005 ("type mismatch: expected i64 but nothing on stack").
/// Reproduce here.

import { Console }, * as stdio from "stdlib/stdio.nx"

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
  try
    Console.eprintln(val: "hello")
    if 1 == 1 then
      raise RuntimeError(val: "boom")
    end
    return ()
  catch e ->
    Console.eprintln(val: "caught")
  end
  end
end
