import { SymbolKind,
         symbol_kind_to_i64, i64_to_symbol_kind,
         rename, rename_add, rename_has,
         scope_new, scope_push, scope_pop, scope_depth,
         symtab_new, symtab_free,
         define_value, lookup_value,
         define_type, lookup_type,
         define_port, lookup_port,
         define_constructor, lookup_constructor,
         define_exception } from "nxc/ir/symtab.nx"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let assert_none = fn (opt: Option<SymbolKind>, msg: string) -> unit throws { Exn } do
  match opt do
    case None -> return ()
    case Some(val: _) -> raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  // ── RenameMap ───────────────────────────────────────────────────────
  let entries = Nil
  let entries = rename_add(entries: entries, original: "foo", qualified: "mod.foo")
  let entries = rename_add(entries: entries, original: "bar", qualified: "mod.bar")

  assert(cond: rename(name: "foo", entries: entries) == "mod.foo",
         msg: "rename: foo -> mod.foo")
  assert(cond: rename(name: "bar", entries: entries) == "mod.bar",
         msg: "rename: bar -> mod.bar")
  assert(cond: rename(name: "baz", entries: entries) == "baz",
         msg: "rename: baz returns original")
  assert(cond: rename_has(name: "foo", entries: entries),
         msg: "rename_has: foo exists")
  assert(cond: rename_has(name: "baz", entries: entries) == false,
         msg: "rename_has: baz missing")

  // ── SymbolKind encoding ─────────────────────────────────────────────
  assert(cond: symbol_kind_to_i64(kind: SkFunction) == 0, msg: "SkFunction -> 0")
  assert(cond: symbol_kind_to_i64(kind: SkVariable) == 1, msg: "SkVariable -> 1")
  assert(cond: symbol_kind_to_i64(kind: SkExternal) == 2, msg: "SkExternal -> 2")
  assert(cond: symbol_kind_to_i64(kind: SkConstructor) == 3, msg: "SkConstructor -> 3")
  assert(cond: symbol_kind_to_i64(kind: SkPort) == 4, msg: "SkPort -> 4")
  assert(cond: symbol_kind_to_i64(kind: SkType) == 5, msg: "SkType -> 5")
  assert(cond: symbol_kind_to_i64(kind: SkException) == 6, msg: "SkException -> 6")

  // Round-trip
  match i64_to_symbol_kind(tag: 3) do
    case SkConstructor -> assert(cond: true, msg: "round-trip 3 = SkConstructor")
    case _ -> raise RuntimeError(val: "round-trip 3 should be SkConstructor")
  end

  // ── ScopeState ──────────────────────────────────────────────────────
  let s0 = scope_new()
  assert(cond: scope_depth(state: s0) == 1, msg: "initial depth = 1")

  let s1 = scope_push(state: s0)
  assert(cond: scope_depth(state: s1) == 2, msg: "after push depth = 2")

  let s2 = scope_push(state: s1)
  assert(cond: scope_depth(state: s2) == 3, msg: "after 2nd push depth = 3")

  let s1b = scope_pop(state: s2)
  assert(cond: scope_depth(state: s1b) == 2, msg: "after pop depth = 2")

  // ── Symbol table: define and lookup ─────────────────────────────────
  let %tab = symtab_new()
  let scope = scope_new()

  // Define in global scope
  let %tab = define_value(tab: %tab, state: scope, name: "x", kind: SkVariable)
  let %tab = define_value(tab: %tab, state: scope, name: "my_func", kind: SkFunction)
  let %tab = define_type(tab: %tab, state: scope, name: "MyRecord")
  let %tab = define_port(tab: %tab, state: scope, name: "Console")
  let %tab = define_constructor(tab: %tab, state: scope, name: "Some")
  let %tab = define_exception(tab: %tab, state: scope, name: "IoError")

  // Lookup correct namespace
  match lookup_value(tab: &%tab, state: scope, name: "x") do
    case Some(val: k) ->
      assert(cond: symbol_kind_to_i64(kind: k) == 1, msg: "x is SkVariable")
    case None -> raise RuntimeError(val: "x should be in values")
  end

  match lookup_value(tab: &%tab, state: scope, name: "my_func") do
    case Some(val: k) ->
      assert(cond: symbol_kind_to_i64(kind: k) == 0, msg: "my_func is SkFunction")
    case None -> raise RuntimeError(val: "my_func should be in values")
  end

  match lookup_type(tab: &%tab, state: scope, name: "MyRecord") do
    case Some(val: k) ->
      assert(cond: symbol_kind_to_i64(kind: k) == 5, msg: "MyRecord is SkType")
    case None -> raise RuntimeError(val: "MyRecord should be in types")
  end

  match lookup_port(tab: &%tab, state: scope, name: "Console") do
    case Some(val: k) ->
      assert(cond: symbol_kind_to_i64(kind: k) == 4, msg: "Console is SkPort")
    case None -> raise RuntimeError(val: "Console should be in ports")
  end

  match lookup_constructor(tab: &%tab, state: scope, name: "Some") do
    case Some(val: k) ->
      assert(cond: symbol_kind_to_i64(kind: k) == 3, msg: "Some is SkConstructor")
    case None -> raise RuntimeError(val: "Some should be in constructors")
  end

  match lookup_type(tab: &%tab, state: scope, name: "IoError") do
    case Some(val: k) ->
      assert(cond: symbol_kind_to_i64(kind: k) == 6, msg: "IoError is SkException")
    case None -> raise RuntimeError(val: "IoError should be in types")
  end

  // Cross-namespace isolation
  assert_none(opt: lookup_type(tab: &%tab, state: scope, name: "x"),
              msg: "x should not be in type namespace")
  assert_none(opt: lookup_value(tab: &%tab, state: scope, name: "MyRecord"),
              msg: "MyRecord should not be in value namespace")
  assert_none(opt: lookup_port(tab: &%tab, state: scope, name: "x"),
              msg: "x should not be in port namespace")

  // ── Scope nesting ───────────────────────────────────────────────────
  let inner = scope_push(state: scope)
  let %tab = define_value(tab: %tab, state: inner, name: "y", kind: SkVariable)

  // y visible from inner scope
  match lookup_value(tab: &%tab, state: inner, name: "y") do
    case Some(val: _) -> assert(cond: true, msg: "y visible in inner scope")
    case None -> raise RuntimeError(val: "y should be visible in inner scope")
  end

  // x (outer) visible from inner scope
  match lookup_value(tab: &%tab, state: inner, name: "x") do
    case Some(val: _) -> assert(cond: true, msg: "x visible from inner scope")
    case None -> raise RuntimeError(val: "x should be visible from inner scope")
  end

  // y NOT visible from outer scope
  assert_none(opt: lookup_value(tab: &%tab, state: scope, name: "y"),
              msg: "y should not leak to outer scope")

  // ── Shadowing ───────────────────────────────────────────────────────
  let %tab = define_value(tab: %tab, state: inner, name: "x", kind: SkFunction)

  // Inner scope sees shadowed x (SkFunction)
  match lookup_value(tab: &%tab, state: inner, name: "x") do
    case Some(val: k) ->
      assert(cond: symbol_kind_to_i64(kind: k) == 0, msg: "inner x = SkFunction (shadowed)")
    case None -> raise RuntimeError(val: "inner x should be found")
  end

  // Outer scope still sees original x (SkVariable)
  match lookup_value(tab: &%tab, state: scope, name: "x") do
    case Some(val: k) ->
      assert(cond: symbol_kind_to_i64(kind: k) == 1, msg: "outer x = SkVariable (unshadowed)")
    case None -> raise RuntimeError(val: "outer x should be found")
  end

  symtab_free(tab: %tab)
  return ()
end
