/// Regression: Nexus-level wrapper functions (Let with Lambda, not FFI
/// externals) must survive reachability filtering and be emitted into
/// program.functions with their canonical name after Step 4 canonical
/// naming. bytebuffer.copy_range is such a wrapper over
/// __nx_copy_range.

import * as buf from "stdlib/bytebuffer.nx"

let main = fn () -> unit throws { Exn } do
  let %b = buf.empty()
  let %b2 = buf.push_byte(buf: %b, byte: 65)
  let %b3 = buf.push_byte(buf: %b2, byte: 66)
  let %b4 = buf.empty()
  let %b5 = buf.copy_range(dst: %b4, src: &b3, start: 0, end_pos: 2)
  buf.free(buf: %b5)
  buf.free(buf: %b3)
  return ()
end
