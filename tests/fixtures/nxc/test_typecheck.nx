// Tests for nxc/typecheck — substitution, type equality, occurs check, unification.
import { TypeExpr, NamedType } from nxc/common/ast.nx
import { SubstEntry, Scheme, FreshResult, UnifyResult, UnifyOk, UnifyErr,
         CheckState, tc_fresh_var, tc_new_state, mono } from nxc/typecheck/types.nx
import { subst_apply, subst_compose, subst_empty, subst_single,
         occurs_check, type_eq } from nxc/typecheck/subst.nx
import { unify } from nxc/typecheck/unify.nx

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  // ── subst_apply ─────────────────────────────────────────────────────
  let s = subst_single(var: "a", typ: TyI64)
  assert(cond: type_eq(a: subst_apply(subst: s, typ: TyVar(name: "a")), b: TyI64),
         msg: "subst: a -> i64")
  assert(cond: type_eq(a: subst_apply(subst: s, typ: TyVar(name: "b")), b: TyVar(name: "b")),
         msg: "subst: b unchanged")
  assert(cond: type_eq(a: subst_apply(subst: s, typ: TyI32), b: TyI32),
         msg: "subst: i32 unchanged")

  // Substitution in compound types
  let arrow = TyArrow(
    params: Cons(v: NamedType(name: "x", typ: TyVar(name: "a")), rest: Nil),
    ret: TyVar(name: "a"),
    requires: TyRow(types: Nil, rest: None),
    throw_row: TyRow(types: Nil, rest: None)
  )
  let substed = subst_apply(subst: s, typ: arrow)
  match substed
    case TyArrow(params: ps, ret: r, requires: _, throw_row: _) ->
      assert(cond: type_eq(a: r, b: TyI64), msg: "subst: arrow ret -> i64")
      match ps
        case NamedType(name: _, typ: pt) :: Nil ->
          assert(cond: type_eq(a: pt, b: TyI64), msg: "subst: arrow param -> i64")
        case _ -> raise RuntimeError(val: "expected 1 param")
      end
    case _ -> raise RuntimeError(val: "expected arrow")
  end

  // ── subst_compose ───────────────────────────────────────────────────
  let s1 = subst_single(var: "a", typ: TyVar(name: "b"))
  let s2 = subst_single(var: "b", typ: TyI64)
  let composed = subst_compose(s1: s1, s2: s2)
  assert(cond: type_eq(a: subst_apply(subst: composed, typ: TyVar(name: "a")), b: TyI64),
         msg: "compose: a -> i64 (transitive)")
  assert(cond: type_eq(a: subst_apply(subst: composed, typ: TyVar(name: "b")), b: TyI64),
         msg: "compose: b -> i64")

  // ── occurs_check ────────────────────────────────────────────────────
  assert(cond: occurs_check(var: "a", typ: TyVar(name: "a")),
         msg: "occurs: a in Var(a)")
  assert(cond: occurs_check(var: "a", typ: TyVar(name: "b")) == false,
         msg: "occurs: a not in Var(b)")
  assert(cond: occurs_check(var: "a", typ: TyList(elem: TyVar(name: "a"))),
         msg: "occurs: a in List(a)")
  assert(cond: occurs_check(var: "a", typ: TyI64) == false,
         msg: "occurs: a not in i64")

  // ── type_eq ─────────────────────────────────────────────────────────
  assert(cond: type_eq(a: TyI64, b: TyI64), msg: "eq: i64 == i64")
  assert(cond: type_eq(a: TyI64, b: TyI32) == false, msg: "eq: i64 != i32")
  assert(cond: type_eq(a: TyVar(name: "a"), b: TyVar(name: "a")), msg: "eq: var a == var a")
  assert(cond: type_eq(a: TyVar(name: "a"), b: TyVar(name: "b")) == false, msg: "eq: var a != var b")
  assert(cond: type_eq(a: TyList(elem: TyI64), b: TyList(elem: TyI64)), msg: "eq: List<i64>")
  assert(cond: type_eq(a: TyList(elem: TyI64), b: TyList(elem: TyI32)) == false, msg: "eq: List<i64> != List<i32>")

  // ── unify ───────────────────────────────────────────────────────────
  let no_tdefs = Nil

  // Same types
  let r1 = unify(t1: TyI64, t2: TyI64, tdefs: no_tdefs)
  match r1
    case UnifyOk(subst: _) -> assert(cond: true, msg: "unify: i64 ~ i64")
    case UnifyErr(message: m) -> raise RuntimeError(val: "unify i64~i64 failed: " ++ m)
  end

  // Variable unification
  let r2 = unify(t1: TyVar(name: "a"), t2: TyI64, tdefs: no_tdefs)
  match r2
    case UnifyOk(subst: s_) ->
      assert(cond: type_eq(a: subst_apply(subst: s_, typ: TyVar(name: "a")), b: TyI64),
             msg: "unify: Var(a) ~ i64 => a=i64")
    case UnifyErr(message: m) -> raise RuntimeError(val: "unify var~i64 failed: " ++ m)
  end

  // Numeric flex
  let r3 = unify(t1: TyIntLit, t2: TyI64, tdefs: no_tdefs)
  match r3
    case UnifyOk(subst: _) -> assert(cond: true, msg: "unify: IntLit ~ i64")
    case UnifyErr(message: m) -> raise RuntimeError(val: "unify IntLit~i64 failed: " ++ m)
  end

  let r3b = unify(t1: TyIntLit, t2: TyI32, tdefs: no_tdefs)
  match r3b
    case UnifyOk(subst: _) -> assert(cond: true, msg: "unify: IntLit ~ i32")
    case UnifyErr(message: m) -> raise RuntimeError(val: "unify IntLit~i32 failed: " ++ m)
  end

  // Mismatch
  let r4 = unify(t1: TyI64, t2: TyString, tdefs: no_tdefs)
  match r4
    case UnifyErr(message: _) -> assert(cond: true, msg: "unify: i64 !~ string")
    case UnifyOk(subst: _) -> raise RuntimeError(val: "unify i64~string should fail")
  end

  // Occurs check
  let r5 = unify(t1: TyVar(name: "a"), t2: TyList(elem: TyVar(name: "a")), tdefs: no_tdefs)
  match r5
    case UnifyErr(message: _) -> assert(cond: true, msg: "unify: occurs check")
    case UnifyOk(subst: _) -> raise RuntimeError(val: "unify should fail on occurs")
  end

  // List unification
  let r6 = unify(t1: TyList(elem: TyVar(name: "x")), t2: TyList(elem: TyI64), tdefs: no_tdefs)
  match r6
    case UnifyOk(subst: s_) ->
      assert(cond: type_eq(a: subst_apply(subst: s_, typ: TyVar(name: "x")), b: TyI64),
             msg: "unify: List<x> ~ List<i64> => x=i64")
    case UnifyErr(message: m) -> raise RuntimeError(val: "unify list failed: " ++ m)
  end

  // Arrow unification
  let arr1 = TyArrow(
    params: Cons(v: NamedType(name: "x", typ: TyVar(name: "a")), rest: Nil),
    ret: TyVar(name: "b"),
    requires: TyRow(types: Nil, rest: None),
    throw_row: TyRow(types: Nil, rest: None)
  )
  let arr2 = TyArrow(
    params: Cons(v: NamedType(name: "x", typ: TyI64), rest: Nil),
    ret: TyString,
    requires: TyRow(types: Nil, rest: None),
    throw_row: TyRow(types: Nil, rest: None)
  )
  let r7 = unify(t1: arr1, t2: arr2, tdefs: no_tdefs)
  match r7
    case UnifyOk(subst: s_) ->
      assert(cond: type_eq(a: subst_apply(subst: s_, typ: TyVar(name: "a")), b: TyI64),
             msg: "unify: arrow param a=i64")
      assert(cond: type_eq(a: subst_apply(subst: s_, typ: TyVar(name: "b")), b: TyString),
             msg: "unify: arrow ret b=string")
    case UnifyErr(message: m) -> raise RuntimeError(val: "unify arrow failed: " ++ m)
  end

  // Borrow transparency
  let r8 = unify(t1: TyBorrow(inner: TyI64), t2: TyI64, tdefs: no_tdefs)
  match r8
    case UnifyOk(subst: _) -> assert(cond: true, msg: "unify: &i64 ~ i64")
    case UnifyErr(message: m) -> raise RuntimeError(val: "unify borrow failed: " ++ m)
  end

  // ── tc_fresh_var ───────────────────────────────────────────────────
  let state = tc_new_state(enum_defs: Nil, type_defs: Nil)
  let fr = tc_fresh_var(state: state)
  match fr
    case FreshResult(state: st2, typ: t) ->
      match t
        case TyVar(name: n) -> assert(cond: n == "?0", msg: "fresh_var: name is ?0")
        case _ -> raise RuntimeError(val: "fresh_var: expected TyVar")
      end
      // Second fresh var should be ?1
      let fr2 = tc_fresh_var(state: st2)
      match fr2
        case FreshResult(state: _, typ: t2) ->
          match t2
            case TyVar(name: n2) -> assert(cond: n2 == "?1", msg: "fresh_var: second is ?1")
            case _ -> raise RuntimeError(val: "fresh_var: expected TyVar for second")
          end
      end
  end

  return ()
end
