import { MirProgram, MirFunction, MirStmt, MirExpr } from "nxc/ir/mir_types.nx"
import { LirProgram } from "nxc/ir/lir_types.nx"
import { lower_mir_to_lir } from "nxc/ir/lir.nx"
import { Span } from "nxc/common/token.nx"
import { Literal, TypeExpr } from "nxc/common/ast.nx"

let main = fn () -> unit throws { Exn } do
  let func = MirFunction(
    name: "test",
    params: Nil,
    ret_type: TyUnit,
    body: Cons(v: MirStmtReturn(expr: MirLiteral(lit: LitUnit)), rest: Nil),
    span: Span(offset: 0, line: 0, col: 0)
  )
  let mir = MirProgram(functions: Cons(v: func, rest: Nil), externals: Nil)
  let lir = lower_mir_to_lir(mir: mir, enum_defs: Nil)
  return ()
end
