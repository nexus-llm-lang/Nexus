import as char from stdlib/char.nx

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then
    return ()
  else
    raise RuntimeError(val: msg)
  end
end

let assert_not = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then
    raise RuntimeError(val: msg)
  else
    return ()
  end
end

let main = fn () -> unit throws { Exn } do
  // is_alpha
  assert(cond: char.is_alpha(c: 'a'), msg: "a should be alpha")
  assert(cond: char.is_alpha(c: 'Z'), msg: "Z should be alpha")
  assert_not(cond: char.is_alpha(c: '0'), msg: "0 should not be alpha")

  // is_digit
  assert(cond: char.is_digit(c: '0'), msg: "0 should be digit")
  assert(cond: char.is_digit(c: '9'), msg: "9 should be digit")
  assert_not(cond: char.is_digit(c: 'a'), msg: "a should not be digit")

  // is_whitespace
  assert(cond: char.is_whitespace(c: ' '), msg: "space should be whitespace")
  assert_not(cond: char.is_whitespace(c: 'a'), msg: "a should not be whitespace")

  // is_upper / is_lower
  assert(cond: char.is_upper(c: 'Z'), msg: "Z should be upper")
  assert(cond: char.is_lower(c: 'a'), msg: "a should be lower")
  assert_not(cond: char.is_upper(c: 'a'), msg: "a should not be upper")

  // is_ident_start / is_ident_char
  assert(cond: char.is_ident_start(c: '_'), msg: "_ should be ident start")
  assert(cond: char.is_ident_start(c: 'a'), msg: "a should be ident start")
  assert_not(cond: char.is_ident_start(c: '0'), msg: "0 should not be ident start")
  assert(cond: char.is_ident_char(c: '_'), msg: "_ should be ident char")
  assert(cond: char.is_ident_char(c: '0'), msg: "0 should be ident char")
  assert_not(cond: char.is_ident_char(c: ' '), msg: "space should not be ident char")

  // is_hex_digit
  assert(cond: char.is_hex_digit(c: 'a'), msg: "a should be hex digit")
  assert(cond: char.is_hex_digit(c: 'F'), msg: "F should be hex digit")
  assert(cond: char.is_hex_digit(c: '0'), msg: "0 should be hex digit")

  // digit_value
  assert(cond: char.digit_value(c: '0') == 0, msg: "digit_value 0")
  assert(cond: char.digit_value(c: '9') == 9, msg: "digit_value 9")

  // hex_digit_value
  assert(cond: char.hex_digit_value(c: 'a') == 10, msg: "hex a == 10")
  assert(cond: char.hex_digit_value(c: 'F') == 15, msg: "hex F == 15")
  assert(cond: char.hex_digit_value(c: '0') == 0, msg: "hex 0 == 0")

  // ord
  assert(cond: char.ord(c: 'A') == 65, msg: "ord A == 65")
  assert(cond: char.ord(c: '0') == 48, msg: "ord 0 == 48")

  return ()
end
