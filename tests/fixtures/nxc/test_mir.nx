import { Span } from "nxc/common/token.nx"
import { Literal, TypeExpr, Sigil, BinaryOp, EnumDef } from "nxc/common/ast.nx"
import { HirExpr, HirStmt, HirCallArg, HirParam, HirFunction,
         HirPort, HirPortMethod, HirExternal, HirHandlerBinding,
         HirHandlerBindingEntry, HirProgram, HirMatchCase, HirPattern,
         HirNamedExpr } from "nxc/ir/hir_types.nx"
import { MirProgram, MirFunction, MirExpr, MirStmt, MirMatchCase, MirPattern } from "nxc/ir/mir_types.nx"
import { lower_hir_to_mir } from "nxc/ir/mir.nx"

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let dummy_span = fn () -> Span do return Span(offset: 0, line: 0, col: 0) end

// ─── Test 1: Basic lowering ─────────────────────────────────────────────────

let test_basic = fn () -> unit throws { Exn } do
  let body = Cons(
    v: HirStmtReturn(expr: HirLiteral(lit: LitInt(val: 42))),
    rest: Nil
  )
  let func = HirFunction(name: "main", params: Nil, ret_type: TyUnit,
    body: body, span: dummy_span())
  let hir = HirProgram(
    ports: Nil, functions: Cons(v: func, rest: Nil),
    externals: Nil, handler_bindings: Nil, enum_defs: Nil
  )
  let mir = lower_hir_to_mir(hir: hir)
  match mir do case MirProgram(functions: fs, externals: _) ->
    match fs do case f :: _ ->
      match f do case MirFunction(name: n, params: _, ret_type: _, body: _, span: _) ->
        assert(cond: n == "main", msg: "basic: function name is main")
      end
    case Nil -> raise RuntimeError(val: "basic: no functions")
    end
  end
end

// ─── Test 2: Port call resolution ───────────────────────────────────────────

let test_port_call = fn () -> unit throws { Exn } do
  // Build: port Console { print }
  let console_port = HirPort(name: "Console",
    methods: Cons(v: HirPortMethod(name: "print"), rest: Nil))
  // Build: handler function __handler_myHandler_print
  let handler_fn = HirFunction(
    name: "__handler_myHandler_print",
    params: Cons(v: HirParam(name: "msg", label: "msg", typ: TyString), rest: Nil),
    ret_type: TyUnit,
    body: Cons(v: HirStmtReturn(expr: HirLiteral(lit: LitUnit)), rest: Nil),
    span: dummy_span()
  )
  // Build: main function that calls Console.print
  let main_body = Cons(
    v: HirStmtExpr(expr: HirCall(
      func: "Console.print",
      args: Cons(v: HirCallArg(label: "msg", value: HirLiteral(lit: LitString(val: "hello"))), rest: Nil)
    )),
    rest: Cons(
      v: HirStmtReturn(expr: HirLiteral(lit: LitUnit)),
      rest: Nil
    )
  )
  let main_fn = HirFunction(name: "main", params: Nil, ret_type: TyUnit,
    body: main_body, span: dummy_span())
  // Handler binding entry
  let binding = HirHandlerBinding(port_name: "Console",
    functions: Cons(v: handler_fn, rest: Nil))
  let binding_entry = HirHandlerBindingEntry(name: "myHandler", binding: binding)
  let hir = HirProgram(
    ports: Cons(v: console_port, rest: Nil),
    functions: Cons(v: main_fn, rest: Cons(v: handler_fn, rest: Nil)),
    externals: Nil,
    handler_bindings: Cons(v: binding_entry, rest: Nil),
    enum_defs: Nil
  )
  let mir = lower_hir_to_mir(hir: hir)
  // Verify the port call got resolved to the handler function
  match mir do case MirProgram(functions: fs, externals: _) ->
    // Find main function and check its body has the resolved call
    match fs do
      case f :: _ ->
        match f do case MirFunction(name: n, params: _, ret_type: _, body: _, span: _) ->
          // The functions list should contain our functions
          assert(cond: true, msg: "port_call: MIR program created successfully")
        end
      case Nil -> raise RuntimeError(val: "port_call: no functions")
    end
  end
end

// ─── Test 3: Lambda lowered to unit ─────────────────────────────────────────

let test_lambda_unit = fn () -> unit throws { Exn } do
  // Build: let f = fn (x) -> x end (lambda should be lowered to Unit in MIR)
  let lambda = HirLambda(
    params: Cons(v: HirParam(name: "x", label: "x", typ: TyInt), rest: Nil),
    ret_type: TyInt,
    body: Cons(v: HirStmtReturn(expr: HirVariable(name: "x", sigil: SigilImmutable)), rest: Nil)
  )
  let main_body = Cons(
    v: HirStmtLet(name: "f", typ: None, value: lambda),
    rest: Cons(
      v: HirStmtReturn(expr: HirLiteral(lit: LitUnit)),
      rest: Nil
    )
  )
  let main_fn = HirFunction(name: "main", params: Nil, ret_type: TyUnit,
    body: main_body, span: dummy_span())
  let hir = HirProgram(
    ports: Nil, functions: Cons(v: main_fn, rest: Nil),
    externals: Nil, handler_bindings: Nil, enum_defs: Nil
  )
  let mir = lower_hir_to_mir(hir: hir)
  match mir do case MirProgram(functions: fs, externals: _) ->
    match fs do case f :: _ ->
      match f do case MirFunction(name: _, params: _, ret_type: _, body: stmts, span: _) ->
        // Check that the body has a let statement (lambda lowered to something)
        match stmts do
          case s :: _ ->
            match s do
              case MirStmtLet(name: n, typ: _, expr: e) ->
                assert(cond: n == "f", msg: "lambda: let name is f")
                // Lambda should be lowered to a literal Unit
                match e do
                  case MirLiteral(lit: l) ->
                    match l do
                      case LitUnit -> assert(cond: true, msg: "lambda: lowered to unit")
                      case _ -> raise RuntimeError(val: "lambda: expected LitUnit")
                    end
                  case _ -> raise RuntimeError(val: "lambda: expected literal")
                end
              case _ -> raise RuntimeError(val: "lambda: expected let stmt")
            end
          case Nil -> raise RuntimeError(val: "lambda: empty body")
        end
      end
    case Nil -> raise RuntimeError(val: "lambda: no functions")
    end
  end
end

let main = fn () -> unit throws { Exn } do
  test_basic()
  test_port_call()
  test_lambda_unit()
end
