import { LirProgram, LirFunction, LirStmt, LirExpr, LirAtom, LirParam,
         LirExternal, LirCallArg, LirNamedAtom } from "nxc/ir/lir_types.nx"
import { compile_lir_to_wasm } from "nxc/backend/codegen.nx"
import { ByteBuffer, buf_empty, length, buf_free, push_byte } from "stdlib/bytebuffer.nx"
import { BinaryOp } from "nxc/common/ast.nx"
import { Span } from "nxc/common/token.nx"

let main = fn () -> unit do
  let sp = Span(offset: 0, line: 0, col: 0)
  let body = Cons(v:
    LirStmtLet(
      name: "x", typ: TyI64,
      expr: LirExprAtom(atom: LirAtomInt(val: 42))
    ), rest: Nil)
  let func = LirFunction(
    name: "main", params: Nil, ret_type: TyI64,
    body: body, ret: LirAtomVar(name: "x", typ: TyI64), span: sp
  )
  let prog = LirProgram(functions: Cons(v: func, rest: Nil), externals: Nil)
  let %wasm = compile_lir_to_wasm(program: prog, string_data_base: 0)
  // Call length — this returns 0 if tag is corrupted
  let wasm_len = length(buf: &wasm)
  // Store wasm_len in a variable to force evaluation but don't div by it
  buf_free(buf: %wasm)
  // Now return wasm_len disguised as unit — impossible in Nexus type system
  // Instead, let's just put 100 / (wasm_len + 1) to avoid div-by-zero trap
  // and check wasm_len value by its effect
  return ()
end
