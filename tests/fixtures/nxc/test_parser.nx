import { Token, Span, SpannedToken } from nxc/common/token.nx
import { Sigil, BinaryOp, Literal, TypeExpr, Pattern, Expr, Stmt,
         SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel,
         Param, Function, MatchCase, CallArg, CtorArg, NamedExpr,
         NamedType, VariantField, CtorPatternField, RecordPatField,
         VariantDef, EnumDef, RecordDef, ExceptionDef, ImportDef,
         FunctionSig, Port, GlobalLet, TopLevel, Program } from nxc/common/ast.nx
import { tokenize } from nxc/frontend/lexer.nx
import { parse } from nxc/frontend/parser.nx
let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  // ── Test 1: Parse a simple let + main function ───────────────────────
  let src1 = "let main = fn () -> unit do\n  return ()\nend\n"
  let tokens1 = tokenize(src: src1)
  let prog1 = parse(tokens: tokens1)

  match prog1 do
    case Program(definitions: defs) ->
      // Should have exactly one top-level definition (a global let)
      match defs do
        case Cons(v: first, rest: Nil) ->
          match first do
            case SpannedTopLevel(node: n, span: _) ->
              match n do
                case TLLet(def: d) ->
                  match d do
                    case GlobalLet(name: nm, is_public: _, typ: _, value: _) ->
                      assert(cond: nm == "main", msg: "expected global let named main")
                  end
                case _ -> raise RuntimeError(val: "expected TLLet")
              end
          end
        case _ -> raise RuntimeError(val: "expected exactly 1 top-level def")
      end
  end

  // ── Test 2: Parse import statement ───────────────────────────────────
  let src2 = "import { foo } from bar/baz.nx\nlet main = fn () -> unit do\n  return ()\nend\n"
  let tokens2 = tokenize(src: src2)
  let prog2 = parse(tokens: tokens2)

  match prog2 do
    case Program(definitions: defs) ->
      match defs do
        case Cons(v: first, rest: Cons(v: _, rest: Nil)) ->
          match first do
            case SpannedTopLevel(node: n, span: _) ->
              match n do
                case TLImport(def: d) ->
                  match d do
                    case ImportDef(path: p, alias: _, items: itms, is_external: _) ->
                      assert(cond: p == "bar/baz.nx", msg: "expected import path bar/baz.nx")
                      match itms do
                        case Cons(v: item, rest: Nil) ->
                          assert(cond: item == "foo", msg: "expected import item foo")
                        case _ -> raise RuntimeError(val: "expected 1 import item")
                      end
                  end
                case _ -> raise RuntimeError(val: "expected TLImport")
              end
          end
        case _ -> raise RuntimeError(val: "expected 2 top-level defs")
      end
  end

  // ── Test 3: Parse enum definition ────────────────────────────────────
  let src3 = "export type Color = Red | Green | Blue\nlet main = fn () -> unit do\n  return ()\nend\n"
  let tokens3 = tokenize(src: src3)
  let prog3 = parse(tokens: tokens3)

  match prog3 do
    case Program(definitions: defs) ->
      match defs do
        case Cons(v: first, rest: _) ->
          match first do
            case SpannedTopLevel(node: n, span: _) ->
              match n do
                case TLEnum(def: d) ->
                  match d do
                    case EnumDef(name: nm, is_public: pub_flag, is_opaque: _, type_params: _, variants: vs) ->
                      assert(cond: nm == "Color", msg: "expected enum named Color")
                      assert(cond: pub_flag, msg: "expected enum to be public")
                      // Check first variant is Red
                      match vs do
                        case Cons(v: v1, rest: Cons(v: v2, rest: Cons(v: v3, rest: Nil))) ->
                          match v1 do case VariantDef(name: n1, fields: _) -> assert(cond: n1 == "Red", msg: "expected Red") end
                          match v2 do case VariantDef(name: n2, fields: _) -> assert(cond: n2 == "Green", msg: "expected Green") end
                          match v3 do case VariantDef(name: n3, fields: _) -> assert(cond: n3 == "Blue", msg: "expected Blue") end
                        case _ -> raise RuntimeError(val: "expected 3 variants")
                      end
                  end
                case _ -> raise RuntimeError(val: "expected TLEnum")
              end
          end
        case _ -> raise RuntimeError(val: "expected defs")
      end
  end

  // ── Test 4: Parse binary expression ──────────────────────────────────
  let src4 = "let main = fn () -> unit do\n  let x = 1 + 2\n  return ()\nend\n"
  let tokens4 = tokenize(src: src4)
  let prog4 = parse(tokens: tokens4)

  match prog4 do
    case Program(definitions: defs) ->
      match defs do
        case Cons(v: first, rest: Nil) ->
          match first do
            case SpannedTopLevel(node: n, span: _) ->
              match n do
                case TLLet(def: d) ->
                  match d do
                    case GlobalLet(name: _, is_public: _, typ: _, value: val_expr) ->
                      // The value is a lambda expression (fn () -> unit do ... end)
                      match val_expr do
                        case SpannedExpr(node: body_expr, span: _) ->
                          match body_expr do
                            case ExprLambda(params: _, ret_type: _, requires: _, throw_row: _, body: stmts) ->
                              // First statement should be let x = 1 + 2
                              match stmts do
                                case Cons(v: s1, rest: _) ->
                                  match s1 do
                                    case SpannedStmt(node: sn, span: _) ->
                                      match sn do
                                        case StmtLet(name: nm, sigil: _, typ: _, value: rhs) ->
                                          assert(cond: nm == "x", msg: "expected let x")
                                          match rhs do
                                            case SpannedExpr(node: rhs_node, span: _) ->
                                              match rhs_node do
                                                case ExprBinaryOp(left: _, op: op_val, right: _) ->
                                                  match op_val do
                                                    case OpAdd -> ()
                                                    case _ -> raise RuntimeError(val: "expected OpAdd")
                                                  end
                                                case _ -> raise RuntimeError(val: "expected ExprBinaryOp")
                                              end
                                          end
                                        case _ -> raise RuntimeError(val: "expected StmtLet")
                                      end
                                  end
                                case _ -> raise RuntimeError(val: "expected stmts")
                              end
                            case _ -> raise RuntimeError(val: "expected ExprLambda")
                          end
                      end
                  end
                case _ -> raise RuntimeError(val: "expected TLLet")
              end
          end
        case _ -> raise RuntimeError(val: "expected 1 def")
      end
  end

  // ── Test 5: Parse match expression ───────────────────────────────────
  let src5 = "let main = fn () -> unit do\n  let x = 1\n  match x do\n    case 0 -> ()\n    case _ -> ()\n  end\n  return ()\nend\n"
  let tokens5 = tokenize(src: src5)
  let prog5 = parse(tokens: tokens5)

  // If we got here without a runtime error, parsing succeeded
  match prog5 do
    case Program(definitions: _) -> ()
  end

  // ── Test 6: Parse if expression ──────────────────────────────────────
  let src6 = "let main = fn () -> unit do\n  if true then return ()\n  else return ()\n  end\nend\n"
  let tokens6 = tokenize(src: src6)
  let prog6 = parse(tokens: tokens6)

  match prog6 do
    case Program(definitions: _) -> ()
  end

  // ── Test 7: Parse function with params and type annotation ───────────
  let src7 = "let add = fn (a: i64, b: i64) -> i64 do\n  return a + b\nend\nlet main = fn () -> unit do\n  return ()\nend\n"
  let tokens7 = tokenize(src: src7)
  let prog7 = parse(tokens: tokens7)

  match prog7 do
    case Program(definitions: defs) ->
      match defs do
        case Cons(v: first, rest: _) ->
          match first do
            case SpannedTopLevel(node: n, span: _) ->
              match n do
                case TLLet(def: d) ->
                  match d do
                    case GlobalLet(name: nm, is_public: _, typ: _, value: _) ->
                      assert(cond: nm == "add", msg: "expected global let named add")
                  end
                case _ -> raise RuntimeError(val: "expected TLLet for add")
              end
          end
        case _ -> raise RuntimeError(val: "expected defs")
      end
  end

  return ()
end
