import { MirProgram, MirFunction, MirStmt, MirExpr, MirParam } from nxc/ir/mir_types.nx
import { LirProgram, LirFunction } from nxc/ir/lir_types.nx
import { lower_mir_to_lir } from nxc/ir/lir.nx
import { Span } from nxc/common/token.nx

let main = fn () -> unit throws { Exn } do
  // Task body = [let y = 99] — no free vars, but body is non-empty
  let mir = MirProgram(
    functions: Cons(
      v: MirFunction(
        name: "main", params: Nil, ret_type: TyUnit,
        body: Cons(
          v: MirStmtConc(tasks: Cons(
            v: MirFunction(name: "t1", params: Nil, ret_type: TyUnit,
              body: Cons(
                v: MirStmtLet(name: "y", typ: TyI64, expr: MirLiteral(lit: LitInt(val: 99))),
                rest: Nil),
              span: Span(offset: 0, line: 0, col: 0)),
            rest: Nil)),
          rest: Nil),
        span: Span(offset: 0, line: 0, col: 0)),
      rest: Nil),
    externals: Nil)
  let lir = lower_mir_to_lir(mir: mir, enum_defs: Nil)
  match lir case LirProgram(functions: _, externals: _) -> return () end
end
