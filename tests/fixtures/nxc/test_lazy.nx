/**
 * test_lazy: Verify the nxc compiler can parse and compile @ lazy syntax.
 *
 * NOTE: The nxc codegen emits LirExprForce as pass-through (no call_indirect).
 * This test verifies parsing + IR propagation only.
 * Full lazy thunk execution requires closure/call_indirect support in nxc codegen.
 */

import { Console }, * as stdio from "stdlib/stdio.nx"

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    // Basic lazy binding and force
    let @x = 42
    let v = @x

    // Lazy with captured variable
    let y = 10
    let @z = y + 1
    let w = @z

    // Force on parenthesized expression
    let a = @(y + 2)

    Console.println(val: "lazy test passed")
    return ()
  end
end
