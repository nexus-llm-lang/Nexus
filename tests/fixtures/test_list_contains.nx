
    import as list from stdlib/list.nx
    let main = fn () -> i64 do
      let xs = Cons(v: 1, rest: Cons(v: 2, rest: Cons(v: 3, rest: Nil())))
      let a = list.contains(xs: xs, val: 2)
      let b = list.contains(xs: xs, val: 5)
      if a then
        if b then return 0 else return 1 end
      else
        return 0
      end
    end
    