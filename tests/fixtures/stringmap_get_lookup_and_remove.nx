import * as smap from "stdlib/stringmap.nx"

let main = fn () -> unit do
  let m0 = smap.empty()
  let m1 = smap.put(map: m0, key: "alpha", value: 70)
  let m2 = smap.put(map: m1, key: "beta", value: 80)
  let got = smap.get(map: &m2, key: "alpha")
  let m3 = smap.remove(map: m2, key: "beta")
  let sz = smap.size(map: &m3)
  smap.free(map: m3)
  match got do
    case Found(value: v) ->
      let result = v + sz
      if result != 71 then raise RuntimeError(val: "expected 71") end
    case Missing -> raise RuntimeError(val: "expected Found, got Missing")
  end
  return ()
end
