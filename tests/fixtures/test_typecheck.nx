import { TypeExpr, NamedType } from nxc/ast.nx
import { SubstEntry, UnifyResult, Scheme, InstResult, FreshResult,
         apply_subst, compose_subst, empty_subst, singleton_subst,
         free_vars, occurs_check, type_eq,
         unify, mono_scheme, generalize, instantiate, fresh_var } from nxc/typecheck.nx

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then return ()
  else raise RuntimeError(val: msg)
  end
end

let main = fn () -> unit throws { Exn } do
  // ── apply_subst ─────────────────────────────────────────────────────
  let s = singleton_subst(var: "a", typ: TyI64)
  assert(cond: type_eq(a: apply_subst(subst: s, typ: TyVar(name: "a")), b: TyI64),
         msg: "subst: a -> i64")
  assert(cond: type_eq(a: apply_subst(subst: s, typ: TyVar(name: "b")), b: TyVar(name: "b")),
         msg: "subst: b unchanged")
  assert(cond: type_eq(a: apply_subst(subst: s, typ: TyI32), b: TyI32),
         msg: "subst: i32 unchanged")

  // Substitution in compound types
  let arrow = TyArrow(
    params: Cons(v: NamedType(name: "x", typ: TyVar(name: "a")), rest: Nil),
    ret: TyVar(name: "a"),
    requires: TyRow(types: Nil, rest: None),
    throw_row: TyRow(types: Nil, rest: None)
  )
  let substed = apply_subst(subst: s, typ: arrow)
  match substed do
    case TyArrow(params: ps, ret: r, requires: _, throw_row: _) ->
      assert(cond: type_eq(a: r, b: TyI64), msg: "subst: arrow ret -> i64")
      match ps do case Cons(v: p, rest: Nil) ->
        match p do case NamedType(name: _, typ: pt) ->
          assert(cond: type_eq(a: pt, b: TyI64), msg: "subst: arrow param -> i64")
        end
      case _ -> raise RuntimeError(val: "expected 1 param") end
    case _ -> raise RuntimeError(val: "expected arrow")
  end

  // ── compose_subst ───────────────────────────────────────────────────
  let s1 = singleton_subst(var: "a", typ: TyVar(name: "b"))
  let s2 = singleton_subst(var: "b", typ: TyI64)
  let composed = compose_subst(s1: s1, s2: s2)
  // After compose: a -> (s2 applied to b) = a -> i64, plus b -> i64
  assert(cond: type_eq(a: apply_subst(subst: composed, typ: TyVar(name: "a")), b: TyI64),
         msg: "compose: a -> i64 (transitive)")
  assert(cond: type_eq(a: apply_subst(subst: composed, typ: TyVar(name: "b")), b: TyI64),
         msg: "compose: b -> i64")

  // ── free_vars ───────────────────────────────────────────────────────
  let fv1 = free_vars(typ: TyI64)
  match fv1 do case Nil -> assert(cond: true, msg: "fv: i64 has no free vars")
  case _ -> raise RuntimeError(val: "expected no free vars for i64") end

  let fv2 = free_vars(typ: TyVar(name: "x"))
  match fv2 do case Cons(v: x, rest: Nil) ->
    assert(cond: x == "x", msg: "fv: var x has free var x")
  case _ -> raise RuntimeError(val: "expected 1 free var for TyVar x") end

  let fv3 = free_vars(typ: TyArrow(
    params: Cons(v: NamedType(name: "a", typ: TyVar(name: "x")), rest: Nil),
    ret: TyVar(name: "y"),
    requires: TyRow(types: Nil, rest: None),
    throw_row: TyRow(types: Nil, rest: None)
  ))
  // Should have x and y
  assert(cond: list_has_string(xs: fv3, s: "x"), msg: "fv: arrow has x")
  assert(cond: list_has_string(xs: fv3, s: "y"), msg: "fv: arrow has y")

  // ── occurs_check ────────────────────────────────────────────────────
  assert(cond: occurs_check(var: "a", typ: TyVar(name: "a")),
         msg: "occurs: a in Var(a)")
  assert(cond: occurs_check(var: "a", typ: TyVar(name: "b")) == false,
         msg: "occurs: a not in Var(b)")
  assert(cond: occurs_check(var: "a", typ: TyList(elem: TyVar(name: "a"))),
         msg: "occurs: a in List(a)")
  assert(cond: occurs_check(var: "a", typ: TyI64) == false,
         msg: "occurs: a not in i64")

  // ── type_eq ─────────────────────────────────────────────────────────
  assert(cond: type_eq(a: TyI64, b: TyI64), msg: "eq: i64 == i64")
  assert(cond: type_eq(a: TyI64, b: TyI32) == false, msg: "eq: i64 != i32")
  assert(cond: type_eq(a: TyVar(name: "a"), b: TyVar(name: "a")), msg: "eq: var a == var a")
  assert(cond: type_eq(a: TyVar(name: "a"), b: TyVar(name: "b")) == false, msg: "eq: var a != var b")
  assert(cond: type_eq(a: TyList(elem: TyI64), b: TyList(elem: TyI64)), msg: "eq: List<i64>")
  assert(cond: type_eq(a: TyList(elem: TyI64), b: TyList(elem: TyI32)) == false, msg: "eq: List<i64> != List<i32>")

  // ── unify ───────────────────────────────────────────────────────────
  // Same types
  let r1 = unify(t1: TyI64, t2: TyI64)
  match r1 do
    case UnifyOk(subst: _) -> assert(cond: true, msg: "unify: i64 ~ i64")
    case UnifyErr(msg: m) -> raise RuntimeError(val: "unify i64~i64 failed: " ++ m)
  end

  // Variable unification
  let r2 = unify(t1: TyVar(name: "a"), t2: TyI64)
  match r2 do
    case UnifyOk(subst: s_) ->
      assert(cond: type_eq(a: apply_subst(subst: s_, typ: TyVar(name: "a")), b: TyI64),
             msg: "unify: Var(a) ~ i64 => a=i64")
    case UnifyErr(msg: m) -> raise RuntimeError(val: "unify var~i64 failed: " ++ m)
  end

  // Numeric flex
  let r3 = unify(t1: TyIntLit, t2: TyI64)
  match r3 do
    case UnifyOk(subst: _) -> assert(cond: true, msg: "unify: IntLit ~ i64")
    case UnifyErr(msg: m) -> raise RuntimeError(val: "unify IntLit~i64 failed: " ++ m)
  end

  let r3b = unify(t1: TyIntLit, t2: TyI32)
  match r3b do
    case UnifyOk(subst: _) -> assert(cond: true, msg: "unify: IntLit ~ i32")
    case UnifyErr(msg: m) -> raise RuntimeError(val: "unify IntLit~i32 failed: " ++ m)
  end

  // Mismatch
  let r4 = unify(t1: TyI64, t2: TyString)
  match r4 do
    case UnifyErr(msg: _) -> assert(cond: true, msg: "unify: i64 !~ string")
    case UnifyOk(subst: _) -> raise RuntimeError(val: "unify i64~string should fail")
  end

  // Occurs check
  let r5 = unify(t1: TyVar(name: "a"), t2: TyList(elem: TyVar(name: "a")))
  match r5 do
    case UnifyErr(msg: _) -> assert(cond: true, msg: "unify: occurs check")
    case UnifyOk(subst: _) -> raise RuntimeError(val: "unify should fail on occurs")
  end

  // List unification
  let r6 = unify(t1: TyList(elem: TyVar(name: "x")), t2: TyList(elem: TyI64))
  match r6 do
    case UnifyOk(subst: s_) ->
      assert(cond: type_eq(a: apply_subst(subst: s_, typ: TyVar(name: "x")), b: TyI64),
             msg: "unify: List<x> ~ List<i64> => x=i64")
    case UnifyErr(msg: m) -> raise RuntimeError(val: "unify list failed: " ++ m)
  end

  // Arrow unification (label matching)
  let arr1 = TyArrow(
    params: Cons(v: NamedType(name: "x", typ: TyVar(name: "a")), rest: Nil),
    ret: TyVar(name: "b"),
    requires: TyRow(types: Nil, rest: None),
    throw_row: TyRow(types: Nil, rest: None)
  )
  let arr2 = TyArrow(
    params: Cons(v: NamedType(name: "x", typ: TyI64), rest: Nil),
    ret: TyString,
    requires: TyRow(types: Nil, rest: None),
    throw_row: TyRow(types: Nil, rest: None)
  )
  let r7 = unify(t1: arr1, t2: arr2)
  match r7 do
    case UnifyOk(subst: s_) ->
      assert(cond: type_eq(a: apply_subst(subst: s_, typ: TyVar(name: "a")), b: TyI64),
             msg: "unify: arrow param a=i64")
      assert(cond: type_eq(a: apply_subst(subst: s_, typ: TyVar(name: "b")), b: TyString),
             msg: "unify: arrow ret b=string")
    case UnifyErr(msg: m) -> raise RuntimeError(val: "unify arrow failed: " ++ m)
  end

  // Borrow transparency
  let r8 = unify(t1: TyBorrow(inner: TyI64), t2: TyI64)
  match r8 do
    case UnifyOk(subst: _) -> assert(cond: true, msg: "unify: &i64 ~ i64")
    case UnifyErr(msg: m) -> raise RuntimeError(val: "unify borrow failed: " ++ m)
  end

  // ── generalize / instantiate ────────────────────────────────────────
  // Generalize: TyVar("a") with no env free vars → Scheme(["a"], TyVar("a"))
  let sch = generalize(env_free: Nil, typ: TyArrow(
    params: Cons(v: NamedType(name: "x", typ: TyVar(name: "a")), rest: Nil),
    ret: TyVar(name: "a"),
    requires: TyRow(types: Nil, rest: None),
    throw_row: TyRow(types: Nil, rest: None)
  ))
  match sch do case Scheme(vars: vs, typ: _) ->
    assert(cond: list_has_string(xs: vs, s: "a"), msg: "generalize: quantifies a")
  end

  // Instantiate: should replace "a" with fresh var
  let ir = instantiate(scheme: sch, supply: 0)
  match ir do case InstResult(supply: ns, typ: t) ->
    assert(cond: ns > 0, msg: "instantiate: supply incremented")
    // The type should be TyArrow with fresh var ?0 instead of a
    match t do
      case TyArrow(params: _, ret: r, requires: _, throw_row: _) ->
        match r do
          case TyVar(name: n) -> assert(cond: n == "?0", msg: "instantiate: ret is ?0")
          case _ -> raise RuntimeError(val: "instantiate: expected var for ret")
        end
      case _ -> raise RuntimeError(val: "instantiate: expected arrow")
    end
  end

  // ── fresh_var ───────────────────────────────────────────────────────
  let fr = fresh_var(supply: 42)
  match fr do case FreshResult(supply: ns, typ: t) ->
    assert(cond: ns == 43, msg: "fresh_var: supply 42 -> 43")
    match t do
      case TyVar(name: n) -> assert(cond: n == "?42", msg: "fresh_var: name is ?42")
      case _ -> raise RuntimeError(val: "fresh_var: expected TyVar")
    end
  end

  return ()
end

let list_has_string = fn (xs: [string], s: string) -> bool do
  match xs do
    case Nil -> return false
    case Cons(v: x, rest: rest) ->
      if x == s then return true
      else return list_has_string(xs: rest, s: s)
      end
  end
end
