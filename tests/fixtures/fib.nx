fn fib(n: i64) -> i64 do
  if n == 0 then
    return 0
  endif
  if n == 1 then
    return 1
  endif
  let n1 = n - 1
  let n2 = n - 2
  let a = fib(n: n1)
  let b = fib(n: n2)
  return a + b
endfn

fn main() -> unit effect { IO } do
  let result = fib(n: 30)
  let result_s = i64_to_string(val: result)
  let msg = [=[Fib(30) = ]=] ++ result_s
  perform print(val: msg)
  return ()
endfn
