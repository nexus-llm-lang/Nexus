// --- Type Definitions ---
type User = {
  id: i64,
  name: string,
  email: string
}

// --- Port Definition ---
port UserRepository do
  fn exists(email: string) -> Result<bool, string>
  fn create(u: User) -> Result<unit, string>
endport

// --- Main Logic ---
pub fn register_user(name: string, email: string) -> Result<unit, string> do

  conc do
    task [=[audit_log]=] do
       let msg = [=[Registration started: ]=] + email
       perform print(val: msg)
    endtask
  endconc

  let exists_res = perform UserRepository.exists(email: email)

  match exists_res do
    case Err(msg_err) ->
      return Err(msg_err)
    
    case Ok(is_exists) ->
      if is_exists then
        return Err([=[User already exists]=])
      endif
  endmatch

  let new_user = {
    id: 0,
    name: name,
    email: email
  }

  return perform UserRepository.create(u: new_user)
endfn
