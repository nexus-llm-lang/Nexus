
    import * as list from stdlib/list.nx
    let main = fn () -> i64 do
      let empty = Nil
      let nonempty = Cons(v: 1, rest: Nil)
      let a = list.is_empty(xs: empty)
      let b = list.is_empty(xs: nonempty)
      if a then
        if b then return 0 else return 1 end
      else
        return 0
      end
    end
    