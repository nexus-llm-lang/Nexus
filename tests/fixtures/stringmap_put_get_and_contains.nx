import * as smap from stdlib/stringmap.nx

let main = fn () -> unit do
  let m0 = smap.empty()
  let m1 = smap.put(map: m0, key: "hello", value: 10)
  let m2 = smap.put(map: m1, key: "world", value: 20)
  let m3 = smap.put(map: m2, key: "hello", value: 99)
  let v1 = smap.get_or(map: &m3, key: "hello", default: 0)
  let v2 = smap.get_or(map: &m3, key: "world", default: 0)
  let v3 = smap.get_or(map: &m3, key: "missing", default: 7)
  let has = smap.contains_key(map: &m3, key: "world")
  smap.free(map: m3)
  if has == false then raise RuntimeError(val: "expected contains_key true") end
  let result = v1 + v2 + v3
  if result != 126 then raise RuntimeError(val: "expected 126") end
  return ()
end
