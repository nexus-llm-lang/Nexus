
    import as result from stdlib/result.nx

    let inc = fn (val: i64) -> i64 do
      return val + 1
    end

    let main = fn () -> i64 do
      let ok = Ok(val: 10)
      let err = Err(err: "boom")
      let a = result.unwrap_or(res: ok, default: 0)
      let b = result.unwrap_or(res: err, default: 31)
      return a + b + inc(val: a)
    end
    