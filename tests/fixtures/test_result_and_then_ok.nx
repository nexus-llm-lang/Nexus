
    import * as result from "stdlib/result.nx"

    let try_double = fn (val: i64) -> Result<i64, string> do
      return Ok(val: val * 2)
    end

    let main = fn () -> i64 do
      let ok = Ok(val: 5)
      let r = result.and_then(res: ok, f: try_double)
      return result.unwrap_or(res: r, default: 0)
    end
    