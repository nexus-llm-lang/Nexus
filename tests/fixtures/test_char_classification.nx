import as char from stdlib/char.nx
import as str from stdlib/string.nx

let assert = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then
    return ()
  else
    raise RuntimeError(val: msg)
  end
end

let assert_not = fn (cond: bool, msg: string) -> unit throws { Exn } do
  if cond then
    raise RuntimeError(val: msg)
  else
    return ()
  end
end

let main = fn () -> unit throws { Exn } do
  let a_code = str.char_code(s: "a", idx: 0)
  let z_upper = str.char_code(s: "Z", idx: 0)
  let zero_code = str.char_code(s: "0", idx: 0)
  let nine_code = str.char_code(s: "9", idx: 0)
  let space_code = str.char_code(s: " ", idx: 0)
  let underscore = str.char_code(s: "_", idx: 0)
  let f_upper = str.char_code(s: "F", idx: 0)

  // is_alpha
  assert(cond: char.is_alpha(c: a_code), msg: "a should be alpha")
  assert(cond: char.is_alpha(c: z_upper), msg: "Z should be alpha")
  assert_not(cond: char.is_alpha(c: zero_code), msg: "0 should not be alpha")

  // is_digit
  assert(cond: char.is_digit(c: zero_code), msg: "0 should be digit")
  assert(cond: char.is_digit(c: nine_code), msg: "9 should be digit")
  assert_not(cond: char.is_digit(c: a_code), msg: "a should not be digit")

  // is_whitespace
  assert(cond: char.is_whitespace(c: space_code), msg: "space should be whitespace")
  assert_not(cond: char.is_whitespace(c: a_code), msg: "a should not be whitespace")

  // is_upper / is_lower
  assert(cond: char.is_upper(c: z_upper), msg: "Z should be upper")
  assert(cond: char.is_lower(c: a_code), msg: "a should be lower")
  assert_not(cond: char.is_upper(c: a_code), msg: "a should not be upper")

  // is_ident_start / is_ident_char
  assert(cond: char.is_ident_start(c: underscore), msg: "_ should be ident start")
  assert(cond: char.is_ident_start(c: a_code), msg: "a should be ident start")
  assert_not(cond: char.is_ident_start(c: zero_code), msg: "0 should not be ident start")
  assert(cond: char.is_ident_char(c: underscore), msg: "_ should be ident char")
  assert(cond: char.is_ident_char(c: zero_code), msg: "0 should be ident char")
  assert_not(cond: char.is_ident_char(c: space_code), msg: "space should not be ident char")

  // is_hex_digit
  assert(cond: char.is_hex_digit(c: a_code), msg: "a should be hex digit")
  assert(cond: char.is_hex_digit(c: f_upper), msg: "F should be hex digit")
  assert(cond: char.is_hex_digit(c: zero_code), msg: "0 should be hex digit")

  // digit_value
  assert(cond: char.digit_value(c: zero_code) == 0, msg: "digit_value 0")
  assert(cond: char.digit_value(c: nine_code) == 9, msg: "digit_value 9")

  // hex_digit_value
  assert(cond: char.hex_digit_value(c: a_code) == 10, msg: "hex a == 10")
  assert(cond: char.hex_digit_value(c: f_upper) == 15, msg: "hex F == 15")
  assert(cond: char.hex_digit_value(c: zero_code) == 0, msg: "hex 0 == 0")

  return ()
end
