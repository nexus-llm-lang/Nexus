// Acceptance test for `import external "X.wasm"` FFI linking.
// The add.wasm fixture (compiled from add.wat) exports `add(i64,i64)->i64`.
// Nexus emits an import for module "add.wasm", name "add"; the build
// pipeline links the dep via merge_with_deps, producing a self-contained
// binary with no unresolved external-module imports.
import * as test_assert from "std:test/assert"
import external "add.wasm"

external add = "add" : (a: i64, b: i64) -> i64

let body = fn () -> unit throws { Exn } do
  let r1 = add(a: 3, b: 4)
  test_assert.assert_eq_i64(actual: r1, expected: 7, label: "3+4==7")
  let r2 = add(a: 0, b: 0)
  test_assert.assert_eq_i64(actual: r2, expected: 0, label: "0+0==0")
  let r3 = add(a: 100, b: 200)
  test_assert.assert_eq_i64(actual: r3, expected: 300, label: "100+200==300")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
