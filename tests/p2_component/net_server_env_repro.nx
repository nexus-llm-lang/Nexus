// Repro: Env.get before Net.listen must not collide with the p2sock_bridge scratch buffer.
// The harness passes NEXUS_TCP_PORT via p2c-env; the component reads it BEFORE Net.listen.
// Without the fix, get-environment writes to address 65536, and the socket bridge then
// hardcodes 65536 as its retptr for create-tcp-socket, causing a spurious error.
// p2c-tcp-serve
// p2c-tcp-port: 19994
// p2c-env: NEXUS_TCP_PORT=19994
// expect-msg: net_p2c_env_server_ok
import { Console } from "std:stdio"
import { Net }, * as net_mod from "std:network"
import { Env }, * as env_mod from "std:env"
import { Some, None } from "std:option"

let main = fn () -> unit require { PermConsole, PermNet, PermEnv } throws { Exn } do
  inject net_mod.system_handler do
    inject env_mod.system_handler do
      // Env.get BEFORE Net.listen — this is the regression trigger.
      // get-environment writes to wasm address 65536; with the old code, Net.listen
      // then hardcodes 65536 as the create-tcp-socket retptr and reads stale data.
      let _port_str = match Env.get(key: "NEXUS_TCP_PORT") do
        | Some(val: v) -> v
        | None -> "19994"
      end
      // Listen on the hardcoded port (same as p2c-tcp-port).
      let %server = Net.listen(addr: "127.0.0.1:19994")
      Console.print(val: "listening")
      let %req = Net.accept(server: &server)
      Net.respond(req: %req, status: 200, body: "net_p2c_env_server_ok")
      Net.stop(server: %server)
    end
  end
  return ()
end
