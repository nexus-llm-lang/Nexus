// E2E: server echoes the parsed request method + path into the response body,
// proving Net.accept returns a non-empty method/path (nexus-nz5yv read side +
// nexus-wj8mk imported-opaque field layout). Harness curls "/" and checks body.
// p2c-tcp-serve
// p2c-tcp-port: 19996
// expect-msg: GET /
import { Console, system_handler as console_handler } from "std:stdio"
import { Net }, * as net_mod from "std:network"
import { concat } from "std:str"

let main = fn () -> unit require { PermConsole, PermNet } throws { Exn } do
  inject console_handler, net_mod.system_handler do
    let %server = Net.listen(addr: "127.0.0.1:19996")
    Console.print(val: "listening")
    let %req = Net.accept(server: &server)
    let m = net_mod.request_method(req: &req)
    let p = net_mod.request_path(req: &req)
    Net.respond(req: %req, status: 200, body: concat(a: concat(a: m, b: " "), b: p))
    Net.stop(server: %server)
  end
  return ()
end
