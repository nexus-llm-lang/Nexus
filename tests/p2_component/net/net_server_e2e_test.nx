// E2E test: TCP HTTP server accepts one request and responds.
// Harness starts the component under wasmtime -S tcp=y -S inherit-network,
// curls the fixed port, asserts body, then kills the server.
// p2c-tcp-serve
// p2c-tcp-port: 19995
// expect-msg: net_p2c_server_e2e_ok
import { Console, system_handler as console_handler } from "std:stdio"
import { Net }, * as net_mod from "std:network"

let main = fn () -> unit require { PermConsole, PermNet } throws { Exn } do
  inject console_handler, net_mod.system_handler do
    let %server = Net.listen(addr: "127.0.0.1:19995")
    Console.print(val: "listening")
    let %req = Net.accept(server: &server)
    Net.respond(req: %req, status: 200, body: "net_p2c_server_e2e_ok")
    Net.stop(server: %server)
  end
  return ()
end
