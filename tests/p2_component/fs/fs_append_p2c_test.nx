// p2c: write_string + append_string + read_to_string roundtrip via WASI preview2 component.
// expect-msg: p2c_fs_append_ok
import { Console, system_handler as console_handler } from "std:stdio"
import { Fs } from "std:fs"
import * as fs_mod from "std:fs"

let main = fn () -> unit require { PermConsole, PermFs } throws { Exn } do
  inject console_handler, fs_mod.system_handler do
    let dir = "/tmp/nx_p2c_append_test"
    let file = "/tmp/nx_p2c_append_test/note.txt"
    Fs.create_dir_all(path: dir)
    Fs.write_string(path: file, content: "hello")
    Fs.append_string(path: file, content: " world")
    let content = Fs.read_to_string(path: file)
    if content == "hello world" then
      Console.print(val: "p2c_fs_append_ok")
    end
  end
  return ()
end
