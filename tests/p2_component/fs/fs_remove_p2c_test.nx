// p2c: write_string + remove_file + exists via WASI preview2 component.
// expect-msg: p2c_fs_remove_ok
import { Console, system_handler as console_handler } from "std:stdio"
import { Fs } from "std:fs"
import * as fs_mod from "std:fs"

let main = fn () -> unit require { PermConsole, PermFs } throws { Exn } do
  inject console_handler, fs_mod.system_handler do
    let dir = "/tmp/nx_p2c_remove_test"
    let file = "/tmp/nx_p2c_remove_test/trash.txt"
    Fs.create_dir_all(path: dir)
    Fs.write_string(path: file, content: "x")
    Fs.remove_file(path: file)
    if Fs.exists(path: file) == false then
      Console.print(val: "p2c_fs_remove_ok")
    end
  end
  return ()
end
