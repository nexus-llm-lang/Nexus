// E2E test: has_fs + has_net + has_server variant — reads a file AND serves a TCP request.
// Exercises the has_fs×has_net×has_server adapter path with correct type/instance indices.
// The harness mounts fixtures as /data and curls port 19993 for the server response.
// p2c-dir: tests/p2_component/fixtures::/data
// p2c-tcp-serve
// p2c-tcp-port: 19993
// expect-msg: p2c_fs_ok
import { Console, system_handler as console_handler } from "std:stdio"
import { Fs } from "std:fs"
import * as fs_mod from "std:fs"
import { Net }, * as net_mod from "std:network"

let read_or_empty = fn (path: string) -> string require { Fs } do
  let result = ""
  try
    let result = Fs.read_to_string(path)
  catch
    | _ -> ()
  end
  return result
end

let main = fn () -> unit require { PermConsole, PermFs, PermNet } throws { Exn } do
  inject fs_mod.system_handler do
    inject console_handler, net_mod.system_handler do
      let content = read_or_empty(path: "/data/hello.txt")
      let %server = Net.listen(addr: "127.0.0.1:19993")
      Console.print(val: "listening")
      let %req = Net.accept(server: &server)
      Net.respond(req: %req, status: 200, body: content)
      Net.stop(server: %server)
    end
  end
  return ()
end
