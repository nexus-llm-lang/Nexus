// Smoke-test: fd_prestat_get/fd_prestat_dir_name/path_open/fd_read via preopened dir.
// Reads a known file from the mounted fixture directory and prints its content.
// p2c-dir: tests/p2_component/fixtures::/data
// expect-msg: p2c_fs_ok
import { Console, system_handler as console_handler } from "std:stdio"
import { Fs } from "std:fs"
import * as fs_mod from "std:fs"

let read_or_empty = fn (path: string) -> string require { Fs } do
  let ~result = ""
  try
    ~result <- Fs.read_to_string(path)
  catch
    | _ -> ()
  end
  return ~result
end

let main = fn () -> unit require { PermConsole, PermFs } throws { Exn } do
  inject console_handler, fs_mod.system_handler do
    let content = read_or_empty(path: "/data/hello.txt")
    Console.print(val: content)
  end
  return ()
end
