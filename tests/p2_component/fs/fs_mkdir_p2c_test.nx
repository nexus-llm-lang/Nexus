// p2c: create_dir_all + exists via WASI preview2 component.
// expect-msg: p2c_fs_mkdir_ok
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as fs_mod from "std:fs"

let main = fn () -> unit require { PermConsole, PermFs } throws { Exn } do
  inject fs_mod.system_handler do
    let dir = "/tmp/nx_p2c_mkdir_test"
    Fs.create_dir_all(path: dir)
    if Fs.exists(path: dir) then
      Console.print(val: "p2c_fs_mkdir_ok")
    end
  end
  return ()
end
