// p2c: write_string + read_to_string roundtrip via WASI preview2 component.
// expect-msg: p2c_fs_write_ok
import { Console, system_handler as console_handler } from "std:stdio"
import { Fs } from "std:fs"
import * as fs_mod from "std:fs"

let main = fn () -> unit require { PermConsole, PermFs } throws { Exn } do
  inject console_handler, fs_mod.system_handler do
    let file = "/tmp/nx_p2c_write_test.txt"
    Fs.write_string(path: file, content: "hello p2c")
    let content = Fs.read_to_string(path: file)
    if content == "hello p2c" then
      Console.print(val: "p2c_fs_write_ok")
    end
  end
  return ()
end
