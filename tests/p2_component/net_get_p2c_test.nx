// e2e smoke-test: Net.get via wasi:http/outgoing-handler (p2-component mode).
// Starts a local python3 http.server, fetches a known file, asserts body content.
// p2c-http-serve: tests/p2_component/fixtures
// expect-msg: net_p2c_ok
import { Console } from "std:stdio"
import { Net }, * as net_mod from "std:network"
import { Env }, * as env_mod from "std:env"
import { Some, None } from "std:option"

let main = fn () -> unit require { PermConsole, PermNet, PermEnv } throws { Exn } do
  inject env_mod.system_handler do
    inject net_mod.system_handler do
      let base_url = match Env.get(key: "HTTP_TEST_URL") do
        | Some(val: v) -> v
        | None -> "http://127.0.0.1:8080"
      end
      let body = Net.get(url: base_url ++ "/net_hello.txt")
      Console.print(val: body)
    end
  end
  return ()
end
