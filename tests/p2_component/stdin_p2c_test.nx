// Smoke-test: stdin → real wasi:cli/stdin get-stdin + blocking-read.
// Reads one line via Console.read_line and echoes it back with a prefix.
// Invoked as: echo "hello" | wasmtime run -W component-model=y,exceptions=y --stdin ... stdin_p2c_test.wasm
import { Console } from "std:stdio"

let main = fn () -> unit require { PermConsole } do
  let line = Console.read_line()
  Console.println(val: "echo: " ++ line)
  return ()
end
