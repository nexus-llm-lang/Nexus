// Smoke-test: a Nexus program compiled with --p2-component produces
// a valid WASI preview2 component that passes wasm-tools validate,
// runs under wasmtime run -W component-model=y,exceptions=y, and
// produces stdout output via Console.println.
import { Console } from "std:stdio"

let main = fn () -> unit require { PermConsole } do
  Console.println(val: "hello from nexus p2")
  return ()
end
