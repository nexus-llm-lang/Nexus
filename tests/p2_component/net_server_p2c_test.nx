// Smoke-test: Net.listen/accept/respond API compiles in --p2-component --net mode.
// The wasi:sockets interfaces are imported and canon-lowered via p2sock_bridge.
// This test verifies the component builds and validates; it does not run a server
// (runtime TCP socket exercise requires -S tcp=y -S inherit-network in the test harness).
// p2c-http
// expect-msg: net_p2c_server_compile_ok
import { Console } from "std:stdio"
import { Net } from "std:network"
import * as net_mod from "std:network"

// Reference Net.listen/accept/respond/stop to ensure they are compiled in.
// The addresses are type-correct but never actually called from main.
let _unused_server_fn = fn () -> unit require { PermNet } throws { Exn } do
  let %server = Net.listen(addr: "127.0.0.1:0")
  let %req = Net.accept(server: &server)
  Net.respond(req: %req, status: 200, body: "ok")
  Net.stop(server: %server)
  return ()
end

let main = fn () -> unit require { PermConsole, PermNet } throws { Exn } do
  inject net_mod.system_handler do
    Console.print(val: "net_p2c_server_compile_ok")
  end
  return ()
end
