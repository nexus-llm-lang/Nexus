// Smoke-test: environ_get/environ_sizes_get → real wasi:cli/environment get-environment.
// Reads the env var NEXUS_P2C_ENV_TEST via std:env and prints it.
// p2c-env: NEXUS_P2C_ENV_TEST=p2c_env_ok
// expect-msg: NEXUS_P2C_ENV_TEST=p2c_env_ok
import { Console } from "std:stdio"
import { Env }, * as env_mod from "std:env"
import { Some, None } from "std:option"

let main = fn () -> unit require { PermConsole, PermEnv } throws { Exn } do
  inject env_mod.system_handler do
    match Env.get(key: "NEXUS_P2C_ENV_TEST") do
      | Some(val: v) -> Console.println(val: "NEXUS_P2C_ENV_TEST=" ++ v)
      | None -> Console.println(val: "NEXUS_P2C_ENV_TEST=<not set>")
    end
  end
  return ()
end
