// Smoke-test: proc_exit → wasi:cli/exit in --p2-component.
// Calls proc_exit(0) which maps to wasi:cli/exit; a clean exit (code 0)
// means wasmtime reports success and the test harness records PASS.
import { Console } from "std:stdio"
import external "wasi_snapshot_preview1"
external w_proc_exit = "proc_exit" : (code: i32) -> unit
import * as cast from "std:runtime/cast"

let main = fn () -> unit require { PermConsole } do
  Console.println(val: "proc_exit ok")
  w_proc_exit(code: cast.i32_of(x: 0))
  return ()
end
