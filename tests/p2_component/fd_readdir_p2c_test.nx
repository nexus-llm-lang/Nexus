// Smoke-test: fd_readdir via wasi:filesystem [method]descriptor.read-directory.
// Lists the preopened /listdir directory and verifies both expected entries appear.
// p2c-dir: tests/p2_component/fixtures/listdir::/listdir
// expect-msg: p2c_readdir_ok
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as fs_mod from "std:fs"

let str_list_contains = fn (xs: [string], val: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == val then return true end
      return str_list_contains(xs: rest, val)
  end
end

let main = fn () -> unit require { PermConsole, PermFs } throws { Exn } do
  inject fs_mod.system_handler do
    let entries = Fs.list_dir(path: "/listdir")
    let found_a = str_list_contains(xs: entries, val: "a.txt")
    let found_b = str_list_contains(xs: entries, val: "b.txt")
    if found_a && found_b then
      Console.print(val: "p2c_readdir_ok")
    end
  end
  return ()
end
