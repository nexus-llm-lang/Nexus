// Smoke-test: random_get → real wasi:random/random get-random-bytes.
// Reads 8 bytes via random_get; checks that the 64-bit word is non-zero.
// (All-zeros would indicate the old memory.fill stub is still in effect.)
import { Console } from "std:stdio"
import external "wasi_snapshot_preview1"
external w_random_get = "random_get" : (buf_ptr: i32, buf_len: i32) -> i32
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"
import * as cast from "std:runtime/cast"

let main = fn () -> unit require { PermConsole } do
  let p = arena.alloc_raw(size: 8)
  let rc = w_random_get(buf_ptr: cast.i32_of(x: p), buf_len: 8)
  let v = mem.load_i64(addr: p)
  if v == 0 then
    Console.println(val: "FAIL: random bytes are all zero (stub still active?)")
    return ()
  end
  Console.println(val: "random ok")
  return ()
end
