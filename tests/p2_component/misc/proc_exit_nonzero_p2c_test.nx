// Regression test for nexus-c3uxw: proc_exit with code >= 2 must not trap.
// Before the fix, codes >= 2 were forwarded raw to wasi:cli/exit whose
// result<_,_> discriminant only accepts {0,1}; any other value caused an
// "invalid expected discriminant" wasm trap.
// After the fix the shim maps code != 0 → 1 (err) before calling exit, so
// proc_exit(42) reaches wasmtime as a clean non-zero exit, not a trap.
// p2c-allow-nonzero
// expect-msg: proc_exit nonzero ok
import { Console, system_handler } from "std:stdio"
import external "wasi_snapshot_preview1"
external w_proc_exit = "proc_exit" : (code: i32) -> unit
import * as cast from "std:runtime/cast"

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: "proc_exit nonzero ok")
  end
  w_proc_exit(code: cast.i32_of(x: 42))
  return ()
end
