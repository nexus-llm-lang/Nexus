// Smoke-test: clock_time_get → wasi:clocks/monotonic-clock now in --p2-component.
// Calls now_ms which invokes clock_time_get; succeeds (returns >= 0) and prints a
// fixed message so the test harness can verify a clean run.
import { Console, system_handler as console_handler } from "std:stdio"
import * as clock from "std:clock"

let main = fn () -> unit require { PermConsole } do
  let t = clock.now_ms()
  inject console_handler do
    Console.println(val: "clock ok")
  end
  return ()
end
