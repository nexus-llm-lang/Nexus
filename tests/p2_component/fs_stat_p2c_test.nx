// p2c: write_string + is_file/exists (which use fd-stat/path-stat internally) via WASI preview2.
// expect-msg: p2c_fs_stat_ok
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as fs_mod from "std:fs"

let main = fn () -> unit require { PermConsole, PermFs } throws { Exn } do
  inject fs_mod.system_handler do
    let dir = "/tmp/nx_p2c_stat_test"
    let file = "/tmp/nx_p2c_stat_test/data.txt"
    Fs.create_dir_all(path: dir)
    Fs.write_string(path: file, content: "stat test")
    if Fs.exists(path: file) then
      if Fs.is_file(path: file) then
        Console.print(val: "p2c_fs_stat_ok")
      end
    end
  end
  return ()
end
