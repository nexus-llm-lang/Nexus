// E2E test: TCP HTTP server accepts one request and responds.
// Harness starts the component under wasmtime -S tcp=y -S inherit-network on a free port,
// injects LISTEN_PORT env var, curls it, asserts body, then kills the server.
// p2c-tcp-serve
// expect-msg: net_p2c_server_e2e_ok
import { Console } from "std:stdio"
import { Net }, * as net_mod from "std:network"
import { Env }, * as env_mod from "std:env"
import { Some, None } from "std:option"

let main = fn () -> unit require { PermConsole, PermNet, PermEnv } throws { Exn } do
  inject env_mod.system_handler do
    inject net_mod.system_handler do
      let port = match Env.get(key: "LISTEN_PORT") do
        | Some(val: p) -> p
        | None -> "8080"
      end
      let addr = "127.0.0.1:" ++ port
      let %server = Net.listen(addr: addr)
      Console.print(val: "listening")
      let %req = Net.accept(server: &server)
      Net.respond(req: %req, status: 200, body: "net_p2c_server_e2e_ok")
      Net.stop(server: %server)
    end
  end
  return ()
end
