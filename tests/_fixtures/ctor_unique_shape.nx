/** Fixture for nexus-987xh: an enum with a constructor whose bare name does
    NOT collide with anything, used to confirm that selective and wildcard
    (`m.Ctor`) constructor access keep working after routing ctors through the
    import-binding rename map. */

export type Shape = Circle(r: i64) | Square(side: i64)

export let area_ish = fn (sh: Shape) -> i64 do
  match sh do
  | Circle(r) -> r * r * 3
  | Square(side) -> side * side
  end
end
