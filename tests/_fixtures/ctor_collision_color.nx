/** Fixture for nexus-987xh: exports an enum `Color` whose constructor `MkV`
    shares its bare name with `MkV` of `Size` in `ctor_collision_size.nx`.
    A selective `import { MkV } from ".../ctor_collision_color.nx"` must bind
    `MkV` to *this* module's `Color` ctor, not the other module's `Size` ctor. */

export type Color = MkV(n: i64) | Red

export let color_to_int = fn (c: Color) -> i64 do
  return match c do
  | MkV(n) -> n + 1000
  | Red -> 0
  end
end
