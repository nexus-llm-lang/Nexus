// Shared test fixture: HIR synthesis helpers for hand-rolled test programs.
//
// Provides `mk_function`, `mk_external`, `empty_hir`, `call_stmt`, and
// `empty_row` — the same boilerplate that appears in 8fzi_caps_test.nx,
// 2v8n_caps_diff_test.nx, and related caps/hir tests.
//
// Import as:
//   import { mk_function, mk_external, empty_hir, call_stmt, empty_row } from "tests/_fixtures/hir_programs.nx"
//
// This file is NOT a test file (does not end in `_test.nx`) and lives in a
// non-negative directory, so the test runner excludes it from discovery.
import { Span } from "src/common/token.nx"
import { TypeExpr, TyUnit, TyRow } from "src/common/ast.nx"
import { None } from "std:option"
import {
  HirProgram, HirFunction, HirBody, EagerBody,
  HirExternal, HirStmt, HirStmtKind, HirExpr, HirExprKind
} from "src/ir/hir/types.nx"

let sp = fn () -> Span do return Span(offset: 0, line: 1, col: 1) end

/** Empty effect row, suitable for throw_row / requires fields on synthetic HIR nodes. */
export let empty_row = fn () -> TypeExpr do return TyRow(types: [], rest: None) end

/** Build a call-expression statement: a bare call to `func` with no args. */
export let call_stmt = fn (func: string) -> HirStmt do
  let call_expr = HirExpr(node: HirExprKind.Call(func, args: []), span: sp())
  return HirStmt(node: HirStmtKind.Expr(expr: call_expr), span: sp())
end

/** Build a minimal HirFunction with the given name and body statements.
 *  All other fields are set to suitable defaults for capability / effect
 *  analysis tests (no params, unit return type, empty rows).
 */
export let mk_function = fn (name: string, body_stmts: [ HirStmt ]) -> HirFunction do
  return HirFunction(
    name,
    type_params: [],
    params: [],
    ret_type: TyUnit,
    throw_row: empty_row(),
    body: EagerBody(stmts: body_stmts),
    span: sp(),
    file: "fixture.nx",
    requires: empty_row()
  )
end

/** Build a minimal HirExternal with the given names and wasm binding. */
export let mk_external = fn (name: string, wasm_module: string, wasm_name: string) -> HirExternal do
  return HirExternal(
    name,
    wasm_module,
    wasm_name,
    type_params: [],
    params: [],
    ret_type: TyUnit,
    throw_row: empty_row()
  )
end

/** Build a HirExpr node with the shared dummy span. */
export let mk_hir_expr = fn (node: HirExprKind) -> HirExpr do
  return HirExpr(node, span: sp())
end

/** Build a HirStmt node with the shared dummy span. */
export let mk_hir_stmt = fn (node: HirStmtKind) -> HirStmt do
  return HirStmt(node, span: sp())
end

/** Build an empty HirProgram from a list of functions and externals. */
export let empty_hir = fn (fs: [ HirFunction ], exts: [ HirExternal ]) -> HirProgram do
  return HirProgram(
    caps: [],
    functions: fs,
    externals: exts,
    handler_bindings: [],
    enum_defs: [],
    exception_groups: [],
    value_binding_names: [],
    type_defs: [],
    visible_enum_names: []
  )
end
