/** Fixture for the per-module scoped-enum memo (`state_full_enums` cache):
    declares its OWN two-variant enum `Color` (bare name collides with
    `color_three.Color`, which has three variants) and matches it EXHAUSTIVELY
    inside its own body. When this module's body is checked, `current_module` is
    THIS file, so the scoped-enum cache key must resolve `Color` to this module's
    two-variant definition — a complete `Red | Green` match here must stay
    exhaustive even though a three-variant same-name `Color` also exists in the
    program. If the cache served another module's scoped list under this body's
    key, this match would wrongly demand `Blue` (over-reject). */

export type Color = Red | Green

export let classify = fn (c: Color) -> i64 do
  match c do
    | Red -> return 1
    | Green -> return 2
  end
end

export let make_red = fn () -> Color do
  return Red
end
