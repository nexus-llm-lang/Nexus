// Shared test fixture: LIR synthesis helpers for hand-rolled LIR test programs.
//
// Provides `mk_lir_fn`, `mk_lir_param`, `mk_lir_let_stmt`, and
// `empty_throw_row` — the same boilerplate that appears in effect_analysis_test,
// backtrace_elision_test, list_fusion_test, memo_plan_test, and related tests.
//
// Import as:
//   import { mk_lir_fn, mk_lir_param, mk_lir_let_stmt, empty_throw_row } from "tests/_fixtures/lir.nx"
//
// This file is NOT a test file (does not end in `_test.nx`) and lives in a
// non-negative directory, so the test runner excludes it from discovery.
import { TypeExpr, TyUnit, TyI64, TyRow } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"
import { None } from "std:option"
import {
  LirFunction, LirParam, LirStmt, LirExpr, LirAtom,
  LirAtomUnit, LirAtomVar, LirAtomInt,
  LirExprAtom, LirExprCall, LirExprRaise, LirCallArg,
  LirStmtLet
} from "src/ir/lir/types.nx"
import { dummy_span } from "tests/_fixtures/span.nx"

/** Empty throw row: TyRow(types: [], rest: None). */
export let empty_throw_row = fn () -> TypeExpr do
  return TyRow(types: [], rest: None)
end

/** Build a LirParam with the given label/name and type. */
export let mk_lir_param = fn (name: string, typ: TypeExpr) -> LirParam do
  return LirParam(label: name, name, typ)
end

/** Build a simple `let <name>: <typ> = <expr>` statement. */
export let mk_lir_let_stmt = fn (name: string, typ: TypeExpr, expr: LirExpr) -> LirStmt do
  return LirStmtLet(name, typ, expr)
end

/** Build a minimal LirFunction with the given name, params, ret_type, body stmts,
 *  and return atom. Span is the shared dummy_span().
 */
export let mk_lir_fn = fn (name: string, params: [LirParam], ret_type: TypeExpr, body: [LirStmt], ret: LirAtom) -> LirFunction do
  return LirFunction(name, params, ret_type, body, ret, span: dummy_span())
end

/** Build a no-arg LirFunction that returns unit, using the given body stmts. */
export let mk_lir_unit_fn = fn (name: string, body: [LirStmt]) -> LirFunction do
  return mk_lir_fn(name, params: [], ret_type: TyUnit, body, ret: LirAtomUnit)
end

/** Build a no-arg LirFunction with a trivial `let r = 42` body returning i64.
 *  Useful as a pure stub in effect-analysis and memo-plan tests.
 */
export let mk_lir_pure_stub = fn (name: string) -> LirFunction do
  let body = [LirStmtLet(name: "r", typ: TyI64, expr: LirExprAtom(atom: LirAtomInt(val: 42)))]
  return mk_lir_fn(name, params: [], ret_type: TyI64, body, ret: LirAtomVar(name: "r", typ: TyI64))
end

/** Build a no-arg LirFunction whose body directly raises (can_throw = true). */
export let mk_lir_raises_stub = fn (name: string) -> LirFunction do
  let body = [LirStmtLet(name: "r", typ: TyUnit, expr: LirExprRaise(value: LirAtomInt(val: 0), typ: TyUnit))]
  return mk_lir_fn(name, params: [], ret_type: TyUnit, body, ret: LirAtomUnit)
end

/** Build a no-arg LirFunction whose body calls `callee` (no args) and returns unit.
 *  Useful for transitive can_throw propagation chains.
 */
export let mk_lir_chain_stub = fn (name: string, callee: string) -> LirFunction do
  let body = [LirStmtLet(name: "r", typ: TyUnit, expr: LirExprCall(func: callee, args: [], typ: TyUnit))]
  return mk_lir_fn(name, params: [], ret_type: TyUnit, body, ret: LirAtomUnit)
end
