/** Fixture for module-qualified nominal identity: exports an enum `Box` that
    shares its bare name with `Box` in `nominal_box_b.nx` but is a DISTINCT
    nominal type. `mk_a` produces this module's `Box`, carrying a raw `i64`
    payload. A value of this `Box` must not be assignable where the other
    module's `Box` is expected. */

export type Box = AWrap(v: i64) | AEmpty

export let mk_a = fn () -> Box do
  return AWrap(v: 999999)
end
