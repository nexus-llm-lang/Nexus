// Shared test fixture: MIR synthesis helpers for hand-rolled MIR test programs.
//
// Provides `mk_mir_fn` and `mk_mir_expr_stmt` — the same boilerplate
// that appears in force_in_kont_arm_test and specialize_inject_deep_scan_test.
//
// Import as:
//   import { mk_mir_fn, mk_mir_expr_stmt } from "tests/_fixtures/mir.nx"
//
// This file is NOT a test file (does not end in `_test.nx`) and lives in a
// non-negative directory, so the test runner excludes it from discovery.
import { TypeExpr, TyUnit } from "src/common/ast.nx"
import {
  MirFunction, MirStmt, MirExpr,
  MirStmtExpr
} from "src/ir/mir/types.nx"
import { dummy_span } from "tests/_fixtures/span.nx"

/** Build a minimal MirFunction with the given name, return type, and body stmts.
 *  Params are empty; span is the shared dummy_span().
 */
export let mk_mir_fn = fn (name: string, ret_type: TypeExpr, body: [ MirStmt ]) -> MirFunction do
  return MirFunction(name, params: [], ret_type, body, span: dummy_span())
end

/** Wrap a MirExpr as a MirStmtExpr (expression statement). */
export let mk_mir_expr_stmt = fn (expr: MirExpr) -> MirStmt do
  return MirStmtExpr(expr)
end
