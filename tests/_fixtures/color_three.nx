/** Fixture for import-order-independent exhaustiveness: exports an enum `Color`
    with THREE variants. Its bare name collides with `Color` in `color_two.nx`
    (which has only `Red | Green`), but this is a DISTINCT nominal type with a
    `Blue` variant. A match on this `Color` that omits `Blue` is non-exhaustive
    regardless of which same-name `Color` was registered first. `mk_blue`
    produces this module's `Blue`. */

export type Color = Red | Green | Blue

export let mk_blue = fn () -> Color do
  return Blue
end
