// Shared test fixture: a zero-position Span for use in hand-rolled AST / LIR
// test programs.
//
// Import as:
//   import { dummy_span } from "tests/_fixtures/span.nx"
//
// This file is NOT a test file (does not end in `_test.nx`) and lives in a
// non-negative directory, so the test runner excludes it from discovery.
import { Span } from "src/common/token.nx"

/** A synthetic Span at offset 0, line 1, col 1. Suitable for any
 *  hand-rolled AST / LIR / HIR node that does not require location fidelity.
 */
export let dummy_span = fn () -> Span do
  return Span(offset: 0, line: 1, col: 1)
end
