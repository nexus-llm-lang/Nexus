/** Fixture (nexus-wj8mk): exports a single-constructor `opaque` record-shaped
    enum whose field DECLARATION order (method, path, headers, body, rid) is
    deliberately NOT alphabetical. The constructor stores fields in alphabetical
    heap order (body, headers, method, path, rid); when this type is IMPORTED
    its variants are stripped to [] (D-Type-Sum-Opaque), so the LIR field
    extraction must recover the declaration order from the layout-only channel
    to map each pattern field to the right heap slot. A read that returns a
    different field's value is the wj8mk miscompile. Accessors live here (the
    defining module) because the opaque constructor is withheld from importers. */

export opaque type Req = Req(method: string, path: string, headers: string, body: string, rid: i64)

export let mk_req = fn () -> %Req do
  return Req(method: "M0", path: "P1", headers: "H2", body: "B3", rid: 7)
end

export let req_method = fn (r: &Req) -> string do
  let Req(method: m, path: _, headers: _, body: _, rid: _) = r
  return m
end

export let req_path = fn (r: &Req) -> string do
  let Req(method: _, path: p, headers: _, body: _, rid: _) = r
  return p
end

export let req_headers = fn (r: &Req) -> string do
  let Req(method: _, path: _, headers: h, body: _, rid: _) = r
  return h
end

export let req_body = fn (r: &Req) -> string do
  let Req(method: _, path: _, headers: _, body: b, rid: _) = r
  return b
end

export let req_rid = fn (r: &Req) -> i64 do
  let Req(method: _, path: _, headers: _, body: _, rid: d) = r
  return d
end

export let free_req = fn (r: %Req) -> unit do
  let Req(method: _, path: _, headers: _, body: _, rid: _) = r
  return ()
end
