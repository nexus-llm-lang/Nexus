/** Fixture for import-order-independent exhaustiveness: sibling of
    `color_three.nx`. Exports an enum `Color` whose bare name collides with
    `color_three.Color` but which has only `Red | Green` — no `Blue`. Imported
    FIRST by the regression test so this two-variant `Color` is registered
    before the three-variant one; exhaustiveness must still resolve the
    scrutinee to its true declaring module (`color_three`) and demand `Blue`,
    rather than picking this first-registered same-name enum. */

export type Color = Red | Green

export let touch = fn () -> i64 do
  return 0
end
