/** Fixture for nexus-987xh: mirrors the in-tree repl.nx (ReplBinOp) vs
    vocab.nx (BinaryOp) collision that the bootstrap relies on. Exports an enum
    `ImportedOp` with nullary constructors that share their bare names with a
    module-LOCAL enum in the importing test. A selective import of these must
    bind to *this* enum; the importer's own local same-named ctors must keep
    binding to the local enum (type-context independence). */

export type ImportedOp = OpAdd | OpSub | OpMul | ImpOnly

export let imported_op_to_int = fn (o: ImportedOp) -> i64 do
  match o do
  | OpAdd -> 1
  | OpSub -> 2
  | OpMul -> 3
  | ImpOnly -> 9
  end
end
