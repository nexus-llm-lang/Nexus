// Shared test fixture: JSON navigation helpers for IR dump / MCP tests.
//
// Provides `expect_object`, `expect_array`, `expect_string`, `require_field`,
// and `nth_or_fail` — the same 4-5 helpers that appear verbatim in every
// `*_dump_test.nx` and mcp smoke test.
//
// Import as:
//   import { expect_array, expect_string, require_field, nth_or_fail } from "tests/_fixtures/json_helpers.nx"
//   import { expect_object } from "tests/_fixtures/json_helpers.nx"
//
// This file is NOT a test file (no `_test.nx` suffix) and lives in a
// non-negative directory, so the test runner excludes it from discovery.
import { JsonValue, JsonField, JsonObject, JsonArray, JsonString, get_field } from "std:json"
import { Some, None } from "std:option"

/** Unwrap a JsonObject, throwing with `label` on mismatch. */
export let expect_object = fn (v: JsonValue, label: string) -> [ JsonField ] throws { Exn } do
  match v do
    | JsonObject(fields) -> return fields
    | _ -> throw RuntimeError(val: label ++ ": expected JsonObject")
  end
end

/** Unwrap a JsonArray, throwing with `label` on mismatch. */
export let expect_array = fn (v: JsonValue, label: string) -> [ JsonValue ] throws { Exn } do
  match v do
    | JsonArray(items) -> return items
    | _ -> throw RuntimeError(val: label ++ ": expected JsonArray")
  end
end

/** Unwrap a JsonString, throwing with `label` on mismatch. */
export let expect_string = fn (v: JsonValue, label: string) -> string throws { Exn } do
  match v do
    | JsonString(val: s) -> return s
    | _ -> throw RuntimeError(val: label ++ ": expected JsonString")
  end
end

/** Look up a field by key, throwing with `label` if missing. */
export let require_field = fn (
  obj: JsonValue,
  key: string,
  label: string
) -> JsonValue throws { Exn } do
  match get_field(obj, key) do
    | Some(val: v) -> return v
    | None -> throw RuntimeError(val: label ++ ": missing field '" ++ key ++ "'")
  end
end

let nth_or_fail_go = fn (xs: [ JsonValue ], i: i64, label: string) -> JsonValue throws { Exn } do
  match xs do
    | [] -> throw RuntimeError(val: label ++ ": index out of range")
    | h :: rest ->
      if i == 0 then
        return h
      end
      return nth_or_fail_go(xs: rest, i: i - 1, label)
  end
end

/** Return the element at index `i` (0-based), throwing with `label` if out of range. */
export let nth_or_fail = fn (
  xs: [ JsonValue ],
  i: i64,
  label: string
) -> JsonValue throws { Exn } do
  return nth_or_fail_go(xs, i, label)
end
