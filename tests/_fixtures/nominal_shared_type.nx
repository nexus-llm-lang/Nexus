/** Fixture for module-qualified nominal identity: declares the SHARED enum
    `Shared` and a consumer. A different module (`nominal_shared_producer.nx`)
    imports this same type and produces a value of it. Because both modules
    reference the SAME declaration (this module), a produced value must remain
    assignable to `consume` — module qualification must not over-reject a
    genuinely shared imported type. */

export type Shared = SWrap(v: i64) | SNil

export let consume = fn (x: Shared) -> i64 do
  match x do
    | SWrap(v: n) -> return n
    | SNil -> return 0
  end
end
