/** Fixture for nexus-987xh: sibling of `ctor_collision_color.nx`. Exports an
    enum `Size` whose constructor `MkV` collides on the bare name with
    `Color`'s `MkV`. `size_to_int` maps `MkV(n) -> n + 2000` so a mis-resolution
    is observable in the printed value. */

export type Size = MkV(n: i64) | Big

export let size_to_int = fn (s: Size) -> i64 do
  return match s do
  | MkV(n) -> n + 2000
  | Big -> 0
  end
end
