/** Fixture for module-qualified nominal identity: sibling of
    `nominal_box_a.nx`. Exports an enum `Box` whose bare name collides with
    `nominal_box_a.Box` but whose payload is a `[i64]` list. `take_b` reads the
    payload as a list, so accepting `nominal_box_a.Box` here would reinterpret
    its raw `i64` as a list pointer — the memory-unsafe type confusion this
    nominal-identity check forbids. */

import * as lst from "std:list"

export type Box = BWrap(v: [ i64 ]) | BEmpty

export let take_b = fn (x: Box) -> i64 do
  match x do
    | BWrap(v: xs) -> return lst.length(xs: xs)
    | BEmpty -> return 0
  end
end
