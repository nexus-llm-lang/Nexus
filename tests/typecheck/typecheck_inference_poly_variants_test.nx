// Port of bootstrap/tests/typecheck/inference.rs::test_poly_variants.
// `Ok` is a built-in polymorphic constructor; instantiating it with i64
// and bool independently and matching on the i64 instance must typecheck
// (and at runtime, exercise the i64 arm so the binding flows correctly).
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let r1 = Ok(val: 1)
  // Sanity for second instantiation.
  let _r2 = Ok(val: true)
  let observed = match r1 do
    | Ok(val: v) -> v + 1
    | Err(err: _) -> 0 - 1
  end
  test_assert.assert_eq_i64(actual: observed, expected: 2, label: "match on Ok(i64)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
