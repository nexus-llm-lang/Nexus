// Negative fixture for nexus-xv62: P-Record disjoint-union enforcement.
//
// Spec docs/spec/type-system-formal.md P-Record (~358-367) requires
// `⨄_i (Γ_i \ Γ)`: per-field bindings must be disjoint. Below,
// `{ a: x, b: x }` reuses the same binder name `x` across sibling
// fields and must be rejected.

type Pair = { a: i64, b: i64 }

let extract = fn (p: Pair) -> i64 do
  match p do
    | { a: x, b: x } -> return x
  end
end

let main = fn () -> unit do
  extract(p: { a: 1, b: 2 })
  return ()
end
