// Negative fixture for arm-level redundancy detection.
// `Some(_)` catches every `Some(...)`; a subsequent `Some(val: 1)` arm is
// unreachable. The Maranget usefulness predicate `U(M, p)` returns false
// for the redundant row and we surface E2001 with the "arm #N is
// unreachable" witness, where N is the 1-indexed source position of the
// unreachable arm.
//
// Filename intentionally omits `_test` so `nexus test` does not pick it
// up (a fixture that intentionally fails compile would otherwise be
// reported as a runner failure).

let main = fn (opt: Option<i64>) -> i64 do
  // The 2nd arm (Some(val: 1)) is shadowed by the 1st arm (Some(_)).
  // Expected diagnostic shape:
  //   redundant match on `Option<...>`: arm #2 is unreachable
  match opt do
    | Some(_) -> return 1
    | Some(val: 1) -> return 100
    | None -> return 0
  end
end
