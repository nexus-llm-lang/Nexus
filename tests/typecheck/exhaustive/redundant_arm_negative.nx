// Negative fixture for nexus-j6mr: arm-level redundancy detection.
// `Some(_)` catches every `Some(...)`; a subsequent `Some(val: 1)` arm is
// unreachable. Pre-fix the v1 column-of-top-patterns check ignored this
// because it only cared about top-level constructor coverage. Post-fix
// the Maranget usefulness predicate `U(M, p)` correctly returns false
// for the redundant row and we surface E2001 with the "arm #N is
// unreachable" witness.
//
// Filename intentionally omits `_test` so `nexus test` does not pick it
// up (a fixture that intentionally fails compile would otherwise be
// reported as a runner failure).

let main = fn (opt: Option<i64>) -> i64 do
  // arm #1 (Some(val: 1)) is shadowed by arm #0 (Some(_)). Expected
  // diagnostic shape:
  //   redundant match on `Option<...>`: arm #1 is unreachable
  match opt do
    | Some(_) -> return 1
    | Some(val: 1) -> return 100
    | None -> return 0
  end
end
