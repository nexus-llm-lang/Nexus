// Positive fixture for nexus-os2d: a legitimately non-redundant match must
// still pass without any E2001.  Specifics before wildcard, and a plain
// two-arm match without any wildcard, must both typecheck cleanly.
import * as test_assert from "std:test/assert"

let f = fn (o: Option<i64>) -> i64 do
  match o do
    | Some(val: x) -> return x
    | None -> return 0
  end
end

let g = fn (o: Option<i64>) -> i64 do
  match o do
    | Some(val: x) -> return x + 1
    | _ -> return 0
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: f(o: Some(val: 42)), expected: 42, label: "specific first")
  test_assert.assert_eq_i64(actual: f(o: None), expected: 0, label: "none arm")
  test_assert.assert_eq_i64(actual: g(o: Some(val: 3)), expected: 4, label: "wildcard last some")
  test_assert.assert_eq_i64(actual: g(o: None), expected: 0, label: "wildcard last none")
  return ()
end
