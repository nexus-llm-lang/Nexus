// Regression for nexus-t9cl.19: `exhaustive.check_match_exhaustive` used
// to short-circuit on `is_universal_exn` and skip the per-arm redundancy
// scan, silently accepting `match e | NotFound -> ... | NotFound -> ... | _ -> ...`.
//
// Spec mapping (docs/spec/type-system-formal.md):
//   - §T-TryCatch lines 1391-1410: an Exn-rooted scrutinee is treated as
//     effectively-open for exhaustiveness — the universal catch-all
//     rule justifies skipping the `is_useful(M, [_])` check.
//   - §Exh-Sum lines 704-713: per-arm usefulness is the *redundancy*
//     leg of Maranget's algorithm. Open-ness does not justify skipping
//     it: a literal duplicate constructor arm is structurally
//     unreachable regardless of which other Exn ctors might also be
//     thrown at runtime.
//
// We directly invoke `check_match_exhaustive` against three handcrafted
// HIR match shapes over the universal `Exn` type:
//   1. duplicate concrete-ctor arms → RedundantArm.
//   2. distinct ctors + wildcard tail → Exhaustive (no false positive).
//   3. distinct ctors + variable tail → Exhaustive (PVar, not PWild,
//      mirrors the desugar shape used by `catch e ->` wrappers).
//
// Property (2) and (3) guard against the secondary bug found while
// fixing (1): `column_signature` returning `SigFinite([])` for `Exn`
// would let `all_ctors_present` over the empty needed-list succeed and
// route the wildcard arm through `any_ctor_useful([])`, which always
// returns false — flagging EVERY wildcard tail in a multi-arm Exn
// catch as redundant. Fix routes `Exn` through `SigInfinite` so
// wildcards survive the default-matrix branch.

import * as test_assert from "std:test/assert"
import {
  check_match_exhaustive, ExhaustiveResult, Exhaustive, NonExhaustive, RedundantArm, ExnNoCatchAll
} from "src/typecheck/exhaustive.nx"
import {
  HirMatchCase, HirPatternField, HirPatternKind, PCtor, PWild, PVar
} from "src/ir/hir/types.nx"
import { TypeExpr, TyUserDefined, SigilImmutable, EnumDef } from "src/syntax/ast.nx"
import { EnumEntry } from "src/typecheck/types.nx"

// ─── Shared fixtures ────────────────────────────────────────────────────────

let exn_ty = fn () -> TypeExpr do
  return TyUserDefined(name: "Exn", args: [])
end

// `Exn` mirrors `add_builtins` in src/typecheck/check.nx — open enum, no
// variants. Concrete `exception Foo` declarations live elsewhere; the
// exhaustiveness check looks them up by ctor name on each arm.
let exn_enum_entries = fn () -> [ EnumEntry ] do
  return [EnumEntry(
    name: "Exn",
    def: EnumDef(name: "Exn", is_public: true, is_opaque: false, type_params: [], variants: [])
  ) ]
end

let ctor_arm = fn (name: string) -> HirMatchCase do
  return HirMatchCase(pattern: PCtor(variant: name, fields: [], sigil: SigilImmutable), body: [])
end

let wild_arm = fn () -> HirMatchCase do
  return HirMatchCase(pattern: PWild, body: [])
end

let var_arm = fn (n: string) -> HirMatchCase do
  return HirMatchCase(pattern: PVar(name: n, sigil: SigilImmutable), body: [])
end

let result_label = fn (r: ExhaustiveResult) -> string do
  match r do
    | Exhaustive -> return "Exhaustive"
    | NonExhaustive(witness: w) -> return "NonExhaustive(" ++ w ++ ")"
    | RedundantArm(witness: w) -> return "RedundantArm(" ++ w ++ ")"
    | ExnNoCatchAll -> return "ExnNoCatchAll"
  end
end

let is_redundant = fn (r: ExhaustiveResult) -> bool do
  match r do
    | RedundantArm(_) -> return true
    | _ -> return false
  end
end

let is_exhaustive = fn (r: ExhaustiveResult) -> bool do
  match r do
    | Exhaustive -> return true
    | _ -> return false
  end
end

// ─── Tests ──────────────────────────────────────────────────────────────────

let test_duplicate_concrete_ctor_is_redundant = fn () -> unit throws { Exn } do
  // Spec §Exh-Sum: a duplicate ctor arm has `is_useful(M[0..i-1], M[i])` =
  // false because specialize_matrix_ctor on the second NotFound produces a
  // non-empty (one row of empty patterns) submatrix, and an empty row is
  // not useful against it.
  let cases = [ ctor_arm(name: "NotFound"), ctor_arm(name: "NotFound"), wild_arm() ]
  let r = check_match_exhaustive(
    cases: cases, scrutinee_type: exn_ty(),
    enum_defs: exn_enum_entries(), type_defs: []
  )
  test_assert.assert_true(
    cond: is_redundant(r: r),
    label: "duplicate Exn ctor must be RedundantArm, got " ++ result_label(r: r)
  )
  return ()
end

let test_distinct_ctors_with_wildcard_tail_is_exhaustive = fn () -> unit throws { Exn } do
  // Pre-fix secondary bug: with `Exn` classed as `SigFinite([])`, the
  // wildcard arm would be reported as redundant because
  // `all_ctors_present(needed: [], have: [Other])` is vacuously true
  // and `any_ctor_useful([])` returns false. Post-fix `column_signature`
  // returns `SigInfinite` for `Exn`, routing through `default_matrix`.
  let cases = [ ctor_arm(name: "Other"), wild_arm() ]
  let r = check_match_exhaustive(
    cases: cases, scrutinee_type: exn_ty(),
    enum_defs: exn_enum_entries(), type_defs: []
  )
  test_assert.assert_true(
    cond: is_exhaustive(r: r),
    label: "Exn ctor + wildcard must be Exhaustive, got " ++ result_label(r: r)
  )
  return ()
end

let test_distinct_ctors_with_var_tail_is_exhaustive = fn () -> unit throws { Exn } do
  // The `catch | InvalidUsage(...) -> ... | e -> ...` shape in
  // src/main.nx desugars the tail bind as PVar, not PWild. Same Exn
  // SigInfinite invariant.
  let cases = [ ctor_arm(name: "InvalidUsage"), var_arm(n: "e") ]
  let r = check_match_exhaustive(
    cases: cases, scrutinee_type: exn_ty(),
    enum_defs: exn_enum_entries(), type_defs: []
  )
  test_assert.assert_true(
    cond: is_exhaustive(r: r),
    label: "Exn ctor + PVar tail must be Exhaustive, got " ++ result_label(r: r)
  )
  return ()
end

let test_single_var_catch_is_exhaustive = fn () -> unit throws { Exn } do
  // `try ... catch e -> body` desugars to `match e do | e -> body end`
  // (single PVar). Must not be flagged redundant or non-exhaustive.
  let cases = [ var_arm(n: "e") ]
  let r = check_match_exhaustive(
    cases: cases, scrutinee_type: exn_ty(),
    enum_defs: exn_enum_entries(), type_defs: []
  )
  test_assert.assert_true(
    cond: is_exhaustive(r: r),
    label: "single PVar catch must be Exhaustive, got " ++ result_label(r: r)
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  test_duplicate_concrete_ctor_is_redundant()
  test_distinct_ctors_with_wildcard_tail_is_exhaustive()
  test_distinct_ctors_with_var_tail_is_exhaustive()
  test_single_var_catch_is_exhaustive()
  return ()
end
