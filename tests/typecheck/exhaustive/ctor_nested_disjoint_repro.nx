// Negative fixture for nexus-xv62: P-Ctor disjoint-union enforcement
// across a nested constructor pattern. The inner pattern
// `Inner(x)` introduces `x`; the sibling field `b: x` reintroduces
// the same name, which must be rejected per spec P-Ctor.

type Inner = MkInner(x: i64)
type Outer = MkOuter(a: Inner, b: i64)

let extract = fn (o: Outer) -> i64 do
  match o do
    | MkOuter(a: MkInner(x), b: x) -> return x
  end
end

let main = fn () -> unit do
  extract(o: MkOuter(a: MkInner(x: 1), b: 2))
  return ()
end
