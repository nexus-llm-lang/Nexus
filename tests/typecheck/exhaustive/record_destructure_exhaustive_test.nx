// Regression: nexus-m63p Bug A — record-pattern is exhaustive at TyRecord
// column. Pre-fix, exhaustiveness lacked a `check_record` arm for
// `TyRecord(_)`, so `let { x } = r` (single-arm desugar of let-destructure
// on an anonymous record) tripped E2001 in standalone `nexus typecheck`
// even though every record value structurally matches the single arm.
//
// Post-fix `check_record` accepts when each field has at least one
// covering pattern, so the single-arm desugar is exhaustive on TyRecord.
// This fixture exercises the standalone-typecheck surface that
// `tests/typecheck/typecheck_inference_let_destructure_test.nx` covers
// only as a downstream consequence — here a single-arm `let { x } = r`
// over an *anonymous* `TyRecord` is the load-bearing shape.
import * as test_assert from "std:test/assert"

// Anonymous record type — exercised inline so the typechecker sees a raw
// TyRecord rather than a named type alias resolving to one.
let single_field = fn () -> i64 do
  let r = { x: 42 }
  let { x } = r
  return x
end

let multi_field = fn () -> i64 do
  let r = { a: 10, b: 20, c: 30 }
  let { a, b, c } = r
  return a + b + c
end

// Punned shape — `{ x }` desugars to `{ x }` so the exhaustiveness
// check has to handle the post-pun pattern as well.
let punned = fn () -> i64 do
  let r = { x: 7, y: 11 }
  let { x, y } = r
  return x + y
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: single_field(),
    expected: 42,
    label: "single-field anonymous record let-destructure"
  )
  test_assert.assert_eq_i64(
    actual: multi_field(),
    expected: 60,
    label: "multi-field anonymous record let-destructure"
  )
  test_assert.assert_eq_i64(
    actual: punned(),
    expected: 18,
    label: "punned anonymous record let-destructure"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
