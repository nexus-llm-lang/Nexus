/** Regression for the per-module scoped-enum memo (`state_full_enums` cache).
 *
 *  The exhaustiveness/redundancy check resolves a bare enum name against the
 *  set of enums VISIBLE to the body's module (`current_module`). That scoped
 *  set is now memoized per module on the shared map; the cache key is
 *  `current_module`. This test exercises two modules that each declare an enum
 *  named `Color` with DIFFERENT variant sets, with an exhaustive match in BOTH
 *  modules' bodies, so the cache is keyed and read once per module:
 *
 *    - `color_two_self_match.Color` = `Red | Green`; its `classify` matches it
 *      exhaustively INSIDE that module's own body (cache key = the fixture).
 *    - `color_three.Color` = `Red | Green | Blue`; `classify_three` below matches
 *      it exhaustively in THIS (root) module's body (cache key = root).
 *
 *  Both matches are complete and must typecheck. If the per-module cache served
 *  one module's scoped `Color` under the other module's key, the two-variant
 *  match would wrongly demand `Blue` (spurious non-exhaustive) or the
 *  three-variant match would resolve to the two-variant `Color` and accept a
 *  match missing `Blue`. The companion negative fixture
 *  cross_module_samename_enum_nonexhaustive_b_first.nx confirms a genuinely
 *  missing `Blue` is STILL rejected, independent of import order. */

import * as test_assert from "std:test/assert"
import { classify, make_red }, * as c2 from "tests/_fixtures/color_two_self_match.nx"
import { Color, mk_blue } from "tests/_fixtures/color_three.nx"

/** Exhaustive match on the THREE-variant `Color` in the ROOT module's body
 *  (cache key = this file). Must demand all of `Red | Green | Blue`. */
let classify_three = fn (c: Color) -> i64 do
  match c do
    | Red -> return 10
    | Green -> return 20
    | Blue -> return 30
  end
end

let driver = fn () -> i64 do
  // Drives the two-variant fixture's own exhaustive self-match (its body is
  // checked under the fixture's cache key).
  let two = classify(c: make_red())
  // Drives the root body's exhaustive three-variant match.
  let three = classify_three(c: mk_blue())
  return two + three
end

let main = fn () -> unit throws { Exn } do
  let r = driver()
  test_assert.assert_eq_i64(
    actual: r,
    expected: 31,
    label: "per-module scoped-enum cache keeps each module's same-name Color match exhaustive"
  )
  return ()
end
