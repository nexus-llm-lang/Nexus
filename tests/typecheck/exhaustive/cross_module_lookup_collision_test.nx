/** Regression: two modules (`std:stringmap` and `std:hashmap`) both export an
 *  enum named `Lookup` whose variants are `Found`/`Missing`. A match that
 *  covers `std:stringmap`'s `Lookup` exhaustively must typecheck even when
 *  `std:hashmap`'s `Lookup` is ALSO in scope.
 *
 *  Pre-fix the exhaustiveness check resolved the scrutinee's enum name `Lookup`
 *  by flat first-match, sometimes selecting the WRONG module's declaration whose
 *  module-qualified `Found`/`Missing` ctors fail to cover the arms' (correctly
 *  resolved) ctors, yielding a spurious "non-exhaustive: missing pattern for
 *  Found(_)". The fix resolves the scrutinee enum to the same-named declaration
 *  that actually declares the arms' constructor, disambiguating by ctor
 *  membership. The companion negative fixture
 *  tests/typecheck/exhaustive/cross_module_lookup_genuine_negative.nx confirms a
 *  genuinely missing arm is STILL rejected. */
import * as test_assert from "std:test/assert"
import { StringMap, Found, Missing }, * as sm from "std:stringmap"
import { Lookup }, * as hm from "std:hashmap"

let lookup_or = fn (m: &StringMap<i64>, key: string, default: i64) -> i64 do
  match sm.get(map: m, key) do
    | Found(value: v) -> return v
    | Missing -> return default
  end
end

let driver = fn () -> i64 throws { Exn } do
  let %m0 = sm.empty()
  let %m1 = sm.put(map: %m0, key: "a", value: 42)
  let hit = lookup_or(m: &m1, key: "a", default: -1)
  let miss = lookup_or(m: &m1, key: "z", default: -1)
  sm.free(map: %m1)
  return hit + miss
end

let main = fn () -> unit throws { Exn } do
  let r = driver()
  test_assert.assert_eq_i64(
    actual: r,
    expected: 41,
    label: "exhaustive match on stringmap Lookup typechecks despite hashmap Lookup collision"
  )
  return ()
end
