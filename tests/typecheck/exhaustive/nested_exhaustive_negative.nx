// Negative fixture for nexus-j6mr: nested exhaustiveness via Maranget.
// `match opt do | Some(val: 1) -> ... | None -> ... end` is non-exhaustive
// at the Some-inner column because `1` only covers one of the infinite i64
// values. Pre-fix the column-of-top-patterns v1 saw only `Some` and `None`
// at the scrutinee column, declared the match exhaustive, and accepted it.
// Post-fix the pattern-matrix walk specializes on Some, recurses into the
// `val: i64` sub-column, and discovers the wildcard `_` is useful there.
//
// Filename intentionally omits `_test` so `nexus test` does not pick it
// up (a fixture that intentionally fails compile would otherwise be
// reported as a runner failure).

let main = fn (opt: Option<i64>) -> i64 do
  // The single nested literal leaves every other i64 uncovered. Expected
  // diagnostic shape:
  //   non-exhaustive match on `Option<...>`: missing pattern for <ctor>
  // The witness names a top-level ctor with an uncovered nested column;
  // either `Some` or `None` is acceptable here.
  match opt do
    | Some(val: 1) -> return 100
    | None -> return 0
  end
end
