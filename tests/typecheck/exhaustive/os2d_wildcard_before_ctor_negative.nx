// Negative fixture for nexus-os2d: specific arm after catch-all wildcard.
// A `_` arm covers every value; `Some(val: x)` afterwards is unreachable.
// Pre-fix, Phase 3 in canonicalize_match silently stripped the arm before
// the typecheck could see it, so no E2001 was emitted.
//
// Filename intentionally omits `_test` so `nexus test` does not pick it up.

let main = fn () -> unit do
  let o = Some(val: 5)
  let r = match o do
    | _ -> 0
    | Some(val: x) -> x
  end
  r
  return ()
end
