// Regression for the match-redundancy diagnostic arm index.
//
// `check_redundancy` reports the FIRST row `i` with `useful(M_{<i}, [p_i]) =
// false` — i.e. the unreachable (redundant) arm itself, not the earlier arm
// that subsumes it.  Two properties are pinned here:
//
//   1. The reported index tracks the OFFENDER's source position, 1-indexed.
//      For `A,B,C,D,<dup>` the redundant arm is always the 5th, so every
//      duplicate constructor must report "arm #5" regardless of which earlier
//      arm covers it.
//   2. A duplicate in a different position reports that position, confirming
//      the index follows the offender rather than a fixed slot.
//
// We invoke `check_match_exhaustive` directly (as t9cl19 does) so the test is
// independent of the canonicalization pipeline: the typecheck program is
// canonicalized with arm reordering OFF precisely so this source-order index
// is preserved.

import * as test_assert from "std:test/assert"
import {
  check_match_exhaustive, ExhaustiveResult, Exhaustive, NonExhaustive, RedundantArm, ExnNoCatchAll
} from "src/typecheck/exhaustive.nx"
import { HirMatchCase, HirPatternKind, PCtor } from "src/ir/hir/types.nx"
import { TypeExpr, TyUserDefined, SigilImmutable, EnumDef, VariantDef } from "src/syntax/ast.nx"
import { EnumEntry } from "src/typecheck/types.nx"

// ─── Fixtures: a closed four-constructor enum `T = A | B | C | D`. ───────────

let t_ty = fn () -> TypeExpr do
  return TyUserDefined(name: "T", args: [])
end

let t_enum_entries = fn () -> [ EnumEntry ] do
  return [EnumEntry(
    name: "T",
    def: EnumDef(
      name: "T",
      is_public: true,
      is_opaque: false,
      type_params: [],
      variants: [
        VariantDef(name: "A", fields: []),
        VariantDef(name: "B", fields: []),
        VariantDef(name: "C", fields: []),
        VariantDef(name: "D", fields: [])
      ],
      layout_variants: [], module: ""
    )
  ) ]
end

let ctor_arm = fn (name: string) -> HirMatchCase do
  return HirMatchCase(pattern: PCtor(variant: name, fields: [], sigil: SigilImmutable), body: [])
end

let run = fn (cases: [ HirMatchCase ]) -> ExhaustiveResult do
  return check_match_exhaustive(
    cases: cases, scrutinee_type: t_ty(),
    enum_defs: t_enum_entries(), type_defs: []
  )
end

let witness_of = fn (r: ExhaustiveResult) -> string do
  match r do
    | RedundantArm(witness: w) -> return w
    | Exhaustive -> return "<Exhaustive>"
    | NonExhaustive(witness: w) -> return "<NonExhaustive:" ++ w ++ ">"
    | ExnNoCatchAll -> return "<ExnNoCatchAll>"
  end
end

// ─── Tests ───────────────────────────────────────────────────────────────────

// `A,B,C,D,<dup>`: the redundant arm is always the 5th.  The reported index
// must be #5 for every duplicate ctor, never the covering arm's index.
let test_trailing_dup_always_reports_fifth = fn () -> unit throws { Exn } do
  let dup_a = run(cases: [
    ctor_arm(name: "A"), ctor_arm(name: "B"), ctor_arm(name: "C"),
    ctor_arm(name: "D"), ctor_arm(name: "A")
  ])
  test_assert.assert_eq_string(
    expected: "arm #5 is unreachable", actual: witness_of(r: dup_a),
    label: "dup-of-A at arm 5"
  )
  let dup_b = run(cases: [
    ctor_arm(name: "A"), ctor_arm(name: "B"), ctor_arm(name: "C"),
    ctor_arm(name: "D"), ctor_arm(name: "B")
  ])
  test_assert.assert_eq_string(
    expected: "arm #5 is unreachable", actual: witness_of(r: dup_b),
    label: "dup-of-B at arm 5"
  )
  let dup_c = run(cases: [
    ctor_arm(name: "A"), ctor_arm(name: "B"), ctor_arm(name: "C"),
    ctor_arm(name: "D"), ctor_arm(name: "C")
  ])
  test_assert.assert_eq_string(
    expected: "arm #5 is unreachable", actual: witness_of(r: dup_c),
    label: "dup-of-C at arm 5"
  )
  let dup_d = run(cases: [
    ctor_arm(name: "A"), ctor_arm(name: "B"), ctor_arm(name: "C"),
    ctor_arm(name: "D"), ctor_arm(name: "D")
  ])
  test_assert.assert_eq_string(
    expected: "arm #5 is unreachable", actual: witness_of(r: dup_d),
    label: "dup-of-D at arm 5"
  )
  return ()
end

// A duplicate in a different position reports that position — the index
// follows the offender, not a fixed slot.
let test_index_follows_offender_position = fn () -> unit throws { Exn } do
  // A,A,B,C,D → redundant arm is the 2nd.
  let dup_2nd = run(cases: [
    ctor_arm(name: "A"), ctor_arm(name: "A"), ctor_arm(name: "B"),
    ctor_arm(name: "C"), ctor_arm(name: "D")
  ])
  test_assert.assert_eq_string(
    expected: "arm #2 is unreachable", actual: witness_of(r: dup_2nd),
    label: "dup-of-A at arm 2"
  )
  // A,B,C,A,D → redundant arm is the 4th (non-adjacent dup of A).
  let dup_4th = run(cases: [
    ctor_arm(name: "A"), ctor_arm(name: "B"), ctor_arm(name: "C"),
    ctor_arm(name: "A"), ctor_arm(name: "D")
  ])
  test_assert.assert_eq_string(
    expected: "arm #4 is unreachable", actual: witness_of(r: dup_4th),
    label: "non-adjacent dup-of-A at arm 4"
  )
  return ()
end

// Detection itself is unchanged: a complete, non-redundant match accepts.
let test_complete_match_is_exhaustive = fn () -> unit throws { Exn } do
  let r = run(cases: [
    ctor_arm(name: "A"), ctor_arm(name: "B"), ctor_arm(name: "C"), ctor_arm(name: "D")
  ])
  test_assert.assert_eq_string(
    expected: "<Exhaustive>", actual: witness_of(r: r),
    label: "A,B,C,D is exhaustive and non-redundant"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  test_trailing_dup_always_reports_fifth()
  test_index_follows_offender_position()
  test_complete_match_is_exhaustive()
  return ()
end
