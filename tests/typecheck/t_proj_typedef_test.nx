// T-Proj: field projection on a named record typedef (TyUserDefined) must
// expand via typedef(x) = ∀ᾱ.{ℓ̄:σ̄} and then project.  Previously the
// typechecker rejected `p.x` when `p : Point` with "field access on
// non-record type".  See nexus-1ca7.
import * as test_assert from "std:test/assert"

type Point = { x: i64, y: i64 }

// Field projection on a typedef parameter must typecheck and run correctly.
let get_x = fn (p: Point) -> i64 do
  return p.x
end

let get_y = fn (p: Point) -> i64 do
  return p.y
end

let main = fn () -> unit throws { Exn } do
  let p: Point = { x: 10, y: 20 }
  let x = get_x(p: p)
  let y = get_y(p: p)
  test_assert.assert_eq_i64(actual: x, expected: 10, label: "typedef field .x")
  test_assert.assert_eq_i64(actual: y, expected: 20, label: "typedef field .y")
  return ()
end
