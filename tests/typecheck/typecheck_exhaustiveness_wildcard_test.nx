// Port of bootstrap/tests/typecheck/exhaustiveness.rs::test_wildcard_exhaustive.
// Integer match must include a wildcard (or every literal up to the type's
// range) — the `0 | _` form is exhaustive.
import * as test_assert from "std:test/assert"

let classify = fn (i: i64) -> i64 do
  match i do
    | 0 -> return 1000
    | _ -> return 2000
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: classify(i: 0), expected: 1000, label: "match literal 0")
  test_assert.assert_eq_i64(actual: classify(i: 42), expected: 2000, label: "match wildcard arm")
  test_assert.assert_eq_i64(actual: classify(i: -1), expected: 2000, label: "match wildcard with negative")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
