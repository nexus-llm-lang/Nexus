// Regression for nexus-hfmw.
//
// The bd issue framed this as "self-host generic-bool instantiation
// through Exn-throwing context fails E2006", attributing the fault to
// bool-tagged-i32 representation interacting with Exn-row narrowing
// during instantiation.
//
// Actual root cause: the self-host typechecker's `infer_let` bound
// every `let` (including `let f = id` aliasing a polymorphic value)
// monomorphically. The first use site of `f` constrained its fresh
// type variable, and a second use at a different type then failed
// unification. The Exn-row was a red herring — the same shape failed
// outside `throws { Exn }` too. The reported "E2006" code was also
// wrong (E2006 is LazyBindingDoubleUse); the actual error code is
// E2001 (TypeMismatch) with detail "cannot unify int literal with
// non-integer type".
//
// Fix: src/typecheck/infer.nx::infer_let copies the source scheme on
// `let f = some_var` when the source binding is polymorphic, so the
// alias preserves its type-parameter list. Same effect as bootstrap's
// HM-style generalize, restricted to syntactic-variable aliasing.
//
// This file exercises the previously-failing shape from bootstrap
// test_let_poly_binding: `let f = id; f(x: 10); f(x: true)`. Pre-fix
// this raised E2001; post-fix the second call re-instantiates and
// typechecks. The bd-issue stated acceptance criterion
// (`fn () -> bool throws { Exn } do return id(x: true) end`) already
// worked pre-fix and is not separately covered here.
import * as test_assert from "std:test/assert"

let id = fn <T>(x: T) -> T do
  return x
end

let body = fn () -> i64 throws { Exn } do
  let f = id
  let a = f(x: 10)
  let b = f(x: true)
  let v = if b then a else 0 end
  test_assert.assert_eq_i64(actual: v, expected: 10, label: "let-aliased poly fn re-instantiates per use")
  return a
end

let safe_run = fn () -> i64 do
  try
    return body()
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let v = safe_run()
  test_assert.assert_eq_i64(actual: v, expected: 10, label: "hfmw end-to-end")
  return ()
end
