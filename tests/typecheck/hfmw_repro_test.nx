// Regression for nexus-hfmw.
//
// `infer_let` must copy the source scheme on `let f = some_var` when
// the source binding is polymorphic, so the alias preserves its
// type-parameter list (HM-style generalize, restricted to
// syntactic-variable aliasing). Without this, `let f = id`
// monomorphizes `f` against its first use site and a second use at
// a different type fails unification with E2001 (TypeMismatch).
//
// This file exercises the let-poly-binding shape: `let f = id;
// f(x: 10); f(x: true)`. The second call must re-instantiate and
// typecheck.
import * as test_assert from "std:test/assert"

let id = fn <T>(x: T) -> T do
  return x
end

let body = fn () -> i64 throws { Exn } do
  let f = id
  let a = f(x: 10)
  let b = f(x: true)
  let v = if b then a else 0 end
  test_assert.assert_eq_i64(actual: v, expected: 10, label: "let-aliased poly fn re-instantiates per use")
  return a
end

let safe_run = fn () -> i64 do
  try
    return body()
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let v = safe_run()
  test_assert.assert_eq_i64(actual: v, expected: 10, label: "hfmw end-to-end")
  return ()
end
