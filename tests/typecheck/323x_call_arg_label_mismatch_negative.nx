// nexus-323x: Negative fixture. Call-argument labels must match the
// parameter name at the corresponding slot. Punning a bare ident whose
// name does not match the parameter (e.g. `f(x, y)` against
// `fn f(a: i64, b: i64)`) used to silently compile to a positional call
// and produce a wrong-slot miscompile at runtime. Typecheck now rejects.
//
// Kept out of `nexus test` discovery by the missing `_test` suffix —
// this fixture must be REJECTED by `nexus typecheck`.
let f = fn (a: i64, b: i64) -> i64 do
  return a * 100 + b
end

let main = fn () -> unit do
  let x = 7
  let y = 3
  let _r = f(x, y)
  return ()
end
