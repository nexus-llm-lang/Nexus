// nexus-rfh1: typecheck must reject body of non-main top-level functions.
//
// `bug` declares its return type as `bool` but the body returns `x: i64`.
// Pre-fix this slipped through typecheck because `local_names` (the
// allow-list used by `check_all_functions` in src/typecheck/check.nx) was
// built from bare AST names while the HirFunction was already canonicalised
// to "<source-path>#bug", so `is_local` filtered the body out.
let bug = fn (x: i64) -> bool do
  return x
end

let main = fn () -> unit do
  let _ = bug(x: 5)
  return ()
end
