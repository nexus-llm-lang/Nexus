// Port of bootstrap/tests/typecheck/linearity.rs::
// test_linear_consumed_before_throwable_call_passes,
// test_linear_across_pure_call_passes,
// test_linear_across_throwable_call_inside_try_with_catch_consume_passes.
//
// Hole-2 from issue nexus-7eex.2 has a positive-side companion: a linear
// can safely be alive across a *non-throwable* call, and across a
// throwable call inside a try/catch where both arms consume it.
import * as test_assert from "std:test/assert"

exception Oops(msg: string)
type FileToken = { id: i64 }

let open_file = fn () -> %FileToken do
  let h: FileToken = { id: 7 }
  let %lh = h
  return %lh
end

let may_throw = fn () -> unit throws { Exn } do
  raise Oops(msg: "boom")
  return ()
end

let pure_call = fn () -> unit do
  return ()
end

let close = fn (h: %FileToken) -> i64 do
  let r = match h do | { id: i } -> i end
  return r
end

// Linear `%x` is alive across the pure call; consumed only after.
let pure_call_path = fn () -> i64 do
  let %x = open_file()
  pure_call()
  return close(h: %x)
end

// Linear `%x` consumed *before* the throwable call; the call site sees
// no linear in scope.
let consume_before_raise_path = fn () -> i64 do
  let %x = open_file()
  let r = close(h: %x)
  try
    may_throw()
  catch _ -> ()
  end
  return r
end

// Linear bound before `try`; both try body and catch arm consume it.
// The throwable call sits inside the try body — strategy A allows this.
let across_throwable_inside_try = fn () -> i64 do
  let h: FileToken = { id: 9 }
  let %x = h
  try
    may_throw()
    return close(h: %x)  // unreachable: raise above
  catch _ ->
    return close(h: %x)
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: pure_call_path(), expected: 7, label: "linear across pure call")
  test_assert.assert_eq_i64(actual: consume_before_raise_path(), expected: 7, label: "consume before throwable call")
  test_assert.assert_eq_i64(actual: across_throwable_inside_try(), expected: 9, label: "throwable inside try, both arms consume")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
