// Port of bootstrap/tests/typecheck/inference.rs::test_basic_poly,
// test_nested_calls, test_two_generics, test_let_poly_binding,
// test_complex_poly_logic. Each invocation of a generic identity
// function with a different argument type must instantiate independently
// so the same `let f = id` can be applied to both i64 and bool.
import * as test_assert from "std:test/assert"

let id = fn <T>(x: T) -> T do
  return x
end

let first = fn <A, B>(a: A, b: B) -> A do
  return a
end

let body = fn () -> unit throws { Exn } do
  // i64 instantiation, observed via assert_eq_i64.
  let i = id(x: 10)
  test_assert.assert_eq_i64(actual: i, expected: 10, label: "id i64 instantiation")

  // Nested polymorphic calls — both at i64 to keep the assert path
  // monomorphic. (The self-host typechecker hits E2006 on certain
  // poly-bool instantiations inside an effect-throwing context — see
  // PORT_SKIPPED note.)
  let n = id(x: id(x: 7))
  test_assert.assert_eq_i64(actual: n, expected: 7, label: "nested id calls")

  // Two type parameters; A is selected by the first arg. We pass a
  // bool in B-position only (so the unifier never has to coerce bool
  // through T into the assert path).
  let f = first(a: 10, b: true)
  test_assert.assert_eq_i64(actual: f, expected: 10, label: "first<i64,bool> via A")

  // Let-bound generic value, called once at i64.
  let g = id
  let p = g(x: 11)
  test_assert.assert_eq_i64(actual: p, expected: 11, label: "let-bound id at i64")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
