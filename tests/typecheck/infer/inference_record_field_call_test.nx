// Tests for calling function-valued record fields (nexus-v3xa.18).
//
// Two forms are tested:
//   (A) `o.field(args)` — direct field-call syntax (T-Proj + T-App)
//   (B) `(o.field)(args)` — parenthesized field access + postfix call
//
// Both plain arrows and arrows carrying throws rows are covered.
import * as test_assert from "std:test/assert"

exception FieldCallExn

// (A) Plain arrow field: direct call syntax
type Ops = { run: () -> i64 }

let use_ops = fn (o: Ops) -> i64 throws { Exn } do
  return o.run()
end

// (A) Throws-row arrow field: direct call syntax
type OpsT = { run: () -> i64 throws { FieldCallExn } }

let use_ops_throws = fn (o: OpsT) -> i64 throws { FieldCallExn } do
  return o.run()
end

// (B) Plain arrow field: parenthesized form
let use_ops_paren = fn (o: Ops) -> i64 throws { Exn } do
  return (o.run)()
end

// (B) Throws-row arrow field: parenthesized form
let use_ops_paren_throws = fn (o: OpsT) -> i64 throws { FieldCallExn } do
  return (o.run)()
end

// Record with multiple function fields
type MultiOps = { add: (a: i64, b: i64) -> i64, negate: (x: i64) -> i64 }

let use_multi_add = fn (m: MultiOps) -> i64 throws { Exn } do
  return m.add(a: 10, b: 32)
end

let use_multi_negate = fn (m: MultiOps) -> i64 throws { Exn } do
  return m.negate(x: 42)
end

let main = fn () -> unit throws { Exn } do
  let ops: Ops = { run: fn () -> i64 do return 42 end }

  // (A) Direct field call — plain arrow
  let v1 = use_ops(o: ops)
  test_assert.assert_eq_i64(actual: v1, expected: 42, label: "A plain direct")

  // (B) Parenthesized field call — plain arrow
  let v2 = use_ops_paren(o: ops)
  test_assert.assert_eq_i64(actual: v2, expected: 42, label: "B plain paren")

  // Multi-field ops
  let mops: MultiOps = {
    add: fn (a: i64, b: i64) -> i64 do return a + b end,
    negate: fn (x: i64) -> i64 do return 0 - x end
  }
  let v3 = use_multi_add(m: mops)
  test_assert.assert_eq_i64(actual: v3, expected: 42, label: "multi-field add")
  let v4 = use_multi_negate(m: mops)
  test_assert.assert_eq_i64(actual: v4, expected: -42, label: "multi-field negate")

  return ()
end
