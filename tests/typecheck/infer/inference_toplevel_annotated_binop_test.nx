// Top-level annotated let-bindings and return-position literal binops narrow
// to the declared type instead of defaulting to i64 / f64.
//
// Top-level `let _x: T = <binop>` is lowered as a zero-arg function with
// return type T; the annotation hint must be threaded into the return-position
// binop inference so the literal op narrows to T.
//
// Unannotated returns still default to i64 / f64 (regression guard).
import * as test_assert from "std:test/assert"

// Positive compile-only: successful compilation is the assertion.
let _int32: i32 = 1 + 1
let _float32: f32 = 1.0 +. 2.0
let _float64: f64 = 1.0 +. 2.0
let _nested_i32: i32 = 2 * 3 - 1

// Return-position narrowing inside an annotated function.
let ret_i32 = fn () -> i32 do
  return 1 + 1
end

let ret_f32 = fn () -> f32 do
  return 1.0 +. 2.0
end

// Regression guard: unannotated return defaults to i64.
let ret_default_int = fn () -> i64 do
  return 1 + 1
end

let main = fn () -> unit throws { Exn } do
  // Runtime checks pin the narrowed values.
  test_assert.assert_eq_i64(actual: ret_default_int(), expected: 2, label: "unannotated return defaults to i64")
  return ()
end
