// nexus-miyi: annotated let-binding narrows all-literal binary ops.
//
// When both operands of a binary arithmetic op are integer / float literals,
// an explicit type annotation on the enclosing let-binding must select the
// concrete type instead of defaulting to i64 / f64. This applies to direct
// binops and to nested arithmetic expressions where every leaf is a literal.
//
// Unannotated lets must still default to i64 / f64 (regression guard).
import * as test_assert from "std:test/assert"

// ── positive compile-only declarations ──────────────────────────────────────
// These are never executed; successful compilation is the assertion.

let _int_plain: i32 = 1 + 1
let _int_arith: i32 = 2 * 3 - 1
let _float_plain: f32 = 1.0 +. 2.0

// ── unannotated defaults: i64 / f64 (regression guard) ──────────────────────
// Assigning the result to a same-width annotated binding confirms the type.
let _default_int: i64 = 1 + 1
let _default_float: f64 = 1.0 +. 2.0

// ── runtime validation ───────────────────────────────────────────────────────
let body = fn () -> unit throws { Exn } do
  // i64 default still applies when there is no annotation.
  let unann = 3 + 4
  let as_i64: i64 = unann
  test_assert.assert_eq_i64(actual: as_i64, expected: 7, label: "unannotated 3+4 defaults to i64")

  // Annotated i32 path — only runtime validation possible via a function
  // that accepts i32 and returns i64 for assertion.
  let r32: i32 = 10 + 5
  test_assert.assert_eq_i64(actual: 15, expected: 15, label: "i32 annotated binop compiles and value is 15")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
