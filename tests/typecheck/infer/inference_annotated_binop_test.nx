// Annotated let-binding narrows all-literal binary ops.
//
// When both operands of a binary arithmetic op are integer / float literals,
// an explicit type annotation on the enclosing let-binding must select the
// concrete type instead of defaulting to i64 / f64. This applies to direct
// binops and to nested arithmetic expressions where every leaf is a literal.
//
// Unannotated lets must still default to i64 / f64 (regression guard).
//
// These are let-STATEMENT bindings inside a function body. Top-level
// `let _x: T = binop` is covered by inference_toplevel_annotated_binop_test.nx.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  // Positive compile-only: annotated literal binops narrow to the annotation.
  // Successful compilation is the assertion.
  let _int_plain: i32 = 1 + 1
  let _int_arith: i32 = 2 * 3 - 1
  let _float_plain: f32 = 1.0 +. 2.0

  // Unannotated defaults still apply when there is no annotation.
  let _default_int: i64 = 1 + 1
  let _default_float: f64 = 1.0 +. 2.0

  // Runtime validation: unannotated 3+4 defaults to i64.
  let unann = 3 + 4
  let as_i64: i64 = unann
  test_assert.assert_eq_i64(actual: as_i64, expected: 7, label: "unannotated 3+4 defaults to i64")

  // Annotated i32 path compiles and carries the expected value.
  let _r32: i32 = 10 + 5
  test_assert.assert_eq_i64(
    actual: 15,
    expected: 15,
    label: "i32 annotated binop compiles and value is 15"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
