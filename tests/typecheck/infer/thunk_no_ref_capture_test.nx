// Positive control for the nexus-vi3v3 thunk-ref-capture rejection.
//
// The fix in src/typecheck/infer/stmt_eval.nx rejects a `let @t = e` whose
// suspended body `e` reads a stack-confined `~`-mutable ref (the same premise
// T-Lambda enforces on closures). This test pins the OTHER side of that gate:
// a `let @t` whose body does NOT read any ref must still type-check and run.
//
// Covered shapes:
//   - reading an ordinary (non-ref) outer `let` binding inside the thunk
//   - a pure literal thunk
//   - a `~`-ref EXISTS in scope but the thunk does not capture it (the scan
//     must only flag refs the thunk actually reads, not refs merely in scope)
//   - an inner binder shadowing the ref's name, so the thunk body's reference
//     resolves to the shadow rather than the outer ref
//
// All four must be accepted; the file must compile and exit 0.

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

// Thunk reads an ordinary non-ref outer binding — accepted.
let plain_outer = fn () -> i64 do
  let y = 41
  let @t = y + 1
  return @t
end

// Pure literal thunk — accepted.
let pure_literal = fn () -> i64 do
  let @t = 6 * 7
  return @t
end

// A `~`-ref is in scope but the thunk does not read it — accepted (the scan
// must not over-reject merely because a ref binding is visible).
let ref_in_scope_unread = fn () -> i64 do
  let ~counter = 100
  let @t = 1 + 2
  ~counter <- ~counter + 1
  return @t + ~counter
end

// An inner lambda parameter shadows the ref's name; the thunk body's `x`
// resolves to the parameter, not the outer `~x` — accepted.
let shadowed_ref_name = fn () -> i64 do
  let ~x = 999
  let bump = fn (x: i64) -> i64 do return x + 1 end
  let @t = bump(x: 5)
  ~x <- ~x + 1
  return @t + ~x
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: from_i64(val: plain_outer()))
    Console.println(val: from_i64(val: pure_literal()))
    Console.println(val: from_i64(val: ref_in_scope_unread()))
    Console.println(val: from_i64(val: shadowed_ref_name()))
  end
  return ()
end
