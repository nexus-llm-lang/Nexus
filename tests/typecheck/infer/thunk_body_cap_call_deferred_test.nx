// Positive test: T-App require-row deferral for @-thunk-wrapped calls.
//
// When a call to a cap-requiring function appears as the RHS of a `let @x = e`
// thunk binding, the callee's require row must NOT be charged eagerly against
// the ambient.  Instead, the required capabilities are carried on the TyLazy
// thunk type and discharged at the force site (`@x`), where inject-provided
// capabilities are in scope.
//
// This is the regression test for nch0x's T-App require-row enforcement, which
// over-rejected valid thunk-wrapped calls by charging the require row at
// thunk-creation time instead of deferring to the force site.

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

let expensive = fn (label: string) -> i64 require { Console } do
  Console.println(val: "computing " ++ label ++ "...")
  return 7 * 6
end

// Case 1: `let @n = expensive(...)` inside `inject system_handler` — the
// ambient at thunk-creation includes Console (via inject), so the thunk's
// deferred require_row carries Console, and the force inside inject is admitted.
let main_case1 = fn () -> unit require { PermConsole } do
  inject system_handler do
    let @n = expensive(label: "n")
    let v = @n
    Console.println(val: from_i64(val: v))
  end
  return ()
end

// Case 2: pure thunk (no require row) — always admitted regardless of context.
let compute_pure = fn () -> i64 do
  return 42
end

let force_pure = fn () -> i64 do
  let @t = compute_pure()
  return @t
end

let main = fn () -> unit do
  return ()
end
