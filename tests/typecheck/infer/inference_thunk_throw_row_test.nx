// Positive test for nexus-v3xa.15: thunk throw_row in type annotations.
//
// 1. A pure `@i64` (TyLazy(i64, {}, {})) can be forced inside `throws {}`.
// 2. A thunk passed as `@i64` parameter works normally.
import * as test_assert from "std:test/assert"

// Forcing a pure `@i64` under `throws {}` is accepted.
let force_pure = fn (th: @i64) -> i64 throws {} do
  return @th
end

let body = fn () -> unit throws { Exn } do
  // Pure thunk: force under throws {} succeeds.
  let @t1 = 42
  let v = force_pure(th: t1)
  test_assert.assert_eq_i64(actual: v, expected: 42, label: "pure thunk force under throws {}")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
