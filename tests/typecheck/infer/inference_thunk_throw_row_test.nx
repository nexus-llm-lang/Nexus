// Positive test: thunk throw_row in type annotations.
//
// A bare `@i64` annotation defaults its throws to the implicit OPEN row
// (effect-polymorphic, like an unannotated arrow), so a thunk forced under
// `throws {}` must be the EXPLICIT closed-pure form `@(i64 throws {})` — the
// same way `(i64) -> i64` (open) differs from `(i64) -> i64 throws {}` (pure).
// 1. A pure `@(i64 throws {})` can be forced inside `throws {}`.
// 2. A thunk passed as an explicit-pure thunk parameter works normally.
import * as test_assert from "std:test/assert"

// Forcing a pure `@(i64 throws {})` under `throws {}` is accepted.
let force_pure = fn (th: @(i64 throws {})) -> i64 throws {} do
  return @th
end

let body = fn () -> unit throws { Exn } do
  // Pure thunk: force under throws {} succeeds.
  let @t1 = 42
  let v = force_pure(th: t1)
  test_assert.assert_eq_i64(actual: v, expected: 42, label: "pure thunk force under throws {}")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
