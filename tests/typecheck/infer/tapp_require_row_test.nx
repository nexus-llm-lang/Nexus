// Positive test for T-App capability-row enforcement.
//
// Case 1: a caller that declares `require { Net }` can call a parameter
// whose arrow type also declares `require { Net }` — the ambient row covers
// the callee's require row, so T-App's premise is satisfied.
//
// Case 2: a caller with an open/unspecified require row passes an annotated
// `() -> i64 require { Net }` function to a higher-order function — admitted
// because the open-row ambient covers any closed callee row.

cap Net do
  fn fetch() -> i64
end

// Case 1: caller declares require { Net }, param requires { Net } — admitted.
let call_with_net = fn (f: () -> i64 require { Net }) -> i64 require { Net } do
  return f()
end

// Case 2: a function with an empty require row calling a parameter that has
// an empty require row — always admitted.
let call_pure_with_pure = fn (f: () -> i64) -> i64 do
  return f()
end

// Case 3: callee with empty require row called from a Net-requiring context —
// empty require is always a subset of any ambient row.
let call_pure_in_net_context = fn (f: () -> i64) -> i64 require { Net } do
  return f()
end

let main = fn () -> unit do
  return ()
end
