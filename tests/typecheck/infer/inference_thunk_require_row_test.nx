// Positive test for nexus-8tgwr item 1: T-Force require_row discharge.
//
// 1. A thunk annotated `@(i64 require { Logger })` can be forced inside a
//    function that declares `require { Logger }` (cap is in the ambient row).
// 2. A pure `@i64` (require {}) can be forced inside a function with any
//    require row (empty require is a subset of everything).

cap Logger do
  fn log(msg: string) -> unit
end

// Case 1: require { Logger } ambient satisfies @(i64 require { Logger }).
// The `require { Logger }` is load-bearing: it discharges the thunk's own
// require row at the `@th` force site. The L0002 unused-cap rule only counts
// explicit `Logger.*` calls and doesn't model force-site discharge, so it
// would flag this row as unused; suppress it (the discharge IS the point).
// lint:allow-next L0002
let force_with_logger = fn (th: @(i64 require { Logger })) -> i64 require { Logger } do
  return @th
end

// Case 2: empty require {} thunk forced anywhere — always admitted.
let force_pure = fn (th: @i64) -> i64 do
  return @th
end

let main = fn () -> unit do
  return ()
end
