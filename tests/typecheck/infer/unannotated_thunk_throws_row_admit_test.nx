// Positive companion to the unannotated-thunk throws-row pinning fix.
//
// An unannotated `let @th = thrower()` pins the thunk's collecting throws-row
// to include the exception the suspended call can raise (T-Raise). Forcing
// that thunk through a parameter slot whose declared row ADMITS the exception
// (T-Force) must still typecheck and run — the fix pins exactly the raised
// variant and must not over-reject a sound program.
//
//   - exact slot `@(i64 throws { E })`            (raised set == declared set)
//   - wider comma-row slot `@(i64 throws { E, F })` (raised set ⊆ declared set)
import * as test_assert from "std:test/assert"

exception E
exception F

// Forces a thunk whose declared throws-row is exactly { E }.
let force_e = fn (t: @(i64 throws { E })) -> i64 throws { E } do
  return @t
end

// Forces a thunk through a wider declared row { E, F }.
let force_ef = fn (t: @(i64 throws { E, F })) -> i64 throws { E, F } do
  return @t
end

let thrower = fn () -> i64 throws { E } do
  throw E
end

// Unannotated thunk into the exact slot: forces, the deferred E surfaces,
// and is caught here.
let run_exact = fn () -> i64 throws { Exn } do
  try
    let @th = thrower()
    return force_e(t: th)
  catch _ ->
    return 1
  end
end

// Unannotated thunk into the wider comma-row slot.
let run_wide = fn () -> i64 throws { Exn } do
  try
    let @th = thrower()
    return force_ef(t: th)
  catch _ ->
    return 2
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: run_exact(),
    expected: 1,
    label: "unannotated thunk into exact { E } slot forces and surfaces E"
  )
  test_assert.assert_eq_i64(
    actual: run_wide(),
    expected: 2,
    label: "unannotated thunk into wider { E, F } slot forces and surfaces E"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
