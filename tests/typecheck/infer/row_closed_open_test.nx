// Regression for nexus-hogq: U-Row-Closed-Open must bind the open tail
// variable to the residual closed row, not leave it unconstrained.
//
// Spec (type-system-formal.md §Unification, U-Row-Closed-Open):
//
//   c = ts1 ∩ ts2,  r1 = ts1 \ c,  r2 = ts2 \ c
//   r2 = ∅,  unify(?t2, { r1 })
//   ──────────────────────────────────────────────
//   unify({ ts1 }, { ts2 | ?t2 })
//
// The bug: the old implementation returned UnifyOk(empty) in the
// None-r1 / Some-r2 branch without performing the binding
//   ?t2 := TyRow(types: e1r, rest: None)
// so ?t2 remained as a free unification variable.
//
// Test strategy: use a row-polymorphic combinator whose throws-row
// variable R is unified against a concrete closed row at the call site.
// With the fix, R is pinned to the correct closed row and the program
// typechecks and runs correctly.

import * as test_assert from "std:test/assert"

exception HogqExn(msg: string)

// Row-polymorphic wrapper: at the call site the throws-row variable R
// must unify with the callee's closed row via U-Row-Closed-Open:
//   unify({ Exn }, { | ?R })  -->  ?R := { Exn }
let call_with = fn <R>(f: () -> i64 throws R) -> i64 throws R do
  return f()
end

// Concrete callee with a specific closed throws row.
let throws_exn = fn () -> i64 throws { Exn } do
  throw HogqExn(msg: "hogq test exception")
end

// Pure callee: empty closed throws row.
let pure_fn = fn () -> i64 do
  return 42
end

// Wraps call_with(throws_exn) and catches the exception.
let run_throwing = fn () -> i64 throws { Exn } do
  try
    let v = call_with(f: throws_exn)
    return v
  catch _e ->
    return -1
  end
end

// Wraps call_with(pure_fn) — no exception expected.
let run_pure = fn () -> i64 do
  return call_with(f: pure_fn)
end

let main = fn () -> unit throws { Exn } do
  // Case 1: closed { Exn } unified with open ?R => R pinned to { Exn }.
  let v1 = run_throwing()
  test_assert.assert_eq_i64(
    actual: v1,
    expected: -1,
    label: "hogq: closed-open tail binds to {Exn} (throw caught)"
  )

  // Case 2: empty closed {} unified with open ?R => R pinned to {}.
  let v2 = run_pure()
  test_assert.assert_eq_i64(
    actual: v2,
    expected: 42,
    label: "hogq: closed-open empty residual binds to {}"
  )

  return ()
end
