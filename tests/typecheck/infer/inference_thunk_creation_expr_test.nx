/**
 * Positive typecheck: the `@(expr)` thunk-creation expression has type `@T`.
 *
 * `@(40 + 2)` produces a `@i64` that unifies with the annotation `@i64`, and
 * passing it where a `@i64` parameter is expected typechecks. Forcing yields
 * the underlying `i64`. Pre-fix `@(expr)` parsed as a force and was rejected.
 */
import * as test_assert from "std:test/assert"

let force_it = fn (th: @i64) -> i64 do
  return @th
end

let body = fn () -> unit throws { Exn } do
  let d: @i64 = @(40 + 2)
  let v = force_it(th: d)
  test_assert.assert_eq_i64(actual: v, expected: 42, label: "@(expr) infers as @i64")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
