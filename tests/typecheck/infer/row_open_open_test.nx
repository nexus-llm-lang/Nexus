// Regression for nexus-s7hf: U-Row-Open-Open must introduce a fresh row
// variable ?γ and distribute residuals, not directly unify the two tails.
//
// Spec (type-system-formal.md §Unification, U-Row-Open-Open):
//
//   c = ts1 ∩ ts2,  r1 = ts1 \ c,  r2 = ts2 \ c
//   ?γ fresh
//   unify(?t1, { r2 | ?γ }),  unify(?t2, { r1 | ?γ })
//   ──────────────────────────────────────────────────
//   unify({ ts1 | ?t1 }, { ts2 | ?t2 })
//
// The bug: the old implementation called unify(tail1, tail2) directly,
// which bound ?t1 := ?t2 (or vice versa) without accounting for the
// residuals r1, r2.  This is only correct when r1 = r2 = [] (both tails
// have the same entries).  When r1 ≠ [] or r2 ≠ [], the direct binding
// loses the residual entries.
//
// Test strategy: use row-polymorphic wrappers with distinct throw entries
// and compose them through a higher-order combinator that must unify the
// two open rows. With the fix the wrapper can type-check; without the fix
// the tail unification loses residual throws entries.

import * as test_assert from "std:test/assert"

exception S7hfExn(msg: string)

// Wrap a call and catch any exception, returning a sentinel on throw.
let safe_call = fn <R>(f: () -> i64 throws R) -> i64 throws { Exn } do
  let result = 0
  try
    let v = f()
    return v
  catch _e ->
    return -1
  end
end

// Two pure callees: empty closed throw rows.
let pure1 = fn () -> i64 do return 10 end
let pure2 = fn () -> i64 do return 20 end

// One thrower: closed throw row { Exn }.
let throws_exn = fn () -> i64 throws { Exn } do
  throw S7hfExn(msg: "s7hf test")
end

// Sequence two safe_call invocations. Each safe_call<R> uses U-Row-Open-Open
// when R is unified against the callee's throw row. With the fix:
//   - For pure callees: R={}  (trivial case, r1=r2=[])
//   - For a thrower callee: R={Exn} bound correctly via U-Row-Closed-Open
// The two safe_call invocations are independent; their respective ?R vars
// are each unified with the concrete callee rows separately.
let sequence_safe = fn (
  a: i64,
  b: i64
) -> i64 do
  return a + b
end

let main = fn () -> unit throws { Exn } do
  // Case 1: both pure — trivial case (r1=r2=[], fresh ?γ={}).
  let v1 = sequence_safe(
    a: safe_call(f: pure1),
    b: safe_call(f: pure2))
  test_assert.assert_eq_i64(actual: v1, expected: 30, label: "s7hf: open-open both pure, residuals empty")

  // Case 2: one thrower, one pure.
  let v2 = sequence_safe(
    a: safe_call(f: throws_exn),
    b: safe_call(f: pure2))
  test_assert.assert_eq_i64(actual: v2, expected: -1 + 20, label: "s7hf: open-open one thrower, residual distributed")

  // Case 3: both throw — same entry Exn on both sides (r1=r2=[], common entry).
  let v3 = sequence_safe(
    a: safe_call(f: throws_exn),
    b: safe_call(f: throws_exn))
  test_assert.assert_eq_i64(actual: v3, expected: -1 + -1, label: "s7hf: open-open both throw, common entry")

  return ()
end
