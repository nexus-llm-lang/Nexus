// Port of bootstrap/tests/typecheck/linearity.rs::
// test_try_catch_arm_consumes_pre_try_linear_pass.
//
// Strategy A (issue nexus-7eex.1): a `try` body's catch arm inherits the
// linear-set snapshot taken *before* the try body. When a linear bound
// before `try` is consumed both inside the try body and inside the
// catch arm, the per-arm linear-set check passes.
import * as test_assert from "std:test/assert"

exception Oops(msg: string)
type Token = { id: i64 }

let may_throw = fn () -> unit throws { Exn } do
  raise Oops(msg: "boom")
  return ()
end

// Returns 1 if the function typechecks and runs the catch path; the
// raise inside the try transfers control to the catch arm where %t is
// finally consumed.
let consume_in_try_or_catch = fn () -> i64 do
  let %t: Token = { id: 1 }
  try
    may_throw()
    match %t do | { id: _ } -> () end
    return 0  // unreachable in this fixture (raise above)
  catch _ ->
    match %t do | { id: _ } -> () end
    return 1
  end
end

let body = fn () -> unit throws { Exn } do
  let r = consume_in_try_or_catch()
  test_assert.assert_eq_i64(actual: r, expected: 1, label: "catch-arm consumed pre-try linear")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
