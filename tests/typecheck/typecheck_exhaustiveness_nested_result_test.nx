// A nested `match` on `Result<Result<i64, i64>, i64>` covers the three
// shapes (Ok(Ok), Ok(Err), Err) — exhaustiveness must thread through
// nested constructor patterns.
import * as test_assert from "std:test/assert"

let label = fn (x: Result<Result<i64, i64>, i64>) -> i64 do
  match x do
    | Ok(val: Ok(val: v)) -> return v
    | Ok(val: Err(err: e)) -> return 100 + e
    | Err(err: e) -> return 200 + e
  end
end

let body = fn () -> unit throws { Exn } do
  let r1: Result<Result<i64, i64>, i64> = Ok(val: Ok(val: 7))
  test_assert.assert_eq_i64(actual: label(x: r1), expected: 7, label: "Ok(Ok)")
  let r2: Result<Result<i64, i64>, i64> = Ok(val: Err(err: 3))
  test_assert.assert_eq_i64(actual: label(x: r2), expected: 103, label: "Ok(Err)")
  let r3: Result<Result<i64, i64>, i64> = Err(err: 5)
  test_assert.assert_eq_i64(actual: label(x: r3), expected: 205, label: "Err")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
