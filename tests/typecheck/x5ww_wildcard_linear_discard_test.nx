// Regression: nexus-x5ww — `let _ = e` must reject when `e` evaluates to a
// structurally-linear (non-auto-droppable) value, but must continue to
// accept the explicit-discard idiom for auto-droppable linears (`%i64`).
//
// This is the *positive* fixture (must compile cleanly): the body
// exercises the legitimate paths that the fix preserves. The negative
// shape (a `let _ = open_handle()` that previously slipped through) is
// pinned in `x5ww_wildcard_linear_discard_negative.nx` (no `_test`
// suffix → outside `nexus test` discovery).
//
// The x5ww fix has been reverted on main pending re-investigation. Both
// arms of this test still pass against the reverted source: the bug is
// "non-auto-droppable linears slip through unchecked", which doesn't
// regress the behaviour exercised here. The negative companion is the
// one that becomes the green-light signal when the fix re-lands.
import * as test_assert from "std:test/assert"

// Auto-droppable linear primitive — wildcard discard via Variable RHS still
// passes (the existing idiom for `%i64`).
let primitive_path = fn () -> i64 do
  let %y = 20
  let _ = %y
  return 0
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: primitive_path(), expected: 0, label: "primitive linear wildcard discard")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
