// Port of bootstrap/tests/typecheck/inference.rs::test_record_access.
// The original Rust test only exercised the *typecheck* path with
// `Box<T> = { val: T }` — it didn't run any code. The self-host LIR
// lowering currently rejects field access on user-defined generic
// record types ("field access '.val' on non-record type
// UserDefined(\"Box\", [...])"), so we exercise the same shape via
// anonymous records (which lower correctly) and pin the original
// type-definition + accessor as a typecheck-only declaration whose
// arrow type the rest of the program never invokes.
import * as test_assert from "std:test/assert"

type Box<T> = { val: T }

// Top-level signature: must typecheck. Body never executes at runtime
// because `unbox_decl` is never called.
let unbox_decl = fn <T>(b: Box<T>) -> T do
  return b.val
end

let body = fn () -> unit throws { Exn } do
  // Anonymous-record analogue of Box, used at runtime.
  let bi = { val: 42 }
  let bs = { val: "hi" }
  test_assert.assert_eq_i64(actual: bi.val, expected: 42, label: "anon-Box<i64>")
  test_assert.assert_eq_string(actual: bs.val, expected: "hi", label: "anon-Box<string>")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
