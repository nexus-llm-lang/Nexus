// Port of bootstrap/tests/typecheck/inference.rs::
// test_int_literal_defaults_to_i64,
// test_int_literal_annotation_can_select_i32.
//
// Bare integer literals default to i64; an explicit `: i32` annotation
// re-selects them to i32 and arithmetic stays inside i32. The i32 path
// is currently typecheck-only in self-host (component composition has a
// codegen gap on i32 sites), so we declare it as an unused top-level
// binding and drive the i64 path at runtime.
import * as test_assert from "std:test/assert"

// Typecheck-only i32 declarations. They must compile but are never
// executed; the runtime body below drives the i64 path.
let _i32_a: i32 = 1
let _i32_arith = fn (a: i32) -> i32 do
  let b = a + 2
  return b
end
let _i32_eq = fn (a: i32, b: i32) -> bool do
  return a == b
end

let body = fn () -> unit throws { Exn } do
  // Default-i64 path: x has no annotation, then flows into an i64 result.
  let x = 1
  let y: i64 = x + 41
  test_assert.assert_eq_i64(actual: y, expected: 42, label: "int literal defaults to i64")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
