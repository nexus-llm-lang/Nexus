// Port of bootstrap/tests/typecheck/inference.rs::
// test_named_function_can_be_used_as_value,
// test_inline_lambda_literal_typechecks.
//
// A `let f = id` binding promotes a top-level non-generic function to a
// first-class value; an inline `fn (...) do ... end` literal is also a
// value of arrow type.
import * as test_assert from "std:test/assert"

let id_i64 = fn (x: i64) -> i64 do
  return x
end

let body = fn () -> unit throws { Exn } do
  let f = id_i64
  let n = f(x: 42)
  test_assert.assert_eq_i64(actual: n, expected: 42, label: "named fn as value")

  let g = fn (x: i64) -> i64 do
    return x + 1
  end
  let m = g(x: 41)
  test_assert.assert_eq_i64(actual: m, expected: 42, label: "inline lambda literal")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
