// Regression: `throws { ExceptionGroup }` callee called from a `throws {
// Exn }` caller previously failed the bootstrap-Rust row unifier with
// "Row mismatch". Pass 2 of `infer_program` in
// `bootstrap/src/lang/typecheck/mod.rs` re-stored the lambda's scheme
// using the raw `throws` annotation without applying
// `expand_exception_groups_in_throws`. Pass 1 expanded groups, but
// Pass 2's overwrite shadowed the expanded form, so a callee declaring
// `throws { Errors }` was queried as `Row([Errors], None)` instead of
// `Row([Exn], None)`. The call site's row-subsumption fallback then
// unified `Row([Exn], None)` (caller's row) with `Row([Errors], None)`
// (callee's row, post-overwrite) and tripped the asymmetric branch in
// the row unifier.
//
// Tested direction (subsumption-legal): narrow (group) callee → broad
// ({Exn}) caller. Pre-fix this failed Stage 0 with "Row mismatch" because
// Pass 2's lambda inference stored the callee scheme with the unexpanded
// `throws { ExceptionGroup }`, so unify saw Row([ExceptionGroup], None)
// vs Row([Exn], None) and tripped the asymmetric branch. Post-fix Pass 2
// uses expand_exception_groups_in_throws (mirroring Pass 1), so the
// callee scheme stores the expanded Row([Exn], None) and unification
// succeeds.

exception LocalErr
exception OtherErr
exception group ExceptionGroup = LocalErr | OtherErr

// narrow (group) callee, broad ({Exn}) caller — the canonical xhhq shape.
let callee_group = fn () -> i64 throws { ExceptionGroup } do
  raise LocalErr
end

let caller_broad = fn () -> i64 throws { Exn } do
  return callee_group()
end

// Top-level driver wraps the throwable caller via statement-form try/catch.
let drive_broad = fn () -> i64 do
  try
    let _ = caller_broad()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let r1 = drive_broad()
  // r1 == 0 means catch arm fired (raise propagated through the previously
  // failing call site). 1 - r1 == 1; 100 / 1 == 100, no trap.
  let _ = 100 / (1 - r1)
  return ()
end
