// Negative fixture for nexus-t9cl.23 — inner `let f = fn <T>(x: T) -> T`
// must be REJECTED with a diagnostic that names "inner lambda" and
// references the T-Let-PolyFn spec section. Pre-fix the quantifier list
// was silently dropped and the user saw "cannot unify int literal with
// non-integer type"; post-fix the diagnostic points at the actual cause.
// Kept out of `nexus test` discovery by the missing `_test` suffix.
let main = fn () -> unit do
  let f = fn <T>(x: T) -> T do
    return x
  end
  let _ = f(x: 42)
  return ()
end
