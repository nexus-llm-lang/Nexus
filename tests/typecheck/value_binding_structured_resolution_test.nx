/** Regression: a top-level value binding `let x = <non-literal>` carries no
 *  annotation, so HIR build registers it with the `() -> i64` placeholder
 *  return type. The value-binding pre-pass (resolve_value_binding_types) infers
 *  the binding's REAL structured type and re-publishes its scheme as `() ->
 *  realT`, so a referrer sees `realT`, never the placeholder `i64` (which would
 *  surface as "[E2001] expected arrow type" / a type mismatch at a ctor-field,
 *  call-arg, or if-branch use of the binding).
 *
 *  Each referrer below is DEFINED BEFORE the value binding it consumes, so the
 *  fix must not depend on definition order. A genuine thunk binding `let t: @T
 *  = @e` keeps its `@T` type because the pre-pass only touches bindings whose
 *  declared return type is exactly the `i64` placeholder, never an explicitly
 *  thunk-typed (`@T`) binding; `force_local_thunk` exercises that a thunk-typed
 *  binding still forces to its inner value, unchanged by the pass. */
import * as test_assert from "std:test/assert"

type Span = Span(offset: i64, line: i64, col: i64)
type Node = Node(name: string, span: Span)

/** Referrer DEFINED BEFORE the structured value binding it consumes, in a
 *  ctor-field position — the `zero_span` cluster archetype. */
let make_node = fn (nm: string) -> Node do
  return Node(name: nm, span: zero_span)
end

/** Referrer using the structured value binding as an `if`-branch result — the
 *  position the per-syntax-site auto-force peels did not previously cover. */
let span_or_default = fn (use_real: bool, real: Span) -> Span do
  if use_real then return real else return zero_span end
end

/** The forward-referenced, non-i64 value binding. Its initializer is a ctor
 *  call, so HIR build defaults its declared type to the `i64` placeholder. */
let zero_span = Span(offset: 0, line: 0, col: 0)

/** Genuine thunk: a `@i64`-typed binding forced at its use site keeps its thunk
 *  type. The pre-pass never narrows a thunk-typed binding (its declared type is
 *  `@i64`, not the `i64` placeholder), so the force still yields the inner i64. */
let force_local_thunk = fn (n: i64) -> i64 do
  let @t = n + 4
  return @t
end

let main = fn () -> unit throws { Exn } do
  let Node(name: nm, span: Span(offset: o, line: ln, col: c)) = make_node(nm: "root")
  test_assert.assert_eq_i64(actual: o, expected: 0, label: "ctor-field-structured-vb-offset")
  test_assert.assert_eq_i64(actual: ln, expected: 0, label: "ctor-field-structured-vb-line")
  test_assert.assert_eq_i64(actual: c, expected: 0, label: "ctor-field-structured-vb-col")

  let Span(
    offset: o2,
    line: _,
    col: _
  ) = span_or_default(use_real: false, real: Span(offset: 9, line: 9, col: 9))
  test_assert.assert_eq_i64(actual: o2, expected: 0, label: "if-branch-structured-vb")

  let Span(
    offset: o3,
    line: _,
    col: _
  ) = span_or_default(use_real: true, real: Span(offset: 9, line: 9, col: 9))
  test_assert.assert_eq_i64(actual: o3, expected: 9, label: "if-branch-real-arg")

  test_assert.assert_eq_i64(
    actual: force_local_thunk(n: 3),
    expected: 7,
    label: "genuine-thunk-kept"
  )
  return ()
end
