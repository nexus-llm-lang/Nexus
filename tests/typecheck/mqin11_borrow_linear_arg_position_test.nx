// Positive fixture for nexus-mqin.11 — the argument-position carve-out
// for T-Borrow.
//
// Spec (docs/spec/type-system-formal.md §T-Borrow + §T-App):
//   At call sites, a `&x` argument passing a borrow of a `%T`/`@T`/`~T`
//   binding does NOT consume the binding's modality — the callee receives
//   `&T`, the borrow is discharged when the call returns, and the
//   binding's original linearity is preserved for downstream consumption.
//
//   This carve-out distinguishes argument position from let-bind position:
//   `let r = &b` creates a fresh `&T` binding with no natural discharge
//   point (rejected, see the matching `_negative.nx` fixture); `f(p: &b)`
//   bounds the borrow's lifetime to the call.
//
// The canonical compiler-side pattern this protects:
//   let %effect_map = analyze_effects(program: lir)
//   ... effect_analysis.effect_map_size(em: &effect_map) ...   // arg position
//   ... lir_opt.optimize_lir_with_effects(effects: &effect_map) ...
//
// Pre-fix, the typechecker accepted both let- and arg-position borrows of
// linear bindings indiscriminately. The mqin.11 fix narrows rejection to
// let-position only; this fixture pins the arg-position survival.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

let body = fn () -> unit throws { Exn } do
  // bb.empty() returns `%ByteBuffer`; b is a linear binding.
  let %b = bb.empty()
  // Arg-position borrow of the linear binding — bb.length takes
  // &ByteBuffer. T-App's borrow-arg carve-out keeps `b` consumable.
  let n = bb.length(buf: &b)
  // Linear `b` is still live after the borrow-arg call; consume it
  // before the throwable test_assert call (else the linearity pass
  // would object to b living across a throwable call).
  bb.free(buf: %b)
  test_assert.assert_eq_i64(actual: n, expected: 0, label: "empty buf has length 0")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
