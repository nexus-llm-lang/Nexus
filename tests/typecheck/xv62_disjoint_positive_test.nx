// Positive fixture for nexus-xv62: with the disjoint-union check in
// place, distinct sibling binders and any number of `_` wildcards
// must still typecheck cleanly. The negative fixtures
// (`xv62_*_repro.nx`, no `_test` suffix) cover the rejection side;
// this file pins the must-still-work side so we don't accidentally
// over-reject.
import * as test_assert from "std:test/assert"

type Pair = MkPair(a: i64, b: i64)
type Recd = { a: i64, b: i64 }
type Inner = MkInner(x: i64)
type Outer = MkOuter(a: Inner, b: i64)

let pair_sum = fn (p: Pair) -> i64 do
  match p do
    | MkPair(a: x, b: y) -> return x + y
  end
end

let pair_drop_b = fn (p: Pair) -> i64 do
  // `_` is PWild and produces no binders, so siblings can each use it.
  match p do
    | MkPair(a: x, b: _) -> return x
  end
end

let pair_drop_both = fn (p: Pair) -> i64 do
  match p do
    | MkPair(a: _, b: _) -> return 0
  end
end

let rec_sum = fn (r: Recd) -> i64 do
  match r do
    | { a: x, b: y } -> return x + y
  end
end

let outer_sum = fn (o: Outer) -> i64 do
  match o do
    | MkOuter(a: MkInner(x: x), b: y) -> return x + y
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: pair_sum(p: MkPair(a: 1, b: 2)), expected: 3, label: "ctor disjoint binders")
  test_assert.assert_eq_i64(actual: pair_drop_b(p: MkPair(a: 7, b: 9)), expected: 7, label: "ctor sibling wildcards")
  test_assert.assert_eq_i64(actual: pair_drop_both(p: MkPair(a: 5, b: 6)), expected: 0, label: "ctor all wildcards")
  test_assert.assert_eq_i64(actual: rec_sum(r: { a: 4, b: 5 }), expected: 9, label: "record disjoint binders")
  test_assert.assert_eq_i64(actual: outer_sum(o: MkOuter(a: MkInner(x: 10), b: 20)), expected: 30, label: "nested ctor disjoint binders")
  return ()
end
