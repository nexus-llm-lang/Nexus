// Negative fixture for nexus-dp4e — T-Let-Alias pure(Γ\{y}) premise.
//
// Spec type-system-formal.md §T-Let-Alias requires `pure(Γ \ {y})` at the
// alias site. When a live linear binding (TyLinear / TyLazy) is present in
// scope at the alias site, the premise fails and the alias must be rejected.
//
// Pre-fix, `alias_poly_scheme` checked only that the RHS was a polymorphic
// variable, without verifying purity; the alias would silently succeed.
// Post-fix, `alias_poly_scheme` returns InferExprErr naming the live linear
// and the spec section.
//
// Filename intentionally omits `_test` so `nexus test` does not pick it
// up — a fixture that intentionally fails compile would otherwise be
// reported as a runner failure.
import * as bb from "std:bytebuffer"

let id = fn <T>(x: T) -> T do
  return x
end

let main = fn () -> unit do
  // %buf is TyLinear in the env at the alias site below.
  let %buf = bb.empty()
  // T-Let-Alias: pure(Γ \ {id}) fails because %buf is TyLinear.
  // Expected: E.... "T-Let-Alias requires pure(Γ\{id}) — a live linear binding..."
  let f = id
  let _ = f(x: 10)
  let _ = %buf
  return ()
end
