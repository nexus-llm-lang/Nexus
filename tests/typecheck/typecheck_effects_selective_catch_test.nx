// Port of bootstrap/tests/typecheck/effects.rs::
// test_selective_catch_constructor_field_binding,
// test_selective_catch_multiple_exceptions.
//
// Catch arms can pattern-match exception constructors and bind their
// payload fields with the declared types; multiple exception
// constructors share one `try`.
//
// Note: avoid placing a `return <int>` statement immediately after a
// `raise` inside the try body — that pattern hits a known wasm-codegen
// E2010 ("variable '__t2' has conflicting wasm local types") in the
// self-host backend. The fix is to move the unreachable return out of
// the try body, after `end`. Tracked separately from this port.
import * as test_assert from "std:test/assert"

exception Boom(code: i64)
exception Oops(msg: string)

// Returns the captured `code` on Boom, or a fixed sentinel when reached
// via Oops or wildcard. The post-`end` return is unreachable in this
// fixture (the raise inside the try body always fires) but satisfies
// the function-level i64 return-type check without poking the E2010
// edge case.
let classify_boom = fn () -> i64 do
  try
    raise Boom(code: 42)
  catch
    | Boom(code: code) ->
      let x: i64 = code
      return x
    | _ -> return -1
  end
  return -2
end

// Multi-exception catch: route Oops separately from Boom.
let classify_oops = fn () -> i64 do
  try
    raise Oops(msg: "hi")
  catch
    | Boom(code: code) -> return 1
    | Oops(msg: msg) -> return 2
    | _ -> return -1
  end
  return -2
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: classify_boom(), expected: 42, label: "catch Boom binds code")
  test_assert.assert_eq_i64(actual: classify_oops(), expected: 2, label: "catch routes Oops branch")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
