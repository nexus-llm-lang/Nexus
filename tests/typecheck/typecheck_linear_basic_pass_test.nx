// Port of bootstrap/tests/typecheck/linear.rs::test_linear_basic_pass,
// test_linear_param_accepts_plain_value_via_weakening,
// test_linear_primitive_auto_drop_pass,
// test_linear_primitive_wildcard_pass,
// test_linear_primitive_match_wildcard_pass.
//
// Linear primitives (i64, etc.) auto-drop when they go out of scope and
// can be discarded via `let _ = %x` or `match %x do | _ -> ... end`.
// A `%i64` parameter also accepts a plain i64 by weakening at the call
// site.
import * as test_assert from "std:test/assert"

let consume = fn (x: %i64) -> unit do
  match x do | _ -> () end
  return ()
end

// Returns 1 if consumption typechecks; the body is observably non-trivial
// because it consumes a linear-i64 parameter via match-wildcard.
let consume_to_one = fn (x: %i64) -> i64 do
  match x do | _ -> () end
  return 1
end

let body = fn () -> unit throws { Exn } do
  // Basic: pass a linear primitive into a function that consumes it.
  let %x = 10
  consume(x: %x)
  test_assert.assert_eq_bool(actual: true, expected: true, label: "linear primitive consumed by callee")

  // Weakening: a plain int literal flows into a `%i64` slot.
  let m = consume_to_one(x: 41)
  test_assert.assert_eq_i64(actual: m, expected: 1, label: "weakening plain int into linear slot")

  // Auto-drop: linear primitive falls out of scope without consumption.
  let %y = 20
  let _ = %y // explicit discard via wildcard, allowed for primitives
  let %z = 30
  match %z do | _ -> () end // match-wildcard discard, also allowed

  test_assert.assert_eq_bool(actual: true, expected: true, label: "auto-drop paths typecheck")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
