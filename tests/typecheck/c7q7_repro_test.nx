// Regression: `let d = if v == K then 1 else 0 end` followed by an integer
// operation on `d` previously failed self-host typechecking with E2001
// ("int op rhs: type mismatch"). Root cause: `infer_if` in
// src/typecheck/infer.nx returned TyUnit unconditionally, so the let-bound
// type was unit; the subsequent `1 / d` then tripped the int-binop unifier.
//
// The fix replaces `TyUnit` with the unified branch tail-expression type,
// mirroring the match-result path (`infer_match_cases`). This fixture
// pins the smallest reproducer reported in nexus-c7q7, plus a
// literal-only branch variant, plus a stand-alone `let d = if ...` that
// is later passed to a function expecting i64.
import * as test_assert from "std:test/assert"

let main = fn () -> unit throws { Exn } do
  // Original repro shape — bool-fork with integer literals on both arms.
  let v: i64 = 10
  let d = if v == 10 then 1 else 0 end
  let _ = 1 / d
  test_assert.assert_eq_i64(actual: d, expected: 1, label: "if/then/else binds i64")

  // else-branch taken
  let w: i64 = 5
  let e = if w == 10 then 7 else 11 end
  test_assert.assert_eq_i64(actual: e, expected: 11, label: "else taken")

  // Branch type flows into a downstream binop so we exercise unification
  // beyond the let-binding itself.
  let q = if v == 10 then 4 else 8 end
  test_assert.assert_eq_i64(actual: q * 2, expected: 8, label: "branch type into binop")

  return ()
end
