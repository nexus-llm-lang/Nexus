// Port of bootstrap/tests/typecheck/inference.rs::
// test_ref_creation_and_type, test_cannot_return_ref, test_ref_assignment,
// test_ref_read.
//
// Refs (`~name`) are created with `let ~c = expr`, assigned with
// `~c <- expr`, and read by name. They must remain in scope (cannot
// be returned) — but here the returned `i64` is the *contents* via
// dereference, which is allowed.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  // Creation + type, with no use beyond binding.
  let ~c = 0
  let _ = ~c

  // Assignment.
  let ~d = 0
  ~d <- 1
  test_assert.assert_eq_i64(actual: ~d, expected: 1, label: "ref assign updates contents")

  // Read into a fresh let.
  let ~e = 10
  let v = ~e
  test_assert.assert_eq_i64(actual: v, expected: 10, label: "ref read")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
