// Port of bootstrap/tests/typecheck/inference.rs::
// test_record_unification, test_anonymous_record (the typecheck
// shape — the original used Console.print for stdio observation; here
// we drop the side-effect and just bind / unify the record).
//
// Two anonymous records with the same fields in different orders must
// unify against the same parameter type.
import * as test_assert from "std:test/assert"

let take_record = fn (r: { x: i64, y: i64 }) -> i64 do
  return r.x + r.y
end

let body = fn () -> unit throws { Exn } do
  let r1 = { x: 1, y: 2 }
  let r2 = { y: 2, x: 1 }
  let s1 = take_record(r: r1)
  let s2 = take_record(r: r2)
  test_assert.assert_eq_i64(actual: s1, expected: 3, label: "record unify ordered")
  test_assert.assert_eq_i64(actual: s2, expected: 3, label: "record unify reordered")

  // Anonymous record with mixed-type fields and field-access typing.
  let r = { x: 7, y: "hello" }
  let i = r.x
  let t = r.y
  test_assert.assert_eq_i64(actual: i, expected: 7, label: "anon record .x")
  test_assert.assert_eq_string(actual: t, expected: "hello", label: "anon record .y")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
