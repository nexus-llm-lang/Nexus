// Negative fixture for nexus-t9cl.20 — T-App weakening must reject a
// borrow argument against a linear parameter.
//
// Spec (type-system-formal.md §T-App, §U-Borrow):
//   weakening: P = %σ ∧ ¬linear(τ_i) → unify(τ_i, strip(P))
//   U-Borrow:  ¬linear(τ_2)   unify(τ_1, τ_2)
//              ──────────────────────────────
//              unify(&τ_1, τ_2)
//
// Naively, linear(&σ) = false (per the spec §Linearity definition: "Borrows
// are *not* recursed into"), so weakening fires for arg_t = &σ against
// P = %σ — and the strip(%σ) = σ unification then succeeds, admitting &x
// where the callee expects %T. The result is **borrow-to-ownership
// smuggling**: the callee consumes the linear payload while the caller
// still believes x is live, enabling double-consume.
//
// The impl in src/typecheck/infer.nx::check_call_args_walk rejects this
// shape (TyBorrow arg against TyLinear param), closing the exploit even
// while the spec's weakening wording is refined upstream.
//
// Filename omits `_test` so the runner does not pick it up.
import * as bb from "std:bytebuffer"

let consume_lin = fn (%p: %bb.ByteBuffer) -> unit do
  bb.free(buf: %p)
  return ()
end

let main = fn () -> unit do
  let %x = bb.empty()
  // Pre-fix: typecheck succeeded (weakening stripped %ByteBuffer → ByteBuffer,
  // then U-Borrow's ¬linear premise saw τ_2 = ByteBuffer, non-linear → ok).
  // Post-fix: rejected at check_call_args_walk's TyLinear-weakening branch.
  consume_lin(p: &x)
  bb.free(buf: %x)
  return ()
end
