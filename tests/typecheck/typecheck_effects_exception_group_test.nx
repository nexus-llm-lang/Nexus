// `exception group` declares an alias matching any of its members. A
// catch arm `| GroupName -> ...` fires for every member exception. A
// `throws { GroupName }` annotation accepts raises of any member.
import * as test_assert from "std:test/assert"

exception NotFound(path: string)
exception PermDenied(path: string)
exception group IOError = NotFound | PermDenied

exception Boom(code: i64)
exception Oops(msg: string)
exception group Errors = Boom | Oops

// The runtime contract (raise of any IOError member fires the IOError
// catch arm) is exercised below via direct raise of each member.

// First member fires the IOError arm.
// The post-`end` return is unreachable but satisfies the i64 return-type
// check while sidestepping the wasm-codegen E2010 edge case triggered
// by `return <int>` immediately after `raise` inside a try body.
let catch_first_member = fn () -> i64 do
  try
    raise NotFound(path: "/tmp/x")
  catch
    | IOError -> return 1
  end
  return -1
end

// Second member also fires the IOError arm.
let catch_second_member = fn () -> i64 do
  try
    raise PermDenied(path: "/etc/shadow")
  catch
    | IOError -> return 2
  end
  return -1
end

// Group with a single arm covering all its members.
let catch_group_wildcard = fn () -> i64 do
  try
    raise Boom(code: 42)
  catch
    | Errors -> return 7
  end
  return -1
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: catch_first_member(), expected: 1, label: "group catches first member")
  test_assert.assert_eq_i64(actual: catch_second_member(), expected: 2, label: "group catches second member")
  test_assert.assert_eq_i64(actual: catch_group_wildcard(), expected: 7, label: "group covers all members")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
