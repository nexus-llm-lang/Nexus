// Regression for nexus-5pgr — T-Let premise μ = ~ ⟹ ¬linear(τ').
//
// Spec: a `let ~x = v` mutable-ref binding requires the rhs type to be
// non-linear. Pre-fix, `wrap_ref` silently returned `TyLinear` /
// `TyLazy` unchanged from the SigilMutable arm, so `let ~r = bb.empty()`
// ended up binding `r` at `%ByteBuffer` and the user-stated `~` sigil
// was dropped at let-time. The error then surfaced from the linearity
// pass as a confusing "linear binding %r never consumed" — naming
// `%r` despite the source saying `~r`.
//
// Post-fix, `infer_let` rejects the binding directly when the rhs
// inferred type is structurally linear (`%T` / `@T`), with a focused
// diagnostic that names the binding and references the spec invariant.
//
// This file is the *positive* fixture: a correctly-modalised `~i64`
// binding (i64 is non-linear) must still typecheck cleanly. The
// negative fixture (deliberately rejected) lives in
// `5pgr_let_mut_rejects_linear_negative.nx` — note the missing
// `_test` suffix, which keeps it out of `nexus test` discovery (a
// fixture that intentionally fails compile would otherwise be
// reported as a runner failure).
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  // `~r = 0` is non-linear i64, so the T-Let premise holds.
  let ~r = 0
  ~r <- ~r + 7
  test_assert.assert_eq_i64(actual: ~r, expected: 7, label: "~r holds non-linear i64 and round-trips through assignment")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
