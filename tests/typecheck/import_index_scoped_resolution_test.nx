/** import-graph-aware resolution. Two different modules declare an
 *  enum under the SAME bare name (`Lookup`, `BindResult`). The per-module import
 *  index must resolve the bare name, for the module under check, to the SOURCE
 *  module that module imports it from — its own definition first, else the one it
 *  selectively imports — never the program-wide first-match. Pins both the
 *  positive resolution and the visibility boundary (a module that imports the
 *  name from neither source resolves to None, leaving the flat fallback intact).
 */

import * as test_assert from "std:test/assert"
import {
  ImportEdge,
  ModuleImportIndex,
  resolve_import_source,
  module_import_index_from_edges,
  empty_module_import_index
}, * as iidx from "src/typecheck/import_index.nx"
import { Some, None } from "std:option"

/** Model: module A imports `Lookup` from collection/hashmap and `BindResult`
 *  from ir/lir/context; module B imports `Lookup` from collection/stringmap.
 *  Same bare name `Lookup`, two different source modules per importer. */
let sample_index = fn () -> ModuleImportIndex do
  return module_import_index_from_edges(edges: [
    ImportEdge(importer: "src/a.nx", name: "Lookup", source: "nxlib/stdlib/collection/hashmap.nx"),
    ImportEdge(importer: "src/a.nx", name: "BindResult", source: "src/ir/lir/context.nx"),
    ImportEdge(importer: "src/b.nx", name: "Lookup", source: "nxlib/stdlib/collection/stringmap.nx")
  ])
end

let resolves_to = fn (idx: ModuleImportIndex, importer: string, name: string) -> string do
  match resolve_import_source(idx, importer, name) do
    | Some(val: s) -> return s
    | None -> return "<none>"
  end
end

let test_same_name_resolves_per_importer = fn () -> unit throws { Exn } do
  let idx = sample_index()
  test_assert.assert_eq_string(
    actual: resolves_to(idx, importer: "src/a.nx", name: "Lookup"),
    expected: "nxlib/stdlib/collection/hashmap.nx",
    label: "module A imports Lookup from hashmap"
  )
  test_assert.assert_eq_string(
    actual: resolves_to(idx, importer: "src/b.nx", name: "Lookup"),
    expected: "nxlib/stdlib/collection/stringmap.nx",
    label: "module B imports the same bare Lookup from stringmap"
  )
  test_assert.assert_eq_string(
    actual: resolves_to(idx, importer: "src/a.nx", name: "BindResult"),
    expected: "src/ir/lir/context.nx",
    label: "module A imports BindResult from ir/lir/context"
  )
  return ()
end

let test_unimported_name_is_none = fn () -> unit throws { Exn } do
  let idx = sample_index()
  test_assert.assert_eq_string(
    actual: resolves_to(idx, importer: "src/b.nx", name: "BindResult"),
    expected: "<none>",
    label: "module B does not import BindResult: no edge, flat fallback governs"
  )
  test_assert.assert_eq_string(
    actual: resolves_to(idx, importer: "src/c.nx", name: "Lookup"),
    expected: "<none>",
    label: "a module with no edges resolves nothing"
  )
  return ()
end

let test_empty_index_resolves_nothing = fn () -> unit throws { Exn } do
  let idx = empty_module_import_index()
  test_assert.assert_eq_string(
    actual: resolves_to(idx, importer: "src/a.nx", name: "Lookup"),
    expected: "<none>",
    label: "empty index falls through to flat resolution everywhere"
  )
  return ()
end

/** The O(1) lookup must preserve the old linear scan's FIRST-edge-wins rule for
 *  a duplicated (importer, name) key, and must not let a `\0`-separated key
 *  collide two distinct pairs whose naive concatenation would coincide. */
let test_first_edge_wins_and_no_key_collision = fn () -> unit throws { Exn } do
  let idx = module_import_index_from_edges(edges: [
    ImportEdge(importer: "src/a.nx", name: "Dup", source: "src/first.nx"),
    ImportEdge(importer: "src/a.nx", name: "Dup", source: "src/second.nx")
  ])
  test_assert.assert_eq_string(
    actual: resolves_to(idx, importer: "src/a.nx", name: "Dup"),
    expected: "src/first.nx",
    label: "duplicate (importer,name): first edge wins, matching the old scan"
  )
  /* ("src/ab", "c") and ("src/a", "bc") both concatenate to "src/abc" without a
   * separator; the NUL separator keys them distinctly. */
  let idx2 = module_import_index_from_edges(edges: [
    ImportEdge(importer: "src/ab", name: "c", source: "src/from_abc.nx"),
    ImportEdge(importer: "src/a", name: "bc", source: "src/from_a_bc.nx")
  ])
  test_assert.assert_eq_string(
    actual: resolves_to(idx: idx2, importer: "src/ab", name: "c"),
    expected: "src/from_abc.nx",
    label: "separator keeps ('src/ab','c') distinct from ('src/a','bc')"
  )
  test_assert.assert_eq_string(
    actual: resolves_to(idx: idx2, importer: "src/a", name: "bc"),
    expected: "src/from_a_bc.nx",
    label: "separator keeps ('src/a','bc') distinct from ('src/ab','c')"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  test_same_name_resolves_per_importer()
  test_unimported_name_is_none()
  test_empty_index_resolves_nothing()
  test_first_edge_wins_and_no_key_collision()
  return ()
end
