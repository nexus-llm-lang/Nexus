// Negative fixture for nexus-mqin.11 — T-Borrow's `x :^ω` precondition.
//
// Spec (docs/spec/type-system-formal.md §T-Borrow):
//   x :^ω ∀ᾱ.τ ∈ Γ    τ' = inst(∀ᾱ.τ)    σ = stripBorrow(τ')
//   ────────────────────────────────────────────────────────────
//   Γ; ρ_q ⊢_e &x : &σ ! { }
//
// "Only unrestricted bindings can be borrowed." A linear (%) binding
// is q = 1; `&b` for `b : %T` must therefore be rejected.
//
// Pre-fix, `infer_borrow` stripped %/@ wrappers indiscriminately and
// accepted `&b`. Post-fix, the borrow site rejects with a typecheck
// error referencing T-Borrow.
//
// Filename intentionally omits `_test` so `nexus test` does not pick it
// up — a fixture that intentionally fails compile would otherwise be
// reported as a runner failure.
//
// We use `bb.empty()` (returns `%ByteBuffer`) so the env binds `b` at
// `TyLinear(ByteBuffer)` — a syntactically-linear type the typechecker
// sees directly. (A `let %x = 10` form would not exercise this fix:
// the rhs is plain `i64` so the env type lacks the `%` wrapper; the
// downstream linearity pass catches the "never consumed" half on its
// own.)
import * as bb from "std:bytebuffer"

let main = fn () -> unit do
  let %b = bb.empty()
  // T-Borrow requires `b :^ω`; b is `%ByteBuffer` (q = 1), so this is
  // rejected with a focused diagnostic.
  let _r = &b
  bb.free(buf: %b)
  return ()
end
