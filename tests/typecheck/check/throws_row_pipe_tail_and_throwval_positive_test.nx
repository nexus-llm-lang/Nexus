// Positive companions to the wfThrow pipe-tail and T-Throw-Val thunk-row
// soundness fixes. These confirm the legitimate forms still typecheck and
// behave correctly — the soundness fixes only reject MALFORMED rows
// (concrete/undeclared pipe-tail) and Exn-narrowing thunks, never the
// well-formed forms below.
//
//  1. Row-polymorphic pipe-tail `<R>() throws { E | R }`: the tail is a bound
//     row variable, so the row stays open and a caller may instantiate R with
//     any additional exceptions. Accepted (must NOT be flagged as malformed).
//  2. Closed comma form `{ E, F }`: an inclusive closed multi-member row.
//     A caller declaring the same closed row admits it.
//  3. T-Throw-Val into an Exn-admitting slot: a thunk of `throw e` (e : Exn)
//     forced through a `@(i64 throws { Exn })` slot is accepted because the
//     slot admits any Exn variant — only narrowing into a strictly smaller
//     row is rejected.
import * as test_assert from "std:test/assert"

exception E(code: i64)
exception F(code: i64)

// (1) Row-polymorphic pipe-tail: R is a bound quantifier; row stays open.
let row_poly = fn <R>() -> i64 throws { E | R } do
  throw E(code: 1)
end

// A caller instantiating R = { F } widens the open tail; both E and F are
// admitted by its declared closed row.
let row_poly_caller = fn () -> i64 throws { E, F } do
  return row_poly()
end

// (2) Closed comma form: an inclusive two-member closed row.
let comma_form = fn () -> i64 throws { E, F } do
  throw F(code: 2)
end

let comma_caller = fn () -> i64 throws { E, F } do
  return comma_form()
end

// (3) T-Throw-Val into a slot that DOES admit Exn: a thunk of `throw e`
// (collecting row pinned with the catch-all Exn) narrows fine into a
// `@(i64 throws { Exn })` slot, since that slot admits any variant.
let force_exn = fn (t: @(i64 throws { Exn })) -> i64 throws { Exn } do
  return @t
end

let throwval_into_exn_slot = fn (e: Exn) -> i64 throws { Exn } do
  let @th = throw e
  return force_exn(t: th)
end

// try/catch is statement-only, so each scenario is wrapped in a helper that
// returns the caught code (or a sentinel when nothing is thrown).
let run_row_poly = fn () -> i64 do
  try
    return row_poly_caller()
  catch
    | E(code: c) -> return c
    | _ -> return 0 - 1
  end
end

let run_comma = fn () -> i64 do
  try
    return comma_caller()
  catch
    | F(code: c) -> return c
    | _ -> return 0 - 1
  end
end

let run_throwval = fn () -> i64 do
  try
    return throwval_into_exn_slot(e: E(code: 7))
  catch
    | E(code: c) -> return c
    | _ -> return 0 - 1
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: run_row_poly(),
    expected: 1,
    label: "row-poly pipe-tail throws E"
  )
  test_assert.assert_eq_i64(actual: run_comma(), expected: 2, label: "comma-form throws F")
  test_assert.assert_eq_i64(actual: run_throwval(), expected: 7, label: "throw-val into Exn slot")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
