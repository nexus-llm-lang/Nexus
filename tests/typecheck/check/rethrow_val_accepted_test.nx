// Positive fixtures for T-Throw-Val (catch-bound rethrow) and
// T-Throw-CtorNullary (bare nullary exception constructor).
//
// (1) `catch e -> throw e` against a declared `throws { Exn }` row:
//     the rethrow emits {Exn} on the actual side; {Exn} on the expected
//     side (declared row contains Exn) admits it — accepted.
//
// (2) `catch e -> throw e` in a function with an open (effect-polymorphic)
//     row: any throw is admitted — accepted.
//
// (3) `throw SomeNullary` against a declared `throws { Nope }` row:
//     T-Throw-CtorNullary emits {Nope}; the declared row contains
//     Nope — accepted.  Regression guard for the nullary-ctor path.
import * as test_assert from "std:test/assert"

exception NotFound(path: string)
exception Nope

// (1) Rethrow against throws { Exn } — admitted.
let rethrow_against_exn = fn () -> i64 throws { Exn } do
  try
    throw NotFound(path: "x")
  catch e ->
    throw e
  end
end

// (2) Rethrow in an open-row function (no throws annotation) — admitted.
let rethrow_open_row = fn () -> i64 do
  try
    throw NotFound(path: "y")
  catch e ->
    throw e
  end
end

// (3) Nullary ctor throw against its own declared row — still accepted.
let throw_nullary_declared = fn () -> i64 throws { Nope } do
  throw Nope
end

let run_rethrow_against_exn = fn () -> i64 do
  try
    return rethrow_against_exn()
  catch _ ->
    return -1
  end
end

let run_rethrow_open_row = fn () -> i64 do
  try
    return rethrow_open_row()
  catch _ ->
    return -2
  end
end

let run_throw_nullary_declared = fn () -> i64 do
  try
    return throw_nullary_declared()
  catch _ ->
    return -3
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: run_rethrow_against_exn(),
    expected: -1,
    label: "rethrow_against_exn: catch-bound rethrow accepted under throws { Exn }"
  )
  test_assert.assert_eq_i64(
    actual: run_rethrow_open_row(),
    expected: -2,
    label: "rethrow_open_row: catch-bound rethrow accepted in open-row fn"
  )
  test_assert.assert_eq_i64(
    actual: run_throw_nullary_declared(),
    expected: -3,
    label: "throw_nullary_declared: nullary ctor accepted against declared row"
  )
  return ()
end
