// Regression fixture for nexus-blcd — top-level `let g = existing_fn`.
//
// Spec §D-Let-Top → T-Let-Alias: a top-level `let g = inc` must copy inc's
// scheme so g is callable with the same argument labels and behaves
// polymorphically when inc is generic.
//
// The bug: HIR build lowered the alias as a zero-param HirFunction with a
// TyI64 placeholder ret_type. register_functions registered g as ()->TyI64,
// breaking call sites (wrong params) and body checking (arrow vs TyI64).
// Fix: resolve_alias_registrations second pass re-registers with inc's scheme;
// check_all_functions skips body checking for alias-pattern functions;
// MIR lower_expr Call arm redirects g(x:1) → inc(x:1) via find_alias_src.
import * as test_assert from "std:test/assert"

let inc = fn (x: i64) -> i64 do
  return x + 1
end

// Top-level monomorphic alias (the primary repro from the issue).
let g = inc

let id = fn <T>(x: T) -> T do
  return x
end

// Top-level polymorphic alias.
let poly_g = id

let main = fn () -> unit throws { Exn } do
  // Monomorphic alias: g must be callable with inc's parameter label.
  let a = g(x: 10)
  test_assert.assert_eq_i64(actual: a, expected: 11, label: "top-level mono alias callable")

  // Polymorphic alias: poly_g must be callable at multiple types.
  let b = poly_g(x: 42)
  test_assert.assert_eq_i64(actual: b, expected: 42, label: "top-level poly alias callable at i64")
  let c = poly_g(x: true)
  test_assert.assert_eq_bool(
    actual: c,
    expected: true,
    label: "top-level poly alias callable at bool"
  )

  // In-body alias (regression guard — must still work).
  let g2 = inc
  let d = g2(x: 5)
  test_assert.assert_eq_i64(actual: d, expected: 6, label: "in-body alias still works")
  return ()
end
