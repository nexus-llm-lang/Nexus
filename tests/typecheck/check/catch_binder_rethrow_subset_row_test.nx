import * as test_assert from "std:test/assert"

exception FrameErr(msg: string)
exception EofErr
exception ParseErr(pos: i64)

exception group ProtoErr = FrameErr | EofErr | ParseErr

let source = fn (n: i64) -> i64 throws { ProtoErr } do
  if n == 0 then
    throw EofErr
  end
  return n
end

let loop_once = fn (n: i64) -> i64 throws { ProtoErr } do
  try
    return source(n: n)
  catch err ->
    match err do
      | FrameErr(msg: _) -> return -1
      | ParseErr(pos: _) -> return -2
      | _ -> throw err
    end
  end
end

let main = fn () -> unit throws { Exn } do
  let r = loop_once(n: 7)
  test_assert.assert_eq_i64(
    actual: r,
    expected: 7,
    label: "catch-all binder rethrow of a group residual is admitted when the body's actual throws are a subset of the declared row"
  )
  return ()
end
