// Negative fixture for nexus-ed9w. Borrows (`&T`) are aliases of
// owned-or-linear bindings, not values — equality on borrows is
// undefined per spec, so `&x == &y` must be REJECTED by the
// comparable(τ) predicate. Kept out of `nexus test` discovery by the
// missing `_test` suffix.
let main = fn () -> unit do
  let x: i64 = 1
  let y: i64 = 2
  &x == &y
  return ()
end
