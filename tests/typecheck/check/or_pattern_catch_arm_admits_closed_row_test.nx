/** An or-pattern catch arm (`| A(x: _) | B(x: _) ->`) with irrefutable
 *  sub-patterns fully handles BOTH variants: every alternative always
 *  matches, so the residual throws-row drops `A` and `B` and the closed
 *  `throws {}` annotation is admissible. This is the or-pattern counterpart
 *  to `irrefutable_catch_arm_admits_closed_row_test`; the separate-arm form
 *  (`| A(x: _) -> ... | B(x: _) -> ...`) was already accepted, so accepting
 *  the equivalent or-pattern closes a pure over-rejection gap. */
import * as test_assert from "std:test/assert"

exception A(x: i64)
exception B(x: i64)

let src = fn () -> i64 throws { A, B } do
  throw A(x: 7)
end

let recover = fn () -> i64 throws {} do
  try
    return src()
  catch
    | A(x: _) | B(x: _) -> return 0
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: recover(),
    expected: 0,
    label: "or-pattern catch arm handles A and B"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
