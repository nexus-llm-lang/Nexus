// Negative fixture for nexus-x1co — T-Lambda premise τ_r ≠ unit ⟹ tail(s†) = ⊥.
// A function that declares `-> i64` but whose body falls off the end without
// a `return` or `throw` must be REJECTED. Pre-fix this typechecked silently.
// Kept out of `nexus test` discovery by the missing `_test` suffix.
let bad = fn (x: i64) -> i64 do
  x
end

let main = fn () -> unit do
  bad(x: 1)
  return ()
end
