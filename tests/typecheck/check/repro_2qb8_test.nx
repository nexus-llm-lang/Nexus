// Regression for nexus-2qb8: indexing a borrowed array (`arr[idx]` where
// `arr` has type `&[| T |]`) was rejected by the self-host typechecker
// with "cannot index non-array type". Root cause: `infer_index` in
// src/typecheck/infer.nx required the indexed target's type to be exactly
// TyArray, never unwrapping TyBorrow / TyLinear / TyLazy wrappers.
//
// The bootstrap-Rust typechecker handles the unwrap (Expr::Index arm in
// bootstrap/src/lang/typecheck/mod.rs) and the assignment side
// of `arr[idx] <- val` was already wrapping-peeled by nexus-s06g (Index
// arm in infer_stmt's Assign handler). The fix mirrors that peel logic
// for the read path — TyBorrow / TyLinear / TyLazy of TyArray now all
// flow through to the element type.
//
// The repro binds `let r = &a` so `r` carries an explicit
// `TyBorrow(TyArray(...))` type and indexing through it exercises the
// previously-rejected code path.
import * as test_assert from "std:test/assert"

let main = fn () -> unit throws { Exn } do
  let a0 = [| 10, 20, 30 |]
  let r0 = &a0
  let v0 = r0[0]

  let a1 = [| 10, 20, 30 |]
  let r1 = &a1
  let v1 = r1[1]

  let a2 = [| 10, 20, 30 |]
  let r2 = &a2
  let v2 = r2[2]

  test_assert.assert_eq_i64(actual: v0, expected: 10, label: "2qb8: borrowed-array index [0]")
  test_assert.assert_eq_i64(actual: v1, expected: 20, label: "2qb8: borrowed-array index [1]")
  test_assert.assert_eq_i64(actual: v2, expected: 30, label: "2qb8: borrowed-array index [2]")
  a0
  a1
  a2
  return ()
end
