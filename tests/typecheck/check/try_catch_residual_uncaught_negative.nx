// nexus-rm9k negative fixture: selective catch that does NOT cover the thrown
// variant must still be rejected against `throws {}`.
//
// This file intentionally fails to compile.  It is excluded from `nexus test`
// discovery by the missing `_test` suffix.
//
// Expected error: uncaught exception Boom escaping try/catch while the
// enclosing function declares throws {}.

exception Boom
exception Other(code: i64)

// Boom is thrown but only Other is caught; Boom escapes the try/catch.
// The enclosing function declares throws {}, so this must be a type error.
let f = fn () -> unit throws {} do
  try
    throw Boom
  catch
    | Other(code: _) -> return ()
  end
  return ()
end

let main = fn () -> unit do f() return () end
