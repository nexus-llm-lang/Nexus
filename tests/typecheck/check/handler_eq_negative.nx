// Negative fixture for nexus-ed9w. Handler values implement
// capabilities — they are not data, and equality on them is undefined
// per spec. `h1 == h2` must be REJECTED by the comparable(τ)
// predicate. Kept out of `nexus test` discovery by the missing
// `_test` suffix.
cap Echo do
  fn say(msg: string) -> unit
end

let h1 = handler Echo do
  fn say(msg: string) -> unit do return () end
end

let h2 = handler Echo do
  fn say(msg: string) -> unit do return () end
end

let main = fn () -> unit do
  let _ = h1 == h2
  return ()
end
