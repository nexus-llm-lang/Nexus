// Regression for nexus-nhje: record-form `type` declaration loses its
// type-scope binding when used as a cap-method parameter type IF an
// `inject` block exists in the same module.
//
// Reproduction (minimal): `type User = { id: i64, name: string }` in
// record form, used as the parameter type of a cap method, then
// referenced via `inject mock_repo do ... end` somewhere in the module.
// Typechecker rejects the cap-method call site with
//   `unknown type definition: User [E2001]`
// even though `User` is a top-level type declaration in the same module.
//
// The workaround applied in nexus-afd1 was to switch to tag-constructor
// form (`type User = User(id: i64, name: string)`); that form does not
// trip the bug. The likely root cause is that type lookup during inject
// specialization treats the record-form anonymous type as
// identifier-bound rather than type-bound — so by the time cap-method
// arg types are resolved, the record-form `User` has been shadowed out
// of the type environment.
//
// This file is a *positive* fixture: it must typecheck cleanly. Until
// the bug is fixed it FAILS with E2001 at the `UserRepository.save`
// call site below; that's the proof. When the fix lands, the file
// flips green automatically with no edit.
import { Result, Ok, Err } from "std:result"

type User = { id: i64, name: string }

cap UserRepository do
  fn save(user: User) -> Result<unit, string>
end

let mock_repo = handler UserRepository do
  fn save(user: User) -> Result<unit, string> do
    return Ok(val: ())
  end
end

let main = fn () -> unit do
  inject mock_repo do
    let u = { id: 1, name: "Alice" }
    UserRepository.save(user: u)
  end
  return ()
end
