// nexus-rrx7 — PBT for scope-closing linearity rules:
// closeBlock / P-Block / P-Loop.
//
// Per bd nexus-rrx7 we verify the algorithmic invariants of the Nexus
// linearity-pass spec on a *toy* block-and-stmt domain (approach (a) from
// the brief). This deliberately avoids dragging in `tc_linearity.check_program`
// — the in-process driver (cf. uaby) is a hammer for full HIR-driven
// arm-equality checks, but rrx7 targets scope-closing arithmetic on
// linear-binding sets, which is faithfully captured by a 3-name toy.
//
// Toy domain
// ----------
//
//   type Name  = "a" | "b" | "c"      (small alphabet)
//   type Stmt  = SDecl(name)           introduces a *fresh-inner* linear
//              | SConsume(name)        consumes a linear from inner ∪ outer
//              | SBlock(stmts)         nested block (its own closeBlock)
//              | SLoop(stmts)          loop with body Stmts (P-Loop)
//   type Block = [Stmt]
//
//   Env = sorted-unique [string]       set of currently-live linears
//
// Spec slice under test
// ---------------------
//
// closeBlock(decl_inner: Env, consumed_inner: Env, outer: Env) -> CloseResult
//   - Inner-introduced (decl_inner) must be ⊆ consumed_inner; else CloseLeak.
//   - Consumed-from-outer = consumed_inner \ decl_inner; outer_post = outer \
//     (consumed_inner ∩ outer).
//   - Result is `CloseOk(outer_post: Env, consumed_from_outer: Env)`.
//
// Properties (≥200 trials each, 5 total)
// --------------------------------------
//
//   P1  closeBlock-no-leak: a Block executed against a synthesized outer
//       env, when there are no leaks (every Decl is matched by a Consume
//       *inside the same block scope*), produces CloseOk.
//   P2  closeBlock-detects-leak: injecting an unmatched Decl into a
//       no-leak block always produces CloseLeak.
//   P3  P-Block linConsumed parity: the syntactic linConsumed of a block
//       equals the union of per-stmt linConsumed (set equality, modulo
//       inner-introduced names which never escape).
//   P4  P-Loop body-equality: every well-formed loop body has
//       linConsumed_body = decl_body (loops cannot consume linears from
//       the lexical parent without re-binding).
//   P5  closeBlock idempotence: closeBlock(closeBlock(I, O), O) =
//       closeBlock(I, O) (the second close is a no-op on the result env).
//
// Anti-gotcha note (see yebe / ul9n): Gen<T> values are built *inside*
// `body()` to avoid top-level nullary-thunk inference; predicates are
// locals inside `body()`; predicate inputs bind to `x`; every Gen<T>
// carries a renderer.

import * as test_assert from "std:test/assert"
import * as pbt from "std:pbt"
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import { Pass, Fail } from "std:pbt"
import { Pair } from "std:tuple"
import * as list from "std:list"
import * as str from "std:str"

// ─── Toy AST ───────────────────────────────────────────────────────────────

type Stmt =
  SDecl(name: string)
  | SConsume(name: string)
  | SBlock(stmts: [ Stmt ])
  | SLoop(stmts: [ Stmt ])

// ─── Sorted-unique "set" representation over strings ───────────────────────

let str_byte_lt_go = fn (a: string, b: string, na: i64, nb: i64, i: i64) -> bool do
  let lim = if na < nb then na else nb end
  if i >= lim then return na < nb end
  let ca = str.byte_at(s: a, idx: i)
  let cb = str.byte_at(s: b, idx: i)
  if ca == cb then return str_byte_lt_go(a, b, na, nb, i: i + 1) end
  return ca < cb
end

let str_lt = fn (a: string, b: string) -> bool do
  if a == b then return false end
  return str_byte_lt_go(a, b, na: str.byte_length(s: a), nb: str.byte_length(s: b), i: 0)
end

let set_insert_go = fn (acc: [ string ], rest: [ string ], x: string) -> [ string ] do
  match rest do
    | [] -> return list.reverse(xs: x :: acc)
    | y :: ys ->
      if x == y then
        return list.concat(xs: list.reverse(xs: acc), ys: rest)
      end
      if str_lt(a: x, b: y) then
        return list.concat(xs: list.reverse(xs: x :: acc), ys: rest)
      end
      return set_insert_go(acc: y :: acc, rest: ys, x)
  end
end

let set_insert = fn (xs: [ string ], x: string) -> [ string ] do
  return set_insert_go(acc: [], rest: xs, x)
end

let set_member_go = fn (xs: [ string ], x: string) -> bool do
  match xs do
    | [] -> return false
    | y :: rest ->
      if x == y then return true end
      return set_member_go(xs: rest, x)
  end
end

let set_member = fn (xs: [ string ], x: string) -> bool do
  return set_member_go(xs, x)
end

let set_remove_go = fn (acc: [ string ], xs: [ string ], x: string) -> [ string ] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | y :: rest ->
      if x == y then
        return list.concat(xs: list.reverse(xs: acc), ys: rest)
      end
      return set_remove_go(acc: y :: acc, xs: rest, x)
  end
end

let set_remove = fn (xs: [ string ], x: string) -> [ string ] do
  return set_remove_go(acc: [], xs, x)
end

let set_union_go = fn (xs: [ string ], ys: [ string ]) -> [ string ] do
  match ys do
    | [] -> return xs
    | y :: rest -> return set_union_go(xs: set_insert(xs, x: y), ys: rest)
  end
end

let set_union = fn (xs: [ string ], ys: [ string ]) -> [ string ] do
  return set_union_go(xs, ys)
end

let set_diff_go = fn (acc: [ string ], xs: [ string ], ys: [ string ]) -> [ string ] do
  match xs do
    | [] -> return acc
    | x :: rest ->
      if set_member(xs: ys, x) then
        return set_diff_go(acc, xs: rest, ys)
      end
      return set_diff_go(acc: set_insert(xs: acc, x), xs: rest, ys)
  end
end

// Returns xs \ ys
let set_diff = fn (xs: [ string ], ys: [ string ]) -> [ string ] do
  return set_diff_go(acc: [], xs, ys)
end

let set_inter_go = fn (acc: [ string ], xs: [ string ], ys: [ string ]) -> [ string ] do
  match xs do
    | [] -> return acc
    | x :: rest ->
      if set_member(xs: ys, x) then
        return set_inter_go(acc: set_insert(xs: acc, x), xs: rest, ys)
      end
      return set_inter_go(acc, xs: rest, ys)
  end
end

let set_inter = fn (xs: [ string ], ys: [ string ]) -> [ string ] do
  return set_inter_go(acc: [], xs, ys)
end

let set_eq_go = fn (xs: [ string ], ys: [ string ]) -> bool do
  match xs do
    | [] ->
      match ys do
        | [] -> return true
        | _ :: _ -> return false
      end
    | x :: xrest ->
      match ys do
        | [] -> return false
        | y :: yrest ->
          if x == y then return set_eq_go(xs: xrest, ys: yrest) end
          return false
      end
  end
end

let set_eq = fn (xs: [ string ], ys: [ string ]) -> bool do
  return set_eq_go(xs, ys)
end

// is xs ⊆ ys ?
let set_subset_go = fn (xs: [ string ], ys: [ string ]) -> bool do
  match xs do
    | [] -> return true
    | x :: rest ->
      if set_member(xs: ys, x) then return set_subset_go(xs: rest, ys) end
      return false
  end
end

let set_subset = fn (xs: [ string ], ys: [ string ]) -> bool do
  return set_subset_go(xs, ys)
end

// ─── Per-stmt linearity analyses ───────────────────────────────────────────
//
// `decl_of(s)` — set of names introduced by `s` (recursively, but inner-
// scope decls are not externally visible, so SBlock / SLoop contribute
// empty: their decls die at the inner closeBlock).
//
// `consumed_of(s)` — set of *external* (outer-visible) consumed names: for
// SBlock / SLoop, this is (inner consumed) \ (inner declared) — only the
// names that escape the inner scope reach the outer count.

let decl_of = fn (s: Stmt) -> [ string ] do
  match s do
    | SDecl(name: n) -> return set_insert(xs: [], x: n)
    | SConsume(name: _) -> return []
    | SBlock(stmts: _) -> return []
    | SLoop(stmts: _) -> return []
  end
end

let consumed_of_stmt_go = fn (s: Stmt) -> [ string ] do
  match s do
    | SDecl(name: _) -> return []
    | SConsume(name: n) -> return set_insert(xs: [], x: n)
    | SBlock(stmts: ss) -> return external_consumed_of_block(ss)
    | SLoop(stmts: ss) -> return external_consumed_of_block(ss)
  end
end

// For an entire block, what its body declares (top-level Decls only).
let block_decls = fn (ss: [ Stmt ]) -> [ string ] do
  match ss do
    | [] -> return []
    | s :: rest -> return set_union(xs: decl_of(s), ys: block_decls(ss: rest))
  end
end

// For an entire block, the *raw* per-stmt consumed union (includes inner
// references to inner-introduced linears — these will be subtracted via
// block_decls to compute external_consumed_of_block).
let block_raw_consumed = fn (ss: [ Stmt ]) -> [ string ] do
  match ss do
    | [] -> return []
    | s :: rest -> return set_union(xs: consumed_of_stmt_go(s), ys: block_raw_consumed(ss: rest))
  end
end

// External-consumed: names consumed within the block that resolve to
// *outer* linears (i.e. not declared inside the block).
let external_consumed_of_block = fn (ss: [ Stmt ]) -> [ string ] do
  let raw = block_raw_consumed(ss)
  let decls = block_decls(ss)
  return set_diff(xs: raw, ys: decls)
end

let consumed_of_stmt = fn (s: Stmt) -> [ string ] do
  return consumed_of_stmt_go(s)
end

// ─── closeBlock ────────────────────────────────────────────────────────────

type CloseResult =
  CloseOk(outer_post: [ string ], consumed_from_outer: [ string ])
  | CloseLeak(leaked: [ string ])

// closeBlock(decl_inner, raw_consumed, outer):
//   leaked = decl_inner \ raw_consumed  (declared-but-unused inside)
//   if leaked nonempty -> CloseLeak
//   else:
//     consumed_outer = raw_consumed \ decl_inner  (the part that hits outer)
//     outer_post = outer \ consumed_outer
//     CloseOk(outer_post, consumed_outer)
let close_block = fn (
  decl_inner: [ string ],
  raw_consumed: [ string ],
  outer: [ string ]
) -> CloseResult do
  let leaked = set_diff(xs: decl_inner, ys: raw_consumed)
  match leaked do
    | [] ->
      let consumed_outer = set_diff(xs: raw_consumed, ys: decl_inner)
      let outer_post = set_diff(xs: outer, ys: consumed_outer)
      return CloseOk(outer_post, consumed_from_outer: consumed_outer)
    | _ :: _ -> return CloseLeak(leaked)
  end
end

// ─── Generators ────────────────────────────────────────────────────────────

let pick_name = fn (seed: i64) -> Pair<string, i64> do
  let s1 = seed ^ (seed << 13)
  let s2 = s1 ^ (s1 >> 7)
  let s3 = s2 ^ (s2 << 17)
  let raw = if s3 < 0 then 0 - s3 else s3 end
  let idx = raw % 3
  let nm = if idx == 0 then "a" else if idx == 1 then "b" else "c" end
  return Pair(left: nm, right: s3)
end

let next_seed = fn (seed: i64) -> i64 do
  let s0 = if seed == 0 then 2685821657736338717 else seed end
  let s1 = s0 ^ (s0 << 13)
  let s2 = s1 ^ (s1 >> 7)
  let s3 = s2 ^ (s2 << 17)
  return s3
end

let abs_i64 = fn (n: i64) -> i64 do
  if n < 0 then return 0 - n end
  return n
end

// Generate a "well-formed no-leak" Block: every Decl introduces a fresh
// inner linear, every Consume references one currently declared at this
// scope. Strategy: walk a budget of `depth` choices, threading the
// currently-available linear set. At the end, force-consume any
// unconsumed names so the block closes cleanly.

let mk_consume_list = fn (xs: [ string ]) -> [ Stmt ] do
  match xs do
    | [] -> return []
    | x :: rest -> return SConsume(name: x) :: mk_consume_list(xs: rest)
  end
end

// Build a no-leak block at this scope. budget = max stmts before forced
// drain. live = currently declared-but-unconsumed linears at this scope.
let gen_block_go = fn (budget: i64, live: [ string ], seed: i64) -> Pair<[ Stmt ], i64> do
  if budget <= 0 then
    return Pair(left: mk_consume_list(xs: live), right: seed)
  end
  let s1 = next_seed(seed)
  let r = abs_i64(n: s1) % 10
  // 0..2: SDecl new name (if alphabet not exhausted)
  // 3..4: SConsume one of live (if live nonempty), else SDecl
  // 5..6: nested SBlock (small budget)
  // 7..8: SLoop (small budget, no parent linears consumed inside)
  // 9   : SDecl
  let live_size = list.length(xs: live)
  if r <= 2 || live_size == 0 then
    // SDecl: pick a fresh name. If alphabet exhausted (size==3), fall back
    // to consume (if any live) or end the block.
    if live_size >= 3 then
      // pick a live name to consume and proceed
      let Pair(left: nm, right: s2) = pick_name(seed: s1)
      let target = if set_member(xs: live, x: nm) then nm else
        match live do
          | [] -> "a"  // unreachable: live_size==3
          | x :: _ -> x
        end
      end
      let live2 = set_remove(xs: live, x: target)
      let Pair(left: tail, right: s3) = gen_block_go(budget: budget - 1, live: live2, seed: s2)
      return Pair(left: SConsume(name: target) :: tail, right: s3)
    end
    // pick a name not in live
    let Pair(left: nm, right: s2) = pick_name(seed: s1)
    let chosen = if set_member(xs: live, x: nm) then
      // try the other alphabet members
      if set_member(xs: live, x: "a") then
        if set_member(xs: live, x: "b") then "c" else "b" end
      else "a" end
    else nm end
    let live2 = set_insert(xs: live, x: chosen)
    let Pair(left: tail, right: s3) = gen_block_go(budget: budget - 1, live: live2, seed: s2)
    return Pair(left: SDecl(name: chosen) :: tail, right: s3)
  end
  if r <= 4 then
    // SConsume of some live
    let Pair(left: nm, right: s2) = pick_name(seed: s1)
    let target = if set_member(xs: live, x: nm) then nm else
      match live do
        | [] -> "a"  // unreachable: live_size>0
        | x :: _ -> x
      end
    end
    let live2 = set_remove(xs: live, x: target)
    let Pair(left: tail, right: s3) = gen_block_go(budget: budget - 1, live: live2, seed: s2)
    return Pair(left: SConsume(name: target) :: tail, right: s3)
  end
  if r <= 6 then
    // SBlock — generate a no-leak nested block (live stays the same: the
    // nested block has its own scope and we only allow consumes of inner
    // linears in this generator, never bubbling parent consumes).
    let Pair(left: inner, right: s2) = gen_block_go(budget: budget / 2, live: [], seed: s1)
    let Pair(left: tail, right: s3) = gen_block_go(budget: budget - 1, live, seed: s2)
    return Pair(left: SBlock(stmts: inner) :: tail, right: s3)
  end
  if r <= 8 then
    // SLoop — P-Loop body-equality requires body consumes exactly its
    // own Decls. The generator already enforces this by using gen_block_go
    // starting from `live: []` (no parent linears in the loop body).
    let Pair(left: inner, right: s2) = gen_block_go(budget: budget / 2, live: [], seed: s1)
    let Pair(left: tail, right: s3) = gen_block_go(budget: budget - 1, live, seed: s2)
    return Pair(left: SLoop(stmts: inner) :: tail, right: s3)
  end
  // r == 9: SDecl fallback
  let Pair(left: nm, right: s2) = pick_name(seed: s1)
  let chosen = if set_member(xs: live, x: nm) then
    if set_member(xs: live, x: "a") then
      if set_member(xs: live, x: "b") then "c" else "b" end
    else "a" end
  else nm end
  if set_member(xs: live, x: chosen) then
    // alphabet exhausted; force consume
    let Pair(
      left: tail,
      right: s3
    ) = gen_block_go(budget: budget - 1, live: set_remove(xs: live, x: chosen), seed: s2)
    return Pair(left: SConsume(name: chosen) :: tail, right: s3)
  end
  let live2 = set_insert(xs: live, x: chosen)
  let Pair(left: tail, right: s3) = gen_block_go(budget: budget - 1, live: live2, seed: s2)
  return Pair(left: SDecl(name: chosen) :: tail, right: s3)
end

// ─── Renderers ─────────────────────────────────────────────────────────────

let render_stmt_go = fn (s: Stmt) -> string do
  match s do
    | SDecl(name: n) -> return "decl " ++ n
    | SConsume(name: n) -> return "use " ++ n
    | SBlock(stmts: ss) -> return "{" ++ render_block_go(ss: ss) ++ "}"
    | SLoop(stmts: ss) -> return "loop{" ++ render_block_go(ss: ss) ++ "}"
  end
end

let render_block_go = fn (ss: [ Stmt ]) -> string do
  match ss do
    | [] -> return ""
    | s :: [] -> return render_stmt_go(s)
    | s :: rest -> return render_stmt_go(s) ++ "; " ++ render_block_go(ss: rest)
  end
end

let render_block = fn (b: [ Stmt ]) -> string do
  return "[" ++ render_block_go(ss: b) ++ "]"
end

// ─── Helpers for properties ────────────────────────────────────────────────

// Collect all SLoop bodies (depth-first). Used by P-Loop check.
let collect_loops_go = fn (s: Stmt, acc: [ [ Stmt ] ]) -> [ [ Stmt ] ] do
  match s do
    | SDecl(name: _) -> return acc
    | SConsume(name: _) -> return acc
    | SBlock(stmts: ss) -> return collect_loops_block(ss, acc)
    | SLoop(stmts: ss) ->
      // include the loop body, then recurse into it for nested loops
      let acc1 = list.concat(xs: acc, ys: [ ss ])
      return collect_loops_block(ss, acc: acc1)
  end
end

let collect_loops_block = fn (ss: [ Stmt ], acc: [ [ Stmt ] ]) -> [ [ Stmt ] ] do
  match ss do
    | [] -> return acc
    | s :: rest ->
      let acc1 = collect_loops_go(s, acc)
      return collect_loops_block(ss: rest, acc: acc1)
  end
end

// Inject an extra SDecl(forcing leak) somewhere in the block: prepend a
// fresh-inner name that is NOT subsequently consumed. We pick a name
// outside the alphabet so it definitely won't collide with later Consumes.
let inject_leak = fn (ss: [ Stmt ]) -> [ Stmt ] do
  return SDecl(name: "leak_z") :: ss
end

// Check that every loop body's external_consumed is empty (decl_body =
// linConsumed_body). Walking the list of loop-body Stmt lists.
let loop_bodies_check_go = fn (loops: [ [ Stmt ] ]) -> bool do
  match loops do
    | [] -> return true
    | b :: rest ->
      let ext = external_consumed_of_block(ss: b)
      let ok = match ext do
        | [] -> true
        | _ :: _ -> false
      end
      if ok then return loop_bodies_check_go(loops: rest) end
      return false
  end
end

let loop_bodies_check = fn (loops: [ [ Stmt ] ]) -> bool do
  return loop_bodies_check_go(loops)
end

// ─── Body ──────────────────────────────────────────────────────────────────

let body = fn () -> unit require { Console } throws { Exn } do
  // Build a Gen<Block> inside body() (avoid the top-level nullary thunk
  // gotcha; see ul9n test for the same idiom).
  let max_budget = 6

  let block_run = fn (seed: i64) -> Pair<[ Stmt ], i64> do
    return gen_block_go(budget: max_budget, live: [], seed)
  end
  let block_shrink = fn (v: [ Stmt ]) -> [ [ Stmt ] ] do
    return []
  end
  let block_render = fn (v: [ Stmt ]) -> string do
    return render_block(b: v)
  end

  let block_gen = pbt.Gen(run: block_run, shrink: block_shrink, render: block_render)

  // ── P1: closeBlock-no-leak ────────────────────────────────────────────
  //
  // Generated blocks are no-leak by construction: every Decl is matched
  // by a Consume before block end. closeBlock(decl_inner, raw_consumed,
  // outer=[]) must return CloseOk.
  let prop_close_no_leak = fn (x: [ Stmt ]) -> bool do
    let d = block_decls(ss: x)
    let c = block_raw_consumed(ss: x)
    let r = close_block(decl_inner: d, raw_consumed: c, outer: [])
    let ok = match r do
      | CloseOk(outer_post: _, consumed_from_outer: _) -> true
      | CloseLeak(leaked: _) -> false
    end
    return ok
  end

  // ── P2: closeBlock-detects-leak ───────────────────────────────────────
  //
  // Inject an unconsumed SDecl("leak_z") into a no-leak block. The
  // resulting block must be rejected by closeBlock with a CloseLeak that
  // includes "leak_z".
  let prop_close_detects_leak = fn (x: [ Stmt ]) -> bool do
    let xl = inject_leak(ss: x)
    let d = block_decls(ss: xl)
    let c = block_raw_consumed(ss: xl)
    let r = close_block(decl_inner: d, raw_consumed: c, outer: [])
    let ok = match r do
      | CloseOk(outer_post: _, consumed_from_outer: _) -> false
      | CloseLeak(leaked: leaked) -> set_member(xs: leaked, x: "leak_z")
    end
    return ok
  end

  // ── P3: P-Block linConsumed parity ────────────────────────────────────
  //
  // The block's external_consumed (computed via subtract-decls) must
  // equal the unioned-per-stmt consumed_of, modulo the names declared
  // inside the block. I.e.:
  //
  //   (⋃ consumed_of(s_i)) \ block_decls = external_consumed_of_block
  //
  // This is the syntactic ⊆ metatheoretic statement: per-stmt analyses
  // compose by set union when restricted to outer-visible names.
  let prop_block_parity = fn (x: [ Stmt ]) -> bool do
    let raw = block_raw_consumed(ss: x)
    let d = block_decls(ss: x)
    let lhs = set_diff(xs: raw, ys: d)
    let rhs = external_consumed_of_block(ss: x)
    let ok = set_eq(xs: lhs, ys: rhs)
    return ok
  end

  // ── P4: P-Loop body-equality ──────────────────────────────────────────
  //
  // For every SLoop body collected from x: linConsumed_body must equal
  // decl_body (no parent linears consumed inside the loop). This is the
  // metatheoretic statement of P-Loop: the loop body sees no parent
  // linears in its consumed-from-outer set.
  let prop_loop_body_eq = fn (x: [ Stmt ]) -> bool do
    let loops = collect_loops_block(ss: x, acc: [])
    let ok = loop_bodies_check(loops)
    return ok
  end

  // ── P5: closeBlock idempotence ────────────────────────────────────────
  //
  // closeBlock is a pure projection. Calling it again on the same outer
  // with the *same* (decl_inner, raw_consumed) inputs returns the same
  // CloseOk. (For OK results, decl_inner subtracts identically and the
  // outer_post agrees.)
  let prop_close_idem = fn (x: [ Stmt ]) -> bool do
    let d = block_decls(ss: x)
    let c = block_raw_consumed(ss: x)
    let outer = [ "a", "b", "c" ]
    let r1 = close_block(decl_inner: d, raw_consumed: c, outer)
    let r2 = close_block(decl_inner: d, raw_consumed: c, outer)
    let ok = match r1 do
      | CloseLeak(leaked: l1) ->
        match r2 do
          | CloseLeak(leaked: l2) -> set_eq(xs: l1, ys: l2)
          | CloseOk(outer_post: _, consumed_from_outer: _) -> false
        end
      | CloseOk(outer_post: op1, consumed_from_outer: co1) ->
        match r2 do
          | CloseLeak(leaked: _) -> false
          | CloseOk(outer_post: op2, consumed_from_outer: co2) ->
            set_eq(xs: op1, ys: op2) && set_eq(xs: co1, ys: co2)
        end
    end
    return ok
  end

  // Iteration count (≥200 per bd brief).
  let n = 200

  let r1 = pbt.forall(g: block_gen, prop: prop_close_no_leak, n)
  match r1 do
    | Pass -> test_assert.assert_true(
      cond: true,
      label: "rrx7 P1: closeBlock-no-leak holds across 200 trials"
    )
    | Fail(witness: w, shrunk: s) ->
      test_assert.assert_true(cond: false,
        label: "rrx7 P1 FAILED — witness=" ++ render_block(b: w) ++ " shrunk=" ++ render_block(b: s))
  end

  let r2 = pbt.forall(g: block_gen, prop: prop_close_detects_leak, n)
  match r2 do
    | Pass -> test_assert.assert_true(
      cond: true,
      label: "rrx7 P2: closeBlock-detects-leak across 200 trials"
    )
    | Fail(witness: w, shrunk: s) ->
      test_assert.assert_true(cond: false,
        label: "rrx7 P2 FAILED — witness=" ++ render_block(b: w) ++ " shrunk=" ++ render_block(b: s))
  end

  let r3 = pbt.forall(g: block_gen, prop: prop_block_parity, n)
  match r3 do
    | Pass -> test_assert.assert_true(
      cond: true,
      label: "rrx7 P3: P-Block linConsumed parity across 200 trials"
    )
    | Fail(witness: w, shrunk: s) ->
      test_assert.assert_true(cond: false,
        label: "rrx7 P3 FAILED — witness=" ++ render_block(b: w) ++ " shrunk=" ++ render_block(b: s))
  end

  let r4 = pbt.forall(g: block_gen, prop: prop_loop_body_eq, n)
  match r4 do
    | Pass -> test_assert.assert_true(
      cond: true,
      label: "rrx7 P4: P-Loop body-equality across 200 trials"
    )
    | Fail(witness: w, shrunk: s) ->
      test_assert.assert_true(cond: false,
        label: "rrx7 P4 FAILED — witness=" ++ render_block(b: w) ++ " shrunk=" ++ render_block(b: s))
  end

  let r5 = pbt.forall(g: block_gen, prop: prop_close_idem, n)
  match r5 do
    | Pass -> test_assert.assert_true(
      cond: true,
      label: "rrx7 P5: closeBlock idempotence across 200 trials"
    )
    | Fail(witness: w, shrunk: s) ->
      test_assert.assert_true(cond: false,
        label: "rrx7 P5 FAILED — witness=" ++ render_block(b: w) ++ " shrunk=" ++ render_block(b: s))
  end

  return ()
end

let safe_run = fn () -> i64 require { Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
