// Regression for nexus-x2xx — `let a.b.C(x) = expr` failed because
// `parse_let_stmt` only performed a depth-1 lookahead to detect the ctor-pattern
// head. Paths with two or more module-qualifier segments fell through to the
// simple `let name = ...` branch and threw `UnexpectedToken`.
//
// Post-fix: `ctor_pat_lookahead` walks N levels of `.Ident` and `.Uident`
// segments, so `let ta.ta.Wrap(val: b) = expr` is correctly routed into
// `parse_pattern` → `try_qualified_ctor_pat`.
import * as test_assert from "std:test/assert"
import * as ta from "std:test/assert"

// Single-ctor type so the let-pattern destructure is exhaustive.
type Wrapper = Wrap(val: i64)

let make = fn () -> Wrapper do
  return Wrap(val: 99)
end

let body = fn () -> unit throws { Exn } do
  // Depth-1 baseline (already worked before this fix).
  let ta.Wrap(val: a) = make()
  test_assert.assert_eq_i64(actual: a, expected: 99, label: "depth-1 qualified ctor baseline")

  // Depth-2: `ta.ta.Wrap(val: b)`. The two-segment path `ta.ta` exercises the
  // new N-level lookahead; `rdr_last_from_dotted` strips all but the last
  // segment so the HIR sees `PCtor("Wrap", ...)` — identical to the unqualified form.
  let ta.ta.Wrap(val: b) = make()
  test_assert.assert_eq_i64(actual: b, expected: 99, label: "depth-2 qualified ctor destructure")

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
