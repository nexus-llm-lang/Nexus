// Regression test for nexus-npnm.
//
// T-Inject premise (∀i. ρ_i ⊆ ρ_q): when a handler declares
// `require { Console }`, and is injected *inside* a body where the outer
// `inject system_handler` has already extended the ambient row with the
// bare "Console" cap, the inner inject must be accepted.
//
// The bug (pre-fix): inject_cap_entries_acc stored the *qualified*
// TyHandler.name (e.g. "nxlib_stdlib_io_stdio_nx#Console") as the cap
// entry added to the ambient row, while the inner handler's require row
// carried the bare name "Console".  row_contains_cap used exact string
// equality, so "Console" ≠ "nxlib_...#Console" → false E2016.
//
// The fix: inject_cap_entries_acc calls base_name_of(pname) to strip the
// module prefix before extending the ambient row, keeping all require-row
// entries in their unqualified form.
//
// nexus-npnm
import { Console, system_handler } from "std:stdio"

cap Greeter do
  fn greet(name: string) -> unit
end

let polite = handler Greeter require { Console } do
  fn greet(name: string) -> unit do
    Console.println(val: "Hello, " ++ name ++ "!")
    return ()
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    // After this outer inject, the ambient row contains bare "Console".
    // The inner inject's handler requires "Console" — must be accepted.
    inject polite do
      Greeter.greet(name: "world")
    end
  end
  return ()
end
