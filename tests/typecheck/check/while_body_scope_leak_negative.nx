// Negative fixture for nexus-skcf — T-While body bindings leak.
// Pre-fix, `let x` introduced inside a while body leaked into the outer
// scope because infer_while returned `st3` (post-body state) directly.
// Post-fix, the body env is reverted to the pre-body state before
// returning InferExprOk to the caller.
//
// This program references `body_local` after the while loop ends; the
// typechecker must REJECT with an unbound-name error.
//
// Kept out of `nexus test` discovery by the missing `_test` suffix.

let main = fn () -> unit do
  let ~i = 0
  while ~i < 3 do
    let body_local = ~i * 2
    let _ = body_local
    ~i <- ~i + 1
  end
  // `body_local` should NOT be visible here — it was introduced inside
  // the while body only.
  let _ = body_local
  return ()
end
