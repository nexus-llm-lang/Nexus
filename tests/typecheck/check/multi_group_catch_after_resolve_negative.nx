// Negative fixture for nexus-vks5 — `expand_groups_in_functions` must run
// after `iterative_resolve` (build pipeline) and after
// `resolve_all_lazy_no_filter` (LSP pipeline). Pre-fix, catch arms in
// functions that arrive as LazyBody and become EagerBody during
// resolution still carried raw group names. The earlier expand pass
// inside `accum_to_program` only saw the LazyBody stubs, so by the time
// typecheck visited the resolved EagerBody the catch arm's `IOError`
// (a group name, not a constructor) tripped E2001 "unknown constructor
// in pattern".
//
// Against current main the vks5 fix is REVERTED (latest of 7 such
// reverts: 2419672). Even a minimal "one group decl, one single-arm
// group catch in a single function" file fails `nexus build` with
// E2001. Once vks5 re-lands every shape below MUST typecheck cleanly.
//
// Filename intentionally omits `_test` so `nexus test` does not pick it
// up — every assertion below currently fails the build, and a runner
// FAIL on a deferred bug class is noise. Treat this file as the
// re-land checklist: when vks5 is back, run
//
//   wasmtime run --dir=. nexus.wasm build \
//     tests/typecheck/vks5_multi_group_catch_after_resolve_negative.nx \
//     -o /tmp/vks5_check.wasm
//
// and require exit-code 0 before promoting the file (or its surviving
// cases) to a `_test.nx`.
import * as test_assert from "std:test/assert"

exception NotFound(path: string)
exception PermDenied(path: string)
exception Timeout(ms: i64)
exception group IOError = NotFound | PermDenied
exception group Transient = Timeout | PermDenied

exception ParseError(line: i64)
exception ValidationError(field: string)
exception group InputError = ParseError | ValidationError

// Case 1 — minimal: one group decl, single arm, single function. Fails
// against current main; this is the load-bearing shape that vks5
// directly fixes.
let catch_minimal = fn () -> i64 do
  try
    throw NotFound(path: "/tmp/x")
  catch
    | IOError -> return 1
  end
  return -1
end

// Case 2 — multiple group decls per file (the bd-task headline shape).
let catch_other_group = fn () -> i64 do
  try
    throw ParseError(line: 7)
  catch
    | InputError -> return 2
  end
  return -1
end

// Case 3 — overlapping group members (PermDenied ∈ IOError ∧ Transient).
let catch_overlapping = fn () -> i64 do
  try
    throw PermDenied(path: "/etc/shadow")
  catch
    | IOError -> return 3
    | Transient -> return -3
  end
  return -1
end

// Case 4 — group catch in the inner of a nested try.
let catch_nested = fn () -> i64 do
  try
    try
      throw Timeout(ms: 500)
    catch
      | Transient -> throw ParseError(line: 7)
    end
  catch
    | InputError -> return 4
  end
  return -1
end

// Case 5 — two group arms in the same catch.
let catch_two_groups_same_catch = fn () -> i64 do
  try
    throw ValidationError(field: "name")
  catch
    | IOError -> return -5
    | InputError -> return 5
  end
  return -1
end

// Case 6 — indirected dispatch: the catching function calls a separate
// function whose body raises. The dispatcher resolves late and the
// catching function's group catch must still typecheck against its
// expanded member list.
let raise_one = fn () -> i64 throws { Exn } do
  throw NotFound(path: "/dev/null")
  return 0
end

let dispatcher = fn (which: i64) -> i64 throws { Exn } do
  if which == 0 then return raise_one() end
  throw PermDenied(path: "/etc/passwd")
  return 0
end

let catch_indirected = fn () -> i64 do
  try
    let _ = dispatcher(which: 1)
  catch
    | IOError -> return 6
  end
  return -1
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: catch_minimal(),
    expected: 1,
    label: "minimal: one group, one arm, one function"
  )
  test_assert.assert_eq_i64(
    actual: catch_other_group(),
    expected: 2,
    label: "two group decls per file"
  )
  test_assert.assert_eq_i64(
    actual: catch_overlapping(),
    expected: 3,
    label: "overlapping group members"
  )
  test_assert.assert_eq_i64(actual: catch_nested(), expected: 4, label: "group catch in nested try")
  test_assert.assert_eq_i64(
    actual: catch_two_groups_same_catch(),
    expected: 5,
    label: "two group arms in same catch"
  )
  test_assert.assert_eq_i64(
    actual: catch_indirected(),
    expected: 6,
    label: "group catch over indirected throw"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
