// Negative fixture: implicit force-call must surface the thunk's deferred
// throw_row (nexus-lq3ma.2 — T-App thunk-callee hole).
//
// Before the fix, `f(x: 1)` where `f : @(arrow throws {E})` dropped the
// thunk's ρ_e row: the call was accepted even though forcing f would throw E,
// and the caller declared throws {}.  This is the P5 exception-containment hole.
//
// After the fix, `f(x: 1)` elaborates to T-Force(f) + T-App, surfacing {E}
// into the ambient throw check.  Since g declares throws {}, E is not admitted
// and the call is REJECTED.
//
// Kept out of `nexus test` discovery by the missing `_test` suffix.
exception E

let g = fn (f: @(((x: i64) -> i64 throws { }) throws { E })) -> i64 throws { } do
  return f(x: 1)
end

let main = fn () -> unit do return () end
