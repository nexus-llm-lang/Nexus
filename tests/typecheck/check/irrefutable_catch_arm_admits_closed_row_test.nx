/** An irrefutable constructor catch arm (`| A(x: y) ->`, binding the field)
 *  fully handles `A`: it always matches, so the residual throws-row drops
 *  `A` and `recover` is admissible at the closed `throws {}` annotation.
 *  This is the positive counterpart to the refutable-arm rejection; if the
 *  irrefutability check were too strict it would over-reject this case and
 *  break the bootstrap (the compiler catches exceptions this way pervasively). */
import * as test_assert from "std:test/assert"

exception A(x: i64)

let src = fn () -> i64 throws { A } do
  throw A(x: 5)
end

let recover = fn () -> i64 throws {} do
  try
    return src()
  catch
    | A(x: y) -> return y
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: recover(),
    expected: 5,
    label: "irrefutable catch binds and handles A"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
