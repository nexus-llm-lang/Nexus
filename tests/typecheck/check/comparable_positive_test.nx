// Regression: T-Cmp comparable(τ) predicate (nexus-ed9w).
//
// Bug: src/typecheck/infer.nx::unify_cmp_binop unified the operands and
// returned TyBool without consulting any `comparable` predicate, so `f
// == g` between two arrows typechecked. Fix: implement comparable(τ) per
// the spec (base / record / named-typedef / list arms; reject for
// arrow, handler, ref, borrow, thunk, array, linear) and have
// unify_cmp_binop / unify_float_cmp consult it after unification.
//
// This file is the *positive* fixture: comparable categories the spec
// accepts must continue to typecheck. The fixture exercises base
// scalars, list-of-i64, and record-of-records (the two recursive
// arms). It only asserts on primitive comparisons whose runtime
// semantics are unambiguous; the record / list `==` calls are present
// solely to drive the typecheck path that the bug fix touches and are
// not asserted on (codegen for non-primitive `==` is reference-style
// and outside this fix's scope).
//
// Negative fixtures (deliberately mistyped, must be REJECTED) live
// alongside this file with `_negative` suffix and no `_test` suffix
// (kept out of `nexus test` discovery — see the rfh1_repro_test.nx
// pattern): ed9w_arrow_eq_negative.nx, ed9w_array_eq_negative.nx,
// ed9w_ref_eq_negative.nx, ed9w_borrow_eq_negative.nx,
// ed9w_lazy_eq_negative.nx, ed9w_handler_eq_negative.nx.
import * as test_assert from "std:test/assert"

type Inner = { x: i64, y: i64 }
type Outer = { a: Inner, b: Inner }

let body = fn () -> unit do
  // Primitive comparisons — the most common shape, must stay green.
  let i: i64 = 7
  let j: i64 = 7
  test_assert.assert_eq_i64(actual: if i == j then 1 else 0 end, expected: 1, label: "i64 ==")
  test_assert.assert_eq_i64(actual: if i != j then 1 else 0 end, expected: 0, label: "i64 !=")
  test_assert.assert_eq_i64(actual: if i < j + 1 then 1 else 0 end, expected: 1, label: "i64 <")

  // String / char / bool — base scalars per spec.
  let s: string = "abc"
  let t: string = "abc"
  test_assert.assert_eq_i64(actual: if s == t then 1 else 0 end, expected: 1, label: "string ==")
  let c: char = 'q'
  test_assert.assert_eq_i64(actual: if c == 'q' then 1 else 0 end, expected: 1, label: "char ==")
  let b1: bool = true
  test_assert.assert_eq_i64(actual: if b1 == true then 1 else 0 end, expected: 1, label: "bool ==")

  // Record-of-records — comparable(τ) recurses into both Outer fields
  // (Inner) and Inner fields (i64). Bug-pre-fix accepted this same shape
  // but also accepted arrows; bug-post-fix must keep accepting this.
  let p: Outer = { a: { x: 1, y: 2 }, b: { x: 3, y: 4 } }
  let _eq_records = if p == p then 1 else 0 end

  // List-of-i64 — comparable(List<i64>) requires comparable(i64).
  let xs: [ i64 ] = [ 1, 2, 3 ]
  let _eq_list = if xs == xs then 1 else 0 end

  return ()
end

let main = fn () -> unit do
  body()
  return ()
end
