// Regression for nexus-tno5 — float literal patterns were not supported.
// `parse_atom_pattern` had a case for `TkInt` but no case for `TkFloat`, so
// `| 1.5 -> ...` in a match arm threw `UnexpectedToken("pattern", "float")`.
//
// Post-fix: TkFloat and negative-float (`-FLOAT`) are both handled as
// `PatLiteral(lit: LitFloat(val: ...))`, parallel to the existing TkInt case.
// Note: `pipe_scan` in parse_core.nx must not abort on TkMinus, since `-` can
// start a negative-literal arm pattern.
import * as test_assert from "std:test/assert"

let classify = fn (x: f64) -> string do
  match x do
    | 0.0 -> return "zero"
    | 1.5 -> return "one-half"
    | -2.5 -> return "neg-two-half"
    | _ -> return "other"
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_string(actual: classify(x: 0.0), expected: "zero", label: "float pattern 0.0")
  test_assert.assert_eq_string(actual: classify(x: 1.5), expected: "one-half", label: "float pattern 1.5")
  // Negative float in expression context uses -.N.N (OpFNeg), not -N.N (OpNeg).
  test_assert.assert_eq_string(actual: classify(x: -.2.5), expected: "neg-two-half", label: "float pattern -2.5")
  test_assert.assert_eq_string(actual: classify(x: 3.14), expected: "other", label: "float wildcard")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
