// Regression for nexus-lq5l: T-Force must use unify(τ, @β) rather than
// a structural pattern match, so that forcing a generically-typed thunk
// parameter (@T) typechecks correctly.
//
// The bug: `infer_force` did a structural `| TyLazy(inner: u) -> ...`
// match on the expression type. When a param is declared as `@f: T`
// (sigil-prefix form), the env stores TyVar("T") — not TyLazy(TyVar("T")).
// So `@f` fell through to the error arm even though the call site always
// passes a thunk.
//
// The fix: if the type is not structurally TyLazy, attempt
// unify(τ, @β) with a fresh β; on success, return the resolved β.
import * as test_assert from "std:test/assert"

// Sigil-prefix form: `@f: T` — env stores TyVar("T"), triggering the bug.
// After the fix, unify(TyVar("T"), @β) pins T := @β.
let force_sigil_prefix = fn <T>(@f: T) -> T do
  return @f
end

// Type-annotation form: `f: @T` — env stores TyLazy(TyVar("T")),
// structural match already worked. Still verified here for completeness.
let force_thunk = fn <T>(f: @T) -> T do
  return @f
end

let body = fn () -> unit throws { Exn } do
  // Sigil-prefix form (the previously broken case).
  let @t = 42
  let v = force_sigil_prefix(f: t)
  test_assert.assert_eq_i64(actual: v, expected: 42, label: "force_sigil_prefix i64")

  let @t2 = true
  let b = force_sigil_prefix(f: t2)
  test_assert.assert_eq_bool(actual: b, expected: true, label: "force_sigil_prefix bool")

  // Type-annotation form (was already working, kept for regression).
  let @t3 = 99
  let w = force_thunk(f: t3)
  test_assert.assert_eq_i64(actual: w, expected: 99, label: "force_thunk i64")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
