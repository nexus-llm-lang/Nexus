// Negative fixture for nexus-ed9w. Thunks (`@T`) are deferred
// computations, not values — equality on thunks is undefined per spec,
// so `t1 == t2` between two `@i64` parameters must be REJECTED by the
// comparable(τ) predicate. Kept out of `nexus test` discovery by the
// missing `_test` suffix.
let cmp_thunks = fn (@a: @i64, @b: @i64) -> bool do
  return a == b
end

let main = fn () -> unit do
  let @x = 1
  let @y = 2
  cmp_thunks(a: x, b: y)
  return ()
end
