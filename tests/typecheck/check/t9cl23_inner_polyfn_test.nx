// Regression for nexus-t9cl.23 — inner `let f = fn <T>(...)` silently
// dropped the quantifier list in `infer_expr`'s Lambda arm, leaving T as
// a rigid `TyUserDefined("T", [])` that failed to unify with anything at
// the first call site. Users saw the misleading diagnostic "cannot unify
// int literal with non-integer type" instead of a hint that `<T>` is
// only allowed on top-level fn declarations.
//
// Spec narrative (type-system-formal.md §T-Let-PolyFn, line 591):
// "Polymorphic schemes enter Γ only via T-Let-PolyFn (top-level fn
// declarations) or T-Let-Alias". The rule body itself is permissive,
// but the narrative restricts polymorphic generalisation to top-level.
// Post-fix, `infer_lambda` rejects inner `fn <...>(...)` with a focused
// diagnostic that points at the actual problem and suggests hoisting
// the lambda to a top-level binding.
//
// This file is the *positive* fixture: an inner lambda *without*
// type parameters still typechecks (the rejection is gated on the
// quantifier list being non-empty), and a top-level polymorphic fn
// instantiates at two different argument types as the spec intends.
// The negative fixture (intentionally rejected) lives in
// `t9cl23_inner_polyfn_negative.nx` — note the missing `_test`
// suffix, which keeps it out of `nexus test` discovery.
import * as test_assert from "std:test/assert"

// Top-level polymorphic `id`: T-Let-PolyFn legitimately generalises here
// because `id` is a *top-level* binding. The two call sites below
// instantiate T at i64 and at string respectively.
let id = fn <T>(x: T) -> T do
  return x
end

let main = fn () -> unit throws { Exn } do
  // Inner lambda *without* type parameters: still works because the
  // t9cl.23 fix only rejects the non-empty-quantifier case.
  let inc = fn (n: i64) -> i64 do
    return n + 1
  end
  test_assert.assert_eq_i64(
    actual: inc(n: 41),
    expected: 42,
    label: "inner non-polymorphic lambda still typechecks and runs"
  )

  // Two instantiations of the same top-level polymorphic binding —
  // spec T-Let-PolyFn says each occurrence is freshly instantiated.
  let a = id(x: 7)
  test_assert.assert_eq_i64(actual: a, expected: 7, label: "id<i64> returns its argument")
  let b = id(x: "hello")
  test_assert.assert_eq_string(
    actual: b,
    expected: "hello",
    label: "id<string> returns its argument"
  )
  return ()
end
