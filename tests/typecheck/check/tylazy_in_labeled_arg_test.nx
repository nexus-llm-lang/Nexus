// Regression for nexus-hk43: a top-level `let x = e` wraps `x` in
// `TyLazy(...)` (lazy capture machinery for top-level bindings). The
// existing auto-force in operator/comparison position already lets
// `x == y` and `x + 1` work transparently. The missing symmetric site
// is labeled-call-arg position: passing `x` (typed `@T`) to a parameter
// expecting bare `T` previously failed with the misleading
// `[E2001] arg <name>: expected arrow type` diagnostic.
import * as test_assert from "std:test/assert"

let const_value = 17

let take_i64 = fn (target: i64) -> i64 do return target + 1 end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: take_i64(target: const_value),
    expected: 18,
    label: "auto-force in labeled arg"
  )
  return ()
end
