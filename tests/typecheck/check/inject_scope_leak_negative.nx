// Negative fixture for nexus-lcr1. spec T-Inject (after fix) closes the
// inject body's scope via closeBlock(Γ_body', Γ_body) — bindings
// introduced inside `inject do ... end` are not visible after `end`.
// This program references `inner` after the inject block ends; the
// typechecker must REJECT with an unbound-name error.
//
// Kept out of `nexus test` discovery by the missing `_test` suffix.
import * as fs from "std:fs"

let body = fn () -> i64 require { PermFs } do
  inject fs.system_handler do
    let inner = 42
  end
  // `inner` should not be visible here.
  return inner
end

let main = fn () -> unit do
  body()
  return ()
end
