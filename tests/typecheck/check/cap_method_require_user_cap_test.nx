// Regression guard: a cap method whose require row names another user-declared cap
// must be accepted (was false E2013 — nexus-dexah).
//
// D-Cap wfCap (docs/spec/type-system-formal.md §D-Cap):
// ∀j∈J. wfCap(α_j) ∧ wfThrow(β_j) — every entry in α_j must be in SysCaps
// or a declared cap. User-declared caps are valid require-row entries.
//
// Before the fix, check_cap_method_rows in registration.nx called
// wf_cap(caps: []) — passing an empty cap list — so user-declared caps
// were never found, even though they were present in the program.

cap B do
  fn run() -> unit
end

cap A do
  // B is a declared cap — must be accepted in A's method require row.
  fn go() -> string require { B }
end

let main = fn () -> unit do
  return ()
end
