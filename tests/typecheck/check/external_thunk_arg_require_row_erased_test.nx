/**
 * Positive fixture: a thunk argument passed to an EXTERNAL function has its
 * `require` row erased at the FFI boundary.
 *
 * An external is opaque to the effect system — it receives a bare function
 * pointer and neither discharges nor propagates effects. `spawn` forwards its
 * task to the `__nx_sched_spawn` external; the spawned thunk is later resumed
 * by the cooperative `scheduler` inject (installing `Coop`) while the ambient
 * `Console` remains in dynamic scope, so the thunk's `require { Coop, Console }`
 * is discharged downstream rather than at the spawn boundary. Erasing the
 * external thunk-param require row admits this without weakening require-row
 * checking at ordinary call sites (see the companion negative fixture).
 *
 * A successful build is the assertion.
 */
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import { Coop, scheduler, spawn } from "std:concurrency/coop"

let reporter = fn () -> unit require { Coop, Console } do
  Console.println(val: "tick")
  Coop.yield()
  return ()
end

let driver = fn () -> unit require { Console } do
  inject scheduler do
    spawn(task: reporter)
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    driver()
  end
end
