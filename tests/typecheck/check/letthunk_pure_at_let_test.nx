// Regression: T-LetThunk must be PURE at the let.
//
// Bug (nexus-lq3ma.1): infer_thunk typed the body in the ENCLOSING function's
// throw context.  If the body had a throw that the enclosing fn doesn't
// declare, the let was rejected — even though the throw only surfaces at
// force time, not at the let.
//
// After the fix, infer_thunk types the body in an isolated collecting context
// (fresh throw_row + require_row), so the let itself is pure (effect {}).
// The deferred rows are captured into @(σ; ρ_q'; ρ_e') and discharged at
// the force site.
//
// This file must typecheck cleanly to pass the regression.
import * as test_assert from "std:test/assert"

exception E

let thrower = fn () -> i64 throws { E } do
  throw E
end

// build_only: the thunk is built but NEVER forced.
// enclosing fn declares throws {} — pure-at-let means this is now accepted.
let build_only = fn () -> @(i64 throws { E }) throws { } do
  let @t = thrower()
  return t
end

// build_and_force: build a pure thunk and force it.
let force_pure = fn (n: i64) -> i64 do
  let @t = n + 1
  return @t
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: force_pure(n: 3), expected: 4, label: "pure thunk force")
  return ()
end
