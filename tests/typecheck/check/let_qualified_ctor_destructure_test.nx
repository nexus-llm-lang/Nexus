// Regression for nexus-iies — `let mod.Ctor(x) = expr` was not supported
// in the parser. `parse_let_stmt` only checked for `TkUident` followed
// immediately by `(`, so `let mod.Ctor(x) = expr` fell through: the `TkDot`
// caused the lookahead to miss, and the fallback `expect_ident` then threw
// `UnexpectedToken('identifier', 'uident')`.
//
// Post-fix: `parse_let_stmt` also triggers the pattern path for:
//   - `TkIdent . TkUident`  (lowercase module alias: `mod.Ctor`)
//   - `TkUident . TkUident` (uppercase module prefix: `Mod.Ctor`)
// Both route to `parse_pattern` → `try_qualified_ctor_pat`.
// The module prefix is stripped via `rdr_occ` before typechecking so the
// ctor resolves identically to the unqualified form.
import * as test_assert from "std:test/assert"
import * as ta from "std:test/assert"

// Single-ctor type so the let-pattern destructure is exhaustive.
type Wrapper = Wrap(val: i64)

let make = fn () -> Wrapper do
  return Wrap(val: 42)
end

let body = fn () -> unit throws { Exn } do
  // Unqualified baseline — already worked pre-fix.
  let Wrap(val: a) = make()
  test_assert.assert_eq_i64(actual: a, expected: 42, label: "unqualified ctor destructure baseline")

  // Qualified ctor pattern: `let mod.Ctor(f: x) = expr`.
  // Pre-fix this threw UnexpectedToken on the `.`.
  // `ta.Wrap` and `Wrap` lower to the same HIR `PCtor("Wrap", ...)` via rdr_occ.
  let ta.Wrap(val: b) = make()
  test_assert.assert_eq_i64(
    actual: b,
    expected: 42,
    label: "let mod.Ctor(f: x) qualified ctor destructure binds field correctly"
  )
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
