// Regression for nexus-emjp — positive fixture.
//
// T-Throw-Val: the fix adds unify(τ, Exn) after infer_expr inside
// infer_raise. Constructor applications already have result type Exn
// (via D-Exception), so the unify succeeds trivially and this program
// must continue to type-check and run correctly.
//
// Also exercises T-Throw-CtorNullary (bare exception identifier) and
// T-Throw-Ctor (constructor with fields), confirming that neither
// regressed.
import * as test_assert from "std:test/assert"

exception Bang(code: i64)
exception Boom

let catch_bang = fn () -> i64 do
  try
    throw Bang(code: 7)
  catch
    | Bang(code: c) -> return c
    | _ -> return -1
  end
end

let catch_boom = fn () -> bool do
  try
    throw Boom
  catch
    | Boom -> return true
    | _ -> return false
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: catch_bang(),
    expected: 7,
    label: "T-Throw-Ctor: exception constructor with fields accepted"
  )
  test_assert.assert_eq_bool(
    actual: catch_boom(),
    expected: true,
    label: "T-Throw-CtorNullary: bare exception constructor accepted"
  )
  return ()
end
