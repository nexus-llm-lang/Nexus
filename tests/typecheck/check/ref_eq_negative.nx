// Negative fixture for nexus-ed9w. Mutable refs (`ref(T)`) hold a
// location, not a value — equality on refs is undefined per spec, so
// `r1 == r2` must be REJECTED by the comparable(τ) predicate. Kept out
// of `nexus test` discovery by the missing `_test` suffix.
//
// The `~`-sigil at use site reads through the cell to inner T (T-DerefRef
// in spec/typecheck/infer.nx), so bare `x` here exposes the underlying
// `TyRef(i64)` to the comparison and surfaces the rejection.
let main = fn () -> unit do
  let ~x = 1
  let ~y = 2
  x == y
  return ()
end
