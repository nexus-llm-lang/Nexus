// Positive fixture for nexus-t9cl.11. The fix tightened comparable() to
// reject TyVar and unknown TyUserDefined, but the record-with-comparable-
// fields path must continue to typecheck. This exercises the
// `TyUserDefined(name) → typedef_lookup → Some(RecordDef)` arm.
//
// The record comparison is not asserted on (codegen for non-primitive `==`
// is reference-style and outside this fix's scope) — the call is present
// solely to drive the typecheck path that the fix touches.
import * as test_assert from "std:test/assert"

type Point = { x: i64, y: i64 }

let body = fn () -> unit do
  let p1: Point = { x: 1, y: 2 }
  let p2: Point = { x: 1, y: 2 }
  // Drives comparable(TyUserDefined("Point")) → typedef_lookup → Some(RecordDef)
  // → comparable_named_type_list(i64, i64) → both true.
  let _eq_records = if p1 == p2 then 1 else 0 end

  // Also re-assert the underlying primitive path still works after the fix.
  test_assert.assert_eq_i64(
    actual: if 7 == 7 then 1 else 0 end,
    expected: 1,
    label: "i64 == post-fix"
  )
  return ()
end

let main = fn () -> unit do
  body()
  return ()
end
