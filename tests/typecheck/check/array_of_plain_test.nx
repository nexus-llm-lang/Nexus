// Regression for nexus-218q: is_auto_droppable recurses into TyArray's
// element type. Positive half of the fix: arrays of plain (non-linear)
// values must still be auto-droppable at scope end and via wildcard
// discard. Only arrays whose element type is itself non-droppable
// (e.g. `[%ByteBuffer]`) become unconsumable — that case lives in
// `218q_array_of_linear_negative.nx`.
import * as test_assert from "std:test/assert"

let make_ints = fn () -> [ i64 ] do
  return [1, 2, 3]
end

let body = fn () -> unit throws { Exn } do
  // Auto-drop: array of plain i64 falls out of scope without consumption.
  let xs = make_ints()
  xs

  // Wildcard discard inline: also allowed for `[i64]`.
  let ys2 = [ 10, 20, 30 ]
  ys2

  test_assert.assert_eq_bool(
    actual: true,
    expected: true,
    label: "plain-array auto-drop paths typecheck"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
