// nexus-a6qh: HIR Lambda node must preserve throw_row and requires from
// inline lambda expressions (fn at expression position).
//
// Before the fix, ExprLambda's `throw_row` and `requires` were discarded
// during HIR conversion; infer_lambda synthesised empty rows for all inline
// lambdas, so an annotated `throws { MyExn }` was silently treated as `throws {}`.
//
// This test verifies that:
//   1. An inline lambda with `throws { LambdaExn }` is properly typed —
//      throwing inside it does not produce a row-mismatch error.
//   2. The throw propagates out when the lambda is called inside a throwing
//      context, confirming the row was not erased.
//   3. A lambda with no throw annotation is still typed as throws-nothing
//      (regression guard).
import * as test_assert from "std:test/assert"

exception LambdaExn(msg: string)

// Wraps calling an inline throwing lambda and catches the exception.
// try/catch is statement-only, so we wrap in a helper function.
let call_throwing_lambda = fn () -> i64 do
  let throwing_lambda = fn (x: i64) -> i64 throws { Exn } do
    if x == 0 then
      throw LambdaExn(msg: "zero")
    end
    return x
  end
  try
    let _ = throwing_lambda(x: 0)
    return -1
  catch
    | LambdaExn(msg: _) -> return 42
    | _ -> return -2
  end
end

let body = fn () -> unit throws { Exn } do
  // Inline lambda with explicit throws annotation — the throw inside must
  // be admitted by the declared row, not silently dropped to `throws {}`.
  // call_throwing_lambda constructs a `fn (x: i64) -> i64 throws { Exn }` and
  // invokes it; the caught LambdaExn returns 42.
  test_assert.assert_eq_i64(
    actual: call_throwing_lambda(),
    expected: 42,
    label: "inline lambda throw propagates"
  )

  // Non-throwing inline lambda — regression guard, must still compile.
  let pure_lambda = fn (x: i64) -> i64 do
    return x + 1
  end
  test_assert.assert_eq_i64(actual: pure_lambda(x: 10), expected: 11, label: "pure inline lambda")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
