// Positive fixture for the ordering / equality predicate split.
//
// Ordering operators (`<`, `<=`, `>`, `>=`) are restricted to ORDERABLE
// types — numeric, `char`, `string` — while equality (`==`, `!=`) keeps the
// broader `comparable` predicate (records / sums / lists OK, structural
// equality). This fixture confirms BOTH paths stay green after the split:
//   - scalar ordering (i64 / string / char) still typechecks and runs,
//   - structural equality on a record AND a sum still typechecks.
//
// The aggregate `==` calls drive the comparable typecheck path and are not
// asserted on (non-primitive `==` codegen is exercised elsewhere); the
// scalar ordering results ARE asserted, since their runtime order is total
// and unambiguous.
import * as test_assert from "std:test/assert"

type Pair = MkPair(a: i64, b: i64)
type Color = Red | Green | Blue

let body = fn () -> unit do
  // Numeric ordering — orderable(i64).
  let i: i64 = 3
  let j: i64 = 7
  test_assert.assert_eq_i64(actual: if i < j then 1 else 0 end, expected: 1, label: "i64 <")
  test_assert.assert_eq_i64(actual: if j > i then 1 else 0 end, expected: 1, label: "i64 >")
  test_assert.assert_eq_i64(actual: if i <= i then 1 else 0 end, expected: 1, label: "i64 <=")
  test_assert.assert_eq_i64(actual: if j >= j then 1 else 0 end, expected: 1, label: "i64 >=")

  // String ordering — orderable(string), lexicographic.
  let s: string = "apple"
  let t: string = "banana"
  test_assert.assert_eq_i64(actual: if s < t then 1 else 0 end, expected: 1, label: "string <")

  // Char ordering — orderable(char), codepoint order.
  let c: char = 'a'
  let d: char = 'b'
  test_assert.assert_eq_i64(actual: if c < d then 1 else 0 end, expected: 1, label: "char <")

  // Structural equality on a record — comparable(Pair), must typecheck.
  let p = MkPair(a: 1, b: 2)
  let _eq_record = if p == p then 1 else 0 end

  // Structural equality on a sum — comparable(Color), must typecheck.
  let col = Red
  let _eq_sum = if col == col then 1 else 0 end

  return ()
end

let main = fn () -> unit do
  body()
  return ()
end
