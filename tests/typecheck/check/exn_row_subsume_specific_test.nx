// Positive control for nexus-v3xa.1: U-Row-Exn must still admit the SOUND
// direction — a specific actual throws-row flowing into an expected {Exn}.
//
// `g` has type `() -> i64 throws { NotFound }`; `apply` expects
// `h: () -> i64 throws { Exn }` (the catch-all). Passing `g` for `h` unifies
// g's actual row {NotFound} against the expected {Exn}, absorbing the specific
// variant into Exn (specific ⊑ catch-all) — sound, and must type-check.
//
// The unsound reverse — actual {Exn} against a narrow declared row — is
// rejected (see tests/negative/typecheck/exn_row_narrowing_escapes_declared.nx).
//
// `apply` does not invoke `h`, so nothing is thrown at runtime; the test
// asserts type-acceptance of the sound subsumption direction.

exception NotFound(path: string)

let main = fn () -> unit do
  let g = fn () -> i64 throws { NotFound } do throw NotFound(path: "x") end
  let apply = fn (h: () -> i64 throws { Exn }) -> i64 throws { Exn } do return 0 end
  let r = apply(h: g)
  return ()
end
