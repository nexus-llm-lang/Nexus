// Regression test for nexus-5lf0: comparable_go must substitute type args
// when unfolding named record/enum types.
//
// Before the fix, `TyUserDefined(name: "Cell", args: [TyI64])` hit the
// `RecordDef` arm but discarded `args`, leaving the field type as `TyVar("T")`.
// Since `comparable_go(TyVar(_)) = false`, the comparison was rejected with
// E2001 "comparison undefined for …".
//
// After the fix, the type args are zipped with the typedef's type_params into
// a substitution [T:=i64], applied to the field list before recursing, so
// `comparable(Cell<i64>)` correctly reduces to `comparable(i64) = true`.
//
// The same path applies to generic enums (Either<i64, string>): each variant's
// field types are substituted before the recursive comparable check.
//
// Runtime comparison for generic records/enums is identity-style; results are
// not asserted (only typecheck acceptance is verified here).

type Cell<T> = { val: T }

type Either<L, R> = Left(val: L) | Right(val: R)

let body = fn () -> unit do
  let a: Cell<i64> = { val: 1 }
  let b: Cell<i64> = { val: 2 }
  // Must typecheck: unfold(Cell<i64>) = {val: i64}, comparable(i64) = true.
  let _eq_cell = if a == b then 1 else 0 end

  // Generic enum: either<i64, string> — payload fields substituted before check.
  let l: Either<i64, string> = Left(val: 1)
  let r: Either<i64, string> = Right(val: "x")
  let _eq_either = if l == r then 1 else 0 end

  return ()
end

let main = fn () -> unit do
  body()
  return ()
end
