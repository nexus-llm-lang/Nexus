// Negative fixture for nexus-t9cl.11. The bd issue's repro:
// `comparable(TyVar(_))` previously returned true unconditionally, which
// allowed equality on a polymorphic value whose type was never pinned to a
// concrete comparable type. Per spec § T-Cmp (line 897 of
// type-system-formal.md), comparable(α) and comparable(?α) are both false
// — the comparability bound is missing. Must be REJECTED with a
// comparable(τ)-based diagnostic. Kept out of `nexus test` discovery by the
// missing `_test` suffix.
let polyeq = fn <T>(x: T, y: T) -> bool do
  return x == y
end
let main = fn () -> unit do
  let _ = polyeq(x: 1, y: 2)
  return ()
end
