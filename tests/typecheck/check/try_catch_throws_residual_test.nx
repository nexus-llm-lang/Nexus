// nexus-rm9k: T-TryCatch throws-row residual narrowing.
//
// A `throws {}` function should be able to locally throw an exception and
// handle it with a catch-all arm — the throw never escapes the try/catch,
// so the residual effect is empty and must typecheck.
//
// This file verifies:
//   1. Positive: catch-all arm in a `throws {}` function swallows the throw.
//   2. Positive: multi-arm catch-all in a `throws {}` function.
//   3. Positive: selective catch in a `throws { Exn }` function still works
//      as a regression guard.
//   4. Positive: catch-all in a `throws {}` function whose callee throws.
//
// Note: `throw X` inside a try body is diverging; the catch body must also
// diverge for the overall expression to return.  All helper functions here
// are parameterised so the try body is non-trivially reachable (avoiding
// E2021 dead-code after unconditional throw).
import * as test_assert from "std:test/assert"

exception Boom
exception Tag(code: i64)

// Helper that may throw depending on a flag.
let maybe_throw_boom = fn (do_it: bool) -> i64 throws { Exn } do
  if do_it then
    throw Boom
  end
  return 0
end

// Helper that may throw a Tag.
let maybe_throw_tag = fn (code: i64, do_it: bool) -> i64 throws { Exn } do
  if do_it then
    throw Tag(code)
  end
  return code
end

// --- Case 1: catch-all swallows local throw in throws {} function ------------
// This is the exact repro from nexus-rm9k.  Before the fix this produced:
//   E2001: try body: throw Boom: function declares throws {}, no exceptions are permitted
let pure_catch_all = fn (do_throw: bool) -> i64 throws {} do
  try
    let _ = maybe_throw_boom(do_it: do_throw)
    return 0
  catch _ ->
    return 42
  end
end

// --- Case 2: multi-arm catch-all in throws {} function ----------------------
let pure_multi_catch_all = fn (code: i64, do_throw: bool) -> i64 throws {} do
  try
    let _ = maybe_throw_tag(code, do_it: do_throw)
    return 0
  catch
    | Tag(code: c) -> return c
    | _ -> return -2
  end
end

// --- Case 3: regression — selective catch still works in throws { Exn } -----
let selective_in_throws_exn = fn (code: i64, do_throw: bool) -> i64 throws { Exn } do
  try
    let _ = maybe_throw_tag(code, do_it: do_throw)
    return 0
  catch
    | Tag(code: c) -> return c
    | _ -> return -3
  end
end

// --- Case 4: catch-all over a callee that throws ----------------------------
let may_throw = fn (x: i64) -> i64 throws { Exn } do
  if x == 0 then
    throw Tag(code: 0)
  end
  return x
end

let wrap_callee_throw = fn (x: i64) -> i64 throws {} do
  try
    return may_throw(x)
  catch _ ->
    return 100
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: pure_catch_all(do_throw: true), expected: 42, label: "catch-all swallows throw in throws {}")
  test_assert.assert_eq_i64(actual: pure_catch_all(do_throw: false), expected: 0, label: "catch-all: no throw returns normally")
  test_assert.assert_eq_i64(actual: pure_multi_catch_all(code: 99, do_throw: true), expected: 99, label: "multi-arm catch-all in throws {}")
  test_assert.assert_eq_i64(actual: selective_in_throws_exn(code: 7, do_throw: true), expected: 7, label: "selective catch in throws { Exn }")
  test_assert.assert_eq_i64(actual: wrap_callee_throw(x: 0), expected: 100, label: "catch-all over callee throw in throws {}")
  test_assert.assert_eq_i64(actual: wrap_callee_throw(x: 5), expected: 5, label: "catch-all: callee doesn't throw returns value")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
