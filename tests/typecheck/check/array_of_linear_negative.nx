// Negative fixture for nexus-218q: is_auto_droppable must recurse into
// TyArray's element type. Pre-fix, `TyArray(_) -> true` accepted any
// array, so a `%[%ByteBuffer]` parameter was silently auto-dropped at
// function end via `param_inner_is_auto_droppable` — even though the
// inner element type `%ByteBuffer` is itself non-droppable.
//
// Post-fix `is_auto_droppable(TyArray(elem: e))` recurses into `e`, so
// `[%ByteBuffer]` is no longer auto-droppable and the linear param
// `bufs` must trigger an unused-linear diagnostic at function end.
//
// Filename intentionally omits `_test` so `nexus test` does not pick
// it up (a fixture that intentionally fails compile would otherwise
// be reported as a runner failure).
import * as bb from "std:bytebuffer"

let body = fn (bufs: %[ %ByteBuffer ]) -> unit do
  // bufs is %[%ByteBuffer]; pre-fix it auto-dropped silently here.
  // Post-fix the function-end linearity check raises LinearUnused(name: "bufs").
  return ()
end

let main = fn () -> unit do
  body(bufs: [ bb.empty() ])
  return ()
end
