// Negative fixture for nexus-t9cl.11. `comparable(TyUserDefined(name))`
// previously returned true when `typedef_lookup(name)` returned None — i.e.
// for enums and opaque imports the predicate silently accepted them. Per
// spec § T-Cmp, an opaque type unfolds to `opaque` (comparable = false) and
// sum-body unfolding is a separate spec follow-up (nexus-t9cl.6). For the
// MVP fix, any unknown TyUserDefined name must be REJECTED. Kept out of
// `nexus test` discovery by the missing `_test` suffix.
//
// This fixture uses an enum (sum) — its `comparable` should not be granted
// automatically; the typechecker has no record body to expand.
type Color = Red | Green | Blue
let main = fn () -> unit do
  let a: Color = Red
  let b: Color = Green
  a == b
  return ()
end
