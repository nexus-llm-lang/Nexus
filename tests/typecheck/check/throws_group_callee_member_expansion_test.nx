// A GROUP label appearing in a CALLEE's declared `throws { G }` row must be
// expanded to its member set when checked against the caller's declared
// throws row. A caller that lists every member of the group individually
// (or lists the group itself) subsumes the callee — the call must be
// admitted (no over-rejection).
//
// Previously the call-site row-subsumption check compared the bare group
// label `IOError` against the caller's member list literally and rejected,
// even though the caller covered all members.
import * as test_assert from "std:test/assert"

exception NotFound(path: string)
exception PermDenied(path: string)
exception group IOError = NotFound | PermDenied

// Callee declares the GROUP and raises members.
let open_file = fn (path: string, missing: bool) -> i64 throws { IOError } do
  if missing then
    throw NotFound(path: path)
  end
  throw PermDenied(path: path)
end

// Caller lists every MEMBER of the group individually and propagates the
// group-declaring callee. The group label in the callee row is expanded to
// {NotFound, PermDenied}, both of which the caller admits -> ACCEPTED.
let try_open_members = fn (path: string) -> i64 throws { NotFound, PermDenied } do
  try
    return open_file(path: path, missing: true)
  catch
    | NotFound -> return 11
    | PermDenied -> return 22
  end
end

// Caller lists the GROUP itself and propagates the group-declaring callee.
let try_open_group = fn (path: string) -> i64 throws { IOError } do
  try
    return open_file(path: path, missing: false)
  catch
    | IOError -> return 33
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: try_open_members(path: "/a"),
    expected: 11,
    label: "caller listing members admits group-declaring callee"
  )
  test_assert.assert_eq_i64(
    actual: try_open_group(path: "/b"),
    expected: 33,
    label: "caller listing the group admits group-declaring callee"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
