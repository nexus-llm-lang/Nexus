// Port of bootstrap/tests/typecheck/effects.rs::
// test_main_require_known_perm_is_accepted.
//
// `main` may declare a `require { PermFs }` row — the typechecker
// validates the row member against the registered permission set.
// We exercise the runtime path by injecting fs.system_handler and
// invoking a no-op (Fs.exists on a fresh path), so the program both
// typechecks and runs to completion under `--allow-fs`.
import { Fs }, * as fs from "std:fs"

let main = fn () -> unit require { PermFs } do
  inject fs.system_handler do
    Fs.exists(path: "/tmp/_nx_typecheck_perm_marker")
    return ()
  end
end
