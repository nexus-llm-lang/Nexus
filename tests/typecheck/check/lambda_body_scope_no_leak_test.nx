// Regression for nexus-z1258 — a `let` introduced inside a sibling lambda
// body must NOT leak into the ENCLOSING block's typecheck Γ.
//
// `helper`'s body declares an inner shadow `let useG = fn (n: i64) ...`.
// Before the fix, that inner binding leaked back into `driver`'s block env
// (infer_lambda returned the body's post-inference state without restoring
// the enclosing env), so the LATER outer call `useG(a: 3)` was checked
// against the LEAKED inner signature (param `n`) and rejected with
//   E2001 argument label 'a' does not match any parameter name.
//
// With the fix (infer_lambda restores the enclosing env after checking the
// body — closeBlock, spec type-system-formal.md :318/:320), the outer
// `useG` still binds the param `a`, so this program typechecks cleanly and
// returns 13 + 1 = 14.
//
// Lexical scope INWARD is unaffected: `helper`'s body can still see the
// outer `useG`; only the inner→outer leak is closed.

let driver = fn () -> i64 do
  let useG = fn (a: i64) -> i64 do return a + 10 end
  let helper = fn (k: i64) -> i64 do
    let useG = fn (n: i64) -> i64 do return n + 1 end
    return useG(n: k)
  end
  // Calls the OUTER useG (param `a`), NOT the inner shadow (param `n`).
  return useG(a: 3) + helper(k: 0)
end

let main = fn () -> unit do
  let r = driver()
  return ()
end
