// nexus-d1gkw: a single-variable catch arm `catch e -> ...` is a catch-all.
//
// Per spec type-system-formal.md §T-TryCatch,
//   hasCatchAll(p̄) = ∃i. pᵢ = _  ∨  pᵢ is a variable pattern x
// so a single-variable catch (binding the exception at type Exn) handles every
// exception and empties the residual throws-row → ρ_residual = {}.  Before the
// fix only the wildcard form `catch _ -> ...` was recognised; the single-var
// binder form `catch e -> ...` was rejected E2001 against a `throws {}` caller.
//
// This file verifies (runtime-executing positives):
//   1. Single-var catch-all swallows a local throw in a `throws {}` function.
//   2. Single-var catch-all over a callee that throws in a `throws {}` function.
//   3. The bound exception variable is usable inside the catch body.
//
// The selective-catch guard (single-var catch-all must NOT over-clear when a
// SPECIFIC-constructor arm leaves a residual) lives in the negative fixture
// tests/negative/typecheck/single_var_selective_catch_residual.nx.
import * as test_assert from "std:test/assert"

exception Boom
exception Tag(code: i64)

let maybe_throw_boom = fn (do_it: bool) -> i64 throws { Exn } do
  if do_it then
    throw Boom
  end
  return 0
end

let maybe_throw_tag = fn (code: i64, do_it: bool) -> i64 throws { Exn } do
  if do_it then
    throw Tag(code)
  end
  return code
end

// --- Case 1: single-var catch-all swallows local throw in throws {} ----------
let pure_single_var_catch_all = fn (do_throw: bool) -> i64 throws {} do
  try
    maybe_throw_boom(do_it: do_throw)
    return 0
  catch e ->
    return 42
  end
end

// --- Case 2: single-var catch-all over a callee that throws ------------------
let wrap_callee_single_var = fn (x: i64) -> i64 throws {} do
  try
    return maybe_throw_tag(code: x, do_it: true)
  catch e ->
    return 100
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: pure_single_var_catch_all(do_throw: true),
    expected: 42,
    label: "single-var catch e -> swallows throw in throws {}"
  )
  test_assert.assert_eq_i64(
    actual: pure_single_var_catch_all(do_throw: false),
    expected: 0,
    label: "single-var catch-all: no throw returns normally"
  )
  test_assert.assert_eq_i64(
    actual: wrap_callee_single_var(x: 7),
    expected: 100,
    label: "single-var catch-all over callee throw in throws {}"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
