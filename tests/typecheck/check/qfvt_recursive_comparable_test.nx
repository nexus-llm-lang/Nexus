// Regression test for nexus-qfvt: comparable'(τ, V) cycle case must be the
// GREATEST fixpoint (return true on a named type already on the unfold path),
// not the least fixpoint (false).
//
// Before the fix, comparable_go's TyUserDefined arm returned false whenever the
// name was already in the visited set. For an AND-combined predicate (a sum is
// comparable iff every variant's every field is) this made EVERY recursive type
// non-comparable: `Node`'s `left: Tree` field hit the cycle guard → false →
// Tree not comparable → even `Leaf == Leaf` was rejected with E2001.
//
// After the fix, the cycle arm returns true (assume the recursive occurrence is
// comparable; only concrete incomparable components — arrow/handler/ref/borrow/
// thunk/array/linear — are rejected). Structural `==` on finite values
// terminates, so this is sound and matches the runtime operator.
//
// Only typecheck acceptance is asserted (comparison results are not checked).

type Tree = Leaf | Node(left: Tree, val: i64, right: Tree)

// Mutually recursive sums.
type Even = Zero | ESucc(odd: Odd)
type Odd = OSucc(even: Even)

let body = fn () -> unit do
  // Self-recursive sum: must typecheck (was rejected pre-fix, even for Leaf).
  let _eq_tree = if Leaf == Leaf then 1 else 0 end
  let t1: Tree = Node(left: Leaf, val: 1, right: Leaf)
  let t2: Tree = Node(left: Leaf, val: 2, right: Leaf)
  let _eq_node = if t1 == t2 then 1 else 0 end

  // Mutually recursive sums: must typecheck.
  let _eq_even = if Zero == Zero then 1 else 0 end

  return ()
end

let main = fn () -> unit do
  body()
  return ()
end
