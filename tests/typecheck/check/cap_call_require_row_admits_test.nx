// Positive fixture for T-CapCall require-row discharge (nexus-iff93).
//
// The env'd require row of a cap method is `{cap} ∪ α` (spec §T-CapCall).
// A function that calls a cap method is admitted in two ways:
//   1. it declares the cap directly in its own require row, or
//   2. an enclosing `inject` extends the ambient require row with the cap.
//
// This fixture exercises BOTH admit paths so the iff93 fix (which replaced the
// hardcoded empty cap-method require row with `{cap} ∪ α`) does not over-reject
// legitimate cap calls. A successful build is the assertion.

cap Logger do
  fn log(msg: string) -> unit
end

let the_logger = handler Logger require { PermConsole } do
  fn log(msg: string) -> unit do
    return ()
  end
end

// Path 1: `Logger` is named directly in `direct_caller`'s require row, so the
// cap-method require row `{ Logger }` is a subset of the ambient row.
let direct_caller = fn () -> unit require { Logger } do
  Logger.log(msg: "direct")
  return ()
end

// Path 2: no `require { Logger }` here; the enclosing `inject the_logger`
// extends the ambient require row with `Logger` (T-Inject), satisfying the
// cap-method require row inside the inject body.
let inject_caller = fn () -> unit require { PermConsole } do
  inject the_logger do
    Logger.log(msg: "injected")
    return ()
  end
end

let main = fn () -> unit do
  return ()
end
