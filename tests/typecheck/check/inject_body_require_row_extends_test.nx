// Positive fixture for nexus-pk1n.
//
// T-Inject (spec type-system-formal.md): when entering the inject body,
// the ambient require_row is extended: ρ_q' = merge(ρ_q, {P̄}), where P̄
// are the port names of the injected handlers.
//
// This test exercises a nested inject inside an outer inject body.  The
// outer inject provides the Fs port; the inner inject provides a Logger
// port.  Both inject sites are accepted: empty ⊆ ρ_q' holds trivially
// for the Logger handler (no require row), and the body_state threaded
// into the outer inject body correctly carries the extended row.
//
// The fixture is purely compile-time (typecheck + codegen) — no runtime
// assertions.  A successful build proves the require_row extension path
// is traversed without error and that nested inject compiles cleanly.
//
// nexus-pk1n
import { Fs }, * as fs from "std:fs"

cap Logger do
  fn log(msg: string) -> unit
end

let the_logger = handler Logger do
  fn log(msg: string) -> unit do return () end
end

let run = fn () -> unit require { PermFs } do
  inject fs.system_handler do
    // After this inject, ρ_q' = merge({PermFs}, {Fs}).
    // The inner inject provides Logger (empty require row ⊆ ρ_q').
    inject the_logger do
      Fs.exists(path: "/tmp/_nx_pk1n_marker")
      Logger.log(msg: "ok")
      return ()
    end
  end
end

let main = fn () -> unit require { PermFs } do
  run()
  return ()
end
