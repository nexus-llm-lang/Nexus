// Positive fixture for T-CapCall require-row enforcement inside a handler arm
// body (nexus-4twfh).
//
// The arm body's ambient require row ρ_q is the handler's declared `require {…}`
// row. When the handler declares the cap it calls, the arm body's cap call is
// admitted (x ∈ ρ_q holds). This guards against the 4twfh fix over-rejecting
// legitimate cap calls inside arm bodies. A successful run is the assertion.
//
// nexus-4twfh

cap Logger do
  fn log(msg: string) -> unit
end

cap Hidden do
  fn h() -> unit
end

let hid_handler = handler Hidden require { } do
  fn h() -> unit do
    return ()
  end
end

// `another` declares `require { Hidden }`, so calling `Hidden.h()` in its arm
// body satisfies the require-row premise (Hidden ∈ { Hidden }).
let another = handler Logger require { Hidden } do
  fn log(msg: string) -> unit do
    Hidden.h()
    return ()
  end
end

// `main` provides Hidden (via `inject hid_handler`) at the point where `another`
// is injected, satisfying T-Inject (ρ_another = { Hidden } ⊆ ambient).
let main = fn () -> unit do
  inject hid_handler do
    inject another do
      Logger.log(msg: "x")
      return ()
    end
  end
end
