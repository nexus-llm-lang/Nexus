// Regression: implicit force-call `f(args)` on a thunk-typed callee must
// count as a force for linearity purposes (nexus-lq3ma.2).
//
// Bug (nexus-lq3ma.2): `f(args)` where `f : @(arrow)` was NOT counted as a
// reference to the lazy binding `f` in the shared/linearity.nx pass, because
// Call(func: name, ...) ignored the func name in count_refs_expr_kind.
// This caused false-positive "lazy binding @f is never forced" (E2005).
//
// After the fix, Call(func: name, ...) counts name as a reference, so
// `f(x: 1)` correctly discharges the linearity obligation on the lazy binding.
//
// This file must typecheck cleanly (no E2005) to pass the regression.
// (Runtime correctness of the implicit-force-call path is a separate codegen
//  concern tracked in the same bd issue.)

let g = fn (f: @((x: i64) -> i64)) -> i64 do
  return f(x: 1)
end

let main = fn () -> unit do return () end
