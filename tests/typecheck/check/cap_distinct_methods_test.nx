// Regression guard: a cap with distinct method names must still type-check
// after D-Cap distinctness enforcement (E2036) was added.
//
// D-Cap requires distinct(ℓ_j | j ∈ J). Two caps with entirely different
// method sets, and one cap with three distinct labels, must all be accepted.

cap Logger do
  fn log(msg: string) -> unit
  fn warn(msg: string) -> unit
  fn error(msg: string) -> unit
end

cap Counter do
  fn inc() -> unit
  fn get() -> i64
end

let main = fn () -> unit do
  return ()
end
