// Regression: the unified inference-row pinning for the throws-row class must
// still ACCEPT every legitimate force / lambda / require-deferral shape — the
// fix closes the soundness holes WITHOUT over-rejecting valid programs.
//
// Covers four positive shapes that must keep typechecking + running cleanly:
//   1. force-into-an-admitting-slot: a collecting body forces an E-throwing
//      thunk and returns it at a slot that DOES admit E.
//   2. lambda-pure: an unannotated lambda whose body throws nothing, returned
//      at a throwing slot, is fine (it throws ⊆ the slot).
//   3. lambda-into-admitting-slot: an unannotated lambda whose body throws E,
//      returned at a `throws { E }` slot, is admitted.
//   4. require-deferral: a collecting body forces a cap-requiring thunk; the
//      surfaced require is DEFERRED into the collecting require row (it surfaces
//      only when the OUTER thunk is forced), so the constructing fn stays
//      `require {}` and the returned thunk legitimately carries the cap.
//
// This file must typecheck cleanly AND run to pass the regression.
import * as test_assert from "std:test/assert"

exception E

// (1) force-into-admitting-slot: surfaced E narrows into a slot that admits E.
let force_admit = fn (inner: @(i64 throws { E })) -> @(i64 throws { E }) throws { } do
  let @t = @inner
  return t
end

// (2) lambda-pure: unannotated lambda, body throws nothing, returned at a
//     throwing slot — fine.
let mk_pure = fn () -> (() -> i64 throws { E }) do
  let g = fn () -> i64 do return 1 end
  return g
end

// (3) lambda-into-admitting-slot: unannotated lambda body throws E, returned at
//     a `throws { E }` slot.
let mk_admit = fn () -> (() -> i64 throws { E }) do
  let g = fn () -> i64 do throw E end
  return g
end

// (4) require-deferral: forcing a cap-requiring inner thunk inside a collecting
//     body defers the require into the collecting row; mk needs no caps to
//     BUILD the thunk, and the returned thunk carries the cap (surfaces only at
//     force time).
let req_defer = fn (
  inner: @(i64 require { PermConsole })
) -> @(i64 require { PermConsole }) require { } do
  let @t = @inner
  return t
end

let main = fn () -> unit throws { Exn } do
  let h = mk_pure()
  let r = h()
  test_assert.assert_eq_i64(actual: r, expected: 1, label: "lambda-pure force")
  return ()
end
