// Negative fixture for nexus-t9cl.11. Variants on an enum (sum) type with
// data payloads — the previous impl returned true unconditionally for any
// TyUserDefined whose typedef_lookup hit None, including enums. Sum-body
// comparability requires unfolding to each variant's payload field types
// (nexus-t9cl.6 follow-up). Until that lands, sum equality must be REJECTED
// to keep the predicate sound. Kept out of `nexus test` discovery by the
// missing `_test` suffix.
type Shape = Circle(radius: i64) | Square(side: i64)
let main = fn () -> unit do
  let a: Shape = Circle(radius: 3)
  let b: Shape = Square(side: 4)
  let _ = a == b
  return ()
end
