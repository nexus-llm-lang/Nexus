// Positive companion to 2yxp_match_thunk_negative.
// After nexus-2yxp, strip(τ) no longer peels @σ — so the explicit
// `match @x do ...` (force-then-match) is the canonical shape, and the
// previously-accepted implicit `match thunk do ...` is rejected. This
// fixture confirms the explicit form still typechecks and runs.
import * as test_assert from "std:test/assert"

type Box = MkBox(val: i64)

let make_box = fn () -> Box do
  return MkBox(val: 21)
end

let body = fn () -> unit throws { Exn } do
  let @t = make_box()
  let v = match @t do
    | MkBox(val: v) -> v
  end
  test_assert.assert_eq_i64(actual: v, expected: 21, label: "match @thunk destructure")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
