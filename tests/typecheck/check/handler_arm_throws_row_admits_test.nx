// Positive fixture for T-Handler throws reconciliation inside a handler arm
// body (throws-side sibling of nexus-4twfh).
//
// The fix pins each arm body's ambient throw row to the cap method's declared
// `throws` row (closing the legacy implicit-open tail). This test guards
// against that pinning OVER-rejecting legitimate handlers. Three legitimate
// shapes must still type-check:
//
//   1. `loud.log`  — the cap method declares `throws { Boom }` and the arm body
//      raises `Boom`: the body throws ⊆ the declared row, so it is admitted.
//   2. `quiet.log` — the cap method declares no throws (closed `{}`) and the
//      arm body raises `Boom` but fully catches it with a catch-all, so nothing
//      escapes the closed row.
//   3. `pure.note` — the cap method declares no throws and the arm body raises
//      nothing at all.
//
// A successful run (no exception) is the assertion: every handler below must
// type-check AND execute without an uncaught exception escaping.

exception Boom

cap Loud do
  fn log(msg: string) -> unit throws { Boom }
end

cap Quiet do
  fn log(msg: string) -> unit
end

cap Note do
  fn note(msg: string) -> unit
end

// (1) arm body throws ⊆ cap method declared `throws { Boom }`.
let loud = handler Loud require { } do
  fn log(msg: string) -> unit throws { Boom } do
    throw Boom
  end
end

// (2) cap method declares no throws; arm body raises but absorbs it locally,
//     so the body's effective throw set is empty.
let quiet = handler Quiet require { } do
  fn log(msg: string) -> unit do
    try
      throw Boom
    catch _ ->
      return ()
    end
  end
end

// (3) cap method declares no throws; arm body raises nothing.
let pure = handler Note require { } do
  fn note(msg: string) -> unit do
    return ()
  end
end

// `consume_loud` declares `throws { Boom }`, so injecting `loud` and calling
// `Loud.log` (which may raise Boom) is admitted.
let consume_loud = fn () -> unit throws { Boom } do
  inject loud do
    Loud.log(msg: "x")
    return ()
  end
end

let main = fn () -> unit do
  // (1) Loud.log can raise Boom; catch it so main stays closed.
  try
    consume_loud()
  catch _ ->
    ()
  end
  // (2) Quiet.log absorbs its own throw — nothing escapes.
  inject quiet do
    Quiet.log(msg: "y")
    ()
  end
  // (3) Note.note raises nothing.
  inject pure do
    Note.note(msg: "z")
    return ()
  end
end
