// Positive regression for nexus-w2x4: a `throws {}` function calling an
// unannotated function that does NOT throw must still type-check and run
// correctly.
//
// The fix distinguishes the `__implicit` absent-annotation open row from a
// genuine effect-polymorphic variable.  When the callee has an `__implicit`
// tail AND the callee body never throws (so the open tail never materialises
// into a concrete exception), the call is still rejected at compile time by
// the strict rule — UNLESS the callee itself declares `throws {}`.
//
// This test verifies the safe subcase: callee annotated `throws {}` (closed
// empty) is admitted by a `throws {}` caller, because a closed-empty callee
// row is always admitted (the fix only restricts open `__implicit` rows).

import * as test_assert from "std:test/assert"

let pure_callee = fn () -> unit throws {} do
  return ()
end

let strict = fn () -> unit throws {} do
  pure_callee()
  return ()
end

let main = fn () -> unit do
  strict()
  test_assert.assert_eq_i64(
    actual: 1,
    expected: 1,
    label: "w2x4: throws{} calling throws{} callee is admitted"
  )
  return ()
end
