// Regression fixture for nexus-dp4e — T-Let-Alias pure(Γ\{y}) premise.
//
// Spec type-system-formal.md §T-Let-Alias requires `pure(Γ \ {y})` at the
// alias site: when `let f = g` copies a polymorphic scheme, the environment
// minus the aliased variable must contain no linear binders.
//
// This file is the *positive* fixture: a T-Let-Alias site where the
// environment contains only non-linear (ω-multiplicity) bindings must
// typecheck cleanly, and the alias must behave polymorphically.
// The negative fixture (alias with live linear in scope) lives in
// `dp4e_let_alias_pure_env_negative.nx` — note the missing `_test` suffix,
// which keeps it out of `nexus test` discovery.
import * as test_assert from "std:test/assert"

let id = fn <T>(x: T) -> T do
  return x
end

let first = fn <A, B>(a: A, b: B) -> A do
  return a
end

let body = fn () -> unit throws { Exn } do
  // Pure env at alias site: no linear binders in scope.
  // T-Let-Alias fires: `f` copies the scheme of `id`.
  let f = id
  let i = f(x: 10)
  test_assert.assert_eq_i64(actual: i, expected: 10, label: "alias polymorphism at i64")
  let b = f(x: true)
  test_assert.assert_eq_bool(actual: b, expected: true, label: "alias polymorphism at bool")

  // Non-linear i64 binding in scope before alias — ω multiplicity,
  // so pure(Γ \ {first}) holds and T-Let-Alias still fires.
  let n = 42
  let g = first
  let r = g(a: n, b: "hello")
  test_assert.assert_eq_i64(actual: r, expected: 42, label: "alias with omega binding in scope")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
