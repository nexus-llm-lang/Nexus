// Negative fixture for nexus-luct — T-For body bindings (including the loop
// variable) leak into the outer scope.
// Pre-fix, `let x` introduced inside a for body (and the loop variable itself)
// leaked into the outer scope because infer_for returned `st4` (post-body
// state) directly.  Post-fix, the body env is reverted to the pre-for state
// before returning InferExprOk to the caller.
//
// This program references `body_local` after the for loop ends; the
// typechecker must REJECT with an unbound-name error.
//
// Kept out of `nexus test` discovery by the missing `_test` suffix.

let main = fn () -> unit do
  for i = 0 to 3 do
    let body_local = i * 2
    let _ = body_local
  end
  // `body_local` should NOT be visible here — it was introduced inside
  // the for body only.
  let _ = body_local
  return ()
end
