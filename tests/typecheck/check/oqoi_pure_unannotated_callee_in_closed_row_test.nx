// nexus-oqoi (case B): a `throws {}` function calling an unannotated callee
// whose body contains no Raise must compile and run correctly.
//
// The fix (direction a) builds a side-table of provably-non-throwing function
// names (fn_pure_set) before body checking.  When `check_call_throw_row_admitted`
// encounters an `__implicit`-tailed callee row under a `throws {}` caller, it
// consults fn_pure_set: if the callee is there, the call is admitted.

import * as test_assert from "std:test/assert"

let pure_helper = fn () -> i64 do
  return 42
end

let strict = fn () -> unit throws {} do
  let _ = pure_helper()
  return ()
end

let main = fn () -> unit do
  strict()
  test_assert.assert_eq_i64(actual: 1, expected: 1, label: "oqoi B: pure unannotated callee admitted under throws {}")
  return ()
end
