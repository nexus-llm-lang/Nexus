import * as test_assert from "std:test/assert"

exception FrameErr(msg: string)
exception EofErr
exception ParseErr(pos: i64)

exception group ProtoErr = FrameErr | EofErr | ParseErr

let source = fn (n: i64) -> i64 throws { ProtoErr } do
  if n == 0 then
    throw EofErr
  end
  return n
end

/** Multi-arm `catch` desugar: a selective `FrameErr` arm followed by a
 *  catch-all `err` binder that re-throws. The catch param is the synthetic
 *  `__exn`, but the rethrown variable is the arm binder `err`. The body's
 *  actual throws (the `ProtoErr` group) minus the `FrameErr` arm is a subset
 *  of the declared row, so the `throw err` rethrow is admitted. */
let dispatch = fn (n: i64) -> i64 throws { ProtoErr } do
  try
    return source(n: n)
  catch
    | FrameErr(msg: _) -> return -1
    | err -> throw err
  end
end

let main = fn () -> unit throws { Exn } do
  let r = dispatch(n: 7)
  test_assert.assert_eq_i64(
    actual: r,
    expected: 7,
    label: "selective-arm-then-catch-all rethrow binder admitted when residual is a subset of the declared row"
  )
  return ()
end
