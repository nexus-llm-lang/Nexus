// T-Cmp sum unfold: enum variants with all-comparable payloads make
// the enum itself comparable at the type-check level (nexus-jrmo).
//
// Before the fix, `comparable(TyUserDefined("Color", _), tdefs)` returned
// false for any enum because comparable_go only expanded RecordDef typedefs
// and fell through to `None -> false` for enum names.  The operator `==`
// on an enum would be rejected with E2001 "comparison undefined …".
//
// After the fix, enum_lookup finds the EnumEntry, checks every variant's
// fields recursively, and returns true when all fields are comparable,
// allowing the `==` / `!=` operators to type-check on such enums.
//
// This fixture verifies type-check acceptance only.  Runtime value equality
// for enums is a separate concern (enum == currently compares by identity,
// not structural equality; tracked as a follow-up).
//
// Note: functions are called from main so they survive DCE and are
// type-checked; results are discarded (not asserted) since runtime enum
// equality is identity-based, not structural.

type Color = Red | Green | Blue(level: i64)

// These functions must type-check without error after the fix.
// Before the fix they would produce E2001 "comparison undefined for …".
let eq_color = fn (a: Color, b: Color) -> bool do
  return a == b
end

let ne_color = fn (a: Color, b: Color) -> bool do
  return a != b
end

// A simple enum with no payload fields must also type-check.
type Dir = North | South | East | West

let eq_dir = fn (a: Dir, b: Dir) -> bool do
  return a == b
end

let main = fn () -> unit do
  // Call the functions to prevent DCE; results not asserted.
  let _ = eq_color(a: Red, b: Green)
  let _ = ne_color(a: Red, b: Green)
  let _ = eq_dir(a: North, b: South)
  return ()
end
