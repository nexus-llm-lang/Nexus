// Negative fixture for nexus-t9cl.21. Spec L548-L552 (kindOf):
// `kindOf(T, σ) = undefined` when `T` appears nowhere in σ — a static
// error raised at the binding site (T-Let-PolyFn). Must be REJECTED
// with E2011 "unused type parameter ... is never used in its signature".
//
// Kept out of `nexus test` discovery by the missing `_test` suffix
// (matches the convention of t9cl11_polymorphic_eq_negative.nx etc.).
let foo = fn <T>(x: i64) -> i64 do
  return x
end
let main = fn () -> unit do
  foo(x: 42)
  return ()
end
