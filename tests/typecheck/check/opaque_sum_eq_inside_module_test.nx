// Regression: inside the defining module, opaque sum types are comparable
// (spec T-Cmp unfold rule, "if typedef(x) is a sum AND (x is not opaque OR
// we are in its defining module)").
//
// Pre-fix: enum_lookup returned None for all opaque enums regardless of
// visibility, causing E2001 "cannot compare values of type" even within the
// defining module.
// Post-fix: enum_lookup inspects the variant list — variants are preserved
// (non-empty) for locally-defined opaque enums and stripped to [] for
// imported ones, so non-empty variants = in the defining module.
//
// This fixture verifies type-check acceptance only. Runtime enum equality
// compares by identity, not structural equality; results are not asserted
// (see t_cmp_sum_unfold_test.nx for the same rationale on non-opaque enums).
// Functions are called from main to survive DCE and exercise the checked path.

opaque type Color = Red | Blue

// No-payload opaque sum: == must type-check inside the defining module.
let color_eq = fn (a: Color, b: Color) -> bool do
  return a == b
end

let color_ne = fn (a: Color, b: Color) -> bool do
  return a != b
end

// Opaque sum with a comparable payload: == recurses into the payload (i64).
opaque type Labeled = Labeled(n: i64) | Unlabeled

let labeled_eq = fn (a: Labeled, b: Labeled) -> bool do
  return a == b
end

let main = fn () -> unit do
  // Invoke the functions so they survive DCE; results not asserted.
  color_eq(a: Red, b: Blue)
  color_ne(a: Red, b: Blue)
  labeled_eq(a: Labeled(n: 7), b: Unlabeled)
  return ()
end
