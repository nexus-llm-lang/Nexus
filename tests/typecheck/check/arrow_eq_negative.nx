// Negative fixture for nexus-ed9w. The bd issue's repro:
// `f == g` between two arrows (the spec's leading T-Cmp violation).
// Must be REJECTED with a comparable(τ)-based diagnostic. Kept out of
// `nexus test` discovery by the missing `_test` suffix.
let f = fn (x: i64) -> i64 do return x end
let g = fn (x: i64) -> i64 do return x end
let main = fn () -> unit do
  f == g
  return ()
end
