// Regression for nexus-8tee: T-Proj with `¬linear(τ)` premise.
//
// Positive half of the fix: projection on a record whose all fields
// are non-linear must still typecheck and evaluate correctly. The
// rejection in `infer_field_access` only fires when the record carries
// a linear field somewhere in its structural shape — a plain
// `{x: i64, y: i64}` must keep working.
//
// The negative half (projection on a structurally-linear record is
// rejected) lives in `8tee_proj_linear_negative.nx` — note the missing
// `_test` suffix, which keeps `nexus test` from picking it up (it is
// expected to fail to compile, so a test runner would mis-flag it).
import * as test_assert from "std:test/assert"

type Point = MkPt(x: i64, y: i64)

let body = fn () -> unit throws { Exn } do
  let p = { px: 3, py: 4 }
  test_assert.assert_eq_i64(actual: p.px, expected: 3, label: "projection on non-linear record (px)")
  test_assert.assert_eq_i64(actual: p.py, expected: 4, label: "projection on non-linear record (py)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
