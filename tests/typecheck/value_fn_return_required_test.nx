// Positive control for strict T-Lambda enforcement (spec: τ_r ≠ unit ⟹
// tail(s†) = ⊥). Implicit return of a trailing expression is rejected for
// value functions/lambdas (see tests/negative/typecheck/
// value_fn_*implicit_return_rejected.nx), but the SANCTIONED shapes must keep
// type-checking AND running:
//
//   1. a `return`-terminated value function,
//   2. a `-> unit` body that "falls off the end" (no return required),
//   3. a `return`ed `if`/`match` EXPRESSION (lower_if_expr / match-expr path),
//   4. a value lambda whose body ends in `return`,
//   5. a `with @k do @k end` continuation-arm tail (T-Continuation; `@k` is the
//      one non-`return` tail the rule permits),
//   6. a value-yielding `inject H do … return v end` (an `inject` is
//      statement-only — it cannot be `let`-bound or `return`ed directly — so
//      the value is supplied by a `return` INSIDE the inject body).
import * as test_assert from "std:test/assert"
import * as stdio from "std:stdio"

cap Ask do
  fn get() -> i64
end

// 1. return-terminated value fn.
let ret_term = fn (x: i64) -> i64 do
  return x + 1
end

// 2. -> unit body, no trailing return needed.
let unit_fall = fn (acc: i64) -> unit do
  let _y = acc + 1
end

// 3. return of an if/match EXPRESSION (distinct from a bare trailing if/match).
let ret_if_expr = fn (c: bool) -> i64 do
  return if c then 10 else 20 end
end

let ret_match_expr = fn (n: i64) -> i64 do
  return match n do
    | 0 -> 100
    | _ -> 200
  end
end

// 4. value lambda ending in return (the lambda-site enforcement still accepts a
//    return-terminated body).
let apply_twice = fn (f: (x: i64) -> i64, x: i64) -> i64 do
  return f(x: f(x: x))
end

// 5. `with @k do @k end` arm tail — the sanctioned continuation-arm shape.
let ask_h = handler Ask do
  fn get() -> i64 with @k do
    @k
  end
end

// 6. value-yielding inject whose body supplies the value via an interior
//    `return` (the wrapper-of-inject idiom under strict enforcement).
let drive_ask = fn () -> i64 throws { RuntimeError } do
  inject ask_h do
    let v = Ask.get()
    return v + 5
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: ret_term(x: 41), expected: 42, label: "return-terminated")
  unit_fall(acc: 7)
  test_assert.assert_eq_i64(actual: ret_if_expr(c: true), expected: 10, label: "return-if-expr-true")
  test_assert.assert_eq_i64(actual: ret_if_expr(c: false), expected: 20, label: "return-if-expr-false")
  test_assert.assert_eq_i64(actual: ret_match_expr(n: 0), expected: 100, label: "return-match-expr-0")
  test_assert.assert_eq_i64(actual: ret_match_expr(n: 9), expected: 200, label: "return-match-expr-other")
  let inc = fn (z: i64) -> i64 do return z + 1 end
  test_assert.assert_eq_i64(actual: apply_twice(f: inc, x: 5), expected: 7, label: "lambda-return")
  // The `with @k` arm resumes the continuation (a bare `@k` resumes with 0, the
  // suspend-point value), so `Ask.get()` is 0 and the inject's `return v + 5`
  // surfaces 5. The assert runs AFTER drive_ask returns (resume frame exited) —
  // twyov-safe. The point here is that the `inject … return v end` shape
  // type-checks and round-trips its value, not the specific resume value.
  test_assert.assert_eq_i64(actual: drive_ask(), expected: 5, label: "inject-return-value")
  return ()
end
