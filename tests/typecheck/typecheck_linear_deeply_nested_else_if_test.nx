// Port of bootstrap/tests/typecheck/linear.rs::
// test_linear_deeply_nested_else_if_value_branches,
// test_linear_deeply_nested_else_if_all_return,
// test_linear_deeply_nested_else_if_mixed_return_and_value.
//
// Regression for nexus-957p: deeply-nested `else if` chains with
// linear types must (a) typecheck when each branch produces the same
// linear value, (b) propagate divergence when ALL branches `return`,
// and (c) flow the value-branch tail type into the let-binding when
// `return` and value branches are mixed.
import * as test_assert from "std:test/assert"

type Resource = { id: i64 }

let transform = fn (%r: Resource) -> Resource do
  return %r
end

let consume = fn (%r: Resource) -> i64 do
  match %r do | { id: x } -> return x end
end

// (a) value branches.
let process_value_branches = fn (op: i64, %buf: Resource) -> i64 do
  let %buf2 = if op == 1 then
    transform(r: %buf)
  else if op == 2 then
    transform(r: %buf)
  else if op == 3 then
    transform(r: %buf)
  else if op == 4 then
    transform(r: %buf)
  else if op == 5 then
    transform(r: %buf)
  else if op == 6 then
    transform(r: %buf)
  else if op == 7 then
    transform(r: %buf)
  else if op == 8 then
    transform(r: %buf)
  else if op == 9 then
    transform(r: %buf)
  else if op == 10 then
    transform(r: %buf)
  else if op == 11 then
    transform(r: %buf)
  else
    transform(r: %buf)
  end
  let id_val = consume(r: %buf2)
  return id_val + 1
end

// (b) all branches return.
let process_all_return = fn (op: i64, %buf: Resource) -> i64 do
  if op == 1 then
    return consume(r: %buf)
  else if op == 2 then
    return consume(r: %buf)
  else if op == 3 then
    return consume(r: %buf)
  else if op == 4 then
    return consume(r: %buf)
  else if op == 5 then
    return consume(r: %buf)
  else if op == 6 then
    return consume(r: %buf)
  else if op == 7 then
    return consume(r: %buf)
  else if op == 8 then
    return consume(r: %buf)
  else if op == 9 then
    return consume(r: %buf)
  else if op == 10 then
    return consume(r: %buf)
  else if op == 11 then
    return consume(r: %buf)
  else
    return consume(r: %buf)
  end
end

// (c) mixed return + value tail.
let process_mixed = fn (op: i64, %buf: Resource) -> i64 do
  let %buf = if op == 1 then
    return consume(r: %buf)
  else if op == 2 then
    return consume(r: %buf)
  else if op == 3 then
    return consume(r: %buf)
  else if op == 4 then
    return consume(r: %buf)
  else if op == 5 then
    return consume(r: %buf)
  else if op == 6 then
    return consume(r: %buf)
  else if op == 7 then
    return consume(r: %buf)
  else if op == 8 then
    return consume(r: %buf)
  else if op == 9 then
    return consume(r: %buf)
  else if op == 10 then
    return consume(r: %buf)
  else
    transform(r: %buf)
  end
  return consume(r: %buf)
end

let body = fn () -> unit throws { Exn } do
  let %r1 = { id: 1 }
  let v = process_value_branches(op: 1, buf: %r1)
  test_assert.assert_eq_i64(actual: v, expected: 2, label: "deep else-if value branches")

  let %r2 = { id: 2 }
  let v2 = process_all_return(op: 1, buf: %r2)
  test_assert.assert_eq_i64(actual: v2, expected: 2, label: "deep else-if all-return")

  let %r3 = { id: 3 }
  let v3 = process_mixed(op: 99, buf: %r3)
  test_assert.assert_eq_i64(actual: v3, expected: 3, label: "deep else-if mixed (else value)")

  let %r4 = { id: 4 }
  let v4 = process_mixed(op: 1, buf: %r4)
  test_assert.assert_eq_i64(actual: v4, expected: 4, label: "deep else-if mixed (early return)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
