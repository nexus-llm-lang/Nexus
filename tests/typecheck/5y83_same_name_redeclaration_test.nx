// nexus-5y83: Positive companion to 5y83_same_name_redeclaration_negative.
// After renaming the second binding, the file typechecks cleanly. Confirms
// the rejection is targeted (same-name only) and the migration story for
// shadowed top-level lets is: rename the second binding.
import * as test_assert from "std:test/assert"

let f = fn (x: i64) -> i64 do
  return x + 1
end

let f_str = fn (s: string) -> i64 do
  return 0
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: f(x: 41), expected: 42, label: "f(x:41)")
  test_assert.assert_eq_i64(actual: f_str(s: "hi"), expected: 0, label: "f_str")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
