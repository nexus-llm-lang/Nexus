// Port of bootstrap/tests/typecheck/exhaustiveness.rs::test_record_exhaustive.
// Record patterns: `{ x: true, y: true } | { x: true, y: false } |
// { x: false, _ }` covers all (x, y) combinations.
import * as test_assert from "std:test/assert"

let label = fn (r: { x: bool, y: bool }) -> i64 do
  match r do
    | { x: true, y: true } -> return 11
    | { x: true, y: false } -> return 10
    | { x: false, _ } -> return 0
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: label(r: { x: true, y: true }), expected: 11, label: "record TT")
  test_assert.assert_eq_i64(actual: label(r: { x: true, y: false }), expected: 10, label: "record TF")
  test_assert.assert_eq_i64(actual: label(r: { x: false, y: true }), expected: 0, label: "record FT (wildcard)")
  test_assert.assert_eq_i64(actual: label(r: { x: false, y: false }), expected: 0, label: "record FF (wildcard)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
