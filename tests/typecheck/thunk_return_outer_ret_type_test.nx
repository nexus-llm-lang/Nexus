// Regression for nexus-toa2 — T-Thunk/T-Force must propagate the enclosing
// function's ret_type when type-checking the inner expression.
//
// Bug: `infer_thunk` and `infer_force` hardcoded `ret_type: TyUnit` when
// calling `infer_expr`. A `return` statement inside a thunk body was
// validated against `TyUnit` instead of the enclosing function's declared
// return type. Gave E2001 "if then: return type mismatch: cannot unify int
// literal with non-integer type".
//
// This file must compile cleanly to pass the regression.
// All functions must be reachable from main so DCE does not skip typecheck.
import * as test_assert from "std:test/assert"

// `return 99` inside a thunk body must typecheck against the outer ret_type
// (i64), not TyUnit. The `let _ = @t` forces the thunk (result: unit since
// the else-less `if` produces unit when flag=false) and discards it.
// When flag=true, the thunk body executes `return 99` which returns 99 from
// the thunk closure; the outer function then receives unit from `let _ = @t`
// (since the thunk returns 99, not unit — the if branch is taken), and
// proceeds to `return 0`.
// The typecheck interest: `return 99` must be checked against i64.
let thunk_early_guard = fn (flag: bool) -> i64 do
  let @t = if flag then return 99 end
  let _ = @t
  return 0
end

// Force also propagates ret_type: `return 42` inside a thunk body in a
// function returning i64 must typecheck against i64.
let force_outer_ret = fn (flag: bool) -> i64 do
  let @t = if flag then return 42 end
  let _ = @t
  return 1
end

// Positive runtime case: thunk-then-force without a return in the body.
let force_basic = fn (n: i64) -> i64 do
  let @t = n + 1
  return @t
end

let body = fn () -> unit throws { Exn } do
  // Basic force: exercises infer_thunk and infer_force with normal ret_type propagation.
  test_assert.assert_eq_i64(actual: force_basic(n: 3), expected: 4, label: "force basic n+1")

  // Guard functions: flag=false path — thunk body evaluates to unit (no-else if),
  // force discards it, function returns the explicit i64.
  test_assert.assert_eq_i64(actual: thunk_early_guard(flag: false), expected: 0, label: "thunk guard flag=false")
  test_assert.assert_eq_i64(actual: force_outer_ret(flag: false), expected: 1, label: "force outer flag=false")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
