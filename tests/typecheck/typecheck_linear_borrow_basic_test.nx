// Port of bootstrap/tests/typecheck/linear.rs::test_linear_borrow_basic.
//
// `&%x` forms an immutable borrow of a linear binding. A function that
// takes `&i64` may be called multiple times with fresh borrows of the
// same `%x` without consuming it.
import * as test_assert from "std:test/assert"

// Pure no-op accessor — exercises the &i64 -> unit arrow and the
// match-on-borrow pattern without doing arithmetic on the reference
// itself (which the lowerer rejects: "Integer op expects i32/i64,
// got &i64 and i64").
let peek = fn (x: &i64) -> unit do
  let _ = x
  return ()
end

let body = fn () -> unit throws { Exn } do
  let %x = 10
  let r1 = &%x
  peek(x: r1)
  let r2 = &%x
  peek(x: r2)
  // Final consumption of the linear binding via match. Reaching this
  // point means both borrows above were observed without consuming %x.
  let result = match %x do | n -> n end
  test_assert.assert_eq_i64(actual: result, expected: 10, label: "borrows preserved %x")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
