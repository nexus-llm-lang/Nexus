// Port of bootstrap/tests/typecheck/inference.rs::
// test_let_destructure_record, test_let_destructure_nested_record.
//
// Top-level `let { x: a, y: b } = expr` and nested `let { inner: {a: x},
// b: y } = expr` bindings must resolve and bring named bindings into scope.
import * as test_assert from "std:test/assert"

type Point = { x: i64, y: i64 }

type Inner = { a: i64 }
type Outer = { inner: Inner, b: bool }

let body = fn () -> unit throws { Exn } do
  let p: Point = { x: 10, y: 20 }
  let { x: a, y: b } = p
  test_assert.assert_eq_i64(actual: a, expected: 10, label: "destructure .x")
  test_assert.assert_eq_i64(actual: b, expected: 20, label: "destructure .y")

  let o: Outer = { inner: { a: 1 }, b: true }
  let { inner: { a: x }, b: y } = o
  test_assert.assert_eq_i64(actual: x, expected: 1, label: "nested destructure .inner.a")
  test_assert.assert_eq_bool(actual: y, expected: true, label: "nested destructure .b")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
