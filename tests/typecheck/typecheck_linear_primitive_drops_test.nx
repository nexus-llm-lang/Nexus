// Port of bootstrap/tests/typecheck/linear.rs::
// prop_linear_primitive_drops (one representative case).
//
// A linear primitive that's discarded via `match %a do | _ -> () end`
// must typecheck.
import * as test_assert from "std:test/assert"

let test_fn = fn () -> i64 do
  let %a = 42
  match %a do | _ -> () end
  return 1
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: test_fn(), expected: 1, label: "linear primitive match-drop")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
