// Port of bootstrap/tests/typecheck/inference.rs::
// test_match_expr_same_type_cases_typechecks,
// test_match_expr_with_return_cases_diverge.
//
// All non-diverging `match` arms must unify; arms that `return` from
// the enclosing function are diverging and don't constrain the unifier.
import * as test_assert from "std:test/assert"

let pure_match = fn (x: i64) -> i64 do
  let result: i64 = match x do
    | 1 -> 10
    | _ -> 20
  end
  return result
end

let diverging_match = fn (x: i64) -> i64 do
  let result = match x do
    | 0 -> return 999
    | _ -> 42
  end
  return result
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: pure_match(x: 1), expected: 10, label: "match arm 1")
  test_assert.assert_eq_i64(actual: pure_match(x: 99), expected: 20, label: "match wildcard")
  test_assert.assert_eq_i64(actual: diverging_match(x: 0), expected: 999, label: "match diverges via return")
  test_assert.assert_eq_i64(actual: diverging_match(x: 7), expected: 42, label: "match value branch")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
