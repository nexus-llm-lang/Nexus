// Regression for nexus-djn1: a sigil-only `%` on a function parameter
// (`fn (%x: T)`) must propagate through HIR conversion and trigger the
// linearity check. Pre-fix, HirParam dropped Param.sigil and only the
// type-side `TyLinear` triggered tracking — so `%r: Resource` was
// equivalent to `r: Resource` and the linear-use-once contract was
// silently waived.
//
// This positive fixture relies on the linearity check actually running
// for sigil-only params. It binds %r through a sigil-only-param consume
// and asserts a value derived from the consumption. The negative fixture
// (sigil-only param left unconsumed) lives in
// `djn1_param_sigil_propagates_negative.nx` — note the missing `_test`
// suffix, which keeps it out of `nexus test` discovery (deliberate
// compile failure).
import * as test_assert from "std:test/assert"

type Resource = MkR(id: i64)

// Sigil-only `%r` — pre-fix, this was treated as a non-linear binding
// because HirParam did not carry the sigil and the inner type
// `Resource` is not `TyLinear`. The body's `match` consumes it; the
// type system now requires that consumption.
let consume_sigil_only = fn (%r: Resource) -> i64 do
  match r do | MkR(id: i) -> return i end
end

let body = fn () -> unit throws { Exn } do
  let v = consume_sigil_only(r: MkR(id: 42))
  test_assert.assert_eq_i64(actual: v, expected: 42, label: "sigil-only %r is tracked and consumed once")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
