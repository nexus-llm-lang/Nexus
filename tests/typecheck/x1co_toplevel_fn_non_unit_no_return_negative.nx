// Negative fixture for nexus-x1co — T-Lambda premise τ_r ≠ unit ⟹ tail(s†) = ⊥.
// A top-level function declaring `-> bool` that falls off the end without a
// `return` on all paths must be REJECTED. The body here has a unit-result
// let-binding as its last statement, so the tail is unit not bool.
// Kept out of `nexus test` discovery by the missing `_test` suffix.
let check = fn (x: i64) -> bool do
  let _ = x
end

let main = fn () -> unit do
  let _ = check(x: 1)
  return ()
end
