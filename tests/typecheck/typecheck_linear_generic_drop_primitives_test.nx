// Port of bootstrap/tests/typecheck/linear.rs::
// test_generic_drop_accepts_non_linear_primitives.
//
// Plain (non-`%`) primitive bindings of i32, f64, and string can be
// dropped without explicit consumption — generic-drop applies to all
// non-linear primitives.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let x: i32 = 1
  let y: f64 = 2.0
  let s = "hello"
  // Use each so we know the bindings type-check.
  let target_i32: i32 = 1
  test_assert.assert_eq_bool(actual: x == target_i32, expected: true, label: "i32 drop")
  test_assert.assert_eq_bool(actual: y <. 3.0, expected: true, label: "f64 drop")
  test_assert.assert_eq_string(actual: s, expected: "hello", label: "string drop")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
