// Regression for nexus-mqin.5 — T-App weakening %σ ↔ σ.
//
// Spec rule: when a parameter is `%σ` and the caller's argument is
// concretely non-linear, unification targets σ (not %σ). The previous
// implementation (src/typecheck/infer.nx::check_call_args) always
// unified arg_t against expected, rejecting `f(x: y)` when
// `y: i64` and `f: (%i64) -> _`.
//
// This test pins:
//   (a) positive — non-linear binding into a `%i64` slot typechecks
//   (b) negative-still-positive — linear-on-linear stays linear-on-linear
//       (we did not break the existing path).
import * as test_assert from "std:test/assert"

let consume_to_one = fn (x: %i64) -> i64 do
  match x do | _ -> () end
  return 1
end

let body = fn () -> unit throws { Exn } do
  // (a) Positive: non-linear `y: i64` flows into `%i64` slot.
  let y: i64 = 7
  let r = consume_to_one(x: y)
  test_assert.assert_eq_i64(actual: r, expected: 1, label: "non-linear i64 weakens into %i64 slot")

  // (b) Linear-on-linear identity (existing path must still work).
  let %z = 9
  let s = consume_to_one(x: %z)
  test_assert.assert_eq_i64(actual: s, expected: 1, label: "linear %i64 still passes to %i64 slot")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
