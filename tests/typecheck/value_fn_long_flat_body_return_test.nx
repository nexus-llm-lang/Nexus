  else if n == 67 then return 1067
  else if n == 68 then return 1068
  else if n == 69 then return 1069
  else if n == 70 then return 1070
  else if n == 71 then return 1071
  else if n == 72 then return 1072
  else if n == 73 then return 1073
  else if n == 74 then return 1074
  else if n == 75 then return 1075
  else if n == 76 then return 1076
  else if n == 77 then return 1077
  else if n == 78 then return 1078
  else if n == 79 then return 1079
  else return -1
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: long_flat_body(seed: 2),
    expected: 82,
    label: "long-flat-return"
  )
  test_assert.assert_eq_i64(
    actual: long_else_if_chain(n: 0),
    expected: 1000,
    label: "else-if-first"
  )
  test_assert.assert_eq_i64(
    actual: long_else_if_chain(n: 79),
    expected: 1079,
    label: "else-if-last-link"
  )
  test_assert.assert_eq_i64(
    actual: long_else_if_chain(n: 999),
    expected: -1,
    label: "else-if-fallthrough"
  )
  return ()
end
