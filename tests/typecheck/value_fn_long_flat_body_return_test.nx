  else if n == 23 then return 1023
  else if n == 24 then return 1024
  else if n == 25 then return 1025
  else if n == 26 then return 1026
  else if n == 27 then return 1027
  else if n == 28 then return 1028
  else if n == 29 then return 1029
  else if n == 30 then return 1030
  else if n == 31 then return 1031
  else if n == 32 then return 1032
  else if n == 33 then return 1033
  else if n == 34 then return 1034
  else if n == 35 then return 1035
  else if n == 36 then return 1036
  else if n == 37 then return 1037
  else if n == 38 then return 1038
  else if n == 39 then return 1039
  else if n == 40 then return 1040
  else if n == 41 then return 1041
  else if n == 42 then return 1042
  else if n == 43 then return 1043
  else if n == 44 then return 1044
  else if n == 45 then return 1045
