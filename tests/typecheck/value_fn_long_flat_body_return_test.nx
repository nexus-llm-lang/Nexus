let long_else_if_chain = fn (n: i64) -> i64 do
  if n == 0 then return 1000
  else if n == 1 then return 1001
  else if n == 2 then return 1002
  else if n == 3 then return 1003
  else if n == 4 then return 1004
  else if n == 5 then return 1005
  else if n == 6 then return 1006
  else if n == 7 then return 1007
  else if n == 8 then return 1008
  else if n == 9 then return 1009
  else if n == 10 then return 1010
  else if n == 11 then return 1011
  else if n == 12 then return 1012
  else if n == 13 then return 1013
  else if n == 14 then return 1014
  else if n == 15 then return 1015
  else if n == 16 then return 1016
  else if n == 17 then return 1017
  else if n == 18 then return 1018
  else if n == 19 then return 1019
  else if n == 20 then return 1020
  else if n == 21 then return 1021
