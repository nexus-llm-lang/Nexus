// Regression for nexus-xhhq: a `throws { ExceptionGroup }` callee called
// from a `throws { Exn }` caller must typecheck via row subsumption.
// Both passes of `infer_program` must store the callee scheme with
// exception groups expanded so the row unifier sees compatible rows.
//
// Tested direction (subsumption-legal): narrow (group) callee → broad
// ({Exn}) caller.
import * as test_assert from "std:test/assert"

exception LocalErr
exception OtherErr
exception group ExceptionGroup = LocalErr | OtherErr

// narrow (group) callee, broad ({Exn}) caller — the canonical xhhq shape.
let callee_group = fn () -> i64 throws { ExceptionGroup } do
  raise LocalErr
end

let caller_broad = fn () -> i64 throws { Exn } do
  return callee_group()
end

// Top-level driver wraps the throwable caller via statement-form try/catch.
// The raise must propagate through caller_broad and fire the catch arm,
// so this returns 0.
let drive_broad = fn () -> i64 do
  try
    let _ = caller_broad()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit throws { Exn } do
  let r1 = drive_broad()
  test_assert.assert_eq_i64(actual: r1, expected: 0, label: "xhhq: raise propagates through group→Exn subsumed call")
  return ()
end
