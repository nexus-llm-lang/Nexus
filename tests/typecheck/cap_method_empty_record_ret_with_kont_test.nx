// Positive fixture (nexus-2ak0p): a `with @k` handler arm for a cap method
// whose return type is an EMPTY RECORD (`type Nothing = {}`) must typecheck.
//
// The genuine non-unit rejection (check/handler_validation.nx) refuses a
// `with @k` arm when the cap method's return type would have to be silently
// fabricated at the suspended call site, because the bare continuation `@k`
// supplies no value back (mirroring the parser's `@k(v)` rejection). But a
// zero-field record is SINGLE-INHABITED and non-linear — semantically
// unit-equivalent — so the fabricated (zero-initialised) value is the unique
// correct value and resuming via `@k` is harmless. The unit-equivalence check
// therefore admits `unit`, a structural `{}` (`TyRecord([])`), AND a nominal
// alias for the empty record (`type Nothing = {}`, reaching the check as a
// `TyUserDefined` that resolves to an empty `RecordDef`).
//
// A return type with one or more fields (or any other non-unit type) is still
// rejected — see tests/negative/typecheck/cap_method_nonunit_ret_with_kont.nx.

type Nothing = {}

cap Gen do
  fn tick() -> Nothing
end

let gen_h = handler Gen do
  fn tick() -> Nothing with @k do
    @k
  end
end

let body = fn () -> unit require { Gen } do
  let n = Gen.tick()
  return ()
end

let main = fn () -> unit do
  inject gen_h do body() end
  return ()
end
