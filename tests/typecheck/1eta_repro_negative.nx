// Negative regression for nexus-1eta: typecheck previously skipped
// `__nx_user_main` (the user's original `main` body, after `main_wrap`
// renamed it to make room for the synthesised throws-row wrapper). This
// file declares a deliberately mistyped main body with `throws { Exn }`
// — `foo` returns i64 but the let-binding annotates the result as
// string. Pre-fix, this slipped through typecheck silently. Post-fix,
// the typechecker must reject it with a TypeMismatch.
//
// IMPORTANT: this fixture is NOT meant to compile. It intentionally
// drops the `_test.nx` suffix so `nexus test` discovery (which runs
// every `*_test.nx`) skips it — a fixture that fails compile would
// otherwise be reported as a runner failure. Drive it manually through
// `nexus typecheck tests/typecheck/1eta_repro_negative.nx` to observe
// the E2001 TypeMismatch.

let foo = fn (x: i64) -> i64 do return x end

let main = fn () -> unit throws { Exn } do
  // Type error: foo returns i64, the annotation says string.
  let bad: string = foo(x: 5)
  let _ = bad
  return ()
end
