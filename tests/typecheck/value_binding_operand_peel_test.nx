import * as test_assert from "std:test/assert"
import * as list from "std:list"

let lim = 10
let add_lim = fn (x: i64) -> i64 do return x + lim end

let base = 3
let scale = 4
let combine = fn (x: i64) -> i64 do return x * scale + base end

let ch_cr = '\r'
let is_cr = fn (c: char) -> bool do return c == ch_cr end

let threshold = 100
let over = fn (n: i64) -> bool do return n > threshold end
let exact = fn (n: i64) -> bool do return n == threshold end

let eof_marker = '\0'
let pick = fn (at_eof: bool) -> char do
  if at_eof then return eof_marker end
  return 'a'
end

let first_byte = 97
let bytes3 = fn () -> [ i64 ] do return [ first_byte, 98, 99 ] end

type Tagged = Tagged(tag: i64, name: string)
let default_tag = 7
let make_tagged = fn (nm: string) -> Tagged do return Tagged(tag: default_tag, name: nm) end

let op_a = 10
let op_b = 20
let sum_list = fn (xs: [ i64 ]) -> i64 do return list.fold_left(
  xs,
  init: 0,
  f: fn (acc: i64, val: i64) -> i64 do return acc + val end
) end
let two_ops = fn () -> i64 do return sum_list(xs: [ op_a, op_b ]) end

type Buf = Buf(codes: [ i64 ])
let make_buf = fn () -> Buf do return Buf(codes: [ op_a, op_b ]) end

/** A scalar value-binding used as a NON-FIRST list element, after a bare int
 *  literal that fixes the element column to the literal type. The value
 *  binding's `() -> i64` placeholder lands on the EXPECTED side of the Cons
 *  field unify; the expected-side thunk peel recovers it. */
let lit_then_vb = fn () -> i64 do return sum_list(xs: [ 5, op_a ]) end
let make_buf_lit_first = fn () -> Buf do return Buf(codes: [ 5, op_a ]) end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: add_lim(x: 5), expected: 15, label: "int-vb-add")
  test_assert.assert_eq_i64(actual: combine(x: 2), expected: 11, label: "int-vb-mul-add")
  test_assert.assert(cond: is_cr(c: '\r'), label: "char-vb-eq-true")
  test_assert.assert(cond: !is_cr(c: '\n'), label: "char-vb-eq-false")
  test_assert.assert(cond: over(n: 150), label: "int-vb-gt-true")
  test_assert.assert(cond: !over(n: 50), label: "int-vb-gt-false")
  test_assert.assert(cond: exact(n: 100), label: "int-vb-eq-true")
  test_assert.assert(cond: pick(at_eof: true) == '\0', label: "vb-return-eof")
  test_assert.assert(cond: pick(at_eof: false) == 'a', label: "vb-return-other")
  let bs = bytes3()
  test_assert.assert_eq_i64(actual: list.length(xs: bs), expected: 3, label: "vb-array-len")
  let Tagged(tag: t, name: nm) = make_tagged(nm: "x")
  test_assert.assert_eq_i64(actual: t, expected: 7, label: "vb-ctor-field")
  test_assert.assert_eq_i64(actual: two_ops(), expected: 30, label: "vb-list-elem-call-arg")
  let Buf(codes: cs) = make_buf()
  test_assert.assert_eq_i64(
    actual: list.length(xs: cs),
    expected: 2,
    label: "vb-list-elem-ctor-field"
  )
  test_assert.assert_eq_i64(
    actual: lit_then_vb(),
    expected: 15,
    label: "vb-list-elem-after-literal-call-arg"
  )
  let Buf(codes: cs2) = make_buf_lit_first()
  test_assert.assert_eq_i64(
    actual: list.length(xs: cs2),
    expected: 2,
    label: "vb-list-elem-after-literal-ctor-field"
  )
  return ()
end
