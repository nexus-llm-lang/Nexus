// Regression for nexus-t9cl.14 — stmts_diverge must recognize
// `let p = raise e'` as a divergent tail statement (spec[tail]).
//
// Spec rule: a `let` whose RHS is a raise (or other divergent expr) is
// itself divergent — the bound name is unreachable. Pre-fix,
// `stmts_diverge_depth` only inspected `Stmt::Expr(Raise(...))` and
// treated every `Let(...)` as non-divergent. That caused the
// branch-arm divergence carve-out (then_diverges /
// all_cases_diverge_depth) to miss a divergent arm, producing a
// spurious "Linear mismatch across branches" when one arm
// legitimately diverges through a `let p = raise ...` tail.
//
// This positive fixture asserts that an if-without-else arm whose
// tail is `let p = raise SomeExn(...)` is classified as divergent
// by the linearity pass, so the surrounding linear-set comparison
// is skipped for that branch and the program typechecks cleanly.
//
// Key shape (post-fix only):
//   if cond then
//     consume(x: %y)            // arm consumes %y (live-set after arm = {})
//     let p = raise Boom(_)  // tail let-with-raise-RHS, divergent
//   end
//   // %y still alive on the fall-through (cond=false) path; linearity
//   // pass without t9cl.14 would compare {<%y>} vs {} and reject.
import * as test_assert from "std:test/assert"

exception Boom(code: i64)

let consume = fn (x: %i64) -> i64 do
  match x do | _ -> () end
  return 7
end

let do_work = fn (cond: bool) -> i64 throws { Boom } do
  let %y = 99
  if cond then
    let _ = consume(x: %y)
    // Tail-position `let p = raise Boom(...)`. Per spec[tail] this is
    // divergent — `p` is unreachable. The if-without-else linearity
    // join now compares the fall-through live-set (still has %y)
    // against the divergent-then-arm carve-out, which is exempted.
    let p = raise Boom(code: 0)
  end
  // Fall-through path: %y is still live and must be consumed here.
  return consume(x: %y)
end

let body = fn () -> unit throws { Exn, Boom } do
  let r = do_work(cond: false)
  test_assert.assert_eq_i64(actual: r, expected: 7, label: "let-raise tail classified as divergent — fall-through consumes %y once")
  return ()
end

let main = fn () -> unit throws { Exn, Boom } do
  body()
  return ()
end
