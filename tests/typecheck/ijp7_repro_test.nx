// Regression for nexus-ijp7: passing a default-pure function as the
// argument to a row-polymorphic combinator like
// `apply<E>(f: () -> i64 throws E)` must typecheck and run without
// hanging the unifier.
//
// Uses a non-zero-arity callee to avoid the unrelated arity-0 closure
// codegen cliff (nexus-cfy4). The typecheck phase is the one this
// regression guards.
import * as test_assert from "std:test/assert"

let apply = fn <E>(f: (n: i64) -> i64 throws E) -> i64 throws E do
  return f(n: 6)
end

let pure_fn = fn (n: i64) -> i64 do
  return n + 1
end

let body = fn () -> i64 throws { Exn } do
  return apply(f: pure_fn)
end

let safe_run = fn () -> i64 do
  try
    return body()
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let v = safe_run()
  test_assert.assert_eq_i64(actual: v, expected: 7, label: "ijp7 apply<E>(pure_fn) typechecks and runs")
  return ()
end
