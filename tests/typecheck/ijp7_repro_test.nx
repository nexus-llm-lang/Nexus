// Regression for nexus-ijp7.
//
// Symptom: passing a default-pure function as the argument to a
// row-polymorphic combinator like `apply<E>(f: () -> i64 throws E)`
// made the self-host typechecker hang (process timed out with no
// output). bd-issue reframed twice — first as "row defaulting", then
// as "loop in unifier" — neither captured the actual fault.
//
// Root cause: src/typecheck/unify.nx::unify_with_kind dispatched the
// rows-vs-rows path via nested `if let TyRow = t1 then if let TyRow =
// t2 then ... end end` and relied on falling through to a trailing
// `return unify(t1, t2, tdefs)`. When t1 was a TyRow but t2 was a
// TyVar (the polymorphic-row case at the `throws` step of an arrow
// unify), neither inner branch fired and the trailing
// `return unify(t1, t2, tdefs)` was never reached — control returned
// from `unify_with_kind` with a `()` value coerced into the result
// slot, which `unify_arrow` then composed into a substitution that
// later passes saw as ill-formed, looping. Rewriting the dispatch with
// a `match` whose every arm has an explicit `return` makes the four
// cases (rows×rows, rows×other, other×rows, other×other) total and
// breaks the loop.
//
// This file uses the row-polymorphic combinator from the bd issue
// with a non-zero-arity callee (so it survives the unrelated arity-0
// closure codegen cliff under nexus-cfy4). The typecheck phase is the
// one this regression guards.
import * as test_assert from "std:test/assert"

let apply = fn <E>(f: (n: i64) -> i64 throws E) -> i64 throws E do
  return f(n: 6)
end

let pure_fn = fn (n: i64) -> i64 do
  return n + 1
end

let body = fn () -> i64 throws { Exn } do
  return apply(f: pure_fn)
end

let safe_run = fn () -> i64 do
  try
    return body()
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let v = safe_run()
  test_assert.assert_eq_i64(actual: v, expected: 7, label: "ijp7 apply<E>(pure_fn) typechecks and runs")
  return ()
end
