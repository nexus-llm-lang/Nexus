// nexus-323x: Positive fixture. Call-argument labels matching the
// parameter names typecheck cleanly. Punning is preserved when the
// punned ident matches the parameter name. Companion to
// `323x_call_arg_label_mismatch_negative.nx`.
import * as test_assert from "std:test/assert"

let f = fn (a: i64, b: i64) -> i64 do
  return a * 100 + b
end

let body = fn () -> unit throws { Exn } do
  // Explicit-label form.
  test_assert.assert_eq_i64(actual: f(a: 7, b: 3), expected: 703, label: "f(a:7, b:3)")

  // Pun form where ident name matches the parameter name.
  let a = 9
  let b = 1
  test_assert.assert_eq_i64(actual: f(a, b), expected: 901, label: "f(a, b) pun")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
