// Port of bootstrap/tests/typecheck/inference.rs::
// prop_typecheck_nested_arithmetic. The Rust property test ran 64 cases
// of `({a} + {b}) * {c}` to confirm typecheck. Here we exercise three
// representative shapes (positive, mixed-sign, with-zero) — typecheck
// passes if compile succeeds, and runtime evaluation pins the values.
import * as test_assert from "std:test/assert"

let nested = fn (a: i64, b: i64, c: i64) -> i64 do
  return (a + b) * c
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: nested(a: 1, b: 2, c: 3), expected: 9, label: "(1+2)*3")
  test_assert.assert_eq_i64(actual: nested(a: 0 - 5, b: 10, c: 2), expected: 10, label: "(-5+10)*2")
  test_assert.assert_eq_i64(actual: nested(a: 7, b: 0 - 7, c: 4), expected: 0, label: "(7-7)*4")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
