// Port of bootstrap/tests/typecheck/linear.rs::test_lazy_binding_and_force,
// test_lazy_type_annotation, test_lazy_force_on_non_lazy_via_parens,
// test_lazy_pass_thunk_by_bare_name.
//
// `let @x = expr` binds a thunk; `@x` forces it. `@(expr)` forces an
// arbitrary expression (identity on non-lazy values). A `@i64` parameter
// can be supplied either by bare name (Γ keys are names only) or by
// explicit `@x` at the call site.
//
// All four cases are pinned at the typecheck layer through unused
// top-level lets — they must compile but are not exercised at runtime
// from this file. The runtime contract for `@x` force is covered by
// `tests/runtime/concurrency_lazy_thunk_basic_test.nx` and
// `tests/runtime/kmib_repro_test.nx` (nexus-kmib regression).
import * as test_assert from "std:test/assert"

// Bind + force.
let _lazy_bind_and_force = fn () -> i64 do
  let @x = 42
  let v = @x
  return v
end

// Annotation form.
let _lazy_with_annotation = fn () -> i64 do
  let @y : i64 = 7
  let w = @y
  return w
end

// Force on non-lazy via parens — identity.
let _lazy_force_non_lazy = fn () -> i64 do
  let plain = 41
  let r = @(plain)
  return r
end

// Consumes a `@i64` parameter via force.
let _lazy_consume_thunk = fn (@t: @i64) -> i64 do
  return @t
end

// Pass thunk by bare name.
let _lazy_pass_bare = fn () -> i64 do
  let @t1 = 100
  return _lazy_consume_thunk(t: t1)
end

// Pass thunk by explicit @-prefix.
let _lazy_pass_at = fn () -> i64 do
  let @t2 = 200
  return _lazy_consume_thunk(t: @t2)
end

let body = fn () -> unit throws { Exn } do
  // Runtime smoke test: the *non-lazy* declaration paths still
  // typecheck and run. A pure i64 binding observed via assert exercises
  // the standard codegen path so the produced component still exports
  // wasi:cli/run.
  let plain: i64 = 42
  test_assert.assert_eq_i64(actual: plain, expected: 42, label: "non-lazy smoke")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
