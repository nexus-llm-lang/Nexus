// Negative fixture for nexus-2yxp. spec strip(τ) peels %/& only — @σ
// thunks must be forced explicitly via T-Force before pattern-matching.
// This fixture exercises `match thunk_x { Ctor(...) -> ... }` where the
// scrutinee has type `@Box`; the typechecker must REJECT with a
// suggestion to force the thunk (`match @x do ...`).
//
// Kept out of `nexus test` discovery by the missing `_test` suffix.
type Box = MkBox(val: i64)

let make_box = fn () -> Box do
  return MkBox(val: 21)
end

let body = fn () -> unit do
  let @t = make_box()
  match t do
    | MkBox(val: v) -> ()
  end
  return ()
end

let main = fn () -> unit do
  body()
  return ()
end
