// Regression for nexus-w2cn — auto-lazify let-binding rhs when binder is
// `@x` and annotation is bare `T`.
//
// Bug: the typechecker's `infer_let` rule rejected `let @y : i64 = 7`
// with "expected lazy type" because the HIR pass auto-wraps a `@`-sigil
// rhs in `Thunk(...)` (so its inferred type is `@i64`), but the bare
// `i64` annotation wasn't lifted to match. Mirrors the call-site
// weakening rule in `check_call_args` that lets a plain `T` value
// satisfy a `@T` parameter.
//
// This test pins:
//   (a) the bare-annotation form `let @y : i64 = 7` typechecks,
//   (b) the explicit-lazy form `let @y : @i64 = 7` still typechecks,
//   (c) the no-annotation form `let @y = 7` still typechecks.
//
// Reachability matters: the bug only manifests on functions reachable
// from `main`, so the lazy-bind helpers are wired through `body()`.
import * as test_assert from "std:test/assert"

let bare_ann = fn () -> i64 do
  let @y : i64 = 7
  return @y
end

let explicit_lazy_ann = fn () -> i64 do
  let @y : @i64 = 11
  return @y
end

let no_ann = fn () -> i64 do
  let @y = 13
  return @y
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: bare_ann(), expected: 7, label: "let @y : i64 = 7")
  test_assert.assert_eq_i64(actual: explicit_lazy_ann(), expected: 11, label: "let @y : @i64 = 11")
  test_assert.assert_eq_i64(actual: no_ann(), expected: 13, label: "let @y = 13")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
