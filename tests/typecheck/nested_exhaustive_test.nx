// nexus-j6mr: Maranget pattern-matrix exhaustiveness must thread through
// nested constructor field columns. A fully-covering nested match over
// `Option<i64>` (Some(_) catches every Some, plus None) must typecheck.
// The negative shape `Some(val: 1) | None` is exercised in the companion
// j6mr_nested_exhaustive_negative.nx fixture.
import * as test_assert from "std:test/assert"

let classify = fn (o: Option<i64>) -> i64 do
  match o do
    | Some(_) -> return 1
    | None -> return 0
  end
end

// A literal nested case still passes when a wildcard catches the rest.
let classify_lit = fn (o: Option<i64>) -> i64 do
  match o do
    | Some(val: 1) -> return 100
    | Some(_) -> return 1
    | None -> return 0
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: classify(o: Some(val: 5)), expected: 1, label: "Some(_) covers any Some")
  test_assert.assert_eq_i64(actual: classify(o: None), expected: 0, label: "None branch")
  test_assert.assert_eq_i64(actual: classify_lit(o: Some(val: 1)), expected: 100, label: "literal Some(1)")
  test_assert.assert_eq_i64(actual: classify_lit(o: Some(val: 99)), expected: 1, label: "Some(other) covered by wildcard")
  test_assert.assert_eq_i64(actual: classify_lit(o: None), expected: 0, label: "None branch (lit)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
