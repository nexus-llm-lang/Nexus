// Negative fixture for nexus-xv62: P-Ctor disjoint-union enforcement.
//
// Spec docs/spec/type-system-formal.md P-Ctor (~344-356) requires
// `⨄_i (Γ_i \ Γ)`: per-field bindings must be disjoint, so this
// pattern — where both fields try to bind the name `x` — must be
// rejected. Pre-fix, `bind_ctor_fields` cons-prepended via
// `append_env` and the second `x` silently shadowed the first.
//
// Filename intentionally omits `_test` so `nexus test` discovery
// skips it (a fixture that intentionally fails compile would
// otherwise be reported as a runner failure).

type Pair = MkPair(a: i64, b: i64)

let extract = fn (p: Pair) -> i64 do
  match p do
    | MkPair(a: x, b: x) -> return x
  end
end

let main = fn () -> unit do
  let _ = extract(p: MkPair(a: 1, b: 2))
  return ()
end
