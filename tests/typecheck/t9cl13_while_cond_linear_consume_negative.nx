// Negative fixture for nexus-t9cl.13 — T-While must reject a cond
// expression that consumes a linear binding.
//
// Spec rule (type-system-formal.md §T-While, t9cl.8 / t9cl.13): the
// while loop's condition is evaluated once per iteration plus the
// final false-check. A linear binding may only be consumed once,
// so consuming a linear inside the cond is unsound: on iteration 2+
// the binding is already gone. Pre-fix the linearity pass walked
// cond → st1, body → st_body and then compared `vars_equal(st1,
// st_body)` — but `st1` already reflected the cond's consume, so
// the comparison passed and the program slipped through.
//
// Post-fix the pass snapshots `pre_vars` BEFORE cond, runs cond
// against the snapshot, and rejects when `vars_equal(pre_vars,
// post_cond_vars)` fails. The diagnostic message names the offending
// linear sets so users can pinpoint the bad consume.
//
// Filename intentionally omits `_test` so `nexus test` does not pick
// it up.
let make_linear = fn () -> %i64 do
  let %v = 1
  return %v
end

// Hypothetical consumer used inside the cond. `consume_to_bool` takes
// a `%i64` linearly and returns a bool — the call discharges the
// linear obligation exactly once. Inside a while cond this is unsound
// because the cond fires on every iteration.
let consume_to_bool = fn (x: %i64) -> bool do
  match x do | _ -> () end
  return true
end

let main = fn () -> unit do
  let %a = make_linear()
  // Pre-fix this slipped through; post-fix the linearity pass raises
  // "while-cond consumes linear binding(s); the cond runs an unbounded
  //  number of times so any linear consume in it is unsound (...)"
  while consume_to_bool(x: %a) do
    ()
  end
  return ()
end
