// Regression: nexus-zy0e — minimal positive shape for a top-level
// `main` declared `throws { Exn }` that raises a concrete exception.
//
// Compile-only check — `nexus build` must accept this without a
// row-mismatch / row-rejection diagnostic. The row-unify path is
// covered by nexus-xhhq (Pass 2 lambda scheme expansion of exception
// groups in `throws`) and nexus-qrx1 (row subsumption fallback when
// the caller row admits `Exn`).

let main = fn () -> unit throws { Exn } do
  raise RuntimeError(val: "test")
end
