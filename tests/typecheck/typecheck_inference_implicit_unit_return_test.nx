// Port of bootstrap/tests/typecheck/inference.rs::
// test_no_return_unit_is_ok, test_implicit_unit_return_with_side_effect,
// test_return_in_if_branch_counts_as_return,
// test_return_in_match_counts_as_return.
//
// A `unit`-returning function may omit `return`. A function that
// returns from every branch of an `if`/`match` is correctly seen as
// totally diverging — i.e. all paths return.
import * as test_assert from "std:test/assert"

let no_return_unit_ok = fn () -> unit do
  let _x = 1
end

let side_effect = fn () -> unit do
  let _x = 1 + 2
end

let abs_via_if = fn (x: i64) -> i64 do
  if x > 0 then
    return x
  else
    return 0 - x
  end
end

let bool_to_int = fn (x: bool) -> i64 do
  match x do
    | true -> return 1
    | false -> return 0
  end
end

let body = fn () -> unit throws { Exn } do
  no_return_unit_ok()
  side_effect()
  test_assert.assert_eq_i64(actual: abs_via_if(x: 5), expected: 5, label: "abs +5")
  test_assert.assert_eq_i64(actual: abs_via_if(x: 0 - 7), expected: 7, label: "abs -7")
  test_assert.assert_eq_i64(actual: bool_to_int(x: true), expected: 1, label: "match true")
  test_assert.assert_eq_i64(actual: bool_to_int(x: false), expected: 0, label: "match false")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
