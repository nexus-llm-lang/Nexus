// Positive companion to the nested-carrier reject fixture
// (tests/negative/linearity/nested_carrier_field_linear_drop.nx): when the
// carrier field `items: [A]` with `A = %Box` is consumed EXACTLY once, the
// program must still type-check. Guards the nested-carrier linearity fix
// against over-rejecting consumed-once forms.
//
// Spec: type-system-formal §Linearity — linear(Wrap<%Box>) = true (the list
// element `%Box` is linear); a linear binding must be consumed exactly once.

import * as test_assert from "std:test/assert"

type Box = Box(x: i64)
type Wrap<A> = Wrap(items: [A])

let take = fn (b: %Box) -> i64 do
  match b do
    | Box(x: v) -> return v
  end
end

// Fully consume the list (no wildcard discard of a linear element).
let sum_take = fn (xs: [%Box]) -> i64 do
  match xs do
    | h :: t -> return take(b: h) + sum_take(xs: t)
    | [] -> return 0
  end
end

let body = fn () -> i64 throws { Exn } do
  let %b = Box(x: 42)
  let w = Wrap(items: [b])
  // Single consume of the carrier field binder `xs : [%Box]`.
  let v = match w do
    | Wrap(items: xs) -> sum_take(xs: xs)
  end
  test_assert.assert_eq_i64(actual: v, expected: 42, label: "single-consume carrier [%Box]")
  return v
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
