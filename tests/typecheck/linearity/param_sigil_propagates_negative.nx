// Negative fixture for nexus-djn1: a sigil-only `%r` on a parameter
// must trigger linearity tracking. Body never consumes %r — pre-fix,
// the sigil was silently dropped during HIR conversion and no error
// fired. Post-fix, this file MUST fail to compile with E2007
// "linear binding '%r' is never consumed".
//
// Filename intentionally omits `_test` so `nexus test` does not pick
// it up (a fixture that intentionally fails compile would otherwise be
// reported as a runner failure).

type Resource = MkR(id: i64)

// %r sigil-only; type is plain Resource. Body returns without
// consuming r — must be rejected post-fix.
let leak = fn (%r: Resource) -> i64 do
  return 0
end

let main = fn () -> unit do
  let n = leak(r: MkR(id: 7))
  let _ = n
  return ()
end
