// Negative fixture for nexus-x5ww — `let _ = e` must reject when `e`
// produces a non-auto-droppable linear value. The `check_stmt` Let arm
// in `src/typecheck/linearity.nx` rejects the binding upfront via the
// `call_ret_non_droppable` predicate, pointing at the offending let line.
//
// Filename intentionally omits `_test` so `nexus test` does not pick it
// up — a fixture that intentionally fails compile would otherwise be
// reported as a runner failure.
import * as bb from "std:bytebuffer"

let main = fn () -> unit do
  // bb.empty() returns %ByteBuffer (linear, non-auto-droppable). The
  // wildcard discard is rejected because the structural pass cannot prove
  // the inner type is auto-droppable — accepting it would silently leak.
  let _ = bb.empty()
  return ()
end
