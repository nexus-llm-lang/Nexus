// Positive fixture (nexus-opd38, guard against over-reach): a `&σ` borrow in
// PARAMETER position is a call-scoped view and remains well-formed. The
// return-type ban (Form A) must not bleed into parameter positions.
//
// `peek` takes a `&ByteBuffer` and returns a plain `i64` (the length) — the
// borrow does NOT escape via the return type, so this must typecheck and run.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule" (borrows valid as
// parameter types; only escape positions are forbidden).

import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

let peek = fn (c: &ByteBuffer) -> i64 do
  return bb.length(buf: c)
end

let body = fn () -> unit throws { Exn } do
  let %b0 = bb.empty()
  let %b1 = bb.push_byte(buf: %b0, byte: 200)
  let n = peek(c: &b1)
  bb.free(buf: %b1)
  test_assert.assert_eq_i64(
    actual: n,
    expected: 1,
    label: "borrow-as-parameter (no return escape) still works"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
