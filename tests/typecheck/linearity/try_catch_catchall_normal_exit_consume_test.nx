// nexus-w1l79 (positive companion): a try/catch whose try-body CONSUMES the
// outer linear `%h` on its normal-exit (return-style divergence) path is
// accepted. Once `%h` is consumed inside the try body it is consumed from the
// catch arm's perspective too (nexus-hjh2: the runtime does not roll back heap
// ops), so the catch-all `_` arm must NOT re-consume it — it just returns a
// constant. No path leaks `%h`: the normal-exit path consumed it, and the
// (operationally-after-consume) catch path treats it as already consumed.
//
// This is the sound counterpart to the rejected catch-all-masks-leak fixture
// (try_catch_catchall_normal_exit_linear_leak.nx, where the try body does NOT
// consume %h). It confirms the w1l79 fix does not over-reject a try body that
// genuinely reclaims its outer linear before returning.
import * as test_assert from "std:test/assert"

type H = H(n: i64)

let consume_h = fn (h: %H) -> i64 do
  let H(n: v) = h
  return v
end

let safe = fn () -> i64 do
  let %h = H(n: 7)
  try
    // normal-exit path consumes %h here, before returning
    let r = consume_h(h: %h)
    return r
  catch _ ->
    // %h already consumed in the try body; do not touch it here.
    return 0
  end
end

let main = fn () -> unit do
  let n = safe()
  test_assert.assert_eq_i64(actual: n, expected: 7, label: "try-body consumes %h on normal exit")
  return ()
end
