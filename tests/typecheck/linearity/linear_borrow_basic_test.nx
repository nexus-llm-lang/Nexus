// Originally a port of bootstrap/tests/typecheck/linear.rs::
// test_linear_borrow_basic — that fixture used `let r1 = &%x` to borrow
// a linear binding into a fresh let-binding, exercising the bootstrap's
// permissive borrow semantics.
//
// Post nexus-mqin.11, T-Borrow's spec-mandated `x :^ω` precondition is
// enforced *at let-rhs position*: `let r = &b` where `b` is linear (`%`)
// or lazy (`@`) is rejected. The argument-position carve-out remains
// (see `mqin11_borrow_linear_arg_position_test.nx`).
//
// This fixture now exercises the surviving spec-compliant shape:
// multiple let-position borrows of a *plain unrestricted* binding.
import * as test_assert from "std:test/assert"

// Pure no-op accessor — exercises the &i64 -> unit arrow and the
// match-on-borrow pattern without doing arithmetic on the reference
// itself (which the lowerer rejects: "Integer op expects i32/i64,
// got &i64 and i64").
let peek = fn (x: &i64) -> unit do
  let _ = x
  return ()
end

let body = fn () -> unit throws { Exn } do
  let x = 10
  let r1 = &x
  peek(x: r1)
  let r2 = &x
  peek(x: r2)
  // x is ^ω, so it remains usable after both borrows.
  let result = match x do | n -> n end
  test_assert.assert_eq_i64(
    actual: result,
    expected: 10,
    label: "multiple let-position borrows preserve unrestricted x"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
