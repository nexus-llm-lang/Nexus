import * as test_assert from "std:test/assert"

type Tagged = Left(l: %i64) | Right(r: %i64)

let consume = fn (t: Tagged) -> i64 do
  match t do
  | Left(l: x) | Right(r: x) ->
    match x do | _ -> () end
    return 1
  end
end

let body = fn () -> unit throws { Exn } do
  let %a = 11
  test_assert.assert_eq_i64(
    actual: consume(t: Left(l: %a)),
    expected: 1,
    label: "or-pattern binding same linear var in both arms (Left)"
  )
  let %b = 29
  test_assert.assert_eq_i64(
    actual: consume(t: Right(r: %b)),
    expected: 1,
    label: "or-pattern binding same linear var in both arms (Right)"
  )
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
