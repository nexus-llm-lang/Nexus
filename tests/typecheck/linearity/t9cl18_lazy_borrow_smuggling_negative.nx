// Negative fixture for nexus-t9cl.18 — borrow-to-lazy smuggling.
//
// Companion to t9cl.20's `_negative` fixture, which pins the `%T`
// parameter side of the same exploit. This one pins the `@T` (lazy)
// parameter side.
//
// Spec (type-system-formal.md §T-App weakening, §Linearity, §U-Borrow):
//   §T-App weakening — line 825 / 834:
//     "The weakening condition is explicit: when P = %σ and ¬linear(τ_i),
//      unification targets the inner type σ. This does NOT apply to other
//      linear forms like @σ."
//   So weakening never fires for P = @σ.
//
//   §U-Borrow — line 510:
//     ¬linear(τ_2)   unify(τ_1, τ_2)
//     ──────────────────────────────
//     unify(&τ_1, τ_2)
//
//   linear(@σ) = true (outermost @-wrapper clause in §Linearity, line 350),
//   so U-Borrow's ¬linear(τ_2) premise blocks unify(&σ, @σ').
//
// Together the two rules formally rule out passing &x where a @T is
// expected — the smuggling shape "callee receives @ByteBuffer, can force
// & consume the underlying linear, while caller still holds &x" cannot
// type-check.
//
// The impl in src/typecheck/infer.nx::check_call_args_walk's TyLazy
// weakening branch performs the same rejection defensively at the
// argument-walk layer (the spec's U-Borrow alone would also block it,
// but the explicit early-reject yields a clearer diagnostic mentioning
// "lazy '@T'").
//
// Filename omits `_test` so the runner does not pick it up — this is a
// compile-fail-expected fixture, not a runtime test.
import * as bb from "std:bytebuffer"

let take_lazy = fn (@p: @bb.ByteBuffer) -> unit do
  let _b = @p
  return ()
end

let main = fn () -> unit do
  let %x = bb.empty()
  // Pre-fix: borrowing would have been silently coerced via the param
  // sigil's lazy-capture machinery, smuggling a borrow into a one-shot
  // lazy slot.
  // Post-fix: rejected at check_call_args_walk's TyLazy branch,
  // diagnostic cites spec §U-Borrow + t9cl.18.
  take_lazy(p: &x)
  bb.free(buf: %x)
  return ()
end
