// nexus-hjh2 (adjusted from nexus-7eex.1): a pre-try linear that the try
// body does NOT consume is available after the try/catch. This is the sound
// version of the original Strategy-A fixture: the try body calls may_throw()
// but does not consume %t; the catch arm diverges (returns) so both arms
// agree on the post-try linear set {t}; %t is then consumed on the success
// path after the try/catch.
//
// The original test consumed %t in BOTH the try body and the catch arm.
// That pattern is unsound (nexus-hjh2): the runtime does not roll back heap
// operations, so a linear consumed anywhere in the try body must be treated
// as consumed from the catch arm's perspective too.
import * as test_assert from "std:test/assert"

exception Oops(msg: string)
type Token = { id: i64 }

let may_throw = fn () -> unit throws { Exn } do
  throw Oops(msg: "boom")
end

// Returns 0 on the success path (catch arm diverges via return-1, and the
// function hits the code after try/catch only if may_throw() does not throw,
// which is never the case here — but the typechecker accepts the structure).
let consume_after_try = fn () -> i64 throws { Exn } do
  let %t: Token = { id: 1 }
  try
    may_throw()      // %t is not consumed in the try body
  catch _ ->
    // %t was not consumed by try body, so it is in the catch arm's live set.
    // Both arms must leave %t in the same state (arm consistency), so we do
    // not consume %t here — the catch arm diverges.
    return 1
  end
  // success path: %t still live — consume it here
  match %t do | { id: _ } -> () end
  return 0
end

let body = fn () -> unit throws { Exn } do
  let r = consume_after_try()
  test_assert.assert_eq_i64(actual: r, expected: 1, label: "catch-arm diverges, pre-try linear consumed after")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
