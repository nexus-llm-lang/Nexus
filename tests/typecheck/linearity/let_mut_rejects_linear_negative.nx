// Negative fixture for nexus-5pgr — T-Let premise μ = ~ ⟹ ¬linear(τ').
// Pre-fix, `let ~r = bb.empty()` silently dropped the `~` sigil and
// bound `r` at `%ByteBuffer`, surfacing a confusing "linear binding %r
// is never consumed" from the linearity pass. Post-fix, infer_let
// rejects the binding directly with a focused diagnostic that names
// the offending source line and references the spec invariant.
//
// Filename intentionally omits `_test` so `nexus test` does not pick it
// up — a fixture that intentionally fails compile would otherwise be
// reported as a runner failure.
import * as bb from "std:bytebuffer"

let main = fn () -> unit do
  // bb.empty() returns %ByteBuffer (linear). Mutable-ref binding of a
  // linear value violates the T-Let premise — must be rejected.
  let ~r = bb.empty()
  let _ = r
  return ()
end
