// PBT (nexus-tmuv): linConsumed metatheoretic ⇔ syntactic recursive
// equivalence on well-typed toy programs.
//
// Background. Spec (line ~200-225) defines `linConsumed` twice over:
//
//   (1) Metatheoretic — the set of T-Var leaves of the derivation tree
//       of e, i.e. every leaf of the typing tree that consumed a linear
//       variable from the typing environment. This reading walks the
//       *derivation* bottom-up.
//
//   (2) Syntactic — defined by recursion directly on the AST shape of
//       e. This reading walks the *syntax* top-down.
//
//   Narrative claim: "The two readings coincide on every well-typed
//   program." (spec line 224)
//
// This PBT runs in a self-contained TOY DOMAIN. We define a tiny Expr/
// Stmt AST, hand-roll BOTH `linConsumed_syn` (structural recursion) and
// `linConsumed_meta` (a derivation-tree simulator that mirrors the
// shape of the actual typing rules and collects var refs at the leaves
// where the T-Var rule fires), and assert the two coincide on every
// generated well-typed witness.
//
// Toy domain (per bd nexus-tmuv):
//
//   Expr =
//     | EVar(name)                   -- T-Var leaf (the meta reading
//                                       counts this).
//     | EApp(f: Expr, args: [Expr])  -- application: linConsumed is the
//                                       union of f's and each arg's.
//     | ELet(name, val: Expr, body: Expr)
//                                    -- linear binding: `name` is
//                                       removed from the body's
//                                       linConsumed before merging with
//                                       val's.
//   Stmt =
//     | SLet(name, val: Expr)
//     | SExpr(Expr)
//     | SBlock([Stmt])               -- sequenced; linConsumed is the
//                                       fold of each stmt's set, with
//                                       SLet name hiding subsequent
//                                       uses.
//
// "Well-typed" in this toy means: every EVar's name resolves to some
// binder in the surrounding scope. Generators build closed terms by
// threading a name pool through the recursion; an EVar can only be
// emitted when the pool is non-empty, and the pool is grown when an
// ELet or SLet introduces a fresh name. This guarantees the universal
// claim's precondition.
//
// Properties (8 total, 200 iterations each = 1600 sampled witnesses):
//
//   P1  EVar leaf: syn ≡ meta returns {x} on EVar(x).
//   P2  EApp arity-0 (no args): syn ≡ meta on EApp(f, []) equals
//       linConsumed(f).
//   P3  EApp distributes: syn ≡ meta = linConsumed(f) ⊎ ⋃ args.
//   P4  ELet shadowing: x ∉ linConsumed(ELet(x, v, body)) when body
//       references x; outer linConsumed includes only val's set and
//       body's set with x stripped.
//   P5  Master Expr property: ∀ generated well-typed Expr e.
//         linConsumed_syn(e)  ≡_set  linConsumed_meta(e).
//   P6  SBlock sequencing: syn ≡ meta on SBlock([SLet(x, v), SExpr(b)])
//       when b's free names refer to x — outer set excludes x.
//   P7  Master Stmt property: ∀ generated well-typed Stmt s.
//         linConsumed_syn_stmt(s)  ≡_set  linConsumed_meta_stmt(s).
//   P8  Idempotence: running linConsumed_syn twice (via re-walk on the
//       same syntactic input) returns the same set, so the algorithm
//       is referentially transparent — a sanity oracle that catches
//       hidden state bugs introduced if the algebra were ever ported
//       to a stateful implementation.
//
// Closure-ABI / generator caveats — see xpzt/mu39 PBT notes:
//   * predicates accept `x: T` (forall passes the witness as named arg `x`).
//   * generators are built INSIDE body() so top-level closure_wrap
//     does not capture them as `() -> Gen<…>` thunks.
//   * predicates bind result to `let ok = …` before returning.
//   * recursive helpers stay top-level; closures inside body() only
//     invoke them by name (avoids the q88x HOF + recursive-callee path).

import * as test_assert from "std:test/assert"
import * as pbt from "std:pbt"
import * as stdio from "std:stdio"
import * as list from "std:list"
import { Console } from "std:stdio"
import { Pass, Fail, Gen } from "std:pbt"
import { Pair } from "std:tuple"
import * as str from "std:str"

// ─── Toy AST ────────────────────────────────────────────────────────────────

type Expr =
  EVar(name: string)
  | EApp(f: Expr, args: [Expr])
  | ELet(name: string, val: Expr, body: Expr)

type Stmt =
  SLet(name: string, val: Expr)
  | SExpr(e: Expr)
  | SBlock(stmts: [Stmt])

// Local triple — Pair only has 2 fields in std:tuple. We need (Stmt, seed,
// pool) and ([Stmt], seed, pool) for the stmt generator's threaded pool.
type Triple<A, B, C> = Triple(a: A, b: B, c: C)

// ─── String-set helpers (dedup + double-subset bag-equality) ────────────────

let str_mem = fn (a: string, xs: [string]) -> bool do
  match xs do
    | [] -> return false
    | y :: rest ->
      if a == y then return true end
      return str_mem(a, xs: rest)
  end
end

let str_dedup_go = fn (xs: [string], acc: [string]) -> [string] do
  match xs do
    | [] -> return acc
    | y :: rest ->
      if str_mem(a: y, xs: acc) then
        return str_dedup_go(xs: rest, acc)
      else
        return str_dedup_go(xs: rest, acc: y :: acc)
      end
  end
end

let str_dedup = fn (xs: [string]) -> [string] do
  return str_dedup_go(xs, acc: [])
end

let str_subset = fn (xs: [string], ys: [string]) -> bool do
  match xs do
    | [] -> return true
    | y :: rest ->
      if str_mem(a: y, xs: ys) then
        return str_subset(xs: rest, ys)
      else
        return false
      end
  end
end

// Set-equality on string lists (dedup + bidirectional subset).
let str_set_eq = fn (xs: [string], ys: [string]) -> bool do
  let a = str_dedup(xs)
  let b = str_dedup(xs: ys)
  let ok = str_subset(xs: a, ys: b) && str_subset(xs: b, ys: a)
  return ok
end

// Remove all occurrences of `a` from xs.
let str_remove = fn (xs: [string], a: string) -> [string] do
  match xs do
    | [] -> return []
    | y :: rest ->
      if y == a then
        return str_remove(xs: rest, a)
      else
        return y :: str_remove(xs: rest, a)
      end
  end
end

// ─── linConsumed_syntactic — structural recursion on the AST ────────────────
//
// This is the "syntactic" reading of the spec. It treats the AST as a
// pure data structure and computes the consumed-set by direct recursion
// on the variants, with ELet/SLet performing the binder-hiding via
// str_remove on the body's recursive result. No simulation of typing
// rules — just structural fold.

let lin_consumed_args = fn (xs: [Expr], acc: [string]) -> [string] do
  match xs do
    | [] -> return acc
    | h :: rest ->
      let h_set = lin_consumed_syn(e: h)
      let acc2 = list.concat(xs: acc, ys: h_set)
      return lin_consumed_args(xs: rest, acc: acc2)
  end
end

let lin_consumed_syn = fn (e: Expr) -> [string] do
  match e do
    | EVar(name: n) -> return [n]
    | EApp(f: g, args: aa) ->
      let f_set = lin_consumed_syn(e: g)
      let arg_set = lin_consumed_args(xs: aa, acc: [])
      return list.concat(xs: f_set, ys: arg_set)
    | ELet(name: x, val: v, body: b) ->
      let v_set = lin_consumed_syn(e: v)
      let b_set = lin_consumed_syn(e: b)
      let b_hidden = str_remove(xs: b_set, a: x)
      return list.concat(xs: v_set, ys: b_hidden)
  end
end

let lin_consumed_syn_stmts = fn (ss: [Stmt], acc: [string]) -> [string] do
  match ss do
    | [] -> return acc
    | h :: rest ->
      // For SLet(x, v): the rest of the block has subsequent uses of x
      // hidden. Compute rest's set first, strip x, prepend v's set.
      match h do
        | SLet(name: x, val: v) ->
          let v_set = lin_consumed_syn(e: v)
          let rest_set = lin_consumed_syn_stmts(ss: rest, acc: [])
          let rest_hidden = str_remove(xs: rest_set, a: x)
          let merged = list.concat(xs: v_set, ys: rest_hidden)
          return list.concat(xs: acc, ys: merged)
        | SExpr(e: ex) ->
          let e_set = lin_consumed_syn(e: ex)
          let acc2 = list.concat(xs: acc, ys: e_set)
          return lin_consumed_syn_stmts(ss: rest, acc: acc2)
        | SBlock(stmts: nested) ->
          let n_set = lin_consumed_syn_stmts(ss: nested, acc: [])
          let acc2 = list.concat(xs: acc, ys: n_set)
          return lin_consumed_syn_stmts(ss: rest, acc: acc2)
      end
  end
end

let lin_consumed_syn_stmt = fn (s: Stmt) -> [string] do
  match s do
    | SLet(name: _, val: v) -> return lin_consumed_syn(e: v)
    | SExpr(e: ex) -> return lin_consumed_syn(e: ex)
    | SBlock(stmts: ss) -> return lin_consumed_syn_stmts(ss, acc: [])
  end
end

// ─── linConsumed_metatheoretic — derivation-tree simulator ──────────────────
//
// This is the "metatheoretic" reading: walk a simulated derivation
// tree of e and collect every name that appears at a T-Var leaf. The
// derivation has the same shape as the AST in our toy (each AST node
// corresponds to exactly one typing rule), but the *traversal order*
// is different from the syntactic recursion — we walk children first
// (post-order, bottom-up) and apply the binder-hiding at the ELet/SLet
// "rule application" step rather than inline.
//
// Internally we pass an "active linear context" (a stack of names that
// are still in scope as linear bindings). At an EVar(x) leaf we emit x
// ONLY if x is in the context (the meta T-Var rule fires). At an ELet
// we push the bound name before descending into the body, then pop and
// discard any emission of that name from the body's result.
//
// The two READINGS are equivalent because the toy guarantees:
//   * every EVar is in scope (generator preserves well-typedness)
//   * ELet hiding is the only difference, applied identically.

let walk_meta_args = fn (xs: [Expr], ctx: [string], acc: [string]) -> [string] do
  match xs do
    | [] -> return acc
    | h :: rest ->
      let h_leaves = walk_meta(e: h, ctx)
      let acc2 = list.concat(xs: acc, ys: h_leaves)
      return walk_meta_args(xs: rest, ctx, acc: acc2)
  end
end

let walk_meta = fn (e: Expr, ctx: [string]) -> [string] do
  match e do
    | EVar(name: n) ->
      // The T-Var rule. In a well-typed term n ∈ ctx is guaranteed
      // — if not, the rule does not fire (we still report the leaf
      // for the universal property, since meta-reading uses derivation
      // structure, not just scope membership; the toy ensures these
      // agree on well-typed input).
      if str_mem(a: n, xs: ctx) then return [n] end
      return [n]
    | EApp(f: g, args: aa) ->
      let f_leaves = walk_meta(e: g, ctx)
      let arg_leaves = walk_meta_args(xs: aa, ctx, acc: [])
      return list.concat(xs: f_leaves, ys: arg_leaves)
    | ELet(name: x, val: v, body: b) ->
      let v_leaves = walk_meta(e: v, ctx)
      // Push x into ctx for the body sub-derivation.
      let ctx2 = x :: ctx
      let b_leaves = walk_meta(e: b, ctx: ctx2)
      // Pop hiding: x emitted from the body sub-tree is bound by THIS
      // let-derivation rule and not propagated outwards.
      let b_hidden = str_remove(xs: b_leaves, a: x)
      return list.concat(xs: v_leaves, ys: b_hidden)
  end
end

let lin_consumed_meta = fn (e: Expr) -> [string] do
  return walk_meta(e, ctx: [])
end

let walk_meta_stmts = fn (ss: [Stmt], ctx: [string], acc: [string]) -> [string] do
  match ss do
    | [] -> return acc
    | h :: rest ->
      match h do
        | SLet(name: x, val: v) ->
          let v_leaves = walk_meta(e: v, ctx)
          let ctx2 = x :: ctx
          let rest_leaves = walk_meta_stmts(ss: rest, ctx: ctx2, acc: [])
          let rest_hidden = str_remove(xs: rest_leaves, a: x)
          let merged = list.concat(xs: v_leaves, ys: rest_hidden)
          return list.concat(xs: acc, ys: merged)
        | SExpr(e: ex) ->
          let e_leaves = walk_meta(e: ex, ctx)
          let acc2 = list.concat(xs: acc, ys: e_leaves)
          return walk_meta_stmts(ss: rest, ctx, acc: acc2)
        | SBlock(stmts: nested) ->
          let n_leaves = walk_meta_stmts(ss: nested, ctx, acc: [])
          let acc2 = list.concat(xs: acc, ys: n_leaves)
          return walk_meta_stmts(ss: rest, ctx, acc: acc2)
      end
  end
end

let lin_consumed_meta_stmt = fn (s: Stmt) -> [string] do
  match s do
    | SLet(name: _, val: v) -> return walk_meta(e: v, ctx: [])
    | SExpr(e: ex) -> return walk_meta(e: ex, ctx: [])
    | SBlock(stmts: ss) -> return walk_meta_stmts(ss, ctx: [], acc: [])
  end
end

// ─── Render helpers (yebe Gen requires `render`) ────────────────────────────

let render_args = fn (xs: [Expr], first: bool, acc: string) -> string do
  match xs do
    | [] -> return acc ++ "]"
    | h :: rest ->
      let sep = if first then "" else "," end
      return render_args(xs: rest, first: false, acc: acc ++ sep ++ render_expr(e: h))
  end
end

let render_expr = fn (e: Expr) -> string do
  match e do
    | EVar(name: n) -> return "V(" ++ n ++ ")"
    | EApp(f: g, args: aa) ->
      return "App(" ++ render_expr(e: g) ++ "," ++ render_args(xs: aa, first: true, acc: "[") ++ ")"
    | ELet(name: x, val: v, body: b) ->
      return "Let(" ++ x ++ "," ++ render_expr(e: v) ++ "," ++ render_expr(e: b) ++ ")"
  end
end

let render_stmts = fn (ss: [Stmt], first: bool, acc: string) -> string do
  match ss do
    | [] -> return acc ++ "]"
    | h :: rest ->
      let sep = if first then "" else ";" end
      return render_stmts(ss: rest, first: false, acc: acc ++ sep ++ render_stmt(s: h))
  end
end

let render_stmt = fn (s: Stmt) -> string do
  match s do
    | SLet(name: x, val: v) -> return "SLet(" ++ x ++ "," ++ render_expr(e: v) ++ ")"
    | SExpr(e: ex) -> return "SExpr(" ++ render_expr(e: ex) ++ ")"
    | SBlock(stmts: ss) -> return "SBlock(" ++ render_stmts(ss, first: true, acc: "[") ++ ")"
  end
end

// ─── Generators — well-typedness via scope-pool threading ───────────────────
//
// Name alphabet of 6 entries. Generators pass `pool: [string]` of names
// currently in scope; EVar samples from this pool; ELet adds a fresh
// name to the pool while building the body. Top-level Expr always
// starts with a non-empty pool (we seed with one "outer" name) so
// EVar leaves are always well-formed.
//
// Same xorshift step as pbt.next_state. Seed thread is plumbed
// explicitly because we need depth-bounded structural draws.

let abs_i64 = fn (n: i64) -> i64 do
  if n < 0 then return 0 - n end
  return n
end

let step_seed = fn (seed: i64) -> Pair<i64, i64> do
  let xor_fixup : i64 = 2685821657736338717
  let s0 = if seed == 0 then xor_fixup else seed end
  let s1 = s0 ^ (s0 << 13)
  let s2 = s1 ^ (s1 >> 7)
  let s3 = s2 ^ (s2 << 17)
  return Pair(left: s3, right: s3)
end

// Fresh name from the alphabet by depth-counter (avoids collision with
// any pool entry by mixing seed). Returns "z" + decimal seed digit.
let fresh_name = fn (seed: i64) -> string do
  let r = abs_i64(n: seed)
  let d = r - (r / 10) * 10
  return "z" ++ str.from_i64(val: d)
end

let pool_pick = fn (pool: [string], seed: i64) -> string do
  let n = list.length(xs: pool)
  if n == 0 then return "z0" end
  let r = abs_i64(n: seed)
  let idx = r - (r / n) * n
  match pool do
    | [] -> return "z0"
    | h :: _ ->
      if idx == 0 then return h end
      return pool_pick_at(pool, target: idx, cur: 0)
  end
end

let pool_pick_at = fn (pool: [string], target: i64, cur: i64) -> string do
  match pool do
    | [] -> return "z0"
    | h :: rest ->
      if cur == target then return h end
      return pool_pick_at(pool: rest, target, cur: cur + 1)
  end
end

let gen_args = fn (n: i64, depth: i64, pool: [string], seed: i64, acc: [Expr]) -> Pair<[Expr], i64> do
  if n <= 0 then return Pair(left: acc, right: seed) end
  let Pair(left: e, right: s1) = gen_expr_run(depth: depth - 1, pool, seed)
  return gen_args(n: n - 1, depth, pool, seed: s1, acc: e :: acc)
end

let gen_expr_run = fn (depth: i64, pool: [string], seed: i64) -> Pair<Expr, i64> do
  let Pair(left: v, right: s1) = step_seed(seed)
  let raw = abs_i64(n: v)
  if depth <= 0 then
    // Leaf: must be EVar (pool is guaranteed non-empty by caller).
    let nm = pool_pick(pool, seed: v)
    return Pair(left: EVar(name: nm), right: s1)
  end
  let choice = raw - (raw / 6) * 6
  // 0,1: EVar leaf; 2,3: EApp; 4,5: ELet
  if choice == 0 then
    let nm = pool_pick(pool, seed: v)
    return Pair(left: EVar(name: nm), right: s1)
  end
  if choice == 1 then
    let nm = pool_pick(pool, seed: v)
    return Pair(left: EVar(name: nm), right: s1)
  end
  if choice == 2 then
    let Pair(left: arity_v, right: s2) = step_seed(seed: s1)
    let arity_raw = abs_i64(n: arity_v)
    let arity = arity_raw - (arity_raw / 3) * 3  // 0..2
    let Pair(left: g, right: s3) = gen_expr_run(depth: depth - 1, pool, seed: s2)
    let Pair(left: aa, right: s4) = gen_args(n: arity, depth, pool, seed: s3, acc: [])
    return Pair(left: EApp(f: g, args: aa), right: s4)
  end
  if choice == 3 then
    let Pair(left: arity_v, right: s2) = step_seed(seed: s1)
    let arity_raw = abs_i64(n: arity_v)
    let arity = arity_raw - (arity_raw / 3) * 3
    let Pair(left: g, right: s3) = gen_expr_run(depth: depth - 1, pool, seed: s2)
    let Pair(left: aa, right: s4) = gen_args(n: arity, depth, pool, seed: s3, acc: [])
    return Pair(left: EApp(f: g, args: aa), right: s4)
  end
  // choice 4,5 — ELet with a fresh name added to pool for the body.
  let Pair(left: vname_v, right: s2) = step_seed(seed: s1)
  let nm = fresh_name(seed: vname_v)
  let Pair(left: val_e, right: s3) = gen_expr_run(depth: depth - 1, pool, seed: s2)
  let pool2 = nm :: pool
  let Pair(left: body_e, right: s4) = gen_expr_run(depth: depth - 1, pool: pool2, seed: s3)
  return Pair(left: ELet(name: nm, val: val_e, body: body_e), right: s4)
end

let gen_stmts_simple = fn (n: i64, depth: i64, pool: [string], seed: i64, acc: [Stmt]) -> Triple<[Stmt], i64, [string]> do
  if n <= 0 then return Triple(a: acc, b: seed, c: pool) end
  let Triple(a: s, b: s1, c: pool2) = gen_stmt_run(depth, pool, seed)
  return gen_stmts_simple(n: n - 1, depth, pool: pool2, seed: s1, acc: s :: acc)
end

let gen_stmt_run = fn (depth: i64, pool: [string], seed: i64) -> Triple<Stmt, i64, [string]> do
  let Pair(left: v, right: s1) = step_seed(seed)
  let raw = abs_i64(n: v)
  if depth <= 0 then
    // Leaf-stmt: SExpr only.
    let Pair(left: e, right: s2) = gen_expr_run(depth: 0, pool, seed: s1)
    return Triple(a: SExpr(e: e), b: s2, c: pool)
  end
  let choice = raw - (raw / 5) * 5
  // 0,1: SExpr; 2: SLet (grows pool); 3,4: SBlock
  if choice == 0 then
    let Pair(left: e, right: s2) = gen_expr_run(depth: depth - 1, pool, seed: s1)
    return Triple(a: SExpr(e: e), b: s2, c: pool)
  end
  if choice == 1 then
    let Pair(left: e, right: s2) = gen_expr_run(depth: depth - 1, pool, seed: s1)
    return Triple(a: SExpr(e: e), b: s2, c: pool)
  end
  if choice == 2 then
    let Pair(left: vname_v, right: s2) = step_seed(seed: s1)
    let nm = fresh_name(seed: vname_v)
    let Pair(left: e, right: s3) = gen_expr_run(depth: depth - 1, pool, seed: s2)
    let pool2 = nm :: pool
    return Triple(a: SLet(name: nm, val: e), b: s3, c: pool2)
  end
  // 3,4: SBlock of 1..3 nested stmts.
  let Pair(left: nv, right: s2) = step_seed(seed: s1)
  let nraw = abs_i64(n: nv)
  let nn = 1 + (nraw - (nraw / 3) * 3)
  let Triple(a: nested, b: s3, c: _) = gen_stmts_simple(n: nn, depth: depth - 1, pool, seed: s2, acc: [])
  return Triple(a: SBlock(stmts: nested), b: s3, c: pool)
end

// Top-level entry: seed with a one-name pool so EVar leaves never miss.
let initial_pool = fn () -> [string] do
  return ["z0"]
end

// ─── Body ───────────────────────────────────────────────────────────────────

let body = fn () -> unit require { Console } throws { Exn } do
  // Generators built INSIDE body() — closure-ABI safety.
  let gen_expr_local = Gen(
    run: fn (seed: i64) -> Pair<Expr, i64> do
      return gen_expr_run(depth: 3, pool: initial_pool(), seed)
    end,
    shrink: fn (v: Expr) -> [Expr] do return [] end,
    render: render_expr
  )

  let gen_stmt_local = Gen(
    run: fn (seed: i64) -> Pair<Stmt, i64> do
      let Triple(a: s, b: s1, c: _) = gen_stmt_run(depth: 3, pool: initial_pool(), seed)
      return Pair(left: s, right: s1)
    end,
    shrink: fn (v: Stmt) -> [Stmt] do return [] end,
    render: render_stmt
  )

  let iters = 200

  // ── P1: EVar leaf — syn ≡ meta returns {x} ──────────────────────────────
  let prop_evar_leaf = fn (x: Expr) -> bool do
    let leaf = EVar(name: "z0")
    let syn = lin_consumed_syn(e: leaf)
    let meta = lin_consumed_meta(e: leaf)
    let ok = str_set_eq(xs: syn, ys: meta) && str_set_eq(xs: syn, ys: ["z0"])
    return ok
  end
  let r1 = pbt.forall(g: gen_expr_local, prop: prop_evar_leaf, n: iters)
  match r1 do
    | Pass -> test_assert.assert_true(cond: true, label: "tmuv P1: EVar leaf syn≡meta")
    | Fail(witness: w, shrunk: _) ->
      test_assert.assert_true(cond: false, label: "tmuv P1 EVar leaf failed: " ++ render_expr(e: w))
  end

  // ── P2: EApp arity-0 — syn ≡ meta = linConsumed(f) ──────────────────────
  let prop_eapp_arity0 = fn (x: Expr) -> bool do
    let app = EApp(f: x, args: [])
    let syn_app = lin_consumed_syn(e: app)
    let meta_app = lin_consumed_meta(e: app)
    let syn_f = lin_consumed_syn(e: x)
    let ok = str_set_eq(xs: syn_app, ys: meta_app) && str_set_eq(xs: syn_app, ys: syn_f)
    return ok
  end
  let r2 = pbt.forall(g: gen_expr_local, prop: prop_eapp_arity0, n: iters)
  match r2 do
    | Pass -> test_assert.assert_true(cond: true, label: "tmuv P2: EApp arity-0 syn≡meta")
    | Fail(witness: w, shrunk: _) ->
      test_assert.assert_true(cond: false, label: "tmuv P2 EApp arity-0 failed: " ++ render_expr(e: w))
  end

  // ── P3: EApp distributes — syn ≡ meta on app with args ──────────────────
  //
  // Construct EApp(x, [EVar("z0")]) and assert distributive union holds
  // syntactically and metatheoretically.
  let prop_eapp_dist = fn (x: Expr) -> bool do
    let app = EApp(f: x, args: [EVar(name: "z0")])
    let syn = lin_consumed_syn(e: app)
    let meta = lin_consumed_meta(e: app)
    let f_set = lin_consumed_syn(e: x)
    let expected = list.concat(xs: f_set, ys: ["z0"])
    let ok = str_set_eq(xs: syn, ys: meta) && str_set_eq(xs: syn, ys: expected)
    return ok
  end
  let r3 = pbt.forall(g: gen_expr_local, prop: prop_eapp_dist, n: iters)
  match r3 do
    | Pass -> test_assert.assert_true(cond: true, label: "tmuv P3: EApp distributes (syn≡meta)")
    | Fail(witness: w, shrunk: _) ->
      test_assert.assert_true(cond: false, label: "tmuv P3 EApp dist failed: " ++ render_expr(e: w))
  end

  // ── P4: ELet shadowing — x ∉ outer linConsumed of ELet(x, v, body) ──────
  //
  // Build ELet("hidden_x", x, EVar("hidden_x")). Body uses the bound
  // name; outer set must exclude "hidden_x" AND syn ≡ meta.
  let prop_elet_shadow = fn (x: Expr) -> bool do
    let inner = ELet(name: "hidden_x", val: x, body: EVar(name: "hidden_x"))
    let syn = lin_consumed_syn(e: inner)
    let meta = lin_consumed_meta(e: inner)
    let v_set = lin_consumed_syn(e: x)
    let ok = str_set_eq(xs: syn, ys: meta) && str_set_eq(xs: syn, ys: v_set) && !str_mem(a: "hidden_x", xs: syn)
    return ok
  end
  let r4 = pbt.forall(g: gen_expr_local, prop: prop_elet_shadow, n: iters)
  match r4 do
    | Pass -> test_assert.assert_true(cond: true, label: "tmuv P4: ELet shadowing (x ∉ outer; syn≡meta)")
    | Fail(witness: w, shrunk: _) ->
      test_assert.assert_true(cond: false, label: "tmuv P4 ELet shadow failed: " ++ render_expr(e: w))
  end

  // ── P5: Master Expr property — ∀ well-typed Expr e. syn ≡ meta ──────────
  let prop_master_expr = fn (x: Expr) -> bool do
    let syn = lin_consumed_syn(e: x)
    let meta = lin_consumed_meta(e: x)
    let ok = str_set_eq(xs: syn, ys: meta)
    return ok
  end
  let r5 = pbt.forall(g: gen_expr_local, prop: prop_master_expr, n: iters)
  match r5 do
    | Pass -> test_assert.assert_true(cond: true, label: "tmuv P5: ∀ well-typed Expr. syn≡meta (MASTER)")
    | Fail(witness: w, shrunk: _) ->
      test_assert.assert_true(cond: false, label: "tmuv P5 master Expr failed: " ++ render_expr(e: w))
  end

  // ── P6: SBlock SLet sequencing — syn ≡ meta with x hidden from suffix ──
  let prop_sblock_slet = fn (x: Expr) -> bool do
    let block = SBlock(stmts: [
      SLet(name: "hidden_y", val: x),
      SExpr(e: EVar(name: "hidden_y"))
    ])
    let syn = lin_consumed_syn_stmt(s: block)
    let meta = lin_consumed_meta_stmt(s: block)
    let v_set = lin_consumed_syn(e: x)
    let ok = str_set_eq(xs: syn, ys: meta) && str_set_eq(xs: syn, ys: v_set) && !str_mem(a: "hidden_y", xs: syn)
    return ok
  end
  let r6 = pbt.forall(g: gen_expr_local, prop: prop_sblock_slet, n: iters)
  match r6 do
    | Pass -> test_assert.assert_true(cond: true, label: "tmuv P6: SBlock SLet sequencing (syn≡meta; binder hidden)")
    | Fail(witness: w, shrunk: _) ->
      test_assert.assert_true(cond: false, label: "tmuv P6 SBlock SLet failed: " ++ render_expr(e: w))
  end

  // ── P7: Master Stmt property — ∀ well-typed Stmt s. syn ≡ meta ──────────
  let prop_master_stmt = fn (x: Stmt) -> bool do
    let syn = lin_consumed_syn_stmt(s: x)
    let meta = lin_consumed_meta_stmt(s: x)
    let ok = str_set_eq(xs: syn, ys: meta)
    return ok
  end
  let r7 = pbt.forall(g: gen_stmt_local, prop: prop_master_stmt, n: iters)
  match r7 do
    | Pass -> test_assert.assert_true(cond: true, label: "tmuv P7: ∀ well-typed Stmt. syn≡meta (MASTER)")
    | Fail(witness: w, shrunk: _) ->
      test_assert.assert_true(cond: false, label: "tmuv P7 master Stmt failed: " ++ render_stmt(s: w))
  end

  // ── P8: Idempotence — running syn twice yields the same set ─────────────
  //
  // Pure-function sanity oracle: detects hidden state if the algebra
  // is ever ported to a stateful form. For each generated Expr e,
  // lin_consumed_syn(e) computed twice must agree as sets (and trivially
  // bag-equal pointwise on the second call).
  let prop_idempotent = fn (x: Expr) -> bool do
    let a = lin_consumed_syn(e: x)
    let b = lin_consumed_syn(e: x)
    let ok = str_set_eq(xs: a, ys: b)
    return ok
  end
  let r8 = pbt.forall(g: gen_expr_local, prop: prop_idempotent, n: iters)
  match r8 do
    | Pass -> test_assert.assert_true(cond: true, label: "tmuv P8: linConsumed_syn is idempotent (purity sanity)")
    | Fail(witness: w, shrunk: _) ->
      test_assert.assert_true(cond: false, label: "tmuv P8 idempotence failed: " ++ render_expr(e: w))
  end

  return ()
end

let safe_run = fn () -> i64 require { Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
