// Positive control for the E0540 ungate (throwable-call leak guard now fires
// in EXPRESSION position, not only at statement level). It must NOT false-
// positive when the live linear is covered by an enclosing try whose catch arm
// frees it.
//
// Here the throwable call sits in let-RHS position (`let v = might_throw()`)
// while `%h` is live, but the whole region is inside a try and the catch arm
// frees `%h` and rethrows. So `%h` is freed on BOTH the success path (after the
// try) and the throw path (in the catch) — no leak. The pre-try snapshot frame
// covers `%h`, so `uncovered_linears` is empty and the guard stays silent.
//
// Companion negative:
// tests/negative/linearity/e0540_throwable_call_leak_let_rhs.nx
import * as test_assert from "std:test/assert"

exception Boom(code: i64)

type Handle = Handle(fd: i64)

let might_throw = fn (raise_it: bool) -> i64 throws { Exn } do
  if raise_it then throw Boom(code: 1) end
  return 42
end

let close = fn (h: %Handle) -> i64 do
  let r = match h do | Handle(fd: i) -> i end
  return r
end

// %h is live across a let-RHS throwable call (`let v = might_throw(...)`), but
// the whole region is inside a statement-position try and BOTH arms consume %h
// via `close`: the success tail returns `v + close(h: %h)`, and the catch arm
// frees %h (via `close`) before producing a fallback. So %h never leaks and the
// guard must accept this — the pre-try snapshot frame covers %h, so the
// throwable-call leak check sees no uncovered linear. `try` is statement-only
// in Nexus, so each arm `return`s its value rather than the try yielding one.
let covered_let_rhs = fn (raise_it: bool) -> i64 do
  let %h = Handle(fd: 5)
  try
    let v = might_throw(raise_it)
    return v + close(h: %h)
  catch _ ->
    return close(h: %h)
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: covered_let_rhs(raise_it: false),
    expected: 47,
    label: "let-RHS throwable call with catch-arm free is accepted"
  )
  return ()
end
