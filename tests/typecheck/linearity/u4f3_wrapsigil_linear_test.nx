// Positive fixture for nexus-u4f3 — T-Let wrapSigil(%) implementation.
//
// When the user writes `let %b = Ctor(...)` and the rhs inferred type is
// a plain `TyUserDefined` (not already `TyLinear`), `infer_let` must wrap
// the type in `TyLinear(...)` before inserting into the env.  Without this,
// `b` lands with type `TyUserDefined(...)` and the T-Borrow linearity check
// (nexus-4n8y) cannot flag non-arg-position borrows of `b`.
//
// This fixture exercises:
//   1. `let %b = Ctor(...)` — plain Ctor rhs, sigil forces TyLinear wrap.
//   2. The binding `b` behaves as linear: it can be consumed once.
//   3. Arg-position borrow `f(p: &b)` still works (T-App carve-out).
import * as test_assert from "std:test/assert"

type Box = Box(val: i64)

let box_val = fn (b: &Box) -> i64 do
  let Box(val: v) = b
  return v
end

let body = fn () -> unit throws { Exn } do
  // Ctor(42) infers to TyUserDefined(Box); SigilLinear on the let triggers
  // wrapSigil — env gets TyLinear(TyUserDefined(Box)).
  let %b = Box(val: 42)
  // Arg-position borrow: T-App carve-out keeps b live after this call.
  let v = box_val(b: &b)
  // Consume the linear binding.
  let Box(val: _) = %b
  test_assert.assert_eq_i64(actual: v, expected: 42, label: "u4f3 wrapsigil: val matches")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
