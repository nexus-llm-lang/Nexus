// Regression for nexus-nahg — parser-side `let %Ctor(_) = e` form.
// The wildcard-fields shape (`Ctor(_)`) must also be reachable from
// the let-destructure with a sigil prefix, mirroring the arm-pattern
// path. Pre-fix this raised a parser UnexpectedToken; post-fix, the
// `SIGIL + Uident + (` peek routes through parse_pattern which builds
// `PatConstructorWildcard(name, sigil)` (sigil propagated since 2atf).
//
// This is a separate fixture from the field-binding case so a future
// regression in either sub-path produces a focused failure label.
import * as test_assert from "std:test/assert"

type Pair = MkPair(fst: i64, snd: i64)

let make_pair = fn () -> Pair do
  return %MkPair(fst: 11, snd: 22)
end

let body = fn () -> unit throws { Exn } do
  // No inner bindings to consume — just destruct-and-drop.
  let %MkPair(_) = make_pair()
  test_assert.assert_eq_i64(
    actual: 1,
    expected: 1,
    label: "let %Ctor(_) wildcard destructure typechecks"
  )
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
