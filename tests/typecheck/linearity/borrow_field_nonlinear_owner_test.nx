// Positive fixture (nexus-ymx7u, guard against over-reach): a record holding a
// borrow of a NON-LINEAR owner (a `&`-typed parameter) may STILL be RETURNED.
// This is the CompileCtx-as-parameter shape: the borrowed owner's lifetime is
// the caller's concern, not this function's, so the borrow may legally outlive
// this frame. Only borrows of a LOCAL LINEAR owner (which THIS function must
// consume) are rejected when they escape.
//
// `wrap` borrows nothing of its own — it forwards its `&i64` parameter `p`
// (non-linear) through the laundering helper `mk` into the returned `Ctx`.
// The owner-locality heuristic must NOT flag this: `p` is not in this
// function's owned-linear set.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule". nexus-ymx7u
import * as test_assert from "std:test/assert"

type Ctx = Ctx(b: &i64)

let mk = fn (c: &i64) -> Ctx do return Ctx(b: c) end

// Returns a Ctx borrowing the NON-linear parameter `p` — permitted.
let wrap = fn (p: &i64) -> Ctx do
  let cx = mk(c: p)
  return cx
end

let read = fn (cx: Ctx) -> i64 do
  match cx do | Ctx(b: x) -> return x end
end

let main = fn () -> unit throws { Exn } do
  let n = 99
  let cx = wrap(p: &n)
  test_assert.assert_eq_i64(
    actual: read(cx: cx),
    expected: 99,
    label: "returning a record holding a borrow of a NON-linear owner is permitted"
  )
  return ()
end
