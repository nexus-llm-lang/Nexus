// A generic (bare type-parameter) constructor field that is INSTANTIATED to a
// non-linear concrete type (e.g. `gen: A` with `A = i64`) must NOT be required
// to be consumed, even when a SIBLING field of the same constructor makes the
// whole scrutinee linear (`payload: %Box`).
//
// Pre-fix: the name-based linearity pass marked any bare-TyVar field of a
// linear scrutinee as linear (it could not see the instantiation), so the
// dropped `gg : i64` binder fired E2007 — a spurious over-rejection.
//
// Post-fix (approach (a)): the pass recovers the scrutinee's construction site
// (`Mix(payload: %p, gen: 7)`) and substitutes each declared type-parameter
// against the structural type-args — `gen`'s slot was filled by the non-linear
// arg `7`, so `gg` is auto-droppable and need not be consumed. The genuine
// linear field `payload` is still consumed exactly once.

import * as test_assert from "std:test/assert"

type Box = Box(val: i64)
type Mix<A> = Mix(payload: %Box, gen: A)

let sink = fn (b: %Box) -> i64 do
  match b do
    | Box(val: v) -> return v
  end
end

let body = fn () -> i64 do
  let %p = Box(val: 5)
  // Inferred Mix<i64>; `m` is linear via the concrete `%Box` field `payload`.
  let m = Mix(payload: %p, gen: 7)
  return match m do
    | Mix(payload: pp, gen: gg) ->
      // `gg : i64` (auto-drop) must NOT require consumption; `pp : %Box` does.
      let r = sink(b: pp)
      r
  end
end

let main = fn () -> unit do
  let v = body()
  test_assert.assert_eq_i64(actual: v, expected: 5, label: "generic non-linear field auto-drops")
  return ()
end
