/**
 * Positive fixture: destructuring a `&`-borrowed value with a wildcard `_`
 * over one of its LINEAR fields must typecheck. A borrowed scrutinee is not
 * owned, so the projected field is borrowed too — discarding it via `_`
 * transfers no resource and is not a P-Wild silent-leak violation.
 *
 * This mirrors the compiler's own `effect_map` idiom
 * (`let EffectMap(entries, lookup: _) = em` where `em: &EffectMap` and the
 * `lookup` field is a linear `%StringMap`). Pre-fix the type-checker's P-Wild
 * premise fired unconditionally on the linear field, ignoring that the
 * scrutinee was borrowed; post-fix the borrow status propagates into field
 * binding so the wildcard discard is accepted.
 *
 * The owned case is covered by the companion negative fixture
 * borrow_field_wildcard_discard_negative.nx, which must STILL reject.
 */
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

opaque type Holder = Holder(tag: i64, payload: %ByteBuffer)

/** Read only the non-linear `tag` field through a borrow, discarding the
 *  linear `payload` field with a wildcard. Permitted: `h` is borrowed. */
let read_tag = fn (h: &Holder) -> i64 do
  let Holder(tag, payload: _) = h
  return tag
end

let driver = fn () -> i64 throws { Exn } do
  let %buf = bb.empty()
  let %h0 = Holder(tag: 7, payload: %buf)
  let t = read_tag(h: &h0)
  let Holder(tag: _, payload: %p) = %h0
  bb.free(buf: %p)
  return t
end

let main = fn () -> unit throws { Exn } do
  let r = driver()
  test_assert.assert_eq_i64(
    actual: r,
    expected: 7,
    label: "wildcard discard of a borrowed value's linear field typechecks"
  )
  return ()
end
