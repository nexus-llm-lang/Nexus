// nexus-c3lk0 positive companion: the ρ_residual all-divergent try-body
// consumption clause must fire ONLY when the residual is non-empty. These two
// shapes keep an all-divergent try/catch with an outer linear and must remain
// ACCEPTED:
//
//   1. catch-all (`catch _ ->`) — every body-throw is caught (ρ_residual = ∅),
//      so no uncaught-throw escape path exists; the catch arm consumes the
//      linear and that suffices.
//   2. consumed-before-escape — the try body consumes the outer linear BEFORE
//      the throw point that forms the residual, so nothing is live on the
//      escape path.
//
// Both run to completion (no throw actually reaches process exit here), proving
// the accept side is operationally sound, not merely a typecheck quirk.
import * as test_assert from "std:test/assert"

exception E1
exception E2
exception E3

type H = H(n: i64)

let make_h = fn () -> H do return H(n: 1) end

let consume_h = fn (h: %H) -> i64 do
  match h do | H(n: v) -> return v end
end

// inner can throw E1 or E3, but here always returns 1 (no actual throw).
let inner = fn () -> i64 throws { E1, E3 } do return 1 end

// (1) catch-all covers the residual: even though inner() *could* throw E3, the
// `catch _` arm catches everything → ρ_residual = ∅ → accepted.
let via_catch_all = fn () -> i64 throws { E2 } do
  let %h = make_h()
  try
    let _x = inner()
    throw E1
  catch _ ->
    return consume_h(h: %h)
  end
end

// (2) all-divergent try (body throws E1 at tail; catch arm throws E2) with a
// non-empty residual (inner() can throw E3, caught only by E1) — BUT %h is
// consumed BEFORE the residual-forming throw point (inner()), so nothing is
// live on the E3 escape path. Must be accepted. Always throws E2 (caught by
// the caller).
let consume_before_escape = fn () -> unit throws { E2, E3 } do
  let %h = make_h()
  let captured = consume_h(h: %h)
  try
    let _x = inner()
    throw E1
  catch
  | E1 -> throw E2
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: via_catch_all(),
    expected: 1,
    label: "catch-all residual covered"
  )
  // consume_before_escape always throws E2; catch it and confirm the typecheck
  // accepted the all-divergent-residual shape (the call is reachable).
  try
    consume_before_escape()
  catch
  | E2 -> test_assert.assert_eq_i64(
    actual: 7,
    expected: 7,
    label: "consumed before residual escape"
  )
  | E3 -> test_assert.assert_eq_i64(actual: 0, expected: 7, label: "unexpected E3 escape")
  end
  return ()
end
