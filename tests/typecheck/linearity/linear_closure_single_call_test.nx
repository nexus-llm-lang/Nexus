// Regression test for nexus-ajwla: a closure that captures a linear binding
// may be called exactly once. The first (and only) call consumes the closure
// (and through it the captured linear).
//
// Also verifies that non-capturing closures remain unrestricted and may be
// called any number of times.

import * as test_assert from "std:test/assert"

type Res = Res(tag: i64)

let consume_res = fn (r: %Res) -> i64 do
  let Res(tag: t) = r
  return t
end

let body = fn () -> unit throws { Exn } do
  // A closure capturing a linear -- callable exactly once; passes.
  let %r = Res(tag: 42)
  let f = fn () -> i64 do
    return consume_res(r: %r)
  end
  let result = f()
  test_assert.assert_eq_i64(actual: result, expected: 42, label: "single-call linear closure")

  // A non-capturing closure may be called multiple times; passes.
  let g = fn (n: i64) -> i64 do
    return n + 1
  end
  let r1 = g(n: 1)
  let r2 = g(n: 2)
  let r3 = g(n: 3)
  test_assert.assert_eq_i64(actual: r1, expected: 2, label: "g(1)")
  test_assert.assert_eq_i64(actual: r2, expected: 3, label: "g(2)")
  test_assert.assert_eq_i64(actual: r3, expected: 4, label: "g(3)")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
