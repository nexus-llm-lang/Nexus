// Positive test: an array that IS consumed must not raise LinearUnused.
// Guard against false positives from the TyArray linear fix (nexus-eai4).
import * as bb from "std:bytebuffer"
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  // Create an array and pass it to a function that consumes it.
  let arr = [| 1, 2, 3 |]
  let %buf = bb.new()
  let %buf = bb.push_bytes(%buf, bytes: arr)
  bb.to_bytes(%buf)
  test_assert.assert_eq_bool(actual: true, expected: true, label: "array consumed once passes")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
