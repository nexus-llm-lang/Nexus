// The lazy "forced exactly once" check must NOT count a non-consuming borrow
// `&x` as a force.
//
// Spec §Linearity: linConsumed(&x) = ∅ — borrowing does not consume the
// binding, and a borrow is not a force. The HIR linearity pass counts forces
// of a `@`-thunk binding (and continuation binders) via reference counting;
// it must count only the actual `@x` force (`Force(Variable x)`), never a
// `&x` borrow of any binding.
//
// Two scenarios pinned here:
//   1. A %-linear binding borrowed in argument position (non-consuming) and
//      then consumed exactly once — the T-App-BorrowLin carve-out. The borrow
//      must not be miscounted as a consumption.
//   2. A `@`-thunk forced exactly once, while a borrow of a SEPARATE linear
//      binding appears in the same body. The borrow of the other binding must
//      not inflate the thunk's force-count (pre-fix it could, yielding a
//      spurious E2006 "forced more than once").
//
// These cases are pinned at the typecheck layer through unused top-level
// lets — they must compile but are not exercised at runtime from this file.
import * as test_assert from "std:test/assert"

let peek = fn (p: &i64) -> i64 do
  p
  return 0
end

let take = fn (p: i64) -> i64 do
  return p
end

// Scenario 1: %-linear borrow-arg (non-consuming) then take (consume once).
let _linear_borrow_then_take = fn () -> i64 do
  let %x = 9
  let r = peek(p: &x)
  let v = take(p: x)
  return r + v
end

// Scenario 2: a thunk forced exactly once, alongside an arg-position borrow of
// a SEPARATE linear binding. The thunk's force-count must stay exactly 1.
let _thunk_force_once_with_other_borrow = fn () -> i64 do
  let %y = 5
  let @t = 7
  let b = peek(p: &y)
  let consumed = take(p: y)
  let forced = @t
  return b + consumed + forced
end

let body = fn () -> unit throws { Exn } do
  let plain: i64 = 1
  test_assert.assert_eq_i64(actual: plain, expected: 1, label: "force-count smoke")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
