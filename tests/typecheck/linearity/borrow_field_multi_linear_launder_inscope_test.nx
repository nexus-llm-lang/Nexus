import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

type Ctx = Ctx(a: &ByteBuffer, b: &ByteBuffer)

let make_ctx = fn (a: &ByteBuffer, b: &ByteBuffer) -> Ctx do return Ctx(a: a, b: b) end

let sum_ctx = fn (cx: Ctx) -> i64 throws { Exn } do
  match cx do
    | Ctx(a: x, b: y) -> return bb.get_byte(buf: x, idx: 0) + bb.get_byte(buf: y, idx: 0)
  end
end

let driver = fn () -> i64 throws { Exn } do
  let %a0 = bb.empty()
  let %a1 = bb.push_byte(buf: %a0, byte: 7)
  let %b0 = bb.empty()
  let %b1 = bb.push_byte(buf: %b0, byte: 35)
  let cx = make_ctx(a: &a1, b: &b1)
  // `sum_ctx` is throwable and borrows %a1/%b1 (both live across the call), so
  // free them on the throw path too — otherwise they leak (E0540). The borrows
  // still never escape the function, which is what this fixture pins.
  try
    let r = sum_ctx(cx: cx)
    bb.free(buf: %a1)
    bb.free(buf: %b1)
    return r
  catch e ->
    bb.free(buf: %a1)
    bb.free(buf: %b1)
    throw e
  end
end

let main = fn () -> unit throws { Exn } do
  let r = driver()
  test_assert.assert_eq_i64(
    actual: r,
    expected: 42,
    label: "two local-linear borrows laundered through a constructor helper and consumed in scope are permitted"
  )
  return ()
end
