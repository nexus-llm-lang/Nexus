// Negative fixture for nexus-mqin.11 — T-Borrow's `x :^ω` precondition in
// LET-BIND position only.
//
// Spec (docs/spec/type-system-formal.md §T-Borrow):
//   x :^ω ∀ᾱ.τ ∈ Γ    τ' = inst(∀ᾱ.τ)    σ = stripBorrow(τ')
//   ────────────────────────────────────────────────────────────
//   Γ; ρ_q ⊢_e &x : &σ ! { }
//
// "Only unrestricted bindings can be borrowed." A linear (`%`) binding
// is q = 1; `&b` at let-rhs position must therefore be rejected because
// the borrow has no natural discharge — it would live on as a `&T`-typed
// binding past the surrounding scope.
//
// Argument position is the carve-out (cf. the positive fixture
// `mqin11_borrow_linear_arg_position_test.nx`): `f(p: &b)` passes the
// borrow into a callee that consumes it, restoring `b`'s linearity post-
// call.
//
// Filename intentionally omits `_test` so `nexus test` does not pick it
// up — a fixture that intentionally fails compile would otherwise be
// reported as a runner failure.
import * as bb from "std:bytebuffer"

let main = fn () -> unit do
  let %b = bb.empty()
  // T-Borrow requires `b :^ω`; b is `%ByteBuffer` (q = 1), so this
  // let-rhs borrow is rejected.
  let _r = &b
  bb.free(buf: %b)
  return ()
end
