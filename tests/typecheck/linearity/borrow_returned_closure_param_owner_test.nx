// Positive fixture (guard against over-reach for the returned-closure borrow
// rule): a closure that captures a borrow of a NON-LINEAR `&`-PARAMETER may
// STILL be RETURNED. The borrowed owner's lifetime is the caller's concern, not
// this function's, so the captured borrow may legally outlive this frame — the
// closure analog of the CompileCtx-as-parameter idiom. Only a captured borrow
// of a binding OWNED BY THIS FRAME (a local linear / non-linear `let`, or a
// `let`-alias of one) is rejected when it escapes via the returned closure.
//
// The owner-locality check must NOT flag this: `p` is a parameter, not in this
// function's frame-owned set, so a closure forwarding a borrow of `p` is sound.
//
// Companion negative test: borrow_escapes_returned_closure_capture.nx (a closure
// capturing a borrow of a frame-LOCAL is rejected with E2022).
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule".
import * as test_assert from "std:test/assert"

// Returns a closure that reads through the borrowed NON-linear parameter `p`.
// `p`'s owner outlives this frame, so the captured borrow may escape — permitted.
let make_reader = fn (p: &i64) -> (() -> i64) do
  let g = fn () -> i64 do return p end
  return g
end

let main = fn () -> unit throws { Exn } do
  let n = 42
  let r = make_reader(p: &n)
  test_assert.assert_eq_i64(
    actual: r(),
    expected: 42,
    label: "returning a closure that captures a borrow of a NON-linear parameter is permitted"
  )
  return ()
end
