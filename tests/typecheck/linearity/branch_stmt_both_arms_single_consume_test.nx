// Positive companion to the branch-statement double-consume reject fixtures
// (tests/negative/linearity/branch_stmt_if_both_arms_double_consume.nx and the
// match form): a linear consumed in BOTH arms of an `if`/`match` STATEMENT and
// NOT reused afterwards is consumed EXACTLY once across the branch, so the
// program must still type-check and run.
//
// Guards the statement-join consumed-set repair against over-rejecting the
// consumed-once-on-every-path form: folding the live-set delta into consumed
// must only block a LATER reuse, never the legitimate single consume inside the
// arms. Spec: type-system-formal §Linearity — a linear binding must be consumed
// exactly once; consuming it once on every branch path satisfies that.

import * as test_assert from "std:test/assert"

type Box = Box(val: i64)
type Tag = A | B

let sink = fn (b: %Box) -> i64 do
  let Box(val: v) = b
  return v
end

// Linear `%p` consumed in both arms of an `if` STATEMENT, never reused.
// The arm results are discarded; the function returns a constant so there is
// no later use of `%p` to reject. Must type-check and run.
let via_if = fn (cond: bool) -> i64 do
  let %p = Box(val: 5)
  if cond then let _a = sink(b: p) else let _b = sink(b: p) end
  return 5
end

// Linear `%q` consumed in both arms of a `match` STATEMENT, never reused.
let via_match = fn (t: Tag) -> i64 do
  let %q = Box(val: 9)
  match t do
    | A -> let _a = sink(b: q)
    | B -> let _b = sink(b: q)
  end
  return 9
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: via_if(cond: true),
    expected: 5,
    label: "if-stmt both-arms single consume (then)"
  )
  test_assert.assert_eq_i64(
    actual: via_if(cond: false),
    expected: 5,
    label: "if-stmt both-arms single consume (else)"
  )
  test_assert.assert_eq_i64(
    actual: via_match(t: A),
    expected: 9,
    label: "match-stmt both-arms single consume (A)"
  )
  test_assert.assert_eq_i64(
    actual: via_match(t: B),
    expected: 9,
    label: "match-stmt both-arms single consume (B)"
  )
  return ()
end
