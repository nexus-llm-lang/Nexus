// Positive fixture (nexus-quuuq, guard against over-reach): a record holding a
// borrow of a LOCAL NON-LINEAR owner, built by DIRECT construction, must STILL
// typecheck when the record is USED IN SCOPE and NOT returned. The borrow does
// not outlive the local owner's frame, so there is no escape.
//
// The owner-locality heuristic extended in quuuq must only fire when the
// tainted record ESCAPES via `return`; in-scope use is sound.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule". nexus-quuuq
import * as test_assert from "std:test/assert"

type Ctx = { b: &i64 }

let peek = fn (cx: Ctx) -> i64 do
  match cx do | { b: x } -> return x end
end

let driver = fn () -> i64 do
  let x = 42
  // cx borrows the LOCAL non-linear x by DIRECT construction, but is consumed
  // IN SCOPE (peek) and never escapes the function.
  let cx: Ctx = { b: &x }
  let r = peek(cx: cx)
  return r
end

let main = fn () -> unit throws { Exn } do
  let r = driver()
  test_assert.assert_eq_i64(
    actual: r,
    expected: 42,
    label: "in-scope record-stored borrow of a local non-linear is permitted (not an escape)"
  )
  return ()
end
