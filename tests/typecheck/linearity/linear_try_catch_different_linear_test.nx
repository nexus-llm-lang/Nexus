// nexus-hjh2 positive: two outer linears; try body consumes %a but NOT %b.
// Both arms must agree on %b: the catch arm does not consume %b either
// (diverges via return), so post_try_vars = post_catch_vars = [b].
// %b is then consumed after the try/catch on the success path.
import * as test_assert from "std:test/assert"

exception Boom(code: i64)
type Token = Token(id: i64)

let may_throw = fn () -> unit throws { Exn } do
  throw Boom(code: 1)
end

let main = fn () -> unit throws { Exn } do
  let %a = Token(id: 1)
  let %b = Token(id: 2)
  try
    match %a do | Token(id: _) -> () end   // consume %a in try body
    may_throw()
  catch _ ->
    // %a was consumed by try body (unavailable here per sound semantics).
    // %b was NOT consumed by try body and is available.
    // We do not consume %b here so both arms leave %b live (arm consistency).
    return ()
  end
  // success path: %a consumed above; %b still live — consume it here
  match %b do | Token(id: _) -> () end
  return ()
end
