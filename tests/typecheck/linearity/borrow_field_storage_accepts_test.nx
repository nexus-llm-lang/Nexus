// Positive fixture (nexus-opd38, guard against over-reach): a `&σ` borrow
// stored in a RECORD field or an ADT (variant) field must STILL typecheck.
// Field-stored borrows are an intentional, lifetime-tracking-free idiom — the
// compiler's own CodegenCtx/CompileCtx store `internal_func_map: &HashMap`,
// `effect_map: &EffectMap`, `local_map: &HashMap` as long-lived non-owning
// views of an owner that outlives the context. The Form-A return-type ban must
// NOT bleed into field positions (that would self-reject Stage1 with E2022).
//
// This pins that the type-declaration well-formedness walk
// (walk_record_fields / walk_variant_fields) accepts `&`-typed fields. Form B
// (a borrow escaping VIA a field that outlives its owner) is intentionally
// LEFT OPEN — it needs region/lifetime tracking, a deeper design item.
//
// Spec: docs/spec/type-system-formal.md §escapesRef table (field-stored
// borrows permitted; only return/escape positions screen `&σ`).
import * as test_assert from "std:test/assert"
import { HashMap } from "std:hashmap"

// Record type with a borrow-typed field (mirrors CodegenCtx.local_map: &HashMap).
type MapViewRec = { view: &HashMap, generation: i64 }

// ADT / variant type with a borrow-typed field.
type MapView = Wrap(view: &HashMap, tag: i64)

let body = fn () -> unit throws { Exn } do
  // The types above only need to be WELL-FORMED at declaration; this body
  // pins that the fixture reaches runtime so the decl walk actually ran.
  test_assert.assert_eq_i64(
    actual: 1,
    expected: 1,
    label: "record/ADT with &-typed field typechecks (field-stored borrow permitted)"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
