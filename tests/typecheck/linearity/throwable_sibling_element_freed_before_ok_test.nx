// Positive companion to the sibling-element throwable-leak rejections for
// CONSTRUCTOR arguments and RECORD-LITERAL fields
// (tests/negative/linearity/e0540_throwable_sibling_ctor_arg_leak.nx and
// tests/negative/linearity/e0540_throwable_sibling_record_field_leak.nx).
//
// The fix that flags a linear consumed by an EARLIER ctor/record element while a
// LATER element is throwable must NOT over-reach:
//
//   1. Non-throwing sibling element: a linear consumed by one element and a
//      plain non-throwing value as the other has no throw path that abandons it,
//      so it must still typecheck — for both constructor args and record fields.
//   2. Freed-before-call: a linear freed by an EARLIER STATEMENT (not by a
//      sibling element) before a throwable-element form is already dead at the
//      throwable point, so nothing leaks and it must still typecheck.
//
// The negative shapes (linear consumed by an earlier element and held live
// across a throwable sibling element) are pinned in
// tests/negative/linearity/e0540_throwable_sibling_{ctor_arg,record_field}_leak.nx.
import * as test_assert from "std:test/assert"

exception E(code: i64)

type Box = Box(val: i64)

type CtorPair = CtorPair(p: i64, q: i64)

type RecPair = { p: i64, q: i64 }

let free = fn (r: %Box) -> i64 do
  let Box(val: v) = r
  return v
end

let safe = fn () -> i64 do
  return 7
end

// (1a) Non-throwing sibling, CONSTRUCTOR: %b consumed by element1, a NON-throwing
// call as element2. No throw path abandons %b → accepted.
let ctor_nonthrowing_sibling = fn () -> i64 do
  let %b = Box(val: 3)
  let p = CtorPair(p: free(r: %b), q: safe())
  let CtorPair(p: a, q: c) = p
  return a + c
end

// (1b) Non-throwing sibling, RECORD LITERAL: %b consumed by field `p`, a
// NON-throwing call as field `q`. No throw path abandons %b → accepted.
let record_nonthrowing_sibling = fn () -> i64 do
  let %b = Box(val: 5)
  let r = { p: free(r: %b), q: safe() }
  return r.p + r.q
end

let thr = fn () -> i64 throws { E } do
  return 5
end

// (2) Freed-before-call: %b freed by an earlier STATEMENT, then a constructor
// takes a throwable-argument element. %b is already dead → accepted.
let ctor_freed_before = fn () -> i64 throws { E } do
  let %b = Box(val: 4)
  let v = free(r: %b)
  let p = CtorPair(p: v, q: thr())
  let CtorPair(p: a, q: c) = p
  return a + c
end

// `Exn` (open group) admits both the assert's AssertError and `ctor_freed_before`'s E.
let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: ctor_nonthrowing_sibling(),
    expected: 10,
    label: "non-throwing sibling constructor element: linear consumed earlier, no leak"
  )
  test_assert.assert_eq_i64(
    actual: record_nonthrowing_sibling(),
    expected: 12,
    label: "non-throwing sibling record field: linear consumed earlier, no leak"
  )
  test_assert.assert_eq_i64(
    actual: ctor_freed_before(),
    expected: 9,
    label: "freed-before-call by statement: linear dead at throwable ctor element, no leak"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
