// Positive test: a single legitimate consume of a linear binding must pass.
// Guard against false positives from the LinearReuse (nexus-6pff) fix.
import * as test_assert from "std:test/assert"

type Box = Box(val: i64)

let consume_box = fn (%b: Box) -> i64 do
  match b do
    | Box(val: v) -> return v
  end
end

let body = fn () -> unit throws { Exn } do
  let %b = Box(val: 42)
  let v = consume_box(%b)
  test_assert.assert_eq_i64(actual: v, expected: 42, label: "single consume passes")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
