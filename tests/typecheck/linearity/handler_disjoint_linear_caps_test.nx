// Positive: handler arms with ω-bound captures shared across arms pass
// T-Handler cross-arm uniqueness.
//
// T-Handler premise:
//   ∀ y ∈ dom(Γ_cap). |{ j ∈ J | y ∈ fv(e_j) }| = 1
//
// The uniqueness premise only constrains LINEAR (TyLinear / TyLazy / TyArray)
// captured bindings.  ω-bound (non-linear) bindings may be freely shared
// across arms without violating any single-use discipline.
//
// This test covers:
//   1. Handler with no shared outer-linear captures — accepted.
//   2. Handler arms that share an ω-bound (string) outer binding — accepted,
//      because the cross-arm check only fires on linear captures.

import * as test_assert from "std:test/assert"

cap Logger do
  fn info(msg: string) -> unit
  fn error(msg: string) -> unit
end

// Shared ω-bound string — not linear, may appear in any number of arms.
let prefix = "LOG"

let test_omega_shared_across_arms = fn () -> bool do
  // Both arms reference `prefix` (ω-bound).  The cross-arm uniqueness check
  // must not reject this: only linear captures are constrained.
  let _h = handler Logger do
    fn info(msg: string) -> unit do
      let _p = prefix
      return ()
    end
    fn error(msg: string) -> unit do
      let _p = prefix
      return ()
    end
  end
  return true
end

let test_no_outer_cap = fn () -> bool do
  // Handler arms that capture nothing from the outer env — vacuously disjoint.
  let _h = handler Logger do
    fn info(msg: string) -> unit do
      return ()
    end
    fn error(msg: string) -> unit do
      return ()
    end
  end
  return true
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_true(cond: test_omega_shared_across_arms(), label: "omega cross-arm: accepted")
  test_assert.assert_true(cond: test_no_outer_cap(), label: "no-outer-cap handler: accepted")
  return ()
end
