// Both-arm force/consumption of a linear or lazy binding where one or both
// branches diverge must be ACCEPTED.  These cases were previously rejected
// as false positives.
//
// Positive: typechecks-only, not run at runtime.

import * as test_assert from "std:test/assert"

type Box = Box(val: i64)
exception E

let consume = fn (%b: Box) -> unit do
  match b do | Box(val: _) -> return () end
end

// Both branches consume %h, one diverges (return), one does not.
// The join state correctly sees %h consumed on both paths.
let _both_consume_one_diverges = fn (%h: Box, cond: bool) -> unit throws { Exn } do
  if cond then
    consume(b: %h)
    return ()
  else
    consume(b: %h)
  end
end

// Both branches consume %h and diverge (return + throw).
// All-diverged case: both must consume, and they do.
let _both_consume_both_diverge = fn (%h: Box, cond: bool) -> unit throws { Exn } do
  if cond then
    consume(b: %h)
    return ()
  else
    consume(b: %h)
    throw E
  end
end

// Both force a lazy binding — should be accepted (nexus-v3xa.13: no
// double-force false positive in non-divergent branches).
let _lazy_both_force = fn () -> i64 do
  let @a = 42
  let result = if true then
    let x = @a
    x
  else
    let y = @a
    y
  end
  return result
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_bool(actual: true, expected: true, label: "divergent-arm linear tests typecheck")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
