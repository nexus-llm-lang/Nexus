// Positive companions to the Shape-A (bare `if`/`match` statement) and
// Shape-B (tail bare call under a non-linear return type) linear-leak
// rejections. These shapes must STILL compile and run cleanly — the tightened
// check must not over-reject:
//
//   1. let-bound `if` whose arms each PRODUCE a fresh linear: the result flows
//      OUT to bind %b, which is consumed. NOT a bare-statement discard.
//   2. let-bound `match` likewise.
//   3. mixed-arm `if` (one linear-consuming arm, one plain i64): the result is
//      a non-linear i64, nothing leaks.
//   4. tail bare producer in a function whose RETURN TYPE IS linear (`-> %B`):
//      the produced %B flows to the caller and is consumed — the Shape-B check
//      is gated on a NON-linear return type, so this must be accepted.
//
// The negative shapes are pinned in:
//   tests/negative/linearity/bare_if_stmt_linear_leak.nx
//   tests/negative/linearity/bare_match_stmt_linear_leak.nx
//   tests/negative/linearity/tail_bare_call_nonlinear_ret_leak.nx
import * as test_assert from "std:test/assert"

type B = B(n: i64)

let mk = fn () -> %B do return B(n: 1) end

let mk_n = fn (n: i64) -> %B do return B(n: n) end

let consume = fn (b: %B) -> i64 do
  let B(n: x) = b
  return x
end

// (1) let-bound if: each producing arm flows out to %b, then consumed.
let if_bound = fn (c: bool) -> i64 do
  let %b = if c then mk() else mk() end
  return consume(b: %b)
end

// (2) let-bound match: each producing case flows out to %b, then consumed.
let match_bound = fn (c: i64) -> i64 do
  let %b = match c do | 0 -> mk() | _ -> mk_n(n: 2) end
  return consume(b: %b)
end

// (3) mixed-arm if: result is a non-linear i64; no leak.
let mixed_arm = fn (c: bool) -> i64 do
  let r = if c then consume(b: mk()) else 0 end
  return r
end

// (4) tail bare producer under a LINEAR return type: %B flows to the caller.
let pass = fn () -> %B do return mk() end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: if_bound(c: true), expected: 1, label: "let-bound if producer consumed"
  )
  test_assert.assert_eq_i64(
    actual: match_bound(c: 0), expected: 1, label: "let-bound match producer consumed"
  )
  test_assert.assert_eq_i64(
    actual: mixed_arm(c: true), expected: 1, label: "mixed-arm if result non-linear"
  )
  test_assert.assert_eq_i64(
    actual: consume(b: pass()), expected: 1, label: "tail producer under linear return flows out"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
