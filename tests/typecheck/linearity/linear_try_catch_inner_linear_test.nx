// nexus-hjh2 positive: a linear binding created and fully consumed INSIDE the
// try body is not an outer linear; it is independent of the catch arm and
// must not affect what the catch arm can access.
import * as test_assert from "std:test/assert"

exception Boom(code: i64)
type Token = Token(id: i64)

let may_throw = fn () -> unit throws { Exn } do
  throw Boom(code: 1)
end

let main = fn () -> unit throws { Exn } do
  try
    let %inner = Token(id: 99)         // created inside try body
    match %inner do | Token(id: _) -> () end  // consumed inside try body
    may_throw()
  catch _ ->
    // %inner is an inner linear — does not affect catch arm at all
    ()
  end
  return ()
end
