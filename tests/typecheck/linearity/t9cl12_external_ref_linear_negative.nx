// Negative fixture for nexus-t9cl.12 — `let ~r = e` where `e`'s
// inferred type structurally carries a linear via record nesting.
//
// This fixture pins the named-typedef recursion path of
// `type_carries_linear`: a typedef `Holder` whose field type is
// itself a typedef-with-linear-field exercises the multi-step
// typedef expansion (depth > 1). Pre-fix the bare match at infer.nx
// missed everything below the outermost TyLinear/TyLazy.
//
// Spec type-system-formal.md §Linearity: "Linearity is entirely
// structural" — depth-bounded typedef recursion is the impl
// realization.
//
// Filename intentionally omits `_test` so `nexus test` does not
// pick it up.

type Inner = { v: %i64 }
type Holder = { inner: Inner, name: i64 }

let make_holder = fn () -> Holder do
  let %v = 5
  let i: Inner = { v: %v }
  let h: Holder = { inner: i, name: 0 }
  return h
end

let main = fn () -> unit do
  // Holder.inner.v is %i64 — structurally linear. The T-Let
  // SigilMutable check must descend through Holder → Inner → %i64.
  let ~r = make_holder()
  let _ = r
  return ()
end
