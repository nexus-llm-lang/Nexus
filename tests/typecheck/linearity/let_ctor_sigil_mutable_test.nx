// Regression for nexus-nahg — `~Ctor(...)` let pattern path. Companion
// to nahg_let_ctor_sigil_destructure_test.nx (`%`) and
// nahg_let_ctor_sigil_lazy_test.nx (`@`). Pre-fix, the `~` arm in
// parse_atom_pattern only handled `~ident` (PatVariable with
// SigilMutable); the `~Ctor` shape failed parse with UnexpectedToken
// on the Uident. nexus-nahg extends the arm to fall into
// try_qualified_ctor_pat with SigilMutable when a Uident is next.
//
// Note: at typecheck time, `~Ctor(...)` pattern just records the
// pattern's sigil — it doesn't constrain the rhs to be a mutable
// reference. The compatibility check (let-mut binding cannot hold
// linear values, T-Let premise μ = ~ ⟹ ¬linear) is enforced
// elsewhere (infer_let for the variable case, nexus-5pgr). This
// fixture only pins down the parse + typecheck pipeline.
import * as test_assert from "std:test/assert"

type Cell = MkCell(val: i64)

let make_cell = fn () -> Cell do
  return MkCell(val: 9)
end

let body = fn () -> unit throws { Exn } do
  let ~MkCell(val: v) = make_cell()
  test_assert.assert_eq_i64(actual: v, expected: 9, label: "let ~Ctor destructure")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
