// `@t` — force a thunk then discard the forced primitive result.
//
// This MUST be accepted: `@t` as a bare expression forces the lazy binding
// (the computation runs), and the resulting i64 is auto-droppable.
// P-Wild applies to the FORCED value type (i64, autoDrop = true), not to
// the thunk itself.

let compute = fn () -> i64 do
  return 99
end

let main = fn () -> unit do
  let @t = compute()
  @t
  return ()
end
