// Positive (nexus-xd8ko relaxed branch): a bare `if cond then throw E end`
// (no else) that abandons an outer-scope linear on the throw path is ADMITTED
// when the thrown variant `E` is NOT caught anywhere in the whole program.
//
// Rationale: an uncaught throw propagates to process exit, which reclaims all
// resources. The type system relaxes the divergent-arm leak check (inner-scope
// only) in this case. Mirrors the compiler's own
// `if cond then throw FatalError(...) end` terminate-and-exit pattern.
//
// There is NO user `try`/`catch` anywhere in this program, so
// caught_variants(Π) does not contain `Fatal` (nor the catch-all `Exn`
// sentinel) → relaxed. `main` deliberately neither declares `throws { Fatal }`
// nor catches it: the only path that reaches `throw` is `b == true`, which
// `main` never takes, so the program is well-typed while exercising the
// relaxed divergent-throw branch in `g`. If the fix regressed to
// always-strict, this would wrongly fail with E2007 on `%r`.

exception Fatal(msg: string)

type Res = Res(n: i64)

let free_res = fn (r: %Res) -> unit do
  let Res(n: _) = r
  return ()
end

let g = fn (r: %Res, b: bool) -> unit throws { Fatal } do
  // `%r` live; abandoned on the uncaught-throw path — admitted (relaxed)
  // because `Fatal` is in no catch arm anywhere in the program.
  if b then throw Fatal(msg: "terminate") end
  free_res(r: r)
  return ()
end

let main = fn () -> unit do
  let %r = Res(n: 1)
  g(r: %r, b: false)
  return ()
end
