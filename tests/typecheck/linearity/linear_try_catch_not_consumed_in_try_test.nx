// nexus-hjh2 positive: the try body does NOT consume the outer linear %tok;
// neither does the catch arm. %tok is consumed after the try/catch on the
// success path. This confirms a linear that the try body never touched
// remains fully available after the try/catch construct.
import * as test_assert from "std:test/assert"

exception Boom(code: i64)
type Handle = Handle(fd: i64)

let may_throw = fn () -> unit throws { Exn } do
  throw Boom(code: 1)
end

let main = fn () -> unit throws { Exn } do
  let %h = Handle(fd: 0)
  try
    may_throw()    // %h not touched in try body
  catch _ ->
    // %h available here (try body did not consume it)
    // both arms leave %h live for the arm-consistency check
    return ()
  end
  // success path: %h still live — consume it
  match %h do | Handle(fd: _) -> () end
  return ()
end
