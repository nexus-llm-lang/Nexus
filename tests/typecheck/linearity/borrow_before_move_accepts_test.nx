// Positive fixture — the legitimate borrow-then-move ordering survives the
// borrow-target liveness check.
//
// Spec (type-system-formal §T-App-BorrowLin): a borrow `&x` is admitted while
// the linear binding `x` is still LIVE. Borrowing BEFORE the consuming move
// is well-formed; only borrowing AFTER the move (use-after-move) is rejected.
// This fixture pins that a borrow followed by a later consume still
// typechecks, so the liveness fix did not over-reject the valid ordering.

import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

let body = fn () -> unit throws { Exn } do
  let %b = bb.empty()
  // Borrow while `b` is live — permitted; `b` stays consumable.
  let n = bb.length(buf: &b)
  // Consume `b` afterwards. The earlier borrow did not move it.
  bb.free(buf: %b)
  test_assert.assert_eq_i64(actual: n, expected: 0, label: "borrow before move keeps b live")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
