// Positive tests for nexus-ans4: enum bindings with direct linear fields
// are tracked as use-once when the RHS is a Ctor node, and properly pass
// linearity checking when the binding is consumed before scope end.
import * as test_assert from "std:test/assert"

type Handle = Handle(fd: i64)

type Wrapper =
  Box(inner: %Handle)
  | Empty

let make_handle = fn () -> %Handle do
  return Handle(fd: 42)
end

// Consume the wrapper by matching it.
let consume_wrapper = fn (w: Wrapper) -> i64 do
  match w do
    | Box(inner: h) ->
      let Handle(fd: n) = h
      return n
    | Empty -> return 0
  end
end

// Ctor RHS without type annotation: w is tracked as linear because the
// owning enum Wrapper has a variant with a direct %Handle field.
let ctor_rhs_consumed = fn () -> i64 do
  let h = make_handle()
  let w = Box(inner: h)
  return consume_wrapper(w)
end

// Variable alias: w2 inherits linear from w1; consuming w2 satisfies both.
let alias_consumed = fn () -> i64 do
  let h = make_handle()
  let %w1 = Box(inner: h)
  let w2 = w1
  return consume_wrapper(w: w2)
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: ctor_rhs_consumed(),
    expected: 42,
    label: "enum ctor rhs consumed passes"
  )
  test_assert.assert_eq_i64(
    actual: alias_consumed(),
    expected: 42,
    label: "enum alias consumed passes"
  )
  return ()
end
