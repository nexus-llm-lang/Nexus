// Positive fixture for nexus-lo64 — T-App B-set: multiple borrows of the
// same linear variable in one call are permitted (no consuming use present).
//
// Spec §T-App B-set: x ∈ B requires ALL uses of x in the arg list to be &x.
// When every use is a borrow (no consuming use), x ∈ B and the call is valid.
//
// This fixture verifies that f(p: &x, q: &x) is accepted when x is linear.

import * as bb from "std:bytebuffer"

let dual_borrow = fn (p: &bb.ByteBuffer, q: &bb.ByteBuffer) -> unit do
  p
  q
  return ()
end

let main = fn () -> unit do
  let %x = bb.empty()
  // Both args borrow x — no consuming use, so x ∈ B and the call is valid.
  dual_borrow(p: &x, q: &x)
  bb.free(buf: %x)
  return ()
end
