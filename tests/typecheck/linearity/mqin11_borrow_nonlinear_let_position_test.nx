// Positive fixture for nexus-mqin.11 — let-position borrow of a plain
// (`^ω`, unrestricted) binding must continue to typecheck.
//
// Spec (docs/spec/type-system-formal.md §T-Borrow): rejection applies
// only when the borrowed binding is q = 1 (linear/lazy). A bare
// `let x = 10` binding has q = ω, so `let r = &x` is well-formed and
// the borrow may live as long as `x` does without violating linearity.
import * as test_assert from "std:test/assert"

let peek = fn (x: &i64) -> i64 do
  match x do | n -> return n end
end

let body = fn () -> unit throws { Exn } do
  let x = 7
  // Plain `x` is ^ω. Let-rhs borrow is permitted; r aliases x for the
  // remainder of the scope, then both drop at end-of-scope.
  let r = &x
  let v = peek(x: r)
  test_assert.assert_eq_i64(actual: v, expected: 7, label: "let-position borrow of nonlinear binding")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
