// Positive: the param→result-slot linear propagation check must NOT
// over-track calls where the linear arg is fully consumed by the callee
// and no type-parameter survives into the return type.
//
//   1. Concrete consume: `take_bb(b: %Bb) -> i64` — pt has no TyVars and
//      rt is `i64`. The linear is consumed by the callee; the result is
//      a plain primitive that does not carry the linear payload.
//   2. ByteBuffer free: `bb.free(buf: %ByteBuffer) -> bool` — pt is
//      concrete linear, rt is bool. Linear consumed, no propagation.
//
// Together these guard against over-rejection of the take-style call
// shape — the linear is correctly consumed exactly once at the call
// site, with no second consume.
//
// Spec: type-system-formal §Linearity — linear(τ) propagates only
// where a type-parameter slot survives into the result type.

import * as bb from "std:bytebuffer"
import * as test_assert from "std:test/assert"

type Bb = Bb(x: i64)

let take_bb = fn (b: %Bb) -> i64 do
  match b do
    | Bb(x: v) -> return v
  end
end

let body = fn () -> unit throws { Exn } do
  let %b1 = Bb(x: 42)
  let n1 = take_bb(b: b1)
  test_assert.assert_eq_i64(
    actual: n1,
    expected: 42,
    label: "take-style concrete consume returns primitive"
  )
  let %buf = bb.empty()
  let _ok = bb.free(buf: %buf)
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
