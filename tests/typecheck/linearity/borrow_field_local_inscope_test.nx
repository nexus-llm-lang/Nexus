// Positive fixture (nexus-ymx7u, guard against over-reach): a record holding a
// borrow of a LOCAL linear, built via a borrow-laundering helper, must STILL
// typecheck when the record is USED IN SCOPE and NOT returned. This is exactly
// the compiler's own CompileCtx/CodegenCtx idiom: the ctx borrows a local
// linear (`%internal_func_map`), is threaded to callees, and is consumed (the
// owner freed) before the function returns — never escaping.
//
// The owner-locality heuristic must only fire when the tainted record ESCAPES
// via `return`; in-scope use is sound and must be accepted.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule". nexus-ymx7u
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

type Ctx = Ctx(b: &ByteBuffer)

// Laundering helper: takes the borrow in argument position (T-Borrow permits)
// and stores it in the returned Ctx.
let mk = fn (c: &ByteBuffer) -> Ctx do return Ctx(b: c) end

let peek = fn (cx: Ctx) -> i64 throws { Exn } do
  match cx do | Ctx(b: x) -> return bb.get_byte(buf: x, idx: 0) end
end

let driver = fn () -> i64 throws { Exn } do
  let %b0 = bb.empty()
  let %b1 = bb.push_byte(buf: %b0, byte: 42)
  // cx borrows the LOCAL linear %b1, but is consumed IN SCOPE (peek) and the
  // owner is freed here — cx never escapes the function.
  let cx = mk(c: &b1)
  // `peek` is throwable and borrows %b1 (live across the call), so free %b1 on
  // the throw path too — otherwise it leaks (E0540). The borrow still never
  // escapes the function, which is what this fixture pins.
  try
    let r = peek(cx: cx)
    bb.free(buf: %b1)
    return r
  catch e ->
    bb.free(buf: %b1)
    throw e
  end
end

let main = fn () -> unit throws { Exn } do
  let r = driver()
  test_assert.assert_eq_i64(
    actual: r,
    expected: 42,
    label: "in-scope record-stored borrow of a local linear is permitted (not an escape)"
  )
  return ()
end
