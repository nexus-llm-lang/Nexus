// nexus-hjh2 positive: ordinary try/catch with no linear bindings whatsoever.
// The linearity pass must accept this without any false positive.

exception Boom(code: i64)

let may_throw = fn () -> unit throws { Exn } do
  throw Boom(code: 1)
end

let main = fn () -> unit throws { Exn } do
  let x: i64 = 42
  try
    may_throw()
  catch _ ->
    ()
  end
  x
  return ()
end
