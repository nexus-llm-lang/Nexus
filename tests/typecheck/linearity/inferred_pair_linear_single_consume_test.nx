// Positive: `let p = Pair(fst: 0, snd: b)` where `b` is linear-bound is
// correctly typed as a linear binding, but a SINGLE-consume of `p` (one
// match arm whose body destructures and forwards the inner linear) must
// pass linearity. Guards against the inferred-Pair-of-linear fix
// over-rejecting consumed-once forms.
//
// Spec: type-system-formal §Linearity — linear(Pair<%T, U>) = true; a
// linear binding must be consumed EXACTLY once.

import * as test_assert from "std:test/assert"

type Bb = Bb(x: i64)
type Pair<A, B> = Pair(fst: A, snd: B)

let take_bb = fn (b: %Bb) -> i64 do
  match b do
    | Bb(x: v) -> return v
  end
end

let body = fn () -> unit throws { Exn } do
  let %b = Bb(x: 42)
  let p = Pair(fst: 7, snd: b)
  let v = match p do
    | Pair(fst: _, snd: b1) -> take_bb(b: b1)
  end
  test_assert.assert_eq_i64(actual: v, expected: 42, label: "single-consume inferred Pair<i64,%Bb>")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
