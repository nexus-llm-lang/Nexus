// Regression for nexus-2atf: the `%Ctor(...)` linear-ctor-literal sigil
// must propagate from AST through HIR `Ctor` / `PCtor` so the downstream
// pipeline (HIR validation, linearity, MIR lowering) keeps seeing the
// sigil. Pre-fix, AST `ExprConstructor` / `PatConstructor` /
// `PatConstructorWildcard` carried `sigil: Sigil` but the corresponding
// HIR `Ctor` / `PCtor` did not, so `convert_expr` / `convert_pattern`
// silently dropped the sigil and any downstream pass that wanted to key
// off "was this literally written with `%`?" had no signal.
//
// Post-fix, HIR `Ctor` and `PCtor` carry `sigil: Sigil`. Linearity of a
// `let %x = %Ctor(...)` binding is still enforced via the let's own
// sigil (set parser-side by `parse_let_without_type` for the
// `let x = %Ctor(...)` shape), not by wrapping the rhs type in
// `TyLinear`: doing so would break the existing `f(%Ctor(...))`
// fresh-ctor leniency. The sigil's role here is data-model
// completeness, not type-shape mutation.
//
// This positive fixture exercises every position the parser now sees a
// `%Ctor(...)`: as a rhs of a `let %x = …`, in a `match` arm pattern
// (`%MkR(id: i)`), and as a function-call argument. It also rides on
// the `let x = %Ctor(...)` parser-side sigil-bump path that already
// shipped a session ago. All three positions must typecheck cleanly and
// the program must run end-to-end.
import * as test_assert from "std:test/assert"

type Resource = MkR(id: i64)

// `%r: Resource` is a sigil-only linear param (the linearity pass keys
// off the param sigil regardless of the inner type).
let consume = fn (%r: Resource) -> i64 do
  match r do | MkR(id: i) -> return i end
end

let body = fn () -> unit throws { Exn } do
  // `%MkR(...)` literal in expression position passes the parser's
  // `TkPercent → TkUident → parse_constructor_expr` path; the HIR
  // `Ctor` now carries `sigil: SigilLinear` (was previously dropped).
  let v = consume(r: %MkR(id: 42))
  test_assert.assert_eq_i64(
    actual: v,
    expected: 42,
    label: "%Ctor(...) call-arg position typechecks and runs"
  )

  // `let x = %Ctor(...)` rides the parse_let_without_type sigil-bump:
  // `x` is linear and must be consumed once.
  let x = %MkR(id: 7)
  match x do | MkR(id: i) ->
    test_assert.assert_eq_i64(
      actual: i,
      expected: 7,
      label: "let x = %Ctor(...) binds x linearly and yields the field on match"
    )
  end

  // `%MkR(...)` arm pattern (`%Ctor` pattern) routes through the new
  // parse_atom_pattern `TkPercent → TkUident → try_qualified_ctor_pat`
  // path; HIR `PCtor` now carries `sigil: SigilLinear` too.
  let y = %MkR(id: 13)
  match y do
    | %MkR(id: i) ->
      test_assert.assert_eq_i64(
        actual: i,
        expected: 13,
        label: "%Ctor(...) arm pattern destructures a linear ctor"
      )
  end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
