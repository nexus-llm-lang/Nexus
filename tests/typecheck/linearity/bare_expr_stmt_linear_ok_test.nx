// Positive companion to the bare-expression-statement linear-leak rejection.
// These shapes must still compile cleanly:
//   1. a bare call that CONSUMES a linear and returns a non-linear value
//      (`consume(b: mk())` -> i64): the linear is taken, the result is not
//      linear, so nothing leaks.
//   2. a producing call in TAIL position of each if-branch
//      (`let %b = if c then mk() else mk() end`): each `mk()` is the branch
//      block's value and flows OUT to bind %b, which is then consumed. This
//      mirrors src/main.nx's `let %wasm_buf = if ... else merge_with_deps(...) end`,
//      the tail-position case the leak check must NOT flag.
// The negative shape (a non-tail bare `mk()` that drops the produced %B) is
// pinned in tests/negative/linearity/bare_expr_stmt_linear_leak.nx.
import * as test_assert from "std:test/assert"

type B = B(n: i64)

let mk = fn () -> %B do return B(n: 1) end

let consume = fn (b: %B) -> i64 do
  let B(n: x) = b
  return x
end

// (1) bare call consuming a freshly-produced linear; result is non-linear.
let consumes_ok = fn () -> unit do
  consume(b: mk())
  return ()
end

// (2) producing call in tail position of each if-branch: %b flows out, then
// is consumed.
let branch_tail = fn (c: bool) -> i64 do
  let %b = if c then mk() else mk() end
  return consume(b: %b)
end

let body = fn () -> unit throws { Exn } do
  consumes_ok()
  test_assert.assert_eq_i64(
    actual: branch_tail(c: true),
    expected: 1,
    label: "branch-tail producer result flows out and is consumed"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
