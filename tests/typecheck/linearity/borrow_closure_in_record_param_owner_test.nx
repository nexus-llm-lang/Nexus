// Positive fixture (guard against over-reach for the closure-in-aggregate-field
// borrow rule): a closure that captures a borrow of a NON-LINEAR `&`-PARAMETER
// may STILL be RETURNED inside a Record field. The borrowed owner's lifetime is
// the caller's concern, not this function's, so the captured borrow may legally
// outlive this frame — the closure-in-aggregate analog of the
// CompileCtx-as-parameter idiom. Only a captured borrow of a binding OWNED BY
// THIS FRAME (a local linear/non-linear `let`, or a `let`-alias of one) is
// rejected when it escapes via a returned aggregate field.
//
// The owner-locality check must NOT flag this: `p` is a parameter, not in this
// function's frame-owned set, so a closure forwarding a borrow of `p` stored in
// a returned record is sound.
//
// Companion negative test: borrow_escapes_closure_in_record_field.nx (a closure
// capturing a borrow of a frame-LOCAL inside a returned record is rejected
// with E2022).
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule".
import * as test_assert from "std:test/assert"

type W = { f: (() -> i64) }

// Returns a record whose closure field reads through the borrowed NON-linear
// parameter `p`. `p`'s owner outlives this frame, so the captured borrow may
// escape via the returned record — permitted.
let make_holder = fn (p: &i64) -> W do
  let g = fn () -> i64 do return p end
  return { f: g }
end

let main = fn () -> unit throws { Exn } do
  let n = 42
  let w = make_holder(p: &n)
  test_assert.assert_eq_i64(
    actual: w.f(),
    expected: 42,
    label: "returning a record whose closure field captures a borrow of a NON-linear parameter is permitted"
  )
  return ()
end
