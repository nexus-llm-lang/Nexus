// Positive fixture — the type-argument linearity recursion must NOT
// over-fire on NON-linear type arguments. A `Box<i64>` carries no linear
// payload, so:
//   - a wildcard `_` discard of `Box<i64>` is allowed (P-Wild only rejects
//     linear, non-auto-droppable scrutinees),
//   - a `ref(Box<i64>)` parameter passes wfRef (inner is not linear),
//   - a `Box<i64>` return type does not escape (no ref reachable).
//
// Spec (type-system-formal §Linearity / §wfRef / §"Gravity Rule"): the
// structural probes recurse into type arguments, but a non-linear arg leaves
// the predicates false, so all three forms remain well-formed.

import * as test_assert from "std:test/assert"

type Box<T> = Box(val: T)

let discard = fn (p: Box<i64>) -> unit do
  match p do
    | _ -> return ()
  end
end

let read_ref = fn (r: ref(Box<i64>)) -> unit do
  return ()
end

let make = fn () -> Box<i64> do
  return Box(val: 7)
end

let body = fn () -> unit throws { Exn } do
  discard(p: Box(val: 1))
  let b = make()
  let Box(val: v) = b
  test_assert.assert_eq_i64(actual: v, expected: 7, label: "non-linear type arg box round-trips")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
