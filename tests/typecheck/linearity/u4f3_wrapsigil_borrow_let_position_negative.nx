// Negative fixture for nexus-u4f3 — wrapSigil(%) makes let %b = Ctor(...)
// produce a linear binding, so T-Borrow at let-rhs position is rejected.
//
// Without the wrapSigil fix, Box(val: 42) would infer to TyUserDefined(Box)
// and `b` would be unrestricted — `let _r = &b` would silently type-check.
// After the fix, `b` has type TyLinear(TyUserDefined(Box)), so T-Borrow's
// precondition `x :^ω` fails and the let-rhs borrow is rejected (same rule
// that rejects `let _r = &b` when b comes from `bb.empty()`).
//
// Intentionally omits `_test` suffix so this compiles-fail fixture is not
// treated as a normal runner test.

type Box = Box(val: i64)

let main = fn () -> unit do
  let %b = Box(val: 42)
  // After wrapSigil fix: b : TyLinear(Box) — T-Borrow rejects this.
  let _r = &b
  let Box(val: _) = %b
  return ()
end
