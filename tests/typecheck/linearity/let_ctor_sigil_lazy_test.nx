// Regression for nexus-nahg — `@Ctor(...)` arm/let pattern path.
// The 2atf landing only enabled `%Uident` in parse_atom_pattern; the
// matching `~Uident`, `@Uident`, `&Uident` shapes were rejected with
// a parser UnexpectedToken on the Ctor name. nexus-nahg extends each
// of those sigil branches in parse_atom_pattern to recognise a
// trailing Uident and route through try_qualified_ctor_pat with the
// branch's sigil, mirroring the existing `%` arm.
//
// This positive fixture exercises the `@`-sigil case at let-position:
// `let @MkBox(val: v) = make_box()`. The pattern's `@` sigil sits on
// PatConstructor; the inner `v: i64` binds at plain i64.
import * as test_assert from "std:test/assert"

type Box = MkBox(val: i64)

let make_box = fn () -> Box do
  return MkBox(val: 21)
end

let body = fn () -> unit throws { Exn } do
  let @MkBox(val: v) = make_box()
  test_assert.assert_eq_i64(actual: v, expected: 21, label: "let @Ctor destructure")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
