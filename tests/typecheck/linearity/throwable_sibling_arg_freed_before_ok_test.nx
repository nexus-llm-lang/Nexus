// Positive companion to the sibling-argument throwable-leak rejections
// (tests/negative/linearity/e0540_throwable_sibling_arg_leak.nx and the
// indirect form). The fix that flags a linear consumed by an EARLIER sibling
// argument while a LATER sibling argument is throwable must NOT over-reach:
//
//   1. Non-throwing sibling: a linear passed as one argument and a plain
//      non-throwing value as the other has no throw path that abandons it, so
//      it must still typecheck.
//   2. Freed-before-call: a linear freed by an EARLIER STATEMENT (not by a
//      sibling argument) before a throwable-argument call is already dead at
//      the throwable point, so nothing leaks and it must still typecheck.
//
// The negative shapes (linear consumed by an earlier sibling argument and held
// live across a throwable sibling argument) are pinned in
// tests/negative/linearity/e0540_throwable_sibling_arg_*_leak.nx.
import * as test_assert from "std:test/assert"

exception E(code: i64)

type Box = Box(val: i64)

let free = fn (r: %Box) -> i64 do
  let Box(val: v) = r
  return v
end

let safe = fn () -> i64 do
  return 7
end

// (1) Non-throwing sibling: %b consumed as arg1, a NON-throwing call as arg2.
// No throw path abandons %b → accepted.
let consume2 = fn (b: %Box, n: i64) -> i64 do
  return free(r: %b) + n
end

let with_nonthrowing_sibling = fn () -> i64 do
  let %b = Box(val: 3)
  return consume2(b: %b, n: safe())
end

// (2) Freed-before-call: %b freed by an earlier STATEMENT, then a throwable
// call takes a throwable-argument. %b is already dead → accepted.
let thr = fn () -> i64 throws { E } do
  return 5
end

let sink = fn (n: i64) -> i64 do
  return n
end

let with_freed_before = fn () -> i64 throws { E } do
  let %b = Box(val: 4)
  let v = free(r: %b)
  let r = sink(n: thr())
  return v + r
end

// `Exn` (open group) admits both the assert's AssertError and `with_freed_before`'s E.
let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: with_nonthrowing_sibling(),
    expected: 10,
    label: "non-throwing sibling argument: linear consumed earlier, no leak"
  )
  test_assert.assert_eq_i64(
    actual: with_freed_before(),
    expected: 9,
    label: "freed-before-call by statement: linear dead at throwable arg, no leak"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
