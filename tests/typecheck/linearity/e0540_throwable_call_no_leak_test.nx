// Positive control for E0540: the guard must
// ACCEPT a linear that is NOT live across a throwable call. Two safe shapes:
//
//  1. The linear is consumed *before* the throwable call (its slot is empty
//     when the call could raise).
//  2. The throwable call sits inside a try/catch and the linear is consumed
//     after the try/catch on a path both arms agree on.
//
// Companion to the negative tests/negative/linearity/e0540_throwable_call_leak.nx
// (which holds the linear live across the call → E0540).
import * as test_assert from "std:test/assert"

exception Boom(code: i64)

type Handle = Handle(fd: i64)

let might_throw = fn () -> unit throws { Exn } do
  throw Boom(code: 1)
end

let close = fn (h: %Handle) -> i64 do
  let r = match h do | Handle(fd: i) -> i end
  return r
end

// Shape 1: consume %h before the throwable call.
let consume_before_call = fn () -> i64 do
  let %h = Handle(fd: 7)
  let r = close(h: %h)
  try
    might_throw()
  catch _ -> ()
  end
  return r
end

// Shape 2: throwable call inside try/catch; %h consumed after, on a set both
// arms agree on (neither arm consumes %h).
let consume_after_try = fn () -> i64 do
  let %h = Handle(fd: 9)
  try
    might_throw()
  catch _ -> ()
  end
  return close(h: %h)
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: consume_before_call(),
    expected: 7,
    label: "consume before throwable call"
  )
  test_assert.assert_eq_i64(
    actual: consume_after_try(),
    expected: 9,
    label: "consume after try/catch"
  )
  return ()
end
