// Positive fixture — a handler bound to `let k` whose arm introduces a
// same-named `with @k` continuation binder typechecks and runs.
//
// Spec (type-system-formal §with-continuation arms, :1541 + force-once
// obligation :1556): the `@k` continuation binder is ARM-LOCAL. It must not
// collide with the handler's own top-level `let k` binding. The arm body here
// forces `@k` on its single exit path, so the force-once obligation is met.
//
// Pre-fix, the HIR conversion renamed the arm-body `@k` reference to the
// top-level binding's qualified name (`let k`'s rename entry leaked into the
// arm body), so the IR force-once tracker (check_handler_arm_konts) counted
// zero references to the bare cont_binder `k` and spuriously raised E2005
// "lazy binding @k is never forced". The fix drops the cont_binder from the
// rename map while converting the arm body, keeping `@k` bare and in sync
// with the recorded cont_binder.

import { Console } from "std:stdio"
import * as stdio from "std:stdio"

cap Ev do fn emit() -> unit end

// Handler bound to `let k` — the SAME name as its arm's `@k` binder.
let k = handler Ev require { Console } do
  fn emit() -> unit with @k do
    Console.println(val: "in-arm")
    @k
  end
end

let drive = fn () -> unit require { Ev, Console } do Ev.emit() end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do inject k do drive() end end
end
