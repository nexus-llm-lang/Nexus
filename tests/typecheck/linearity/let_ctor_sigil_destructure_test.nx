// Regression for nexus-nahg — parser-side `let %Ctor(f: x) = e`
// destructure. Pre-fix, `parse_let_stmt` only recognised
// `let Ctor(...) = e` (no sigil) or `let %x = e` (sigil on a bare
// variable). The shape `let %Ctor(...) = e` — sigil on a constructor
// pattern — fell off the parser cliff because `parse_sigil` consumed
// the `%` and then `expect_ident` rejected the `TkUident` Ctor name.
//
// Post-fix, `parse_let_stmt` peeks `SIGIL + Uident + (` and routes
// through `parse_pattern`, which already knows how to build a
// `PatConstructor` with `sigil`. The HIR/MIR/typecheck plumbing for
// the `sigil` field landed in nexus-2atf (commit aa0663a); the
// peeling for `let %Ctor(...) = %rhs` rides on the existing
// `bind_constructor_pattern` modality-strip (TyLinear/TyLazy/
// TyRef/TyBorrow → inner) introduced by the record-pattern fix in
// nexus-lyh6.
//
// This positive fixture exercises a `%`-sigil constructor pattern on
// the LHS of a let, destructuring a linear ctor returned from a
// builder fn. The inner field `i: i64` must bind unwrapped (i.e. not
// `%i64`) — i64 is plain, not linear, so any over-eager wrapping would
// fail the assertion call.
import * as test_assert from "std:test/assert"

type Pair = MkPair(fst: i64, snd: i64)

let make_pair = fn () -> Pair do
  return %MkPair(fst: 3, snd: 4)
end

let body = fn () -> unit throws { Exn } do
  // The let-pattern's `%` matches the ctor literal's `%` sigil.
  // Pre-fix this raised a parser UnexpectedToken on `MkPair`.
  let %MkPair(fst: a, snd: b) = make_pair()
  test_assert.assert_eq_i64(actual: a, expected: 3, label: "let %Ctor destructure: fst field")
  test_assert.assert_eq_i64(actual: b, expected: 4, label: "let %Ctor destructure: snd field")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
