// Positive companion to the indirect-throwable-call linear-leak rejections
// (tests/negative/linearity/e0540_throwable_closure_call_leak.nx and friends).
// An INDIRECT throwable call must NOT be flagged when no linear is live across
// it. These shapes must still compile and run cleanly:
//   1. local let-bound CLOSURE call where the linear is consumed BEFORE the
//      throwable closure call (`close(h: %h)` then `mt()`): nothing live leaks.
//   2. function-typed PARAMETER call where the linear is consumed before the
//      throwable param call.
// The negative shapes (linear live ACROSS the indirect throwable call) are
// pinned in tests/negative/linearity/e0540_throwable_*_leak.nx.
import * as test_assert from "std:test/assert"

type Handle = Handle(fd: i64)

let close = fn (h: %Handle) -> i64 do
  let r = match h do | Handle(fd: i) -> i end
  return r
end

// (1) local closure callee: %h freed before the throwable call → no leak.
let with_closure = fn () -> i64 throws { Exn } do
  let mt = fn () -> i64 throws { Exn } do return 7 end
  let %h = Handle(fd: 3)
  let c = close(h: %h)
  let r = mt()
  return c + r
end

// (2) function-typed param callee: %h freed before the throwable param call.
let with_param = fn (mt: () -> i64 throws { Exn }) -> i64 throws { Exn } do
  let %h = Handle(fd: 4)
  let c = close(h: %h)
  let r = mt()
  return c + r
end

let supplier = fn () -> i64 throws { Exn } do return 5 end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: with_closure(),
    expected: 10,
    label: "closure callee: linear freed before throwable call, no leak"
  )
  test_assert.assert_eq_i64(
    actual: with_param(mt: supplier),
    expected: 9,
    label: "param callee: linear freed before throwable call, no leak"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
