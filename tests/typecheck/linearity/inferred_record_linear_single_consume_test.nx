// Positive: `let r = { val: b }` where `b` is linear-bound is correctly
// typed as a linear binding, but a SINGLE-consume of `r` (one destructure
// that forwards the inner linear) must pass linearity. Guards against
// the inferred-Record-of-linear fix over-rejecting consumed-once forms.
//
// Spec: type-system-formal §Linearity — linear({ val: %T, .. }) = true; a
// linear binding must be consumed EXACTLY once.

import * as test_assert from "std:test/assert"

type Bb = Bb(x: i64)
type Box<T> = { val: T }

let take_bb = fn (b: %Bb) -> i64 do
  match b do
    | Bb(x: v) -> return v
  end
end

let body = fn () -> unit throws { Exn } do
  let %b = Bb(x: 42)
  let r = { val: b }
  let { val: b1 } = r
  let v = take_bb(b: b1)
  test_assert.assert_eq_i64(actual: v, expected: 42, label: "single-consume inferred Box{val:%Bb}")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
