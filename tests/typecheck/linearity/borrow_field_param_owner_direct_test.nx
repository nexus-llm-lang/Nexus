// Positive fixture (nexus-quuuq, guard against over-reach): a record holding a
// borrow of a NON-LINEAR PARAMETER, built by DIRECT construction, may STILL be
// RETURNED. This is the CompileCtx-as-parameter shape: the borrowed owner's
// lifetime is the caller's concern, so the borrow may legally outlive this
// frame. Only borrows of a LOCAL owner (which THIS function's frame owns) are
// rejected when they escape.
//
// `wrap` forwards its `&i64` parameter `p` (a non-local owner) directly into
// the returned `Ctx` record. The owner-locality heuristic must NOT flag this:
// `p` is a parameter, not a local `let` binding.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule". nexus-quuuq
import * as test_assert from "std:test/assert"

type Ctx = { b: &i64 }

// Returns a Ctx borrowing the NON-linear parameter `p` — permitted (param
// owner outlives this frame).
let wrap = fn (p: &i64) -> Ctx do
  let cx: Ctx = { b: p }
  return cx
end

let read = fn (cx: Ctx) -> i64 do
  match cx do | { b: x } -> return x end
end

let main = fn () -> unit throws { Exn } do
  let n = 99
  let cx = wrap(p: &n)
  test_assert.assert_eq_i64(
    actual: read(cx: cx),
    expected: 99,
    label: "returning a record holding a borrow of a NON-linear parameter is permitted"
  )
  return ()
end
