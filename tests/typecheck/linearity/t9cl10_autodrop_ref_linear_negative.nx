// Documentation fixture for nexus-t9cl.10 — `is_auto_droppable` impl
// remains the source of truth for the autoDrop spec.
//
// Per the t9cl.10 audit (P2 docs-sync followup), `is_auto_droppable`
// in src/typecheck/linearity.nx correctly recurses through
// `%`/`&`/`~` wrappers and intentionally treats `@T` (TyLazy) and
// arrays as NON-auto-droppable. The spec was brought into line via
// t9cl.2/.3; this fixture documents the invariant and pins the
// nontrivial case: a `let _ = %x` discard on a `%i64` (the
// innermost-non-modality type `i64` is auto-droppable, so the
// discard typechecks).
//
// Filename intentionally omits `_test` so `nexus test` does not pick
// it up — it is documentation-grade and pairs with the impl comment
// in src/typecheck/linearity.nx::is_auto_droppable.
let main = fn () -> unit do
  // %i64 strips `%` → i64, which is auto-droppable.
  // is_auto_droppable(TyLinear(TyI64)) recurses to is_auto_droppable(TyI64) = true.
  // `let _ = %x` (nexus-x5ww) does not throw LinearUnused for
  // auto-droppable inner types.
  let %x = 7
  %x
  return ()
end
