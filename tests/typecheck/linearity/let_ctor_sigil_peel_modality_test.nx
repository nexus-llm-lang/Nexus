// Regression for nexus-nahg — modality-peel for `let %Ctor(...) = e`.
// Mirrors the record-pattern peel in nexus-lyh6 (commit 1246a93):
// `bind_constructor_pattern` already strips a single TyLinear/TyLazy/
// TyRef/TyBorrow wrapper from the target type before unifying against
// the constructor's enum, so a `let %Ctor(f: x) = e` where `e: %T`
// binds the inner field at the un-wrapped enum-field type.
//
// This fixture exercises that peel via the new parser path: the
// builder returns a bare `Resource` (not `%Resource`), but the
// constructor literal carries `%` and the inner field is plain i64.
// The pattern binding `i` must therefore see plain `i64` — any
// over-eager wrapping (e.g. binding `i` at `%i64`) would surface as a
// linearity error on the bare `i` read at the assertion site.
import * as test_assert from "std:test/assert"

type Resource = MkR(id: i64, tag: i64)

let make_res = fn () -> Resource do
  return %MkR(id: 99, tag: 5)
end

let body = fn () -> unit throws { Exn } do
  // Inner `id` / `tag` bind at i64 (plain), not %i64.
  let %MkR(id: i, tag: t) = make_res()
  let sum = i + t
  test_assert.assert_eq_i64(
    actual: sum,
    expected: 104,
    label: "let %Ctor inner fields bind at unwrapped type"
  )
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
