// Regression test for linear %type in higher-order function (HOF) position.
//
// Verifies that a function-typed parameter whose signature carries a linear
// `%` type in argument and/or return position is fully supported through
// parse, typecheck, linearity pass, and codegen.
//
// Key patterns exercised:
//   1. Basic linear callback: (b: %T) -> %T
//   2. Linear callback with extra non-linear args: (b: %T, n: i64) -> %T
//   3. Linear callback invoked multiple times sequentially
//   4. Named top-level function used as linear HOF argument
//   5. Mutual-recursion via callback injection (the codegen SCC pattern)
//   6. Linearity enforcement: double-use of a linear binding caught through a HOF

import * as test_assert from "std:test/assert"

type Buf = Buf(data: string)
type Node = Leaf(val: i64) | Inner(left: Node, right: Node)

// (1) Basic linear callback
let apply = fn (f: (b: %Buf) -> %Buf, %b: %Buf) -> %Buf do
  return f(b: %b)
end

let append_x = fn (%b: %Buf) -> %Buf do
  match %b do | Buf(data: s) -> return Buf(data: s ++ "X") end
end

// (2) Linear callback with extra non-linear arg
let apply_with_n = fn (f: (b: %Buf, n: i64) -> %Buf, %b: %Buf, n: i64) -> %Buf do
  return f(b: %b, n: n)
end

let mark_n = fn (%b: %Buf, n: i64) -> %Buf do
  match %b do | Buf(data: s) -> return Buf(data: s ++ "N") end
end

// (3) Linear callback invoked multiple times sequentially (different callee arg each time)
let apply_twice = fn (f: (b: %Buf) -> %Buf, %b: %Buf) -> %Buf do
  let %b2 = f(b: %b)
  let %b3 = f(b: %b2)
  return %b3
end

// (5) Mutual-recursion via callback: exactly the emit_stmt/emit_expr SCC shape
let process_node = fn (rec_cb: (buf: %Buf, node: Node) -> %Buf, %buf: %Buf, node: Node) -> %Buf do
  match node do
    | Leaf(val: _) ->
      match %buf do | Buf(data: s) -> return Buf(data: s ++ "L") end
    | Inner(left: l, right: r) ->
      let %b2 = rec_cb(buf: %buf, node: l)
      let %b3 = rec_cb(buf: %b2, node: r)
      match %b3 do | Buf(data: s) -> return Buf(data: s ++ "I") end
  end
end

let process_node_impl = fn (%buf: %Buf, node: Node) -> %Buf do
  return process_node(rec_cb: process_node_impl, buf: %buf, node: node)
end

let main = fn () -> unit throws { Exn } do
  // (1) basic linear callback
  let %buf1 = Buf(data: "")
  let %r1 = apply(f: append_x, b: %buf1)
  let v1 = match %r1 do | Buf(data: s) -> s end
  test_assert.assert_eq_string(actual: v1, expected: "X", label: "basic linear callback")

  // (2) linear callback with extra arg
  let %buf2 = Buf(data: "")
  let %r2 = apply_with_n(f: mark_n, b: %buf2, n: 7)
  let v2 = match %r2 do | Buf(data: s) -> s end
  test_assert.assert_eq_string(actual: v2, expected: "N", label: "linear callback with extra arg")

  // (3) callback invoked twice sequentially
  let %buf3 = Buf(data: "")
  let %r3 = apply_twice(f: append_x, b: %buf3)
  let v3 = match %r3 do | Buf(data: s) -> s end
  test_assert.assert_eq_string(actual: v3, expected: "XX", label: "callback twice sequential")

  // (5) mutual-recursion via callback
  let %buf5 = Buf(data: "")
  let %r5 = process_node_impl(buf: %buf5, node: Inner(left: Leaf(val: 1), right: Leaf(val: 2)))
  let v5 = match %r5 do | Buf(data: s) -> s end
  test_assert.assert_eq_string(actual: v5, expected: "LLI", label: "mutual-recursion via callback")

  return ()
end
