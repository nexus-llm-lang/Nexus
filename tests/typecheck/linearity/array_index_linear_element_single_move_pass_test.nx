/**
 * Positive companion to the linear-element array move-out rejection: moving a
 * single linear element out of a linear-element array via `a[i]` (which now
 * registers the array's use-once obligation) must STILL pass when the element
 * is consumed exactly once and the array is not re-read.
 *
 * Guards against the move-out fix over-rejecting legitimate single reads.
 */
import * as test_assert from "std:test/assert"

type Box = Box(val: i64)

let unwrap = fn (b: %Box) -> i64 do
  match b do
    | Box(val: v) -> return v
  end
end

let body = fn () -> unit throws { Exn } do
  let %b1 = Box(val: 42)
  let a = [| b1 |]
  let e0 = a[0]
  test_assert.assert_eq_i64(
    actual: unwrap(b: e0),
    expected: 42,
    label: "single linear-element move-out passes"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
