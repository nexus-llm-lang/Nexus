// Port of bootstrap/tests/typecheck/inference.rs::
// if_else_expr_infers_i64, if_else_expr_infers_string,
// if_else_expr_as_return_value, if_else_expr_nested.
//
// `if t then e1 else e2 end` is an expression whose type unifies the
// branch tails. The annotation drives the unifier.
import * as test_assert from "std:test/assert"

let max = fn (a: i64, b: i64) -> i64 do
  return if a > b then a else b end
end

let classify = fn (x: i64) -> i64 do
  return if x > 0 then if x > 100 then 2 else 1 end else 0 end
end

let body = fn () -> unit throws { Exn } do
  let x: i64 = if true then 1 else 2 end
  test_assert.assert_eq_i64(actual: x, expected: 1, label: "if-expr i64")

  let s: string = if false then "yes" else "no" end
  test_assert.assert_eq_string(actual: s, expected: "no", label: "if-expr string")

  test_assert.assert_eq_i64(actual: max(a: 1, b: 2), expected: 2, label: "if-expr in return")
  test_assert.assert_eq_i64(actual: max(a: 5, b: 3), expected: 5, label: "if-expr in return (else)")

  test_assert.assert_eq_i64(actual: classify(x: 5), expected: 1, label: "nested if-expr small")
  test_assert.assert_eq_i64(actual: classify(x: 500), expected: 2, label: "nested if-expr large")
  test_assert.assert_eq_i64(actual: classify(x: 0 - 1), expected: 0, label: "nested if-expr neg")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
