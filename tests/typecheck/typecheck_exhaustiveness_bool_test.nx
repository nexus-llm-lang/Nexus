// Port of bootstrap/tests/typecheck/exhaustiveness.rs::test_bool_exhaustive.
// Bool is finite at the type level — `true | false` is exhaustive without
// a wildcard.
import * as test_assert from "std:test/assert"

let label = fn (b: bool) -> i64 do
  match b do
    | true -> return 1
    | false -> return 0
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: label(b: true), expected: 1, label: "bool true")
  test_assert.assert_eq_i64(actual: label(b: false), expected: 0, label: "bool false")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
