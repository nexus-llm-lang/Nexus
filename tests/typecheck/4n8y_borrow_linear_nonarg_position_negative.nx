// Negative fixture for nexus-4n8y — T-Borrow `x :^ω` enforcement at
// non-argument, non-let-rhs positions.
//
// Spec (docs/spec/type-system-formal.md §T-Borrow):
//   x :^ω ∀ᾱ.τ ∈ Γ    τ' = inst(∀ᾱ.τ)    σ = stripBorrow(τ')
//   ─────────────────────────────────────────────────────────
//   Γ; ρ_q ⊢_e &x : &σ ! { }
//
// "Only unrestricted bindings can be borrowed." A linear (`%`) binding is
// q = 1. T-Borrow must reject `&x` when x :^1 at ANY expression position,
// not only let-rhs (nexus-mqin.11) and argument position (T-App-BorrowLin
// carve-out). Array-element position is one such non-carve-out position:
// `[&b]` creates a freshly allocated borrow with no discharge mechanism,
// violating the ownership model.
//
// Filename omits `_test` so `nexus test` does not pick it up as a runner
// test — this is a compile-fail fixture.
// expect-fail: E2001
// expect-msg: cannot borrow
// expect-msg: linear
import * as bb from "std:bytebuffer"

let wrap = fn () -> unit do
  let %b = bb.empty()
  // Array-element position: &b borrows a linear binding outside any
  // discharge context (not a call argument, not a let-rhs with `infer_let`
  // pre-check). infer_borrow's x:^ω premise must reject this.
  let _arr: [&bb.ByteBuffer] = [&b]
  bb.free(buf: %b)
  return ()
end

let main = fn () -> unit do
  wrap()
  return ()
end
