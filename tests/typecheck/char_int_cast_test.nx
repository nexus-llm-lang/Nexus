/**
 * Positive control for the sound char->int conversion path. A `char` is a
 * 32-bit code point; widening it to an integer is sound, but the type
 * checker keeps strict discipline (`cast.i64_of` accepts only `i32`). The
 * char-accepting widening goes through `cast.i64_of_char` / the canonical
 * `char.ord`, and the `std:str` helpers that consume a `char` (`from_char`,
 * `find_byte`) route through that same primitive. All of these must
 * type-check AND round-trip their runtime values.
 *
 * The negative direction (passing a bare `char` to `cast.i64_of`, which
 * declares an `i32` parameter, must be REJECTED) is covered by
 * tests/negative/typecheck/char_to_i64_cast_rejected.nx.
 */
import * as test_assert from "std:test/assert"
import * as char from "std:char"
import * as cast from "std:runtime/cast"
import * as str from "std:str"

/** `char.ord` widens a char to its i64 codepoint via `cast.i64_of_char`. */
let ord_path = fn () -> i64 do
  return char.ord(c: 'A')
end

/** The primitive `cast.i64_of_char` accepts a `char` directly. */
let prim_path = fn () -> i64 do
  return cast.i64_of_char(x: '0')
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: ord_path(), expected: 65, label: "char.ord('A')")
  test_assert.assert_eq_i64(actual: prim_path(), expected: 48, label: "cast.i64_of_char('0')")
  test_assert.assert_eq_i64(actual: char.ord(c: 'z'), expected: 122, label: "char.ord('z')")
  test_assert.assert_eq_string(actual: str.from_char(c: 'Q'), expected: "Q", label: "str.from_char('Q')")
  test_assert.assert_eq_i64(actual: str.find_byte(s: "abc", start: 0, ch: 'b'), expected: 1, label: "str.find_byte 'b'")
  test_assert.assert_eq_i64(actual: str.find_byte(s: "abc", start: 0, ch: 'x'), expected: 0 - 1, label: "str.find_byte miss")
  return ()
end
