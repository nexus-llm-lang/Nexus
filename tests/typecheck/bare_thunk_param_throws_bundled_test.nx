/**
 * Positive control for the bare-`@T` thunk-parameter throws-bundling fix.
 *
 * A bare shorthand thunk parameter `@i64` carries an OPEN `__implicit` deferred
 * throws row, so it is effect-polymorphic: it can BUNDLE the deferred throws of
 * whatever thunk is passed. The leak-fix (flatten_throw_row in
 * src/typecheck/infer/control_flow.nx) makes those bundled exceptions visible to
 * the call-admission check so they are surfaced into the caller — it must NOT
 * over-reject the legitimate case where the caller declares a row that covers
 * the bundled exceptions.
 *
 * `myforce` has a single bare `@i64` param and forces it (`return @a`),
 * declaring `throws { E }`. Two callers exercise the bundling:
 *   - a non-throwing thunk passed through the bare param, accepted under the
 *     matching `{ E }` row, and its forced value round-trips at runtime;
 *   - a throwing thunk whose deferred `{ E }` is correctly SURFACED through the
 *     forced bare param (observed via assert_raises).
 *
 * The negative direction (the bundled exception escaping a `throws {}` caller)
 * is covered by tests/negative/typecheck/bare_thunk_param_throws_row_leak.nx.
 */
import * as test_assert from "std:test/assert"

exception E(msg: string)

/** Bare `@i64` thunk param, forced; bundles the passed thunk's `{ E }`. */
let myforce = fn (a: @i64) -> i64 throws { E } do
  return @a
end

let thrower = fn () -> i64 throws { E } do
  throw E(msg: "boom")
end

/** Throwing thunk through the bare param: the bundled `{ E }` surfaces here. */
let use_throwing = fn () -> bool throws { Exn } do
  let @t = thrower()
  let v = myforce(a: t)
  return v == 0
end

let pure_thunk = fn () -> i64 throws { E } do
  return 42
end

/** Non-throwing thunk through the bare param, caller declares matching `{ E }`. */
let use_pure = fn () -> i64 throws { E } do
  let @t = pure_thunk()
  return myforce(a: t)
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: use_pure(),
    expected: 42,
    label: "non-throwing thunk via bare @i64 param accepted under matching { E }"
  )
  test_assert.assert_raises(
    label: "throwing thunk surfaces E through forced bare @i64 param",
    body: use_throwing
  )
  return ()
end
