// Port of bootstrap/tests/typecheck/inference.rs::
// test_linear_capture_makes_lambda_linear_and_single_use, and
// bootstrap/tests/typecheck/linear.rs::
// test_adt_with_linear_arg_consumed_once_passes.
//
// Capturing a linear binding makes the lambda linear (callable once);
// wrapping a linear payload in an ADT and then matching it consumes it.
//
// The Rust harness only typechecks; here we additionally exercise the
// ADT path at runtime. The linear-capture-lambda path is held at the
// typecheck layer (declared as an unused top-level let) because the
// self-host codegen has a stack-mismatch bug when a closure that
// captures a linear primitive is invoked through `let y = f()`. The
// declaration alone forces typecheck of the linear-capture rule.
import * as test_assert from "std:test/assert"

type Wrapper<T> = Wrap(val: T)

// Typecheck-only: declares a linear-capture closure shape. The
// `mk_capture` factory takes %x, returns a closure that consumes it
// via match-discard, and itself returns a constant. The returned
// closure is itself linear because it captures %x. Never called.
let _mk_capture = fn (%x: %i64) -> %() -> i64 do
  return fn () -> i64 do
    match %x do | _ -> () end
    return 1
  end
end

let body = fn () -> unit throws { Exn } do
  // ADT promoted to linear via a linear payload, consumed once via
  // nested match.
  let %r = { id: 1 }
  let w = Wrap(val: %r)
  let id_val = match w do
    | Wrap(val: inner) ->
        match inner do | { id: i } -> i end
  end
  test_assert.assert_eq_i64(actual: id_val, expected: 1, label: "ADT-with-linear consumed once")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
