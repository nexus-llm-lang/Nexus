import * as test_assert from "std:test/assert"

type Tree = Leaf(value: i64)
  | Branch(left: Tree, right: Tree)

type Expr = Lit(n: i64)
  | Neg(inner: Expr)
  | Add(a: Expr, b: Expr)

type Rose = Rose(label: i64, kids: [ Rose ])

let sum_tree = fn (t: Tree) -> i64 do
  match t do
    | Leaf(value: v) -> return v
    | Branch(left: l, right: r) -> return sum_tree(t: l) + sum_tree(t: r)
  end
end

let eval_expr = fn (e: Expr) -> i64 do
  match e do
    | Lit(n: k) -> return k
    | Neg(inner: x) -> return 0 - eval_expr(e: x)
    | Add(a: x, b: y) -> return eval_expr(e: x) + eval_expr(e: y)
  end
end

let sum_rose = fn (r: Rose) -> i64 do
  match r do
    | Rose(label: lb, kids: ks) -> return lb + sum_rose_list(rs: ks)
  end
end

let sum_rose_list = fn (rs: [ Rose ]) -> i64 do
  match rs do
    | [] -> return 0
    | h :: t -> return sum_rose(r: h) + sum_rose_list(rs: t)
  end
end

let build_deep = fn (n: i64, acc: Tree) -> Tree do
  if n <= 0 then return acc end
  return build_deep(n: n - 1, acc: Branch(left: acc, right: Leaf(value: n)))
end

let main = fn () -> unit throws { Exn } do
  let t = Branch(left: Branch(left: Leaf(value: 1), right: Leaf(value: 2)), right: Leaf(value: 3))
  test_assert.assert_eq_i64(actual: sum_tree(t: t), expected: 6, label: "recursive-ctor-tree")

  let e = Add(a: Neg(inner: Lit(n: 4)), b: Add(a: Lit(n: 10), b: Lit(n: 5)))
  test_assert.assert_eq_i64(actual: eval_expr(e: e), expected: 11, label: "recursive-ctor-expr")

  let r = Rose(label: 1, kids: [ Rose(label: 2, kids: []), Rose(label: 3, kids: [ Rose(label: 4, kids: []) ]) ])
  test_assert.assert_eq_i64(actual: sum_rose(r: r), expected: 10, label: "recursive-ctor-rose-through-list")

  let deep = build_deep(n: 200, acc: Leaf(value: 0))
  test_assert.assert_eq_i64(actual: sum_tree(t: deep), expected: 20100, label: "recursive-ctor-deep-nesting")

  return ()
end
