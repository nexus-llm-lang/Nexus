// Regression for nexus-hawq: infer_borrow must peel TyRef per spec
// stripBorrow. Borrowing a `~r` binding (mutable ref cell) yields a
// `&i64` of the cell's contents — not a nonsensical `&(~i64)` borrow.
//
// Pre-fix this body fails typechecking with
//   'arg x: expected ref type'
// because the impl unifies the expected `&i64` against the produced
// `&(~i64)`. Post-fix it typechecks and runs.
import * as test_assert from "std:test/assert"

let take_borrow = fn (x: &i64) -> i64 do
  let _ = x
  return 1
end

let body = fn () -> unit throws { Exn } do
  let ~r = 5
  let result = take_borrow(x: &r)
  test_assert.assert_eq_i64(actual: result, expected: 1, label: "&r on ~r typechecks")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
