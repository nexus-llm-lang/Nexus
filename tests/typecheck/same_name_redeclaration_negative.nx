// nexus-5y83: Negative fixture. Same-name top-level `let` redeclaration
// must be rejected at typecheck time.
//
// Background: previously, two top-level `let f = fn (...) ... end` bindings
// in the same file silently overwrote each other in the type env, while a
// downstream lir_opt pass mis-resolved `return_call` to itself and corrupted
// UNRELATED functions' return atoms with `default_atom(typ)`. The bug was
// discovered while investigating env.nx wrappers (nexus-bh9o) and is fixed
// by typecheck-time rejection (DuplicateTopLevelBinding / E2010).
//
// Kept out of `nexus test` discovery by the missing `_test` suffix — this
// fixture must be REJECTED by `nexus typecheck`.
let f = fn (x: i64) -> i64 do
  return x + 1
end

let f = fn (x: i64) -> i64 do
  return x + 2
end

let main = fn () -> unit do
  let _r1 = f(x: 7)
  return ()
end
