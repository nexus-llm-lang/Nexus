// test_enum_exhaustive (enum with all 3 constructor arms),
// test_or_pattern_covers_all_constructors_is_exhaustive,
// test_or_pattern_alternatives_with_same_binding_typechecks.
//
// User-defined nullary enums: every constructor must be reached, either
// directly (Red | Green | Blue) or through or-patterns merging arms.
// Or-pattern alternatives must bind the same variables — when both `Left`
// and `Right` carry `v: i64`, `Left(v: v) | Right(v: v)` is well-typed.
import * as test_assert from "std:test/assert"

type Color = Red | Green | Blue
type Either = Left(v: i64) | Right(v: i64)

// All three Color variants present — direct exhaustiveness.
let color_id = fn (c: Color) -> i64 do
  match c do
    | Red -> return 1
    | Green -> return 2
    | Blue -> return 3
  end
end

// Or-pattern: Red | Green merged into one arm, Blue separate.
let color_or = fn (c: Color) -> i64 do
  match c do
    | Red | Green -> return 12
    | Blue -> return 3
  end
end

// Or-pattern with same-name binding across alternatives. Both branches
// extract `v` regardless of which constructor matches.
let extract = fn (e: Either) -> i64 do
  match e do
    | Left(v: v) | Right(v: v) -> return v
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: color_id(c: Red), expected: 1, label: "color Red")
  test_assert.assert_eq_i64(actual: color_id(c: Green), expected: 2, label: "color Green")
  test_assert.assert_eq_i64(actual: color_id(c: Blue), expected: 3, label: "color Blue")
  test_assert.assert_eq_i64(actual: color_or(c: Red), expected: 12, label: "or-pattern Red")
  test_assert.assert_eq_i64(actual: color_or(c: Green), expected: 12, label: "or-pattern Green")
  test_assert.assert_eq_i64(actual: color_or(c: Blue), expected: 3, label: "or-pattern Blue")
  test_assert.assert_eq_i64(actual: extract(e: Left(v: 7)), expected: 7, label: "or-pattern same binding Left")
  test_assert.assert_eq_i64(actual: extract(e: Right(v: 9)), expected: 9, label: "or-pattern same binding Right")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
