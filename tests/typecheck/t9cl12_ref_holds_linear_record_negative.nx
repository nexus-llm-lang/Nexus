// Negative fixture for nexus-t9cl.12 — T-Let SigilMutable must reject
// `let ~r = e` when `e`'s inferred type carries a linear component
// structurally, even when the top-level type is a record/typedef.
//
// Pre-fix the T-Let SigilMutable check at src/typecheck/infer.nx
// matched only `TyLinear(_)` / `TyLazy(_)` directly and let
// `TyUserDefined("Bundle", ...)` (a typedef whose body contains a
// `%i64` field) flow through silently. The downstream `wrap_ref`
// produced `~Bundle`, an ill-formed `~` cell holding a structurally
// linear record. Spec type-system-formal.md §Linearity:
// "Linearity is entirely structural, so the check also rejects ~
// cells holding records or ADTs with any linear component."
//
// Post-fix the check threads tdefs into `type_carries_linear`,
// which walks TyRecord / TyUserDefined / TyRef / TyBorrow recursively
// and rejects this `let ~r = make()` directly with a focused message
// that cites the T-Let premise (μ = ~ ⟹ ¬linear(τ')).
//
// Filename intentionally omits `_test` so `nexus test` does not pick
// it up — a fixture that intentionally fails typecheck would otherwise
// be reported as a runner failure.
type Bundle = { val: %i64, count: i64 }

let make = fn () -> Bundle do
  let %v = 7
  let b: Bundle = { val: %v, count: 0 }
  return b
end

let main = fn () -> unit do
  // The RHS has type Bundle, which structurally carries a linear `%i64`
  // field. Post-fix this must be rejected at typecheck time.
  let ~r = make()
  let _ = r
  return ()
end
