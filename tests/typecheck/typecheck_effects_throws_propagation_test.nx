// Effect rows propagate through call sites: a function declared
// `throws { Exn }` may call another `throws { Exn }`, and an impure
// function may call a pure function (effect set widening at the call
// site is implicit). Each annotated function actually raises on at
// least one path so the row is non-reducible (empty-record rows are
// rejected as reducible).
//
// The polymorphic-apply<E> shape is not exercised here because the
// surface-level `pure_fn` has its throws-row defaulted to `{}` and
// instantiating `E = {}` from the call site produces a row mismatch.
import * as test_assert from "std:test/assert"

exception Tag(code: i64)

let pure_fn = fn () -> i64 do
  return 7
end

// Impure-from-pure: pure_fn's empty throws row is a sub-row of { Exn }.
// The conditional raise keeps the throws row non-reducible.
let impure_caller = fn (do_raise: bool) -> i64 throws { Exn } do
  if do_raise then
    raise Tag(code: 99)
  end
  return pure_fn()
end

// Impure-from-impure: propagation through the same throws { Exn } row.
let propagator = fn (do_raise: bool) -> i64 throws { Exn } do
  return impure_caller(do_raise: do_raise)
end

// Catch the propagated raise — confirms the row threads end-to-end.
let propagator_caught = fn () -> i64 do
  try
    let _ = propagator(do_raise: true)
    return -1
  catch
    | Tag(code: c) -> return c
    | _ -> return -1
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: pure_fn(), expected: 7, label: "pure call")
  test_assert.assert_eq_i64(actual: impure_caller(do_raise: false), expected: 7, label: "impure-from-pure (no raise)")
  test_assert.assert_eq_i64(actual: propagator(do_raise: false), expected: 7, label: "impure-from-impure (no raise)")
  test_assert.assert_eq_i64(actual: propagator_caught(), expected: 99, label: "raise propagates two layers")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
