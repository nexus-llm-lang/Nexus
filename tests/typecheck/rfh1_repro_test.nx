// Regression: typecheck previously skipped the body of every non-main
// top-level function in the entry file because `local_names` (the
// allow-list used by `check_all_functions`) was built with bare AST
// names while `HirFunction.name` had already been canonicalised by
// `process_top_level` to "<sanitized-source-path>#<name>". `is_local`
// matches by string equality, so every entry-file `let foo = fn ...`
// other than `main` (which special-cases to bare "main" via
// `build_entry_self_entries`) silently bypassed body typechecking.
//
// Fix: have `extract_function_names` apply the same canonicalisation as
// `build_entry_self_entries` so the names line up.
//
// This file is the *positive* fixture: a correctly-typed non-main
// top-level fn that must still compile cleanly post-fix. The negative
// fixture (deliberately mistyped, must be REJECTED) lives in
// `rfh1_repro.nx` — note the missing `_test` suffix.
import * as test_assert from "std:test/assert"

let bug_free = fn (x: i64) -> i64 do return x end

let main = fn () -> unit do
  let n: i64 = bug_free(x: 7)
  test_assert.assert_eq_i64(actual: n, expected: 7, label: "rfh1: non-main top-level fn typechecks correctly")
  return ()
end
