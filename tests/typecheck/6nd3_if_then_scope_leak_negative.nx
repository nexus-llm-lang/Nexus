// Negative fixture for nexus-6nd3 — T-If else sees then bindings.
// Pre-fix, `let x` introduced inside the then branch leaked into the
// else branch because infer_if threaded `st3` (post-then state) directly
// into the else arm.  Post-fix, the then-branch env is reverted to the
// pre-then state (st2) before entering the else arm.
//
// This program references `then_local` inside the else branch; the
// typechecker must REJECT with an unbound-name error.
//
// Kept out of `nexus test` discovery by the missing `_test` suffix.

let main = fn () -> unit do
  let flag = true
  if flag then
    let then_local = 42
    let _ = then_local
  else
    // `then_local` should NOT be visible here — it was introduced in the
    // then branch only.
    let _ = then_local
  end
  return ()
end
