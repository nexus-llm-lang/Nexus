// Port of bootstrap/tests/typecheck/inference.rs::
// test_float_literal_annotation_can_select_f32, test_float_arithmetic,
// test_float_compare, test_float_literal_type, test_f32_and_f64_keywords.
//
// Float operators are `+. *. -. /. <. >. <=. >=.`. The `float` keyword is
// an alias for f64.
//
// f32 codegen has gaps in the self-host runtime path (component
// composition rejects mixed f32/f64 sites), so the f32 path is pinned
// at the typecheck layer through unused top-level lets — they're
// declared, must typecheck, but are never executed. The f64 / `float`
// path is exercised through `body()`.
import * as test_assert from "std:test/assert"

// Top-level f32 declarations: these must typecheck. We never call them.
let _f32_declared_x: f32 = 1.25
let _f32_add = fn (a: f32, b: f32) -> f32 do
  return a +. b
end
let _f32_compare = fn (a: f32, b: f32) -> bool do
  return a <. b
end

let abs_f64 = fn (x: f64) -> f64 do
  if x <. 0.0 then return 0.0 -. x end
  return x
end

let close_f64 = fn (a: f64, b: f64) -> bool do
  return abs_f64(x: a -. b) <. 0.0001
end

let body = fn () -> unit throws { Exn } do
  // f64 (alias `float`).
  let xf: float = 3.14
  let yf: float = 0.01
  let zf: float = 123.456789
  let sum: float = xf +. yf +. zf
  test_assert.assert_eq_bool(actual: close_f64(a: sum, b: 126.606789), expected: true, label: "float-alias arithmetic")

  // f64 keyword.
  let xd: f64 = 1.5 +. 2.5
  let yd: f64 = xd *. 2.0
  test_assert.assert_eq_bool(actual: close_f64(a: yd, b: 8.0), expected: true, label: "f64 mul")

  // f64 compare.
  let cmp = 1.0 <. 2.0
  test_assert.assert_eq_bool(actual: cmp, expected: true, label: "f64 lt")

  // f64 add via separate locals.
  let q: f64 = 2.0
  let qq = q +. 4.0
  test_assert.assert_eq_bool(actual: close_f64(a: qq, b: 6.0), expected: true, label: "f64 add (f64+f64)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
