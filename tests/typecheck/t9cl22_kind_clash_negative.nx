// Negative fixture for nexus-t9cl.22. Spec L548-L552 (kindOf):
// `kindOf(R, σ) = undefined` when `R` appears at BOTH a type position
// AND as a row tail in σ ("kind clash") — a static error raised at the
// binding site (T-Let-PolyFn). Must be REJECTED with E2012 "kind clash:
// type parameter R is used at both a type position and a row-tail
// position".
//
// `bad` has R in return position (Type-kind) and as the tail of `f`'s
// requires-row (Row-kind). Without binding-site rejection, the unifier
// surfaces a confusing downstream "expected Type, got Row" at a use
// site rather than pointing at the malformed quantifier list directly.
//
// Reachable from `main` via `trigger` so the post-DCE typecheck pass
// actually visits `bad`'s signature. Kept out of `nexus test` discovery
// by the missing `_test` suffix.
import { Console, system_handler } from "std:stdio"
let bad = fn <R>(x: R, f: () -> unit require { PermConsole | R }) -> R do
  return x
end
let trigger = fn () -> unit require { PermConsole } do
  let _ = bad(x: 1, f: fn () -> unit require { PermConsole } do return () end)
  return ()
end
let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    trigger()
    return ()
  end
end
