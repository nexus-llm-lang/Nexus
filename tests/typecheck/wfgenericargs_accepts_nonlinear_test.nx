// Positive: the type-formation rule that rejects generic instantiation at
// a linear type-arg (Map<string, %bb>, Pair<%bb, _>, …) must NOT fire on
// non-linear instantiations. Covers param, return, let-binding, and record
// field positions across Pair / Map / Option / Result and nested cases.
//
// Spec: type-system-formal §Linearity (linear inspects type arguments).
import * as test_assert from "std:test/assert"
import * as map from "std:collection/map"
import { Pair } from "std:tuple"
import { Option, Some, None } from "std:option"

let pair_param = fn (p: Pair<i64, i64>) -> i64 do
  let Pair(left: a, right: b) = p
  return a + b
end

let map_return = fn () -> Map<string, i64> do
  return map.string_map()
end

let opt_param = fn (o: Option<i64>) -> i64 do
  match o do
    | Some(val: x) -> return x
    | None -> return 0
  end
end

let nested_param = fn (p: Pair<Pair<i64, i64>, i64>) -> i64 do
  let Pair(left: inner, right: r) = p
  let Pair(left: a, right: b) = inner
  return a + b + r
end

type R = R(p: Pair<i64, i64>, m: Map<string, i64>)

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: pair_param(p: Pair(left: 1, right: 2)),
    expected: 3,
    label: "pair"
  )
  let m = map_return()
  test_assert.assert_eq_i64(actual: opt_param(o: Some(val: 42)), expected: 42, label: "opt-some")
  test_assert.assert_eq_i64(actual: opt_param(o: None), expected: 0, label: "opt-none")
  test_assert.assert_eq_i64(
    actual: nested_param(p: Pair(left: Pair(left: 1, right: 2), right: 3)),
    expected: 6,
    label: "nested"
  )
  let rec: R = R(p: Pair(left: 7, right: 8), m: m)
  let R(p: rp, m: rm) = rec
  let Pair(left: rl, right: rr) = rp
  test_assert.assert_eq_i64(actual: rl + rr, expected: 15, label: "record-field")
  return ()
end
