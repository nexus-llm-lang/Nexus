// Port of bootstrap/tests/typecheck/inference.rs::
// test_main_with_args_typechecks. The `main` entrypoint may accept
// `(args: [string])` in addition to the bare `()` form.
//
// Note: at runtime the Wasm host typically supplies an empty list, but
// this fixture just exercises the typecheck shape.

let main = fn (args: [string]) -> unit do
  // Touch `args` so it counts as used; bare `let _ = args` is fine for
  // a list of strings.
  let _ = args
  return ()
end
