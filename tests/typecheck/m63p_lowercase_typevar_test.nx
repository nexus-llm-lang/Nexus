// Regression: nexus-m63p Bug C — `parse_type_param_list` accepts lowercase
// single-letter type variables (`<a>`, `<b>`, `<a, b>`). Pre-fix the
// parser's `parse_type_param_list` only matched the uppercase token form,
// so `fn <a>(x: a) -> a` raised a parse error. Post-fix the lowercase
// `TkIdent(name: n)` arm threads the binding through to typecheck.
//
// Existing polymorphic fixtures (e.g. typecheck_inference_basic_poly_test)
// use only uppercase `<T>` / `<A, B>` / `<E>`, so this fix had zero
// coverage. Without this fixture a future parse_type unification refactor
// would silently regress lowercase support.
import * as test_assert from "std:test/assert"

// Single lowercase letter — the canonical shape from the bd report.
let id_a = fn <a>(x: a) -> a do
  return x
end

// Two lowercase letters — exercises the comma-separated arm of
// parse_type_param_list, not just the single-binder fast path.
let first_ab = fn <a, b>(x: a, y: b) -> a do
  return x
end

// Mixed lowercase + uppercase — pre-fix this would also fail at the
// lowercase position; post-fix both arms thread cleanly.
let mix_aB = fn <a, B>(x: a, y: B) -> B do
  return y
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: id_a(x: 7), expected: 7, label: "fn <a>(x: a) -> a at i64")
  test_assert.assert_eq_bool(actual: id_a(x: true), expected: true, label: "fn <a>(x: a) -> a at bool")
  test_assert.assert_eq_i64(actual: first_ab(x: 11, y: true), expected: 11, label: "fn <a, b> selects A by first arg")
  test_assert.assert_eq_i64(actual: mix_aB(x: true, y: 42), expected: 42, label: "fn <a, B> mixed-case lowercase head accepted")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
