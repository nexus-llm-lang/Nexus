// Negative fixture for nexus-ed9w. Arrays are mutable in Nexus — value
// equality on them is undefined per spec, so `arr_a == arr_b` must be
// REJECTED by the comparable(τ) predicate. Kept out of `nexus test`
// discovery by the missing `_test` suffix.
let main = fn () -> unit do
  let a: [|i64|] = [|1, 2, 3|]
  let b: [|i64|] = [|1, 2, 3|]
  let _ = a == b
  return ()
end
