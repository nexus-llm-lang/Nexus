// Regression: typecheck previously skipped `__nx_user_main` (the user's
// original `main` body, after `main_wrap` synthesised a wrapper) because
// the rename happens before `check_program` runs and `local_names` is
// extracted from the *pre-wrap* module — so `__nx_user_main` is not in
// the local-names allow-list and `check_all_functions` filters it out.
//
// The result was that every program with `let main = fn () -> ... throws
// { ... }` had its main body silently un-typechecked. Fix: append
// `__nx_user_main` to `local_names` after the wrap pass renames the
// original main, so `check_all_functions` includes it.
//
// This file is the *positive* fixture: a correctly-typed main with
// `throws { Exn }` that must still compile cleanly post-fix. The
// negative fixture (deliberately mistyped, must be REJECTED) lives in
// `1eta_repro_negative.nx` — note the missing `_test` suffix, which
// keeps it out of `nexus test` discovery (a fixture that intentionally
// fails compile would otherwise be reported as a runner failure).
import * as test_assert from "std:test/assert"

let foo = fn (x: i64) -> i64 do return x end

let main = fn () -> unit throws { Exn } do
  // Correctly typed: `foo` returns i64 and we bind to i64.
  let n: i64 = foo(x: 5)
  test_assert.assert_eq_i64(actual: n, expected: 5, label: "main-with-throws typechecks correctly")
  return ()
end
