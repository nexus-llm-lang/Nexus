// Port of bootstrap/tests/typecheck/inference.rs::
// test_binary_op_in_call_arg, test_string_concat_in_call_arg.
//
// Argument positions accept arbitrary expressions, including binary
// arithmetic and string concat — they are checked against the parameter
// type at the call site.
import * as test_assert from "std:test/assert"

let add = fn (a: i64, b: i64) -> i64 do
  return a + b
end

let greet = fn (msg: string) -> string do
  return msg
end

let body = fn () -> unit throws { Exn } do
  let n = add(a: 1 + 2, b: 3 * 4)
  test_assert.assert_eq_i64(actual: n, expected: 15, label: "binop in call arg")

  let s = greet(msg: "hello " ++ "world")
  test_assert.assert_eq_string(actual: s, expected: "hello world", label: "concat in call arg")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
