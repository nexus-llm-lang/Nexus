// Positive test: normal integer and float literals must still lex correctly
// after the digit-abutting-ident-start guard was added (nexus-dzdn3).
// Covers: plain integers (0, 255, 1000, i64 MAX), float dot form (1.5),
// float exponent form (1.5e3, 1.0e-3, 1e10), and zero float (0.0).

import * as test_assert from "std:test/assert"

let float_pos = fn (x: f64) -> bool do
  return x > 0.0
end

let main = fn () -> unit throws { Exn } do
  // Plain integers
  test_assert.assert_eq_i64(actual: 0, expected: 0, label: "zero")
  test_assert.assert_eq_i64(actual: 255, expected: 255, label: "255")
  test_assert.assert_eq_i64(actual: 1000, expected: 1000, label: "1000")
  test_assert.assert_eq_i64(
    actual: 9223372036854775807,
    expected: 9223372036854775807,
    label: "i64-max"
  )

  // Float literals (verify they produce non-zero values as expected)
  test_assert.assert_true(cond: float_pos(x: 1.5), label: "1.5 > 0")
  test_assert.assert_true(cond: float_pos(x: 1.5e3), label: "1.5e3 > 0")
  test_assert.assert_true(cond: float_pos(x: 1.0e-3), label: "1.0e-3 > 0")
  test_assert.assert_true(cond: float_pos(x: 1e10), label: "1e10 > 0")
  test_assert.assert_eq_bool(actual: float_pos(x: 0.0), expected: false, label: "0.0 not > 0")
  return ()
end
