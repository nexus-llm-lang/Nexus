// protobuf_v3: packed repeated varints — proto3-specific default behaviour.
import * as test_assert from "std:test/assert"
import {
  encode_packed_varints, decode_packed_varints,
  decode,
  PbField, PbValue, PbVarint, PbFixed64, PbLenDelim, PbFixed32,
  PbThrow
} from "std:protobuf_v3"
import * as list from "std:list"

let check_list_eq = fn (actual: [ i64 ], expected: [ i64 ], label: string) -> unit throws { Exn } do
  let la = list.length(xs: actual)
  let le = list.length(xs: expected)
  test_assert.assert_eq_i64(actual: la, expected: le, label: label ++ " length")
  check_elems(actual: actual, expected: expected, label: label, idx: 0)
end

let check_elems = fn (actual: [ i64 ], expected: [ i64 ], label: string, idx: i64) -> unit throws { Exn } do
  match actual do
    | [] -> return ()
    | a :: arest ->
      match expected do
        | [] -> return ()
        | e :: erest ->
          test_assert.assert_eq_i64(actual: a, expected: e, label: label ++ " elem")
          return check_elems(actual: arest, expected: erest, label: label, idx: idx + 1)
      end
  end
end

let main = fn () -> unit throws { Exn } do
  // ─── Packed varints round-trip ───────────────────────────────────────────

  // [1, 2, 3, 4] packed in field 5
  let values = [ 1, 2, 300, 4 ]
  let wire = encode_packed_varints(field_number: 5, values)
  // Decode outer field (should be a LEN field for field 5)
  let outer_fields = decode(data: wire)
  match outer_fields do
    | PbField(field_number: fn1, value: PbLenDelim(data: payload)) :: [] ->
      test_assert.assert_eq_i64(actual: fn1, expected: 5, label: "packed field_number")
      // Decode the payload as packed varints
      let decoded = decode_packed_varints(data: payload)
      check_list_eq(actual: decoded, expected: values, label: "packed varints round-trip")
    | _ -> test_assert.assert_true(cond: false, label: "expected single LEN field for packed")
  end

  // ─── Empty packed field ──────────────────────────────────────────────────

  let wire2 = encode_packed_varints(field_number: 1, values: [])
  let outer2 = decode(data: wire2)
  match outer2 do
    | PbField(field_number: fn2, value: PbLenDelim(data: payload2)) :: [] ->
      test_assert.assert_eq_i64(actual: fn2, expected: 1, label: "empty packed field_number")
      let decoded2 = decode_packed_varints(data: payload2)
      test_assert.assert_eq_i64(actual: list.length(xs: decoded2), expected: 0, label: "empty packed length")
    | _ -> test_assert.assert_true(cond: false, label: "expected empty packed LEN field")
  end

  // ─── Single-element packed field ─────────────────────────────────────────

  let wire3 = encode_packed_varints(field_number: 7, values: [ 99 ])
  let outer3 = decode(data: wire3)
  match outer3 do
    | PbField(field_number: fn3, value: PbLenDelim(data: payload3)) :: [] ->
      test_assert.assert_eq_i64(actual: fn3, expected: 7, label: "single packed field_number")
      let decoded3 = decode_packed_varints(data: payload3)
      match decoded3 do
        | v :: [] -> test_assert.assert_eq_i64(actual: v, expected: 99, label: "single packed value")
        | _ -> test_assert.assert_true(cond: false, label: "expected single packed value")
      end
    | _ -> test_assert.assert_true(cond: false, label: "expected single-element packed field")
  end

  return ()
end
