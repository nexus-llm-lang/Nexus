// nexus-9zrq: fd_close must prune the fd-table entry so that fd_path
// returns "" after close and does not return the stale path after fd reuse.
// Strategy: open a file, verify fd_path returns its path, close it, then
// verify fd_path returns "" (empty packed string = 0).
import * as test_assert from "std:test/assert"
import { Fs }, * as fs_mod from "std:fs"
import * as sysio from "std:runtime/sysio"

let main = fn () -> unit require { PermFs } throws { Exn } do
  inject fs_mod.system_handler do
    let dir = "/tmp/nx_9zrq_fdtable"
    let file = "/tmp/nx_9zrq_fdtable/probe.txt"
    Fs.create_dir_all(path: dir)
    Fs.write_string(path: file, content: "probe")
    let fd = sysio.fd_open_read_path(path: file)
    test_assert.assert_true(cond: fd >= 0, label: "fd_open_read_path succeeds")
    test_assert.assert_true(cond: sysio.fd_path_n(fd: fd) == file, label: "fd_path before close returns file path")
    sysio.fd_close_n(fd)
    let path_after = sysio.fd_path_n(fd)
    test_assert.assert_true(cond: path_after == "", label: "fd_path after close returns empty string")
  end
  return ()
end
