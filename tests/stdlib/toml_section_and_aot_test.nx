// TOML standard table [section] and array-of-tables [[section]].
import * as test_assert from "std:test/assert"
import { parse, TomlTable, TomlArray, TomlString, TomlInt, TomlField, TomlValue } from "std:toml"

let count_fields = fn (fields: [TomlField]) -> i64 do
  match fields do
    | [] -> return 0
    | _ :: rest -> return 1 + count_fields(fields: rest)
  end
end

let count_items = fn (items: [TomlValue]) -> i64 do
  match items do
    | [] -> return 0
    | _ :: rest -> return 1 + count_items(items: rest)
  end
end

let main = fn () -> unit throws { Exn } do
  // Standard table.
  let doc1 =
    "[server]\n" ++
    "host = \"localhost\"\n" ++
    "port = 8080\n"
  let root1 = parse(s: doc1)
  match root1 do
    | TomlTable(fields: fs1) ->
      let n1 = count_fields(fields: fs1)
      test_assert.assert_eq_i64(actual: n1, expected: 1, label: "root has 1 section")
    | _ -> test_assert.assert_true(cond: false, label: "root must be table")
  end

  // Array of tables.
  let doc2 =
    "[[products]]\n" ++
    "name = \"hammer\"\n" ++
    "sku = 738594937\n" ++
    "\n" ++
    "[[products]]\n" ++
    "name = \"nail\"\n" ++
    "sku = 284758393\n"
  let root2 = parse(s: doc2)
  match root2 do
    | TomlTable(fields: fs2) ->
      match fs2 do
        | TomlField(key: k, value: TomlArray(items: items)) :: _ ->
          test_assert.assert_eq_string(actual: k, expected: "products", label: "aot key")
          let n2 = count_items(items)
          test_assert.assert_eq_i64(actual: n2, expected: 2, label: "two product entries")
        | _ -> test_assert.assert_true(cond: false, label: "expected products array")
      end
    | _ -> test_assert.assert_true(cond: false, label: "root2 must be table")
  end

  return ()
end
