// Port of bootstrap/tests/stdlib/math.rs::negate_in_math_module.
import { negate } from "std:math"

let body = fn () -> unit throws { Exn } do
  let r = negate(val: false)
  if r != true then raise RuntimeError(val: "expected true") end
  let r2 = negate(val: true)
  if r2 != false then raise RuntimeError(val: "expected false") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
