// Port of bootstrap/tests/stdlib/rand.rs::rand_determinism_pcg_step_byte_equal_across_runs.
// (fixture: bootstrap/tests/fixtures/nxc/test_rand_determinism.nx)
//
// Acceptance: same seed -> same next_i64() sequence (byte-equal across runs);
// different seeds -> divergent first output. Reference values come from
// offline u64 wrapping_mul/add of (6364136223846793005, 1442695040888963407)
// starting from state = seed, top-bit cleared on output.
//
// The Rust harness uses exec_nxc_core_capture_stdout to compare stdout
// line-by-line. We replace that with inline assertions on the in-memory
// next_i64() values — it's the same contract, but printable-output-free
// so the test fits the safe_run scaffold without PermConsole.
import { Random, seed_with, reset }, * as rng from "std:rand"

let body = fn () -> unit require { PermRandom } throws { Exn } do
  inject rng.system_handler do
    // Phase A: seed = 1, ten next_i64 outputs against offline reference.
    let _ = seed_with(seed: 1)
    let r1 = Random.next_i64()
    if r1 != 7806831264735756412 then raise RuntimeError(val: "PCG step 1 mismatch (seed=1)") end
    let r2 = Random.next_i64()
    if r2 != 173536691264035611 then raise RuntimeError(val: "PCG step 2 mismatch (seed=1)") end
    let r3 = Random.next_i64()
    if r3 != 2736747771374053902 then raise RuntimeError(val: "PCG step 3 mismatch (seed=1)") end
    let r4 = Random.next_i64()
    if r4 != 7062582979898595269 then raise RuntimeError(val: "PCG step 4 mismatch (seed=1)") end
    let r5 = Random.next_i64()
    if r5 != 5450049017633417712 then raise RuntimeError(val: "PCG step 5 mismatch (seed=1)") end
    let r6 = Random.next_i64()
    if r6 != 9431502868738175 then raise RuntimeError(val: "PCG step 6 mismatch (seed=1)") end
    let r7 = Random.next_i64()
    if r7 != 994931806658971810 then raise RuntimeError(val: "PCG step 7 mismatch (seed=1)") end
    let r8 = Random.next_i64()
    if r8 != 1206773305466921929 then raise RuntimeError(val: "PCG step 8 mismatch (seed=1)") end
    let r9 = Random.next_i64()
    if r9 != 6266840599827907236 then raise RuntimeError(val: "PCG step 9 mismatch (seed=1)") end
    let r10 = Random.next_i64()
    if r10 != 3660572683296592931 then raise RuntimeError(val: "PCG step 10 mismatch (seed=1)") end

    // Phase B: reset + seed = 2, one step. Must differ from r1 (seed=1).
    let _ = reset()
    let _ = seed_with(seed: 2)
    let s1 = Random.next_i64()
    if s1 != 4947595451727773609 then raise RuntimeError(val: "PCG step 1 mismatch (seed=2)") end
    if s1 == r1 then raise RuntimeError(val: "seed=1 and seed=2 produced identical first output") end
    return ()
  end
end

let safe_run = fn () -> i64 require { PermRandom } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermRandom } do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
