// Port of bootstrap/tests/stdlib/list.rs::concat_tail_recursive_deep.
// list.concat must be tail-safe: a 50k-element prefix concatenated with a
// 3-element suffix should not blow the wasm stack.
import * as list from "std:list"

let make_list = fn (n: i64, acc: [i64]) -> [i64] do
  if n == 0 then return acc end
  return make_list(n: n - 1, acc: n :: acc)
end

let body = fn () -> unit throws { Exn } do
  let xs = make_list(n: 50000, acc: [])
  let ys = make_list(n: 3, acc: [])
  let zs = list.concat(xs: xs, ys: ys)
  match zs do
    | h :: _ ->
      if h != 1 then raise RuntimeError(val: "expected 1 at head of concat") end
    | [] -> raise RuntimeError(val: "expected non-empty concat result")
  end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
