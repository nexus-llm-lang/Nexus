// Port of bootstrap/tests/stdlib/option.rs::option_some_is_some.
import * as test_assert from "std:test/assert"
import { is_some } from "std:option"

let main = fn () -> unit throws { Exn } do
  let opt = Some(val: 42)
  test_assert.assert_true(cond: is_some(opt), label: "is_some(Some(42))")
  return ()
end
