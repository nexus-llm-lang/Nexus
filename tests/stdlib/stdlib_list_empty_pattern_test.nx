// Port of bootstrap/tests/stdlib/list.rs:
//   test_empty_list_pattern,
//   test_cons_operator_with_empty_list_pattern.

let body = fn () -> unit throws { Exn } do
  // Empty list matches [].
  let xs: [i64] = []
  match xs do
    | [] -> ()
    | _ -> raise RuntimeError(val: "expected empty list")
  end

  // Singleton matches h :: [].
  let ys = [42]
  match ys do
    | h :: [] ->
      if h != 42 then raise RuntimeError(val: "expected 42") end
    | _ -> raise RuntimeError(val: "expected singleton")
  end

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
