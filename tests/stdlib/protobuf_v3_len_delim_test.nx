// protobuf_v3: length-delimited field round-trip tests.
import * as test_assert from "std:test/assert"
import {
  encode, decode,
  PbField, PbValue, PbVarint, PbFixed64, PbLenDelim, PbFixed32,
  PbThrow
} from "std:protobuf_v3"

let main = fn () -> unit throws { Exn } do
  // ─── Length-delimited (string/bytes) round-trip ──────────────────────────

  // Field 1, data "hello"
  let wire1 = encode(fields: [PbField(field_number: 1, value: PbLenDelim(data: "hello"))])
  let fields1 = decode(data: wire1)
  match fields1 do
    | PbField(field_number: fn1, value: PbLenDelim(data: d1)) :: [] ->
      test_assert.assert_eq_i64(actual: fn1, expected: 1, label: "len_delim field_number")
      test_assert.assert_eq_string(actual: d1, expected: "hello", label: "len_delim hello")
    | _ -> test_assert.assert_true(cond: false, label: "expected PbLenDelim hello")
  end

  // Empty payload
  let wire2 = encode(fields: [PbField(field_number: 2, value: PbLenDelim(data: ""))])
  let fields2 = decode(data: wire2)
  match fields2 do
    | PbField(field_number: fn2, value: PbLenDelim(data: d2)) :: [] ->
      test_assert.assert_eq_i64(actual: fn2, expected: 2, label: "len_delim empty field_number")
      test_assert.assert_eq_string(actual: d2, expected: "", label: "len_delim empty payload")
    | _ -> test_assert.assert_true(cond: false, label: "expected empty PbLenDelim")
  end

  // ─── Multiple fields round-trip ──────────────────────────────────────────

  // Encode two fields: field 1 (varint 42) and field 2 (string "pb3")
  let two_fields = [
    PbField(field_number: 1, value: PbVarint(val: 42)),
    PbField(field_number: 2, value: PbLenDelim(data: "pb3"))
  ]
  let wire3 = encode(fields: two_fields)
  let fields3 = decode(data: wire3)
  match fields3 do
    | PbField(field_number: fn3a, value: PbVarint(val: v3)) :: PbField(field_number: fn3b, value: PbLenDelim(data: d3)) :: [] ->
      test_assert.assert_eq_i64(actual: fn3a, expected: 1, label: "two-field: field 1 number")
      test_assert.assert_eq_i64(actual: v3, expected: 42, label: "two-field: varint 42")
      test_assert.assert_eq_i64(actual: fn3b, expected: 2, label: "two-field: field 2 number")
      test_assert.assert_eq_string(actual: d3, expected: "pb3", label: "two-field: string pb3")
    | _ -> test_assert.assert_true(cond: false, label: "expected two fields")
  end

  return ()
end
