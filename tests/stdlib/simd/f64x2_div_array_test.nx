// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/simd.nx::f64x2_div_array` — autovectorized element-
// wise f64 division. WASM SIMD has no integer division opcode
// (i32x4 / i64x2 div lacks a proposal-spec op), so `_div_array`
// only exists for f32x4 / f64x2 lanes — this fixture pins the f64
// path. A regression that wired div to a different opcode (e.g.
// mul or sub) would be caught by every non-identity assert.
//
// IEEE 754 edge cases pinned:
//   1. Exact-integer division: 10.0 / 2.0 = 5.0 (no rounding).
//   2. Fractional result with no precision loss: 1.0 / 4.0 = 0.25
//      (power-of-2 divisor → bit-exact f64 result).
//   3. Division by 0.0: 1.0 / 0.0 = +Inf (not a trap, not NaN —
//      IEEE 754 well-defined). Detected via x !=. x being false
//      AND x > any finite value.
//   4. 0.0 / 0.0 = NaN (the canonical NaN-producing op). Detected
//      via NaN !=. NaN being true.
//   5. Negative-result division: -6.0 / 2.0 = -3.0 (sign propagates).
import * as test_assert from "std:test/assert"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"
import * as simd from "std:simd"

let align16 = fn (p: i64) -> i64 do
  let r = p % 16
  if r == 0 then return p end
  return p + (16 - r)
end

let body = fn () -> unit throws { Exn } do
  let pa = align16(p: arena.alloc_raw(size: 32))
  let pb = align16(p: arena.alloc_raw(size: 32))
  let pd = align16(p: arena.alloc_raw(size: 32))

  // ── case 1 & 2: exact-integer + power-of-2 fraction
  mem.store_f64(addr: pa,     val: 10.0)
  mem.store_f64(addr: pa + 8, val: 1.0)
  mem.store_f64(addr: pb,     val: 2.0)
  mem.store_f64(addr: pb + 8, val: 4.0)
  simd.f64x2_div_array(a_addr: pa, b_addr: pb, dst_addr: pd, n_quads: 1)
  let d1_l0 = mem.load_f64(addr: pd)
  let d1_l1 = mem.load_f64(addr: pd + 8)

  // ── case 3 & 4: div-by-zero edge cases ──
  mem.store_f64(addr: pa,     val: 1.0)   // 1 / 0 = +Inf
  mem.store_f64(addr: pa + 8, val: 0.0)   // 0 / 0 = NaN
  mem.store_f64(addr: pb,     val: 0.0)
  mem.store_f64(addr: pb + 8, val: 0.0)
  simd.f64x2_div_array(a_addr: pa, b_addr: pb, dst_addr: pd, n_quads: 1)
  let d2_inf  = mem.load_f64(addr: pd)
  let d2_nan  = mem.load_f64(addr: pd + 8)
  // +Inf has the property: it is finite-comparing larger than any concrete
  // value, AND it is equal to itself (i.e. it is not NaN). Reuse f64
  // sentinel via repeated multiplication (avoids relying on scientific
  // literal parsing which is brittle in some compilation paths).
  let big = 1000000000.0 *. 1000000000.0 *. 1000000000.0  // 1e27
  let inf_test = (d2_inf >. big) && (d2_inf ==. d2_inf)
  let nan_test = d2_nan !=. d2_nan

  // ── case 5: negative result ──
  mem.store_f64(addr: pa,     val: 0.0 -. 6.0)
  mem.store_f64(addr: pa + 8, val: 0.0 -. 9.0)
  mem.store_f64(addr: pb,     val: 2.0)
  mem.store_f64(addr: pb + 8, val: 3.0)
  simd.f64x2_div_array(a_addr: pa, b_addr: pb, dst_addr: pd, n_quads: 1)
  let d3_l0 = mem.load_f64(addr: pd)
  let d3_l1 = mem.load_f64(addr: pd + 8)

  test_assert.assert_true(cond: d1_l0 ==. 5.0,
    label: "f64x2_div_array lane 0: 10.0 / 2.0 = 5.0 (exact integer)")
  test_assert.assert_true(cond: d1_l1 ==. 0.25,
    label: "f64x2_div_array lane 1: 1.0 / 4.0 = 0.25 (power-of-2 divisor, bit-exact)")
  test_assert.assert_true(cond: inf_test,
    label: "f64x2_div_array lane 0: 1.0 / 0.0 = +Inf (greater than any finite, not NaN)")
  test_assert.assert_true(cond: nan_test,
    label: "f64x2_div_array lane 1: 0.0 / 0.0 = NaN (IEEE 754 canonical)")
  test_assert.assert_true(cond: d3_l0 ==. (0.0 -. 3.0),
    label: "f64x2_div_array lane 0: -6 / 2 = -3 (sign propagates)")
  test_assert.assert_true(cond: d3_l1 ==. (0.0 -. 3.0),
    label: "f64x2_div_array lane 1: -9 / 3 = -3")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
