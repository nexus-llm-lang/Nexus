// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/simd.nx::i32x4_add` wrapping semantics on the i32
// signed-overflow boundary. WASM SIMD `i32x4.add` is documented as
// "wrapping arithmetic"; the existing intrinsic_simd_i32x4_add
// fixture exercises only small positive lane values, so this
// fixture pins the boundary contract explicitly.
//
// A regression that wired i32x4_add to a saturating-add opcode
// (i32x4.add_sat_s / .add_sat_u — distinct opcodes in the SIMD
// proposal) would clamp at INT32_MAX/INT32_MIN instead of wrapping;
// every boundary lane below would catch it.
//
// Edge cases pinned:
//   1. lane 0: INT32_MAX + 1 → INT32_MIN (-2147483648).
//      Saturating-signed would clamp to INT32_MAX (2147483647);
//      saturating-unsigned would clamp to 0xFFFFFFFF read as -1.
//   2. lane 1: INT32_MIN + (-1) → INT32_MAX (under-flow wraparound).
//      Saturating would clamp to INT32_MIN.
//   3. lane 2: -1 + 1 → 0 (non-overflow control).
//   4. lane 3: INT32_MAX + INT32_MAX → -2 (double overflow:
//      2*INT32_MAX = 2^32 - 2, which as signed i32 is -2).
import * as test_assert from "std:test/assert"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"
import * as simd from "std:simd"

let align16 = fn (p: i64) -> i64 do
  let r = p % 16
  if r == 0 then return p end
  return p + (16 - r)
end

let body = fn () -> unit throws { Exn } do
  let pa = align16(p: arena.alloc_raw(size: 48))
  let pb = align16(p: arena.alloc_raw(size: 48))
  let pd = align16(p: arena.alloc_raw(size: 48))

  // INT32_MAX = 2147483647, INT32_MIN = -2147483648
  mem.store_i32(addr: pa,      val: 2147483647)         // INT32_MAX
  mem.store_i32(addr: pa + 4,  val: 0 - 2147483648)     // INT32_MIN
  mem.store_i32(addr: pa + 8,  val: 0 - 1)              // -1
  mem.store_i32(addr: pa + 12, val: 2147483647)         // INT32_MAX

  mem.store_i32(addr: pb,      val: 1)                  // +1: triggers overflow
  mem.store_i32(addr: pb + 4,  val: 0 - 1)              // -1: triggers underflow
  mem.store_i32(addr: pb + 8,  val: 1)                  // +1: non-overflow control
  mem.store_i32(addr: pb + 12, val: 2147483647)         // INT32_MAX

  simd.i32x4_add(a_addr: pa, b_addr: pb, dst_addr: pd)

  let l0 = mem.load_i32(addr: pd)
  let l1 = mem.load_i32(addr: pd + 4)
  let l2 = mem.load_i32(addr: pd + 8)
  let l3 = mem.load_i32(addr: pd + 12)

  test_assert.assert_eq_i64(actual: l0, expected: 0 - 2147483648,
    label: "i32x4_add lane 0: INT32_MAX + 1 wraps to INT32_MIN (not saturating-signed)")
  test_assert.assert_eq_i64(actual: l1, expected: 2147483647,
    label: "i32x4_add lane 1: INT32_MIN + -1 wraps to INT32_MAX (underflow wraparound)")
  test_assert.assert_eq_i64(actual: l2, expected: 0,
    label: "i32x4_add lane 2: -1 + 1 = 0 (non-overflow control)")
  test_assert.assert_eq_i64(actual: l3, expected: 0 - 2,
    label: "i32x4_add lane 3: INT32_MAX + INT32_MAX = -2 (2 * (2^31 - 1) wraps in i32)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
