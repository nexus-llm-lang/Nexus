// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/simd.nx::f32x4_mul_array` + `f32x4_sub_array` —
// the 4-lane f32 autovectorized array primitives. Each quad spans
// 16 bytes / 4 f32 lanes. These complement the f64x2 array tests
// by exercising the 4-lane shape; a regression that wired the
// f32x4 mul/sub intrinsics to the matching f64x2 opcode would
// process two lanes (not four) per quad and leave half the dst
// region stale.
//
// f32 lane semantics: `mem.load_f32` / `store_f32` promote f32 to
// f64 across the FFI boundary. The 4 f32 lanes occupy 16 bytes
// (4 × 4) just like the i32x4 shape.
//
// Edge cases pinned:
//   1. f32x4 mul, single quad: [1, 2, 3, 4] * [10, 20, 30, 40] =
//      [10, 40, 90, 160]. Distinct per-lane products → catches a
//      lane-stride or lane-fusion bug.
//   2. f32x4 sub, single quad: [10, 20, 30, 40] - [1, 2, 3, 4] =
//      [9, 18, 27, 36]. Sub is non-commutative → catches an
//      operand-order swap (sub-as-add or swapped args).
//   3. f32 fractional precision: 0.5 * 0.5 = 0.25 round-trips
//      exactly (powers of 2 in f32 are bit-precise).
//   4. f32 negative-result subtraction: 1.0 - 2.0 = -1.0.
import * as test_assert from "std:test/assert"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"
import * as simd from "std:simd"

let align16 = fn (p: i64) -> i64 do
  let r = p % 16
  if r == 0 then return p end
  return p + (16 - r)
end

let body = fn () -> unit throws { Exn } do
  let pa = align16(p: arena.alloc_raw(size: 48))
  let pb = align16(p: arena.alloc_raw(size: 48))
  let pd = align16(p: arena.alloc_raw(size: 48))

  // ── case 1: mul single quad [1,2,3,4] * [10,20,30,40] = [10,40,90,160]
  mem.store_f32(addr: pa,      val: 1.0)
  mem.store_f32(addr: pa + 4,  val: 2.0)
  mem.store_f32(addr: pa + 8,  val: 3.0)
  mem.store_f32(addr: pa + 12, val: 4.0)
  mem.store_f32(addr: pb,      val: 10.0)
  mem.store_f32(addr: pb + 4,  val: 20.0)
  mem.store_f32(addr: pb + 8,  val: 30.0)
  mem.store_f32(addr: pb + 12, val: 40.0)
  simd.f32x4_mul_array(a_addr: pa, b_addr: pb, dst_addr: pd, n_quads: 1)
  let m_l0 = mem.load_f32(addr: pd)
  let m_l1 = mem.load_f32(addr: pd + 4)
  let m_l2 = mem.load_f32(addr: pd + 8)
  let m_l3 = mem.load_f32(addr: pd + 12)

  // ── case 2: sub single quad [10,20,30,40] - [1,2,3,4] = [9,18,27,36]
  mem.store_f32(addr: pa,      val: 10.0)
  mem.store_f32(addr: pa + 4,  val: 20.0)
  mem.store_f32(addr: pa + 8,  val: 30.0)
  mem.store_f32(addr: pa + 12, val: 40.0)
  mem.store_f32(addr: pb,      val: 1.0)
  mem.store_f32(addr: pb + 4,  val: 2.0)
  mem.store_f32(addr: pb + 8,  val: 3.0)
  mem.store_f32(addr: pb + 12, val: 4.0)
  simd.f32x4_sub_array(a_addr: pa, b_addr: pb, dst_addr: pd, n_quads: 1)
  let s_l0 = mem.load_f32(addr: pd)
  let s_l1 = mem.load_f32(addr: pd + 4)
  let s_l2 = mem.load_f32(addr: pd + 8)
  let s_l3 = mem.load_f32(addr: pd + 12)

  // ── case 3: fractional precision — 0.5 * 0.5 = 0.25 (exact in f32)
  mem.store_f32(addr: pa,      val: 0.5)
  mem.store_f32(addr: pa + 4,  val: 0.5)
  mem.store_f32(addr: pa + 8,  val: 0.25)
  mem.store_f32(addr: pa + 12, val: 0.25)
  mem.store_f32(addr: pb,      val: 0.5)
  mem.store_f32(addr: pb + 4,  val: 0.25)
  mem.store_f32(addr: pb + 8,  val: 0.5)
  mem.store_f32(addr: pb + 12, val: 0.25)
  simd.f32x4_mul_array(a_addr: pa, b_addr: pb, dst_addr: pd, n_quads: 1)
  let f_l0 = mem.load_f32(addr: pd)        // 0.25
  let f_l1 = mem.load_f32(addr: pd + 4)    // 0.125
  let f_l2 = mem.load_f32(addr: pd + 8)    // 0.125
  let f_l3 = mem.load_f32(addr: pd + 12)   // 0.0625

  // ── case 4: negative-result sub — 1.0 - 2.0 = -1.0
  mem.store_f32(addr: pa,      val: 1.0)
  mem.store_f32(addr: pa + 4,  val: 1.0)
  mem.store_f32(addr: pa + 8,  val: 1.0)
  mem.store_f32(addr: pa + 12, val: 1.0)
  mem.store_f32(addr: pb,      val: 2.0)
  mem.store_f32(addr: pb + 4,  val: 2.0)
  mem.store_f32(addr: pb + 8,  val: 2.0)
  mem.store_f32(addr: pb + 12, val: 2.0)
  simd.f32x4_sub_array(a_addr: pa, b_addr: pb, dst_addr: pd, n_quads: 1)
  let n_l0 = mem.load_f32(addr: pd)
  let n_l3 = mem.load_f32(addr: pd + 12)

  test_assert.assert_true(cond: m_l0 ==. 10.0,
    label: "f32x4_mul_array lane 0: 1 * 10 = 10")
  test_assert.assert_true(cond: m_l1 ==. 40.0,
    label: "f32x4_mul_array lane 1: 2 * 20 = 40 (distinct from lane 0)")
  test_assert.assert_true(cond: m_l2 ==. 90.0,
    label: "f32x4_mul_array lane 2: 3 * 30 = 90")
  test_assert.assert_true(cond: m_l3 ==. 160.0,
    label: "f32x4_mul_array lane 3: 4 * 40 = 160 (top lane processed)")
  test_assert.assert_true(cond: s_l0 ==. 9.0,
    label: "f32x4_sub_array lane 0: 10 - 1 = 9 (non-commutative)")
  test_assert.assert_true(cond: s_l1 ==. 18.0,
    label: "f32x4_sub_array lane 1: 20 - 2 = 18")
  test_assert.assert_true(cond: s_l2 ==. 27.0,
    label: "f32x4_sub_array lane 2: 30 - 3 = 27")
  test_assert.assert_true(cond: s_l3 ==. 36.0,
    label: "f32x4_sub_array lane 3: 40 - 4 = 36")
  test_assert.assert_true(cond: f_l0 ==. 0.25,
    label: "f32x4_mul_array: 0.5 * 0.5 = 0.25 (exact in f32)")
  test_assert.assert_true(cond: f_l1 ==. 0.125,
    label: "f32x4_mul_array: 0.5 * 0.25 = 0.125")
  test_assert.assert_true(cond: f_l2 ==. 0.125,
    label: "f32x4_mul_array: 0.25 * 0.5 = 0.125 (commutative)")
  test_assert.assert_true(cond: f_l3 ==. 0.0625,
    label: "f32x4_mul_array: 0.25 * 0.25 = 0.0625")
  test_assert.assert_true(cond: n_l0 ==. (0.0 -. 1.0),
    label: "f32x4_sub_array negative result: 1 - 2 = -1 lane 0")
  test_assert.assert_true(cond: n_l3 ==. (0.0 -. 1.0),
    label: "f32x4_sub_array negative result: 1 - 2 = -1 lane 3")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
