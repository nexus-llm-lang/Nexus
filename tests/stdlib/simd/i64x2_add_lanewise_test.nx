// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/simd.nx::i64x2_add` — lane-wise i64 addition over
// the *2-lane* shape (16 bytes / 8 bytes per lane). Lowers to
// v128.load → i64x2.add → v128.store.
//
// Adds coverage for a shape that wasn't pinned by the i32x4
// fixture: the WASM SIMD spec has 16/8/4/2 lane variants and each
// has its own opcode. A regression that wired the i64x2 SIMD
// intrinsic to the i32x4 opcode would compute the right answer on
// lane 0 (low half) but corrupt lane 1 by reading from the wrong
// offset.
//
// Edge cases pinned:
//   1. Both positive lanes round-trip ([1e9, 2e9] + [3, 4]).
//   2. Mixed sign (negative + positive).
//   3. Wrapping at the i64 boundary — INT64_MAX + 1 wraps to
//      INT64_MIN (-2^63). Pins that i64x2.add is true 64-bit
//      wraparound, not promoted to a wider type.
//
// 16-byte alignment via align16 helper; same pattern as the existing
// i32x4_add fixture.
import * as test_assert from "std:test/assert"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"
import * as simd from "std:simd"

let align16 = fn (p: i64) -> i64 do
  let r = p % 16
  if r == 0 then return p end
  return p + (16 - r)
end

let body = fn () -> unit throws { Exn } do
  let pa = align16(p: arena.alloc_raw(size: 32))
  let pb = align16(p: arena.alloc_raw(size: 32))
  let pd = align16(p: arena.alloc_raw(size: 32))

  // ── case 1: positive lanes — [1_000_000_000, 2_000_000_000] + [3, 4]
  //   → [1_000_000_003, 2_000_000_004]
  mem.store_i64(addr: pa,     val: 1000000000)
  mem.store_i64(addr: pa + 8, val: 2000000000)
  mem.store_i64(addr: pb,     val: 3)
  mem.store_i64(addr: pb + 8, val: 4)
  simd.i64x2_add(a_addr: pa, b_addr: pb, dst_addr: pd)
  let p1_l0 = mem.load_i64(addr: pd)
  let p1_l1 = mem.load_i64(addr: pd + 8)

  // ── case 2: mixed sign — [-7, 100] + [10, -250] → [3, -150]
  mem.store_i64(addr: pa,     val: 0 - 7)
  mem.store_i64(addr: pa + 8, val: 100)
  mem.store_i64(addr: pb,     val: 10)
  mem.store_i64(addr: pb + 8, val: 0 - 250)
  simd.i64x2_add(a_addr: pa, b_addr: pb, dst_addr: pd)
  let p2_l0 = mem.load_i64(addr: pd)
  let p2_l1 = mem.load_i64(addr: pd + 8)

  // ── case 3: wrap at INT64_MAX — INT64_MAX + 1 → INT64_MIN
  //   (INT64_MAX = 9223372036854775807; INT64_MIN = -9223372036854775808)
  //   In the second lane we add INT64_MIN + INT64_MIN = 0 (wraps twice).
  mem.store_i64(addr: pa,     val: 9223372036854775807)
  mem.store_i64(addr: pa + 8, val: 0 - 9223372036854775807 - 1)  // INT64_MIN
  mem.store_i64(addr: pb,     val: 1)
  mem.store_i64(addr: pb + 8, val: 0 - 9223372036854775807 - 1)  // INT64_MIN
  simd.i64x2_add(a_addr: pa, b_addr: pb, dst_addr: pd)
  let p3_l0 = mem.load_i64(addr: pd)
  let p3_l1 = mem.load_i64(addr: pd + 8)

  test_assert.assert_eq_i64(actual: p1_l0, expected: 1000000003,
    label: "i64x2_add positive lane 0: 1e9 + 3 = 1_000_000_003")
  test_assert.assert_eq_i64(actual: p1_l1, expected: 2000000004,
    label: "i64x2_add positive lane 1: 2e9 + 4 = 2_000_000_004 (distinct from lane 0)")
  test_assert.assert_eq_i64(actual: p2_l0, expected: 3,
    label: "i64x2_add mixed-sign lane 0: -7 + 10 = 3")
  test_assert.assert_eq_i64(actual: p2_l1, expected: 0 - 150,
    label: "i64x2_add mixed-sign lane 1: 100 + -250 = -150")
  test_assert.assert_eq_i64(actual: p3_l0, expected: 0 - 9223372036854775807 - 1,
    label: "i64x2_add wrap: INT64_MAX + 1 = INT64_MIN")
  test_assert.assert_eq_i64(actual: p3_l1, expected: 0,
    label: "i64x2_add wrap: INT64_MIN + INT64_MIN = 0 (double wrap)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
