// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/simd.nx::i32x4_mul` — lane-wise i32 multiplication
// over four 32-bit integers with wrapping arithmetic. Lowers to
// v128.load → i32x4.mul → v128.store.
//
// Companion to the existing `intrinsic_simd_i32x4_add_test.nx`
// fixture which pins lane-wise *addition*. Multiplication exercises
// a distinct codegen path (different opcode, different result-width
// truncation), so it deserves its own coverage:
//   * signed lanes (negative × positive crosses a sign boundary)
//   * lane independence (a bug that fused two lanes' products would
//     reveal itself only with distinct per-lane products)
//   * one wrapping case: INT32_MAX * 2 — the i32 product wraps to
//     -2; pins that the SIMD lane truncates to 32 bits like the
//     scalar i32 op (not 64 bits).
//
// Alignment: `alloc_raw` returns 8-byte-aligned pointers. v128
// loads/stores accept any alignment per the SIMD spec; we still
// bump to 16-byte for engine fast-path symmetry with the sibling
// fixtures.
import * as test_assert from "std:test/assert"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"
import * as simd from "std:simd"

let align16 = fn (p: i64) -> i64 do
  let r = p % 16
  if r == 0 then return p end
  return p + (16 - r)
end

let body = fn () -> unit throws { Exn } do
  let pa = align16(p: arena.alloc_raw(size: 48))
  let pb = align16(p: arena.alloc_raw(size: 48))
  let pd = align16(p: arena.alloc_raw(size: 48))

  // a = [3, -4, 7, 2147483647] (INT32_MAX in lane 3)
  // b = [5, 6, -8, 2]
  // expected dst = [15, -24, -56, -2]
  //   lane 3: 2147483647 * 2 = 4294967294 → wraps to -2 in i32.
  mem.store_i32(addr: pa,      val: 3)
  mem.store_i32(addr: pa + 4,  val: 0 - 4)
  mem.store_i32(addr: pa + 8,  val: 7)
  mem.store_i32(addr: pa + 12, val: 2147483647)

  mem.store_i32(addr: pb,      val: 5)
  mem.store_i32(addr: pb + 4,  val: 6)
  mem.store_i32(addr: pb + 8,  val: 0 - 8)
  mem.store_i32(addr: pb + 12, val: 2)

  simd.i32x4_mul(a_addr: pa, b_addr: pb, dst_addr: pd)

  let l0 = mem.load_i32(addr: pd)
  let l1 = mem.load_i32(addr: pd + 4)
  let l2 = mem.load_i32(addr: pd + 8)
  let l3 = mem.load_i32(addr: pd + 12)

  test_assert.assert_eq_i64(actual: l0, expected: 15,
    label: "i32x4_mul lane 0: 3 * 5 = 15")
  test_assert.assert_eq_i64(actual: l1, expected: 0 - 24,
    label: "i32x4_mul lane 1: -4 * 6 = -24 (signed)")
  test_assert.assert_eq_i64(actual: l2, expected: 0 - 56,
    label: "i32x4_mul lane 2: 7 * -8 = -56 (sign crosses)")
  test_assert.assert_eq_i64(actual: l3, expected: 0 - 2,
    label: "i32x4_mul lane 3: INT32_MAX * 2 wraps to -2 (i32 truncation)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
