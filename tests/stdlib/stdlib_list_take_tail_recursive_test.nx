// Port of bootstrap/tests/stdlib/list.rs::take_tail_recursive_deep.
// list.take must be tail-safe: taking 50k elements from a 60k list.
import * as list from "std:list"

let make_list = fn (n: i64, acc: [i64]) -> [i64] do
  if n == 0 then return acc end
  return make_list(n: n - 1, acc: n :: acc)
end

let body = fn () -> unit throws { Exn } do
  let xs = make_list(n: 60000, acc: [])
  let ys = list.take(xs: xs, n: 50000)
  let n = list.length(xs: ys)
  if n != 50000 then raise RuntimeError(val: "expected length 50000 after take") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
