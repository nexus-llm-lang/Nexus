// Port of bootstrap/tests/stdlib/collections.rs::hashmap_get_lookup_and_remove
// (fixture: hashmap_get_lookup_and_remove.nx).
//
// Exercises hashmap.get (returns Found/Missing) and hashmap.remove (size
// decreases by one).
import * as test_assert from "std:test/assert"
import * as hashmap from "std:hashmap"

let main = fn () -> unit throws { Exn } do
  let m0 = hashmap.empty()
  let m1 = hashmap.put(map: m0, key: 7, value: 70)
  let m2 = hashmap.put(map: m1, key: 8, value: 80)
  let got = hashmap.get(map: &m2, key: 7)
  let m3 = hashmap.remove(map: m2, key: 8)
  let sz = hashmap.size(map: &m3)
  hashmap.free(map: m3)
  match got do
    | Found(value: v) ->
      test_assert.assert_eq_i64(actual: v + sz, expected: 71, label: "get(7) value + size after remove(8)")
    | Missing -> throw RuntimeError(val: "expected Found, got Missing")
  end
  return ()
end
