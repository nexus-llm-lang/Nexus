// TOML numeric literal support: underscore separators, hex, octal, binary.
import * as test_assert from "std:test/assert"
import { parse, TomlTable, TomlInt, TomlField } from "std:toml"

let get_int = fn (doc: string, key: string) -> i64 throws { Exn } do
  match parse(s: doc) do
    | TomlTable(fields: fs) -> return find_int(fields: fs, key)
    | _ ->
      test_assert.assert_true(cond: false, label: "expected TomlTable")
      return 0
  end
end

let find_int = fn (fields: [ TomlField ], key: string) -> i64 throws { Exn } do
  match fields do
    | [] ->
      test_assert.assert_true(cond: false, label: "key not found: " ++ key)
      return 0
    | TomlField(key: k, value: TomlInt(val: v)) :: rest ->
      if k == key then return v end
      return find_int(fields: rest, key)
    | _ :: rest -> return find_int(fields: rest, key)
  end
end

let main = fn () -> unit throws { Exn } do
  // Underscore separator.
  let v1 = get_int(doc: "n = 1_000_000\n", key: "n")
  test_assert.assert_eq_i64(actual: v1, expected: 1000000, label: "underscore int")

  // Hexadecimal.
  let v2 = get_int(doc: "n = 0xFF\n", key: "n")
  test_assert.assert_eq_i64(actual: v2, expected: 255, label: "hex 0xFF")

  // Octal.
  let v3 = get_int(doc: "n = 0o17\n", key: "n")
  test_assert.assert_eq_i64(actual: v3, expected: 15, label: "octal 0o17")

  // Binary.
  let v4 = get_int(doc: "n = 0b1010\n", key: "n")
  test_assert.assert_eq_i64(actual: v4, expected: 10, label: "binary 0b1010")

  // Hex with underscores.
  let v5 = get_int(doc: "n = 0xDEAD_BEEF\n", key: "n")
  test_assert.assert_eq_i64(actual: v5, expected: 3735928559, label: "hex with underscore")

  return ()
end
