// Port of bootstrap/tests/stdlib/list.rs:
//   test_empty_list_pattern,
//   test_cons_operator_with_empty_list_pattern.
import * as test_assert from "std:test/assert"

let main = fn () -> unit throws { Exn } do
  // Empty list matches [].
  let xs: [i64] = []
  match xs do
    | [] -> test_assert.assert_true(cond: true, label: "[] matches []")
    | _ -> throw RuntimeError(val: "expected empty list")
  end

  // Singleton matches h :: [].
  let ys = [42]
  match ys do
    | h :: [] ->
      test_assert.assert_eq_i64(actual: h, expected: 42, label: "[42] head matches h :: []")
    | _ -> throw RuntimeError(val: "expected singleton")
  end

  return ()
end
