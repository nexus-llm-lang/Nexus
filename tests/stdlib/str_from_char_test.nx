// Issue nexus-9y5m — str.from_char must typecheck cleanly under wide-scope
// (LSP/MCP wide diagnostics walk imported function bodies, not just the
// entry file's). The previous implementation routed `c: char` through
// `cast.i64_of(x: i32) -> i64` and surfaced a false-positive E2001 unify
// error because `char` does not unify with `i32`. `nexus build` masked it
// by skipping unreached stdlib bodies (`local_names` allow-list, see
// `nexus-0190`'s `compute_driver_diagnostics_for_buffer` rationale).
//
// Fix: route through `pun_i64`'s polymorphic `value_of_i64` intrinsic
// (already used by `s_ptr` / `s_len` in str.nx) and dispatch to
// `string_from_char_code(a_code: i64)` directly — same emitted wasm, no
// new intrinsic, body typechecks.
//
// This test calls `str.from_char` from `main` so that the body is in the
// narrow-scope `local_names` allow-list reach: `nexus build` typechecks the
// body, and any future regression of the i32/char unify would surface here
// even without re-exercising the LSP wide-scope path.
import * as test_assert from "std:test/assert"
import * as str from "std:str"

let body = fn () -> unit throws { Exn } do
  // ASCII (1-byte UTF-8): codepoint 65 -> "A"
  test_assert.assert_eq_string(
    actual: str.from_char(c: 'A'),
    expected: "A",
    label: "from_char('A') == \"A\""
  )
  // Punctuation: codepoint 33 -> "!"
  test_assert.assert_eq_string(
    actual: str.from_char(c: '!'),
    expected: "!",
    label: "from_char('!') == \"!\""
  )
  // Whitespace: codepoint 32 -> " "
  test_assert.assert_eq_string(
    actual: str.from_char(c: ' '),
    expected: " ",
    label: "from_char(' ') == \" \""
  )
  // Newline escape: codepoint 10 -> "\n"
  test_assert.assert_eq_string(
    actual: str.from_char(c: '\n'),
    expected: "\n",
    label: "from_char('\\n') == \"\\n\""
  )

  // Round-trip via char_at: encode a char to string then read it back.
  let s = str.from_char(c: 'Z')
  test_assert.assert_eq_i64(
    actual: str.byte_length(s),
    expected: 1,
    label: "from_char('Z') byte length is 1 (ASCII)"
  )

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
