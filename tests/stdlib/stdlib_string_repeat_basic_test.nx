// Port of bootstrap/tests/stdlib/string.rs::string_repeat_basic.
// repeat(s: "ab", n: 3) must produce a string of length 6.
import { repeat, length } from "std:str"

let body = fn () -> unit throws { Exn } do
  let result = repeat(s: "ab", n: 3)
  if length(s: result) != 6 then raise RuntimeError(val: "expected length 6") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
