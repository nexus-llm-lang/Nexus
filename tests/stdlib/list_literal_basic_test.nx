// Port of bootstrap/tests/stdlib/list.rs:
//   test_list_builtin_no_import,
//   test_list_constructor_returns_list_type.
// Reframed to use [] / :: instead of Nil / Cons (Nil/Cons sugar is
// disallowed in new test code per repo style).
import * as test_assert from "std:test/assert"

let main = fn () -> unit throws { Exn } do
  // List literal of 3 ints.
  let xs = [ 10, 20, 30 ]
  match xs do
    | [] -> throw RuntimeError(val: "expected non-empty")
    | h :: _ ->
      test_assert.assert_eq_i64(actual: h, expected: 10, label: "[10,20,30] head")
  end

  // Singleton built via :: + [].
  let ys: [ i64 ] = 1 :: []
  match ys do
    | [] -> throw RuntimeError(val: "expected non-empty")
    | h :: _ ->
      test_assert.assert_eq_i64(actual: h, expected: 1, label: "1 :: [] head")
  end
  return ()
end
