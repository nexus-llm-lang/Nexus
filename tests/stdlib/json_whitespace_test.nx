// Port of bootstrap/tests/stdlib/json.rs::json_whitespace_around_tokens.
// RFC 8259 whitespace (space, tab, CR, LF) at every separator position is
// ignored on parse; the canonical compact form drops it.
import * as test_assert from "std:test/assert"
import { parse, serialize } from "std:json"

let main = fn () -> unit throws { Exn } do
  // Space, tab, CR, LF in every separator position.
  let raw = " \t\r\n[ 1 ,\t2 ,\n3\r] \t\n"
  test_assert.assert_eq_string(
    actual: serialize(v: parse(s: raw)),
    expected: "[1,2,3]",
    label: "RFC 8259 whitespace ignored at separator positions"
  )
  return ()
end
