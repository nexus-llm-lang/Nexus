// Port of bootstrap/tests/stdlib/string.rs::string_pad_right_basic.
// pad_right("hi", width: 5, fill: ".") must produce a 5-byte string.
import * as test_assert from "std:test/assert"
import { pad_right, length } from "std:str"

let main = fn () -> unit throws { Exn } do
  let result = pad_right(s: "hi", width: 5, fill: ".")
  test_assert.assert_eq_i64(
    actual: length(s: result),
    expected: 5,
    label: "length(pad_right(\"hi\", 5, \".\"))"
  )
  return ()
end
