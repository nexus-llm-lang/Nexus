// Tests for std:test/snapshot assert_snapshot helper.
//
// Test 1 (update path): sets NEXUS_SNAPSHOT=update via Env.set, calls
//   assert_snapshot — expects the file to be written and the call to pass.
// Test 2 (match path): calls assert_snapshot again on the file written in
//   test 1 with the same actual string — expects it to pass (content matches).
//
// The mismatch / raise path is not exercised here because it requires
// runtime env-var manipulation between two assert_snapshot calls on the
// same path, which is cumbersome to wire correctly in a single fixture.
// That path is covered by the assert_eq_string unit tests already.
import * as test_assert from "std:test/assert"
import * as snap from "std:test/snapshot"
import { Env }, * as env_mod from "std:env"
import { Fs }, * as fs_mod from "std:fs"

let main = fn () -> unit require { PermFs, PermEnv } throws { Exn } do
  inject env_mod.system_handler do
    inject fs_mod.system_handler do
      let dir = "/tmp/nx_snap1_snapshot"
      let path = "/tmp/nx_snap1_snapshot/hello.txt"
      let actual = "hello, snapshot!\nline two\n"

      // Ensure directory exists.
      Fs.create_dir_all(path: dir)

      // Remove any stale file from a previous run so we hit the
      // first-run (file-absent) write path.
      if Fs.exists(path) then
        Fs.remove_file(path)
      else
        ()
      end

      // Test 1: file absent → write and pass.
      snap.assert_snapshot(actual: actual, path, label: "first-run write")
      test_assert.assert_true(cond: Fs.exists(path), label: "snapshot file created after first-run write")

      // Test 2: file present and matching → pass.
      snap.assert_snapshot(actual: actual, path, label: "content matches stored snapshot")

      // Test 3: NEXUS_SNAPSHOT=update → overwrite and pass even if content differs.
      Env.set(key: "NEXUS_SNAPSHOT", value: "update")
      let updated = "updated content\n"
      snap.assert_snapshot(actual: updated, path, label: "update mode rewrites snapshot")
      let stored = Fs.read_to_string(path)
      test_assert.assert_eq_string(actual: stored, expected: updated, label: "snapshot file contains updated content")
    end
  end
  return ()
end
