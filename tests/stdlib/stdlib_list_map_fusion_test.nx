// Port of bootstrap/tests/stdlib/list.rs::deforestation_map_map_fusion.
// list.map(list.map(xs, double), inc) should fuse into one traversal.
import * as list from "std:list"

let double = fn (val: i64) -> i64 do return val * 2 end
let inc = fn (val: i64) -> i64 do return val + 1 end

let body = fn () -> unit throws { Exn } do
  let xs = [1, 2, 3]
  let result = list.map(xs: list.map(xs: xs, f: double), f: inc)
  // Expected: [3, 5, 7] = [(1*2+1), (2*2+1), (3*2+1)].
  match result do
    | a :: b :: c :: [] ->
      if a != 3 then raise RuntimeError(val: "expected 3") end
      if b != 5 then raise RuntimeError(val: "expected 5") end
      if c != 7 then raise RuntimeError(val: "expected 7") end
    | _ -> raise RuntimeError(val: "expected 3-element result")
  end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
