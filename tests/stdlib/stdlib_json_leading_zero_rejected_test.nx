// Port of bootstrap/tests/stdlib/json.rs::json_rejects_leading_zero.
// RFC 8259 forbids leading zeros on integer literals; parse must raise.
import { parse } from "std:json"

let body = fn () -> unit throws { Exn } do
  // Inverted control flow: the parse must raise, so a normal return signals
  // a missed rejection. The outer try-catch swallows the expected raise.
  try
    let _ = parse(s: "01")
    raise RuntimeError(val: "expected JsonError on leading-zero literal")
  catch _ ->
    return ()
  end
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
