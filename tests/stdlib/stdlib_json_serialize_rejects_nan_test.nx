// Port of bootstrap/tests/stdlib/json.rs::json_serialize_rejects_nan.
// NaN is not part of JSON; the serializer must raise rather than silently
// emit a malformed token. We construct NaN via `to_f64("NaN")` (the host
// parser accepts the literal and yields a true NaN bit pattern).
import { serialize, float } from "std:json"
import { to_f64 } from "std:str"

let body = fn () -> unit throws { Exn } do
  let nan_val = to_f64(s: "NaN")
  let v = float(val: nan_val)
  try
    let _ = serialize(v)
    raise RuntimeError(val: "expected JsonError on NaN")
  catch _ ->
    return ()
  end
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
