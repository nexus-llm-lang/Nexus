// Pins the sequential semantics of std:lazy combinators (issue nexus-qhms).
//
// `nxlib/stdlib/lazy.nx` provides the type signatures listed in
// `docs/spec/lazy.md`, but the runtime/lazy host interface (in
// `std:task`) exposes only `__nx_lazy_spawn` and `__nx_lazy_join` —
// there is no `__nx_lazy_drop` or first-of-two arbiter. Until those
// primitives are added, every combinator forces its arguments
// left-to-right via the `@` sigil, observable side effects included.
// This test pins that contract:
//
//   * race(a, b) returns a's value (sequential force order, b's force
//     discharges its linearity but its result is dropped).
//   * cancel(a) returns unit (force-and-discard).
//   * detach(a) returns unit (force-and-discard, mirror of cancel).
//   * force_all([@a, @b, ...]) returns the forced values in input order.
//
// If a future runtime adds drop/race primitives, the implementations
// should be updated in lockstep with this test (cancel becoming side-
// effect-free observably distinguishes the two regimes).
import * as test_assert from "std:test/assert"
import { race, cancel, detach, force_all } from "std:lazy"

let body = fn () -> unit throws { Exn } do
  // race: a's value wins.
  let @a = 99
  let @b = 88
  let r = race(a, b)
  test_assert.assert_eq_i64(actual: r, expected: 99, label: "race returns a's value (sequential)")

  // cancel: returns unit; the thunk is forced.
  let @c = 7
  cancel(a: c)

  // detach: same shape as cancel, distinct name.
  let @d = 11
  detach(a: d)

  // force_all: pins input order.
  let @t1 = 10
  let @t2 = 20
  let @t3 = 30
  let xs = force_all(tasks: [t1, t2, t3])
  test_assert.assert_eq_i64_list(actual: xs, expected: [10, 20, 30], label: "force_all preserves input order")

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
