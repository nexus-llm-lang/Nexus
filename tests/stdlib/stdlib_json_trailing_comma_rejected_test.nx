// Port of bootstrap/tests/stdlib/json.rs::json_trailing_comma_rejected.
// RFC 8259 forbids trailing commas in arrays; parse must raise.
import { parse } from "std:json"

let body = fn () -> unit throws { Exn } do
  try
    let _ = parse(s: "[1,2,]")
    raise RuntimeError(val: "expected error on trailing comma")
  catch _ ->
    return ()
  end
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
