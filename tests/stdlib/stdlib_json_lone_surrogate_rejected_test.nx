// Port of bootstrap/tests/stdlib/json.rs::json_string_rejects_lone_surrogate.
// An unpaired high surrogate (0xD800..0xDBFF) is not a valid Unicode scalar;
// parse must raise JsonError instead of producing a malformed string.
import { parse } from "std:json"

let body = fn () -> unit throws { Exn } do
  try
    let _ = parse(s: "\"\\uD83D\"")
    raise RuntimeError(val: "expected error on lone high surrogate")
  catch _ ->
    return ()
  end
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
