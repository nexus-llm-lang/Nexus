// Regression test for nexus-9sih: dec_digits / i64_len / write_i64 in
// runtime/collection/core.nx mishandled i64::MIN because `0 - i64::MIN`
// overflows back to i64::MIN (still negative), making dec_digits return 1.
//
// This test exercises:
//   - core.i64_len on i64::MIN (must return 20, not 1)
//   - write_i64 via hmap_keys (key = i64::MIN) — must produce
//     the string "-9223372036854775808"
//   - write_i64 via hmap_vals (value = i64::MIN) — same expected string

import * as test_assert from "std:test/assert"
import * as cm from "std:runtime/collection"
import * as core from "std:runtime/collection/core"

// i64::MIN, written as a parenthesised expression (nexus-rpn8 workaround:
// the parser cannot represent the magnitude 9223372036854775808 directly).
let i64_min = (0 - 9223372036854775807) - 1

// Unpack the (ptr << 32 | len) i64 returned by hmap_keys / hmap_vals into
// a Nexus string value using the pun_str intrinsic.
let packed_to_string = fn (packed: i64) -> string do
  return core.pun_str(a_x: packed)
end

let main = fn () -> unit throws { Exn } do
  // 1. i64_len must return 20 for i64::MIN (not 1 as the overflow-bugged
  //    version did).
  let len = core.i64_len(v: i64_min)
  test_assert.assert_eq_i64(actual: len, expected: 20, label: "i64_len(i64::MIN) == 20")

  // 2. hmap_keys with i64::MIN as the sole key must yield "-9223372036854775808".
  let id_key = cm.hmap_new()
  let _ = cm.hmap_put(a_id: id_key, b_key: i64_min, c_value: 1)
  let keys_packed = cm.hmap_keys(a_id: id_key)
  let keys_str = packed_to_string(packed: keys_packed)
  test_assert.assert_eq_string(
    actual: keys_str,
    expected: "-9223372036854775808",
    label: "hmap_keys with i64::MIN key"
  )

  // 3. hmap_vals with i64::MIN as the sole value must yield "-9223372036854775808".
  let id_val = cm.hmap_new()
  let _ = cm.hmap_put(a_id: id_val, b_key: 1, c_value: i64_min)
  let vals_packed = cm.hmap_vals(a_id: id_val)
  let vals_str = packed_to_string(packed: vals_packed)
  test_assert.assert_eq_string(
    actual: vals_str,
    expected: "-9223372036854775808",
    label: "hmap_vals with i64::MIN value"
  )

  return ()
end
