// Port of bootstrap/tests/stdlib/string.rs::test_to_string_invalid_index.
// exn.to_string of InvalidIndex(val: 42) yields "InvalidIndex: 42".
import * as test_assert from "std:test/assert"
import { to_string } from "std:exn"

let main = fn () -> unit throws { Exn } do
  let e: Exn = InvalidIndex(val: 42)
  test_assert.assert_eq_string(
    actual: to_string(exn: e),
    expected: "InvalidIndex: 42",
    label: "to_string(InvalidIndex(42))"
  )
  return ()
end
