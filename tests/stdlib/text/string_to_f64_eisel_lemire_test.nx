// Regression: string_to_f64 must round full-precision (>16-digit) decimal
// strings to nearest, ties-to-even (nexus-rxnv5, Bug A).
//
// Before the Eisel-Lemire fix, assemble_f64 went through
// i64_to_float(mant) *. pow10(dexp), which truncates the significand's dropped
// low bits and inherits pow10's per-exponent reciprocal rounding error, so
// 17-digit inputs landed 1-2 ULP off. The canonical witness:
//   "3.1415926535897931"  parsed to bits 4614256656552045847 (1 ULP low);
//   the correctly-rounded result is 4614256656552045848.
//
// The fix multiplies the normalised 64-bit significand by a precomputed 128-bit
// power-of-ten (std:text/str/pow5_table) via a 64x64->128 multiply and reads the
// correctly-rounded mantissa directly, falling back to the legacy multiply only
// for genuinely-ambiguous halfway / out-of-range inputs. Every value here is
// asserted against the IEEE-754 round-to-nearest-even bit pattern.
import * as test_assert from "std:test/assert"
import { to_f64 } from "std:str"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"

let bits_of = fn (x: f64) -> i64 do
  let p = arena.alloc_raw(size: 8)
  mem.store_f64(addr: p, val: x)
  return mem.load_i64(addr: p)
end

let check = fn (s: string, expected: i64, label: string) -> unit throws { Exn } do
  let got = bits_of(x: to_f64(s))
  test_assert.assert_eq_i64(actual: got, expected, label)
  return ()
end

let main = fn () -> unit throws { Exn } do
  // --- The two bd witnesses ---
  // 3.1415926535897931 -> nearest double has bits 4614256656552045848.
  check(s: "3.1415926535897931", expected: 4614256656552045848, label: "pi-17-digit")
  // 0.020408163265306118 was already correct by lucky cancellation; must stay.
  check(s: "0.020408163265306118", expected: 4581539473982948664, label: "1/49-control")

  // --- Other 17-digit full-precision inputs (all 1 ULP off pre-fix) ---
  check(s: "1.2345678901234567", expected: 4608238818662570491, label: "12345.../17")
  check(s: "9.9999999999999999", expected: 4621819117588971520, label: "nines-17")
  check(s: "123456789012345678", expected: 4862596447618666293, label: "18-digit-int")
  check(s: "1.5e-5", expected: 4534972062662729065, label: "1.5e-5")
  check(s: "1.0e308", expected: 9214871658872686752, label: "1.0e308")
  check(s: "0.30000000000000004", expected: 4599075939470750516, label: "0.1+0.2")

  // --- Controls across the magnitude range (must be exact, never regress) ---
  check(s: "0.1", expected: 4591870180066957722, label: "0.1")
  check(s: "0.5", expected: 4602678819172646912, label: "0.5")
  check(s: "3.25", expected: 4614500768194494464, label: "3.25")
  check(s: "42", expected: 4631107791820423168, label: "42")
  check(s: "100", expected: 4636737291354636288, label: "100")
  check(s: "1000000000000000", expected: 4831355200913801216, label: "1e15")
  check(s: "9007199254740992", expected: 4845873199050653696, label: "2^53")
  check(s: "9007199254740994", expected: 4845873199050653697, label: "2^53+2")
  check(s: "1.7976931348623157e308", expected: 9218868437227405311, label: "f64::MAX")
  check(s: "1e300", expected: 9094988921128908188, label: "1e300")
  check(s: "1e-300", expected: 118622047889322841, label: "1e-300")
  // Smallest normal double (2.2250738585072014e-308): now handled correctly.
  check(s: "2.2250738585072014e-308", expected: 4503599627370496, label: "min-normal")
  return ()
end
