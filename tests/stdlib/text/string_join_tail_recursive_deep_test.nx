// Port of bootstrap/tests/stdlib/string.rs::join_tail_recursive_deep.
// 5_000 single-char strings joined by "," must not blow the wasm stack.
// Expected byte length: 5000 * 1 + 4999 separators = 9999.
//
// N is smaller than the split test (50k) because join is O(N^2) on
// string length — 50k would be too slow.
import * as test_assert from "std:test/assert"
import { join, length } from "std:str"

let make_strs = fn (n: i64, acc: [ string ]) -> [ string ] do
  if n == 0 then return acc end
  return make_strs(n: n - 1, acc: "x" :: acc)
end

let main = fn () -> unit throws { Exn } do
  let xs = make_strs(n: 5000, acc: [])
  let result = join(xs, sep: ",")
  test_assert.assert_eq_i64(
    actual: length(s: result),
    expected: 9999,
    label: "length(join(5000x \"x\", \",\"))"
  )
  return ()
end
