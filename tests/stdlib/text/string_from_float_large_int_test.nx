// Regression: string_from_float must print exact-integer f64 values at and
// above 2^53 without a spurious fractional digit (nexus-1ylu9).
// Before the fix, 2^53 printed as "9007199254740992.7" and 2^53+2 as
// "9007199254740994.5" because the integer-fast-path guard excluded values
// >= 9007199254740992 (= 2^53), falling into the general digit-extraction
// path which accumulates rounding error at large magnitudes.
import * as test_assert from "std:test/assert"
import { from_float } from "std:str"
import { i64_to_float } from "std:math"

let check = fn (val: float, expected: string, label: string) -> unit throws { Exn } do
  test_assert.assert_eq_string(actual: from_float(val), expected, label)
  return ()
end

let main = fn () -> unit throws { Exn } do
  // --- Buggy cases (nexus-1ylu9): exact integers at/above 2^53 ---
  // 2^53 = 9007199254740992 (the first ulp->=1 boundary)
  check(val: i64_to_float(val: 9007199254740992), expected: "9007199254740992", label: "2^53")
  // 2^53 + 2 (2^53+1 is not representable in f64; next is +2)
  check(val: i64_to_float(val: 9007199254740994), expected: "9007199254740994", label: "2^53+2")

  // --- Controls that must still work ---
  // small exact integer
  check(val: i64_to_float(val: 100), expected: "100", label: "100")
  // fractional value
  check(val: i64_to_float(val: 1005) /. i64_to_float(val: 10), expected: "100.5", label: "100.5")
  // 1e15 (large but below 2^53)
  check(val: i64_to_float(val: 1000000000000000), expected: "1000000000000000", label: "1e15")
  // 15-digit exact integer below 2^53
  check(val: i64_to_float(val: 123456789012345), expected: "123456789012345", label: "123456789012345")
  // zero
  check(val: i64_to_float(val: 0), expected: "0", label: "0.0")
  // negative large exact integer above 2^53
  check(val: i64_to_float(val: 0) -. i64_to_float(val: 9007199254740992), expected: "-9007199254740992", label: "-2^53")
  // true fractional value: 3.25 = 13/4 (exact in f64)
  check(val: i64_to_float(val: 13) /. i64_to_float(val: 4), expected: "3.25", label: "3.25")
  // 0.1 (not exact in f64 but must not crash)
  // just check it contains a '.' and is non-empty via bool check
  let s01 = from_float(val: i64_to_float(val: 1) /. i64_to_float(val: 10))
  test_assert.assert_eq_bool(actual: s01 != "0", expected: true, label: "0.1 non-zero")
  return ()
end
