// nexus-wvu9: regexp from_string compiles valid patterns and rejects
// invalid ones via InvalidRegexp.
import * as test_assert from "std:test/assert"
import * as re from "std:regexp"

let compiles_ok = fn (src: string) -> bool do
  try
    re.from_string(src)
    return true
  catch _ ->
    return false
  end
end

let main = fn () -> unit throws { Exn } do
  // Positive: every documented syntactic form must compile.
  test_assert.assert_true(cond: compiles_ok(src: ""), label: "compile empty")
  test_assert.assert_true(cond: compiles_ok(src: "abc"), label: "compile literal")
  test_assert.assert_true(cond: compiles_ok(src: "a|b|c"), label: "compile alt")
  test_assert.assert_true(cond: compiles_ok(src: "a*b+c?"), label: "compile quantifiers")
  test_assert.assert_true(cond: compiles_ok(src: "a{3}"), label: "compile {n}")
  test_assert.assert_true(cond: compiles_ok(src: "a{2,5}"), label: "compile {n,m}")
  test_assert.assert_true(cond: compiles_ok(src: "a{2,}"), label: "compile {n,}")
  // At-the-cap repetition bound (1000) still compiles.
  test_assert.assert_true(cond: compiles_ok(src: "a{1000}"), label: "compile {1000} at cap")
  test_assert.assert_true(cond: compiles_ok(src: "a{2,1000}"), label: "compile {2,1000} at cap")
  test_assert.assert_true(cond: compiles_ok(src: "[a-z]+"), label: "compile class range")
  test_assert.assert_true(cond: compiles_ok(src: "[^0-9]"), label: "compile negated class")
  test_assert.assert_true(cond: compiles_ok(src: "(?:ab)+"), label: "compile non-capturing")
  test_assert.assert_true(cond: compiles_ok(src: "(a)(b)"), label: "compile groups")
  test_assert.assert_true(cond: compiles_ok(src: "\\d+\\s+\\w+"), label: "compile escapes")
  test_assert.assert_true(cond: compiles_ok(src: "^foo$"), label: "compile anchors")
  test_assert.assert_true(cond: compiles_ok(src: "\\."), label: "compile escaped dot")
  test_assert.assert_true(cond: compiles_ok(src: "a\\\\b"), label: "compile escaped backslash")

  // Negative: must throw InvalidRegexp — migrated to assert_raises.
  test_assert.assert_raises(label: "reject unclosed group", body: fn () -> bool throws { Exn } do
    re.from_string(src: "(") return false end)
  test_assert.assert_raises(label: "reject unclosed class", body: fn () -> bool throws { Exn } do
    re.from_string(src: "[abc") return false end)
  test_assert.assert_raises(label: "reject unmatched right paren", body: fn () -> bool throws { Exn } do
    re.from_string(src: ")") return false end)
  test_assert.assert_raises(label: "reject malformed quantifier", body: fn () -> bool throws { Exn } do
    re.from_string(src: "a{") return false end)
  test_assert.assert_raises(label: "reject reversed {n,m}", body: fn () -> bool throws { Exn } do
    re.from_string(src: "a{2,1}") return false end)
  // Oversized repetition bounds are rejected at parse time with
  // InvalidRegexp rather than faulting the wasm during copy emission.
  test_assert.assert_raises(label: "reject {1001} above cap", body: fn () -> bool throws { Exn } do
    re.from_string(src: "a{1001}") return false end)
  test_assert.assert_raises(label: "reject huge {n} bound", body: fn () -> bool throws { Exn } do
    re.from_string(src: "a{9999999999}") return false end)
  test_assert.assert_raises(label: "reject {2,1001} above cap", body: fn () -> bool throws { Exn } do
    re.from_string(src: "a{2,1001}") return false end)
  test_assert.assert_raises(label: "reject backreference", body: fn () -> bool throws { Exn } do
    re.from_string(src: "\\1") return false end)
  test_assert.assert_raises(label: "reject lookahead", body: fn () -> bool throws { Exn } do
    re.from_string(src: "(?=a)") return false end)
  test_assert.assert_raises(label: "reject reversed range", body: fn () -> bool throws { Exn } do
    re.from_string(src: "[z-a]") return false end)
  test_assert.assert_raises(label: "reject dangling backslash", body: fn () -> bool throws { Exn } do
    re.from_string(src: "a\\") return false end)
  test_assert.assert_raises(label: "reject leading quantifier", body: fn () -> bool throws { Exn } do
    re.from_string(src: "*foo") return false end)
  test_assert.assert_raises(label: "reject lazy quantifier", body: fn () -> bool throws { Exn } do
    re.from_string(src: "a*?") return false end)

  return ()
end
