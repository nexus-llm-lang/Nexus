// nexus-wvu9: sub / gsub / split / gsub_with — replacement templates,
// zero-width-match safety, and the functional callback variant.
import * as test_assert from "std:test/assert"
import * as re from "std:regexp"
import { Match } from "std:regexp"
import { Some, None } from "std:option"
import { byte_length } from "std:str"

let upper_or_passthrough = fn (m: Match) -> string do
  let Match(start: _, end_pos: _, text, groups: _) = m
  return "[" ++ text ++ "]"
end

let body = fn () -> unit throws { Exn } do
  // ── sub ─────────────────────────────────────────────────────────────────
  let r_digits = re.from_string(src: "\\d+")
  test_assert.assert_eq_string(
    actual: re.sub(re: r_digits, s: "a1 b22 c333", repl: "N"),
    expected: "aN b22 c333",
    label: "sub first only"
  )
  test_assert.assert_eq_string(
    actual: re.sub(re: r_digits, s: "abc", repl: "N"),
    expected: "abc",
    label: "sub no-match passthrough"
  )

  // $& expansion (whole match)
  test_assert.assert_eq_string(
    actual: re.sub(re: r_digits, s: "a1b2", repl: "<$&>"),
    expected: "a<1>b2",
    label: "sub $& whole match"
  )

  // $1 group expansion
  let r_kv = re.from_string(src: "(\\w+)=(\\d+)")
  test_assert.assert_eq_string(
    actual: re.sub(re: r_kv, s: "answer=42", repl: "$2 is $1"),
    expected: "42 is answer",
    label: "sub $N group expansion"
  )

  // $$ literal
  test_assert.assert_eq_string(
    actual: re.sub(re: r_digits, s: "x9y", repl: "$$$&"),
    expected: "x$9y",
    label: "sub $$ literal"
  )

  // ── gsub ────────────────────────────────────────────────────────────────
  test_assert.assert_eq_string(
    actual: re.gsub(re: r_digits, s: "a1 b22 c333", repl: "N"),
    expected: "aN bN cN",
    label: "gsub replaces all"
  )

  test_assert.assert_eq_string(
    actual: re.gsub(re: r_digits, s: "abc", repl: "N"),
    expected: "abc",
    label: "gsub no-match passthrough"
  )

  // Zero-width match: `a*` matches at every position. We require that gsub
  // terminates (no infinite loop) and preserves at least the original byte
  // count (we don't pin the exact output because zero-width replacement
  // strategies vary across implementations).
  let r_star = re.from_string(src: "a*")
  let zw_result = re.gsub(re: r_star, s: "xyz", repl: "|")
  test_assert.assert_true(
    cond: byte_length(s: zw_result) >= 3,
    label: "gsub zero-width terminates and preserves >= input bytes"
  )

  // gsub_with: callback receives the Match and returns its replacement.
  let r_word = re.from_string(src: "\\w+")
  test_assert.assert_eq_string(
    actual: re.gsub_with(re: r_word, s: "hello world", f: upper_or_passthrough),
    expected: "[hello] [world]",
    label: "gsub_with brackets each word"
  )

  // ── split ───────────────────────────────────────────────────────────────
  let r_comma = re.from_string(src: ",")
  let parts = re.split(re: r_comma, s: "a,b,c,d")
  test_assert.assert_eq_i64(actual: list_len(xs: parts), expected: 4, label: "split count")
  test_assert.assert_eq_string(actual: nth_str(xs: parts, n: 0), expected: "a", label: "split[0]")
  test_assert.assert_eq_string(actual: nth_str(xs: parts, n: 1), expected: "b", label: "split[1]")
  test_assert.assert_eq_string(actual: nth_str(xs: parts, n: 3), expected: "d", label: "split[3]")

  // Split on whitespace runs (\s+) collapses adjacent separators.
  let r_ws = re.from_string(src: "\\s+")
  let words = re.split(re: r_ws, s: "  foo   bar  baz")
  // Leading whitespace yields an empty first element.
  test_assert.assert_eq_string(
    actual: nth_str(xs: words, n: 0),
    expected: "",
    label: "split ws leading empty"
  )
  test_assert.assert_eq_string(
    actual: nth_str(xs: words, n: 1),
    expected: "foo",
    label: "split ws[1]"
  )
  test_assert.assert_eq_string(
    actual: nth_str(xs: words, n: 2),
    expected: "bar",
    label: "split ws[2]"
  )
  test_assert.assert_eq_string(
    actual: nth_str(xs: words, n: 3),
    expected: "baz",
    label: "split ws[3]"
  )

  // Split with no matches returns the whole input.
  let r_zz = re.from_string(src: "Z+")
  let solo = re.split(re: r_zz, s: "abc")
  test_assert.assert_eq_i64(actual: list_len(xs: solo), expected: 1, label: "split no-match len")
  test_assert.assert_eq_string(
    actual: nth_str(xs: solo, n: 0),
    expected: "abc",
    label: "split no-match content"
  )

  // Zero-width (non-empty) pattern must preserve every byte instead of
  // dropping the byte at each match position: split(/x*/, "abc") = ["a","b","c"].
  let r_star_zw = re.from_string(src: "x*")
  let zw = re.split(re: r_star_zw, s: "abc")
  test_assert.assert_eq_i64(actual: list_len(xs: zw), expected: 3, label: "split x* len")
  test_assert.assert_eq_string(actual: nth_str(xs: zw, n: 0), expected: "a", label: "split x*[0]")
  test_assert.assert_eq_string(actual: nth_str(xs: zw, n: 1), expected: "b", label: "split x*[1]")
  test_assert.assert_eq_string(actual: nth_str(xs: zw, n: 2), expected: "c", label: "split x*[2]")

  // Empty pattern returns the whole input as a single element (docstring),
  // not one element per character.
  let r_empty = re.from_string(src: "")
  let em = re.split(re: r_empty, s: "abc")
  test_assert.assert_eq_i64(actual: list_len(xs: em), expected: 1, label: "split // len")
  test_assert.assert_eq_string(actual: nth_str(xs: em, n: 0), expected: "abc", label: "split //[0]")

  // Splitting an empty string still yields a single empty field, never [].
  let empty_in = re.split(re: r_star_zw, s: "")
  test_assert.assert_eq_i64(
    actual: list_len(xs: empty_in),
    expected: 1,
    label: "split empty-input len"
  )
  test_assert.assert_eq_string(
    actual: nth_str(xs: empty_in, n: 0),
    expected: "",
    label: "split empty-input[0]"
  )

  return ()
end

// ─── String list helpers (kept local so the file stays self-contained) ─

let list_len = fn (xs: [ string ]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + list_len(xs: rest)
  end
end

let nth_str = fn (xs: [ string ], n: i64) -> string do
  match xs do
    | [] -> return "<oob>"
    | v :: rest ->
      if n <= 0 then return v end
      return nth_str(xs: rest, n: n - 1)
  end
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
