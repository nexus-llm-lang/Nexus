// nexus-wvu9: test / find / find_all across every quantifier, char class,
// and anchor in the supported syntax subset.
import * as test_assert from "std:test/assert"
import * as re from "std:regexp"
import { Match } from "std:regexp"
import { Some, None } from "std:option"

let test_one = fn (
  pat: string,
  input: string,
  expected: bool,
  label: string
) -> unit throws { Exn } do
  let r = re.from_string(src: pat)
  test_assert.assert_eq_bool(actual: re.test(re: r, s: input), expected, label)
  return ()
end

// Run `find` and assert the matched substring equals `expected`. When
// `expected` is "" we assert no match.
let find_one = fn (
  pat: string,
  input: string,
  expected_text: string,
  label: string
) -> unit throws { Exn } do
  let r = re.from_string(src: pat)
  match re.find(re: r, s: input) do
    | Some(val: m) ->
      let Match(start: _, end_pos: _, text, groups: _) = m
      test_assert.assert_eq_string(actual: text, expected: expected_text, label)
    | None ->
      test_assert.assert_eq_string(
        actual: "<none>",
        expected: expected_text,
        label: label ++ " (no match)"
      )
  end
  return ()
end

let count_matches = fn (pat: string, input: string) -> i64 throws { Exn } do
  let r = re.from_string(src: pat)
  return len_go(xs: re.find_all(re: r, s: input), n: 0)
end

let len_go = fn (xs: [ Match ], n: i64) -> i64 do
  match xs do
    | [] -> return n
    | _ :: rest -> return len_go(xs: rest, n: n + 1)
  end
end

let body = fn () -> unit throws { Exn } do
  // ── test (substring containment) ────────────────────────────────────────
  test_one(pat: "abc", input: "xabcy", expected: true, label: "literal hits")
  test_one(pat: "abc", input: "ab", expected: false, label: "literal misses")
  test_one(pat: "a*", input: "", expected: true, label: "star matches empty")
  test_one(pat: "a+", input: "", expected: false, label: "plus needs one")
  test_one(pat: "a+", input: "aaa", expected: true, label: "plus matches many")
  test_one(pat: "ab?c", input: "ac", expected: true, label: "optional absent")
  test_one(pat: "ab?c", input: "abc", expected: true, label: "optional present")

  // ── bounded quantifiers ─────────────────────────────────────────────────
  test_one(pat: "a{3}", input: "aaa", expected: true, label: "{3} exact")
  test_one(pat: "a{3}", input: "aa", expected: false, label: "{3} short")
  test_one(pat: "a{2,4}", input: "aaaa", expected: true, label: "{2,4} max")
  test_one(pat: "^a{2,4}$", input: "a", expected: false, label: "{2,4} too few")
  test_one(pat: "^a{2,4}$", input: "aaaaa", expected: false, label: "{2,4} too many")
  test_one(pat: "a{2,}", input: "aaaaa", expected: true, label: "{2,} unbounded")

  // ── character classes & escapes ─────────────────────────────────────────
  find_one(pat: "[a-z]+", input: "  hello world  ", expected_text: "hello", label: "class range")
  find_one(pat: "[^a-z]+", input: "abc 123!def", expected_text: " 123!", label: "negated class")
  find_one(pat: "\\d+", input: "abc123def", expected_text: "123", label: "digit shorthand")
  find_one(
    pat: "\\w+",
    input: "  foo_bar123 ",
    expected_text: "foo_bar123",
    label: "word shorthand"
  )
  find_one(pat: "\\s+", input: "x  \t y", expected_text: "  \t ", label: "ws shorthand")
  find_one(pat: "\\D+", input: "123abc456", expected_text: "abc", label: "non-digit shorthand")

  // ── anchors ─────────────────────────────────────────────────────────────
  test_one(pat: "^abc", input: "abcde", expected: true, label: "^ at start")
  test_one(pat: "^abc", input: "xabcde", expected: false, label: "^ mismatch")
  test_one(pat: "abc$", input: "xyabc", expected: true, label: "$ at end")
  test_one(pat: "abc$", input: "abcde", expected: false, label: "$ mismatch")
  test_one(pat: "^$", input: "", expected: true, label: "^$ empty matches")
  test_one(pat: "^$", input: "x", expected: false, label: "^$ rejects nonempty")

  // ── alternation & grouping ──────────────────────────────────────────────
  find_one(pat: "cat|dog", input: "we have a dog here", expected_text: "dog", label: "alt 2nd")
  find_one(pat: "(?:ab)+", input: "abababx", expected_text: "ababab", label: "non-capturing repeat")

  // ── find_all ────────────────────────────────────────────────────────────
  test_assert.assert_eq_i64(
    actual: count_matches(pat: "\\d+", input: "a1 b22 c333"),
    expected: 3,
    label: "find_all count"
  )
  test_assert.assert_eq_i64(
    actual: count_matches(pat: "x", input: ""),
    expected: 0,
    label: "find_all empty"
  )

  // ── capture groups ──────────────────────────────────────────────────────
  let r = re.from_string(src: "(\\w+)=(\\d+)")
  match re.find(re: r, s: "answer=42, year=2026") do
    | Some(val: m) ->
      let Match(start: _, end_pos: _, text, groups: _) = m
      test_assert.assert_eq_string(actual: text, expected: "answer=42", label: "group whole match")
    | None ->
      throw RuntimeError(val: "expected match")
  end

  // ── byte semantics on non-ASCII (regression: pattern/subject scanners must
  // read raw bytes 0-255, not UTF-8-decode them) ──────────────────────────
  //
  // U+0618 (bytes D8 98) must NOT match U+0E18 `ธ` (bytes E0 B8 98): with the
  // old char_code decode both 0xD8 and 0x98 collapsed to 1536, producing a
  // false positive and a find of the invalid-UTF-8 slice B8 98. Byte-faithful
  // reads make these distinct byte sequences disagree.
  test_one(pat: "\u{0618}", input: "\u{0E18}", expected: false, label: "U+0618 must not match U+0E18 (no byte collision)")
  // The exact same multibyte char matches itself, byte-for-byte.
  test_one(pat: "\u{0E18}", input: "x\u{0E18}y", expected: true, label: "multibyte char matches itself")
  find_one(pat: "\u{0E18}", input: "x\u{0E18}y", expected_text: "\u{0E18}", label: "multibyte find yields the whole char")

  // Character classes must admit non-ASCII bytes (the bitmap covers 0-255):
  // `[中]+` matches `中`, and the negated `[^...]` / \S shorthand treat
  // multibyte runs as non-space.
  test_one(pat: "[\u{4E2D}]+", input: "\u{4E2D}", expected: true, label: "[中]+ matches 中")
  find_one(pat: "[\u{4E2D}]+", input: "a\u{4E2D}\u{4E2D}b", expected_text: "\u{4E2D}\u{4E2D}", label: "[中]+ spans the run")
  // \S+ over "日本語 x": the leading non-space run is the three-char word,
  // not just the trailing ASCII "x".
  find_one(pat: "\\S+", input: "\u{65E5}\u{672C}\u{8A9E} x", expected_text: "\u{65E5}\u{672C}\u{8A9E}", label: "\\S+ finds the non-space CJK run")

  // gsub over non-ASCII must not corrupt bytes: replacing U+0618 in a subject
  // that only contains U+0E18 finds nothing, so the text is preserved verbatim
  // (the old bug emitted a lone E0 continuation-orphan + replacement).
  let r_no = re.from_string(src: "\u{0618}")
  test_assert.assert_eq_string(
    actual: re.gsub(re: r_no, s: "\u{0E18}", repl: "Z"),
    expected: "\u{0E18}",
    label: "gsub of non-matching multibyte pattern preserves text"
  )
  return ()
end

// safe_run / divide-by-zero scaffold so the test driver sees a nonzero
// exit on assertion failure (mirrors other stdlib tests).
let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
