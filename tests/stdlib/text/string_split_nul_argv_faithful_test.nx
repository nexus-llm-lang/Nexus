// Regression (silent argv corruption): the argv wire format is
// the raw WASI argv buffer, NUL-separated with the trailing NUL dropped. The
// `Proc.argv()` / `main(args)` plumbing splits this buffer on "\0" (NOT "\n"),
// so an OS argument that itself contains a newline survives as a single
// element instead of being shredded into multiple args.
//
// This locks the `str.split(buf, "\0")` contract that `io/proc.nx::argv` and
// `runtime/sysio/proc.nx::argv` rely on. Building the buffer here mirrors the
// post-`args_get` state: `arg0\0arg1\0arg2` (trailing NUL already dropped).
import * as test_assert from "std:test/assert"
import { split, from_char_code } from "std:str"
import * as list from "std:list"

let main = fn () -> unit throws { Exn } do
  let nul = from_char_code(code: 0)
  let nl = from_char_code(code: 10)

  // Wire buffer: prog \0 "one<nl>two" \0 tail  (newline lives INSIDE arg1).
  let buf = "p.wasm" ++ nul ++ ("one" ++ nl ++ "two") ++ nul ++ "tail"
  let args = split(s: buf, sep: nul)

  test_assert.assert_eq_i64(
    actual: list.length(xs: args),
    expected: 3,
    label: "newline-containing arg stays a single element (argc==3)"
  )
  match args do
    | a0 :: a1 :: a2 :: [] ->
        test_assert.assert_eq_string(actual: a0, expected: "p.wasm", label: "arg0 = program name")
        test_assert.assert_eq_string(actual: a1, expected: "one" ++ nl ++ "two", label: "arg1 = newline intact")
        test_assert.assert_eq_string(actual: a2, expected: "tail", label: "arg2 = tail")
    | _ -> test_assert.assert(cond: false, label: "args must have exactly 3 elements")
  end

  // Single-element buffer (zero extra args): just arg0, no trailing empty.
  let solo = split(s: "p.wasm", sep: nul)
  test_assert.assert_eq_i64(
    actual: list.length(xs: solo),
    expected: 1,
    label: "zero-extra-args buffer yields exactly arg0 (argc==1)"
  )

  // Normal multi-arg buffer still splits per NUL.
  let three = split(s: "p.wasm" ++ nul ++ "aaa" ++ nul ++ "bbb", sep: nul)
  test_assert.assert_eq_i64(
    actual: list.length(xs: three),
    expected: 3,
    label: "normal NUL-separated buffer splits to argc==3"
  )
  return ()
end
