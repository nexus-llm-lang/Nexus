// Regression: string_to_f64 must preserve the sign of a ZERO magnitude, i.e.
// "-0.0" (and "-0", "-0.0e5") parse to IEEE-754 negative zero, not +0.0.
//
// Before the fix, assemble_f64/assemble_legacy applied a negative sign via
// `f0() -. mag`; for a zero magnitude that is `0.0 -. 0.0`, which IEEE-754
// defines as +0.0 -- so the sign was silently dropped and "-0.0" collapsed to
// +0.0. The observable symptom was `1.0 /. parse("-0.0")` yielding +inf instead
// of -inf. Nonzero magnitudes kept their sign fine; only zero lost it.
//
// The fix sets the IEEE sign bit on the assembled bit pattern directly (the
// magnitude is always a nonnegative finite value, inf/nan handled separately),
// which yields -0.0 for a zero magnitude and is the exact IEEE negation for a
// nonzero one. Every case is asserted against the raw IEEE-754 bit pattern;
// -0.0 is all-zero bits except the sign bit (bit 63 == `1 << 63`).
import * as test_assert from "std:test/assert"
import { to_f64 } from "std:str"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"

let bits_of = fn (x: f64) -> i64 do
  let p = arena.alloc_raw(size: 8)
  mem.store_f64(addr: p, val: x)
  return mem.load_i64(addr: p)
end

let check = fn (s: string, expected: i64, label: string) -> unit throws { Exn } do
  let got = bits_of(x: to_f64(s))
  test_assert.assert_eq_i64(actual: got, expected, label)
  return ()
end

let main = fn () -> unit throws { Exn } do
  // IEEE-754 -0.0: every bit zero except the sign bit (bit 63).
  let neg_zero = 1 << 63
  // The three negative-zero spellings must all carry the sign into the result.
  check(s: "-0.0", expected: neg_zero, label: "-0.0 -> -0.0")
  check(s: "-0", expected: neg_zero, label: "-0 -> -0.0")
  check(s: "-0.0e5", expected: neg_zero, label: "-0.0e5 -> -0.0")
  // Positive-zero controls must stay +0.0 (all bits zero).
  check(s: "0.0", expected: 0, label: "0.0 -> +0.0")
  check(s: "+0.0", expected: 0, label: "+0.0 -> +0.0")

  // Behavioural witness: 1/-0.0 is -inf (< 0), 1/+0.0 is +inf (> 0).
  test_assert.assert_true(cond: (1.0 /. to_f64(s: "-0.0")) <. 0.0, label: "1/-0.0 == -inf")
  test_assert.assert_true(cond: (1.0 /. to_f64(s: "0.0")) >. 0.0, label: "1/+0.0 == +inf")

  // A normal negative value must be unaffected by the sign-application change.
  check(s: "-3.5", expected: bits_of(x: 0.0 -. 3.5), label: "-3.5 unaffected")
  return ()
end
