// Regression test for nexus-wnfih: str.index_of must return a codepoint index
// not a byte offset, so that split and other codepoint-indexed callers are correct
// when multibyte UTF-8 codepoints precede the separator.
import * as test_assert from "std:test/assert"
import { index_of, split, join, length } from "std:str"
import * as list from "std:list"

let main = fn () -> unit throws { Exn } do
  // --- index_of: multibyte codepoints before the match ---
  // "aé,b": 'é' is 2 bytes; ',' is at codepoint 2, byte 3
  test_assert.assert_eq_i64(
    actual: index_of(s: "aé,b", sub: ","),
    expected: 2,
    label: "index_of(\"aé,b\", \",\")"
  )

  // "café,bar": 'é' is 2 bytes; ',' is at codepoint 4, byte 5
  test_assert.assert_eq_i64(
    actual: index_of(s: "café,bar", sub: ","),
    expected: 4,
    label: "index_of(\"café,bar\", \",\")"
  )

  // "α,β": 'α' is 2 bytes; ',' is at codepoint 1, byte 2
  test_assert.assert_eq_i64(
    actual: index_of(s: "α,β", sub: ","),
    expected: 1,
    label: "index_of(\"α,β\", \",\")"
  )

  // --- index_of: ASCII-only (no regression) ---
  test_assert.assert_eq_i64(
    actual: index_of(s: "a,b", sub: ","),
    expected: 1,
    label: "index_of(\"a,b\", \",\") ASCII"
  )

  // --- index_of: not found returns -1 ---
  test_assert.assert_eq_i64(
    actual: index_of(s: "café", sub: ","),
    expected: 0 - 1,
    label: "index_of not found → -1"
  )

  // --- split: multibyte before separator ---
  // split("café,bar", ",") → ["café", "bar"]
  let parts1 = split(s: "café,bar", sep: ",")
  test_assert.assert_eq_i64(
    actual: list.length(xs: parts1),
    expected: 2,
    label: "split(\"café,bar\") length"
  )
  test_assert.assert_eq_string(
    actual: join(xs: parts1, sep: "|"),
    expected: "café|bar",
    label: "split(\"café,bar\") segments"
  )

  // split("α,β", ",") → ["α", "β"]
  let parts2 = split(s: "α,β", sep: ",")
  test_assert.assert_eq_i64(
    actual: list.length(xs: parts2),
    expected: 2,
    label: "split(\"α,β\") length"
  )
  test_assert.assert_eq_string(
    actual: join(xs: parts2, sep: "|"),
    expected: "α|β",
    label: "split(\"α,β\") segments"
  )

  // split("aé,b", ",") must yield ["aé", "b"]
  let parts3 = split(s: "aé,b", sep: ",")
  test_assert.assert_eq_i64(
    actual: list.length(xs: parts3),
    expected: 2,
    label: "split(\"aé,b\") length"
  )
  test_assert.assert_eq_string(
    actual: join(xs: parts3, sep: "|"),
    expected: "aé|b",
    label: "split(\"aé,b\") segments"
  )

  // --- split: ASCII (no regression) ---
  let parts_ascii = split(s: "a,b,c", sep: ",")
  test_assert.assert_eq_string(
    actual: join(xs: parts_ascii, sep: "|"),
    expected: "a|b|c",
    label: "split ASCII unchanged"
  )

  return ()
end
