import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as char from "std:char"

let body = fn () -> unit throws { Exn } do
  let s = "Az!"

  test_assert.assert_eq_i64(
    actual: char.ord(c: str.byte_at(s, idx: 0)),
    expected: 65,
    label: "byte_at(\"Az!\", 0) is 'A' (65)"
  )
  test_assert.assert_eq_i64(
    actual: char.ord(c: str.byte_at(s, idx: 1)),
    expected: 122,
    label: "byte_at(\"Az!\", 1) is 'z' (122)"
  )
  test_assert.assert_eq_i64(
    actual: char.ord(c: str.byte_at(s, idx: 2)),
    expected: 33,
    label: "byte_at(\"Az!\", 2) is '!' (33)"
  )

  test_assert.assert_eq_i64(
    actual: char.ord(c: str.char_at(s, idx: 0)),
    expected: 65,
    label: "char_at(\"Az!\", 0) is 'A' (65)"
  )
  test_assert.assert_eq_i64(
    actual: char.ord(c: str.char_at(s, idx: 2)),
    expected: 33,
    label: "char_at(\"Az!\", 2) is '!' (33)"
  )

  test_assert.assert_true(
    cond: str.byte_at(s, idx: 0) == 'A',
    label: "byte_at result compares equal to char literal 'A'"
  )

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
