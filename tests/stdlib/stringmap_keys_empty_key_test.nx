// Regression test for nexus-o2vu: keys() must return [""] when the only
// entry has the empty string as its key.  The old encoding computed
// total = sm_ksize - 1 = 0 and returned a null packed string, causing
// keys() to return [] instead of [""].
import * as test_assert from "std:test/assert"
import * as smap from "std:stringmap"

let list_length = fn <T>(xs: [ T ]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + list_length(xs: rest)
  end
end

let list_contains = fn (xs: [ string ], target: string) -> bool do
  match xs do
    | [] -> return false
    | h :: rest ->
      if h == target then return true end
      return list_contains(xs: rest, target)
  end
end

let main = fn () -> unit throws { Exn } do
  let m0 = smap.empty()
  let m1 = smap.put(map: m0, key: "", value: 42)
  let ks = smap.keys(map: &m1)
  let sz = smap.size(map: &m1)
  smap.free(map: m1)
  test_assert.assert_eq_i64(actual: sz,                  expected: 1,  label: "size with empty-string key")
  test_assert.assert_eq_i64(actual: list_length(xs: ks), expected: 1,  label: "keys() length with empty-string key")
  test_assert.assert_true(cond: list_contains(xs: ks, target: ""),     label: "keys() contains empty-string key")
  return ()
end
