// Port of bootstrap/tests/stdlib/arena.rs::arena_100k_echo_workload_g0_bounded_with_reset.
//
// 100_000 iterations of a per-request echo workload wrapped in
// arena.heap_mark / heap_reset must keep the G0 bump pointer (string-heap
// watermark) bounded. The fixture self-asserts (via `1 / ok` trap on
// mismatch) that post-loop G0 == pre-loop G0 — every iteration's
// allocations were reclaimed by heap_reset.
//
// The original Rust source declares `main` with PermConsole and prints a
// status line. We drop the Console.println (it would force a
// capability-bearing main that the safe_run scaffold can't wrap) and
// instead anchor `~acc` to a global through the trap-on-mismatch i64.div_s
// so the optimizer cannot DCE the loop.
import * as test_assert from "std:test/assert"
import { heap_mark, heap_reset } from "std:arena"
import { length, from_i64, substring } from "std:str"

// Recover the G0 bump pointer from a heap_mark() packed i64 — low 32 bits
// are the offset; upper 32 are the routed-allocator count (zero in
// component mode).
let g0_of = fn (mark: i64) -> i64 do
  return mark & 4294967295
end

let simulate_echo_handler = fn (i: i64) -> i64 do
  let id_str = from_i64(val: i)
  let path = "/echo/" ++ id_str
  let body_in = "ping " ++ id_str
  let header = "content-type:text/plain\nlength:" ++ from_i64(val: length(s: body_in))
  let response_full = header ++ "\n\n" ++ "echo: " ++ body_in ++ " path=" ++ path
  let _ = substring(s: response_full, start: 0, len: 4)
  return length(s: response_full)
end

let body = fn () -> unit throws { Exn } do
  let mark0 = heap_mark()
  let g0_before = g0_of(mark: mark0)
  let ~i = 0
  let ~acc = 0
  while ~i < 100000 do
    let m = heap_mark()
    let n = simulate_echo_handler(i: ~i)
    ~acc <- ~acc + n
    heap_reset(mark: m)
    ~i <- ~i + 1
  end
  let mark1 = heap_mark()
  let g0_after = g0_of(mark: mark1)
  // With wrapping, the bump pointer must return to its pre-loop value.
  test_assert.assert_eq_i64(actual: g0_after, expected: g0_before, label: "G0 bounded across 100k iters")
  // Anchor ~acc so the loop cannot be DCE'd.
  test_assert.assert_true(cond: ~acc > 0, label: "loop body executed (acc > 0)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
