// Port of bootstrap/tests/stdlib/option.rs::option_some_is_some.
import { Option, is_some } from "std:option"

let body = fn () -> unit throws { Exn } do
  let opt = Some(val: 42)
  let r = is_some(opt: opt)
  if r != true then raise RuntimeError(val: "expected is_some true") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
