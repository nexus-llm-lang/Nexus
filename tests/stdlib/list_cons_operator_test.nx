// Port of bootstrap/tests/stdlib/list.rs:
//   test_cons_operator_expr,
//   test_cons_operator_pattern,
//   test_cons_operator_chained_pattern,
//   test_cons_operator_expr_prepend_to_list,
//   test_cons_operator_precedence.
// Reframed to use [] / :: throughout.
import * as test_assert from "std:test/assert"

let main = fn () -> unit throws { Exn } do
  // Build a 3-element list with right-associative ::.
  let xs = 1 :: 2 :: 3 :: []
  match xs do
    | a :: b :: c :: [] ->
      test_assert.assert_eq_i64(actual: a, expected: 1, label: "1 :: 2 :: 3 :: [] head")
      test_assert.assert_eq_i64(actual: b, expected: 2, label: "1 :: 2 :: 3 :: [] mid")
      test_assert.assert_eq_i64(actual: c, expected: 3, label: "1 :: 2 :: 3 :: [] tail elem")
    | _ -> throw RuntimeError(val: "expected 3-element list")
  end

  // h :: t pattern, then h2 :: _ on the tail.
  let ys = [10, 20, 30]
  match ys do
    | h :: t ->
      test_assert.assert_eq_i64(actual: h, expected: 10, label: "[10,20,30] head")
      match t do
        | h2 :: _ ->
          test_assert.assert_eq_i64(actual: h2, expected: 20, label: "[10,20,30] tail head")
        | _ -> throw RuntimeError(val: "expected tail")
      end
    | _ -> throw RuntimeError(val: "expected cons")
  end

  // Prepend with :: to a list literal.
  let tail = [2, 3]
  let zs = 1 :: tail
  match zs do
    | h :: _ ->
      test_assert.assert_eq_i64(actual: h, expected: 1, label: "1 :: [2,3] head")
    | [] -> throw RuntimeError(val: "expected non-empty")
  end

  // Precedence: 1 + 2 :: [] parses as (1 + 2) :: [].
  let ws = 1 + 2 :: []
  match ws do
    | h :: [] ->
      test_assert.assert_eq_i64(actual: h, expected: 3, label: "1 + 2 :: [] head")
    | _ -> throw RuntimeError(val: "expected [3]")
  end

  return ()
end
