// Port of bootstrap/tests/stdlib/fs.rs::fs_create_dir_and_exists_work.
// `Fs.create_dir_all` creates a fresh directory and `Fs.exists` reports
// it as present. Original Rust test uses `TempDir` to allocate a unique
// path; standalone wasmtime mounts /tmp under bootstrap.sh's `--dir`
// flags, so we use a hardcoded path under /tmp with a per-test suffix.
import * as test_assert from "std:test/assert"
import { Fs }, * as fs_mod from "std:fs"

let main = fn () -> unit require { PermFs } throws { Exn } do
  inject fs_mod.system_handler do
    let dir = "/tmp/nx_dvr66_mkdir"
    Fs.create_dir_all(path: dir)
    test_assert.assert_true(cond: Fs.exists(path: dir), label: "Fs.exists after create_dir_all")
  end
  return ()
end
