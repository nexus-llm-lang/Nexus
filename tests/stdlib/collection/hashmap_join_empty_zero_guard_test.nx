// Regression test for nexus-vh6g: hm_join_i64 in core.nx computed
// `total = hm_join_size(...) - 1` without guarding against hm_join_size
// returning 0.  When all slots are non-full (empty or tombstoned map),
// size - 1 underflows to -1, and arena.alloc_raw(-1) causes corruption.
//
// This test verifies:
//   1. hmap_keys on a fresh empty map returns a zero-length packed string.
//   2. hmap_vals on a fresh empty map returns a zero-length packed string.
//   3. hset_to_list on a fresh empty set returns a zero-length packed string.
//
// The packed string encoding is (ptr << 32 | len); a well-formed empty
// result has len == 0, so (packed & 0xFFFFFFFF) == 0.

import * as test_assert from "std:test/assert"
import * as cm from "std:runtime/collection"

let lo32 = fn (v: i64) -> i64 do return v & 4294967295 end

let main = fn () -> unit throws { Exn } do
  // case 1: hmap_keys on empty map
  let m = cm.hmap_new()
  let keys_packed = cm.hmap_keys(a_id: m)
  test_assert.assert_eq_i64(actual: lo32(v: keys_packed), expected: 0,
    label: "hmap_keys on empty map: packed length == 0 (no underflow)")

  // case 2: hmap_vals on empty map (same map, still empty)
  let vals_packed = cm.hmap_vals(a_id: m)
  test_assert.assert_eq_i64(actual: lo32(v: vals_packed), expected: 0,
    label: "hmap_vals on empty map: packed length == 0 (no underflow)")

  cm.hmap_free(a_id: m)

  // case 3: hset_to_list on empty set
  let s = cm.hset_new()
  let list_packed = cm.hset_to_list(a_id: s)
  test_assert.assert_eq_i64(actual: lo32(v: list_packed), expected: 0,
    label: "hset_to_list on empty set: packed length == 0 (no underflow)")
  cm.hset_free(a_id: s)

  return ()
end
