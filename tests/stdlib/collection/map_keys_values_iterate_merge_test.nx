// Map<K,V> traversal + merge: keys / values / iterate return one element per
// live binding, and merge layers the right-hand map's bindings over the left
// (right wins on key collision) without disturbing either input.
import * as test_assert from "std:test/assert"
import * as map from "std:collection/map"
import * as list from "std:list"

let main = fn () -> unit throws { Exn } do
  let m1 = map.insert(m: map.string_map(), k: "a", v: 1)
  let m2 = map.insert(m: m1, k: "b", v: 2)
  let m3 = map.insert(m: m2, k: "c", v: 3)

  test_assert.assert_eq_i64(
    actual: list.length(xs: map.keys(m: m3)),
    expected: 3,
    label: "keys length 3"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: map.values(m: m3)),
    expected: 3,
    label: "values length 3"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: map.iterate(m: m3)),
    expected: 3,
    label: "iterate length 3"
  )

  // merge: right operand wins on overlapping keys; non-overlapping keys union.
  let b1 = map.insert(m: map.string_map(), k: "b", v: 99)
  let b2 = map.insert(m: b1, k: "d", v: 4)
  let mg = map.merge(a: m3, b: b2)
  test_assert.assert_eq_i64(actual: map.size(m: mg), expected: 4, label: "merge size 4 (a,b,c,d)")
  test_assert.assert_eq_i64(
    actual: map.get_or(m: mg, k: "b", default: 0),
    expected: 99,
    label: "merge: b wins from right"
  )
  test_assert.assert_eq_i64(
    actual: map.get_or(m: mg, k: "a", default: 0),
    expected: 1,
    label: "merge: a kept from left"
  )
  test_assert.assert_eq_i64(
    actual: map.get_or(m: mg, k: "d", default: 0),
    expected: 4,
    label: "merge: d added from right"
  )

  // inputs to merge are unaffected.
  test_assert.assert_eq_i64(
    actual: map.get_or(m: m3, k: "b", default: 0),
    expected: 2,
    label: "left input unchanged"
  )
  test_assert.assert_eq_i64(actual: map.size(m: b2), expected: 2, label: "right input unchanged")
  return ()
end
