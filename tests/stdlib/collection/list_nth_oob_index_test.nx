// Regression (nexus-k9l22): list.nth on a beyond-length index must report the
// REQUESTED index in IndexOutOfBounds, not requested-minus-length (the recursion
// decrements the cursor; the original index must be threaded through).
import { Console, system_handler } from "std:stdio"
import * as list from "std:list"
import { IndexOutOfBounds } from "std:collection/list"
import { from_i64 } from "std:str"
let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let xs = [ 10, 20 ]
    try
      let _v = list.nth(xs: xs, n: 5)
      Console.println(val: "NO-THROW-BAD")
      let _b = 1 / 0
    catch e ->
      match e do
        | IndexOutOfBounds(op: _, index: i) ->
          Console.println(val: "idx=" ++ from_i64(val: i))
          let ok = if i == 5 then 1 else 0 end
          let _g = 1 / ok
        | _ -> let _g2 = 1 / 0
      end
    end
  end
  return ()
end
