// Persistent key-generic Map<K,V> with string keys: insert / get / get_or /
// contains, repeated-key overwrite, and value semantics — an old snapshot is
// unaffected by a later insert/remove on a derived map.
import * as test_assert from "std:test/assert"
import * as map from "std:collection/map"
import { Some, None } from "std:option"

let main = fn () -> unit throws { Exn } do
  let m0 = map.string_map()
  let m1 = map.insert(m: m0, k: "hello", v: 10)
  let m2 = map.insert(m: m1, k: "world", v: 20)
  let m3 = map.insert(m: m2, k: "hello", v: 99)

  // get returns the most recent binding; missing keys are None.
  match map.get(m: m3, k: "hello") do
    | Some(val: x) -> test_assert.assert_eq_i64(
      actual: x,
      expected: 99,
      label: "hello overwritten to 99"
    )
    | None -> test_assert.assert_true(cond: false, label: "hello present")
  end
  match map.get(m: m3, k: "missing") do
    | Some(_) -> test_assert.assert_true(cond: false, label: "missing absent")
    | None -> test_assert.assert_true(cond: true, label: "missing -> None")
  end

  test_assert.assert_eq_i64(
    actual: map.size(m: m3),
    expected: 2,
    label: "size 2 (overwrite is not a new key)"
  )
  test_assert.assert_true(cond: map.contains(m: m3, k: "world"), label: "contains world")
  test_assert.assert_eq_i64(
    actual: map.get_or(m: m3, k: "nope", default: 7),
    expected: 7,
    label: "get_or returns default"
  )

  // Value semantics: m1 (built before the "hello" overwrite) still sees 10.
  test_assert.assert_eq_i64(
    actual: map.get_or(m: m1, k: "hello", default: 0),
    expected: 10,
    label: "snapshot m1 unaffected"
  )

  // remove yields a fresh map; the source map is unaffected.
  let m4 = map.remove(m: m3, k: "hello")
  test_assert.assert_eq_i64(actual: map.size(m: m4), expected: 1, label: "size 1 after remove")
  test_assert.assert_true(
    cond: map.contains(m: m4, k: "hello") == false,
    label: "hello removed from m4"
  )
  test_assert.assert_true(
    cond: map.contains(m: m3, k: "hello"),
    label: "m3 still has hello (value semantics)"
  )
  return ()
end
