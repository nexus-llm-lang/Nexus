// Exercises the generic %StringMap<V> with bool values (V = bool), a second
// distinct value type, and walks the typed `values` iterator. Confirms a single
// instantiation safely carries a non-i64 value type through put / get_or /
// values.
import * as test_assert from "std:test/assert"
import * as smap from "std:stringmap"
import * as list from "std:list"

// Count how many bools in the list are true.
let count_true = fn (xs: [ bool ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | x :: rest -> return count_true(xs: rest, acc: if x then acc + 1 else acc end)
  end
end

let main = fn () -> unit throws { Exn } do
  let m0 = smap.empty()
  let m1 = smap.put(map: m0, key: "enabled", value: true)
  let m2 = smap.put(map: m1, key: "verbose", value: false)
  let m3 = smap.put(map: m2, key: "strict", value: true)
  let enabled = smap.get_or(map: &m3, key: "enabled", default: false)
  let verbose = smap.get_or(map: &m3, key: "verbose", default: true)
  let missing = smap.get_or(map: &m3, key: "absent", default: false)
  let sz = smap.size(map: &m3)
  let vals = smap.values(map: &m3)
  smap.free(map: m3)

  test_assert.assert_eq_bool(actual: enabled, expected: true, label: "get_or(\"enabled\") is true")
  test_assert.assert_eq_bool(
    actual: verbose,
    expected: false,
    label: "get_or(\"verbose\") is false"
  )
  test_assert.assert_eq_bool(
    actual: missing,
    expected: false,
    label: "get_or returns the typed bool default for an absent key"
  )
  test_assert.assert_eq_i64(actual: sz, expected: 3, label: "size is 3")
  test_assert.assert_eq_i64(
    actual: count_true(xs: vals, acc: 0),
    expected: 2,
    label: "values() yields two true bools (enabled, strict)"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: vals),
    expected: 3,
    label: "values() length matches size"
  )
  return ()
end
