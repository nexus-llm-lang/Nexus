// Companion to bootstrap/tests/stdlib/array.rs.
//
// All five tests in array.rs are typecheck-only checks (four
// should_fail_typecheck with insta snapshot, one should_typecheck).
// Snapshot infra is Rust-only; the positive case is a pure compile-time
// check with no runtime exercise. See PORT_SKIPPED.md.
//
// In place of those, this file exercises the runtime-observable subset of
// std:array that is currently runnable via standalone wasmtime: `length`
// (resolved via `__nx_array_length` external).
//
// `MirArray` atoms use a canonical packed `(ptr<<32) | len` layout, so an
// asserted value can carry a pointer-shaped wrong value. nexus-1a5t was a
// concrete false-pass against this fixture's earlier `1 / (n - K)` shape:
// the buggy `__nx_array_length` returned ~65000 and `1 / 65000 == 0` did
// not trap. The current `test_assert.assert_eq_i64` form catches any
// non-matching value, including pointer-shaped ones.
//
// `import * as array from "std:array"` is avoided because the self-host
// parser does not yet accept `arr[idx] <- val` (used by `array.set`),
// which blocks the whole module from parsing; declare `length` directly
// against `std:collections` so this fixture stays runnable via
// `./nexus build` standalone. Tracked separately as a parser gap.
import * as test_assert from "std:test/assert"
import external "nexus:intrinsic"
external length = "array_length" : <T>(arr: &[| T |]) -> i64

let main = fn () -> unit throws { Exn } do
  let a = [| 10, 20, 30 |]
  let a_ref = &a
  let n = length(arr: a_ref)
  // Consume each linear array *before* the throwable asserts: on a throw
  // path the array must not be left live (E0540). `n`/`m` are primitives
  // and survive the consumption.
  a

  let single = [| 42 |]
  let single_ref = &single
  let m = length(arr: single_ref)
  single

  test_assert.assert_eq_i64(actual: n, expected: 3, label: "array length: [|10,20,30|]")
  test_assert.assert_eq_i64(actual: m, expected: 1, label: "array length: [|42|]")
  return ()
end
