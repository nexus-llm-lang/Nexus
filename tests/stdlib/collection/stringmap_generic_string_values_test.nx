// Exercises the generic %StringMap<V> with string values (V = string), proving
// the value channel is no longer pinned to i64. Covers put / get / get_or /
// contains_key / remove / size on a non-i64 value type.
import * as test_assert from "std:test/assert"
import * as smap from "std:stringmap"

let main = fn () -> unit throws { Exn } do
  let m0 = smap.empty()
  let m1 = smap.put(map: m0, key: "lang", value: "nexus")
  let m2 = smap.put(map: m1, key: "kind", value: "compiler")
  let m3 = smap.put(map: m2, key: "lang", value: "nexus2") // overwrite
  let got_lang = smap.get(map: &m3, key: "lang")
  let got_missing = smap.get(map: &m3, key: "absent")
  let or_default = smap.get_or(map: &m3, key: "absent", default: "fallback")
  let or_present = smap.get_or(map: &m3, key: "kind", default: "fallback")
  let has_kind = smap.contains_key(map: &m3, key: "kind")
  let m4 = smap.remove(map: m3, key: "kind")
  let sz = smap.size(map: &m4)
  smap.free(map: m4)

  test_assert.assert_true(cond: has_kind, label: "contains_key(\"kind\")")
  test_assert.assert_eq_string(
    actual: or_default,
    expected: "fallback",
    label: "get_or returns the typed string default for an absent key"
  )
  test_assert.assert_eq_string(
    actual: or_present,
    expected: "compiler",
    label: "get_or returns the stored string for a present key"
  )
  test_assert.assert_eq_i64(actual: sz, expected: 1, label: "size after remove(\"kind\") is 1")
  match got_missing do
    | Found(value: _) -> throw RuntimeError(val: "expected Missing for absent key")
    | Missing -> ()
  end
  match got_lang do
    | Found(value: v) ->
      test_assert.assert_eq_string(
        actual: v,
        expected: "nexus2",
        label: "get(\"lang\") reflects the overwrite"
      )
    | Missing -> throw RuntimeError(val: "expected Found for \"lang\"")
  end
  return ()
end
