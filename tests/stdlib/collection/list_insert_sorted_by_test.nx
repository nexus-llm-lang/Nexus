// list.insert_sorted_by inserts an element into an already-sorted list using a
// caller-supplied `lt` comparator, placing the new element before the first
// element it compares strictly-less-than (so an equal value lands *after* the
// existing one — stable — and duplicates are kept).
import * as test_assert from "std:test/assert"
import * as list from "std:list"

let lt_i64 = fn (a: i64, b: i64) -> bool do return a < b end

let main = fn () -> unit throws { Exn } do
  // Insert in the middle.
  test_assert.assert_eq_i64_list(
    actual: list.insert_sorted_by(x: 3, xs: [ 1, 2, 4, 5 ], lt: lt_i64),
    expected: [ 1, 2, 3, 4, 5 ],
    label: "insert 3 into [1,2,4,5]"
  )
  // Insert at the front.
  test_assert.assert_eq_i64_list(
    actual: list.insert_sorted_by(x: 0, xs: [ 1, 2, 3 ], lt: lt_i64),
    expected: [ 0, 1, 2, 3 ],
    label: "insert 0 at front"
  )
  // Insert at the back.
  test_assert.assert_eq_i64_list(
    actual: list.insert_sorted_by(x: 9, xs: [ 1, 2, 3 ], lt: lt_i64),
    expected: [ 1, 2, 3, 9 ],
    label: "insert 9 at back"
  )
  // Insert into the empty list.
  test_assert.assert_eq_i64_list(
    actual: list.insert_sorted_by(x: 7, xs: [], lt: lt_i64),
    expected: [ 7 ],
    label: "insert 7 into []"
  )
  // Equal element is kept and lands after the existing one (stable, no dedup).
  test_assert.assert_eq_i64_list(
    actual: list.insert_sorted_by(x: 2, xs: [ 1, 2, 3 ], lt: lt_i64),
    expected: [ 1, 2, 2, 3 ],
    label: "duplicate 2 kept after existing 2"
  )
  return ()
end
