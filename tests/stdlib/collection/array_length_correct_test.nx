// Regression for nexus-qg7e: `__nx_array_length` returned garbage on
// self-host-allocated arrays because `MirArray` lowered to a `LirExprRecord`
// whose result atom was `i64.extend_i32_u(ptr)` (ptr in the low 32 bits, zero
// in the high 32 bits) while `emit_external_arg(TyArray)` decoded the atom
// as packed `(ptr<<32) | len`. The host stub
// `__nx_array_length(_ptr: i32, len: i32) -> i64` then returned the
// `len` argument — which carried the raw pointer instead of the count.
//
// Fix: align `LirExprRecord` array codegen with the canonical packed atom
// layout — after building `[tag | e0 | e1 | ... | e_{n-1}]` on the heap,
// finish with `(ptr<<32) | n` instead of `i64.extend_i32_u(ptr)`. The
// internal `__array_get` intrinsic extracts the pointer from the upper
// 32 bits via `(arr_atom >> 32) -> i32_wrap`.
//
// Validation strategy: assert `length(arr)` returns the EXACT element
// count for arrays of varying sizes. A `1 / (n - K)` form would only trap
// when `n == K`, so a returned pointer slipping past the check would look
// like a green test (the original misbehavior — see nexus-1a5t false-pass).
// `test_assert.assert_eq_i64` catches any non-matching value, pointer-
// shaped or otherwise.
//
// std:array's `length` is the canonical entry point, but importing the full
// module currently fails to parse via the self-host (nxlib/stdlib/array.nx
// uses `arr[idx] <- val` in `set`, which the self-host parser does not yet
// accept — orthogonal parser gap). Declare the external directly here so
// the fixture exercises the array-length atom layout without pulling in
// unparseable stdlib code.
import * as test_assert from "std:test/assert"
import external "nexus:intrinsic"
external length = "array_length" : <T>(arr: &[| T |]) -> i64

let main = fn () -> unit throws { Exn } do
  // Read each length (a borrow), then consume the linear array *before*
  // the throwable asserts: on a throw path no array may be left live
  // (E0540). The `n`/`m`/`k` counts are primitives and survive consumption.
  // Three-element array literal: length must be 3.
  let a = [| 10, 20, 30 |]
  let a_ref = &a
  let n = length(arr: a_ref)
  a

  // Single-element array literal: length must be 1.
  let single = [| 42 |]
  let single_ref = &single
  let m = length(arr: single_ref)
  single

  // Five-element array literal exercises a different len encoding.
  let five = [| 1, 2, 3, 4, 5 |]
  let five_ref = &five
  let k = length(arr: five_ref)
  five

  test_assert.assert_eq_i64(actual: n, expected: 3, label: "array length: [|10,20,30|]")
  test_assert.assert_eq_i64(actual: m, expected: 1, label: "array length: [|42|]")
  test_assert.assert_eq_i64(actual: k, expected: 5, label: "array length: [|1..5|]")
  return ()
end
