// Port of bootstrap/tests/stdlib/list.rs::length_tail_recursive_deep.
// list.length must be tail-safe at 50k elements.
import * as test_assert from "std:test/assert"
import * as list from "std:list"

let make_list = fn (n: i64, acc: [ i64 ]) -> [ i64 ] do
  if n == 0 then return acc end
  return make_list(n: n - 1, acc: n :: acc)
end

let main = fn () -> unit throws { Exn } do
  let xs = make_list(n: 50000, acc: [])
  test_assert.assert_eq_i64(
    actual: list.length(xs),
    expected: 50000,
    label: "length of 50k-element list"
  )
  return ()
end
