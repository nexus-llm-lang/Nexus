// Persistent Map<K,V> exercised with i64 keys: the same generic structure
// keys on i64 via the i64_map dictionary, proving key-genericity (string and
// i64 are both instantiations of one Map). Covers insert/get/remove/size.
import * as test_assert from "std:test/assert"
import * as map from "std:collection/map"
import { Some, None } from "std:option"

let fill = fn (m: map.Map<i64, i64>, i: i64, n: i64) -> map.Map<i64, i64> do
  if i >= n then return m end
  return fill(m: map.insert(m, k: i, v: i * 10), i: i + 1, n)
end

let verify = fn (m: map.Map<i64, i64>, i: i64, n: i64) -> bool do
  if i >= n then return true end
  if map.get_or(m, k: i, default: -1) != i * 10 then return false end
  return verify(m, i: i + 1, n)
end

let main = fn () -> unit throws { Exn } do
  // Enough keys to force trie branch splits and multi-level descent.
  let n = 300
  let built = fill(m: map.i64_map(), i: 0, n)
  test_assert.assert_eq_i64(actual: map.size(m: built), expected: 300, label: "size 300")
  test_assert.assert_true(cond: verify(m: built, i: 0, n), label: "all keys map to key*10")

  match map.get(m: built, k: 150) do
    | Some(val: v) -> test_assert.assert_eq_i64(actual: v, expected: 1500, label: "get 150 -> 1500")
    | None -> test_assert.assert_true(cond: false, label: "150 present")
  end
  match map.get(m: built, k: 999999) do
    | Some(_) -> test_assert.assert_true(cond: false, label: "absent i64 key")
    | None -> test_assert.assert_true(cond: true, label: "absent -> None")
  end

  // Overwrite does not grow the count.
  let over = map.insert(m: built, k: 42, v: -1)
  test_assert.assert_eq_i64(
    actual: map.size(m: over),
    expected: 300,
    label: "size unchanged on overwrite"
  )
  test_assert.assert_eq_i64(
    actual: map.get_or(m: over, k: 42, default: 0),
    expected: -1,
    label: "overwrite took"
  )

  // Remove a present and an absent key.
  let r1 = map.remove(m: built, k: 7)
  test_assert.assert_eq_i64(
    actual: map.size(m: r1),
    expected: 299,
    label: "size 299 after removing 7"
  )
  test_assert.assert_true(cond: map.contains(m: r1, k: 7) == false, label: "7 removed")
  let r2 = map.remove(m: r1, k: 999999)
  test_assert.assert_eq_i64(
    actual: map.size(m: r2),
    expected: 299,
    label: "removing absent key keeps size"
  )
  return ()
end
