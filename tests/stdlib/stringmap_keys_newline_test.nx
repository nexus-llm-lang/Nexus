// Regression test for nexus-h5e5: keys() must survive keys that contain
// a literal newline character.  The old newline-join encoding would split
// such a key into multiple fragments; the new length-prefixed encoding is
// unambiguous.
import * as test_assert from "std:test/assert"
import * as smap from "std:stringmap"

let list_length = fn <T>(xs: [ T ]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + list_length(xs: rest)
  end
end

let list_contains = fn (xs: [ string ], target: string) -> bool do
  match xs do
    | [] -> return false
    | h :: rest ->
      if h == target then return true end
      return list_contains(xs: rest, target)
  end
end

let main = fn () -> unit throws { Exn } do
  let m0 = smap.empty()
  let m1 = smap.put(map: m0, key: "a\nb", value: 1)
  let m2 = smap.put(map: m1, key: "c",   value: 2)
  let ks = smap.keys(map: &m2)
  let sz = smap.size(map: &m2)
  smap.free(map: m2)
  test_assert.assert_eq_i64(
    actual: sz,
    expected: 2,
    label: "size with newline key"
  )
  test_assert.assert_eq_i64(
    actual: list_length(xs: ks),
    expected: 2,
    label: "keys() length with newline key"
  )
  test_assert.assert_true(
    cond: list_contains(xs: ks, target: "a\nb"),
    label: "keys() contains newline key"
  )
  test_assert.assert_true(
    cond: list_contains(xs: ks, target: "c"),
    label: "keys() contains plain key"
  )
  return ()
end
