// Port of bootstrap/tests/stdlib/json.rs::json_lsp_initialize_request_roundtrip.
// LSP `initialize` request payload (nested objects with mixed value kinds)
// round-trips through parse + serialize on its canonical compact form.
import * as test_assert from "std:test/assert"
import { parse, serialize } from "std:json"

let main = fn () -> unit throws { Exn } do
  let raw = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"processId\":4242,\"rootUri\":\"file:///tmp/proj\",\"capabilities\":{\"textDocument\":{\"synchronization\":{\"didSave\":true}}}}}"
  test_assert.assert_eq_string(actual: serialize(v: parse(s: raw)), expected: raw, label: "initialize roundtrip")
  return ()
end
