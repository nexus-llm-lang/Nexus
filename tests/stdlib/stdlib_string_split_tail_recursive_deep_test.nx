// Port of bootstrap/tests/stdlib/string.rs::split_tail_recursive_deep.
// 50_000 repeats of "a," → split on "," → 50_001 segments. Must not
// overflow the wasm stack.
import { split, repeat, length } from "std:str"
import * as list from "std:list"

let body = fn () -> unit throws { Exn } do
  let s = repeat(s: "a,", n: 50000)
  let segs = split(s: s, sep: ",")
  let n = list.length(xs: segs)
  if n != 50001 then raise RuntimeError(val: "expected 50001 segments from split") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
