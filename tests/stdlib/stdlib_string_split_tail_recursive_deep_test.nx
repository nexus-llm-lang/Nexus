// Port of bootstrap/tests/stdlib/string.rs::split_tail_recursive_deep.
// 50_000 repeats of "a," → split on "," → 50_001 segments. Must not
// overflow the wasm stack.
import * as test_assert from "std:test/assert"
import { split, repeat } from "std:str"
import * as list from "std:list"

let main = fn () -> unit throws { Exn } do
  let s = repeat(s: "a,", n: 50000)
  let segs = split(s, sep: ",")
  test_assert.assert_eq_i64(
    actual: list.length(xs: segs),
    expected: 50001,
    label: "length(split(50000x \"a,\", \",\"))"
  )
  return ()
end
