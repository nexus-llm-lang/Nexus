// Port of bootstrap/tests/stdlib/fs.rs::fs_remove_file_updates_exists.
// Remove a file and verify exists returns false afterwards. Original
// used TempDir; here a fixed path under /tmp (mounted by bootstrap.sh's
// wasmtime --dir flag).
import { Fs }, * as fs_mod from "std:fs"

let body = fn () -> unit require { PermFs } throws { Exn } do
  inject fs_mod.system_handler do
    let dir = "/tmp/nx_dvr66_remove"
    let file = "/tmp/nx_dvr66_remove/trash.txt"
    Fs.create_dir_all(path: dir)
    Fs.write_string(path: file, content: "x")
    Fs.remove_file(path: file)
    let exists = Fs.exists(path: file)
    if exists then raise RuntimeError(val: "file should not exist") end
    return ()
  end
end

let safe_run = fn () -> i64 require { PermFs } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs } do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
