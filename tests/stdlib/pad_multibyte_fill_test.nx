// Regression test for nexus-eylm: pad_left/pad_right with multi-byte fill must
// allocate fill_byte_len * pad_chars bytes, not pad_chars bytes.
import * as test_assert from "std:test/assert"
import { pad_left, pad_right, length, byte_length } from "std:str"

let main = fn () -> unit throws { Exn } do
  /* "€" is 3 bytes (UTF-8: 0xE2 0x82 0xAC).
     pad_left("x", 5, "€"): 1 char + 4 pad chars = 5 chars, 1 + 12 = 13 bytes. */
  let pl = pad_left(s: "x", width: 5, fill: "€")
  test_assert.assert_eq_i64(actual: length(s: pl), expected: 5, label: "pad_left char count")
  test_assert.assert_eq_i64(actual: byte_length(s: pl), expected: 13, label: "pad_left byte count")

  /* pad_right("x", 5, "€"): same counts, fill appended on right. */
  let pr = pad_right(s: "x", width: 5, fill: "€")
  test_assert.assert_eq_i64(actual: length(s: pr), expected: 5, label: "pad_right char count")
  test_assert.assert_eq_i64(actual: byte_length(s: pr), expected: 13, label: "pad_right byte count")

  /* ASCII fill must still work correctly (no regression). */
  let pa = pad_left(s: "42", width: 5, fill: "0")
  test_assert.assert_eq_i64(actual: length(s: pa), expected: 5, label: "pad_left ASCII char count")
  test_assert.assert_eq_i64(actual: byte_length(s: pa), expected: 5, label: "pad_left ASCII byte count")
  return ()
end
