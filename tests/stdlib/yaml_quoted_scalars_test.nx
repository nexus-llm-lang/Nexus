// YAML quoted scalar styles: single-quoted, double-quoted with escapes.
import * as test_assert from "std:test/assert"
import { parse, YamlValue, YamlString } from "std:yaml"

let main = fn () -> unit throws { Exn } do
  // Single-quoted scalar: '' → single quote.
  let sq = parse(s: "'it''s a test'")
  match sq do
    | YamlString(val: s) ->
      test_assert.assert_eq_string(
        actual: s,
        expected: "it's a test",
        label: "single-quoted '' escape"
      )
    | _ -> throw RuntimeError(val: "expected YamlString for single-quoted")
  end
  // Double-quoted scalar with \n, \t escapes.
  let dq = parse(s: "\"hello\\nworld\\t!\"")
  match dq do
    | YamlString(val: s) ->
      test_assert.assert_eq_string(
        actual: s,
        expected: "hello\nworld\t!",
        label: "double-quoted escape sequences"
      )
    | _ -> throw RuntimeError(val: "expected YamlString for double-quoted")
  end
  // Double-quoted with \uXXXX escape.
  let dq_u = parse(s: "\"caf\\u00e9\"")
  match dq_u do
    | YamlString(val: s) ->
      // é is U+00E9, UTF-8 bytes 0xC3 0xA9.
      test_assert.assert_eq_string(actual: s, expected: "café", label: "double-quoted \\u escape")
    | _ -> throw RuntimeError(val: "expected YamlString for unicode escape")
  end
  // Plain scalar that contains no special markers stays a string.
  let plain = parse(s: "hello world")
  match plain do
    | YamlString(val: s) ->
      test_assert.assert_eq_string(actual: s, expected: "hello world", label: "plain scalar string")
    | _ -> throw RuntimeError(val: "expected YamlString for plain scalar")
  end
  return ()
end
