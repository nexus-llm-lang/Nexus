// Port of bootstrap/tests/stdlib/json.rs::json_trailing_data_rejected.
// Bytes after a complete top-level value are rejected; parse must raise.
import * as test_assert from "std:test/assert"
import { parse } from "std:json"

let raises_parse = fn (s: string) -> bool do
  try
    let _ = parse(s)
    return false
  catch _ ->
    return true
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_true(
    cond: raises_parse(s: "1 2"),
    label: "parse(\"1 2\") rejects trailing data"
  )
  return ()
end
