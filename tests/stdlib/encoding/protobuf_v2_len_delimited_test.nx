// protobuf_v2: length-delimited field roundtrip (empty, ASCII, binary).
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { decode, encode, PbField, PbThrow, PbLenDelimited } from "std:protobuf/v2"

// `decode` is throwable and the encoded buffer is live across it; take the
// buffer by move so it is freed on BOTH the success and the throw path (E0540).
let decode_and_free = fn (enc: %bb.ByteBuffer) -> [ PbField ] throws { PbThrow } do
  try
    let fields = decode(buf: &enc)
    bb.free(buf: %enc)
    return fields
  catch e ->
    bb.free(buf: %enc)
    throw e
  end
end

let roundtrip_len = fn (payload: string, label: string) -> unit throws { Exn } do
  let %dbuf = bb.empty()
  let %dbuf2 = bb.push_string(buf: %dbuf, s: payload)
  let fields_in = [ PbField(field_number: 1, value: PbLenDelimited(data: %dbuf2)) ]
  let %enc = encode(fields: fields_in)
  let fields_out = decode_and_free(enc: %enc)
  match fields_out do
    | PbField(field_number: fn1, value: PbLenDelimited(data: got_buf)) :: [] ->
      // Read the (borrowed) contents into a primitive string and free the
      // linear buffer *before* the throwable asserts: holding `%got_buf`
      // live across a throwable call would leak it on the throw path (E0540).
      let got_str = bb.to_string(buf: &got_buf)
      bb.free(buf: %got_buf)
      test_assert.assert_eq_i64(actual: fn1, expected: 1, label: label ++ ":fn")
      test_assert.assert_eq_string(actual: got_str, expected: payload, label: label ++ ":content")
    | _ -> test_assert.assert_true(cond: false, label: label ++ ":shape")
  end
  return ()
end

let main = fn () -> unit throws { Exn } do
  roundtrip_len(payload: "",         label: "len_empty")
  roundtrip_len(payload: "hello",    label: "len_ascii")
  roundtrip_len(payload: "nexus pb", label: "len_space")
  return ()
end
