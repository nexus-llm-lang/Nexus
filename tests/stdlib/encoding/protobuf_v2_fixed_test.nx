// protobuf_v2: fixed32 and fixed64 roundtrip.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { decode, encode, PbField, PbFixed32, PbFixed64 } from "std:protobuf/v2"

let roundtrip_fixed32 = fn (v: i64, label: string) -> unit throws { Exn } do
  let fields_in = [ PbField(field_number: 1, value: PbFixed32(val: v)) ]
  let %enc = encode(fields: fields_in)
  let fields_out = decode(buf: &enc)
  bb.free(buf: %enc)
  match fields_out do
    | PbField(field_number: fn1, value: PbFixed32(val: got)) :: [] ->
      test_assert.assert_eq_i64(actual: fn1, expected: 1, label: label ++ ":fn")
      let expected = v & 4294967295
      test_assert.assert_eq_i64(actual: got & 4294967295, expected, label: label ++ ":val")
    | _ -> test_assert.assert_true(cond: false, label: label ++ ":shape")
  end
  return ()
end

let roundtrip_fixed64 = fn (v: i64, label: string) -> unit throws { Exn } do
  let fields_in = [ PbField(field_number: 2, value: PbFixed64(val: v)) ]
  let %enc = encode(fields: fields_in)
  let fields_out = decode(buf: &enc)
  bb.free(buf: %enc)
  match fields_out do
    | PbField(field_number: fn2, value: PbFixed64(val: got)) :: [] ->
      test_assert.assert_eq_i64(actual: fn2, expected: 2, label: label ++ ":fn")
      test_assert.assert_eq_i64(actual: got, expected: v, label: label ++ ":val")
    | _ -> test_assert.assert_true(cond: false, label: label ++ ":shape")
  end
  return ()
end

let main = fn () -> unit throws { Exn } do
  roundtrip_fixed32(v: 0,          label: "f32_zero")
  roundtrip_fixed32(v: 1,          label: "f32_one")
  roundtrip_fixed32(v: 2147483647, label: "f32_i32max")
  roundtrip_fixed64(v: 0,          label: "f64_zero")
  roundtrip_fixed64(v: 1,          label: "f64_one")
  roundtrip_fixed64(v: 9223372036854775807, label: "f64_i64max")
  return ()
end
