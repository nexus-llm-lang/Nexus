// HCL heredoc: <<EOF and <<-EOF (indent-stripping variant).
import * as test_assert from "std:test/assert"
import * as str from "std:str"
import {
  parse,
  HclBody,
  HclItem,
  HclAttr,
  HclValue,
  HString,
  HNull,
  Attribute
} from "std:encoding/hcl"

let count_items = fn (items: [ HclItem ]) -> i64 do
  match items do
    | [] -> return 0
    | _ :: rest -> return 1 + count_items(items: rest)
  end
end

let first_item = fn (items: [ HclItem ]) -> HclItem throws { Exn } do
  match items do
    | x :: _ -> return x
    | [] ->
      test_assert.assert_true(cond: false, label: "no items")
      return Attribute(attr: HclAttr(name: "", value: HNull))
  end
end

let second_item = fn (items: [ HclItem ]) -> HclItem throws { Exn } do
  match items do
    | _ :: x :: _ -> return x
    | _ ->
      test_assert.assert_true(cond: false, label: "no second item")
      return Attribute(attr: HclAttr(name: "", value: HNull))
  end
end

let main = fn () -> unit throws { Exn } do
  // Basic heredoc <<EOF.
  let doc1 =
    "script = <<EOF\n" ++
    "#!/bin/bash\n" ++
    "echo hello\n" ++
    "EOF\n"

  let HclBody(items: xs1) = parse(s: doc1)
  test_assert.assert_eq_i64(actual: count_items(items: xs1), expected: 1, label: "1 heredoc attr")

  let item0 = first_item(items: xs1)
  match item0 do
    | Attribute(attr: HclAttr(name: k, value: HString(val: sv))) ->
      test_assert.assert_eq_string(actual: k, expected: "script", label: "heredoc key")
      // Content should contain both lines followed by newlines.
      test_assert.assert_true(cond: str.contains(s: sv, sub:"#!/bin/bash"), label: "heredoc line1")
      test_assert.assert_true(cond: str.contains(s: sv, sub:"echo hello"), label: "heredoc line2")
    | _ -> test_assert.assert_true(cond: false, label: "item0 must be heredoc string attr")
  end

  // Indent-stripping heredoc <<-EOF.
  let doc2 =
    "policy = <<-POLICY\n" ++
    "  allow read\n" ++
    "  deny write\n" ++
    "  POLICY\n"

  let HclBody(items: xs2) = parse(s: doc2)
  test_assert.assert_eq_i64(actual: count_items(items: xs2), expected: 1, label: "1 indent-strip heredoc")

  let item1 = first_item(items: xs2)
  match item1 do
    | Attribute(attr: HclAttr(name: k, value: HString(val: sv))) ->
      test_assert.assert_eq_string(actual: k, expected: "policy", label: "policy key")
      test_assert.assert_true(cond: str.contains(s: sv, sub:"allow read"), label: "indent-stripped line1")
      test_assert.assert_true(cond: str.contains(s: sv, sub:"deny write"), label: "indent-stripped line2")
    | _ -> test_assert.assert_true(cond: false, label: "item1 must be heredoc string")
  end

  return ()
end
