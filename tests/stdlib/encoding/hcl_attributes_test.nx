// HCL attributes: parse top-level key=value pairs of various primitive types.
import * as test_assert from "std:test/assert"
import {
  parse,
  HclBody,
  HclItem,
  HclAttr,
  HclValue,
  HString,
  HNumber,
  HBool,
  HNull,
  Attribute
} from "std:encoding/hcl"

let count_items = fn (items: [ HclItem ]) -> i64 do
  match items do
    | [] -> return 0
    | _ :: rest -> return 1 + count_items(items: rest)
  end
end

let first_item = fn (items: [ HclItem ]) -> HclItem throws { Exn } do
  match items do
    | x :: _ -> return x
    | [] ->
      test_assert.assert_true(cond: false, label: "no items")
      return Attribute(attr: HclAttr(name: "", value: HNull))
  end
end

let nth_item = fn (items: [ HclItem ], n: i64) -> HclItem throws { Exn } do
  if n == 0 then return first_item(items) end
  match items do
    | _ :: rest -> return nth_item(items: rest, n: n - 1)
    | [] ->
      test_assert.assert_true(cond: false, label: "index out of range")
      return Attribute(attr: HclAttr(name: "", value: HNull))
  end
end

let main = fn () -> unit throws { Exn } do
  let doc =
    "name = \"terraform\"\n" ++
    "version = 1\n" ++
    "enabled = true\n" ++
    "disabled = false\n" ++
    "nothing = null\n" ++
    "pi = 3.14\n"

  let HclBody(items: xs) = parse(s: doc)

  test_assert.assert_eq_i64(actual: count_items(items: xs), expected: 6, label: "6 attributes")

  // First: name = "terraform"
  let item0 = nth_item(items: xs, n: 0)
  match item0 do
    | Attribute(attr: HclAttr(name: k, value: HString(val: sv))) ->
      test_assert.assert_eq_string(actual: k, expected: "name", label: "attr name")
      test_assert.assert_eq_string(actual: sv, expected: "terraform", label: "attr value string")
    | _ -> test_assert.assert_true(cond: false, label: "item0 must be string attr")
  end

  // Second: version = 1
  let item1 = nth_item(items: xs, n: 1)
  match item1 do
    | Attribute(attr: HclAttr(name: k, value: HNumber(val: nv))) ->
      test_assert.assert_eq_string(actual: k, expected: "version", label: "version key")
      test_assert.assert_true(cond: nv ==. 1.0, label: "version = 1")
    | _ -> test_assert.assert_true(cond: false, label: "item1 must be number attr")
  end

  // Third: enabled = true
  let item2 = nth_item(items: xs, n: 2)
  match item2 do
    | Attribute(attr: HclAttr(name: k, value: HBool(val: bv))) ->
      test_assert.assert_eq_string(actual: k, expected: "enabled", label: "enabled key")
      test_assert.assert_true(cond: bv, label: "enabled = true")
    | _ -> test_assert.assert_true(cond: false, label: "item2 must be bool attr")
  end

  // Fourth: disabled = false
  let item3 = nth_item(items: xs, n: 3)
  match item3 do
    | Attribute(attr: HclAttr(name: k, value: HBool(val: bv))) ->
      test_assert.assert_eq_string(actual: k, expected: "disabled", label: "disabled key")
      test_assert.assert_true(cond: !bv, label: "disabled = false")
    | _ -> test_assert.assert_true(cond: false, label: "item3 must be bool attr")
  end

  // Fifth: nothing = null
  let item4 = nth_item(items: xs, n: 4)
  match item4 do
    | Attribute(attr: HclAttr(name: k, value: HNull)) ->
      test_assert.assert_eq_string(actual: k, expected: "nothing", label: "null key")
    | _ -> test_assert.assert_true(cond: false, label: "item4 must be null attr")
  end

  // Sixth: pi = 3.14
  let item5 = nth_item(items: xs, n: 5)
  match item5 do
    | Attribute(attr: HclAttr(name: k, value: HNumber(val: nv))) ->
      test_assert.assert_eq_string(actual: k, expected: "pi", label: "pi key")
      test_assert.assert_true(cond: nv >. 3.13 && nv <. 3.15, label: "pi ~ 3.14")
    | _ -> test_assert.assert_true(cond: false, label: "item5 must be float attr")
  end

  return ()
end
