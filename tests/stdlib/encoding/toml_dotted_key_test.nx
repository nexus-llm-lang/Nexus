// TOML dotted-key round-trip: [a.b] / [a.c] sections and a.b = 1 inline
// assignment must produce ONE table `a` with nested sub-tables, not flat
// "a.b" string keys.
import * as test_assert from "std:test/assert"
import { parse, serialize, TomlTable, TomlInt, TomlField, TomlValue } from "std:toml"

// Walk a field list and find a TomlTable child by key.
let find_table = fn (fields: [ TomlField ], key: string) -> [ TomlField ] throws { Exn } do
  match fields do
    | [] ->
      test_assert.assert_true(cond: false, label: "key not found: " ++ key)
      return []
    | TomlField(key: k, value: v) :: rest ->
      if k == key then
        match v do
          | TomlTable(fields: sub) -> return sub
          | _ ->
            test_assert.assert_true(cond: false, label: "expected table at key: " ++ key)
            return []
        end
      end
      return find_table(fields: rest, key)
  end
end

// Walk a field list and find an integer child by key.
let find_int = fn (fields: [ TomlField ], key: string) -> i64 throws { Exn } do
  match fields do
    | [] ->
      test_assert.assert_true(cond: false, label: "int key not found: " ++ key)
      return 0
    | TomlField(key: k, value: v) :: rest ->
      if k == key then
        match v do
          | TomlInt(val: n) -> return n
          | _ ->
            test_assert.assert_true(cond: false, label: "expected int at key: " ++ key)
            return 0
        end
      end
      return find_int(fields: rest, key)
  end
end

let count_fields = fn (fields: [ TomlField ]) -> i64 do
  match fields do
    | [] -> return 0
    | _ :: rest -> return 1 + count_fields(fields: rest)
  end
end

let main = fn () -> unit throws { Exn } do
  // ── Test 1: [a.b] and [a.c] create one table a with two sub-tables ────────
  let doc1 =
    "[a.b]\n" ++
    "x = 1\n" ++
    "[a.c]\n" ++
    "y = 2\n"
  let root1 = parse(s: doc1)
  match root1 do
    | TomlTable(fields: top) ->
      // Top-level must have ONE field: "a"
      test_assert.assert_eq_i64(
        actual: count_fields(fields: top),
        expected: 1,
        label: "top has one field (a)"
      )
      // a must be a table containing b and c
      let a_fields = find_table(fields: top, key: "a")
      test_assert.assert_eq_i64(
        actual: count_fields(fields: a_fields),
        expected: 2,
        label: "a has two sub-tables (b, c)"
      )
      // b.x = 1
      let b_fields = find_table(fields: a_fields, key: "b")
      let x = find_int(fields: b_fields, key: "x")
      test_assert.assert_eq_i64(actual: x, expected: 1, label: "a.b.x = 1")
      // c.y = 2
      let c_fields = find_table(fields: a_fields, key: "c")
      let y = find_int(fields: c_fields, key: "y")
      test_assert.assert_eq_i64(actual: y, expected: 2, label: "a.c.y = 2")
    | _ -> test_assert.assert_true(cond: false, label: "root must be table (test 1)")
  end

  // ── Test 2: dotted inline key a.b = 1 produces nested table ───────────────
  let doc2 = "a.b = 42\n"
  let root2 = parse(s: doc2)
  match root2 do
    | TomlTable(fields: top) ->
      test_assert.assert_eq_i64(
        actual: count_fields(fields: top),
        expected: 1,
        label: "top has one field (a) for inline dotted"
      )
      let a2 = find_table(fields: top, key: "a")
      let bval = find_int(fields: a2, key: "b")
      test_assert.assert_eq_i64(actual: bval, expected: 42, label: "a.b = 42")
    | _ -> test_assert.assert_true(cond: false, label: "root must be table (test 2)")
  end

  // ── Test 3: non-dotted sections still round-trip correctly ────────────────
  let doc3 =
    "[server]\n" ++
    "port = 8080\n"
  let root3 = parse(s: doc3)
  match root3 do
    | TomlTable(fields: top) ->
      test_assert.assert_eq_i64(
        actual: count_fields(fields: top),
        expected: 1,
        label: "non-dotted section: one top field"
      )
      let srv = find_table(fields: top, key: "server")
      let port = find_int(fields: srv, key: "port")
      test_assert.assert_eq_i64(actual: port, expected: 8080, label: "server.port = 8080")
    | _ -> test_assert.assert_true(cond: false, label: "root must be table (test 3)")
  end

  // ── Test 4: serialize round-trip preserves nested structure ───────────────
  let ser4 = serialize(v: root1)
  let re4 = parse(s: ser4)
  match re4 do
    | TomlTable(fields: re_top) ->
      test_assert.assert_eq_i64(
        actual: count_fields(fields: re_top),
        expected: 1,
        label: "round-trip: top still has one field (a)"
      )
      let re_a = find_table(fields: re_top, key: "a")
      let re_b = find_table(fields: re_a, key: "b")
      let re_x = find_int(fields: re_b, key: "x")
      test_assert.assert_eq_i64(actual: re_x, expected: 1, label: "round-trip: a.b.x = 1")
    | _ -> test_assert.assert_true(cond: false, label: "re-parsed must be table")
  end

  return ()
end
