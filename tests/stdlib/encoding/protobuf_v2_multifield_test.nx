// protobuf_v2: multi-field message roundtrip — decode then re-encode == same bytes.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { decode, encode, PbField, PbThrow, PbVarint, PbFixed32 } from "std:protobuf/v2"

// Primitive snapshot of the roundtrip comparison, lifted out of the linear
// encoded buffers so the asserts can run after the buffers are freed.
type RoundtripCmp = RoundtripCmp(bytes_eq: bool, len1: i64, len2: i64)

// Decode then re-encode `%enc1`, compare, and free both buffers — returning
// only primitives. `decode` and `encode` are throwable and `%enc1` is live
// across them, so take `%enc1` by move and free it (and `%enc2` once built) on
// the throw path before rethrowing (E0540).
let roundtrip_compare = fn (enc1: %bb.ByteBuffer) -> RoundtripCmp throws { PbThrow } do
  try
    let decoded = decode(buf: &enc1)
    let %enc2 = encode(fields: decoded)
    let bytes_eq = buf_eq(a: &enc1, b: &enc2)
    let len1 = bb.length(buf: &enc1)
    let len2 = bb.length(buf: &enc2)
    bb.free(buf: %enc1)
    bb.free(buf: %enc2)
    return RoundtripCmp(bytes_eq, len1, len2)
  catch e ->
    bb.free(buf: %enc1)
    throw e
  end
end

let buf_eq = fn (a: &bb.ByteBuffer, b: &bb.ByteBuffer) -> bool do
  let la = bb.length(buf: a)
  let lb = bb.length(buf: b)
  if la != lb then return false end
  return buf_eq_go(a, b, idx: 0, len: la)
end

let buf_eq_go = fn (a: &bb.ByteBuffer, b: &bb.ByteBuffer, idx: i64, len: i64) -> bool do
  if idx >= len then return true end
  let ba = bb.get_byte(buf: a, idx)
  let bb_byte = bb.get_byte(buf: b, idx)
  if ba != bb_byte then return false end
  return buf_eq_go(a, b, idx: idx + 1, len)
end

let main = fn () -> unit throws { Exn } do
  let fields = [
    PbField(field_number: 1, value: PbVarint(val: 42)),
    PbField(field_number: 2, value: PbFixed32(val: 7)),
    PbField(field_number: 3, value: PbVarint(val: 300))
  ]

  let %enc1 = encode(fields)
  // Decode + re-encode + compare + free both buffers inside a by-move helper so
  // the linear encoded buffers never sit live across the throwable decode/encode
  // calls (E0540); only the primitive comparison flows back out.
  let RoundtripCmp(bytes_eq, len1, len2) = roundtrip_compare(enc1: %enc1)

  test_assert.assert_true(cond: bytes_eq, label: "multifield_roundtrip_bytes")
  test_assert.assert_eq_i64(actual: len1, expected: len2, label: "multifield_len")

  return ()
end
