// protobuf_v2: multi-field message roundtrip — decode then re-encode == same bytes.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { decode, encode, PbField, PbVarint, PbFixed32 } from "std:protobuf/v2"

let buf_eq = fn (a: &bb.ByteBuffer, b: &bb.ByteBuffer) -> bool do
  let la = bb.length(buf: a)
  let lb = bb.length(buf: b)
  if la != lb then return false end
  return buf_eq_go(a, b, idx: 0, len: la)
end

let buf_eq_go = fn (a: &bb.ByteBuffer, b: &bb.ByteBuffer, idx: i64, len: i64) -> bool do
  if idx >= len then return true end
  let ba = bb.get_byte(buf: a, idx)
  let bb_byte = bb.get_byte(buf: b, idx)
  if ba != bb_byte then return false end
  return buf_eq_go(a, b, idx: idx + 1, len)
end

let main = fn () -> unit throws { Exn } do
  let fields = [
    PbField(field_number: 1, value: PbVarint(val: 42)),
    PbField(field_number: 2, value: PbFixed32(val: 7)),
    PbField(field_number: 3, value: PbVarint(val: 300))
  ]

  let %enc1 = encode(fields)
  let decoded = decode(buf: &enc1)
  let %enc2 = encode(fields: decoded)

  test_assert.assert_true(cond: buf_eq(a: &enc1, b: &enc2), label: "multifield_roundtrip_bytes")
  test_assert.assert_eq_i64(
    actual: bb.length(buf: &enc1),
    expected: bb.length(buf: &enc2),
    label: "multifield_len"
  )

  bb.free(buf: %enc1)
  bb.free(buf: %enc2)

  return ()
end
