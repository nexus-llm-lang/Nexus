// TOML inline table: {key = value, ...} parses to TomlTable.
import * as test_assert from "std:test/assert"
import { parse, serialize, TomlTable, TomlString, TomlInt, TomlField } from "std:toml"

let main = fn () -> unit throws { Exn } do
  let doc = "point = {x = 10, y = 20}\n"
  let root = parse(s: doc)

  match root do
    | TomlTable(fields: fs) ->
      match fs do
        | TomlField(key: k, value: TomlTable(fields: sub)) :: _ ->
          test_assert.assert_eq_string(actual: k, expected: "point", label: "outer key is point")
          let n = list_length(fields: sub)
          test_assert.assert_eq_i64(actual: n, expected: 2, label: "inline table has 2 fields")
        | _ -> test_assert.assert_true(cond: false, label: "expected TomlTable for point")
      end
    | _ -> test_assert.assert_true(cond: false, label: "root must be TomlTable")
  end

  return ()
end

let list_length = fn (fields: [ TomlField ]) -> i64 do
  match fields do
    | [] -> return 0
    | _ :: rest -> return 1 + list_length(fields: rest)
  end
end
