// protobuf_v2: varint roundtrip for values with bit 63 set (negative i64 / large uint64).
// Guards against regression of the signed predicate in push_varint that
// drops the top 57 bits of any bit-63-set value, producing a single-byte encoding.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { decode, encode, PbField, PbVarint } from "std:protobuf/v2"

// Encode a single PbVarint field and return a borrow of the encoded buffer length.
let encoded_byte_count = fn (v: i64) -> i64 throws { Exn } do
  let fields_in = [ PbField(field_number: 1, value: PbVarint(val: v)) ]
  let %enc = encode(fields: fields_in)
  // tag for field_number=1, wire_type=0 encodes as a single byte (0x08).
  let total = bb.length(buf: &enc)
  bb.free(buf: %enc)
  return total - 1
end

let roundtrip_varint = fn (v: i64, label: string) -> unit throws { Exn } do
  let fields_in = [ PbField(field_number: 1, value: PbVarint(val: v)) ]
  let %enc = encode(fields: fields_in)
  let fields_out = decode(buf: &enc)
  bb.free(buf: %enc)
  match fields_out do
    | PbField(field_number: fn1, value: PbVarint(val: got)) :: [] ->
      test_assert.assert_eq_i64(actual: fn1, expected: 1, label: label ++ ":field_number")
      test_assert.assert_eq_i64(actual: got, expected: v, label: label ++ ":value")
    | _ -> test_assert.assert_true(cond: false, label: label ++ ":shape")
  end
  return ()
end

let main = fn () -> unit throws { Exn } do
  // Values that were previously broken (bit 63 set — signed negative):
  roundtrip_varint(v: -1,   label: "varint_neg1")
  roundtrip_varint(v: -2,   label: "varint_neg2")
  roundtrip_varint(v: -256, label: "varint_neg256")
  // i64::MIN = -9223372036854775808 = 0x8000000000000000
  roundtrip_varint(v: -9223372036854775808, label: "varint_i64min")
  // Large positive values near and above 2^62 (still fits in positive i64):
  roundtrip_varint(v: 4611686018427387904,  label: "varint_2pow62")
  // 2^63 - 1 = i64::MAX = 9223372036854775807
  roundtrip_varint(v: 9223372036854775807,  label: "varint_i64max")
  // Positive baselines (must still pass):
  roundtrip_varint(v: 0,   label: "varint_zero")
  roundtrip_varint(v: 300, label: "varint_300")
  // -1 encodes as exactly 10 varint bytes (ULEB128 of all-64-bits-set).
  // Total message: 1 byte tag + 10 bytes varint = 11 bytes.
  test_assert.assert_eq_i64(
    actual: encoded_byte_count(v: -1),
    expected: 10,
    label: "neg1_varint_byte_count"
  )
  // -9223372036854775808 (0x8000000000000000) also encodes as 10 varint bytes.
  test_assert.assert_eq_i64(
    actual: encoded_byte_count(v: -9223372036854775808),
    expected: 10,
    label: "i64min_varint_byte_count"
  )
  // 9223372036854775807 (i64::MAX = 0x7FFFFFFFFFFFFFFF) encodes as 9 varint bytes.
  test_assert.assert_eq_i64(
    actual: encoded_byte_count(v: 9223372036854775807),
    expected: 9,
    label: "i64max_varint_byte_count"
  )
  return ()
end
