// Port of bootstrap/tests/stdlib/json.rs::json_string_named_escapes_roundtrip.
// JSON's named escapes (\" \\ \/ \b \f \n \r \t) decode to 8 bytes and
// re-serialize without changing decoded length.
import * as test_assert from "std:test/assert"
import { parse, serialize, JsonString } from "std:json"
import { byte_length } from "std:str"

let main = fn () -> unit throws { Exn } do
  // \" \\ \/ \b \f \n \r \t — raw JSON spelled out as a Nexus string literal.
  // \\\" → JSON \" ; \\\\ → JSON \\ ; etc.
  let raw = "\"\\\"\\\\\\/\\b\\f\\n\\r\\t\""
  let v = parse(s: raw)
  match v do
    | JsonString(val: s) ->
      // Decoded content must be 8 bytes: " \ / BS FF LF CR TAB
      test_assert.assert_eq_i64(
        actual: byte_length(s),
        expected: 8,
        label: "decoded named escapes byte length"
      )
    | _ -> throw RuntimeError(val: "expected JsonString")
  end
  // Round-trip: serializer escapes back; parsing again gives the same value.
  let again = parse(s: serialize(v))
  match again do
    | JsonString(val: s2) ->
      test_assert.assert_eq_i64(
        actual: byte_length(s: s2),
        expected: 8,
        label: "roundtrip named escapes byte length"
      )
    | _ -> throw RuntimeError(val: "roundtrip lost JsonString")
  end
  return ()
end
