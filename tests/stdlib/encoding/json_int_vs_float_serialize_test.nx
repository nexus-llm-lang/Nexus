// Port of bootstrap/tests/stdlib/json.rs::json_serialize_preserves_int_vs_float.
// Integer literals stay integer-shaped on round-trip; float literals keep
// the decimal-point form.
import * as test_assert from "std:test/assert"
import { parse, serialize } from "std:json"

let main = fn () -> unit throws { Exn } do
  // Integer literal stays integer.
  test_assert.assert_eq_string(
    actual: serialize(v: parse(s: "42")),
    expected: "42",
    label: "int 42 keeps integer form"
  )
  // Float with explicit decimal point round-trips with one.
  test_assert.assert_eq_string(
    actual: serialize(v: parse(s: "1.5")),
    expected: "1.5",
    label: "float 1.5 keeps decimal form"
  )
  return ()
end
