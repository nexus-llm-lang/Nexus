// YAML round-trip for sequences containing compound items (maps or seqs).
// Verifies that serialize→parse recovers the original value.
import * as test_assert from "std:test/assert"
import {
  parse,
  serialize,
  YamlValue,
  YamlNull,
  YamlBool,
  YamlInt,
  YamlFloat,
  YamlString,
  YamlSeq,
  YamlMap,
  YamlField
} from "std:yaml"

let yaml_eq = fn (a: YamlValue, b: YamlValue) -> bool do
  match a do
    | YamlNull ->
      match b do
        | YamlNull -> return true
        | _ -> return false
      end
    | YamlBool(val: ba) ->
      match b do
        | YamlBool(val: bb) -> return ba == bb
        | _ -> return false
      end
    | YamlInt(val: ia) ->
      match b do
        | YamlInt(val: ib) -> return ia == ib
        | _ -> return false
      end
    | YamlFloat(val: fa) ->
      match b do
        | YamlFloat(val: fb) ->
          if fa !=. fa && fb !=. fb then return true end
          return fa ==. fb
        | _ -> return false
      end
    | YamlString(val: sa) ->
      match b do
        | YamlString(val: sb) -> return sa == sb
        | _ -> return false
      end
    | YamlSeq(items: xa) ->
      match b do
        | YamlSeq(items: xb) -> return items_eq(a: xa, b: xb)
        | _ -> return false
      end
    | YamlMap(fields: fma) ->
      match b do
        | YamlMap(fields: fmb) -> return fields_eq(a: fma, b: fmb)
        | _ -> return false
      end
  end
end

let items_eq = fn (a: [ YamlValue ], b: [ YamlValue ]) -> bool do
  match a do
    | [] ->
      match b do
        | [] -> return true
        | _ -> return false
      end
    | v1 :: rest1 ->
      match b do
        | [] -> return false
        | v2 :: rest2 ->
          if !yaml_eq(a: v1, b: v2) then return false end
          return items_eq(a: rest1, b: rest2)
      end
  end
end

let fields_eq = fn (a: [ YamlField ], b: [ YamlField ]) -> bool do
  match a do
    | [] ->
      match b do
        | [] -> return true
        | _ -> return false
      end
    | YamlField(key: k1, value: v1) :: rest1 ->
      match b do
        | [] -> return false
        | YamlField(key: k2, value: v2) :: rest2 ->
          if !yaml_eq(a: k1, b: k2) then return false end
          if !yaml_eq(a: v1, b: v2) then return false end
          return fields_eq(a: rest1, b: rest2)
      end
  end
end

let roundtrip = fn (v: YamlValue, label: string) -> unit throws { Exn } do
  let serialized = serialize(v)
  let v2 = parse(s: serialized)
  test_assert.assert_true(cond: yaml_eq(a: v, b: v2), label)
  return ()
end

let main = fn () -> unit throws { Exn } do
  // seq-of-single-key-maps: [{a:1},{b:2}]
  roundtrip(
    v: YamlSeq(items: [
      YamlMap(fields: [ YamlField(key: YamlString(val: "a"), value: YamlInt(val: 1)) ]),
      YamlMap(fields: [ YamlField(key: YamlString(val: "b"), value: YamlInt(val: 2)) ])
    ]),
    label: "roundtrip seq-of-single-key-maps")

  // seq-of-multi-key-maps: [{x:1,y:2}]
  roundtrip(
    v: YamlSeq(items: [
      YamlMap(fields: [
        YamlField(key: YamlString(val: "x"), value: YamlInt(val: 1)),
        YamlField(key: YamlString(val: "y"), value: YamlInt(val: 2))
      ])
    ]),
    label: "roundtrip seq-of-multi-key-maps")

  // seq-of-seqs: [[1,2],[3,4]]
  roundtrip(
    v: YamlSeq(items: [
      YamlSeq(items: [ YamlInt(val: 1), YamlInt(val: 2) ]),
      YamlSeq(items: [ YamlInt(val: 3), YamlInt(val: 4) ])
    ]),
    label: "roundtrip seq-of-seqs")

  // map with seq-of-maps value
  roundtrip(
    v: YamlMap(fields: [
      YamlField(
        key: YamlString(val: "items"),
        value: YamlSeq(items: [
          YamlMap(fields: [ YamlField(key: YamlString(val: "id"), value: YamlInt(val: 1)) ]),
          YamlMap(fields: [ YamlField(key: YamlString(val: "id"), value: YamlInt(val: 2)) ])
        ]))
    ]),
    label: "roundtrip map-with-seq-of-maps-value")

  return ()
end
