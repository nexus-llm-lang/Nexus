// HCL nested blocks: blocks inside blocks + mixed attrs and sub-blocks.
import * as test_assert from "std:test/assert"
import {
  parse,
  HclBody,
  HclItem,
  HclAttr,
  HclValue,
  HString,
  HNumber,
  HNull,
  Attribute,
  Block
} from "std:encoding/hcl"

let count_items = fn (items: [ HclItem ]) -> i64 do
  match items do
    | [] -> return 0
    | _ :: rest -> return 1 + count_items(items: rest)
  end
end

let first_item = fn (items: [ HclItem ]) -> HclItem throws { Exn } do
  match items do
    | x :: _ -> return x
    | [] ->
      test_assert.assert_true(cond: false, label: "no items")
      return Attribute(attr: HclAttr(name: "", value: HNull))
  end
end

let second_item = fn (items: [ HclItem ]) -> HclItem throws { Exn } do
  match items do
    | _ :: x :: _ -> return x
    | _ ->
      test_assert.assert_true(cond: false, label: "no second item")
      return Attribute(attr: HclAttr(name: "", value: HNull))
  end
end

let main = fn () -> unit throws { Exn } do
  // Nested blocks: provider block containing a features sub-block.
  let doc =
    "provider \"azurerm\" {\n" ++
    "  subscription_id = \"abc-123\"\n" ++
    "  features {\n" ++
    "    key_vault {\n" ++
    "      purge_soft_delete_on_destroy = true\n" ++
    "    }\n" ++
    "  }\n" ++
    "}\n"

  let HclBody(items: xs) = parse(s: doc)
  test_assert.assert_eq_i64(actual: count_items(items: xs), expected: 1, label: "1 top-level block")

  let top = first_item(items: xs)
  match top do
    | Block(block_type: bt, labels: lbls, body: HclBody(items: body_items)) ->
      test_assert.assert_eq_string(actual: bt, expected: "provider", label: "provider block")
      test_assert.assert_eq_i64(
        actual: count_items(items: body_items),
        expected: 2,
        label: "2 body items"
      )

      // First item in body: subscription_id attribute.
      let b0 = first_item(items: body_items)
      match b0 do
        | Attribute(attr: HclAttr(name: k, value: HString(val: sv))) ->
          test_assert.assert_eq_string(actual: k, expected: "subscription_id", label: "sub id key")
          test_assert.assert_eq_string(actual: sv, expected: "abc-123", label: "sub id value")
        | _ -> test_assert.assert_true(cond: false, label: "b0 must be string attr")
      end

      // Second item in body: features block.
      let b1 = second_item(items: body_items)
      match b1 do
        | Block(block_type: feat_bt, labels: feat_lbls, body: HclBody(items: feat_body)) ->
          test_assert.assert_eq_string(
            actual: feat_bt,
            expected: "features",
            label: "features block"
          )
          test_assert.assert_eq_i64(
            actual: count_items(items: feat_body),
            expected: 1,
            label: "1 sub-block in features"
          )

          // key_vault block inside features.
          let f0 = first_item(items: feat_body)
          match f0 do
            | Block(block_type: kv_bt, labels: _, body: HclBody(items: kv_body)) ->
              test_assert.assert_eq_string(
                actual: kv_bt,
                expected: "key_vault",
                label: "key_vault block"
              )
              test_assert.assert_eq_i64(
                actual: count_items(items: kv_body),
                expected: 1,
                label: "1 attr in key_vault"
              )
            | _ -> test_assert.assert_true(cond: false, label: "f0 must be key_vault block")
          end
        | _ -> test_assert.assert_true(cond: false, label: "b1 must be features block")
      end
    | _ -> test_assert.assert_true(cond: false, label: "top must be block")
  end

  return ()
end
