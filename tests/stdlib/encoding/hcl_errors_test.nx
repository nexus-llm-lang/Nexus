// HCL parse error cases: malformed input should throw HclError.
import * as test_assert from "std:test/assert"
import { parse } from "std:encoding/hcl"

let raises = fn (doc: string) -> bool do
  try
    parse(s: doc)
    return false
  catch _ ->
    return true
  end
end

let main = fn () -> unit throws { Exn } do
  // Missing '=' after attribute name.
  test_assert.assert_true(
    cond: raises(doc: "name \"missing_eq\"\n"),
    label: "missing = after name"
  )

  // Unterminated quoted string.
  test_assert.assert_true(
    cond: raises(doc: "key = \"unterminated\n"),
    label: "unterminated quoted string"
  )

  // Unclosed block body.
  test_assert.assert_true(
    cond: raises(doc: "resource \"aws_instance\" \"web\" {\n  ami = \"x\"\n"),
    label: "unclosed block body"
  )

  // Unclosed list.
  test_assert.assert_true(
    cond: raises(doc: "ports = [80, 443\n"),
    label: "unclosed list"
  )

  // Unterminated block comment.
  test_assert.assert_true(
    cond: raises(doc: "/* unterminated\n  value = 1\n"),
    label: "unterminated block comment"
  )

  // Trailing garbage after a valid document.
  test_assert.assert_true(
    cond: raises(doc: "x = 1\n!!!\n"),
    label: "trailing garbage"
  )

  return ()
end
