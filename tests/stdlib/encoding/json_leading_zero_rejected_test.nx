// Port of bootstrap/tests/stdlib/json.rs::json_rejects_leading_zero.
// RFC 8259 forbids leading zeros on integer literals; parse must throw.
import * as test_assert from "std:test/assert"
import { parse } from "std:json"

let raises_parse = fn (s: string) -> bool do
  try
    parse(s)
    return false
  catch _ ->
    return true
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_true(cond: raises_parse(s: "01"), label: "parse(\"01\") rejects leading zero")
  return ()
end
