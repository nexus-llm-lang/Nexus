// TOML integer overflow: 0xFFFFFFFFFFFFFFFF (2^64-1) is out of i64 range
// and must throw, consistent with how decimal overflow throws.
// Valid in-range hex/oct/bin values must still parse correctly.
import * as test_assert from "std:test/assert"
import { parse, TomlTable, TomlInt, TomlField } from "std:toml"

let raises = fn (doc: string) -> bool do
  try
    parse(s: doc)
    return false
  catch _ ->
    return true
  end
end

let get_int = fn (doc: string) -> i64 throws { Exn } do
  match parse(s: doc) do
    | TomlTable(fields: fs) ->
      match fs do
        | TomlField(key: _, value: TomlInt(val: n)) :: _ -> return n
        | _ ->
          test_assert.assert_true(cond: false, label: "expected TomlInt first field")
          return 0
      end
    | _ ->
      test_assert.assert_true(cond: false, label: "expected TomlTable root")
      return 0
  end
end

let main = fn () -> unit throws { Exn } do
  // ── Bug B: hex/oct/bin overflow must throw ─────────────────────────────────
  // Hex 2^64-1 (= 0xFFFFFFFFFFFFFFFF) exceeds i64 max (0x7FFFFFFFFFFFFFFF).
  test_assert.assert_true(
    cond: raises(doc: "n = 0xFFFFFFFFFFFFFFFF\n"),
    label: "hex 2^64-1 must throw (out of i64 range)"
  )

  // Octal: 0o1777777777777777777777 = 2^64-1 (22 octal digits of 7).
  test_assert.assert_true(
    cond: raises(doc: "n = 0o1777777777777777777777\n"),
    label: "octal 2^64-1 must throw"
  )

  // Binary: 64 ones = 2^64-1.
  test_assert.assert_true(
    cond: raises(doc: "n = 0b1111111111111111111111111111111111111111111111111111111111111111\n"),
    label: "binary 2^64-1 must throw"
  )

  // ── Valid in-range values still parse ──────────────────────────────────────
  // Hex max i64: 0x7FFFFFFFFFFFFFFF = 9223372036854775807
  let hex_max = get_int(doc: "n = 0x7FFFFFFFFFFFFFFF\n")
  test_assert.assert_eq_i64(
    actual: hex_max,
    expected: 9223372036854775807,
    label: "hex 0x7FFFFFFFFFFFFFFF = i64 max"
  )

  // Simple octal: 0o17 = 15
  let oct_val = get_int(doc: "n = 0o17\n")
  test_assert.assert_eq_i64(actual: oct_val, expected: 15, label: "0o17 = 15")

  // Simple binary: 0b1010 = 10
  let bin_val = get_int(doc: "n = 0b1010\n")
  test_assert.assert_eq_i64(actual: bin_val, expected: 10, label: "0b1010 = 10")

  // Hex with underscores: 0xDEAD_BEEF = 3735928559
  let hex_us = get_int(doc: "n = 0xDEAD_BEEF\n")
  test_assert.assert_eq_i64(actual: hex_us, expected: 3735928559, label: "0xDEAD_BEEF = 3735928559")

  return ()
end
