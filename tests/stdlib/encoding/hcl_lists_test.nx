// HCL list values: parse attribute values that are list [...] expressions.
import * as test_assert from "std:test/assert"
import {
  parse,
  HclBody,
  HclItem,
  HclAttr,
  HclValue,
  HString,
  HNumber,
  HBool,
  HNull,
  HList,
  Attribute
} from "std:encoding/hcl"

let count_items = fn (items: [ HclItem ]) -> i64 do
  match items do
    | [] -> return 0
    | _ :: rest -> return 1 + count_items(items: rest)
  end
end

let count_values = fn (values: [ HclValue ]) -> i64 do
  match values do
    | [] -> return 0
    | _ :: rest -> return 1 + count_values(values: rest)
  end
end

let first_val = fn (values: [ HclValue ]) -> HclValue throws { Exn } do
  match values do
    | x :: _ -> return x
    | [] ->
      test_assert.assert_true(cond: false, label: "no values")
      return HNull
  end
end

let second_val = fn (values: [ HclValue ]) -> HclValue throws { Exn } do
  match values do
    | _ :: x :: _ -> return x
    | _ ->
      test_assert.assert_true(cond: false, label: "no second value")
      return HNull
  end
end

let first_item = fn (items: [ HclItem ]) -> HclItem throws { Exn } do
  match items do
    | x :: _ -> return x
    | [] ->
      test_assert.assert_true(cond: false, label: "no items")
      return Attribute(attr: HclAttr(name: "", value: HNull))
  end
end

let main = fn () -> unit throws { Exn } do
  // Empty list.
  let doc1 = "tags = []\n"
  let HclBody(items: xs1) = parse(s: doc1)
  let item0 = first_item(items: xs1)
  match item0 do
    | Attribute(attr: HclAttr(name: k, value: HList(items: lst))) ->
      test_assert.assert_eq_string(actual: k, expected: "tags", label: "tags key")
      test_assert.assert_eq_i64(actual: count_values(values: lst), expected: 0, label: "empty list")
    | _ -> test_assert.assert_true(cond: false, label: "item0 must be list attr")
  end

  // String list.
  let doc2 = "regions = [\"us-east-1\", \"eu-west-1\", \"ap-south-1\"]\n"
  let HclBody(items: xs2) = parse(s: doc2)
  let item1 = first_item(items: xs2)
  match item1 do
    | Attribute(attr: HclAttr(name: k, value: HList(items: lst))) ->
      test_assert.assert_eq_string(actual: k, expected: "regions", label: "regions key")
      test_assert.assert_eq_i64(actual: count_values(values: lst), expected: 3, label: "3 regions")
      let v0 = first_val(values: lst)
      match v0 do
        | HString(val: sv) ->
          test_assert.assert_eq_string(actual: sv, expected: "us-east-1", label: "first region")
        | _ -> test_assert.assert_true(cond: false, label: "v0 must be string")
      end
    | _ -> test_assert.assert_true(cond: false, label: "item1 must be list attr")
  end

  // Number list.
  let doc3 = "ports = [80, 443, 8080]\n"
  let HclBody(items: xs3) = parse(s: doc3)
  let item2 = first_item(items: xs3)
  match item2 do
    | Attribute(attr: HclAttr(name: k, value: HList(items: lst))) ->
      test_assert.assert_eq_string(actual: k, expected: "ports", label: "ports key")
      test_assert.assert_eq_i64(actual: count_values(values: lst), expected: 3, label: "3 ports")
      let v1 = second_val(values: lst)
      match v1 do
        | HNumber(val: nv) ->
          test_assert.assert_true(cond: nv ==. 443.0, label: "second port is 443")
        | _ -> test_assert.assert_true(cond: false, label: "v1 must be number")
      end
    | _ -> test_assert.assert_true(cond: false, label: "item2 must be list attr")
  end

  return ()
end
