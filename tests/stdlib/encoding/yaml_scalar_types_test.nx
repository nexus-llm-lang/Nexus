// YAML core-schema scalar type inference: null, bool, int, float.
import * as test_assert from "std:test/assert"
import { parse, YamlValue, YamlNull, YamlBool, YamlInt, YamlFloat, YamlString } from "std:yaml"

let assert_null = fn (v: YamlValue, label: string) -> unit throws { Exn } do
  match v do
    | YamlNull -> test_assert.assert_true(cond: true, label)
    | _ -> throw RuntimeError(val: label ++ ": expected YamlNull")
  end
  return ()
end

let assert_bool = fn (v: YamlValue, expected: bool, label: string) -> unit throws { Exn } do
  match v do
    | YamlBool(val: b) -> test_assert.assert_eq_bool(actual: b, expected, label)
    | _ -> throw RuntimeError(val: label ++ ": expected YamlBool")
  end
  return ()
end

let assert_int = fn (v: YamlValue, expected: i64, label: string) -> unit throws { Exn } do
  match v do
    | YamlInt(val: i) -> test_assert.assert_eq_i64(actual: i, expected, label)
    | _ -> throw RuntimeError(val: label ++ ": expected YamlInt")
  end
  return ()
end

let assert_float = fn (v: YamlValue, label: string) -> unit throws { Exn } do
  match v do
    | YamlFloat(_) -> test_assert.assert_true(cond: true, label)
    | _ -> throw RuntimeError(val: label ++ ": expected YamlFloat")
  end
  return ()
end

let main = fn () -> unit throws { Exn } do
  assert_null(v: parse(s: "~"), label: "~ is null")
  assert_null(v: parse(s: "null"), label: "null is null")
  assert_null(v: parse(s: "Null"), label: "Null is null")
  assert_bool(v: parse(s: "true"), expected: true, label: "true literal")
  assert_bool(v: parse(s: "false"), expected: false, label: "false literal")
  assert_int(v: parse(s: "42"), expected: 42, label: "decimal int")
  assert_int(v: parse(s: "0xff"), expected: 255, label: "hex int")
  assert_int(v: parse(s: "0o17"), expected: 15, label: "octal int")
  assert_int(v: parse(s: "-7"), expected: -7, label: "negative int")
  assert_float(v: parse(s: "3.14"), label: "float 3.14")
  assert_float(v: parse(s: ".inf"), label: ".inf float")
  assert_float(v: parse(s: ".nan"), label: ".nan float")
  return ()
end
