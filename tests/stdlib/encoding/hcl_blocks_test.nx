// HCL blocks: unlabeled and labeled block parsing.
import * as test_assert from "std:test/assert"
import {
  parse,
  HclBody,
  HclItem,
  HclAttr,
  HclValue,
  HString,
  HNumber,
  HNull,
  Attribute,
  Block
} from "std:encoding/hcl"

let count_items = fn (items: [ HclItem ]) -> i64 do
  match items do
    | [] -> return 0
    | _ :: rest -> return 1 + count_items(items: rest)
  end
end

let first_item = fn (items: [ HclItem ]) -> HclItem throws { Exn } do
  match items do
    | x :: _ -> return x
    | [] ->
      test_assert.assert_true(cond: false, label: "no items")
      return Attribute(attr: HclAttr(name: "", value: HNull))
  end
end

let count_labels = fn (labels: [ string ]) -> i64 do
  match labels do
    | [] -> return 0
    | _ :: rest -> return 1 + count_labels(labels: rest)
  end
end

let first_label = fn (labels: [ string ]) -> string throws { Exn } do
  match labels do
    | x :: _ -> return x
    | [] ->
      test_assert.assert_true(cond: false, label: "no labels")
      return ""
  end
end

let second_label = fn (labels: [ string ]) -> string throws { Exn } do
  match labels do
    | _ :: x :: _ -> return x
    | _ ->
      test_assert.assert_true(cond: false, label: "no second label")
      return ""
  end
end

let main = fn () -> unit throws { Exn } do
  // Unlabeled block.
  let doc1 =
    "terraform {\n" ++
    "  required_version = \"~> 1.0\"\n" ++
    "}\n"

  let HclBody(items: xs1) = parse(s: doc1)
  test_assert.assert_eq_i64(actual: count_items(items: xs1), expected: 1, label: "1 top-level item")
  let item0 = first_item(items: xs1)
  match item0 do
    | Block(block_type: bt, labels: lbls, body: HclBody(items: body_items)) ->
      test_assert.assert_eq_string(actual: bt, expected: "terraform", label: "block type")
      test_assert.assert_eq_i64(actual: count_labels(labels: lbls), expected: 0, label: "no labels")
      test_assert.assert_eq_i64(
        actual: count_items(items: body_items),
        expected: 1,
        label: "1 body attr"
      )
      let bi0 = first_item(items: body_items)
      match bi0 do
        | Attribute(attr: HclAttr(name: k, value: HString(val: sv))) ->
          test_assert.assert_eq_string(actual: k, expected: "required_version", label: "inner key")
          test_assert.assert_eq_string(actual: sv, expected: "~> 1.0", label: "inner value")
        | _ -> test_assert.assert_true(cond: false, label: "inner must be string attr")
      end
    | _ -> test_assert.assert_true(cond: false, label: "item0 must be a block")
  end

  // Two-label block (e.g. resource "aws_instance" "web").
  let doc2 =
    "resource \"aws_instance\" \"web\" {\n" ++
    "  ami           = \"ami-12345\"\n" ++
    "  instance_type = \"t3.micro\"\n" ++
    "}\n"

  let HclBody(items: xs2) = parse(s: doc2)
  test_assert.assert_eq_i64(actual: count_items(items: xs2), expected: 1, label: "1 block in doc2")
  let item1 = first_item(items: xs2)
  match item1 do
    | Block(block_type: bt2, labels: lbls2, body: HclBody(items: body2)) ->
      test_assert.assert_eq_string(actual: bt2, expected: "resource", label: "resource block type")
      test_assert.assert_eq_i64(actual: count_labels(labels: lbls2), expected: 2, label: "2 labels")
      test_assert.assert_eq_string(
        actual: first_label(labels: lbls2),
        expected: "aws_instance",
        label: "label1"
      )
      test_assert.assert_eq_string(
        actual: second_label(labels: lbls2),
        expected: "web",
        label: "label2"
      )
      test_assert.assert_eq_i64(
        actual: count_items(items: body2),
        expected: 2,
        label: "2 body attrs"
      )
    | _ -> test_assert.assert_true(cond: false, label: "item1 must be a block")
  end

  return ()
end
