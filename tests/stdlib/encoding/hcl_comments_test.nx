// HCL comments: #, //, and /* */ block comments are stripped/ignored.
import * as test_assert from "std:test/assert"
import {
  parse,
  HclBody,
  HclItem,
  HclAttr,
  HclValue,
  HString,
  HNumber,
  HNull,
  Attribute
} from "std:encoding/hcl"

let count_items = fn (items: [ HclItem ]) -> i64 do
  match items do
    | [] -> return 0
    | _ :: rest -> return 1 + count_items(items: rest)
  end
end

let first_item = fn (items: [ HclItem ]) -> HclItem throws { Exn } do
  match items do
    | x :: _ -> return x
    | [] ->
      test_assert.assert_true(cond: false, label: "no items")
      return Attribute(attr: HclAttr(name: "", value: HNull))
  end
end

let second_item = fn (items: [ HclItem ]) -> HclItem throws { Exn } do
  match items do
    | _ :: x :: _ -> return x
    | _ ->
      test_assert.assert_true(cond: false, label: "no second item")
      return Attribute(attr: HclAttr(name: "", value: HNull))
  end
end

let main = fn () -> unit throws { Exn } do
  // Hash comments and double-slash comments.
  let doc1 =
    "# This is a hash comment\n" ++
    "name = \"example\"  # trailing hash comment\n" ++
    "// This is a slash-slash comment\n" ++
    "count = 42  // trailing slash comment\n"

  let HclBody(items: xs1) = parse(s: doc1)
  test_assert.assert_eq_i64(actual: count_items(items: xs1), expected: 2, label: "2 items after comment strip")

  let item0 = first_item(items: xs1)
  match item0 do
    | Attribute(attr: HclAttr(name: k, value: HString(val: sv))) ->
      test_assert.assert_eq_string(actual: k, expected: "name", label: "name attr key")
      test_assert.assert_eq_string(actual: sv, expected: "example", label: "name attr value")
    | _ -> test_assert.assert_true(cond: false, label: "item0 must be string attr")
  end

  let item1 = second_item(items: xs1)
  match item1 do
    | Attribute(attr: HclAttr(name: k, value: HNumber(val: nv))) ->
      test_assert.assert_eq_string(actual: k, expected: "count", label: "count key")
      test_assert.assert_true(cond: nv ==. 42.0, label: "count = 42")
    | _ -> test_assert.assert_true(cond: false, label: "item1 must be number attr")
  end

  // Block comment /* ... */.
  let doc2 =
    "/* block\n" ++
    "   comment\n" ++
    "   spanning lines */\n" ++
    "value = 99\n"

  let HclBody(items: xs2) = parse(s: doc2)
  test_assert.assert_eq_i64(actual: count_items(items: xs2), expected: 1, label: "1 item after block comment")

  let item2 = first_item(items: xs2)
  match item2 do
    | Attribute(attr: HclAttr(name: k, value: HNumber(val: nv))) ->
      test_assert.assert_eq_string(actual: k, expected: "value", label: "value key")
      test_assert.assert_true(cond: nv ==. 99.0, label: "value = 99")
    | _ -> test_assert.assert_true(cond: false, label: "item2 must be number attr")
  end

  return ()
end
