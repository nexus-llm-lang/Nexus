// nexus-rmlq: create_dir_all must create the full path chain, not just the
// leaf. Verify that a deeply nested path whose parents do not yet exist is
// created successfully and can be written to.
import * as test_assert from "std:test/assert"
import { Fs }, * as fs_mod from "std:fs"

let main = fn () -> unit require { PermFs } throws { Exn } do
  inject fs_mod.system_handler do
    let deep = "/tmp/nx_rmlq_deep/a/b/c"
    let file = "/tmp/nx_rmlq_deep/a/b/c/data.txt"
    Fs.create_dir_all(path: deep)
    test_assert.assert_true(cond: Fs.exists(path: deep), label: "deep dir exists after create_dir_all")
    Fs.write_string(path: file, content: "ok")
    test_assert.assert_true(cond: Fs.exists(path: file), label: "file under deep dir exists")
    let content = Fs.read_to_string(path: file)
    test_assert.assert_true(cond: content == "ok", label: "file content correct")
  end
  return ()
end
