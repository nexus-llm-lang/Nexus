// Port of bootstrap/tests/stdlib/json.rs::json_trailing_comma_rejected.
// RFC 8259 forbids trailing commas in arrays; parse must throw.
import * as test_assert from "std:test/assert"
import { parse } from "std:json"

let raises_parse = fn (s: string) -> bool do
  try
    parse(s)
    return false
  catch _ ->
    return true
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_true(
    cond: raises_parse(s: "[1,2,]"),
    label: "parse(\"[1,2,]\") rejects trailing comma in array"
  )
  return ()
end
