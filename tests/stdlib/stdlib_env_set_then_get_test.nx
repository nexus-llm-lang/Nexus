// Standalone wasmtime inherits the parent shell's env rather than
// letting the .nx fixture script-set it, so we exercise the round-trip
// end-to-end inside the wasm: Env.set then Env.get.
//
// Validates that the host bridge round-trips a non-empty value
// through Env.get/Env.set without coercion — even if the variable
// wasn't pre-populated.
import { Env }, * as env_mod from "std:env"
import { Some, None } from "std:option"

let body = fn () -> unit require { PermEnv } throws { Exn } do
  inject env_mod.system_handler do
    Env.set(key: "NX_DVR66_SET_VAR", value: "hello")
    match Env.get(key: "NX_DVR66_SET_VAR") do
      | Some(val: v) ->
        if v != "hello" then raise RuntimeError(val: "expected hello") end
        return ()
      | None -> raise RuntimeError(val: "expected Some after set")
    end
  end
end

let safe_run = fn () -> i64 require { PermEnv } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermEnv } do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
