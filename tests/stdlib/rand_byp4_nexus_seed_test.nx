// byp4: std:rand reads NEXUS_SEED env var for deterministic seeding.
//
// Uses Env.set to write NEXUS_SEED into the override table, then resets the
// PRNG state so ensure_seeded re-runs and picks up the env value.  The
// resulting sequence must match the offline PCG reference for seed = 42.
//
// PCG reference (seed = 42, multiplier = 6364136223846793005,
//               increment = 1442695040888963407, top bit cleared):
//   step 1: 1258627373665771185
//   step 2: 4159066171780167020
//   step 3: 7615522811268512075
import * as test_assert from "std:test/assert"
import { Env } from "std:env"
import { Random, seed_with, reset }, * as rng from "std:rand"
import * as env_mod from "std:env"

let main = fn () -> unit require { PermRandom, PermEnv } throws { Exn } do
  inject env_mod.system_handler do
    // Write NEXUS_SEED into the env override table so raw_get picks it up.
    Env.set(key: "NEXUS_SEED", value: "42")
    // Reset so ensure_seeded runs again and reads the new value.
    let _ = reset()
    inject rng.system_handler do
      test_assert.assert_eq_i64(
        actual: Random.next_i64(),
        expected: 1258627373665771185,
        label: "NEXUS_SEED=42 step 1"
      )
      test_assert.assert_eq_i64(
        actual: Random.next_i64(),
        expected: 4159066171780167020,
        label: "NEXUS_SEED=42 step 2"
      )
      test_assert.assert_eq_i64(
        actual: Random.next_i64(),
        expected: 7615522811268512075,
        label: "NEXUS_SEED=42 step 3"
      )
    end
  end
  return ()
end
