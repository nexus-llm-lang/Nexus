// Port of bootstrap/tests/stdlib/string.rs::string_concat_basic.
// concat("hello", " world") must produce an 11-byte string.
import * as test_assert from "std:test/assert"
import { concat, length } from "std:str"

let main = fn () -> unit throws { Exn } do
  let result = concat(a: "hello", b: " world")
  test_assert.assert_eq_i64(actual: length(s: result), expected: 11, label: "length of \"hello world\"")
  return ()
end
