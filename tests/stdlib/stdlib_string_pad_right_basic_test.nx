// Port of bootstrap/tests/stdlib/string.rs::string_pad_right_basic.
// pad_right("hi", width: 5, fill: ".") must produce a 5-byte string.
import { pad_right, length } from "std:str"

let body = fn () -> unit throws { Exn } do
  let result = pad_right(s: "hi", width: 5, fill: ".")
  if length(s: result) != 5 then raise RuntimeError(val: "expected length 5") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
