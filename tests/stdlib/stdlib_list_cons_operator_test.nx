// Port of bootstrap/tests/stdlib/list.rs:
//   test_cons_operator_expr,
//   test_cons_operator_pattern,
//   test_cons_operator_chained_pattern,
//   test_cons_operator_expr_prepend_to_list,
//   test_cons_operator_precedence.
// Reframed to use [] / :: throughout.

let body = fn () -> unit throws { Exn } do
  // Build a 3-element list with right-associative ::.
  let xs = 1 :: 2 :: 3 :: []
  match xs do
    | a :: b :: c :: [] ->
      if a != 1 then raise RuntimeError(val: "expected 1") end
      if b != 2 then raise RuntimeError(val: "expected 2") end
      if c != 3 then raise RuntimeError(val: "expected 3") end
    | _ -> raise RuntimeError(val: "expected 3-element list")
  end

  // h :: t pattern, then h2 :: _ on the tail.
  let ys = [10, 20, 30]
  match ys do
    | h :: t ->
      if h != 10 then raise RuntimeError(val: "expected 10") end
      match t do
        | h2 :: _ ->
          if h2 != 20 then raise RuntimeError(val: "expected 20") end
        | _ -> raise RuntimeError(val: "expected tail")
      end
    | _ -> raise RuntimeError(val: "expected cons")
  end

  // Prepend with :: to a list literal.
  let tail = [2, 3]
  let zs = 1 :: tail
  match zs do
    | h :: _ ->
      if h != 1 then raise RuntimeError(val: "expected 1") end
    | [] -> raise RuntimeError(val: "expected non-empty")
  end

  // Precedence: 1 + 2 :: [] parses as (1 + 2) :: [].
  let ws = 1 + 2 :: []
  match ws do
    | h :: [] ->
      if h != 3 then raise RuntimeError(val: "expected 3") end
    | _ -> raise RuntimeError(val: "expected [3]")
  end

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
