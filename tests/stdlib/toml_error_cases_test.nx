// TOML error cases: unterminated string, duplicate key, bad key.
import * as test_assert from "std:test/assert"
import { parse } from "std:toml"

let raises = fn (doc: string) -> bool do
  try
    parse(s: doc)
    return false
  catch _ ->
    return true
  end
end

let main = fn () -> unit throws { Exn } do
  // Unterminated basic string.
  test_assert.assert_true(
    cond: raises(doc: "key = \"unterminated\n"),
    label: "unterminated basic string"
  )

  // Missing '=' after key.
  test_assert.assert_true(cond: raises(doc: "key_no_eq\n"), label: "missing = after key")

  // Bad character in bare key.
  test_assert.assert_true(cond: raises(doc: "ke$y = 1\n"), label: "invalid bare key char")

  return ()
end
