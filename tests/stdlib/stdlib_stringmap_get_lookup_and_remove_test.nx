// Port of bootstrap/tests/stdlib/collections.rs::stringmap_get_lookup_and_remove
// (fixture: stringmap_get_lookup_and_remove.nx).
//
// Exercises stringmap.get (Found/Missing) and stringmap.remove on string
// keys.
import * as smap from "std:stringmap"

let body = fn () -> unit throws { Exn } do
  let m0 = smap.empty()
  let m1 = smap.put(map: m0, key: "alpha", value: 70)
  let m2 = smap.put(map: m1, key: "beta", value: 80)
  let got = smap.get(map: &m2, key: "alpha")
  let m3 = smap.remove(map: m2, key: "beta")
  let sz = smap.size(map: &m3)
  smap.free(map: m3)
  match got do
    | Found(value: v) ->
      let result = v + sz
      if result != 71 then raise RuntimeError(val: "expected 71") end
    | Missing -> raise RuntimeError(val: "expected Found, got Missing")
  end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
