// Port of bootstrap/tests/stdlib/json.rs::json_lsp_publish_diagnostics_roundtrip.
// LSP `textDocument/publishDiagnostics` notification round-trips —
// nested arrays + objects + numbers + strings.
import * as test_assert from "std:test/assert"
import { parse, serialize } from "std:json"

let main = fn () -> unit throws { Exn } do
  let raw = "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/publishDiagnostics\",\"params\":{\"uri\":\"file:///tmp/a.nx\",\"diagnostics\":[{\"range\":{\"start\":{\"line\":3,\"character\":7},\"end\":{\"line\":3,\"character\":12}},\"severity\":1,\"message\":\"unknown identifier\"}]}}"
  test_assert.assert_eq_string(actual: serialize(v: parse(s: raw)), expected: raw, label: "publishDiagnostics roundtrip")
  return ()
end
