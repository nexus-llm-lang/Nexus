// Port of bootstrap/tests/stdlib/list.rs:
//   test_list_builtin_no_import,
//   test_list_constructor_returns_list_type.
// Reframed to use [] / :: instead of Nil / Cons (Nil/Cons sugar is
// disallowed in new test code per repo style).

let body = fn () -> unit throws { Exn } do
  // List literal of 3 ints.
  let xs = [10, 20, 30]
  match xs do
    | [] -> raise RuntimeError(val: "expected non-empty")
    | h :: _ ->
      if h != 10 then raise RuntimeError(val: "expected 10") end
  end

  // Singleton built via :: + [].
  let ys: [i64] = 1 :: []
  match ys do
    | [] -> raise RuntimeError(val: "expected non-empty")
    | h :: _ ->
      if h != 1 then raise RuntimeError(val: "expected 1") end
  end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
