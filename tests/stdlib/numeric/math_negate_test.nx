// Port of bootstrap/tests/stdlib/math.rs::negate_in_math_module.
import * as test_assert from "std:test/assert"
import { negate } from "std:math"

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_bool(actual: negate(val: false), expected: true, label: "negate(false)")
  test_assert.assert_eq_bool(actual: negate(val: true), expected: false, label: "negate(true)")
  return ()
end
