// Regression test for nexus-bdmx: parse_i64 must return None for values outside i64 range.
import * as test_assert from "std:test/assert"
import { parse_i64 } from "std:str"
import { is_none, is_some } from "std:option"

let main = fn () -> unit throws { Exn } do
  test_assert.assert_true(
    cond: is_none(opt: parse_i64(s: "99999999999999999999")),
    label: "parse_i64(\"99999999999999999999\") is None (overflow)"
  )
  test_assert.assert_true(
    cond: is_none(opt: parse_i64(s: "-99999999999999999999")),
    label: "parse_i64(\"-99999999999999999999\") is None (negative overflow)"
  )
  test_assert.assert_true(
    cond: is_some(opt: parse_i64(s: "9223372036854775807")),
    label: "parse_i64(\"9223372036854775807\") is Some (i64 max)"
  )
  test_assert.assert_true(
    cond: is_some(opt: parse_i64(s: "-9223372036854775808")),
    label: "parse_i64(\"-9223372036854775808\") is Some (i64 min)"
  )
  test_assert.assert_true(
    cond: is_none(opt: parse_i64(s: "9223372036854775808")),
    label: "parse_i64(\"9223372036854775808\") is None (i64 max + 1)"
  )
  return ()
end
