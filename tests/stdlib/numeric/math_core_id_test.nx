// Port of bootstrap/tests/stdlib/math.rs::core_id_returns_argument.
import * as test_assert from "std:test/assert"
import { id } from "std:core"

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: id(val: 42), expected: 42, label: "id(42)")
  test_assert.assert_eq_i64(actual: id(val: -7), expected: -7, label: "id(-7)")
  return ()
end
