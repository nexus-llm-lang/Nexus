// Regression: math.i64_to_float(i64::MIN) must return exactly
// -2^63 = -9223372036854775808.0, not -0.0.
//
// The i64::MIN special case fed i64_min's own integer bit pattern
// (0x8000000000000000) straight into i64_bits_to_f64. But that bit pattern,
// reinterpreted as an f64, IS -0.0 (sign=1, exp=0, mantissa=0) -- not -2^63.
// The correct f64 bits for -2^63 are 0xC3E0000000000000 (sign=1, biased
// exp=1086, mantissa=0), which as a signed i64 is -4332462841530417152.
//
// Before the fix, f64_bits(i64_to_float(i64_min)) == -9223372036854775808
// (the -0.0 pattern); after, it is -4332462841530417152.
import * as test_assert from "std:test/assert"
import { i64_to_float } from "std:math"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"

// Reinterpret the 64 bits of an f64 as an i64 (matches math's f64_to_i64_bits).
let f64_to_bits = fn (x: float) -> i64 do
  let p = arena.alloc_raw(size: 8)
  mem.store_f64(addr: p, val: x)
  return mem.load_i64(addr: p)
end

// Reinterpret the 64 bits of an i64 as an f64 (matches math's i64_bits_to_f64).
let bits_to_f64 = fn (bits: i64) -> float do
  let p = arena.alloc_raw(size: 8)
  mem.store_i64(addr: p, val: bits)
  return mem.load_f64(addr: p)
end

let main = fn () -> unit throws { Exn } do
  // i64::MIN = -(2^63), written as a negation of a positive literal so the
  // bare literal never overflows the positive i64 range.
  let i64_min = (0 - 9223372036854775807) - 1
  let r = i64_to_float(val: i64_min)

  // Primary witness: the f64 bit pattern is -2^63's (0xC3E0000000000000 =
  // -4332462841530417152), NOT -0.0's (0x8000000000000000 =
  // -9223372036854775808). This single assertion was -9223372036854775808
  // before the fix.
  test_assert.assert_eq_i64(
    actual: f64_to_bits(x: r),
    expected: -4332462841530417152,
    label: "i64_to_float(i64::MIN) bits == -2^63 bits"
  )

  // The result is strictly negative. -0.0 is NOT `<. 0.0`, so this fails
  // under the old -0.0 behaviour.
  test_assert.assert_eq_bool(actual: r <. 0.0, expected: true, label: "i64_to_float(i64::MIN) < 0")

  // The result equals the independently reconstructed -2^63 f64 value.
  let neg_two_pow_63 = bits_to_f64(bits: -4332462841530417152)
  test_assert.assert_eq_bool(actual: r ==. neg_two_pow_63, expected: true, label: "== -2^63 (reconstructed)")

  // Neighbour ordering: i64::MIN maps strictly below i64::MIN + 1. Under the
  // old -0.0 behaviour this was false (-0.0 is not below a large negative).
  let r_min_plus_1 = i64_to_float(val: i64_min + 1)
  test_assert.assert_eq_bool(actual: r <. r_min_plus_1, expected: true, label: "i64::MIN < i64::MIN+1")

  // Neighbour spot-check: -2^62 is exactly representable. It must convert to
  // a negative value strictly greater than i64_to_float(i64::MIN), and -2^63
  // halved must land exactly on it (both are exact in f64).
  let neg_two_pow_62 = i64_to_float(val: 0 - 4611686018427387904)
  test_assert.assert_eq_bool(actual: neg_two_pow_62 <. 0.0, expected: true, label: "-2^62 < 0")
  test_assert.assert_eq_bool(actual: r <. neg_two_pow_62, expected: true, label: "i64::MIN < -2^62")
  test_assert.assert_eq_bool(actual: r /. 2.0 ==. neg_two_pow_62, expected: true, label: "-2^63 / 2 == -2^62")

  return ()
end
