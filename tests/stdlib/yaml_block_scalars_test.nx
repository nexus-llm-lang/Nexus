// YAML block scalars: literal | and folded > with chomping variants.
import * as test_assert from "std:test/assert"
import { parse, YamlValue, YamlMap, YamlField, YamlString } from "std:yaml"

let get_str_field = fn (fields: [ YamlField ], key: string) -> string do
  match fields do
    | [] -> throw RuntimeError(val: "key not found: " ++ key)
    | YamlField(key: k, value: v) :: rest ->
      match k do
        | YamlString(val: s) ->
          if s == key then
            match v do
              | YamlString(val: sv) -> return sv
              | _ -> throw RuntimeError(val: "field is not a string: " ++ key)
            end
          else
            return get_str_field(fields: rest, key)
          end
        | _ -> return get_str_field(fields: rest, key)
      end
  end
end

let main = fn () -> unit throws { Exn } do
  // Literal block scalar | (clip chomping — default, one trailing newline).
  let doc_literal = "text: |\n  line one\n  line two\n"
  let v1 = parse(s: doc_literal)
  match v1 do
    | YamlMap(fields: fs) ->
      let sv = get_str_field(fields: fs, key: "text")
      test_assert.assert_eq_string(actual: sv, expected: "line one\nline two\n", label: "literal block clip")
    | _ -> throw RuntimeError(val: "expected YamlMap for literal test")
  end
  // Literal block scalar |- (strip chomping — no trailing newline).
  let doc_strip = "text: |-\n  line one\n  line two\n"
  let v2 = parse(s: doc_strip)
  match v2 do
    | YamlMap(fields: fs) ->
      let sv = get_str_field(fields: fs, key: "text")
      test_assert.assert_eq_string(actual: sv, expected: "line one\nline two", label: "literal block strip")
    | _ -> throw RuntimeError(val: "expected YamlMap for literal strip test")
  end
  // Folded block scalar > (clip chomping — spaces join lines).
  let doc_folded = "text: >\n  line one\n  line two\n"
  let v3 = parse(s: doc_folded)
  match v3 do
    | YamlMap(fields: fs) ->
      let sv = get_str_field(fields: fs, key: "text")
      test_assert.assert_eq_string(actual: sv, expected: "line one line two\n", label: "folded block clip")
    | _ -> throw RuntimeError(val: "expected YamlMap for folded test")
  end
  // Folded block scalar >- (strip chomping).
  let doc_folded_strip = "text: >-\n  line one\n  line two\n"
  let v4 = parse(s: doc_folded_strip)
  match v4 do
    | YamlMap(fields: fs) ->
      let sv = get_str_field(fields: fs, key: "text")
      test_assert.assert_eq_string(actual: sv, expected: "line one line two", label: "folded block strip")
    | _ -> throw RuntimeError(val: "expected YamlMap for folded strip test")
  end
  return ()
end
