// Port of bootstrap/tests/stdlib/string.rs::string_parse_i64_invalid.
// parse_i64 on a non-numeric string returns None.
import * as test_assert from "std:test/assert"
import { parse_i64 } from "std:str"
import { is_none } from "std:option"

let main = fn () -> unit throws { Exn } do
  test_assert.assert_true(
    cond: is_none(opt: parse_i64(s: "not_a_number")),
    label: "parse_i64(\"not_a_number\") is None"
  )
  return ()
end
