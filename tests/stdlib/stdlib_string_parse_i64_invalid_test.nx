// Port of bootstrap/tests/stdlib/string.rs::string_parse_i64_invalid.
// parse_i64 on a non-numeric string returns None.
import { parse_i64 } from "std:str"
import { Option, is_none } from "std:option"

let body = fn () -> unit throws { Exn } do
  let result = is_none(opt: parse_i64(s: "not_a_number"))
  if result != true then raise RuntimeError(val: "expected is_none to be true") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
