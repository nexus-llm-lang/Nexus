// nexus-wvu9: regexp from_string compiles valid patterns and rejects
// invalid ones via InvalidRegexp.
import * as test_assert from "std:test/assert"
import * as re from "std:regexp"

let raises_compile = fn (src: string) -> bool do
  try
    let _ = re.from_string(src)
    return false
  catch _ ->
    return true
  end
end

let compiles_ok = fn (src: string) -> bool do
  try
    let _ = re.from_string(src)
    return true
  catch _ ->
    return false
  end
end

let main = fn () -> unit throws { Exn } do
  // Positive: every documented syntactic form must compile.
  test_assert.assert_true(cond: compiles_ok(src: ""), label: "compile empty")
  test_assert.assert_true(cond: compiles_ok(src: "abc"), label: "compile literal")
  test_assert.assert_true(cond: compiles_ok(src: "a|b|c"), label: "compile alt")
  test_assert.assert_true(cond: compiles_ok(src: "a*b+c?"), label: "compile quantifiers")
  test_assert.assert_true(cond: compiles_ok(src: "a{3}"), label: "compile {n}")
  test_assert.assert_true(cond: compiles_ok(src: "a{2,5}"), label: "compile {n,m}")
  test_assert.assert_true(cond: compiles_ok(src: "a{2,}"), label: "compile {n,}")
  test_assert.assert_true(cond: compiles_ok(src: "[a-z]+"), label: "compile class range")
  test_assert.assert_true(cond: compiles_ok(src: "[^0-9]"), label: "compile negated class")
  test_assert.assert_true(cond: compiles_ok(src: "(?:ab)+"), label: "compile non-capturing")
  test_assert.assert_true(cond: compiles_ok(src: "(a)(b)"), label: "compile groups")
  test_assert.assert_true(cond: compiles_ok(src: "\\d+\\s+\\w+"), label: "compile escapes")
  test_assert.assert_true(cond: compiles_ok(src: "^foo$"), label: "compile anchors")
  test_assert.assert_true(cond: compiles_ok(src: "\\."), label: "compile escaped dot")
  test_assert.assert_true(cond: compiles_ok(src: "a\\\\b"), label: "compile escaped backslash")

  // Negative: must raise InvalidRegexp.
  test_assert.assert_true(cond: raises_compile(src: "("), label: "reject unclosed group")
  test_assert.assert_true(cond: raises_compile(src: "[abc"), label: "reject unclosed class")
  test_assert.assert_true(cond: raises_compile(src: ")"), label: "reject unmatched right paren")
  test_assert.assert_true(cond: raises_compile(src: "a{"), label: "reject malformed quantifier")
  test_assert.assert_true(cond: raises_compile(src: "a{2,1}"), label: "reject reversed {n,m}")
  test_assert.assert_true(cond: raises_compile(src: "\\1"), label: "reject backreference")
  test_assert.assert_true(cond: raises_compile(src: "(?=a)"), label: "reject lookahead")
  test_assert.assert_true(cond: raises_compile(src: "[z-a]"), label: "reject reversed range")
  test_assert.assert_true(cond: raises_compile(src: "a\\"), label: "reject dangling backslash")
  test_assert.assert_true(cond: raises_compile(src: "*foo"), label: "reject leading quantifier")
  test_assert.assert_true(cond: raises_compile(src: "a*?"), label: "reject lazy quantifier")

  return ()
end
