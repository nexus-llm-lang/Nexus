// Companion to bootstrap/tests/stdlib/array.rs.
//
// All five tests in array.rs are typecheck-only checks (four
// should_fail_typecheck with insta snapshot, one should_typecheck).
// Snapshot infra is Rust-only; the positive case is a pure compile-time
// check with no runtime exercise. See PORT_SKIPPED.md.
//
// In place of those, this file exercises the runtime-observable subset of
// std:array that is currently runnable via standalone wasmtime: `length`
// (resolved via `__nx_array_length` external) and `is_empty`. Other array
// stdlib functions (get/set/fold_left/any/all/find_index/map_in_place/
// consume) lower internally through the `arr[idx]` → `__array_get`
// pseudo-call, which the bootstrap codegen does not register as an
// external — calling them currently produces `internal compiler error:
// call target '__array_get' not found in lowered symbols` (E2007).
// Documented as a stdlib-array runtime gap; runtime coverage of those
// functions is deferred to a follow-up after that ICE is fixed.
//
// We deliberately avoid `std:test/assert` here — observed: routing an
// array-length result through `try { assert_eq_i64(...) }` traps the
// compare-and-raise path even when `n == expected` in direct
// `1 / (n - 2)` form. Treated as an unrelated assert/try interaction;
// raise/divide directly so the outcome is unambiguous.
import * as array from "std:array"

let main = fn () -> unit do
  let a = [| 10, 20, 30 |]
  let a_ref = &a
  let n = array.length(arr: a_ref)
  // Trap if length != 3.
  let _ = 1 / (n - 2)

  let single = [| 42 |]
  let single_ref = &single
  let m = array.length(arr: single_ref)
  // Trap if length != 1.
  let _ = 1 / m

  // is_empty on a non-empty array returns false; coerce to i64 and trap
  // if it returned true (i.e., 1 / (1 - 0) succeeds, 1 / (1 - 1) traps).
  let e = array.is_empty(arr: a_ref)
  let e_int = if e then 1 else 0 end
  let _ = 1 / (1 - e_int)

  return ()
end
