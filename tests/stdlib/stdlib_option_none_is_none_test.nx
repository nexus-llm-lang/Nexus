// Port of bootstrap/tests/stdlib/option.rs::option_none_is_none.
import { Option, is_none } from "std:option"

let body = fn () -> unit throws { Exn } do
  let opt: Option<i64> = None
  let r = is_none(opt: opt)
  if r != true then raise RuntimeError(val: "expected is_none true") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
