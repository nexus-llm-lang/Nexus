// protobuf_v3: varint and zigzag round-trip tests.
import * as test_assert from "std:test/assert"
import {
  encode, decode,
  PbField, PbValue, PbVarint, PbFixed64, PbLenDelim, PbFixed32,
  zigzag_encode, zigzag_decode,
  PbThrow
} from "std:protobuf_v3"

// ─── Zigzag helpers ──────────────────────────────────────────────────────────

let main = fn () -> unit throws { Exn } do
  // Zigzag: 0 → 0
  test_assert.assert_eq_i64(
    actual: zigzag_encode(n: 0),
    expected: 0,
    label: "zigzag_encode(0)=0")

  // Zigzag: -1 → 1
  test_assert.assert_eq_i64(
    actual: zigzag_encode(n: -1),
    expected: 1,
    label: "zigzag_encode(-1)=1")

  // Zigzag: 1 → 2
  test_assert.assert_eq_i64(
    actual: zigzag_encode(n: 1),
    expected: 2,
    label: "zigzag_encode(1)=2")

  // Zigzag: -2 → 3
  test_assert.assert_eq_i64(
    actual: zigzag_encode(n: -2),
    expected: 3,
    label: "zigzag_encode(-2)=3")

  // Zigzag decode inverse
  test_assert.assert_eq_i64(
    actual: zigzag_decode(n: zigzag_encode(n: 42)),
    expected: 42,
    label: "zigzag round-trip 42")

  test_assert.assert_eq_i64(
    actual: zigzag_decode(n: zigzag_encode(n: -100)),
    expected: -100,
    label: "zigzag round-trip -100")

  // ─── Varint field round-trip ─────────────────────────────────────────────

  // Encode field 1 with value 150 (multi-byte varint: 0x96 0x01)
  let wire = encode(fields: [PbField(field_number: 1, value: PbVarint(val: 150))])
  let fields = decode(data: wire)
  match fields do
    | PbField(field_number: fn_num, value: PbVarint(val: v)) :: [] ->
      test_assert.assert_eq_i64(actual: fn_num, expected: 1, label: "varint field_number")
      test_assert.assert_eq_i64(actual: v, expected: 150, label: "varint value 150")
    | _ -> test_assert.assert_true(cond: false, label: "expected single PbVarint field")
  end

  // Encode field 2 with value 0
  let wire2 = encode(fields: [PbField(field_number: 2, value: PbVarint(val: 0))])
  let fields2 = decode(data: wire2)
  match fields2 do
    | PbField(field_number: fn_num2, value: PbVarint(val: v2)) :: [] ->
      test_assert.assert_eq_i64(actual: fn_num2, expected: 2, label: "varint zero field_number")
      test_assert.assert_eq_i64(actual: v2, expected: 0, label: "varint value 0")
    | _ -> test_assert.assert_true(cond: false, label: "expected single PbVarint zero")
  end

  // Large varint (field 3, value 2^32)
  let big_val = 4294967296
  let wire3 = encode(fields: [PbField(field_number: 3, value: PbVarint(val: big_val))])
  let fields3 = decode(data: wire3)
  match fields3 do
    | PbField(field_number: fn_num3, value: PbVarint(val: v3)) :: [] ->
      test_assert.assert_eq_i64(actual: fn_num3, expected: 3, label: "large varint field_number")
      test_assert.assert_eq_i64(actual: v3, expected: big_val, label: "large varint value")
    | _ -> test_assert.assert_true(cond: false, label: "expected single large PbVarint")
  end

  return ()
end
