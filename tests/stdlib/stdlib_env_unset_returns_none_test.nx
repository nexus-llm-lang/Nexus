// Port of bootstrap/tests/stdlib/env.rs::env_get_unset_returns_none.
// An env var that is not present in the host environment must surface as
// None through the Env port — never as Some("") (regression for
// nexus-9lp4.25, see env_get_set_to_empty_returns_some_empty in env.rs).
//
// Original test injects an explicit empty-env via exec_with_stdlib_envs;
// here we pick a name unlikely to collide with anything wasmtime inherits.
import { Env }, * as env_mod from "std:env"
import { Option, Some, None } from "std:option"

let body = fn () -> unit require { PermEnv } throws { Exn } do
  inject env_mod.system_handler do
    match Env.get(key: "NX_NEVER_DEFINED_VAR_DVR66") do
      | Some(_) -> raise RuntimeError(val: "expected None for unset var")
      | None -> return ()
    end
  end
end

let safe_run = fn () -> i64 require { PermEnv } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermEnv } do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
