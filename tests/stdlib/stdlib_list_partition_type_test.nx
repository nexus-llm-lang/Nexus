// Port of bootstrap/tests/stdlib/list.rs::partition_type_in_list_module.
// Reframed to use [] / :: instead of Nil / Cons.
import { Partition } from "std:list"

let body = fn () -> unit throws { Exn } do
  let p = Partition(matched: 1 :: [], rest: [])
  match p do
    | Partition(matched: m, rest: _) ->
      match m do
        | v :: _ ->
          if v != 1 then raise RuntimeError(val: "expected 1") end
        | [] -> raise RuntimeError(val: "expected non-empty matched")
      end
  end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
