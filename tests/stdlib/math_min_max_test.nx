// Port of bootstrap/tests/stdlib/math.rs::prop_math_max_symmetry,
// prop_math_min_symmetry, prop_math_max_gte. Original tests were proptests
// over -1000..1000; reframed as a deterministic finite-sample sweep.
// Proptest infra is Rust-only.
import * as test_assert from "std:test/assert"
import * as str from "std:str"
import { max, min } from "std:math"

let pair_label = fn (op: string, a: i64, b: i64) -> string do
  return op ++ "(" ++ str.from_i64(val: a) ++ ", " ++ str.from_i64(val: b) ++ ")"
end

let check_symmetry_max = fn (a: i64, b: i64) -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: max(a, b),
    expected: max(a: b, b: a),
    label: "max symmetry " ++ pair_label(op: "max", a, b)
  )
  return ()
end

let check_symmetry_min = fn (a: i64, b: i64) -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: min(a, b),
    expected: min(a: b, b: a),
    label: "min symmetry " ++ pair_label(op: "min", a, b)
  )
  return ()
end

let check_max_gte = fn (a: i64, b: i64) -> unit throws { Exn } do
  let m = max(a, b)
  test_assert.assert_true(cond: m >= a, label: pair_label(op: "max >= a", a, b))
  test_assert.assert_true(cond: m >= b, label: pair_label(op: "max >= b", a, b))
  return ()
end

let check_min_lte = fn (a: i64, b: i64) -> unit throws { Exn } do
  let m = min(a, b)
  test_assert.assert_true(cond: m <= a, label: pair_label(op: "min <= a", a, b))
  test_assert.assert_true(cond: m <= b, label: pair_label(op: "min <= b", a, b))
  return ()
end

let main = fn () -> unit throws { Exn } do
  // Equal pair, ordered pair, reverse-ordered pair, mixed signs, zeros.
  check_symmetry_max(a: 5, b: 5)
  check_symmetry_max(a: 3, b: 7)
  check_symmetry_max(a: 7, b: 3)
  check_symmetry_max(a: -10, b: 10)
  check_symmetry_max(a: 0, b: 0)
  check_symmetry_max(a: -1000, b: 1000)
  check_symmetry_min(a: 5, b: 5)
  check_symmetry_min(a: 3, b: 7)
  check_symmetry_min(a: 7, b: 3)
  check_symmetry_min(a: -10, b: 10)
  check_symmetry_min(a: 0, b: 0)
  check_symmetry_min(a: -1000, b: 1000)
  check_max_gte(a: 5, b: 5)
  check_max_gte(a: 3, b: 7)
  check_max_gte(a: -50, b: 50)
  check_max_gte(a: -1000, b: -999)
  check_min_lte(a: 5, b: 5)
  check_min_lte(a: 3, b: 7)
  check_min_lte(a: -50, b: 50)
  check_min_lte(a: 1000, b: 999)
  return ()
end
