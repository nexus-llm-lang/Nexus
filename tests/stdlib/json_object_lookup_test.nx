// Port of bootstrap/tests/stdlib/json.rs::json_object_lookup_and_roundtrip.
// get_field returns Some(value) for present keys, None for missing keys,
// and the canonical compact serialization round-trips.
import * as test_assert from "std:test/assert"
import { parse, serialize, get_field, JsonInt, JsonString } from "std:json"
import { Some, None } from "std:option"

let main = fn () -> unit throws { Exn } do
  let raw = "{\"a\":1,\"b\":\"two\"}"
  let v = parse(s: raw)
  match get_field(obj: v, key: "a") do
    | Some(val: JsonInt(val: i)) ->
      test_assert.assert_eq_i64(actual: i, expected: 1, label: "object.a == 1")
    | _ -> throw RuntimeError(val: "missing a")
  end
  match get_field(obj: v, key: "b") do
    | Some(val: JsonString(val: s)) ->
      test_assert.assert_eq_string(actual: s, expected: "two", label: "object.b == \"two\"")
    | _ -> throw RuntimeError(val: "missing b")
  end
  let is_none = match get_field(obj: v, key: "missing") do
    | None -> true
    | Some(_) -> false
  end
  test_assert.assert_true(cond: is_none, label: "object.missing is None")
  test_assert.assert_eq_string(actual: serialize(v), expected: raw, label: "object roundtrip")
  return ()
end
