// YAML block mapping: simple key-value and nested mapping.
import * as test_assert from "std:test/assert"
import { parse, YamlValue, YamlMap, YamlField, YamlString, YamlInt, YamlBool } from "std:yaml"

let get_field = fn (fields: [ YamlField ], key: string) -> YamlValue do
  match fields do
    | [] -> throw RuntimeError(val: "key not found: " ++ key)
    | YamlField(key: k, value: v) :: rest ->
      match k do
        | YamlString(val: s) -> if s == key then return v else return get_field(
          fields: rest,
          key
        ) end
        | _ -> return get_field(fields: rest, key)
      end
  end
end

let main = fn () -> unit throws { Exn } do
  let doc = "name: Alice\nage: 30\nactive: true\n"
  let v = parse(s: doc)
  match v do
    | YamlMap(fields: fs) ->
      match get_field(fields: fs, key: "name") do
        | YamlString(val: s) ->
          test_assert.assert_eq_string(actual: s, expected: "Alice", label: "name field")
        | _ -> throw RuntimeError(val: "name should be YamlString")
      end
      match get_field(fields: fs, key: "age") do
        | YamlInt(val: i) ->
          test_assert.assert_eq_i64(actual: i, expected: 30, label: "age field")
        | _ -> throw RuntimeError(val: "age should be YamlInt")
      end
      match get_field(fields: fs, key: "active") do
        | YamlBool(val: b) ->
          test_assert.assert_true(cond: b, label: "active field")
        | _ -> throw RuntimeError(val: "active should be YamlBool")
      end
    | _ -> throw RuntimeError(val: "expected YamlMap")
  end
  return ()
end
