// Basic smoke test for std:nexus/parse.
// Parses small Nexus source snippets and asserts meaningful properties of the AST.
import * as test_assert from "std:test/assert"
import * as parse_mod from "std:nexus/parse"
import { tokenize } from "std:nexus/lexer"
import { Program, SpannedTopLevel, TopLevel, GlobalLet } from "std:nexus/ast"
import * as list from "std:list"
import * as str from "std:str"

// Count the number of top-level definitions in a parsed program.
let count_defs = fn (defs: [ SpannedTopLevel ]) -> i64 do
  return match defs do
    | [] -> 0
    | _ :: rest -> 1 + count_defs(defs: rest)
  end
end

// Check if parse_source returns a Program with N definitions.
let assert_def_count = fn (src: string, expected: i64, label: string) -> unit throws { Exn } do
  let prog = parse_mod.parse_source(src: src)
  let Program(definitions: defs, module_doc: _) = prog
  let got = count_defs(defs)
  test_assert.assert_eq_i64(actual: got, expected, label)
end

// Check that parse_source_collect of valid source has zero diagnostics.
let assert_clean_parse = fn (src: string, label: string) -> unit throws { Exn } do
  let parse_mod.NxParseResult(prog: _, diags) = parse_mod.parse_source_collect(src: src, file: "")
  let n_diags = count_diags(diags)
  test_assert.assert_eq_i64(actual: n_diags, expected: 0, label)
end

let count_diags = fn (diags: [ parse_mod.NxDiagnostic ]) -> i64 do
  return match diags do
    | [] -> 0
    | _ :: rest -> 1 + count_diags(diags: rest)
  end
end

// Check that parse_source_collect of invalid source has at least one diagnostic.
let assert_has_error = fn (src: string, label: string) -> unit throws { Exn } do
  let parse_mod.NxParseResult(prog: _, diags) = parse_mod.parse_source_collect(src: src, file: "")
  let n_diags = count_diags(diags)
  test_assert.assert_true(cond: n_diags > 0, label)
end

// Extract the name from the first TLLet definition, or return "" on mismatch.
let first_let_name = fn (defs: [ SpannedTopLevel ]) -> string do
  return match defs do
    | SpannedTopLevel(node: TLLet(def: GlobalLet(name: n, is_public: _, typ: _, value: _)), span: _) :: _ ->
      n
    | _ -> ""
  end
end

let main = fn () -> unit throws { Exn } do
  // Empty source produces a program with zero definitions.
  assert_def_count(src: "", expected: 0, label: "empty source has 0 defs")

  // A single let binding produces one definition.
  assert_def_count(src: "let x = 42", expected: 1, label: "single let has 1 def")

  // Two let bindings produce two definitions.
  assert_def_count(
    src: "let a = 1\nlet b = 2",
    expected: 2,
    label: "two lets have 2 defs"
  )

  // The name of the binding is preserved.
  let prog1 = parse_mod.parse_source(src: "let hello = 0")
  let Program(definitions: defs1, module_doc: _) = prog1
  test_assert.assert_eq_string(
    actual: first_let_name(defs: defs1),
    expected: "hello",
    label: "let name is 'hello'"
  )

  // A type definition produces one definition.
  assert_def_count(
    src: "type Point = Point(x: i64, y: i64)",
    expected: 1,
    label: "type def has 1 def"
  )

  // An exception definition produces one definition.
  assert_def_count(
    src: "exception MyError(msg: string)",
    expected: 1,
    label: "exception def has 1 def"
  )

  // Valid source has no parse diagnostics.
  assert_clean_parse(
    src: "let add = fn (a: i64, b: i64) -> i64 do\n  return a + b\nend",
    label: "valid fn has no parse errors"
  )

  // Invalid source (missing `=`) produces at least one diagnostic.
  assert_has_error(
    src: "let bad_syntax",
    label: "missing '=' produces a diagnostic"
  )

  // Module doc extraction: leading /** ... */ is captured.
  let prog_doc = parse_mod.parse_source(src: "/** My module. */\nlet x = 1")
  let Program(definitions: _, module_doc: doc_opt) = prog_doc
  match doc_opt do
    | Some(val: _) ->
      test_assert.assert_true(cond: true, label: "module_doc is Some when /** present")
    | None ->
      test_assert.assert_false(cond: false, label: "module_doc should be Some but was None")
  end

  // Source without doc comment has None module_doc.
  let prog_nodoc = parse_mod.parse_source(src: "let y = 2")
  let Program(definitions: _, module_doc: nodoc_opt) = prog_nodoc
  match nodoc_opt do
    | None ->
      test_assert.assert_true(cond: true, label: "module_doc is None when no /** present")
    | Some(val: _) ->
      test_assert.assert_false(cond: false, label: "module_doc should be None but was Some")
  end

  // parse_collect on valid source returns 0 diagnostics.
  let tokens = tokenize(src: "let z = 99")
  let parse_mod.NxParseResult(prog: prog2, diags: diags2) = parse_mod.parse_collect(tokens, file: "test.nx")
  test_assert.assert_eq_i64(
    actual: count_diags(diags: diags2),
    expected: 0,
    label: "parse_collect has 0 diags for valid source"
  )
  let Program(definitions: defs2, module_doc: _) = prog2
  test_assert.assert_eq_i64(
    actual: count_defs(defs: defs2),
    expected: 1,
    label: "parse_collect returns 1 def for 'let z = 99'"
  )

  return ()
end
