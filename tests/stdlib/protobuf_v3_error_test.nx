// protobuf_v3: error cases — groups rejected, truncated input, bad field number.
import * as test_assert from "std:test/assert"
import {
  encode, decode,
  PbField, PbValue, PbVarint, PbFixed64, PbLenDelim, PbFixed32,
  encode_packed_varints,
  PbThrow
} from "std:protobuf_v3"

// Returns true if decode raises PbError.
let decode_raises = fn (data: string) -> bool do
  try
    let _ = decode(data)
    return false
  catch _ ->
    return true
  end
end

// Returns true if encode raises PbError.
let encode_raises = fn (fields: [PbField]) -> bool do
  try
    let _ = encode(fields)
    return false
  catch _ ->
    return true
  end
end

// Returns true if encode_packed_varints raises PbError.
let packed_raises = fn (field_number: i64, values: [i64]) -> bool do
  try
    let _ = encode_packed_varints(field_number, values)
    return false
  catch _ ->
    return true
  end
end

let main = fn () -> unit throws { Exn } do
  // ─── SGROUP (wire type 3) is rejected ────────────────────────────────────
  // Tag for field 1, wire type 3: (1 << 3) | 3 = 0x0B = 11
  // A single byte 0x0B as input.
  let sgroup_byte = "\x0b"
  test_assert.assert_true(
    cond: decode_raises(data: sgroup_byte),
    label: "SGROUP wire type 3 rejected")

  // ─── EGROUP (wire type 4) is rejected ────────────────────────────────────
  // Tag for field 1, wire type 4: (1 << 3) | 4 = 0x0C = 12
  let egroup_byte = "\x0c"
  test_assert.assert_true(
    cond: decode_raises(data: egroup_byte),
    label: "EGROUP wire type 4 rejected")

  // ─── Truncated length-delimited ──────────────────────────────────────────
  // Tag (field 1, wire type 2 = 0x0A) followed by length 5 but only 2 bytes of payload.
  let truncated_len = "\x0a\x05\x01\x02"
  test_assert.assert_true(
    cond: decode_raises(data: truncated_len),
    label: "truncated length-delimited rejected")

  // ─── Truncated varint ────────────────────────────────────────────────────
  // Tag byte for field 1 varint = 0x08, then a varint with continuation bit
  // set but no following byte.
  let truncated_varint = "\x08\x80"
  test_assert.assert_true(
    cond: decode_raises(data: truncated_varint),
    label: "truncated varint rejected")

  // ─── Invalid field_number (0) in encode ──────────────────────────────────
  test_assert.assert_true(
    cond: encode_raises(fields: [PbField(field_number: 0, value: PbVarint(val: 1))]),
    label: "field_number 0 rejected by encode")

  // ─── Invalid field_number in encode_packed_varints ───────────────────────
  test_assert.assert_true(
    cond: packed_raises(field_number: 0, values: [1, 2, 3]),
    label: "packed field_number 0 rejected")

  // ─── Well-formed encode/decode still works after error cases ─────────────
  let wire = encode(fields: [PbField(field_number: 1, value: PbVarint(val: 7))])
  let fields = decode(data: wire)
  match fields do
    | PbField(field_number: fn1, value: PbVarint(val: v1)) :: [] ->
      test_assert.assert_eq_i64(actual: v1, expected: 7, label: "valid encode after error check")
    | _ -> test_assert.assert_true(cond: false, label: "expected valid field after errors")
  end

  return ()
end
