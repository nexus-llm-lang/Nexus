// Port of bootstrap/tests/stdlib/collections.rs::stringmap_keys_and_values
// (fixture: stringmap_keys_and_values.nx).
//
// stringmap.keys / values return a list of length == size; check both
// against the size after three puts.
import * as test_assert from "std:test/assert"
import * as smap from "std:stringmap"

let list_length = fn <T>(xs: [T]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + list_length(xs: rest)
  end
end

let main = fn () -> unit throws { Exn } do
  let m0 = smap.empty()
  let m1 = smap.put(map: m0, key: "x", value: 1)
  let m2 = smap.put(map: m1, key: "y", value: 2)
  let m3 = smap.put(map: m2, key: "z", value: 3)
  let ks = smap.keys(map: &m3)
  let vs = smap.values(map: &m3)
  let sz = smap.size(map: &m3)
  smap.free(map: m3)
  test_assert.assert_eq_i64(actual: sz, expected: 3, label: "size after 3 puts")
  test_assert.assert_eq_i64(actual: list_length(xs: ks), expected: 3, label: "keys length")
  test_assert.assert_eq_i64(actual: list_length(xs: vs), expected: 3, label: "values length")
  return ()
end
