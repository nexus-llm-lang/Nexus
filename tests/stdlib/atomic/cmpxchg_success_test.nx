// Issue nexus-byiw subset: targeted coverage for `std:runtime/atomic.cmpxchg_i32`
// — the compare-and-swap primitive. The existing atomic intrinsic test
// (tests/codegen/intrinsic_atomic_rmw_test.nx) only covers rmw_add / load /
// store; cmpxchg has its own emitter (emit_atomic_cmpxchg_i32 in
// src/backend/codegen/intrinsics.nx) and a distinct semantics that needs
// pinning.
//
// Contract under test (atomic.nx line 31-36):
//   "Stores `replacement` at `addr` iff the current value equals `expected`.
//    Returns whatever value was at `addr` *before* the attempt; the swap
//    succeeded iff that returned value == `expected`."
//
// This fixture pins the SUCCESS path: prepare cell=42, cmpxchg expecting 42,
// confirm return is 42 (pre-value) and the cell now reads back 99.
// A wrong-arm regression that returned the replacement (or the new cell value)
// would fail "cmpxchg succ returns pre-value 42".
import * as test_assert from "std:test/assert"
import * as atomic from "std:runtime/atomic"
import * as arena from "std:runtime/arena"

let body = fn () -> unit throws { Exn } do
  // Allocate an 8-byte aligned cell (validator demands 4-byte alignment
  // for i32-width atomic ops; alloc_raw gives at least 8-byte alignment).
  let p = arena.alloc_raw(size: 8)
  atomic.store_i32(addr: p, val: 42)

  // cmpxchg with matching expected: succeeds, returns pre-value 42.
  let pre = atomic.cmpxchg_i32(addr: p, expected: 42, replacement: 99)
  test_assert.assert_eq_i64(actual: pre, expected: 42,
    label: "cmpxchg succ returns pre-value 42")

  // Cell must now hold the replacement.
  let after = atomic.load_i32(addr: p)
  test_assert.assert_eq_i64(actual: after, expected: 99,
    label: "cmpxchg succ updated cell to replacement 99")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
