// Issue nexus-byiw subset: targeted coverage for `std:runtime/atomic.cmpxchg_i32`
// — the FAILURE branch. Sibling to cmpxchg_success_test.nx; pins the
// "didn't match expected" semantics that the contract spells out as
// "succeeded iff that returned value == `expected`."
//
// Setup: cell = 7. Call cmpxchg expecting 0 (mismatch). The op must:
//   1. Leave the cell at 7 (no write).
//   2. Return the *current* value 7 (NOT the expected 0, NOT the replacement).
//
// A miscompile that swapped the no-match → no-write branch with a write-anyway
// (or returned `expected` instead of the current cell value) would flunk one
// of these two assertions. The "cell still 7 after failed cmpxchg" assertion
// is the load-bearing guard for any lock-free retry-loop client.
import * as test_assert from "std:test/assert"
import * as atomic from "std:runtime/atomic"
import * as arena from "std:runtime/arena"

let body = fn () -> unit throws { Exn } do
  let p = arena.alloc_raw(size: 8)
  let _ = atomic.store_i32(addr: p, val: 7)

  // expected (0) does NOT match current (7) → cmpxchg must not write,
  // and must return the current value 7.
  let pre = atomic.cmpxchg_i32(addr: p, expected: 0, replacement: 999)
  test_assert.assert_eq_i64(actual: pre, expected: 7,
    label: "cmpxchg fail returns current value 7 (not expected, not replacement)")

  // Confirm the cell is untouched.
  let after = atomic.load_i32(addr: p)
  test_assert.assert_eq_i64(actual: after, expected: 7,
    label: "cmpxchg fail leaves cell unchanged at 7")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
