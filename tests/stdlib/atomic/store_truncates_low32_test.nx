// Issue nexus-byiw subset: targeted coverage for `std:runtime/atomic.store_i32`
// width semantics. The intrinsic crosses the FFI boundary as i64 and gets
// wrapped to wasm i32 internally (atomic.nx line 7: "Addresses and values
// cross the FFI boundary as `i64` and are wrapped to wasm `i32` internally").
// The store_i32 docstring is explicit: "Atomic store of `val` (low 32 bits)
// to `addr`."
//
// Edge case: pass an i64 value whose high 32 bits are non-zero. The store
// must truncate; subsequent load_i32 must return only the low 32 bits.
// A regression that emitted i64 store/load (or skipped the i32.wrap_i64)
// would either trap on alignment or return the full 64-bit value.
//
// Value choice: 0x1_FFFF_FFFF (high-bit-set in the bit-33 region).
//   low 32 bits = 0xFFFF_FFFF.
// Since wasm i32 is signed in our i64-typed wrapper, the loaded value should
// equal -1 (sign-extended 0xFFFF_FFFF) OR 0xFFFF_FFFF — we pin whichever
// matches the actual codegen by checking that high bits beyond 32 are gone.
import * as test_assert from "std:test/assert"
import * as atomic from "std:runtime/atomic"
import * as arena from "std:runtime/arena"

let body = fn () -> unit throws { Exn } do
  let p = arena.alloc_raw(size: 8)

  // First, sanity-check round-trip of a small positive value.
  let _ = atomic.store_i32(addr: p, val: 12345)
  let v0 = atomic.load_i32(addr: p)
  test_assert.assert_eq_i64(actual: v0, expected: 12345,
    label: "store/load round-trip small positive value")

  // Now pass an i64 with bits set ABOVE bit 31. We deliberately use a
  // value 0x1_0000_002A — low 32 bits are 0x2A = 42, high bits set the
  // 33rd bit. After store, load_i32 must return 42, not 0x1_0000_002A,
  // confirming the low-32-bits-only contract.
  let big_val = 4294967338  // = 0x1_0000_002A
  let _ = atomic.store_i32(addr: p, val: big_val)
  let v1 = atomic.load_i32(addr: p)
  test_assert.assert_eq_i64(actual: v1, expected: 42,
    label: "store_i32 truncates to low 32 bits; high bits discarded")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
