// Port of bootstrap/tests/stdlib/char.rs::char_classification.
// The original test re-runs bootstrap/tests/fixtures/test_char_classification.nx
// through exec_with_stdlib; this file inlines that fixture in the
// safe_run/divide-by-zero scaffold used elsewhere under tests/.
import * as test_assert from "std:test/assert"
import * as char from "std:char"

let body = fn () -> unit throws { Exn } do
  // is_alpha
  test_assert.assert_true(cond: char.is_alpha(c: 'a'), label: "a is alpha")
  test_assert.assert_true(cond: char.is_alpha(c: 'Z'), label: "Z is alpha")
  test_assert.assert_false(cond: char.is_alpha(c: '0'), label: "0 not alpha")

  // is_digit
  test_assert.assert_true(cond: char.is_digit(c: '0'), label: "0 is digit")
  test_assert.assert_true(cond: char.is_digit(c: '9'), label: "9 is digit")
  test_assert.assert_false(cond: char.is_digit(c: 'a'), label: "a not digit")

  // is_whitespace
  test_assert.assert_true(cond: char.is_whitespace(c: ' '), label: "space is whitespace")
  test_assert.assert_false(cond: char.is_whitespace(c: 'a'), label: "a not whitespace")

  // is_upper / is_lower
  test_assert.assert_true(cond: char.is_upper(c: 'Z'), label: "Z is upper")
  test_assert.assert_true(cond: char.is_lower(c: 'a'), label: "a is lower")
  test_assert.assert_false(cond: char.is_upper(c: 'a'), label: "a not upper")

  // is_ident_start / is_ident_char
  test_assert.assert_true(cond: char.is_ident_start(c: '_'), label: "_ is ident start")
  test_assert.assert_true(cond: char.is_ident_start(c: 'a'), label: "a is ident start")
  test_assert.assert_false(cond: char.is_ident_start(c: '0'), label: "0 not ident start")
  test_assert.assert_true(cond: char.is_ident_char(c: '_'), label: "_ is ident char")
  test_assert.assert_true(cond: char.is_ident_char(c: '0'), label: "0 is ident char")
  test_assert.assert_false(cond: char.is_ident_char(c: ' '), label: "space not ident char")

  // is_hex_digit
  test_assert.assert_true(cond: char.is_hex_digit(c: 'a'), label: "a is hex digit")
  test_assert.assert_true(cond: char.is_hex_digit(c: 'F'), label: "F is hex digit")
  test_assert.assert_true(cond: char.is_hex_digit(c: '0'), label: "0 is hex digit")

  // digit_value
  test_assert.assert_eq_i64(actual: char.digit_value(c: '0'), expected: 0, label: "digit_value 0")
  test_assert.assert_eq_i64(actual: char.digit_value(c: '9'), expected: 9, label: "digit_value 9")

  // hex_digit_value
  test_assert.assert_eq_i64(actual: char.hex_digit_value(c: 'a'), expected: 10, label: "hex a == 10")
  test_assert.assert_eq_i64(actual: char.hex_digit_value(c: 'F'), expected: 15, label: "hex F == 15")
  test_assert.assert_eq_i64(actual: char.hex_digit_value(c: '0'), expected: 0, label: "hex 0 == 0")

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
