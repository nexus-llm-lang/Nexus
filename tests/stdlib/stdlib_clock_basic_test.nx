// Port of bootstrap/tests/stdlib/clock.rs:
//   clock_now_returns_positive_value,
//   clock_sleep_does_not_crash.
// The other two (denied-cap trap, missing-PermClock typecheck failure)
// require Rust harness wiring; see PORT_SKIPPED.md.
import { Clock }, * as clk from "std:clock"

let body = fn () -> unit require { PermClock } throws { Exn } do
  inject clk.system_handler do
    // clock_now_returns_positive_value: monotonic ticks > 0.
    let t = Clock.now()
    if t <= 0 then raise RuntimeError(val: "clock not positive") end
    // clock_sleep_does_not_crash: 10ms sleep returns cleanly.
    Clock.sleep(ms: 10)
    return ()
  end
end

let safe_run = fn () -> i64 require { PermClock } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermClock } do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
