// Port of bootstrap/tests/stdlib/json.rs::json_trailing_data_rejected.
// Bytes after a complete top-level value are rejected; parse must raise.
import { parse } from "std:json"

let body = fn () -> unit throws { Exn } do
  try
    let _ = parse(s: "1 2")
    raise RuntimeError(val: "expected error on trailing data")
  catch _ ->
    return ()
  end
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
