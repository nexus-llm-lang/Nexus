// Pilot (nexus-5hsbc wave-2): `forall_with` with `PropOpts.coop_progress = true`
// runs the trial loop under a std:concurrency/coop scheduler with a spawned
// progress reporter. This must produce the SAME Pass/Fail verdict as the
// default sequential path — the cooperative scheduling only interleaves a
// reporter fiber; the property/generator are pure so the run stays exit-0
// (twyov-safe). Covers both a passing property (→ Pass) and a failing one
// (→ Fail, with the witness re-derived from the failing seed OUTSIDE the coop
// block, since only i64s cross the suspend/resume boundary).
//
// Trial counts are well past the old 64-slot cont-table limit (100 trials ⇒
// ~200 suspends), exercising the de-globalized dispatcher's per-fiber slot
// reuse — coop_progress would have trapped at ~31 trials before that fix.
import * as test_assert from "std:test/assert"
import * as prop from "std:test/prop"
import { Option, Some, None } from "std:option"
import { Console } from "std:stdio"
import * as stdio from "std:stdio"

let body = fn () -> unit require { Console } throws { Exn } do
  // Passing property: x == x always holds → Pass, under cooperative progress,
  // at 100 trials (~200 suspends — far past the old 64-slot limit).
  let always = fn (x: i64) -> bool do
    let ok = x == x
    return ok
  end
  let pass_opts = prop.PropOpts(trials: 100, seed: Some(val: 42), coop_progress: true)
  let pass_res = prop.forall_with(g: prop.small_int, prop: always, opts: pass_opts)
  test_assert.assert_true(cond: prop.passed(r: pass_res),
    label: "coop pass-path: " ++ prop.render_summary(r: pass_res))

  // Failing property: x < 50 fails for the upper quarter of small_int's range,
  // so 100 trials at a fixed seed deterministically find a counterexample →
  // Fail. Confirms the coop found-flag + seed re-derivation path.
  let under50 = fn (x: i64) -> bool do
    let ok = x < 50
    return ok
  end
  let fail_opts = prop.PropOpts(trials: 100, seed: Some(val: 42), coop_progress: true)
  let fail_res = prop.forall_with(g: prop.small_int, prop: under50, opts: fail_opts)
  test_assert.assert_true(cond: !prop.passed(r: fail_res),
    label: "coop fail-path should find a counterexample: " ++ prop.render_summary(r: fail_res))

  // The same failing property under the DEFAULT (sequential) path must agree.
  let seq_opts = prop.PropOpts(trials: 100, seed: Some(val: 42), coop_progress: false)
  let seq_res = prop.forall_with(g: prop.small_int, prop: under50, opts: seq_opts)
  test_assert.assert_true(cond: !prop.passed(r: seq_res),
    label: "sequential path must agree with coop verdict: " ++ prop.render_summary(r: seq_res))
  return ()
end

let safe_run = fn () -> i64 require { Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
