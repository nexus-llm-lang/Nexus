// Property: reverse(reverse(xs)) == xs over i64 lists.
// Should pass with 100 trials at the default seed.
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import * as prop from "std:test/prop"
import { Option, Some, None } from "std:option"
import { Console } from "std:stdio"
import * as stdio from "std:stdio"

let i64_list_eq = fn (xs: [ i64 ], ys: [ i64 ]) -> bool do
  match xs do
    | [] ->
      match ys do
        | [] -> return true
        | _ :: _ -> return false
      end
    | x :: xrest ->
      match ys do
        | [] -> return false
        | y :: yrest ->
          if x == y then
            return i64_list_eq(xs: xrest, ys: yrest)
          else
            return false
          end
      end
  end
end

let body = fn () -> unit require { Console } throws { Exn } do
  let gen = prop.bounded_list(g: prop.small_int, max: 20)
  let check = fn (xs: [ i64 ]) -> bool do
    // Bind the result to a local first so the closure does not emit a
    // type-incoherent `return_call` (closure ABI is i64, i64_list_eq returns
    // bool/i32 — see the codegen note in prop.nx::property).
    let ok = i64_list_eq(xs: list.reverse(xs: list.reverse(xs)), ys: xs)
    return ok
  end
  let opts = prop.PropOpts(trials: 100, seed: Some(val: 42), coop_progress: false)
  let result = prop.forall_with(g: gen, prop: check, opts)
  test_assert.assert_true(cond: prop.passed(r: result), label: prop.render_summary(r: result))
  return ()
end

let safe_run = fn () -> i64 require { Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
