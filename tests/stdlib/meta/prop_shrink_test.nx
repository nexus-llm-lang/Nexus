// Property: deliberately-wrong `length(xs) < 5` — the shrinker should
// minimise the failing counterexample to a list of length exactly 5
// (the smallest input that violates the predicate).
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import * as prop from "std:pbt"
import { Option, Some, None } from "std:option"
import { Console } from "std:stdio"
import * as stdio from "std:stdio"

let body = fn () -> unit require { Console } throws { Exn } do
  // Pick a range that gives generous random spread but bounded element
  // values so the shrinker is exercised primarily on length.
  let gen = prop.bounded_list(g: prop.small_int, max: 30)
  let check = fn (xs: [ i64 ]) -> bool do
    return list.length(xs) < 5
  end
  let opts = prop.PropOpts(trials: 100, seed: Some(val: 7))
  let result = prop.forall_with(g: gen, prop: check, opts)

  // The property is wrong, so we expect a FAIL outcome.
  test_assert.assert_false(
    cond: prop.passed(r: result),
    label: "expected property to fail: " ++ prop.render_summary(r: result)
  )

  // And the shrunk counterexample must be a list of length exactly 5 —
  // the smallest input violating `length(xs) < 5`.
  match prop.counterexample(r: result) do
    | None -> test_assert.assert(cond: false, label: "expected a counterexample, got None")
    | Some(val: xs) ->
      test_assert.assert_eq_i64(actual: list.length(xs), expected: 5,
        label: "shrunk counterexample length")
  end
  return ()
end

let safe_run = fn () -> i64 require { Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
