// Port of bootstrap/tests/stdlib/fs.rs::fs_append_and_read_roundtrip.
// write_string + append_string + read_to_string compose into a known
// final content. Original used TempDir; here a fixed path under /tmp
// (mounted by bootstrap.sh's wasmtime --dir flag).
import { Fs }, * as fs_mod from "std:fs"
import { length, contains } from "std:str"

let body = fn () -> unit require { PermFs } throws { Exn } do
  inject fs_mod.system_handler do
    let dir = "/tmp/nx_dvr66_append"
    let file = "/tmp/nx_dvr66_append/note.txt"
    Fs.create_dir_all(path: dir)
    Fs.write_string(path: file, content: "hello")
    Fs.append_string(path: file, content: " world")
    let content = Fs.read_to_string(path: file)
    let n = length(s: content)
    if n != 11 then raise RuntimeError(val: "expected length 11") end
    let ok = contains(s: content, sub: "world")
    if ok != true then raise RuntimeError(val: "expected contains world") end
    return ()
  end
end

let safe_run = fn () -> i64 require { PermFs } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermFs } do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
