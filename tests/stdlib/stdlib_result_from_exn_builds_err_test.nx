// Port of bootstrap/tests/stdlib/result.rs::result_from_exn_builds_err.
// from_exn must wrap an Exn into Err and is_err must report true.
import * as result from "std:result"

let body = fn () -> unit throws { Exn } do
  let exn = RuntimeError(val: "boom")
  let r = result.from_exn(exn: exn)
  let ok = result.is_err(res: r)
  if ok != true then raise RuntimeError(val: "expected is_err to be true") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
