// Port of bootstrap/tests/stdlib/json.rs::json_roundtrip_null_true_false.
// JSON null/true/false atoms parse and serialize back to canonical form.
import * as test_assert from "std:test/assert"
import { parse, serialize } from "std:json"

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_string(actual: serialize(v: parse(s: "null")), expected: "null", label: "null roundtrip")
  test_assert.assert_eq_string(actual: serialize(v: parse(s: "true")), expected: "true", label: "true roundtrip")
  test_assert.assert_eq_string(actual: serialize(v: parse(s: "false")), expected: "false", label: "false roundtrip")
  return ()
end
