// Port of bootstrap/tests/stdlib/json.rs::json_roundtrip_null_true_false.
// JSON null/true/false atoms parse and serialize back to canonical form.
import { parse, serialize } from "std:json"

let body = fn () -> unit throws { Exn } do
  let n = parse(s: "null")
  if serialize(v: n) != "null" then raise RuntimeError(val: "null roundtrip") end

  let t = parse(s: "true")
  if serialize(v: t) != "true" then raise RuntimeError(val: "true roundtrip") end

  let f = parse(s: "false")
  if serialize(v: f) != "false" then raise RuntimeError(val: "false roundtrip") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
