// Port of bootstrap/tests/stdlib/option.rs::tuple_fst_returns_left.
// (Lives in option.rs upstream but exercises std:tuple.)
import { Pair, fst, snd } from "std:tuple"

let body = fn () -> unit throws { Exn } do
  let p = Pair(left: 10, right: 20)
  let l = fst(p: p)
  if l != 10 then raise RuntimeError(val: "expected 10") end
  let r = snd(p: p)
  if r != 20 then raise RuntimeError(val: "expected 20") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
