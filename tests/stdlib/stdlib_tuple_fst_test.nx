// Port of bootstrap/tests/stdlib/option.rs::tuple_fst_returns_left.
// (Lives in option.rs upstream but exercises std:tuple.)
import * as test_assert from "std:test/assert"
import { Pair, fst, snd } from "std:tuple"

let main = fn () -> unit throws { Exn } do
  let p = Pair(left: 10, right: 20)
  test_assert.assert_eq_i64(actual: fst(p), expected: 10, label: "fst(Pair(10, 20))")
  test_assert.assert_eq_i64(actual: snd(p), expected: 20, label: "snd(Pair(10, 20))")
  return ()
end
