// Port of bootstrap/tests/stdlib/json.rs::json_number_boundaries.
// Integer / float discrimination at parse time:
//   - negative ints, zero, i64 max/min round-trip as JsonInt
//   - any literal with a fractional or exponent part lands as JsonFloat
import * as test_assert from "std:test/assert"
import { parse, JsonInt, JsonFloat } from "std:json"

let expect_int = fn (s: string, want: i64) -> unit throws { Exn } do
  let v = parse(s)
  match v do
    | JsonInt(val: got) ->
      test_assert.assert_eq_i64(actual: got, expected: want, label: "JsonInt for " ++ s)
    | _ -> raise RuntimeError(val: "expected JsonInt for " ++ s)
  end
end

let expect_float_round = fn (s: string) -> unit throws { Exn } do
  let v = parse(s)
  let is_float = match v do
    | JsonFloat(_) -> true
    | _ -> false
  end
  test_assert.assert_true(cond: is_float, label: "JsonFloat for " ++ s)
end

let main = fn () -> unit throws { Exn } do
  // Negative integer.
  expect_int(s: "-42", want: -42)
  // Zero.
  expect_int(s: "0", want: 0)
  // i64 max.
  expect_int(s: "9223372036854775807", want: 9223372036854775807)
  // i64 min — written as -9223372036854775807 - 1 because the unary minus on
  // the bare 9223372036854775808 literal overflows during lex.
  expect_int(s: "-9223372036854775808", want: -9223372036854775807 - 1)
  // Fractional.
  expect_float_round(s: "3.1415926535")
  // Exponent (lowercase).
  expect_float_round(s: "1e10")
  // Exponent (uppercase, signed).
  expect_float_round(s: "-2.5E-3")
  // Negative fractional with leading zero in integer part.
  expect_float_round(s: "-0.5")
  return ()
end
