// YAML flow sequences and flow mappings.
import * as test_assert from "std:test/assert"
import { parse, YamlValue, YamlSeq, YamlMap, YamlField, YamlString, YamlInt } from "std:yaml"

let main = fn () -> unit throws { Exn } do
  // Flow sequence.
  let seq_v = parse(s: "[1, 2, 3]")
  match seq_v do
    | YamlSeq(items: xs) ->
      test_assert.assert_eq_i64(actual: 3, expected: 3, label: "flow seq length")
      match xs do
        | YamlInt(val: a) :: YamlInt(val: b) :: YamlInt(val: c) :: [] ->
          test_assert.assert_eq_i64(actual: a, expected: 1, label: "seq[0]")
          test_assert.assert_eq_i64(actual: b, expected: 2, label: "seq[1]")
          test_assert.assert_eq_i64(actual: c, expected: 3, label: "seq[2]")
        | _ -> throw RuntimeError(val: "unexpected seq items")
      end
    | _ -> throw RuntimeError(val: "expected YamlSeq")
  end
  // Flow mapping.
  let map_v = parse(s: "{x: 10, y: 20}")
  match map_v do
    | YamlMap(fields: fs) ->
      test_assert.assert_eq_i64(actual: 2, expected: 2, label: "flow map field count")
      match fs do
        | YamlField(key: YamlString(val: k1), value: YamlInt(val: v1)) ::
          YamlField(key: YamlString(val: k2), value: YamlInt(val: v2)) :: [] ->
          test_assert.assert_eq_string(actual: k1, expected: "x", label: "map key x")
          test_assert.assert_eq_i64(actual: v1, expected: 10, label: "map val x")
          test_assert.assert_eq_string(actual: k2, expected: "y", label: "map key y")
          test_assert.assert_eq_i64(actual: v2, expected: 20, label: "map val y")
        | _ -> throw RuntimeError(val: "unexpected map fields")
      end
    | _ -> throw RuntimeError(val: "expected YamlMap")
  end
  return ()
end
