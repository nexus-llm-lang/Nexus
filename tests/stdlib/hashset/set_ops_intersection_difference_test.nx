// Issue nexus-byiw subset: unit-test `hset_intersection` and
// `hset_difference` (nxlib/stdlib/runtime/collection/hashset.nx).
//
// Both are implemented via `hs_copy_if` with the want_present flag:
//   intersection → want_present = true
//   difference   → want_present = false
// A regression that swapped the flags would silently invert the
// operations — calls to intersection would return the difference, etc.
// Pinning both with the SAME pair of inputs catches this directly.
//
// Edge cases pinned:
//   1. Intersection of overlapping sets: only common members survive.
//   2. Intersection with disjoint sets: empty result.
//   3. Difference A \ B: members in A and not in B; size = |A| - |A∩B|.
//   4. Difference with empty B: result == A.
//   5. Difference A \ A: empty result.
//   6. Result-set independence: free()-ing the result must not affect
//      the inputs (the result is a freshly-allocated map, not a view).
import * as test_assert from "std:test/assert"
import * as cm from "std:runtime/collection"

let body = fn () -> unit throws { Exn } do
  // Build A = {1, 2, 3, 4}, B = {3, 4, 5, 6}.  A∩B = {3,4}, A\B = {1,2}.
  let a = cm.hset_new()
  let _ = cm.hset_insert(a_id: a, b_val: 1)
  let _ = cm.hset_insert(a_id: a, b_val: 2)
  let _ = cm.hset_insert(a_id: a, b_val: 3)
  let _ = cm.hset_insert(a_id: a, b_val: 4)
  let b = cm.hset_new()
  let _ = cm.hset_insert(a_id: b, b_val: 3)
  let _ = cm.hset_insert(a_id: b, b_val: 4)
  let _ = cm.hset_insert(a_id: b, b_val: 5)
  let _ = cm.hset_insert(a_id: b, b_val: 6)

  // ── case 1: intersection ──
  let inter = cm.hset_intersection(a_id_a: a, b_id_b: b)
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: inter), expected: 2,
    label: "hset_intersection: |A∩B| = 2 (members {3,4})")
  test_assert.assert_true(cond: cm.hset_contains(a_id: inter, b_val: 3),
    label: "hset_intersection: contains 3")
  test_assert.assert_true(cond: cm.hset_contains(a_id: inter, b_val: 4),
    label: "hset_intersection: contains 4")
  test_assert.assert_false(cond: cm.hset_contains(a_id: inter, b_val: 1),
    label: "hset_intersection: excludes 1 (only in A)")
  test_assert.assert_false(cond: cm.hset_contains(a_id: inter, b_val: 5),
    label: "hset_intersection: excludes 5 (only in B)")

  // ── case 2: disjoint intersection = ∅ ──
  let x = cm.hset_new()
  let _ = cm.hset_insert(a_id: x, b_val: 100)
  let _ = cm.hset_insert(a_id: x, b_val: 200)
  let inter_empty = cm.hset_intersection(a_id_a: a, b_id_b: x)
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: inter_empty),
    expected: 0, label: "hset_intersection: disjoint sets → ∅")

  // ── case 3: difference A\B ──
  let diff = cm.hset_difference(a_id_a: a, b_id_b: b)
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: diff), expected: 2,
    label: "hset_difference: |A\\B| = 2 (members {1,2})")
  test_assert.assert_true(cond: cm.hset_contains(a_id: diff, b_val: 1),
    label: "hset_difference: contains 1")
  test_assert.assert_true(cond: cm.hset_contains(a_id: diff, b_val: 2),
    label: "hset_difference: contains 2")
  test_assert.assert_false(cond: cm.hset_contains(a_id: diff, b_val: 3),
    label: "hset_difference: excludes 3 (in B)")

  // ── case 4: A \ ∅ = A ──
  let e_empty = cm.hset_new()
  let diff_e = cm.hset_difference(a_id_a: a, b_id_b: e_empty)
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: diff_e), expected: 4,
    label: "hset_difference: A \\ ∅ = A (size)")
  test_assert.assert_true(cond: cm.hset_contains(a_id: diff_e, b_val: 1),
    label: "hset_difference: A \\ ∅ contains 1")

  // ── case 5: A \ A = ∅ ──
  let diff_self = cm.hset_difference(a_id_a: a, b_id_b: a)
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: diff_self), expected: 0,
    label: "hset_difference: A \\ A = ∅")

  // ── case 6: result independence — freeing result leaves A intact ──
  cm.hset_free(a_id: inter)
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: a), expected: 4,
    label: "hset_intersection: freeing result preserves source A")
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: b), expected: 4,
    label: "hset_intersection: freeing result preserves source B")

  cm.hset_free(a_id: a)
  cm.hset_free(a_id: b)
  cm.hset_free(a_id: x)
  cm.hset_free(a_id: inter_empty)
  cm.hset_free(a_id: diff)
  cm.hset_free(a_id: diff_e)
  cm.hset_free(a_id: diff_self)
  cm.hset_free(a_id: e_empty)
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
