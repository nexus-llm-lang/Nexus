// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/runtime/collection/hashset.nx::hset_union` —
// produces a NEW set containing every element of either input.
// Uses hs_copy_all under the hood, called once per source.
//
// Edge cases pinned:
//   1. Union of two disjoint sets: |A∪B| = |A| + |B|.
//   2. Union with overlap: duplicates are NOT double-counted
//      (the second copy is an hm_put-overwrite, not a fresh insert).
//   3. Union with empty A: result == B (size match + membership).
//   4. Union with empty B: result == A.
//   5. Inputs are NOT mutated: A and B retain their original sizes
//      after the union call (the underlying hs_copy_all reads source,
//      writes to a fresh `r` map — verify the read side is read-only).
import * as test_assert from "std:test/assert"
import * as cm from "std:runtime/collection"

let body = fn () -> unit throws { Exn } do
  // ── case 1: disjoint union ──
  let a = cm.hset_new()
  cm.hset_insert(a_id: a, b_val: 1)
  cm.hset_insert(a_id: a, b_val: 2)
  let b = cm.hset_new()
  cm.hset_insert(a_id: b, b_val: 3)
  cm.hset_insert(a_id: b, b_val: 4)
  let u_disjoint = cm.hset_union(a_id_a: a, b_id_b: b)
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: u_disjoint),
    expected: 4, label: "hset_union: disjoint sizes add (|{1,2} ∪ {3,4}| = 4)")
  test_assert.assert_true(cond: cm.hset_contains(a_id: u_disjoint, b_val: 1),
    label: "hset_union: contains 1 from A")
  test_assert.assert_true(cond: cm.hset_contains(a_id: u_disjoint, b_val: 4),
    label: "hset_union: contains 4 from B")
  cm.hset_free(a_id: u_disjoint)

  // ── case 2: overlap — duplicates merged ──
  let c = cm.hset_new()
  cm.hset_insert(a_id: c, b_val: 1)
  cm.hset_insert(a_id: c, b_val: 2)
  cm.hset_insert(a_id: c, b_val: 3)
  let d = cm.hset_new()
  cm.hset_insert(a_id: d, b_val: 2)
  cm.hset_insert(a_id: d, b_val: 3)
  cm.hset_insert(a_id: d, b_val: 4)
  let u_overlap = cm.hset_union(a_id_a: c, b_id_b: d)
  // |C∪D| = |{1,2,3,4}| = 4, NOT 6.
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: u_overlap),
    expected: 4, label: "hset_union: overlap NOT double-counted (|{1,2,3}∪{2,3,4}| = 4)")
  cm.hset_free(a_id: u_overlap)

  // ── case 3: union with empty A ──
  let e_empty = cm.hset_new()
  let u_e_a = cm.hset_union(a_id_a: e_empty, b_id_b: c)
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: u_e_a),
    expected: 3, label: "hset_union: ∅ ∪ C = C (size)")
  test_assert.assert_true(cond: cm.hset_contains(a_id: u_e_a, b_val: 1),
    label: "hset_union: ∅ ∪ C contains 1")
  cm.hset_free(a_id: u_e_a)

  // ── case 4: union with empty B ──
  let u_a_e = cm.hset_union(a_id_a: c, b_id_b: e_empty)
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: u_a_e),
    expected: 3, label: "hset_union: C ∪ ∅ = C (size)")
  cm.hset_free(a_id: u_a_e)

  // ── case 5: inputs not mutated ──
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: c), expected: 3,
    label: "hset_union: source A unchanged")
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: d), expected: 3,
    label: "hset_union: source B unchanged")

  cm.hset_free(a_id: a)
  cm.hset_free(a_id: b)
  cm.hset_free(a_id: c)
  cm.hset_free(a_id: d)
  cm.hset_free(a_id: e_empty)
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
