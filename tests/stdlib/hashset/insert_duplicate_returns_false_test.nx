// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/runtime/collection/hashset.nx::hset_insert` —
// the boolean return value contract: true on a NEW insertion, false
// on a duplicate. A regression that returned true unconditionally
// would silently break any caller using insert-result to detect
// first-vs-duplicate (e.g. dedup loops, "if let _ = insert(x)" gates).
//
// Edge cases pinned:
//   1. Empty set: hset_size == 0, hset_contains(_) == false for any key.
//   2. First insert returns true; size becomes 1; contains() flips to true.
//   3. Re-insert of the SAME key returns false; size stays at 1.
//   4. Second distinct key returns true; size becomes 2.
//   5. Insert of a NEGATIVE key works (i64 keys, not "non-negative i64").
import * as test_assert from "std:test/assert"
import * as cm from "std:runtime/collection"

let body = fn () -> unit throws { Exn } do
  // ── case 1: empty set ──
  let s = cm.hset_new()
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: s), expected: 0,
    label: "hset_size: empty set size = 0")
  test_assert.assert_false(cond: cm.hset_contains(a_id: s, b_val: 42),
    label: "hset_contains: empty set has no members")

  // ── case 2: first insert returns true ──
  let ins1 = cm.hset_insert(a_id: s, b_val: 42)
  test_assert.assert_true(cond: ins1,
    label: "hset_insert: first insertion returns true")
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: s), expected: 1,
    label: "hset_size: after one insert = 1")
  test_assert.assert_true(cond: cm.hset_contains(a_id: s, b_val: 42),
    label: "hset_contains: inserted member is present")

  // ── case 3: re-insert of the SAME key returns false ──
  let ins2 = cm.hset_insert(a_id: s, b_val: 42)
  test_assert.assert_false(cond: ins2,
    label: "hset_insert: duplicate insertion returns false")
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: s), expected: 1,
    label: "hset_size: duplicate insert does not grow size")

  // ── case 4: distinct key bumps size ──
  let ins3 = cm.hset_insert(a_id: s, b_val: 99)
  test_assert.assert_true(cond: ins3,
    label: "hset_insert: distinct key returns true")
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: s), expected: 2,
    label: "hset_size: after distinct insert = 2")

  // ── case 5: negative key ──
  let ins4 = cm.hset_insert(a_id: s, b_val: 0 - 7)
  test_assert.assert_true(cond: ins4,
    label: "hset_insert: negative key returns true")
  test_assert.assert_true(cond: cm.hset_contains(a_id: s, b_val: 0 - 7),
    label: "hset_contains: negative key round-trips")
  cm.hset_free(a_id: s)
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
