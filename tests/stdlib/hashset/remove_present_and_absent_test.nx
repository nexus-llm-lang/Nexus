// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/runtime/collection/hashset.nx::hset_remove` —
// boolean return value indicates whether the element was present.
//
// Edge cases pinned:
//   1. Remove from empty set returns false (no crash).
//   2. Remove of present member returns true; size decrements.
//   3. Remove of absent member from non-empty set returns false;
//      size unchanged.
//   4. Re-remove of the same key returns false (already gone).
//   5. After removal, contains() reflects the deletion.
//   6. Re-insert after remove returns TRUE (the slot is fully reclaimed,
//      not a "present-but-tombstoned" state).
import * as test_assert from "std:test/assert"
import * as cm from "std:runtime/collection"

let body = fn () -> unit throws { Exn } do
  let s = cm.hset_new()

  // ── case 1: remove from empty ──
  let r0 = cm.hset_remove(a_id: s, b_val: 1)
  test_assert.assert_false(cond: r0,
    label: "hset_remove: empty set returns false")
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: s), expected: 0,
    label: "hset_size: still 0 after no-op remove")

  // populate
  cm.hset_insert(a_id: s, b_val: 10)
  cm.hset_insert(a_id: s, b_val: 20)
  cm.hset_insert(a_id: s, b_val: 30)
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: s), expected: 3,
    label: "hset_size: 3 after three inserts")

  // ── case 2: remove of present member ──
  let r1 = cm.hset_remove(a_id: s, b_val: 20)
  test_assert.assert_true(cond: r1,
    label: "hset_remove: present member returns true")
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: s), expected: 2,
    label: "hset_size: 2 after one remove")

  // ── case 3: remove of absent member (not in set) ──
  let r2 = cm.hset_remove(a_id: s, b_val: 999)
  test_assert.assert_false(cond: r2,
    label: "hset_remove: absent member returns false")
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: s), expected: 2,
    label: "hset_size: unchanged after no-op remove on non-empty set")

  // ── case 4: re-remove of the same key returns false ──
  let r3 = cm.hset_remove(a_id: s, b_val: 20)
  test_assert.assert_false(cond: r3,
    label: "hset_remove: already-removed key returns false")

  // ── case 5: contains() reflects removal ──
  test_assert.assert_false(cond: cm.hset_contains(a_id: s, b_val: 20),
    label: "hset_contains: removed member absent")
  test_assert.assert_true(cond: cm.hset_contains(a_id: s, b_val: 10),
    label: "hset_contains: untouched member 10 still present")
  test_assert.assert_true(cond: cm.hset_contains(a_id: s, b_val: 30),
    label: "hset_contains: untouched member 30 still present")

  // ── case 6: re-insert after remove returns true ──
  let r4 = cm.hset_insert(a_id: s, b_val: 20)
  test_assert.assert_true(cond: r4,
    label: "hset_insert: re-insert after remove returns true (slot reclaimed)")
  test_assert.assert_eq_i64(actual: cm.hset_size(a_id: s), expected: 3,
    label: "hset_size: back to 3 after re-insert")
  cm.hset_free(a_id: s)
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
