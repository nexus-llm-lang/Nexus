// Port of bootstrap/tests/stdlib/env.rs::env_mock_handler.
// A user-defined handler for the `Env` port short-circuits the system
// handler — useful for testing code that calls Env.get/set without
// touching the host process's environment.
import { Env } from "std:env"
import { Option, Some, None } from "std:option"
import { byte_length } from "std:str"

let mock_env = handler Env do
  fn get(key: string) -> Option<string> do
    return Some(val: "mock_value")
  end
  fn set(key: string, value: string) -> unit do
    return ()
  end
end

let body = fn () -> unit throws { Exn } do
  inject mock_env do
    let result = Env.get(key: "MOCK_VAR")
    match result do
      | Some(val: v) ->
        if v != "mock_value" then raise RuntimeError(val: "expected mock_value") end
        // byte_length is referenced so the std bundle gets linked, which
        // forces the bundler to emit the wasi:cli/run wrapper. Without
        // any std-external reference the test still typechecks but
        // produces a bare-component wasm with no wasi:cli/run, and
        // `wasmtime run` rejects it with "no exported instance named
        // `wasi:cli/run@0.2.6`". The check against length 0 of the empty
        // string is incidental.
        if byte_length(s: "") != 0 then raise RuntimeError(val: "byte_length sanity") end
        return ()
      | None -> raise RuntimeError(val: "expected Some")
    end
  end
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
