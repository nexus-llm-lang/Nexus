// Port of bootstrap/tests/stdlib/arena.rs::arena_echo_workload_g0_grows_without_reset.
//
// Same per-request workload as the bounded test, run for 1_000 iterations
// WITHOUT heap_mark / heap_reset wrapping. Self-asserts that the G0 bump
// pointer GREW by at least one byte per iteration — the leak shape that
// the mark/reset fix eliminates.
import * as test_assert from "std:test/assert"
import { heap_mark } from "std:arena"
import { length, from_i64, substring } from "std:str"

let g0_of = fn (mark: i64) -> i64 do
  return mark & 4294967295
end

let simulate_echo_handler = fn (i: i64) -> i64 do
  let id_str = from_i64(val: i)
  let path = "/echo/" ++ id_str
  let body_in = "ping " ++ id_str
  let header = "content-type:text/plain\nlength:" ++ from_i64(val: length(s: body_in))
  let response_full = header ++ "\n\n" ++ "echo: " ++ body_in ++ " path=" ++ path
  let _ = substring(s: response_full, start: 0, len: 4)
  return length(s: response_full)
end

let body = fn () -> unit throws { Exn } do
  let mark0 = heap_mark()
  let g0_before = g0_of(mark: mark0)
  let ~i = 0
  let ~acc = 0
  while ~i < 1000 do
    let n = simulate_echo_handler(i: ~i)
    ~acc <- ~acc + n
    ~i <- ~i + 1
  end
  let mark1 = heap_mark()
  let g0_after = g0_of(mark: mark1)
  // Threshold of 1000 bytes is comfortably below 60 bytes/iter * 1000 = 60_000
  // but high enough that a DCE'd workload wouldn't reach it.
  test_assert.assert_true(cond: g0_after > g0_before + 1000, label: "G0 grew by > 1000 bytes")
  test_assert.assert_true(cond: ~acc > 0, label: "loop body executed (acc > 0)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
