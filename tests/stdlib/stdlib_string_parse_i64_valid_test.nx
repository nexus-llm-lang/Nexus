// Port of bootstrap/tests/stdlib/string.rs::string_parse_i64_valid.
// parse_i64("42") returns Some(42); unwrap_or with default 0 yields 42.
import * as test_assert from "std:test/assert"
import { parse_i64 } from "std:str"
import { unwrap_or } from "std:option"

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: unwrap_or(opt: parse_i64(s: "42"), default: 0),
    expected: 42,
    label: "parse_i64(\"42\") unwrap_or 0"
  )
  return ()
end
