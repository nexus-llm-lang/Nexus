// Port of bootstrap/tests/stdlib/string.rs::string_parse_i64_valid.
// parse_i64("42") returns Some(42); unwrap_or with default 0 yields 42.
import { parse_i64 } from "std:str"
import { Option, unwrap_or } from "std:option"

let body = fn () -> unit throws { Exn } do
  let result = unwrap_or(opt: parse_i64(s: "42"), default: 0)
  if result != 42 then raise RuntimeError(val: "expected 42") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
