// Regression test for nexus-05ga: pad_right fill-cycle must start at offset 0.
// pad_right("abc", 5, "XY") must produce "abcXY", not "abcYX".
import * as test_assert from "std:test/assert"
import { pad_right } from "std:str"

let main = fn () -> unit throws { Exn } do
  let result = pad_right(s: "abc", width: 5, fill: "XY")
  test_assert.assert_eq_string(
    actual: result,
    expected: "abcXY",
    label: "pad_right(\"abc\", 5, \"XY\")"
  )
  return ()
end
