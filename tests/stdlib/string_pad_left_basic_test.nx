// Port of bootstrap/tests/stdlib/string.rs::string_pad_left_basic.
// pad_left("42", width: 5, fill: "0") must produce a 5-byte string.
import * as test_assert from "std:test/assert"
import { pad_left, length } from "std:str"

let main = fn () -> unit throws { Exn } do
  let result = pad_left(s: "42", width: 5, fill: "0")
  test_assert.assert_eq_i64(
    actual: length(s: result),
    expected: 5,
    label: "length(pad_left(\"42\", 5, \"0\"))"
  )
  return ()
end
