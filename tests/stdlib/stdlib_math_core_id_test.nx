// Port of bootstrap/tests/stdlib/math.rs::core_id_returns_argument.
import { id } from "std:core"

let body = fn () -> unit throws { Exn } do
  let r = id(val: 42)
  if r != 42 then raise RuntimeError(val: "expected 42") end
  let r2 = id(val: -7)
  if r2 != -7 then raise RuntimeError(val: "expected -7") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
