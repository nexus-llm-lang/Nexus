// TOML basic key/value roundtrip: parse a minimal document, verify scalar values.
import * as test_assert from "std:test/assert"
import {
  parse,
  serialize,
  TomlTable,
  TomlString,
  TomlInt,
  TomlFloat,
  TomlBool,
  TomlField,
  TomlValue
} from "std:toml"

let field_key = fn (f: TomlField) -> string do
  let TomlField(key: k, value: v) = f
  return k
end

let field_value = fn (f: TomlField) -> TomlValue do
  let TomlField(key: k, value: v) = f
  return v
end

let first_field = fn (fields: [ TomlField ]) -> TomlField throws { Exn } do
  match fields do
    | f :: rest -> return f
    | [] ->
      test_assert.assert_true(cond: false, label: "no fields")
      return TomlField(key: "", value: TomlString(val: ""))
  end
end

let main = fn () -> unit throws { Exn } do
  let doc =
    "title = \"hello\"\n" ++
    "count = 42\n" ++
    "enabled = true\n"

  let result = parse(s: doc)

  match result do
    | TomlTable(fields: fs) ->
      let f = first_field(fields: fs)
      test_assert.assert_eq_string(
        actual: field_key(f),
        expected: "title",
        label: "first key is title"
      )
      match field_value(f) do
        | TomlString(val: sv) ->
          test_assert.assert_eq_string(actual: sv, expected: "hello", label: "title value")
        | _ -> test_assert.assert_true(cond: false, label: "expected TomlString")
      end
    | _ -> test_assert.assert_true(cond: false, label: "root must be TomlTable")
  end

  return ()
end
