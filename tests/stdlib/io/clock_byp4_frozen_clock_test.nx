// byp4: std:clock reads NEXUS_FROZEN_CLOCK env var for deterministic time.
//
// Uses Env.set to write NEXUS_FROZEN_CLOCK into the override table, then
// verifies that now_ms() returns the frozen epoch value instead of the real
// wall clock.  The Clock.now() method (which delegates to now_ms) must also
// return the same value.
import * as test_assert from "std:test/assert"
import { Env } from "std:env"
import { Clock }, * as clk from "std:clock"
import { now_ms } from "std:clock"
import * as env_mod from "std:env"

let main = fn () -> unit require { PermClock, PermEnv } throws { Exn } do
  let frozen_epoch = 1700000000000
  inject env_mod.system_handler do
    Env.set(key: "NEXUS_FROZEN_CLOCK", value: "1700000000000")
    inject clk.system_handler do
      test_assert.assert_eq_i64(
        actual: now_ms(),
        expected: frozen_epoch,
        label: "now_ms() returns NEXUS_FROZEN_CLOCK value"
      )
      test_assert.assert_eq_i64(
        actual: Clock.now(),
        expected: frozen_epoch,
        label: "Clock.now() returns NEXUS_FROZEN_CLOCK value"
      )
    end
  end
  return ()
end
