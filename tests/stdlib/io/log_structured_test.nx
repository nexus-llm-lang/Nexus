// Exercises the structured-logging port (std:log): the JsonValue-typed
// fields payload, severity-level priorities, the JSON-Lines + text
// renderers, and the level/sample gate state cells.
//
// We render records via the pure helpers (`render_record_*`) rather than
// going through the cap+handler pipeline so the assertions are
// deterministic and don't require mocking Console. Cap-level wiring is
// smoke-tested in tests/integration via the di_cap example.
import * as test_assert from "std:test/assert"
import { LogLevel, LogField, Trace, Debug, Info, Warn, Error,
         field_str, field_i64, field_bool,
         priority_of_level, level_to_string,
         render_record_text, render_record_json,
         set_min_level, set_sample_every, reset_sampler,
         should_emit_level, should_emit_sample, should_emit,
         get_min_priority } from "std:log"

let assert_priority = fn (
  level: LogLevel,
  expected: i64,
  label: string
) -> unit throws { test_assert.AssertError } do
  return test_assert.assert_eq_i64(
    actual: priority_of_level(level),
    expected, label)
end

let assert_label = fn (
  level: LogLevel,
  expected: string,
  label: string
) -> unit throws { test_assert.AssertError } do
  return test_assert.assert_eq_string(
    actual: level_to_string(level),
    expected, label)
end

let main = fn () -> unit throws { Exn } do
  // ── Priorities monotone, low→high ──────────────────────────────────────
  assert_priority(level: Trace, expected: 0, label: "Trace = 0")
  assert_priority(level: Debug, expected: 1, label: "Debug = 1")
  assert_priority(level: Info,  expected: 2, label: "Info = 2")
  assert_priority(level: Warn,  expected: 3, label: "Warn = 3")
  assert_priority(level: Error, expected: 4, label: "Error = 4")

  // ── Canonical level labels ────────────────────────────────────────────
  assert_label(level: Trace, expected: "TRACE", label: "Trace label")
  assert_label(level: Debug, expected: "DEBUG", label: "Debug label")
  assert_label(level: Info,  expected: "INFO",  label: "Info label")
  assert_label(level: Warn,  expected: "WARN",  label: "Warn label")
  assert_label(level: Error, expected: "ERROR", label: "Error label")

  // ── Text formatter: empty fields → no trailing space ──────────────────
  let txt0 = render_record_text(level: Info, ts: 42, msg: "boot", fields: [])
  test_assert.assert_eq_string(
    actual: txt0,
    expected: "INFO ts=42 msg=\"boot\"",
    label: "text fmt with no fields")

  // ── Text formatter: fields appear in insertion order ──────────────────
  let txt1 = render_record_text(
    level: Warn, ts: 100, msg: "slow",
    fields: [
      field_str(key: "endpoint", value: "/users"),
      field_i64(key: "ms", value: 1500),
      field_bool(key: "cached", value: false),
    ])
  test_assert.assert_eq_string(
    actual: txt1,
    expected: "WARN ts=100 msg=\"slow\" endpoint=\"/users\" ms=1500 cached=false",
    label: "text fmt with mixed fields")

  // ── Text formatter: msg with quotes/spaces survives JSON-quoting ──────
  let txt2 = render_record_text(
    level: Error, ts: 0, msg: "panic: \"bad input\"",
    fields: [])
  test_assert.assert_eq_string(
    actual: txt2,
    expected: "ERROR ts=0 msg=\"panic: \\\"bad input\\\"\"",
    label: "text fmt escapes quotes in msg")

  // ── JSON formatter: empty fields → empty fields object ────────────────
  let js0 = render_record_json(level: Debug, ts: 7, msg: "tick", fields: [])
  test_assert.assert_eq_string(
    actual: js0,
    expected: "{\"level\":\"DEBUG\",\"ts\":7,\"msg\":\"tick\",\"fields\":{}}",
    label: "json fmt with no fields")

  // ── JSON formatter: field insertion order preserved ───────────────────
  let js1 = render_record_json(
    level: Info, ts: 999, msg: "ok",
    fields: [ field_i64(key: "n", value: 3), field_str(key: "user", value: "alice") ])
  test_assert.assert_eq_string(
    actual: js1,
    expected: "{\"level\":\"INFO\",\"ts\":999,\"msg\":\"ok\",\"fields\":{\"n\":3,\"user\":\"alice\"}}",
    label: "json fmt with fields")

  // ── Level gate threshold ──────────────────────────────────────────────
  // Start clean: install Info threshold and clear the sampler counter.
  set_sample_every(n: 1)
  reset_sampler()
  set_min_level(level: Info)
  test_assert.assert_eq_i64(
    actual: get_min_priority(),
    expected: 2,
    label: "min level recorded as priority 2")
  test_assert.assert_false(cond: should_emit_level(level: Trace), label: "Trace < Info gate")
  test_assert.assert_false(cond: should_emit_level(level: Debug), label: "Debug < Info gate")
  test_assert.assert_true(cond: should_emit_level(level: Info),  label: "Info passes Info gate")
  test_assert.assert_true(cond: should_emit_level(level: Warn),  label: "Warn passes Info gate")
  test_assert.assert_true(cond: should_emit_level(level: Error), label: "Error passes Info gate")

  // ── Sampler: every record passes when N=1 ─────────────────────────────
  set_sample_every(n: 1)
  reset_sampler()
  test_assert.assert_true(cond: should_emit_sample(), label: "sample 1/1 pass 0")
  test_assert.assert_true(cond: should_emit_sample(), label: "sample 1/1 pass 1")
  test_assert.assert_true(cond: should_emit_sample(), label: "sample 1/1 pass 2")

  // ── Sampler: 1-in-3 keeps records 0, 3, 6 ─────────────────────────────
  set_sample_every(n: 3)
  reset_sampler()
  test_assert.assert_true (cond: should_emit_sample(), label: "1/3 keeps idx 0")
  test_assert.assert_false(cond: should_emit_sample(), label: "1/3 drops idx 1")
  test_assert.assert_false(cond: should_emit_sample(), label: "1/3 drops idx 2")
  test_assert.assert_true (cond: should_emit_sample(), label: "1/3 keeps idx 3")
  test_assert.assert_false(cond: should_emit_sample(), label: "1/3 drops idx 4")
  test_assert.assert_false(cond: should_emit_sample(), label: "1/3 drops idx 5")
  test_assert.assert_true (cond: should_emit_sample(), label: "1/3 keeps idx 6")

  // ── Combined gate: level threshold short-circuits past sampler ────────
  // Records below the threshold must NOT advance the sampler — otherwise a
  // noisy Trace-spewing call site could starve a sampled Info channel.
  set_min_level(level: Warn)
  set_sample_every(n: 2)
  reset_sampler()
  test_assert.assert_false(cond: should_emit(level: Info), label: "Info dropped by Warn gate")
  test_assert.assert_false(
    cond: should_emit(level: Info),
    label: "Info dropped (sampler not advanced)"
  )
  test_assert.assert_true (cond: should_emit(level: Warn), label: "Warn pass + sampler tick 0")
  test_assert.assert_false(cond: should_emit(level: Warn), label: "Warn drop sampler tick 1")
  test_assert.assert_true (cond: should_emit(level: Warn), label: "Warn pass sampler tick 2")

  // ── Sampler reset rewinds the counter ─────────────────────────────────
  set_sample_every(n: 2)
  set_min_level(level: Trace)
  reset_sampler()
  test_assert.assert_true (cond: should_emit_sample(), label: "after reset, 0 passes")
  test_assert.assert_false(cond: should_emit_sample(), label: "after reset, 1 drops")
  reset_sampler()
  test_assert.assert_true (cond: should_emit_sample(), label: "after second reset, 0 passes")

  // Restore defaults so the rest of the test run (or repeated runs in
  // sequential mode) isn't poisoned by leftover gate state.
  set_min_level(level: Trace)
  set_sample_every(n: 1)
  reset_sampler()
  return ()
end
