// protobuf_v3: fixed32 and fixed64 round-trip tests.
import * as test_assert from "std:test/assert"
import {
  encode, decode,
  PbField, PbValue, PbVarint, PbFixed64, PbLenDelim, PbFixed32,
  PbThrow
} from "std:protobuf_v3"

let main = fn () -> unit throws { Exn } do
  // ─── Fixed32 round-trip ──────────────────────────────────────────────────

  // Field 1, value 0x01020304
  let val32 = 16909060
  let wire1 = encode(fields: [PbField(field_number: 1, value: PbFixed32(val: val32))])
  let fields1 = decode(data: wire1)
  match fields1 do
    | PbField(field_number: fn1, value: PbFixed32(val: v1)) :: [] ->
      test_assert.assert_eq_i64(actual: fn1, expected: 1, label: "fixed32 field_number")
      test_assert.assert_eq_i64(actual: v1, expected: val32, label: "fixed32 value")
    | _ -> test_assert.assert_true(cond: false, label: "expected PbFixed32")
  end

  // Fixed32 value 0 round-trip
  let wire2 = encode(fields: [PbField(field_number: 2, value: PbFixed32(val: 0))])
  let fields2 = decode(data: wire2)
  match fields2 do
    | PbField(field_number: fn2, value: PbFixed32(val: v2)) :: [] ->
      test_assert.assert_eq_i64(actual: fn2, expected: 2, label: "fixed32 zero field_number")
      test_assert.assert_eq_i64(actual: v2, expected: 0, label: "fixed32 zero value")
    | _ -> test_assert.assert_true(cond: false, label: "expected PbFixed32 zero")
  end

  // ─── Fixed64 round-trip ──────────────────────────────────────────────────

  // Field 3, value 0x0102030405060708
  let val64 = 72623859790382856
  let wire3 = encode(fields: [PbField(field_number: 3, value: PbFixed64(val: val64))])
  let fields3 = decode(data: wire3)
  match fields3 do
    | PbField(field_number: fn3, value: PbFixed64(val: v3)) :: [] ->
      test_assert.assert_eq_i64(actual: fn3, expected: 3, label: "fixed64 field_number")
      test_assert.assert_eq_i64(actual: v3, expected: val64, label: "fixed64 value")
    | _ -> test_assert.assert_true(cond: false, label: "expected PbFixed64")
  end

  // Fixed64 value 1 round-trip
  let wire4 = encode(fields: [PbField(field_number: 4, value: PbFixed64(val: 1))])
  let fields4 = decode(data: wire4)
  match fields4 do
    | PbField(field_number: fn4, value: PbFixed64(val: v4)) :: [] ->
      test_assert.assert_eq_i64(actual: fn4, expected: 4, label: "fixed64 one field_number")
      test_assert.assert_eq_i64(actual: v4, expected: 1, label: "fixed64 one value")
    | _ -> test_assert.assert_true(cond: false, label: "expected PbFixed64 one")
  end

  return ()
end
