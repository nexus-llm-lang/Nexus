// Port of bootstrap/tests/stdlib/rand.rs::rand_determinism_pcg_step_byte_equal_across_runs.
// (fixture: bootstrap/tests/fixtures/nxc/test_rand_determinism.nx)
//
// Acceptance: same seed -> same next_i64() sequence (byte-equal across runs);
// different seeds -> divergent first output. Reference values come from
// offline u64 wrapping_mul/add of (6364136223846793005, 1442695040888963407)
// starting from state = seed, top-bit cleared on output.
//
// The Rust harness uses exec_nxc_core_capture_stdout to compare stdout
// line-by-line. We replace that with inline assertions on the in-memory
// next_i64() values — it's the same contract, but printable-output-free
// so the test fits the safe_run scaffold without PermConsole.
import * as test_assert from "std:test/assert"
import { Random, seed_with, reset }, * as rng from "std:rand"

let main = fn () -> unit require { PermRandom } throws { Exn } do
  inject rng.system_handler do
    // Phase A: seed = 1, ten next_i64 outputs against offline reference.
    let _ = seed_with(seed: 1)
    test_assert.assert_eq_i64(
      actual: Random.next_i64(),
      expected: 7806831264735756412,
      label: "PCG step 1 (seed=1)"
    )
    test_assert.assert_eq_i64(
      actual: Random.next_i64(),
      expected: 173536691264035611,
      label: "PCG step 2 (seed=1)"
    )
    test_assert.assert_eq_i64(
      actual: Random.next_i64(),
      expected: 2736747771374053902,
      label: "PCG step 3 (seed=1)"
    )
    test_assert.assert_eq_i64(
      actual: Random.next_i64(),
      expected: 7062582979898595269,
      label: "PCG step 4 (seed=1)"
    )
    test_assert.assert_eq_i64(
      actual: Random.next_i64(),
      expected: 5450049017633417712,
      label: "PCG step 5 (seed=1)"
    )
    test_assert.assert_eq_i64(
      actual: Random.next_i64(),
      expected: 9431502868738175,
      label: "PCG step 6 (seed=1)"
    )
    test_assert.assert_eq_i64(
      actual: Random.next_i64(),
      expected: 994931806658971810,
      label: "PCG step 7 (seed=1)"
    )
    test_assert.assert_eq_i64(
      actual: Random.next_i64(),
      expected: 1206773305466921929,
      label: "PCG step 8 (seed=1)"
    )
    test_assert.assert_eq_i64(
      actual: Random.next_i64(),
      expected: 6266840599827907236,
      label: "PCG step 9 (seed=1)"
    )
    let r1_recap = Random.next_i64()
    test_assert.assert_eq_i64(
      actual: r1_recap,
      expected: 3660572683296592931,
      label: "PCG step 10 (seed=1)"
    )

    // Phase B: reset + seed = 2, one step. Must differ from seed=1 first output.
    let _ = reset()
    let _ = seed_with(seed: 2)
    let s1 = Random.next_i64()
    test_assert.assert_eq_i64(
      actual: s1,
      expected: 4947595451727773609,
      label: "PCG step 1 (seed=2)"
    )
    test_assert.assert_true(
      cond: s1 != 7806831264735756412,
      label: "seed=1 and seed=2 produce different first output"
    )
  end
  return ()
end
