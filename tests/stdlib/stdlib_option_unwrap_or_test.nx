// Port of bootstrap/tests/stdlib/option.rs::option_unwrap_or_some,
// option_unwrap_or_none.
import { Option, unwrap_or } from "std:option"

let body = fn () -> unit throws { Exn } do
  let some_opt = Some(val: 10)
  let r1 = unwrap_or(opt: some_opt, default: 0)
  if r1 != 10 then raise RuntimeError(val: "expected 10") end

  let none_opt: Option<i64> = None
  let r2 = unwrap_or(opt: none_opt, default: 99)
  if r2 != 99 then raise RuntimeError(val: "expected 99") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
