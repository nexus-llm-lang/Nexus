// Port of bootstrap/tests/stdlib/option.rs::option_unwrap_or_some,
// option_unwrap_or_none.
import * as test_assert from "std:test/assert"
import { Option, unwrap_or } from "std:option"

let main = fn () -> unit throws { Exn } do
  let some_opt = Some(val: 10)
  test_assert.assert_eq_i64(actual: unwrap_or(opt: some_opt, default: 0), expected: 10, label: "unwrap_or(Some(10), 0)")

  let none_opt: Option<i64> = None
  test_assert.assert_eq_i64(actual: unwrap_or(opt: none_opt, default: 99), expected: 99, label: "unwrap_or(None, 99)")
  return ()
end
