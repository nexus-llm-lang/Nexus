// Port of bootstrap/src/lib/nexus_host_bridge/src/url_guard.rs tests.
// Validates the guest-side SSRF classifier (ssrf_is_blocked) baked into
// nxlib/stdlib/io/network.nx. The guard runs before any outgoing connection
// even when the allow_net capability is granted, implementing deny-by-default
// for private/loopback/link-local/metadata/ULA ranges.
//
// Design note: the guard is wired into get/request_raw/request_with_timeout
// at the stdlib layer. No sub-capability (allow_net_private) is added —
// hard deny-by-default was chosen to match the original url_guard.rs behaviour.
// Known limitation: DNS rebinding is not defended (resolve-then-connect race).
// See nexus-xjbs.5 for the follow-up.
//
// Test coverage (32 cases):
//   Deny: loopback IPv4, link-local/metadata IPv4, private IPv4 ranges,
//         unspecified+broadcast IPv4, IPv6 loopback+unspecified, ULA, link-local IPv6,
//         IPv4-mapped private IPv6, localhost hostnames, cloud metadata hostnames,
//         mDNS .local suffix, bracketed IPv6.
//   Deny (bypass fixes — nexus-gyetk):
//     trailing-dot hosts (localhost., 127.0.0.1., metadata.google.internal.),
//     octal IPv4 octet (0177.0.0.1 = 127.0.0.1),
//     scheme-relative URL (//127.0.0.1/foo).
//   Allow: public IPv4, public IPv4-mapped IPv6, normal public hostnames,
//     public hostname with trailing dot (trailing dot alone must not block).
//
// The file imports only from std:test/assert — it does not actually open any
// network connection, so it runs without allow_net capability.

import * as test_assert from "std:test/assert"
import { ssrf_is_blocked } from "std:network"

let body = fn () -> unit throws { Exn } do
  // ── Deny: loopback IPv4 ────────────────────────────────────────────────────
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://127.0.0.1/"),
    label: "blocks loopback 127.0.0.1")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://127.255.255.254/"),
    label: "blocks loopback 127.255.255.254 (end of /8)")

  // ── Deny: link-local IPv4 (cloud metadata at 169.254.169.254) ─────────────
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://169.254.169.254/latest/meta-data/"),
    label: "blocks AWS/GCP IMDS 169.254.169.254")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://169.254.0.0/"),
    label: "blocks link-local boundary 169.254.0.0")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://169.254.255.255/"),
    label: "blocks link-local boundary 169.254.255.255")

  // ── Deny: private IPv4 ranges ──────────────────────────────────────────────
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://10.0.0.1/"),
    label: "blocks private 10.0.0.1 (10/8)")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://172.16.0.1/"),
    label: "blocks private 172.16.0.1 (172.16/12)")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://172.31.255.255/"),
    label: "blocks private 172.31.255.255 (172.16/12 end)")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://192.168.1.1/"),
    label: "blocks private 192.168.1.1 (192.168/16)")

  // ── Deny: unspecified and broadcast ───────────────────────────────────────
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://0.0.0.0/"),
    label: "blocks unspecified 0.0.0.0")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://255.255.255.255/"),
    label: "blocks broadcast 255.255.255.255")

  // ── Deny: IPv6 loopback and unspecified ───────────────────────────────────
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://[::1]/"),
    label: "blocks IPv6 loopback ::1 (bracketed)")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://[::]/"),
    label: "blocks IPv6 unspecified :: (bracketed)")

  // ── Deny: ULA fc00::/7 ────────────────────────────────────────────────────
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://[fc00::1]/"),
    label: "blocks ULA fc00::1")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://[fd12:3456::1]/"),
    label: "blocks ULA fd12:3456::1")

  // ── Deny: link-local IPv6 fe80::/10 ───────────────────────────────────────
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://[fe80::1]/"),
    label: "blocks link-local IPv6 fe80::1")

  // ── Deny: IPv4-mapped private IPv6 ────────────────────────────────────────
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://[::ffff:169.254.169.254]/"),
    label: "blocks IPv4-mapped IMDS ::ffff:169.254.169.254")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://[::ffff:127.0.0.1]/"),
    label: "blocks IPv4-mapped loopback ::ffff:127.0.0.1")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://[::ffff:10.0.0.1]/"),
    label: "blocks IPv4-mapped private ::ffff:10.0.0.1")

  // ── Deny: well-known localhost hostnames ──────────────────────────────────
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://localhost/"),
    label: "blocks hostname 'localhost'")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://LOCALHOST/"),
    label: "blocks hostname 'LOCALHOST' (case-insensitive)")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://my.localhost/"),
    label: "blocks hostname 'my.localhost' (.localhost suffix)")

  // ── Deny: cloud metadata hostnames ────────────────────────────────────────
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://metadata.google.internal/"),
    label: "blocks metadata.google.internal")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://Metadata.Google.Internal/"),
    label: "blocks Metadata.Google.Internal (case-insensitive)")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://metadata.goog/"),
    label: "blocks metadata.goog")

  // ── Deny: mDNS .local suffix ──────────────────────────────────────────────
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://printer.local/"),
    label: "blocks mDNS printer.local (.local suffix)")

  // ── Allow: public IPv4 ────────────────────────────────────────────────────
  test_assert.assert_false(
    cond: ssrf_is_blocked(url: "http://8.8.8.8/"),
    label: "allows public 8.8.8.8")
  test_assert.assert_false(
    cond: ssrf_is_blocked(url: "http://1.1.1.1/"),
    label: "allows public 1.1.1.1")

  // ── Allow: IPv4-mapped public IPv6 ────────────────────────────────────────
  test_assert.assert_false(
    cond: ssrf_is_blocked(url: "http://[::ffff:8.8.8.8]/"),
    label: "allows IPv4-mapped public ::ffff:8.8.8.8")

  // ── Allow: normal public hostnames ────────────────────────────────────────
  test_assert.assert_false(
    cond: ssrf_is_blocked(url: "http://example.com/"),
    label: "allows public hostname example.com")
  test_assert.assert_false(
    cond: ssrf_is_blocked(url: "http://api.github.com/v3/"),
    label: "allows public hostname api.github.com")

  // ── nexus-gyetk: Trailing-dot host bypass (all three must now be BLOCKED) ─
  // A trailing root '.' is a valid absolute-FQDN form that resolves identically
  // to the name without the dot.  The guard must strip it before classification.
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://localhost./"),
    label: "blocks localhost. (trailing-dot loopback hostname)")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://127.0.0.1./"),
    label: "blocks 127.0.0.1. (trailing-dot loopback IPv4)")
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://metadata.google.internal./"),
    label: "blocks metadata.google.internal. (trailing-dot metadata hostname)")

  // ── nexus-gyetk: Octal IPv4 octet bypass ──────────────────────────────────
  // inet_aton()/getaddrinfo() treat a leading-zero multi-digit octet as octal:
  // 0177 = 127 decimal → loopback.  The guard must match resolver semantics.
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "http://0177.0.0.1/"),
    label: "blocks 0177.0.0.1 (octal 0177 = decimal 127, loopback)")

  // ── nexus-gyetk: Scheme-relative URL bypass ───────────────────────────────
  // "//host/path" is a valid relative-URL form whose authority is the host.
  // Without a "://" the old code fell back to auth_start=0 and the leading
  // '/' terminated the authority at position 0 → empty host → allowed.
  test_assert.assert_true(
    cond: ssrf_is_blocked(url: "//127.0.0.1/foo"),
    label: "blocks //127.0.0.1/foo (scheme-relative loopback)")

  // ── nexus-gyetk: Public-host not-over-blocked controls ────────────────────
  // Stripping a trailing dot from a public hostname must not cause a block.
  // The classification (allowed public) is decided AFTER stripping, not before.
  test_assert.assert_false(
    cond: ssrf_is_blocked(url: "http://example.com./"),
    label: "allows example.com. (trailing dot on public hostname)")
  test_assert.assert_false(
    cond: ssrf_is_blocked(url: "http://8.8.8.8/"),
    label: "allows public 8.8.8.8 (still not over-blocked after octal fix)")
  test_assert.assert_false(
    cond: ssrf_is_blocked(url: "http://93.184.216.34/"),
    label: "allows public 93.184.216.34 (no leading zeros)")

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
