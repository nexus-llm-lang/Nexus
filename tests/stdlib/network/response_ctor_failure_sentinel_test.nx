// Issue nexus-byiw subset: pin the `Response(status: 0, ...)` failure
// sentinel shape used throughout `nxlib/stdlib/network.nx`.
//
// `get` (line 179), `request_raw` (line 189), and `request_with_timeout`
// (line 305) all branch on `response_status(res) == 0` to decide
// whether to `throw RequestError`. The `0`-status sentinel is also
// what `decode_response` returns at line 100 when the raw bridge
// payload is missing its first `\n` separator (i.e. a wire-format
// failure from the host bridge).
//
// A regression that changed `Response`'s default-zero behaviour for
// status, or that made the field signed-vs-unsigned, would silently
// either swallow real failures (false success) or fail healthy
// responses (false failure). Pinning the sentinel + the "the raw
// body survives even on failure" shape catches both.
//
// Edge cases pinned:
//   1. Response(status: 0, headers: "", body: "") is constructable
//      and round-trips — the bridge-error path uses exactly this
//      shape at line 139's neighbour code paths.
//   2. Response(status: 0, headers: "", body: <raw>) keeps the
//      caller's raw body intact (matches decode_response line 100).
//   3. status==0 is the sentinel the caller branches on — pin
//      assert_eq_i64 against the literal 0 so a switch to a
//      different sentinel (e.g. -1) is caught.
import * as test_assert from "std:test/assert"
import { Response } from "std:network"

let body = fn () -> unit throws { Exn } do
  // Case A: complete-failure shape — everything blank.
  let r_empty = Response(status: 0, headers: "", body: "")
  let Response(status: s_a, headers: h_a, body: b_a) = r_empty
  test_assert.assert_eq_i64(actual: s_a, expected: 0,
    label: "Response sentinel: status=0 round-trips (failure marker)")
  test_assert.assert_eq_string(actual: h_a, expected: "",
    label: "Response sentinel: empty headers round-trips")
  test_assert.assert_eq_string(actual: b_a, expected: "",
    label: "Response sentinel: empty body round-trips")

  // Case B: malformed-wire shape — status=0 but body has raw payload
  // (decode_response line 100 returns this when no '\n' delimits a
  // status from the rest).
  let r_raw = Response(status: 0, headers: "", body: "garbage-from-bridge")
  let Response(status: s_b, headers: h_b, body: b_b) = r_raw
  test_assert.assert_eq_i64(actual: s_b, expected: 0,
    label: "Response sentinel: malformed-wire path still has status=0")
  test_assert.assert_eq_string(actual: h_b, expected: "",
    label: "Response sentinel: malformed-wire path keeps empty headers")
  test_assert.assert_eq_string(actual: b_b, expected: "garbage-from-bridge",
    label: "Response sentinel: malformed-wire path preserves raw body")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
