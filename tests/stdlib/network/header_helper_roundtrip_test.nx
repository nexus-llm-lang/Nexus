// Issue nexus-byiw subset: unit-test `nxlib/stdlib/network.nx::header`
// — the only exported pure constructor helper in the module. It is a
// thin wrapper around the `Header(name, value)` ctor:
//
//   let header = fn (name, value) -> Header do return Header(name, value) end
//
// A regression that swapped the two positional fields, or that began
// trimming/normalizing the inputs, would break every header that
// `request`/`respond_with_headers` later encode into the canonical
// `name:value\n` bridge format (see encode_headers_go at line 77).
//
// Edge cases pinned:
//   1. header("Host", "example.com").name  == "Host"
//   2. header("Host", "example.com").value == "example.com"
//   3. The two fields are independent (a regression that pointed both
//      destructure slots at the same arg would still pass an
//      identity-on-one-field test; testing distinct values catches that).
//
// Header is a non-linear nominal record-ctor type — no `free` required.
// Use the explicit `field: var` destructure syntax (the source-internal
// shorthand `Header(name, value)` at line 80 happens to work only
// because the bindings reuse the literal field names; an out-of-source
// test must spell out the renaming).
import * as test_assert from "std:test/assert"
import { Header, header } from "std:network"

let body = fn () -> unit throws { Exn } do
  let h = header(name: "Host", value: "example.com")
  let Header(name: got_name, value: got_value) = h

  test_assert.assert_eq_string(actual: got_name, expected: "Host",
    label: "net.header: name field round-trips")
  test_assert.assert_eq_string(actual: got_value, expected: "example.com",
    label: "net.header: value field round-trips")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
