// Issue nexus-byiw subset: pin `Response`'s `status: i64` slot across
// the canonical HTTP status-code spread (2xx / 3xx / 4xx / 5xx) so
// any future regression that narrowed the field (e.g. from i64 to
// i32 / u8) or that silently bucketed via integer division breaks
// here instead of in a hard-to-trace request path.
//
// Currently the module has no `status -> status-text` mapping — the
// status field is a raw `i64`. The test pins that fact: callers must
// be able to round-trip arbitrary status codes verbatim, NOT see
// them rewritten or truncated. (If a `status_text` helper is added
// later, a separate fixture should cover its enum mapping.)
//
// Codes pinned, picked one per status class so any class-specific
// off-by-one shows up:
//   * 200 — the success default; the most-used path.
//   * 301 — redirect class.
//   * 404 — client-error class; also the "missing" path in
//     `skills/nexus-lang/templates/web-server.nx` (which `Net.respond`s
//     with literal `404`).
//   * 500 — server-error class boundary.
//   * 599 — class-class-boundary high value (still i64-safe).
//
// Edge cases:
//   1. Each code round-trips through ctor + destructure unchanged.
//   2. The `status` field stays distinct from `headers`/`body`
//      (we read all three each time to make sure the slot didn't
//      shift under us).
import * as test_assert from "std:test/assert"
import { Response } from "std:network"

let check_status = fn (code: i64, label_suffix: string) -> unit throws { Exn } do
  let res = Response(status: code, headers: "x:y\n", body: "b")
  let Response(status: s, headers: h, body: b) = res
  test_assert.assert_eq_i64(actual: s, expected: code,
    label: "Response status round-trip: " ++ label_suffix)
  test_assert.assert_eq_string(actual: h, expected: "x:y\n",
    label: "Response status round-trip keeps headers slot: " ++ label_suffix)
  test_assert.assert_eq_string(actual: b, expected: "b",
    label: "Response status round-trip keeps body slot: " ++ label_suffix)
  return ()
end

let body = fn () -> unit throws { Exn } do
  check_status(code: 200, label_suffix: "200 OK")
  check_status(code: 301, label_suffix: "301 redirect")
  check_status(code: 404, label_suffix: "404 not found")
  check_status(code: 500, label_suffix: "500 server error")
  check_status(code: 599, label_suffix: "599 upper 5xx")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
