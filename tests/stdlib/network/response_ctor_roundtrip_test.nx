// Issue nexus-byiw subset: unit-test the exported `Response` ctor —
//
//   export type Response = Response(status: i64, headers: string, body: string)
//
// `nxlib/stdlib/network.nx` consumes `Response` from `get` (line 178),
// `request_raw` (line 188), and `request_with_timeout` (line 304),
// all of which build their `Response` via `decode_response` and then
// destructure via `response_status` / `response_body` (lines 153, 159).
// A regression in field ordering — for example mixing up the `headers`
// and `body` slots — would cause a 200 response with an HTML body to
// surface to callers as if `body == "<the headers>"`.
//
// Edge cases pinned:
//   1. A typical-shaped Response (status=200, non-empty headers,
//      non-empty body) round-trips every slot independently.
//   2. Shorthand (field-name = binding-name) and renaming destructure
//      agree on the same value, catching a regression where one was
//      wired to the wrong slot.
//
// Response is a non-linear nominal type; no `free` required.
import * as test_assert from "std:test/assert"
import { Response } from "std:network"

let body_fn = fn () -> unit throws { Exn } do
  let res = Response(status: 200, headers: "Content-Type:text/html\n", body: "<h1>ok</h1>")

  // Shorthand destructure: binding names match the field names —
  // this is what the source-internal helpers use (e.g. network.nx
  // line 154 `let Response(status, headers: _, body: _) = res`).
  let Response(status, headers, body) = res
  test_assert.assert_eq_i64(actual: status, expected: 200,
    label: "Response: shorthand destructure pulls status")
  test_assert.assert_eq_string(actual: headers, expected: "Content-Type:text/html\n",
    label: "Response: shorthand destructure pulls headers")
  test_assert.assert_eq_string(actual: body, expected: "<h1>ok</h1>",
    label: "Response: shorthand destructure pulls body")

  // Explicit-renaming destructure — the form `decode_response` uses
  // when constructing (line 100, 109, 118).
  let Response(status: s_named, headers: h_named, body: b_named) = res
  test_assert.assert_eq_i64(actual: s_named, expected: 200,
    label: "Response: renamed destructure pulls status")
  test_assert.assert_eq_string(actual: h_named, expected: "Content-Type:text/html\n",
    label: "Response: renamed destructure pulls headers")
  test_assert.assert_eq_string(actual: b_named, expected: "<h1>ok</h1>",
    label: "Response: renamed destructure pulls body")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body_fn()
  return ()
end
