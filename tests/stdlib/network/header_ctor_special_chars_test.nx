// Issue nexus-byiw subset: pin `Header` ctor against HTTP-realistic
// header values that contain the bridge-format delimiters.
//
// `nxlib/stdlib/network.nx::encode_headers_go` (line 77) writes
// each header as `name:value\n`. The serializer does NOT escape `:`
// inside `value`, and that's actually correct per the docstring at
// line 68 ("canonical bridge headers format ... no space after the
// colon, single-`\n` terminator") — every receiver splits on the
// FIRST `:` only. But this only works if the ctor stores `value`
// verbatim. A regression that trimmed, lower-cased, or split on `:`
// inside the ctor itself would silently mangle a `Content-Type:
// text/html; charset=utf-8` header.
//
// Edge cases pinned:
//   1. A `value` containing `;`, `=`, `/`, and a space survives
//      ctor round-trip unchanged.
//   2. A hyphenated `name` ("Content-Type") survives unchanged — the
//      ctor must not normalize case or strip the dash.
//   3. The two fields stay distinct; nothing leaks across slots.
import * as test_assert from "std:test/assert"
import { Header } from "std:network"

let body = fn () -> unit throws { Exn } do
  let h = Header(name: "Content-Type", value: "text/html; charset=utf-8")
  let Header(name: n, value: v) = h

  test_assert.assert_eq_string(actual: n, expected: "Content-Type",
    label: "Header ctor: hyphenated name survives ctor")
  test_assert.assert_eq_string(actual: v, expected: "text/html; charset=utf-8",
    label: "Header ctor: value with ; = / space survives ctor")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
