// protobuf_v2: varint roundtrip — encode then decode a varint field, verify value survives.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { decode, encode, PbField, PbVarint } from "std:protobuf_v2"

let roundtrip_varint = fn (v: i64, label: string) -> unit throws { Exn } do
  let fields_in = [PbField(field_number: 1, value: PbVarint(val: v))]
  let %enc = encode(fields: fields_in)
  let fields_out = decode(buf: &enc)
  bb.free(buf: %enc)
  match fields_out do
    | PbField(field_number: fn1, value: PbVarint(val: got)) :: [] ->
      test_assert.assert_eq_i64(actual: fn1, expected: 1, label: label ++ ":field_number")
      test_assert.assert_eq_i64(actual: got, expected: v, label: label ++ ":value")
    | _ -> test_assert.assert_true(cond: false, label: label ++ ":shape")
  end
  return ()
end

let main = fn () -> unit throws { Exn } do
  roundtrip_varint(v: 0,    label: "varint_zero")
  roundtrip_varint(v: 1,    label: "varint_one")
  roundtrip_varint(v: 127,  label: "varint_127")
  roundtrip_varint(v: 128,  label: "varint_128")
  roundtrip_varint(v: 300,  label: "varint_300")
  return ()
end
