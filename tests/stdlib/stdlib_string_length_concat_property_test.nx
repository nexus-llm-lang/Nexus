// Port of bootstrap/tests/stdlib/string.rs::prop_string_length_concat (proptest).
//
// Property: length(s1 ++ s2) == length(s1) + length(s2) for ASCII strings.
// We pick a single representative pair (no fuzzer in .nx); the inner
// invariant is what matters.
import { length } from "std:str"

let body = fn () -> unit throws { Exn } do
  let s1 = "Hello"
  let s2 = "World123"
  let joined = s1 ++ s2
  if length(s: joined) != length(s: s1) + length(s: s2) then
    raise RuntimeError(val: "length mismatch")
  end

  // empty + empty
  let e1 = ""
  let e2 = ""
  let je = e1 ++ e2
  if length(s: je) != 0 then raise RuntimeError(val: "empty concat must be 0") end

  // empty + nonempty
  let je2 = "" ++ "abc"
  if length(s: je2) != 3 then raise RuntimeError(val: "empty + abc must be 3") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
