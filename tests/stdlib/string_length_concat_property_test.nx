// Port of bootstrap/tests/stdlib/string.rs::prop_string_length_concat (proptest).
//
// Property: length(s1 ++ s2) == length(s1) + length(s2) for ASCII strings.
// We pick a single representative pair (no fuzzer in .nx); the inner
// invariant is what matters.
import * as test_assert from "std:test/assert"
import { length } from "std:str"

let main = fn () -> unit throws { Exn } do
  let s1 = "Hello"
  let s2 = "World123"
  let joined = s1 ++ s2
  test_assert.assert_eq_i64(
    actual: length(s: joined),
    expected: length(s: s1) + length(s: s2),
    label: "length(s1 ++ s2) == length(s1) + length(s2)"
  )

  // empty + empty
  let je = "" ++ ""
  test_assert.assert_eq_i64(actual: length(s: je), expected: 0, label: "length(\"\" ++ \"\") == 0")

  // empty + nonempty
  let je2 = "" ++ "abc"
  test_assert.assert_eq_i64(
    actual: length(s: je2),
    expected: 3,
    label: "length(\"\" ++ \"abc\") == 3"
  )
  return ()
end
