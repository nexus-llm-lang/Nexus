// protobuf_v2: error cases — truncated varint and invalid wire type raise PbError.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { decode } from "std:protobuf_v2"

let decode_raises = fn (bytes: [i64]) -> bool do
  let %tbuf = bb.empty()
  let %tbuf2 = bb.push_bytes(buf: %tbuf, bytes)
  try
    let _ = decode(buf: &tbuf2)
    bb.free(buf: %tbuf2)
    return false
  catch _ ->
    bb.free(buf: %tbuf2)
    return true
  end
end

let main = fn () -> unit throws { Exn } do
  // Truncated varint: single byte 0x80 (continuation bit set, no more bytes).
  test_assert.assert_true(
    cond: decode_raises(bytes: [128]),
    label: "truncated_varint")

  // Invalid wire type 6: tag byte encodes field_number=1, wire_type=6 — (1 << 3) | 6 = 14.
  test_assert.assert_true(
    cond: decode_raises(bytes: [14]),
    label: "invalid_wire_type_6")

  return ()
end
