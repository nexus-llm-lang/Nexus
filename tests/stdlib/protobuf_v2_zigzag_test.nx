// protobuf_v2: zigzag roundtrip for signed integers.
import * as test_assert from "std:test/assert"
import { zigzag_encode_i64, zigzag_decode_i64 } from "std:protobuf/v2"

let roundtrip_zz = fn (v: i64, label: string) -> unit throws { Exn } do
  let enc = zigzag_encode_i64(v)
  let dec = zigzag_decode_i64(v: enc)
  test_assert.assert_eq_i64(actual: dec, expected: v, label: label)
  return ()
end

let main = fn () -> unit throws { Exn } do
  roundtrip_zz(v: 0,    label: "zz_zero")
  roundtrip_zz(v: 1,    label: "zz_one")
  roundtrip_zz(v: -1,   label: "zz_neg_one")
  roundtrip_zz(v: 2147483647,  label: "zz_i32max")
  roundtrip_zz(v: -2147483648, label: "zz_i32min")
  // Verify known zigzag encodings per proto spec.
  // 0 -> 0, -1 -> 1, 1 -> 2, -2 -> 3
  test_assert.assert_eq_i64(actual: zigzag_encode_i64(v: 0),  expected: 0,  label: "zz_enc_0")
  test_assert.assert_eq_i64(actual: zigzag_encode_i64(v: -1), expected: 1,  label: "zz_enc_neg1")
  test_assert.assert_eq_i64(actual: zigzag_encode_i64(v: 1),  expected: 2,  label: "zz_enc_1")
  test_assert.assert_eq_i64(actual: zigzag_encode_i64(v: -2), expected: 3,  label: "zz_enc_neg2")
  return ()
end
