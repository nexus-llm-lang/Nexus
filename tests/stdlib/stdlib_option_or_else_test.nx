// Port of bootstrap/tests/stdlib/option.rs::option_or_else_prefers_some.
import { Option, or_else, unwrap_or } from "std:option"

let body = fn () -> unit throws { Exn } do
  let a: Option<i64> = None
  let b = Some(val: 42)
  let r = unwrap_or(opt: or_else(opt: a, other: b), default: 0)
  if r != 42 then raise RuntimeError(val: "expected 42") end

  // Both Some: or_else preserves the original Some.
  let c = Some(val: 1)
  let d = Some(val: 2)
  let r2 = unwrap_or(opt: or_else(opt: c, other: d), default: 0)
  if r2 != 1 then raise RuntimeError(val: "expected 1") end

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
