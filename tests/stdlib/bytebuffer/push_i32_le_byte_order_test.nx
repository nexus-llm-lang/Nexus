// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/bytebuffer.nx::push_i32_le` — appends a 32-bit integer
// as four bytes in little-endian order (byte 0 = low 8 bits, byte 3
// = high 8 bits). Pins the byte-order contract; a regression that
// stored big-endian or shifted in the wrong direction would yield the
// wrong byte at each position.
//
// Edge cases pinned:
//   1. Pure-low byte: val 0x01 → [0x01, 0x00, 0x00, 0x00].
//   2. Spread-across-bytes: val 0x12345678 → [0x78, 0x56, 0x34, 0x12].
//      Each byte distinct → catches any shift-direction or mask bug.
//   3. Top-byte-only: val 0xFF000000 (4278190080) → [0x00, 0x00, 0x00,
//      0xFF]. Verifies the >> 24 path produces 0xFF, not -1
//      (i64 arithmetic shift on positive operand stays positive).
//   4. length advances by exactly 4 bytes per call.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

let body = fn () -> unit throws { Exn } do
  // ── case 1: low-byte only (val=1) ──
  let %b0 = bb.empty()
  let %b1 = bb.push_i32_le(buf: %b0, val: 1)
  // ── case 2: spread val=0x12345678 ──
  let %b2 = bb.push_i32_le(buf: %b1, val: 305419896)
  // ── case 3: high-byte only (val=0xFF000000) ──
  let %b3 = bb.push_i32_le(buf: %b2, val: 4278190080)
  let len = bb.length(buf: &b3)
  // case 1 bytes (offsets 0..4)
  let c1_b0 = bb.get_byte(buf: &b3, idx: 0)
  let c1_b1 = bb.get_byte(buf: &b3, idx: 1)
  let c1_b2 = bb.get_byte(buf: &b3, idx: 2)
  let c1_b3 = bb.get_byte(buf: &b3, idx: 3)
  // case 2 bytes (offsets 4..8)
  let c2_b0 = bb.get_byte(buf: &b3, idx: 4)
  let c2_b1 = bb.get_byte(buf: &b3, idx: 5)
  let c2_b2 = bb.get_byte(buf: &b3, idx: 6)
  let c2_b3 = bb.get_byte(buf: &b3, idx: 7)
  // case 3 bytes (offsets 8..12)
  let c3_b0 = bb.get_byte(buf: &b3, idx: 8)
  let c3_b1 = bb.get_byte(buf: &b3, idx: 9)
  let c3_b2 = bb.get_byte(buf: &b3, idx: 10)
  let c3_b3 = bb.get_byte(buf: &b3, idx: 11)
  bb.free(buf: %b3)

  test_assert.assert_eq_i64(actual: len, expected: 12,
    label: "bb.push_i32_le: each call advances length by 4 (3 calls → 12)")

  // case 1
  test_assert.assert_eq_i64(actual: c1_b0, expected: 1,
    label: "bb.push_i32_le(1): byte[0] = 0x01")
  test_assert.assert_eq_i64(actual: c1_b1, expected: 0,
    label: "bb.push_i32_le(1): byte[1] = 0x00")
  test_assert.assert_eq_i64(actual: c1_b2, expected: 0,
    label: "bb.push_i32_le(1): byte[2] = 0x00")
  test_assert.assert_eq_i64(actual: c1_b3, expected: 0,
    label: "bb.push_i32_le(1): byte[3] = 0x00")
  // case 2 — distinct bytes nail down lane order
  test_assert.assert_eq_i64(actual: c2_b0, expected: 120,
    label: "bb.push_i32_le(0x12345678): byte[0] = 0x78")
  test_assert.assert_eq_i64(actual: c2_b1, expected: 86,
    label: "bb.push_i32_le(0x12345678): byte[1] = 0x56")
  test_assert.assert_eq_i64(actual: c2_b2, expected: 52,
    label: "bb.push_i32_le(0x12345678): byte[2] = 0x34")
  test_assert.assert_eq_i64(actual: c2_b3, expected: 18,
    label: "bb.push_i32_le(0x12345678): byte[3] = 0x12")
  // case 3 — verifies >> 24 path
  test_assert.assert_eq_i64(actual: c3_b0, expected: 0,
    label: "bb.push_i32_le(0xFF000000): byte[0] = 0x00")
  test_assert.assert_eq_i64(actual: c3_b1, expected: 0,
    label: "bb.push_i32_le(0xFF000000): byte[1] = 0x00")
  test_assert.assert_eq_i64(actual: c3_b2, expected: 0,
    label: "bb.push_i32_le(0xFF000000): byte[2] = 0x00")
  test_assert.assert_eq_i64(actual: c3_b3, expected: 255,
    label: "bb.push_i32_le(0xFF000000): byte[3] = 0xFF (high byte via >> 24)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
