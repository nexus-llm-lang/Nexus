// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/bytebuffer.nx::truncate` — sets length to
// `min(b_len, current_len)` clamped at zero. Preserves the
// capacity (bump-allocator) but exposes a shorter view. Source:
//   let n  = if b_len < cur then b_len else cur end
//   let n2 = if n < 0 then 0 else n end
//
// A regression that swapped the order of the min/clamp (e.g.
// clamped negative inputs to `cur` instead of `0`) would silently
// retain bytes that should be discarded — or worse, expose stale
// bytes past the (now-incorrect) len.
//
// Edge cases pinned:
//   1. truncate(buf, len: 3) on a 5-byte buffer → len=3; bytes 0..3
//      readable, byte at idx=3 returns -1 (idx >= len).
//   2. truncate(buf, len: 100) on a 5-byte buffer → len stays at 5
//      (no growth — `b_len > cur` means `n = cur`).
//   3. truncate(buf, len: 0) → length becomes 0, get_byte(0) = -1.
//   4. truncate(buf, len: -1) → clamped to 0 (negative → 0 branch).
//   5. After truncate-to-0, a fresh push_byte resumes writing at
//      offset 0 (re-use the existing capacity; length is the
//      single source of truth for the write cursor).
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

let body = fn () -> unit throws { Exn } do
  // Build 5-byte buffer [10, 20, 30, 40, 50].
  let %a0 = bb.empty()
  let %a1 = bb.push_byte(buf: %a0, byte: 10)
  let %a2 = bb.push_byte(buf: %a1, byte: 20)
  let %a3 = bb.push_byte(buf: %a2, byte: 30)
  let %a4 = bb.push_byte(buf: %a3, byte: 40)
  let %a5 = bb.push_byte(buf: %a4, byte: 50)
  // case 1: truncate to 3
  let %t1 = bb.truncate(buf: %a5, len: 3)
  let len1 = bb.length(buf: &t1)
  let last_kept = bb.get_byte(buf: &t1, idx: 2)  // should be 30
  let past_end = bb.get_byte(buf: &t1, idx: 3)   // should be -1
  bb.free(buf: %t1)

  // case 2: truncate beyond current length (no-grow)
  let %b0 = bb.empty()
  let %b1 = bb.push_byte(buf: %b0, byte: 10)
  let %b2 = bb.push_byte(buf: %b1, byte: 20)
  let %b3 = bb.push_byte(buf: %b2, byte: 30)
  let %b4 = bb.push_byte(buf: %b3, byte: 40)
  let %b5 = bb.push_byte(buf: %b4, byte: 50)
  let %t2 = bb.truncate(buf: %b5, len: 100)
  let len2 = bb.length(buf: &t2)
  bb.free(buf: %t2)

  // case 3: truncate to 0
  let %c0 = bb.empty()
  let %c1 = bb.push_byte(buf: %c0, byte: 10)
  let %c2 = bb.push_byte(buf: %c1, byte: 20)
  let %t3 = bb.truncate(buf: %c2, len: 0)
  let len3 = bb.length(buf: &t3)
  let read_zero = bb.get_byte(buf: &t3, idx: 0)
  bb.free(buf: %t3)

  // case 4: truncate with negative len
  let %d0 = bb.empty()
  let %d1 = bb.push_byte(buf: %d0, byte: 10)
  let %d2 = bb.push_byte(buf: %d1, byte: 20)
  let %t4 = bb.truncate(buf: %d2, len: 0 - 1)
  let len4 = bb.length(buf: &t4)
  bb.free(buf: %t4)

  // case 5: push after truncate-to-0 resumes at offset 0
  let %e0 = bb.empty()
  let %e1 = bb.push_byte(buf: %e0, byte: 99)
  let %e2 = bb.push_byte(buf: %e1, byte: 88)
  let %t5 = bb.truncate(buf: %e2, len: 0)
  let %r1 = bb.push_byte(buf: %t5, byte: 7)
  let len5 = bb.length(buf: &r1)
  let read5 = bb.get_byte(buf: &r1, idx: 0)
  bb.free(buf: %r1)

  test_assert.assert_eq_i64(actual: len1, expected: 3,
    label: "truncate(buf, 3): shrinks length to 3")
  test_assert.assert_eq_i64(actual: last_kept, expected: 30,
    label: "truncate(buf, 3): byte at idx 2 still readable (still in range)")
  test_assert.assert_eq_i64(actual: past_end, expected: 0 - 1,
    label: "truncate(buf, 3): byte at idx 3 now out-of-bounds (-1)")
  test_assert.assert_eq_i64(actual: len2, expected: 5,
    label: "truncate(buf, 100): clamps to current length (no grow path)")
  test_assert.assert_eq_i64(actual: len3, expected: 0,
    label: "truncate(buf, 0): length becomes 0")
  test_assert.assert_eq_i64(actual: read_zero, expected: 0 - 1,
    label: "truncate(buf, 0): idx 0 now out-of-bounds")
  test_assert.assert_eq_i64(actual: len4, expected: 0,
    label: "truncate(buf, -1): negative len clamped to 0")
  test_assert.assert_eq_i64(actual: len5, expected: 1,
    label: "push_byte after truncate-to-0: length resumes from 0 → 1")
  test_assert.assert_eq_i64(actual: read5, expected: 7,
    label: "push_byte after truncate-to-0: writes at offset 0 (overwrites stale)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
