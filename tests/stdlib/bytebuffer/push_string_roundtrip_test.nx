// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/bytebuffer.nx::push_string` + `to_string` — the
// string-bytes append + readback round-trip. Together they exercise:
//   * `pun_raw` to unpack a string into (ptr<<32 | len)
//   * `bput_range` bulk-byte append over the unpacked region
//   * `buf_to_string` allocate-and-copy via arena.alloc_raw + return
//     a fresh packed (ptr<<32 | len) (so the buffer's mutable
//     backing storage is NOT aliased by the returned string).
//
// A regression in any of: pun_raw's ptr/len decode, bput_range's
// copy direction, or buf_to_string's repack arithmetic would break
// at least one of the asserts.
//
// Edge cases pinned:
//   1. Ascii round-trip ("hello" → 5 bytes, exact readback).
//   2. Multi-byte UTF-8 round-trip ("héllo" — 6 bytes due to U+00E9
//      encoding as 0xC3 0xA9). Pins that push_string operates on
//      *bytes*, not codepoints.
//   3. Two pushes concatenate ("foo" + "bar" → "foobar"); growth path
//      kicks in (initial cap=0, first push allocates, second push
//      may or may not require a grow — either way the result must
//      be contiguous).
//   4. length matches expected byte count post-concatenation.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

let body = fn () -> unit throws { Exn } do
  // ── case 1: pure ASCII ──
  let %a0 = bb.empty()
  let %a1 = bb.push_string(buf: %a0, s: "hello")
  let a_len = bb.length(buf: &a1)
  let a_str = bb.to_string(buf: &a1)
  bb.free(buf: %a1)

  // ── case 2: multi-byte UTF-8 (é = 0xC3 0xA9, two bytes) ──
  let %u0 = bb.empty()
  let %u1 = bb.push_string(buf: %u0, s: "héllo")
  let u_len = bb.length(buf: &u1)
  let u_str = bb.to_string(buf: &u1)
  bb.free(buf: %u1)

  // ── case 3: two-push concatenation through grow ──
  let %c0 = bb.empty()
  let %c1 = bb.push_string(buf: %c0, s: "foo")
  let %c2 = bb.push_string(buf: %c1, s: "bar")
  let c_len = bb.length(buf: &c2)
  let c_str = bb.to_string(buf: &c2)
  bb.free(buf: %c2)

  test_assert.assert_eq_i64(actual: a_len, expected: 5,
    label: "bb.push_string: ASCII length matches byte count (\"hello\" → 5)")
  test_assert.assert_eq_string(actual: a_str, expected: "hello",
    label: "bb.to_string: ASCII round-trip preserves bytes")
  test_assert.assert_eq_i64(actual: u_len, expected: 6,
    label: "bb.push_string: UTF-8 length counts bytes, not codepoints (\"héllo\" → 6)")
  test_assert.assert_eq_string(actual: u_str, expected: "héllo",
    label: "bb.to_string: UTF-8 round-trip preserves multi-byte sequences")
  test_assert.assert_eq_i64(actual: c_len, expected: 6,
    label: "bb.push_string: \"foo\" ++ \"bar\" → len 6 after grow path")
  test_assert.assert_eq_string(actual: c_str, expected: "foobar",
    label: "bb.to_string: two-push concatenation produces contiguous bytes")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
