// Issue nexus-byiw subset: unit-test `nxlib/stdlib/bytebuffer.nx::empty`
// — the constructor that allocates a fresh 24-byte header (len=0,
// cap=0, data_ptr=0) and wraps it in a linear `%ByteBuffer`.
//
// A regression that wrote a non-zero into the len slot would break
// every subsequent push/length call (everything is anchored on the
// stored len). Edge cases pinned:
//   1. length(&empty()) == 0.
//   2. get_byte at index 0 on an empty buffer returns -1 (the
//      "out-of-bounds" sentinel from buf_get_byte — `idx >= len`
//      is true at idx=0 when len=0).
//   3. get_byte at a negative index returns -1 (the same sentinel;
//      the negative-index branch is a separate `idx < 0` check).
//   4. to_string(&empty()) == "" (buf_to_string short-circuits when
//      len <= 0 and returns the packed (ptr=0, len=0) which puns to
//      the empty string).
//
// Snapshot observations into non-linear locals before asserting so
// the linear %b handle is freed before any throwable assert can
// raise (avoids E0540 linearity-across-throw).
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

let body = fn () -> unit throws { Exn } do
  let %b = bb.empty()
  let len = bb.length(buf: &b)
  let at_zero = bb.get_byte(buf: &b, idx: 0)
  let at_neg = bb.get_byte(buf: &b, idx: 0 - 1)
  let s = bb.to_string(buf: &b)
  bb.free(buf: %b)

  test_assert.assert_eq_i64(actual: len, expected: 0,
    label: "bb.empty: length of fresh buffer = 0")
  test_assert.assert_eq_i64(actual: at_zero, expected: 0 - 1,
    label: "bb.get_byte: idx=0 on empty buffer = -1 (out-of-bounds)")
  test_assert.assert_eq_i64(actual: at_neg, expected: 0 - 1,
    label: "bb.get_byte: negative idx on empty buffer = -1")
  test_assert.assert_eq_string(actual: s, expected: "",
    label: "bb.to_string: empty buffer = \"\"")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
