// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/bytebuffer.nx::push_uleb128` — unsigned LEB128
// variable-length encoding. Each byte holds 7 payload bits; the
// high bit (0x80) is the continuation flag (1 = more bytes follow,
// 0 = last byte). Used everywhere in WASM section emit to encode
// sizes, indices, and immediates.
//
// The implementation uses `(v >> 7) & shr7_logical_mask` to turn
// the arithmetic shift into a logical one — a regression that
// dropped the mask would loop forever on negative inputs, but the
// public API only accepts non-negative-shaped i64 anyway, so we
// stick to documented boundaries.
//
// Edge cases pinned:
//   1. val=0: one byte 0x00 (single-byte termination, payload 0,
//      no continuation).
//   2. val=127 (0x7F): one byte 0x7F — the single-byte boundary
//      (`rest == 0` reached, continuation bit cleared).
//   3. val=128 (0x80): two bytes [0x80, 0x01] — payload 0 with
//      continuation, then payload 1 with terminator. Catches a
//      regression that mistakes payload bits for continuation.
//   4. val=300 (0x12C = 0b100101100): two bytes [0xAC, 0x02] —
//      low 7 bits = 0b0101100 = 0x2C, with continuation → 0xAC;
//      next 7 bits = 0b0000010 = 0x02, no continuation.
//   5. val=16384 (0x4000): three bytes [0x80, 0x80, 0x01] — the
//      three-byte boundary, catches one-off in the shift counter.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

let body = fn () -> unit throws { Exn } do
  // case 1: val=0
  let %b0 = bb.empty()
  let %b1 = bb.push_uleb128(buf: %b0, val: 0)
  let l1 = bb.length(buf: &b1)
  let b1_0 = bb.get_byte(buf: &b1, idx: 0)
  bb.free(buf: %b1)

  // case 2: val=127
  let %c0 = bb.empty()
  let %c1 = bb.push_uleb128(buf: %c0, val: 127)
  let l2 = bb.length(buf: &c1)
  let c1_0 = bb.get_byte(buf: &c1, idx: 0)
  bb.free(buf: %c1)

  // case 3: val=128 → [0x80, 0x01]
  let %d0 = bb.empty()
  let %d1 = bb.push_uleb128(buf: %d0, val: 128)
  let l3 = bb.length(buf: &d1)
  let d1_0 = bb.get_byte(buf: &d1, idx: 0)
  let d1_1 = bb.get_byte(buf: &d1, idx: 1)
  bb.free(buf: %d1)

  // case 4: val=300 → [0xAC, 0x02]
  let %e0 = bb.empty()
  let %e1 = bb.push_uleb128(buf: %e0, val: 300)
  let l4 = bb.length(buf: &e1)
  let e1_0 = bb.get_byte(buf: &e1, idx: 0)
  let e1_1 = bb.get_byte(buf: &e1, idx: 1)
  bb.free(buf: %e1)

  // case 5: val=16384 → [0x80, 0x80, 0x01]
  let %f0 = bb.empty()
  let %f1 = bb.push_uleb128(buf: %f0, val: 16384)
  let l5 = bb.length(buf: &f1)
  let f1_0 = bb.get_byte(buf: &f1, idx: 0)
  let f1_1 = bb.get_byte(buf: &f1, idx: 1)
  let f1_2 = bb.get_byte(buf: &f1, idx: 2)
  bb.free(buf: %f1)

  test_assert.assert_eq_i64(actual: l1, expected: 1,
    label: "push_uleb128(0): single byte")
  test_assert.assert_eq_i64(actual: b1_0, expected: 0,
    label: "push_uleb128(0): byte 0 = 0x00")
  test_assert.assert_eq_i64(actual: l2, expected: 1,
    label: "push_uleb128(127): single byte (max single-byte value)")
  test_assert.assert_eq_i64(actual: c1_0, expected: 127,
    label: "push_uleb128(127): byte 0 = 0x7F (no continuation)")
  test_assert.assert_eq_i64(actual: l3, expected: 2,
    label: "push_uleb128(128): two bytes (single-byte boundary crossed)")
  test_assert.assert_eq_i64(actual: d1_0, expected: 128,
    label: "push_uleb128(128): byte 0 = 0x80 (continuation, payload 0)")
  test_assert.assert_eq_i64(actual: d1_1, expected: 1,
    label: "push_uleb128(128): byte 1 = 0x01 (terminator, payload 1)")
  test_assert.assert_eq_i64(actual: l4, expected: 2,
    label: "push_uleb128(300): two bytes")
  test_assert.assert_eq_i64(actual: e1_0, expected: 172,
    label: "push_uleb128(300): byte 0 = 0xAC (cont. bit | low 7 of 300)")
  test_assert.assert_eq_i64(actual: e1_1, expected: 2,
    label: "push_uleb128(300): byte 1 = 0x02 (terminator, next 7 bits)")
  test_assert.assert_eq_i64(actual: l5, expected: 3,
    label: "push_uleb128(16384): three bytes (two-byte boundary crossed)")
  test_assert.assert_eq_i64(actual: f1_0, expected: 128,
    label: "push_uleb128(16384): byte 0 = 0x80")
  test_assert.assert_eq_i64(actual: f1_1, expected: 128,
    label: "push_uleb128(16384): byte 1 = 0x80")
  test_assert.assert_eq_i64(actual: f1_2, expected: 1,
    label: "push_uleb128(16384): byte 2 = 0x01 (terminator)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
