// Issue nexus-byiw subset: unit-test
// `nxlib/stdlib/bytebuffer.nx::push_byte` + `get_byte` round-trip,
// specifically the low-8-bit mask that `bput` applies via
// `val & 255`. A regression that wrote the full i64 (e.g.
// `mem.store_u8(addr, val: byte)` without masking) would store
// the wrong low byte under some host engines; even when it works
// it would still produce a wrong read for negative `byte` values
// (i64 sign-extends to a non-zero high byte before truncation).
//
// Edge cases pinned:
//   1. Round-trip of byte 0x00 (zero byte).
//   2. Round-trip of byte 0xFF (255 — top of the u8 range).
//   3. Out-of-range byte 256 stores as 0 (low 8 bits of 256 are
//      0x00); confirms the mask wraps modulo 256.
//   4. Out-of-range byte 511 stores as 255 (low 8 bits of 511
//      are 0xFF).
//   5. Negative byte -1 stores as 255 (i64 -1 has all bits set;
//      masking with 0xFF leaves 0xFF) — pinpoints the sign-aware
//      truncation contract.
//   6. length() increments by exactly 1 per push.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"

let body = fn () -> unit throws { Exn } do
  let %b0 = bb.empty()
  let %b1 = bb.push_byte(buf: %b0, byte: 0)           // 0x00
  let %b2 = bb.push_byte(buf: %b1, byte: 255)         // 0xFF
  let %b3 = bb.push_byte(buf: %b2, byte: 256)         // 0x100 → low8 = 0x00
  let %b4 = bb.push_byte(buf: %b3, byte: 511)         // 0x1FF → low8 = 0xFF
  let %b5 = bb.push_byte(buf: %b4, byte: 0 - 1)       // 0xFFFFFFFFFFFFFFFF → 0xFF
  let len = bb.length(buf: &b5)
  let g0 = bb.get_byte(buf: &b5, idx: 0)
  let g1 = bb.get_byte(buf: &b5, idx: 1)
  let g2 = bb.get_byte(buf: &b5, idx: 2)
  let g3 = bb.get_byte(buf: &b5, idx: 3)
  let g4 = bb.get_byte(buf: &b5, idx: 4)
  let oob = bb.get_byte(buf: &b5, idx: 5)
  bb.free(buf: %b5)

  test_assert.assert_eq_i64(actual: len, expected: 5,
    label: "bb.push_byte: length increments by 1 per push (5 pushes → len=5)")
  test_assert.assert_eq_i64(actual: g0, expected: 0,
    label: "bb.push_byte: byte 0x00 round-trips")
  test_assert.assert_eq_i64(actual: g1, expected: 255,
    label: "bb.push_byte: byte 0xFF round-trips")
  test_assert.assert_eq_i64(actual: g2, expected: 0,
    label: "bb.push_byte: byte 256 masked to 0x00 (low 8 bits)")
  test_assert.assert_eq_i64(actual: g3, expected: 255,
    label: "bb.push_byte: byte 511 masked to 0xFF (low 8 bits)")
  test_assert.assert_eq_i64(actual: g4, expected: 255,
    label: "bb.push_byte: negative -1 masked to 0xFF (low 8 bits)")
  test_assert.assert_eq_i64(actual: oob, expected: 0 - 1,
    label: "bb.get_byte: idx past last pushed byte returns -1")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
