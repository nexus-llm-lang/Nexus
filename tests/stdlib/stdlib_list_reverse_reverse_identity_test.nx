// Port of bootstrap/tests/stdlib/list.rs::deforestation_reverse_reverse_identity.
// list.reverse(list.reverse(xs)) should round-trip back to xs.
import * as list from "std:list"

let body = fn () -> unit throws { Exn } do
  let xs = [10, 20, 30]
  let result = list.reverse(xs: list.reverse(xs: xs))
  match result do
    | a :: b :: c :: [] ->
      if a != 10 then raise RuntimeError(val: "expected 10") end
      if b != 20 then raise RuntimeError(val: "expected 20") end
      if c != 30 then raise RuntimeError(val: "expected 30") end
    | _ -> raise RuntimeError(val: "expected 3-element result")
  end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
