// Port of bootstrap/tests/stdlib/list.rs::deforestation_reverse_reverse_identity.
// list.reverse(list.reverse(xs)) should round-trip back to xs.
import * as test_assert from "std:test/assert"
import * as list from "std:list"

let main = fn () -> unit throws { Exn } do
  let xs = [10, 20, 30]
  let result = list.reverse(xs: list.reverse(xs))
  test_assert.assert_eq_i64_list(actual: result, expected: [10, 20, 30], label: "reverse(reverse([10,20,30]))")
  return ()
end
