// Port of bootstrap/tests/stdlib/string.rs::string_pad_left_basic.
// pad_left("42", width: 5, fill: "0") must produce a 5-byte string.
import { pad_left, length } from "std:str"

let body = fn () -> unit throws { Exn } do
  let result = pad_left(s: "42", width: 5, fill: "0")
  if length(s: result) != 5 then raise RuntimeError(val: "expected length 5") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
