// YAML round-trip: parse then serialize should produce re-parseable output
// that yields an equivalent value.
import * as test_assert from "std:test/assert"
import { parse, serialize, YamlValue, YamlNull, YamlBool, YamlInt, YamlFloat, YamlString, YamlSeq, YamlMap, YamlField } from "std:yaml"

// Structural equality for YamlValue.
let yaml_eq = fn (a: YamlValue, b: YamlValue) -> bool do
  match a do
    | YamlNull ->
      match b do
        | YamlNull -> return true
        | _ -> return false
      end
    | YamlBool(val: ba) ->
      match b do
        | YamlBool(val: bb) -> return ba == bb
        | _ -> return false
      end
    | YamlInt(val: ia) ->
      match b do
        | YamlInt(val: ib) -> return ia == ib
        | _ -> return false
      end
    | YamlFloat(val: fa) ->
      match b do
        | YamlFloat(val: fb) ->
          if fa !=. fa && fb !=. fb then return true end
          return fa ==. fb
        | _ -> return false
      end
    | YamlString(val: sa) ->
      match b do
        | YamlString(val: sb) -> return sa == sb
        | _ -> return false
      end
    | YamlSeq(items: xa) ->
      match b do
        | YamlSeq(items: xb) -> return items_eq(a: xa, b: xb)
        | _ -> return false
      end
    | YamlMap(fields: fma) ->
      match b do
        | YamlMap(fields: fmb) -> return fields_eq(a: fma, b: fmb)
        | _ -> return false
      end
  end
end

let items_eq = fn (a: [YamlValue], b: [YamlValue]) -> bool do
  match a do
    | [] ->
      match b do
        | [] -> return true
        | _ -> return false
      end
    | v1 :: rest1 ->
      match b do
        | [] -> return false
        | v2 :: rest2 ->
          if !yaml_eq(a: v1, b: v2) then return false end
          return items_eq(a: rest1, b: rest2)
      end
  end
end

let fields_eq = fn (a: [YamlField], b: [YamlField]) -> bool do
  match a do
    | [] ->
      match b do
        | [] -> return true
        | _ -> return false
      end
    | YamlField(key: k1, value: v1) :: rest1 ->
      match b do
        | [] -> return false
        | YamlField(key: k2, value: v2) :: rest2 ->
          if !yaml_eq(a: k1, b: k2) then return false end
          if !yaml_eq(a: v1, b: v2) then return false end
          return fields_eq(a: rest1, b: rest2)
      end
  end
end

let roundtrip = fn (v: YamlValue, label: string) -> unit throws { Exn } do
  let serialized = serialize(v)
  let v2 = parse(s: serialized)
  test_assert.assert_true(cond: yaml_eq(a: v, b: v2), label)
  return ()
end

let main = fn () -> unit throws { Exn } do
  roundtrip(v: YamlNull, label: "roundtrip null")
  roundtrip(v: YamlBool(val: true), label: "roundtrip true")
  roundtrip(v: YamlBool(val: false), label: "roundtrip false")
  roundtrip(v: YamlInt(val: 42), label: "roundtrip 42")
  roundtrip(v: YamlInt(val: -100), label: "roundtrip -100")
  roundtrip(v: YamlString(val: "hello"), label: "roundtrip plain string")
  roundtrip(v: YamlString(val: "has: colon"), label: "roundtrip string with colon")
  roundtrip(v: YamlSeq(items: [YamlInt(val: 1), YamlInt(val: 2)]), label: "roundtrip seq")
  roundtrip(
    v: YamlMap(fields: [YamlField(key: YamlString(val: "k"), value: YamlInt(val: 99))]),
    label: "roundtrip map")
  return ()
end
