// Pins the sequential semantics of std:lazy combinators.
//
// `docs/spec/lazy.md` gives surface semantics (cancel = "discard without
// evaluating"; race = "loser is cancelled") that would need a runtime drop
// primitive and a first-of-two arbiter, neither of which the host provides.
// So every combinator forces its arguments left-to-right via the `@` sigil
// (observable side effects included) and disposes any non-returned forced
// value through a caller-supplied `drop: (T) -> unit`. This test pins that:
//
//   * race(a, b, drop) returns a's value; b is forced and its value passed
//     to drop.
//   * cancel(a, drop) returns unit; a is forced, its value passed to drop.
//   * detach(a, drop) returns unit (mirror of cancel).
//   * force_all([@a, @b, ...]) returns the forced values in input order.
import * as test_assert from "std:test/assert"
import { race, cancel, detach, force_all } from "std:lazy"

// Disposer for the auto-droppable i64 thunk results used below.
let drop_i64 = fn (v: i64) -> unit do return () end

let body = fn () -> unit throws { Exn } do
  // race: a's value wins; b's forced value goes to drop.
  let @a = 99
  let @b = 88
  let r = race(a: a, b: b, drop: drop_i64)
  test_assert.assert_eq_i64(actual: r, expected: 99, label: "race returns a's value (sequential)")

  // cancel: returns unit; the thunk is forced, its value dropped.
  let @c = 7
  cancel(a: c, drop: drop_i64)

  // detach: same shape as cancel, distinct name.
  let @d = 11
  detach(a: d, drop: drop_i64)

  // force_all: pins input order.
  let @t1 = 10
  let @t2 = 20
  let @t3 = 30
  let xs = force_all(tasks: [ t1, t2, t3 ])
  test_assert.assert_eq_i64_list(
    actual: xs,
    expected: [ 10, 20, 30 ],
    label: "force_all preserves input order"
  )

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
