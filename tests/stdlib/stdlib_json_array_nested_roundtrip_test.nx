// Port of bootstrap/tests/stdlib/json.rs::json_array_nested_roundtrip.
// Deeply nested arrays preserve structure on parse + serialize.
import * as test_assert from "std:test/assert"
import { parse, serialize } from "std:json"

let main = fn () -> unit throws { Exn } do
  let raw = "[1,[2,[3,[]]]]"
  test_assert.assert_eq_string(actual: serialize(v: parse(s: raw)), expected: raw, label: "nested array roundtrip")
  return ()
end
