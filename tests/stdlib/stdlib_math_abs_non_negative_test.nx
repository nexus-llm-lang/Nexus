// Port of bootstrap/tests/stdlib/math.rs::prop_math_abs_non_negative.
// Original is a proptest over -1000..1000; reframed as a deterministic
// finite-sample sweep through representative values. Proptest infra is
// Rust-only.
import { abs } from "std:math"

let check = fn (n: i64) -> unit throws { Exn } do
  let x = abs(val: n)
  if x < 0 then raise RuntimeError(val: "abs returned negative") end
  return ()
end

let body = fn () -> unit throws { Exn } do
  check(n: 0)
  check(n: 1)
  check(n: -1)
  check(n: 42)
  check(n: -42)
  check(n: 999)
  check(n: -999)
  check(n: 1000)
  check(n: -1000)
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
