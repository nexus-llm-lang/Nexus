// Port of bootstrap/tests/stdlib/math.rs::prop_math_abs_non_negative.
// Original is a proptest over -1000..1000; reframed as a deterministic
// finite-sample sweep through representative values. Proptest infra is
// Rust-only.
import * as test_assert from "std:test/assert"
import * as str from "std:str"
import { abs } from "std:math"

let check = fn (n: i64) -> unit throws { Exn } do
  test_assert.assert_true(
    cond: abs(val: n) >= 0,
    label: "abs(" ++ str.from_i64(val: n) ++ ") >= 0"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  check(n: 0)
  check(n: 1)
  check(n: -1)
  check(n: 42)
  check(n: -42)
  check(n: 999)
  check(n: -999)
  check(n: 1000)
  check(n: -1000)
  return ()
end
