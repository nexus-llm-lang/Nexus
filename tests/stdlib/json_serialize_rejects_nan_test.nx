// Port of bootstrap/tests/stdlib/json.rs::json_serialize_rejects_nan.
// NaN is not part of JSON; the serializer must throw rather than silently
// emit a malformed token. We construct NaN via `to_f64("NaN")` (the host
// parser accepts the literal and yields a true NaN bit pattern).
import * as test_assert from "std:test/assert"
import { serialize, float, JsonValue } from "std:json"
import { to_f64 } from "std:str"

let raises_serialize = fn (v: JsonValue) -> bool do
  try
    let _ = serialize(v)
    return false
  catch _ ->
    return true
  end
end

let main = fn () -> unit throws { Exn } do
  let nan_val = to_f64(s: "NaN")
  let v = float(val: nan_val)
  test_assert.assert_true(cond: raises_serialize(v), label: "serialize rejects NaN")
  return ()
end
