// Port of bootstrap/tests/stdlib/string.rs::test_to_string_runtime_error.
// exn.to_string of RuntimeError(val: "boom") yields "RuntimeError: boom".
import { to_string } from "std:exn"

let body = fn () -> unit throws { Exn } do
  let e: Exn = RuntimeError(val: "boom")
  let result = to_string(exn: e)
  if result != "RuntimeError: boom" then raise RuntimeError(val: "unexpected to_string result") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
