// Port of bootstrap/tests/stdlib/json.rs::json_string_rejects_lone_surrogate.
// An unpaired high surrogate (0xD800..0xDBFF) is not a valid Unicode scalar;
// parse must throw JsonError instead of producing a malformed string.
import * as test_assert from "std:test/assert"
import { parse } from "std:json"

let raises_parse = fn (s: string) -> bool do
  try
    let _ = parse(s)
    return false
  catch _ ->
    return true
  end
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_true(
    cond: raises_parse(s: "\"\\uD83D\""),
    label: "parse rejects lone high surrogate"
  )
  return ()
end
