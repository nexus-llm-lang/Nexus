// Smoke test for std:pbt MVP (nexus-yebe).
//
// Three cases exercise the forall runner end-to-end:
//   1. Always-true property → Pass.
//   2. Always-false property (predicate `x == 999` on small_int, whose
//      range is [-100, 100], so it never matches) → Fail with a witness
//      in the expected range.
//   3. Property that fails for negative numbers → Fail, and greedy
//      shrinking should reduce the witness magnitude (we accept any
//      witness whose absolute value is small enough to demonstrate
//      shrinking actually fired).
import * as test_assert from "std:test/assert"
import * as pbt from "std:pbt"
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import { Pass, Fail } from "std:pbt"
import * as str from "std:str"

let abs_i64 = fn (n: i64) -> i64 do
  if n < 0 then return 0 - n end
  return n
end

let body = fn () -> unit require { Console } throws { Exn } do
  // NOTE: Predicates are declared as locals (not top-level lets) so the
  // codegen avoids the `__closure_wrap_<top_level>` path that mismatches
  // the closure ABI's i64 return slot against `bool`/i32 returns. See
  // `prop_reverse_test.nx` and the codegen note in `prop.nx::property`.
  // Predicates also bind the result to a local before returning, same
  // reason.
  let always_true = fn (x: i64) -> bool do
    let ok = true
    return ok
  end
  let always_false = fn (x: i64) -> bool do
    let ok = x == 999
    return ok
  end
  let nonnegative = fn (x: i64) -> bool do
    let ok = x >= 0
    return ok
  end

  // ── Case 1: always-true property passes ────────────────────────────────
  let r1 = pbt.forall(g: pbt.small_int, prop: always_true, n: 50)
  match r1 do
    | Pass -> test_assert.assert_true(cond: true, label: "always-true forall returns Pass")
    | Fail(witness: w, shrunk_input: _) ->
      test_assert.assert_true(cond: false,
        label: "always-true forall unexpectedly returned Fail with witness " ++ w)
  end

  // ── Case 2: always-false property fails with some witness ──────────────
  let r2 = pbt.forall(g: pbt.small_int, prop: always_false, n: 50)
  match r2 do
    | Pass ->
      test_assert.assert_true(cond: false,
        label: "always-false forall unexpectedly returned Pass")
    | Fail(witness: w, shrunk_input: s) ->
      // The witness is some i64 in [-100, 100]; we don't pin a specific
      // value (depends on the PRNG sequence), only that we got Fail.
      test_assert.assert_true(cond: true,
        label: "always-false forall returned Fail (witness=" ++ w ++ ", shrunk=" ++ s ++ ")")
  end

  // ── Case 3: negative-detecting property shrinks to a small witness ─────
  // The property fails for x < 0; the original counterexample is some
  // negative integer in [-100, 0); shrinking should walk it toward 0
  // (the largest still-failing value is -1). We assert the shrunk witness
  // parses back to a small-magnitude negative integer.
  let r3 = pbt.forall(g: pbt.small_int, prop: nonnegative, n: 50)
  match r3 do
    | Pass ->
      test_assert.assert_true(cond: false,
        label: "negative-detecting forall unexpectedly returned Pass")
    | Fail(witness: _, shrunk_input: s) ->
      // shrunk_input is the rendered i64 — re-parse and check magnitude.
      let parsed = str.to_i64_raw(s)
      test_assert.assert_true(cond: parsed < 0,
        label: "shrunk witness is negative: " ++ s)
      test_assert.assert_true(cond: abs_i64(n: parsed) <= 1,
        label: "shrunk witness has small magnitude (<=1): " ++ s)
  end

  return ()
end

let safe_run = fn () -> i64 require { Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
