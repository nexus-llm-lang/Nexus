// Port of bootstrap/tests/stdlib/string.rs::string_repeat_basic.
// repeat(s: "ab", n: 3) must produce a string of length 6.
import * as test_assert from "std:test/assert"
import { repeat, length } from "std:str"

let main = fn () -> unit throws { Exn } do
  let result = repeat(s: "ab", n: 3)
  test_assert.assert_eq_i64(
    actual: length(s: result),
    expected: 6,
    label: "length(repeat(\"ab\", 3))"
  )
  return ()
end
