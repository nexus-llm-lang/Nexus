// Port of bootstrap/tests/stdlib/option.rs::option_or_else_prefers_some.
import * as test_assert from "std:test/assert"
import { Option, or_else, unwrap_or } from "std:option"

let main = fn () -> unit throws { Exn } do
  let a: Option<i64> = None
  let b = Some(val: 42)
  test_assert.assert_eq_i64(
    actual: unwrap_or(opt: or_else(opt: a, other: b), default: 0),
    expected: 42,
    label: "or_else(None, Some(42))"
  )

  // Both Some: or_else preserves the original Some.
  let c = Some(val: 1)
  let d = Some(val: 2)
  test_assert.assert_eq_i64(
    actual: unwrap_or(opt: or_else(opt: c, other: d), default: 0),
    expected: 1,
    label: "or_else(Some(1), Some(2)) preserves original"
  )

  return ()
end
