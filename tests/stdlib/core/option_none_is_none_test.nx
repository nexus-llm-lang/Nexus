// Port of bootstrap/tests/stdlib/option.rs::option_none_is_none.
import * as test_assert from "std:test/assert"
import { Option, is_none } from "std:option"

let main = fn () -> unit throws { Exn } do
  let opt: Option<i64> = None
  test_assert.assert_true(cond: is_none(opt), label: "is_none(None)")
  return ()
end
