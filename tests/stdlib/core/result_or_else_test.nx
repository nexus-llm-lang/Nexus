// or_else on Ok returns the original; on Err returns the fallback.
import * as test_assert from "std:test/assert"
import * as result from "std:result"

let main = fn () -> unit throws { Exn } do
  let ok_val = result.Ok(val: 1)
  let fallback = result.Ok(val: 99)
  test_assert.assert_eq_i64(
    actual: result.unwrap_or(res: result.or_else(res: ok_val, other: fallback), default: 0),
    expected: 1,
    label: "or_else(Ok(1), Ok(99)) returns original Ok"
  )

  let err_val = result.Err(err: 42)
  let ok_fallback = result.Ok(val: 7)
  test_assert.assert_eq_i64(
    actual: result.unwrap_or(res: result.or_else(res: err_val, other: ok_fallback), default: 0),
    expected: 7,
    label: "or_else(Err(42), Ok(7)) returns fallback Ok"
  )

  return ()
end
