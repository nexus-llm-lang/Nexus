// Port of bootstrap/tests/stdlib/json.rs::json_unicode_basic_bmp_escape.
// JSON \uXXXX escape for a basic-plane codepoint (U+00E9 'é') decodes to
// the expected UTF-8 byte sequence (0xC3 0xA9).
import * as test_assert from "std:test/assert"
import { parse, JsonString } from "std:json"
import { byte_length, byte_at } from "std:str"
import { ord } from "std:char"

let main = fn () -> unit throws { Exn } do
  // U+00E9 = é. JSON: "é". UTF-8 byte sequence: 0xC3 0xA9.
  let v = parse(s: "\"\\u00e9\"")
  match v do
    | JsonString(val: s) ->
      test_assert.assert_eq_i64(
        actual: byte_length(s),
        expected: 2,
        label: "UTF-8 byte length for é"
      )
      test_assert.assert_eq_i64(
        actual: ord(c: byte_at(s, idx: 0)),
        expected: 195,
        label: "byte 0 == 0xC3"
      )
      test_assert.assert_eq_i64(
        actual: ord(c: byte_at(s, idx: 1)),
        expected: 169,
        label: "byte 1 == 0xA9"
      )
    | _ -> throw RuntimeError(val: "expected JsonString")
  end
  return ()
end
