// Port of bootstrap/tests/stdlib/json.rs::json_lsp_did_change_roundtrip.
// LSP `textDocument/didChange` notification round-trips. Embedded JSON
// string contains a literal newline escape (\n) inside the contentChanges
// text payload — the parser/serializer must preserve it.
import { parse, serialize } from "std:json"

let body = fn () -> unit throws { Exn } do
  let raw = "{\"jsonrpc\":\"2.0\",\"method\":\"textDocument/didChange\",\"params\":{\"textDocument\":{\"uri\":\"file:///tmp/a.nx\",\"version\":2},\"contentChanges\":[{\"text\":\"let x = 1\\n\"}]}}"
  let v = parse(s: raw)
  if serialize(v) != raw then raise RuntimeError(val: "didChange roundtrip") end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
