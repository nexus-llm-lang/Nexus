// nexus-wj8mk: reading a field of an IMPORTED single-constructor `opaque`
// record returned a DIFFERENT field's value whenever the field declaration
// order differed from alphabetical order. Construction stores fields in
// alphabetical heap order, but for an opaque imported type the variants are
// stripped to [] (D-Type-Sum-Opaque), so the LIR field-extraction fell back to
// a declaration-order index and read the wrong heap slot (e.g. `method` read
// the `body` slot). The fix carries a layout-only copy of the stripped variants
// so extraction recovers the declaration order. `Req`'s fields are declared
// method, path, headers, body, rid (NOT alphabetical), so every accessor would
// return a scrambled value without the fix.
import * as test_assert from "std:test/assert"
import {
  mk_req,
  req_method,
  req_path,
  req_headers,
  req_body,
  req_rid,
  free_req
} from "tests/_fixtures/opaque_record_fields.nx"

let body = fn () -> unit throws { Exn } do
  let r = mk_req()
  test_assert.assert_eq_string(actual: req_method(r: &r), expected: "M0", label: "opaque imported field method -> M0")
  test_assert.assert_eq_string(actual: req_path(r: &r), expected: "P1", label: "opaque imported field path -> P1")
  test_assert.assert_eq_string(actual: req_headers(r: &r), expected: "H2", label: "opaque imported field headers -> H2")
  test_assert.assert_eq_string(actual: req_body(r: &r), expected: "B3", label: "opaque imported field body -> B3")
  test_assert.assert_eq_i64(actual: req_rid(r: &r), expected: 7, label: "opaque imported field rid -> 7")
  free_req(r: r)
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
