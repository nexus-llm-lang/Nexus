// nexus-987xh control: non-colliding constructor imports keep working via both
// selective import (`Circle`) and wildcard/qualified access (`sh.Square`) after
// constructors are routed through the import-binding rename map.
import * as test_assert from "std:test/assert"
import { Shape, Circle, area_ish } from "tests/_fixtures/ctor_unique_shape.nx"
import * as sh from "tests/_fixtures/ctor_unique_shape.nx"

let body = fn () -> unit throws { Exn } do
  // selective ctor + selective fn
  let c = Circle(r: 4)
  test_assert.assert_eq_i64(actual: area_ish(sh: c), expected: 48, label: "selective Circle")
  // qualified ctor + qualified fn
  let s = sh.Square(side: 5)
  test_assert.assert_eq_i64(actual: sh.area_ish(sh: s), expected: 25, label: "qualified Square")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
