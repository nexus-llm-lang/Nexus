// nexus-987xh guard: mirrors the in-tree repl.nx (ReplBinOp) vs vocab.nx
// (BinaryOp) collision the bootstrap depends on. This module defines its own
// `LocalOp` enum with nullary ctors that share their bare names with the
// selectively-imported `ImportedOp`. A module-local enum SHADOWS the imported
// same-named ctor in its own scope (self-binding wins over import), so the bare
// `OpAdd`/`OpMul` here bind to `LocalOp` — exactly how repl.nx's own OpXxx bind
// to ReplBinOp even though vocab.BinaryOp is also in the whole program. The
// imported ctor is reached through a NON-colliding name (`ImpOnly`) to confirm
// the import binding is still live for names the local enum does not shadow.
import * as test_assert from "std:test/assert"
import { ImportedOp, OpAdd, OpSub, OpMul, ImpOnly, imported_op_to_int } from "tests/_fixtures/ctor_collision_binop.nx"

type LocalOp = OpAdd | OpSub | OpMul

let local_op_to_int = fn (o: LocalOp) -> i64 do
  match o do
  | OpAdd -> 100
  | OpSub -> 200
  | OpMul -> 300
  end
end

let body = fn () -> unit throws { Exn } do
  // Local enum shadows the imported same-named ctor: OpAdd binds to LocalOp.
  let l = local_op_to_int(o: OpAdd)
  test_assert.assert_eq_i64(actual: l, expected: 100, label: "local OpAdd shadows imported (100)")
  // A non-shadowed imported ctor still binds to ImportedOp.
  let i = imported_op_to_int(o: ImpOnly)
  test_assert.assert_eq_i64(actual: i, expected: 9, label: "imported ImpOnly -> ImportedOp (9)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
