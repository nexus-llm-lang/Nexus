// Module-qualified nominal identity must NOT over-reject a genuinely shared
// imported type. `produce` (in nominal_shared_producer.nx) builds a value of
// `Shared`, declared in nominal_shared_type.nx; `consume` (same declaring
// module) accepts it. Both references resolve to the SAME declaration, so the
// value flows across modules and yields its payload (7).
import * as test_assert from "std:test/assert"
import { consume } from "tests/_fixtures/nominal_shared_type.nx"
import { produce } from "tests/_fixtures/nominal_shared_producer.nx"

let body = fn () -> unit throws { Exn } do
  let got = consume(x: produce())
  test_assert.assert_eq_i64(
    actual: got,
    expected: 7,
    label: "shared imported type still unifies (7)"
  )
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
