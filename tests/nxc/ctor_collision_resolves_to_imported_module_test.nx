// nexus-987xh: a selectively-imported constructor binds the constructor of the
// *imported* module even when another whole-program enum exports a same-named,
// same-arity constructor. Here `MkV` is imported from `Color`; calling
// `color_to_int` (which expects Color) must use Color's `MkV` and yield 1005,
// NOT the colliding `Size` ctor's 2005.
import * as test_assert from "std:test/assert"
import { Color, MkV, color_to_int } from "tests/_fixtures/ctor_collision_color.nx"
import { Size, size_to_int } from "tests/_fixtures/ctor_collision_size.nx"

let body = fn () -> unit throws { Exn } do
  let v = MkV(n: 5)
  let got = color_to_int(c: v)
  test_assert.assert_eq_i64(actual: got, expected: 1005, label: "MkV resolves to Color (1005)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
