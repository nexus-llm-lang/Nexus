// Port of bootstrap/tests/nxc/qualified_imports.rs::qualified_imports_diamond_and_mixed.
// Diamond regression: list.nx and string.nx are transitively imported
// multiple times via stdlib internals. With caller_entries propagation,
// each reference must resolve to a single registered function — no
// forwarder stubs emitted.
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import * as str from "std:str"

let body = fn () -> unit throws { Exn } do
  let xs = list.reverse(xs: [ 1, 2, 3 ])
  match xs do
    | h :: _ -> test_assert.assert_eq_i64(actual: h, expected: 3, label: "reverse head")
    | _ -> throw RuntimeError(val: "reverse produced empty list")
  end

  let n = list.length(xs: [ 10, 20, 30, 40 ])
  test_assert.assert_eq_i64(actual: n, expected: 4, label: "list.length [10,20,30,40]")

  let glen = str.length(s: "hello")
  test_assert.assert_eq_i64(actual: glen, expected: 5, label: "str.length hello")

  let s2 = str.substring(s: "abcdef", start: 1, len: 3)
  test_assert.assert_eq_string(actual: s2, expected: "bcd", label: "str.substring abcdef[1..3]")

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
