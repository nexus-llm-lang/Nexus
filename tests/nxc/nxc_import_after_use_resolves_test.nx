// Regression: under canonical naming, function bodies must resolve names
// regardless of source ordering — `compute_length` references `str_length`
// before its `import { length as str_length } from "std:str"` declaration
// appears in the file.
import * as test_assert from "std:test/assert"

let compute_length = fn (s: string) -> i64 do
  return str_length(s: s)
end

import { length as str_length } from "std:str"

let body = fn () -> unit throws { Exn } do
  let n = compute_length(s: "hello")
  test_assert.assert_eq_i64(actual: n, expected: 5, label: "compute_length hello")
  let m = compute_length(s: "")
  test_assert.assert_eq_i64(actual: m, expected: 0, label: "compute_length empty")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
