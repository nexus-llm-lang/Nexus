// Port of bootstrap/tests/nxc/transitive_wrapper.rs::transitive_wrapper_resolves.
// Regression: Nexus-level wrapper functions (Let with Lambda, not FFI
// externals) must survive reachability filtering and be emitted with their
// canonical name when called through a qualified import alias.
// `bytebuffer.copy_range` is such a wrapper over `__nx_copy_range`.
import * as test_assert from "std:test/assert"
import * as buf from "std:bytebuffer"

let body = fn () -> unit throws { Exn } do
  // Build the result inside a small scope so all linear buffers are
  // freed before any throwable assert call (E0540: linear values cannot
  // live across throwable call sites).
  let %b = buf.empty()
  let %b2 = buf.push_byte(buf: %b, byte: 65)
  let %b3 = buf.push_byte(buf: %b2, byte: 66)
  let %b4 = buf.empty()
  let %b5 = buf.copy_range(dst: %b4, src: &b3, start: 0, end_pos: 2)
  let n = buf.length(buf: &b5)
  let b0 = buf.get_byte(buf: &b5, idx: 0)
  let b1 = buf.get_byte(buf: &b5, idx: 1)
  buf.free(buf: %b5)
  buf.free(buf: %b3)

  test_assert.assert_eq_i64(actual: n, expected: 2, label: "copy_range result length")
  test_assert.assert_eq_i64(actual: b0, expected: 65, label: "copy_range[0] == 'A'")
  test_assert.assert_eq_i64(actual: b1, expected: 66, label: "copy_range[1] == 'B'")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
