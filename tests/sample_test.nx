// Second smoke fixture for `nexus test` — exercises the list-equality
// assertion path so the runner's PASS aggregation handles >1 fixture.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64_list(actual: [1, 2, 3], expected: [1, 2, 3], label: "i64-list-eq")
  test_assert.assert_eq_string_list(actual: ["a", "b"], expected: ["a", "b"], label: "string-list-eq")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
