/**
 * Regression test: first-class unit-returning function codegen soundness.
 *
 * A named top-level function of type `(v: i64) -> unit` passed as a first-class
 * value causes the compiler to synthesize a `__closure_wrap_*` lifted function.
 * Pre-fix, the wrapper was declared with wasm return type `()` (from
 * lower_lambda_ret_type leaving TyUnit unchanged) while its body was compiled
 * with ret_type widened to i64 by compile_function_body, leaving an i64 on the
 * stack for a declared-unit function.  The wasm validator rejected this with
 * "values remaining on stack at end of block".
 *
 * Fix: lower_lambda_ret_type now coerces TyUnit -> TyI64 so that the declared
 * wasm type, the LirFunction ret_type, and the body's placeholder all agree.
 *
 * Expected: program exits cleanly (no wasm trap, no validate error).
 */

let discard = fn (v: i64) -> unit do
  let _ = v
  return ()
end

let apply = fn (g: (v: i64) -> unit, x: i64) -> unit do
  g(v: x)
  return ()
end

let safe_run = fn () -> i64 do
  apply(g: discard, x: 42)
  return 1
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
