// nexus-byiw.3: targeted coverage for the f64-unary-math intrinsic
// category in src/backend/codegen/intrinsics.nx. `std:runtime/math.sqrt`
// is `external "f64_sqrt" : (val: float) -> float` and lowers to a single
// inline `f64.sqrt` opcode (kebab key `f64-sqrt`). The test pins the
// codegen-to-wasm wiring with three perfect-square inputs whose exact
// f64.sqrt result is representable without rounding:
//   sqrt(4.0)   == 2.0   (i64 bits 0x4000000000000000)
//   sqrt(16.0)  == 4.0   (i64 bits 0x4010000000000000)
//   sqrt(625.0) == 25.0  (i64 bits 0x4039000000000000)
// Round-tripping each result through linear memory with `mem.store_f64` /
// `mem.load_i64` and asserting the exact i64 bit pattern avoids the
// approximate-equality + epsilon dance of float compares while still
// catching any miscompile of the dispatch path (wrong opcode, wrong arg
// width, missing emit). A wrong arm (e.g. emitting `f64.abs` instead of
// `f64.sqrt`) would change the bit pattern of `sqrt(16.0)` from
// 0x4010000000000000 (= 4.0) to 0x4030000000000000 (= 16.0).
import * as test_assert from "std:test/assert"
import * as fmath from "std:runtime/math"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"

let f64_bits = fn (x: float) -> i64 do
  let p = arena.alloc_raw(size: 8)
  let _ = mem.store_f64(addr: p, val: x)
  return mem.load_i64(addr: p)
end

let body = fn () -> unit throws { Exn } do
  let r1 = fmath.sqrt(val: 4.0)
  test_assert.assert_eq_i64(actual: f64_bits(x: r1), expected: 4611686018427387904, label: "f64-sqrt: sqrt(4.0) bits == 2.0 bits")

  let r2 = fmath.sqrt(val: 16.0)
  test_assert.assert_eq_i64(actual: f64_bits(x: r2), expected: 4616189618054758400, label: "f64-sqrt: sqrt(16.0) bits == 4.0 bits")

  let r3 = fmath.sqrt(val: 625.0)
  test_assert.assert_eq_i64(actual: f64_bits(x: r3), expected: 4627730092099895296, label: "f64-sqrt: sqrt(625.0) bits == 25.0 bits")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
