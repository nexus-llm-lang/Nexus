// nexus-byiw.3: targeted coverage for the atomic intrinsic category in
// src/backend/codegen/intrinsics.nx. `atomic_rmw_add_i32` / `atomic_load_i32`
// / `atomic_store_i32` are `nexus:intrinsic` externals declared in
// std:runtime/atomic; each lowers to a single 0xFE-prefixed wasm op
// (kebab keys `atomic-rmw-add-i32`, `atomic-load-i32`, `atomic-store-i32`).
//
// rmw_add semantics under wasm threads: returns the value held BEFORE the
// add. This contract is the bump-pointer-allocator primitive — getting it
// wrong (e.g. emitting the after-value, or wiring the args reversed)
// silently corrupts every per-thread allocator. The test pins the
// before-value return and then re-loads to confirm the after-value
// persisted in linear memory.
//
// The cell address is 8-byte aligned (the validator requires 4-byte
// alignment for the i32-width atomic ops; 8 satisfies that). Three rounds
// of rmw_add ensures the test catches any "always-return-0" miscompile —
// only the first round would happen to return 0 if the cell starts at 0.
import * as test_assert from "std:test/assert"
import * as atomic from "std:runtime/atomic"
import * as arena from "std:runtime/arena"

let body = fn () -> unit throws { Exn } do
  let p = arena.alloc_raw(size: 8)

  // Initialize cell to 0 via atomic-store-i32 (mutation of the wire
  // would lose this and the rmw_add return value below would be junk).
  let _ = atomic.store_i32(addr: p, val: 0)

  // First rmw: cell 0 → 10, returns 0 (pre-value).
  let prev0 = atomic.rmw_add_i32(addr: p, val: 10)
  test_assert.assert_eq_i64(
    actual: prev0,
    expected: 0,
    label: "atomic-rmw-add-i32 first call returns pre-value 0"
  )

  let after0 = atomic.load_i32(addr: p)
  test_assert.assert_eq_i64(
    actual: after0,
    expected: 10,
    label: "atomic-load-i32 after first add reads 10"
  )

  // Second rmw: cell 10 → 17, returns 10.
  let prev1 = atomic.rmw_add_i32(addr: p, val: 7)
  test_assert.assert_eq_i64(
    actual: prev1,
    expected: 10,
    label: "atomic-rmw-add-i32 second call returns pre-value 10"
  )

  // Third rmw: cell 17 → 100, returns 17. A wrong arm that emitted the
  // after-value instead of the before-value would return 100 here.
  let prev2 = atomic.rmw_add_i32(addr: p, val: 83)
  test_assert.assert_eq_i64(
    actual: prev2,
    expected: 17,
    label: "atomic-rmw-add-i32 third call returns pre-value 17"
  )

  let final_val = atomic.load_i32(addr: p)
  test_assert.assert_eq_i64(
    actual: final_val,
    expected: 100,
    label: "atomic-load-i32 final reads 100"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
