// Regression test for nexus-rzaij: when a local name is bound first at
// f32/f64 and then rebound at i64 (or vice versa) in the same function
// scope, register_local widens the WASM slot to i64.  Pre-fix, the
// store path missed the float→i64 bit-reinterpret and the read path
// missed the i64→float bit-reinterpret, producing invalid WASM (stack
// type mismatch) that wasm-tools validate rejected.
//
// All four shapes are exercised:
//   f64-then-i64: slot widened when second binding is i64; read back f64
//   f32-then-i64: same for f32
//   i64-then-f32: slot widened when second binding is f32; read back i64
//   i32-control:  bool→i64 widening must still work (was correct pre-fix)
//
// Values round-trip through the widened slot.
//   1.5f64 = 0x3FF8000000000000 = 4609434218613702656 as i64 bits
import * as test_assert from "std:test/assert"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"

// Store f64 into linear memory and read back as i64 bits.
let f64_bits = fn (x: float) -> i64 do
  let p = arena.alloc_raw(size: 8)
  mem.store_f64(addr: p, val: x)
  return mem.load_i64(addr: p)
end

// f64-then-i64: v starts as f64, is rebound as i64; keep holds the f64.
let f64_then_i64 = fn (x: float) -> float do
  let v = x
  let keep = v
  let v = 99
  let _d = v
  return keep
end

// f32-then-i64: v starts as f32, is rebound as i64; keep holds the f32.
// Compares the kept f32 against a separate f32 constant of the same value.
let f32_then_i64_eq = fn () -> bool do
  let baseline: f32 = 1.5
  let v: f32 = 1.5
  let keep = v
  let v = 99
  let _d = v
  // keep and baseline should hold the same f32 bits.
  return keep == baseline
end

// i64-then-f32: v starts as i64, is rebound as f32; keep holds the i64.
let i64_then_f32 = fn (x: i64) -> i64 do
  let v = x
  let keep = v
  let v: f32 = 2.5
  let _d = v
  return keep
end

// i32/bool control: pre-existing widening must not break.
let bool_then_i64 = fn (x: bool) -> bool do
  let v = x
  let keep = v
  let v = 99
  let _d = v
  return keep
end

let body = fn () -> unit throws { Exn } do
  // f64-then-i64: pass 1.5, expect 1.5 back as exact bit pattern.
  let r1 = f64_then_i64(x: 1.5)
  test_assert.assert_eq_i64(
    actual: f64_bits(x: r1),
    expected: 4609434218613702656,
    label: "rzaij f64-then-i64: keep==1.5 (bits 0x3FF8000000000000)"
  )

  // f32-then-i64: compare the round-tripped f32 value against a reference
  // f32 constant of the same value. Both go through the widened i64 slot.
  let r2_ok = f32_then_i64_eq()
  test_assert.assert_eq_bool(
    actual: r2_ok,
    expected: true,
    label: "rzaij f32-then-i64: keep==ref (both 1.5 as f32)"
  )

  // i64-then-f32: pass 42, expect 42 back.
  let r3 = i64_then_f32(x: 42)
  test_assert.assert_eq_i64(
    actual: r3,
    expected: 42,
    label: "rzaij i64-then-f32: keep==42"
  )

  // bool/i32 control: true stays true (non-zero).
  let r4 = bool_then_i64(x: true)
  let r4_i = if r4 then 1 else 0 end
  test_assert.assert_eq_i64(
    actual: r4_i,
    expected: 1,
    label: "rzaij bool-then-i64 control: keep==true"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
