// nexus-byiw subset: pin the launcher preamble shape produced by
// `src/backend/polyglot.nx::pack_polyglot`.
//
// `preamble()` (polyglot.nx:170) hard-codes the POSIX-sh prologue:
//   #!/bin/sh
//   # nexus polyglot launcher ...
//   set -eu
//   T=$(mktemp); trap 'rm -f "$T"' EXIT INT TERM HUP
//   WASMTIME_BIN="${NEXUS_WASMTIME:-wasmtime}"
//   ...
// Any rewrite that alters the shebang, the `set -eu` guard, the mktemp
// allocation, or the wasmtime-not-found early-exit would invalidate the
// runtime behavior of every emitted launcher — the polyglot binary
// stops being executable on systems where /bin/sh is the only shell.
//
// We assert the *visible* characteristics of the preamble via the
// public `pack_polyglot` entry; the helpers (`preamble`, `render_*`)
// are file-private so we observe their composition through the
// output bytes.
//
// Mutation-verify: changing `"#!/bin/sh\n"` → `"#!/bin/bash\n"` in
// polyglot.nx flips both the starts_with assertion and the substring
// presence assertions for "set -eu" / "mktemp" (the preamble layout
// is otherwise unaffected by upstream cap/manifest variation).
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import * as str from "std:str"
import { pack_polyglot, StripManifest } from "src/backend/polyglot.nx"

let body = fn () -> unit throws { Exn } do
  // 4-byte dummy wasm payload. The preamble doesn't depend on payload
  // contents — only on caps + manifest mode — so empty/minimal is fine.
  let %w0 = bb.empty()
  let %w1 = bb.push_bytes(buf: %w0, bytes: [ 0, 97, 115, 109 ])  // "\0asm"
  let %out = pack_polyglot(wasm: &w1, caps: [], manifest: StripManifest)
  let header_str = bb.to_string(buf: &out)
  bb.free(buf: %out)
  bb.free(buf: %w1)

  test_assert.assert_true(
    cond: str.starts_with(s: header_str, prefix: "#!/bin/sh\n"),
    label: "pack_polyglot: launcher begins with POSIX-sh shebang")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "set -eu\n"),
    label: "pack_polyglot: preamble enables strict-mode (set -eu)")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "T=$(mktemp);"),
    label: "pack_polyglot: preamble allocates a tempfile via mktemp")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "NEXUS_WASMTIME:-wasmtime"),
    label: "pack_polyglot: preamble honors NEXUS_WASMTIME env override")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "#__NEXUS_PAYLOAD_BEGIN__\n"),
    label: "pack_polyglot: payload-begin marker terminates header")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
