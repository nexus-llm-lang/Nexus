// nexus-byiw subset: pin the canonical cap-ordering invariant + the
// `Net -> inherit-network` mapping in `src/backend/polyglot.nx`.
//
// Determinism is the entire reason `sort_caps` exists (polyglot.nx:80).
// Per the file header (line 14-19), two builds of the same source
// MUST yield byte-identical output regardless of input cap ordering
// or hash-map iteration order — caps are funneled through
// `known_cap_order()` (Clock, Console, Env, Fs, Net, Proc, Random)
// before any wasmtime flag emission.
//
// What this fixture pins:
//   1. `pack_polyglot(["Net", "Clock"])` produces a byte-identical
//      output to `pack_polyglot(["Clock", "Net"])`. Failure means
//      `sort_caps` regressed and launchers are no longer reproducible.
//   2. `pack_polyglot([..., "Net", ...])` injects "inherit-network"
//      into the exec line (see `cap_sflag_string`, polyglot.nx:129).
//      The mapping is single-source — every Net-cap launcher MUST
//      carry this flag.
//   3. `pack_polyglot([])` (no caps) MUST NOT contain
//      "inherit-network" — only Net should trigger it.
//
// Mutation-verify: removing the canonical-order walk (making
// `sort_caps` return input verbatim) breaks (1); changing
// `cap_sflag_string` to return "" for Net or to mis-spell the flag
// breaks (2) without affecting (1) or (3).
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import * as str from "std:str"
import { pack_polyglot, StripManifest } from "src/backend/polyglot.nx"

let body = fn () -> unit throws { Exn } do
  // Trivial payload — sort_caps determinism is orthogonal to payload bytes.
  let %w0 = bb.empty()
  let %w1 = bb.push_bytes(buf: %w0, bytes: [0, 97, 115, 109])

  // Two inputs that differ only in cap ordering.
  let %a = pack_polyglot(wasm: &w1, caps: ["Net", "Clock"], manifest: StripManifest)
  let a_str = bb.to_string(buf: &a)
  let a_len = bb.length(buf: &a)
  bb.free(buf: %a)

  let %b = pack_polyglot(wasm: &w1, caps: ["Clock", "Net"], manifest: StripManifest)
  let b_str = bb.to_string(buf: &b)
  let b_len = bb.length(buf: &b)
  bb.free(buf: %b)

  // No-cap baseline for the negative inherit-network assertion.
  let %c = pack_polyglot(wasm: &w1, caps: [], manifest: StripManifest)
  let c_str = bb.to_string(buf: &c)
  bb.free(buf: %c)
  bb.free(buf: %w1)

  // (1) Canonical-ordering determinism — same bytes regardless of input order.
  test_assert.assert_eq_i64(actual: a_len, expected: b_len,
    label: "sort_caps: [Net,Clock] and [Clock,Net] yield equal-length output")
  test_assert.assert_eq_string(actual: a_str, expected: b_str,
    label: "sort_caps: byte-identical output for cap-list permutations")

  // (2) Net cap injects -S inherit-network.
  test_assert.assert_true(
    cond: str.contains(s: a_str, sub: "inherit-network"),
    label: "cap_sflag_string: Net cap injects -S inherit-network into exec line")

  // (3) No-Net launcher MUST NOT carry inherit-network.
  test_assert.assert_false(
    cond: str.contains(s: c_str, sub: "inherit-network"),
    label: "cap_sflag_string: cap-less launcher omits inherit-network")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
