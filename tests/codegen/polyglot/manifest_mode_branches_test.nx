// nexus-byiw subset: pin the `KeepManifest` vs `StripManifest` branch
// in `src/backend/polyglot.nx::pack_polyglot` / `header_size`.
//
// The selector flows through:
//   pack_polyglot -> (KeepManifest? render_manifest_header : render_minimal_header)
//
// `render_manifest_header` (polyglot.nx:214) emits two additional lines
// after the exec line:
//   #__NEXUS_PAYLOAD_MANIFEST__
//   app:<payload_size>
// and the runtime preamble in manifest mode parses
// `MANIFEST_LINE=$(awk ...)` to discover the payload size.
//
// `render_minimal_header` (polyglot.nx:205) omits both — it tails
// straight to EOF.
//
// Behavioral contract:
//   * KeepManifest header MUST contain "#__NEXUS_PAYLOAD_MANIFEST__"
//     and "app:<N>" where N is the payload size.
//   * StripManifest header MUST contain NEITHER, and its rendered
//     length MUST be strictly smaller than the KeepManifest version
//     for the same caps + payload size.
//
// Mutation-verify: swapping the `if let KeepManifest = manifest` arms
// in pack_polyglot flips both the substring presence and the size
// ordering simultaneously. Stripping just the manifest payload size
// line breaks the "app:N" substring check.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import * as str from "std:str"
import { pack_polyglot, header_size, KeepManifest, StripManifest } from "src/backend/polyglot.nx"

let body = fn () -> unit throws { Exn } do
  // 12-byte distinctive payload (wasm magic + version + 4 sentinel bytes).
  // 12 is small enough that `app:12` is unambiguous in the output.
  let %w0 = bb.empty()
  let %w1 = bb.push_bytes(buf: %w0,
    bytes: [ 0, 97, 115, 109, 1, 0, 0, 0, 1, 2, 3, 4 ])
  let payload_len = bb.length(buf: &w1)

  let strip_size = header_size(caps: [], manifest: StripManifest, payload_size: payload_len)
  let keep_size = header_size(caps: [], manifest: KeepManifest, payload_size: payload_len)

  let %out_k = pack_polyglot(wasm: &w1, caps: [], manifest: KeepManifest)
  let keep_str = bb.to_string(buf: &out_k)
  bb.free(buf: %out_k)

  let %out_s = pack_polyglot(wasm: &w1, caps: [], manifest: StripManifest)
  let strip_str = bb.to_string(buf: &out_s)
  bb.free(buf: %out_s)
  bb.free(buf: %w1)

  test_assert.assert_eq_i64(actual: payload_len, expected: 12,
    label: "pack_polyglot: 12-byte payload sanity")

  // KeepManifest must inject the manifest markers + the size line.
  test_assert.assert_true(
    cond: str.contains(s: keep_str, sub: "#__NEXUS_PAYLOAD_MANIFEST__\n"),
    label: "pack_polyglot/KeepManifest: emits PAYLOAD_MANIFEST marker")
  test_assert.assert_true(
    cond: str.contains(s: keep_str, sub: "app:12\n"),
    label: "pack_polyglot/KeepManifest: emits `app:<payload_size>` line")

  // StripManifest must NOT contain either; minimal mode has no manifest.
  test_assert.assert_false(
    cond: str.contains(s: strip_str, sub: "#__NEXUS_PAYLOAD_MANIFEST__"),
    label: "pack_polyglot/StripManifest: omits PAYLOAD_MANIFEST marker")
  test_assert.assert_false(
    cond: str.contains(s: strip_str, sub: "app:"),
    label: "pack_polyglot/StripManifest: omits `app:` size line")

  // Size ordering — KeepManifest adds bytes, so it must be strictly larger.
  test_assert.assert_true(
    cond: keep_size > strip_size,
    label: "header_size: KeepManifest header is strictly larger than StripManifest")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
