// nexus-byiw subset: pin the payload-concat invariant of
// `src/backend/polyglot.nx::pack_polyglot`.
//
// pack_polyglot composes:
//   header_bytes (rendered POSIX sh script ending in PAYLOAD_BEGIN marker)
//   ++ wasm_bytes (verbatim, no transformation)
//
// and `header_size(caps, manifest, payload_size)` reports the byte
// length of just the header portion. The two functions MUST agree:
//
//   length(pack_polyglot(w,c,m)) == header_size(c,m, length(w)) + length(w)
//
// A drift between them — e.g. if `pack_polyglot` started compressing
// or re-encoding the wasm payload, or if `header_size` failed to
// account for the trailing `app:<N>` line in manifest mode — would
// poison every consumer of `header_size` (verbose-mode launcher
// reporting in src/driver.nx).
//
// We also assert that the LAST bytes of the output match the input
// wasm verbatim. This pins that pack_polyglot doesn't accidentally
// truncate, pad, or reorder the payload tail.
//
// Mutation-verify: replacing `bb.push_buf(dst: %out, src: wasm)` in
// pack_polyglot with a no-op (or with a `push_byte 0` instead) breaks
// the total-length and tail-byte assertions independently.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { pack_polyglot, header_size, StripManifest } from "src/backend/polyglot.nx"

let body = fn () -> unit throws { Exn } do
  // 8-byte sentinel payload: wasm magic header (`\0asm\1\0\0\0`).
  // The sentinel value is irrelevant to the invariant being pinned —
  // we just need known, distinguishable bytes to verify they reappear
  // at the tail of the output.
  let %w0 = bb.empty()
  let %w1 = bb.push_bytes(buf: %w0,
    bytes: [0, 97, 115, 109, 1, 0, 0, 0])
  let payload_len = bb.length(buf: &w1)

  let predicted_header = header_size(caps: [], manifest: StripManifest, payload_size: payload_len)

  let %out = pack_polyglot(wasm: &w1, caps: [], manifest: StripManifest)
  let total_len = bb.length(buf: &out)

  // Tail bytes — they should be the 8 payload bytes in original order.
  let tail0 = bb.get_byte(buf: &out, idx: total_len - 8)
  let tail3 = bb.get_byte(buf: &out, idx: total_len - 5)  // 'm' of "\0asm"
  let tail7 = bb.get_byte(buf: &out, idx: total_len - 1)  // last byte (0)
  bb.free(buf: %out)
  bb.free(buf: %w1)

  test_assert.assert_eq_i64(actual: payload_len, expected: 8,
    label: "pack_polyglot: 8-byte input payload length sanity")
  test_assert.assert_eq_i64(actual: total_len, expected: predicted_header + payload_len,
    label: "pack_polyglot: total length = header_size + payload length")
  test_assert.assert_eq_i64(actual: tail0, expected: 0,
    label: "pack_polyglot: tail byte 0 = payload[0] (0x00, wasm magic)")
  test_assert.assert_eq_i64(actual: tail3, expected: 109,
    label: "pack_polyglot: tail byte 3 = payload[3] ('m' of \"\\0asm\")")
  test_assert.assert_eq_i64(actual: tail7, expected: 0,
    label: "pack_polyglot: tail byte 7 = payload[7] (version trailing zero)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
