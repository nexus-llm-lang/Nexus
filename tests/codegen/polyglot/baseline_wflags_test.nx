// nexus-byiw subset: pin every wasm proposal flag enumerated in
// `src/backend/polyglot.nx::baseline_wflag_str` (line 116-118).
//
// The flag string is emitted *unconditionally* because stdlib runtime
// code depends on every one of these proposals regardless of the
// entry-point's caps. If any of these drops out of the launcher,
// wasmtime instantiation fails with "unknown import: env::memory" or
// "function refers to undefined index" at run time — far from the
// build that introduced the regression.
//
// Concretely, the launcher's exec line must always carry:
//   -W tail-call=y,exceptions=y,function-references=y,\
//      stack-switching=y,threads=y,shared-memory=y
//   -S threads      (always emitted by build_exec_line, polyglot.nx:199)
//   --dir=.         (working-dir grant)
//   --dir="${TMPDIR:-/tmp}"   (tempdir grant for the extracted payload)
//
// Mutation-verify: deleting any single feature from
// `baseline_wflag_str` flips exactly its substring check.
// Removing the `"-S threads "` literal from `build_exec_line` flips
// the threads-sflag check independently from the -W feature checks.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import * as str from "std:str"
import { pack_polyglot, StripManifest } from "src/backend/polyglot.nx"

let body = fn () -> unit throws { Exn } do
  let %w0 = bb.empty()
  let %w1 = bb.push_bytes(buf: %w0, bytes: [0, 97, 115, 109])
  let %out = pack_polyglot(wasm: &w1, caps: [], manifest: StripManifest)
  let header_str = bb.to_string(buf: &out)
  bb.free(buf: %out)
  bb.free(buf: %w1)

  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "tail-call=y"),
    label: "baseline_wflag_str: -W tail-call=y (TCO requirement)")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "exceptions=y"),
    label: "baseline_wflag_str: -W exceptions=y (stdlib throws)")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "function-references=y"),
    label: "baseline_wflag_str: -W function-references=y (typed funcref)")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "stack-switching=y"),
    label: "baseline_wflag_str: -W stack-switching=y (algebraic effects)")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "threads=y"),
    label: "baseline_wflag_str: -W threads=y (parallel-@ runtime)")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "shared-memory=y"),
    label: "baseline_wflag_str: -W shared-memory=y (env::memory import)")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "-S threads "),
    label: "build_exec_line: -S threads always emitted (shared env::memory)")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "--dir=."),
    label: "build_exec_line: --dir=. grants cwd access")
  test_assert.assert_true(
    cond: str.contains(s: header_str, sub: "--dir=\"${TMPDIR:-/tmp}\""),
    label: "build_exec_line: --dir=$TMPDIR grants extracted-payload tempdir")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
