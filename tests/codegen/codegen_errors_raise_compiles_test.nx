// Port of bootstrap/tests/codegen/errors.rs:
//   codegen_raise_compiles_and_traps.
// Original test asserts the program compiles and traps with a non-empty
// message; here we observe the same lowering by catching the raise and
// verifying the payload survives the round-trip.
import * as test_assert from "std:test/assert"

// Original Rust source uses positional `Boom(i64)`; the typechecker and
// `nexus build` CLI require labeled fields, so we use `code:`. Same shape.
exception Boom(code: i64)

let trigger = fn () -> i64 throws { Exn } do
  let err = Boom(code: 42)
  raise err
  return 0
end

let attempt = fn () -> i64 throws { Exn } do
  try
    let _ = trigger()
    return -1
  catch
    | Boom(code: c) -> return c
    | _ -> return -2
  end
  return -3
end

let body = fn () -> unit throws { Exn } do
  let observed = attempt()
  test_assert.assert_eq_i64(actual: observed, expected: 42, label: "Boom payload survives raise")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
