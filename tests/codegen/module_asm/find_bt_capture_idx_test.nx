// nexus-byiw — pins find_bt_capture_idx in src/backend/codegen/ctx/module_asm.nx.
//
// find_bt_capture_idx scans externals by Nexus-side name (NOT wasm_name) and
// returns the slot index of the entry whose name == bt_capture_symbol_name(),
// or -1 when absent. Codegen uses this slot to emit a `call` before every
// `op_throw` so the in-wasm bt ring buffer can capture the frame.
import * as test_assert from "std:test/assert"
import { TypeExpr, TyUnit, TyRow } from "src/common/ast.nx"
import { LirExternal } from "src/ir/lir/types.nx"
import { find_bt_capture_idx } from "src/backend/codegen/ctx/module_asm.nx"
import { bt_capture_symbol_name } from "src/ir/main_wrap.nx"
import { None } from "std:option"

let empty_throw_row = fn () -> TypeExpr do
  return TyRow(types: [], rest: None)
end

let mk_ext = fn (name: string) -> LirExternal do
  return LirExternal(
    name, wasm_module: "test", wasm_name: name,
    params: [], ret_type: TyUnit, throw_row: empty_throw_row()
  )
end

let body = fn () -> unit throws { Exn } do
  // ── case 1: empty external list → -1 ──
  // Programs that compile with main_wrap disabled (no catch-around-main) skip
  // injecting the bt_capture import. The lookup must return -1 cleanly.
  let r_empty = find_bt_capture_idx(exts: [])
  test_assert.assert_eq_i64(actual: r_empty, expected: -1,
    label: "find_bt_capture_idx: [] → -1 (no bt_capture import)")

  // ── case 2: bt_capture present at slot 0 ──
  let bt_name = bt_capture_symbol_name()
  let exts0 = [mk_ext(name: bt_name)]
  let r0 = find_bt_capture_idx(exts: exts0)
  test_assert.assert_eq_i64(actual: r0, expected: 0,
    label: "find_bt_capture_idx: only entry is bt_capture → 0")

  // ── case 3: bt_capture absent in a list with other entries → -1 ──
  let exts_no = [mk_ext(name: "host_a"), mk_ext(name: "host_b")]
  let r_no = find_bt_capture_idx(exts: exts_no)
  test_assert.assert_eq_i64(actual: r_no, expected: -1,
    label: "find_bt_capture_idx: bt_capture absent → -1 (matches by Nexus name)")

  // ── case 4: bt_capture at middle slot ──
  let exts_mid = [
    mk_ext(name: "host_a"),
    mk_ext(name: "host_b"),
    mk_ext(name: bt_name),
    mk_ext(name: "host_c")
  ]
  let r_mid = find_bt_capture_idx(exts: exts_mid)
  test_assert.assert_eq_i64(actual: r_mid, expected: 2,
    label: "find_bt_capture_idx: returns first matching slot index, not name length")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
