// nexus-byiw — pins build_bt_symbols_section in src/backend/codegen/ctx/module_asm.nx.
//
// Builds the `nx.bt.symbols` custom-section PAYLOAD (NOT the section frame —
// the section_id + content_len header is added later by emit_section). Layout:
//
//   payload = emit_name("nx.bt.symbols") || body
//   body    = u32_LE(count) || count × ( u32_LE(func_idx) || u32_LE(name_len) || name_bytes )
//
// emit_name(s) writes ULEB(len) followed by raw UTF-8 bytes — the section-name
// prefix is the WASM custom-section convention.
//
// "nx.bt.symbols" has length 13 → ULEB(13) is the single byte 0x0D.
import * as test_assert from "std:test/assert"
import { TypeExpr, TyI64, TyUnit } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"
import { LirFunction, LirAtomUnit } from "src/ir/lir/types.nx"
import { build_bt_symbols_section } from "src/backend/codegen/ctx/module_asm.nx"
import * as bb from "std:bytebuffer"
import { ByteBuffer } from "std:bytebuffer"

let dummy_span = fn () -> Span do
  return Span(offset: 0, line: 1, col: 1)
end

let mk_fn = fn (name: string) -> LirFunction do
  return LirFunction(
    name, params: [], ret_type: TyI64, body: [],
    ret: LirAtomUnit, span: dummy_span()
  )
end

let read_all = fn (buf: &ByteBuffer) -> [ i64 ] do
  return read_all_go(buf, idx: 0, len: bb.length(buf), acc: [])
end
let read_all_go = fn (buf: &ByteBuffer, idx: i64, len: i64, acc: [ i64 ]) -> [ i64 ] do
  if idx >= len then return rev_i64(xs: acc, out: []) end
  return read_all_go(buf, idx: idx + 1, len, acc: bb.get_byte(buf, idx) :: acc)
end
let rev_i64 = fn (xs: [ i64 ], out: [ i64 ]) -> [ i64 ] do
  match xs do
    | [] -> return out
    | x :: rest -> return rev_i64(xs: rest, out: x :: out)
  end
end

// The 14 leading bytes of every payload encode the section-name:
//   ULEB("nx.bt.symbols".length=13) || UTF-8 bytes of "nx.bt.symbols"
// = [13, 'n', 'x', '.', 'b', 't', '.', 's', 'y', 'm', 'b', 'o', 'l', 's']
// (ASCII: n=110, x=120, .=46, b=98, t=116, s=115, y=121, m=109, o=111, l=108)

let body = fn () -> unit throws { Exn } do
  // ── case 1: zero functions ──
  // body = u32_LE(0) only → 4 bytes [0,0,0,0]. Total payload = 14 + 4 = 18.
  let %p0 = build_bt_symbols_section(funcs: [], import_count: 0)
  let p0_len = bb.length(buf: &p0)
  let p0_bytes = read_all(buf: &p0)
  bb.free(buf: %p0)
  test_assert.assert_eq_i64(actual: p0_len, expected: 18,
    label: "build_bt_symbols_section: 0 funcs → 14B name prefix + 4B count = 18B payload")
  test_assert.assert_eq_i64_list(actual: p0_bytes,
    expected: [ 13, 110, 120, 46, 98, 116, 46, 115, 121, 109, 98, 111, 108, 115,
               0, 0, 0, 0 ],
    label: "build_bt_symbols_section: payload = emit_name(nx.bt.symbols) || u32_LE(0)")

  // ── case 2: single 1-char function name "f", import_count=0 ──
  // body = u32_LE(1)            // count
  //      || u32_LE(0)           // func_idx (start = import_count = 0)
  //      || u32_LE(1)           // name_len
  //      || 'f'  (= 0x66 = 102) // name bytes
  // Body length = 4 + 4 + 4 + 1 = 13. Total payload = 14 + 13 = 27.
  let %p1 = build_bt_symbols_section(funcs: [ mk_fn(name: "f") ], import_count: 0)
  let p1_bytes = read_all(buf: &p1)
  bb.free(buf: %p1)
  test_assert.assert_eq_i64_list(actual: p1_bytes,
    expected: [ 13, 110, 120, 46, 98, 116, 46, 115, 121, 109, 98, 111, 108, 115,
               1, 0, 0, 0,   // count = 1
               0, 0, 0, 0,   // func_idx = 0
               1, 0, 0, 0,   // name_len = 1
               102 ],         // 'f'
    label: "build_bt_symbols_section: 1 entry → u32_LE(count,idx,nlen) + name byte")

  // ── case 3: import_count offset is reflected in first func_idx ──
  // Same single "f" but with import_count=5 → func_idx = 5 (LE: [5,0,0,0]).
  let %p2 = build_bt_symbols_section(funcs: [ mk_fn(name: "f") ], import_count: 5)
  let p2_bytes = read_all(buf: &p2)
  bb.free(buf: %p2)
  test_assert.assert_eq_i64_list(actual: p2_bytes,
    expected: [ 13, 110, 120, 46, 98, 116, 46, 115, 121, 109, 98, 111, 108, 115,
               1, 0, 0, 0,   // count = 1
               5, 0, 0, 0,   // func_idx = import_count = 5
               1, 0, 0, 0,   // name_len = 1
               102 ],
    label: "build_bt_symbols_section: import_count offsets the first func_idx")

  // ── case 4: two functions — second func_idx = import_count + 1 ──
  // funcs=["a","b"], import_count=10. Body bytes:
  //   count=2, [10,0,0,0] [1,0,0,0] 'a',
  //            [11,0,0,0] [1,0,0,0] 'b'
  // The strictly-increasing idx by 1 is what disassemblers rely on to map
  // wasm function indices back to Nexus names.
  let %p3 = build_bt_symbols_section(funcs: [ mk_fn(name: "a"), mk_fn(name: "b") ], import_count: 10)
  let p3_bytes = read_all(buf: &p3)
  bb.free(buf: %p3)
  test_assert.assert_eq_i64_list(actual: p3_bytes,
    expected: [ 13, 110, 120, 46, 98, 116, 46, 115, 121, 109, 98, 111, 108, 115,
               2, 0, 0, 0,                   // count = 2
               10, 0, 0, 0, 1, 0, 0, 0, 97,  // idx=10, nlen=1, 'a'
               11, 0, 0, 0, 1, 0, 0, 0, 98 ], // idx=11, nlen=1, 'b'
    label: "build_bt_symbols_section: 2 entries — idx monotonically increases by 1")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
