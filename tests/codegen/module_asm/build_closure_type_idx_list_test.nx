// nexus-byiw — pins build_closure_type_idx_list in src/backend/codegen/ctx/module_asm.nx.
//
// Zips parallel arities[] and type_idxs[] into [ArityTypeIdx]. The pairing
// is positional: arities[i] ↔ type_idxs[i]. Length is min(|arities|, |type_idxs|)
// — the longer list is truncated. This pairing feeds call_indirect's type
// lookup; mis-zipping would mis-type every closure call.
import * as test_assert from "std:test/assert"
import { ArityTypeIdx } from "src/backend/wasm/defs.nx"
import { build_closure_type_idx_list } from "src/backend/codegen/ctx/module_asm.nx"
import * as list from "std:list"

// Flatten [ArityTypeIdx] into [arity0, type_idx0, arity1, type_idx1, ...] so
// assert_eq_i64_list can verify both fields and ordering in one pass.
let flatten = fn (xs: [ArityTypeIdx]) -> [i64] do
  return flatten_go(xs, acc: [])
end
let flatten_go = fn (xs: [ArityTypeIdx], acc: [i64]) -> [i64] do
  match xs do
    | [] -> return rev_i64(xs: acc, out: [])
    | ArityTypeIdx(arity: a, type_idx: t) :: rest ->
      return flatten_go(xs: rest, acc: t :: a :: acc)
  end
end
let rev_i64 = fn (xs: [i64], out: [i64]) -> [i64] do
  match xs do
    | [] -> return out
    | x :: rest -> return rev_i64(xs: rest, out: x :: out)
  end
end

let body = fn () -> unit throws { Exn } do
  // ── case 1: both empty ⇒ empty pair list ──
  let r0 = build_closure_type_idx_list(arities: [], type_idxs: [])
  test_assert.assert_eq_i64(actual: list.length(xs: r0), expected: 0,
    label: "build_closure_type_idx_list: [] [] → []")

  // ── case 2: equal-length lists zipped positionally ──
  // arities=[0,1,2] paired with type_idxs=[7,8,9] → [(0,7), (1,8), (2,9)].
  // Input order is preserved (NOT sorted by arity here — collect_closure_arities
  // already sorts upstream, so this function is a pure positional zip).
  let r3 = build_closure_type_idx_list(arities: [0, 1, 2], type_idxs: [7, 8, 9])
  test_assert.assert_eq_i64(actual: list.length(xs: r3), expected: 3,
    label: "build_closure_type_idx_list: 3+3 → 3 pairs")
  test_assert.assert_eq_i64_list(actual: flatten(xs: r3),
    expected: [0, 7, 1, 8, 2, 9],
    label: "build_closure_type_idx_list: positional zip of arity ↔ type_idx")

  // ── case 3: type_idxs shorter than arities → truncates to shorter length ──
  // arities has 3 entries but type_idxs has 2 → only 2 pairs produced.
  // Without this guard a downstream call_indirect would index past the
  // type-section bound — silent corruption.
  let r_trunc = build_closure_type_idx_list(arities: [0, 1, 2], type_idxs: [10, 11])
  test_assert.assert_eq_i64_list(actual: flatten(xs: r_trunc),
    expected: [0, 10, 1, 11],
    label: "build_closure_type_idx_list: shorter type_idxs truncates output length")

  // ── case 4: arities shorter than type_idxs → also truncates ──
  let r_trunc2 = build_closure_type_idx_list(arities: [0], type_idxs: [10, 11, 12])
  test_assert.assert_eq_i64_list(actual: flatten(xs: r_trunc2),
    expected: [0, 10],
    label: "build_closure_type_idx_list: shorter arities also truncates output")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
