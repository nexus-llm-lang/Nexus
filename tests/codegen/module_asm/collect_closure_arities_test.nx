// nexus-byiw — pins collect_closure_arities in src/backend/codegen/ctx/module_asm.nx.
//
// Computes the sorted-ascending, deduped set of closure arities that the
// wasm type section must register. Always seeds [0] so 0-arity closure calls
// and lazy `force` resolve their type lookup even when no __closure_*
// wrapper carries arity 0.
//
// Arity is derived from a __closure_* function's param count minus 1 (the
// implicit env param). Non-closure top-level functions are ignored.
import * as test_assert from "std:test/assert"
import { TypeExpr, TyI64, TyUnit } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"
import {
  LirFunction, LirParam, LirAtomUnit
} from "src/ir/lir/types.nx"
import { collect_closure_arities } from "src/backend/codegen/ctx/module_asm.nx"

let dummy_span = fn () -> Span do
  return Span(offset: 0, line: 1, col: 1)
end

let mk_param = fn (n: string) -> LirParam do
  return LirParam(label: n, name: n, typ: TyI64)
end

// Build a function with `n_params` synthetic params (all i64). Used to
// control reported arity (= n_params - 1 once the env param is subtracted).
let mk_params = fn (n: i64) -> [LirParam] do
  return mk_params_go(n, acc: [])
end
let mk_params_go = fn (n: i64, acc: [LirParam]) -> [LirParam] do
  if n <= 0 then return acc end
  return mk_params_go(n: n - 1, acc: mk_param(n: "p") :: acc)
end

let mk_fn = fn (name: string, n_params: i64) -> LirFunction do
  return LirFunction(
    name, params: mk_params(n: n_params),
    ret_type: TyI64, body: [], ret: LirAtomUnit, span: dummy_span()
  )
end

let body = fn () -> unit throws { Exn } do
  // ── case 1: empty function list — arity 0 always seeded ──
  // collect_closure_arities([]) returns [0] (no closures means only the
  // mandatory arity-0 entry for `force` / 0-arg closure-call sites).
  let a0 = collect_closure_arities(funcs: [])
  test_assert.assert_eq_i64_list(actual: a0, expected: [0],
    label: "collect_closure_arities: [] → [0] (arity-0 always present)")

  // ── case 2: non-closure functions are ignored ──
  // "regular_fn" and "main" are not __closure_*, not __inject_*, not the
  // sched trampoline — they must not contribute arities.
  let a_ignore = collect_closure_arities(funcs: [
    mk_fn(name: "regular_fn", n_params: 3),
    mk_fn(name: "main", n_params: 0)
  ])
  test_assert.assert_eq_i64_list(actual: a_ignore, expected: [0],
    label: "collect_closure_arities: non-__closure_ funcs do not contribute arities")

  // ── case 3: __closure_* with 3 params → arity 2 (3 - 1 env param) ──
  // Result is sorted ascending: [0, 2].
  let a_one = collect_closure_arities(funcs: [
    mk_fn(name: "__closure_foo", n_params: 3)
  ])
  test_assert.assert_eq_i64_list(actual: a_one, expected: [0, 2],
    label: "collect_closure_arities: __closure_foo(3 params) → arity 2, sorted [0,2]")

  // ── case 4: deduplication + sort across multiple __closure_* ──
  // arities {1, 1, 3, 0(from __closure_z 1-param), 0(seed)} dedup+sort → [0,1,3].
  // Also ensures 2 distinct closures with the same arity collapse to one entry.
  let a_dedup = collect_closure_arities(funcs: [
    mk_fn(name: "__closure_a", n_params: 4),  // arity 3
    mk_fn(name: "__closure_b", n_params: 2),  // arity 1
    mk_fn(name: "__closure_c", n_params: 2),  // arity 1 (dup → collapsed)
    mk_fn(name: "regular",     n_params: 9),  // ignored
    mk_fn(name: "__closure_z", n_params: 1)   // arity 0 (collapses into seed)
  ])
  test_assert.assert_eq_i64_list(actual: a_dedup, expected: [0, 1, 3],
    label: "collect_closure_arities: sorted-ascending dedup across multiple closures")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
