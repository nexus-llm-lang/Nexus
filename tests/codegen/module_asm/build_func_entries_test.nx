// nexus-byiw — pins build_external_func_entries and build_internal_func_entries
// in src/backend/codegen/ctx/module_asm.nx.
//
// Both builders preserve input order and assign monotonically increasing
// indices. External indices start at `idx`; internal indices start at
// `import_count + idx` — the offset that places internals after the import
// list in the wasm function index space.
import * as test_assert from "std:test/assert"
import { TypeExpr, TyI64, TyUnit, TyRow } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"
import {
  LirFunction, LirExternal, LirParam,
  LirAtomUnit
} from "src/ir/lir/types.nx"
import { FuncEntry } from "src/backend/wasm/defs.nx"
import {
  build_external_func_entries,
  build_internal_func_entries
} from "src/backend/codegen/ctx/module_asm.nx"
import { None } from "std:option"

let dummy_span = fn () -> Span do
  return Span(offset: 0, line: 1, col: 1)
end

let empty_throw_row = fn () -> TypeExpr do
  return TyRow(types: [], rest: None)
end

let mk_ext = fn (name: string, wm: string, wn: string) -> LirExternal do
  return LirExternal(
    name, wasm_module: wm, wasm_name: wn,
    params: [], ret_type: TyUnit, throw_row: empty_throw_row()
  )
end

let mk_fn = fn (name: string) -> LirFunction do
  return LirFunction(
    name, params: [], ret_type: TyI64, body: [],
    ret: LirAtomUnit, span: dummy_span()
  )
end

// Walk a FuncEntry list and project (name, index) pairs into two parallel
// i64-keyed lists for direct assertion. Names are converted to length so we
// can compare with assert_eq_i64_list (avoids a string-list assertion helper).
let project_indices = fn (es: [FuncEntry]) -> [i64] do
  return project_indices_go(es, acc: [])
end
let project_indices_go = fn (es: [FuncEntry], acc: [i64]) -> [i64] do
  match es do
    | [] -> return rev_i64(xs: acc, out: [])
    | FuncEntry(name: _, index: i) :: rest ->
      return project_indices_go(es: rest, acc: i :: acc)
  end
end
let rev_i64 = fn (xs: [i64], out: [i64]) -> [i64] do
  match xs do
    | [] -> return out
    | x :: rest -> return rev_i64(xs: rest, out: x :: out)
  end
end

let body = fn () -> unit throws { Exn } do
  // ── case 1: empty external list ⇒ empty FuncEntry list ──
  let e_empty = build_external_func_entries(exts: [], idx: 7)
  test_assert.assert_eq_i64_list(actual: project_indices(es: e_empty),
    expected: [],
    label: "build_external_func_entries: [] input → [] output regardless of idx")

  // ── case 2: 3 externals starting at idx=0 ⇒ indices [0,1,2] in input order ──
  let exts3 = [
    mk_ext(name: "host_a", wm: "wasi:io", wn: "a"),
    mk_ext(name: "host_b", wm: "wasi:io", wn: "b"),
    mk_ext(name: "host_c", wm: "wasi:io", wn: "c")
  ]
  let e3 = build_external_func_entries(exts: exts3, idx: 0)
  test_assert.assert_eq_i64_list(actual: project_indices(es: e3),
    expected: [0, 1, 2],
    label: "build_external_func_entries: 3 externs at idx=0 → indices 0,1,2 in order")

  // ── case 3: nonzero idx offset is honored ──
  // External list builders are called from compile_lir_to_wasm with a starting
  // index that reserves slots for prepended synthetic imports.
  let e3_off = build_external_func_entries(exts: exts3, idx: 5)
  test_assert.assert_eq_i64_list(actual: project_indices(es: e3_off),
    expected: [5, 6, 7],
    label: "build_external_func_entries: idx=5 offset → indices 5,6,7")

  // ── case 4: internal builder applies import_count + idx ──
  // import_count=4 simulates a module with 4 imports already; internals start
  // at the next slot. idx kicks in on top of that — both must add.
  let funcs2 = [mk_fn(name: "main"), mk_fn(name: "helper")]
  let i2 = build_internal_func_entries(funcs: funcs2, import_count: 4, idx: 0)
  test_assert.assert_eq_i64_list(actual: project_indices(es: i2),
    expected: [4, 5],
    label: "build_internal_func_entries: 2 funcs after 4 imports → indices 4,5")

  // ── case 5: internal builder combined offset (import_count=10, idx=3) ──
  let i2_off = build_internal_func_entries(funcs: funcs2, import_count: 10, idx: 3)
  test_assert.assert_eq_i64_list(actual: project_indices(es: i2_off),
    expected: [13, 14],
    label: "build_internal_func_entries: indices = import_count + idx + position")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
