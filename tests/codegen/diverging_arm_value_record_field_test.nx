import * as test_assert from "std:test/assert"

type R = { b: i64, a: i64 }
exception Boom

let if_form = fn (c: bool) -> i64 throws { Boom } do
  let r = if c then throw Boom else { b: 2, a: 200 } end
  return r.a
end

let match_form = fn (c: bool) -> i64 throws { Boom } do
  let r = match c do | true -> throw Boom | false -> { b: 2, a: 200 } end
  return r.a
end

let if_form_else_diverges = fn (c: bool) -> i64 throws { Boom } do
  let r = if c then { b: 5, a: 42 } else throw Boom end
  return r.a
end

let body = fn () -> unit throws { Exn, Boom } do
  test_assert.assert_eq_i64(
    actual: if_form(c: false),
    expected: 200,
    label: "diverging-arm pin1: if-form first arm throws, project .a"
  )
  test_assert.assert_eq_i64(
    actual: match_form(c: false),
    expected: 200,
    label: "diverging-arm pin2: match-form first arm throws, project .a"
  )
  test_assert.assert_eq_i64(
    actual: if_form_else_diverges(c: true),
    expected: 42,
    label: "diverging-arm pin3: if-form else arm throws, project .a"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
