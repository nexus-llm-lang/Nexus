// Regression test for nexus-fal73: a function whose body ends in a bare
// `if cond then E1 else E2 end` in implicit-return position (no explicit
// `return`) used to type-check but silently return 0 — both branch values
// were DROPPED at LIR lowering. The trailing-if statement path
// (lower_if_stmt -> lower_block) treats branches as side-effect-only, so the
// emitted `LirStmtIf` carried no value (`if c then  else  end => 0`).
//
// Fix: at the trailing implicit-return position, a value-producing `if/else`
// is lowered as an EXPRESSION (lower_if_expr captures each branch's trailing
// value into a result temp), mirroring how a trailing `match` surfaces its
// value. Unit-typed ifs (side effects) and both-diverging ifs keep the
// statement path. The fix also covers the MIXED shape where one branch yields
// a bare value and the other diverges via `return` — which the statement
// path's then_ret/else_ret machinery likewise dropped (the bare-value branch
// was lost while only the diverging branch's value was captured).
//
// Covered shapes:
//   - plain trailing if/else                (returns taken branch value)
//   - nested / chained trailing if/else     (inner if value propagates out)
//   - trailing if/else whose branches end in a match
//   - trailing if/else whose branches end in a bare arithmetic expr
//   - MIXED: then yields a value, else diverges via `return`
//   - MIXED: then diverges via `return`, else yields a value
//   - nested mixed: an inner value+return if feeding an outer trailing if
//   - both-branches-diverge control          (still returns taken branch value)
//   - no-else trailing if control            (statement-path fallthrough)
//   - unit trailing if (side effect) followed by explicit return (unaffected)
//   - `return if ...` (already worked, must still work)
import * as test_assert from "std:test/assert"

// Plain trailing if/else.
let plain = fn (x: i64) -> i64 do
  if x > 0 then 111 else 222 end
end

// Nested / chained trailing if/else.
let nested = fn (x: i64) -> i64 do
  if x > 10 then
    if x > 20 then 2 else 1 end
  else
    0
  end
end

type Col = R | G | B

// Trailing if/else whose branches each end in a match.
let branch_match = fn (x: i64) -> i64 do
  if x > 0 then
    match R do | R -> 7 | G -> 8 | B -> 9 end
  else
    match B do | R -> 70 | G -> 80 | B -> 90 end
  end
end

// Trailing if/else whose branches end in a bare arithmetic expr.
let branch_expr = fn (x: i64) -> i64 do
  if x > 0 then x + 100 else x - 100 end
end

// MIXED: then-branch yields a bare value, else-branch diverges via `return`.
let mixed_then_value = fn (x: i64) -> i64 do
  if x > 0 then x + 100 else return -1 end
end

// MIXED: then-branch diverges via `return`, else-branch yields a bare value.
let mixed_else_value = fn (x: i64) -> i64 do
  if x > 0 then return 999 else x + 5 end
end

// Nested mixed: inner trailing-if mixes value+return, feeding an outer
// trailing if whose else yields a plain value.
let nested_mixed = fn (x: i64, y: i64) -> i64 do
  if x > 0 then
    if y > 0 then y + 1 else return -7 end
  else
    9
  end
end

// Both branches diverge via `return` — must stay on the statement path and
// still return the taken branch's value (regression guard for the fix's
// "at least one bare value" gate, which keeps this off the expression path).
let both_diverge = fn (x: i64) -> i64 do
  if x > 0 then return 7 else return 8 end
end

// No-else trailing if — statement-path fallthrough must be unaffected.
let no_else = fn (x: i64) -> i64 do
  if x > 0 then return 11 end
  222
end

// Unit trailing if used purely for side effects, then explicit return. If the
// unit branches were mis-lowered to yield a value, the emitted wasm would be
// invalid; reaching the explicit `return 99` confirms the unit path is intact.
let noop = fn () -> unit do
  return ()
end

let unit_if_then_return = fn (x: i64) -> i64 do
  if x > 0 then noop() else noop() end
  return 99
end

// `return if ...` must still work.
let return_if = fn (x: i64) -> i64 do
  return if x > 0 then 11 else 22 end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: plain(x: 5), expected: 111,
    label: "fal73 plain trailing if: positive branch")
  test_assert.assert_eq_i64(actual: plain(x: -5), expected: 222,
    label: "fal73 plain trailing if: negative branch")

  test_assert.assert_eq_i64(actual: nested(x: 25), expected: 2,
    label: "fal73 nested trailing if: x>20")
  test_assert.assert_eq_i64(actual: nested(x: 15), expected: 1,
    label: "fal73 nested trailing if: 10<x<=20")
  test_assert.assert_eq_i64(actual: nested(x: 5), expected: 0,
    label: "fal73 nested trailing if: x<=10")

  test_assert.assert_eq_i64(actual: branch_match(x: 1), expected: 7,
    label: "fal73 trailing if with match branch: then")
  test_assert.assert_eq_i64(actual: branch_match(x: -1), expected: 90,
    label: "fal73 trailing if with match branch: else")

  test_assert.assert_eq_i64(actual: branch_expr(x: 5), expected: 105,
    label: "fal73 trailing if with expr branch: then")
  test_assert.assert_eq_i64(actual: branch_expr(x: -5), expected: -105,
    label: "fal73 trailing if with expr branch: else")

  test_assert.assert_eq_i64(actual: mixed_then_value(x: 3), expected: 103,
    label: "fal73 mixed (then value, else return): value branch")
  test_assert.assert_eq_i64(actual: mixed_then_value(x: -3), expected: -1,
    label: "fal73 mixed (then value, else return): return branch")
  test_assert.assert_eq_i64(actual: mixed_else_value(x: 3), expected: 999,
    label: "fal73 mixed (then return, else value): return branch")
  test_assert.assert_eq_i64(actual: mixed_else_value(x: -3), expected: 2,
    label: "fal73 mixed (then return, else value): value branch")

  test_assert.assert_eq_i64(actual: nested_mixed(x: 1, y: 5), expected: 6,
    label: "fal73 nested mixed: inner value branch")
  test_assert.assert_eq_i64(actual: nested_mixed(x: 1, y: -5), expected: -7,
    label: "fal73 nested mixed: inner return branch")
  test_assert.assert_eq_i64(actual: nested_mixed(x: -1, y: 0), expected: 9,
    label: "fal73 nested mixed: outer else branch")

  test_assert.assert_eq_i64(actual: both_diverge(x: 1), expected: 7,
    label: "fal73 both-diverge control: then")
  test_assert.assert_eq_i64(actual: both_diverge(x: -1), expected: 8,
    label: "fal73 both-diverge control: else")

  test_assert.assert_eq_i64(actual: no_else(x: 1), expected: 11,
    label: "fal73 no-else control: then return")
  test_assert.assert_eq_i64(actual: no_else(x: -1), expected: 222,
    label: "fal73 no-else control: fallthrough value")

  test_assert.assert_eq_i64(actual: unit_if_then_return(x: 1), expected: 99,
    label: "fal73 unit if + explicit return unaffected")

  test_assert.assert_eq_i64(actual: return_if(x: 1), expected: 11,
    label: "fal73 return-if still works")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
