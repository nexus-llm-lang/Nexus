/**
 * nexus-q88x regression test: local closure passed to list.fold_left
 * whose body recurses into a top-level fn (whose return type is bool /
 * i32) must compile and execute without wasm validation errors.
 *
 * Root cause (pre-fix):
 *   1. lambda_lift.nx#lower_lambda_params_go used coerce_arrow_to_i64,
 *      which leaves TyBool/TyI32/TyChar untouched. The lifted lambda's
 *      wasm sig therefore had `(param i64 i32 i64)` while the
 *      call_indirect site (fold_left's HOF slot) expected
 *      `(param i64 i64 i64)`.
 *   2. codegen.nx#emit_internal_call decided return_call eligibility
 *      via a unit-vs-non-unit check only. The lifted lambda has
 *      ret_type coerced to i64, but the callee returns bool (i32);
 *      return_call requires exact wasm type match, so the resulting
 *      module failed wasm validation with "current function requires
 *      result type [i32] but callee returns [i64]" (or vice versa).
 *
 * Fix: (1) use coerce_to_closure_slot in lower_lambda_params_go so
 * bool/i32/char params are declared as i64 in the lifted wasm sig.
 * (2) extend the return_call eligibility check to also require equal
 * wasm value-types via type_to_valtype.
 *
 * Expected output: result=true
 */
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import * as list from "std:list"

type Ty =
  TBool
  | TList(elem: Ty)
  | TRecord(fields: [ Ty ])

let is_comparable = fn (t: Ty) -> bool do
  match t do
    | TBool -> return true
    | TList(elem: e) -> return is_comparable(t: e)
    | TRecord(fields: fs) -> return all_fields_comparable(fs: fs)
  end
end

let all_fields_comparable = fn (fs: [ Ty ]) -> bool do
  let go = fn (acc: bool, val: Ty) -> bool do
    if acc then return is_comparable(t: val) end
    return false
  end
  return list.fold_left(xs: fs, init: true, f: go)
end

let main = fn (args: [ string ]) -> unit require { PermConsole } do
  inject stdio.system_handler do
  let _ = args
  let t = TRecord(fields: [ TBool, TList(elem: TBool) ])
  let result = is_comparable(t: t)
  if result then
    Console.println(val: "result=true")
  else
    Console.println(val: "result=false")
  end
  end
end
