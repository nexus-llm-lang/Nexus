// Regression test for nexus-i7alf: a `let` (or for-loop variable) inside a
// nested block (if / while / for / match-arm body) that SHADOWS an outer
// binding of the same name must get its OWN wasm local slot. Before the fix,
// codegen keyed slots by name only, so the inner binding reused the outer
// slot and the inner write CLOBBERED the outer value — `return i` after the
// block read the inner value instead of the surviving outer one.
//
// The typechecker scopes lexically (a different-TYPE inner shadow proves it:
// `let i = "hello"` inside the `if` of `typ_shadow` type-checks against the
// OUTER i64), so this was a typecheck/codegen disagreement. The HIR-conversion
// alpha-renames a shadowing binding to a fresh `name#depth` so distinct
// bindings reach codegen with distinct names → distinct slots, restoring
// agreement.
//
// Also pins the intended behaviors that must NOT regress:
//   * a FLAT same-scope re-`let` is a rebind and shares the slot (returns last)
//   * a shadowing binding's RHS sees the OUTER value (not itself)

import * as test_assert from "std:test/assert"

let sink = fn (n: i64) -> unit do return () end
let sink_s = fn (s: string) -> unit do return () end

// --- if-body shadow: outer survives ---
let if_shadow = fn () -> i64 do
  let i = 999
  if true then let i = 7  sink(n: i) end
  return i
end

// --- for-loop variable shadow: outer survives ---
let for_shadow = fn () -> i64 do
  let i = 999
  for i = 0 to 5 do sink(n: i) end
  return i
end

// --- while-body shadow: outer survives ---
let while_shadow = fn () -> i64 do
  let i = 999
  let ~c = 0
  while ~c < 3 do
    let i = 7
    sink(n: i)
    ~c <- ~c + 1
  end
  return i
end

// --- match-arm-body shadow: outer survives ---
let match_shadow = fn () -> i64 do
  let i = 999
  match true do
    | true -> let i = 7  sink(n: i)
    | false -> sink(n: 0)
  end
  return i
end

// --- nested if shadow at depth 2: each level keeps its own slot ---
let nested_shadow = fn () -> i64 do
  let i = 100
  if true then
    let i = 200
    if true then
      let i = 300
      sink(n: i)
    end
    // back at depth 1: must still see 200, not 300
    sink(n: i)
    return i
  end
  return i
end

// --- shadowing binding's RHS reads the OUTER value ---
let shadow_rhs_reads_outer = fn () -> i64 do
  let i = 10
  if true then
    let i = i + 5   // RHS `i` is the outer 10 → inner i = 15
    sink(n: i)
  end
  return i          // outer i unchanged = 10
end

// --- FLAT re-let (same scope) rebinds and shares the slot (returns 2) ---
let flat_rebind = fn () -> i64 do
  let i = 1
  let i = 2
  return i
end

// --- FLAT re-let INSIDE a nested block still rebinds (returns 22) ---
let flat_rebind_in_block = fn () -> i64 do
  let outer = 0
  if true then
    let x = 11
    let x = 22
    return x
  end
  return outer
end

// --- different-TYPE inner shadow: typechecks against outer i64, runs as 999 ---
let typ_shadow = fn () -> i64 do
  let i = 999
  if true then let i = "hello"  sink_s(s: i) end
  return i
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: if_shadow(), expected: 999, label: "if-body shadow keeps outer")
  test_assert.assert_eq_i64(
    actual: for_shadow(),
    expected: 999,
    label: "for-var shadow keeps outer"
  )
  test_assert.assert_eq_i64(
    actual: while_shadow(),
    expected: 999,
    label: "while-body shadow keeps outer"
  )
  test_assert.assert_eq_i64(
    actual: match_shadow(),
    expected: 999,
    label: "match-arm shadow keeps outer"
  )
  test_assert.assert_eq_i64(
    actual: nested_shadow(),
    expected: 200,
    label: "depth-2 shadow keeps depth-1"
  )
  test_assert.assert_eq_i64(
    actual: shadow_rhs_reads_outer(),
    expected: 10,
    label: "shadow RHS reads outer"
  )
  test_assert.assert_eq_i64(actual: flat_rebind(), expected: 2, label: "flat re-let rebinds")
  test_assert.assert_eq_i64(
    actual: flat_rebind_in_block(),
    expected: 22,
    label: "flat re-let in block rebinds"
  )
  test_assert.assert_eq_i64(
    actual: typ_shadow(),
    expected: 999,
    label: "different-type shadow keeps outer i64"
  )
  return ()
end
