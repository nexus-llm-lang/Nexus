// nexus-byiw.3 + nexus-i6fj V1: coverage for the Backtrace intrinsics in
// src/backend/codegen/intrinsics.nx. `bt_depth` / `bt_frame` are now
// inlined to direct reads from the page-18 ring buffer:
//
//   bt-depth          ->  i32.atomic.load (saved depth at last raise)
//                         then i64.extend_i32_u
//   bt-frame(idx)     ->  load packed (ptr<<32)|len from ring[idx & 63]
//   capture-backtrace ->  no-op stub (raise sites snapshot inline)
//
// Per nexus-i6fj V1, function prologues atomically push their packed
// name into the ring at function entry (for can_throw functions only).
// Each raise inline-snapshots `depth` -> `saved_depth` so backtrace()
// surfaces the call stack at raise time.
//
// Test approach: raise + catch, call `backtrace(e)`, assert the result
// is non-empty and that the most recent frame is `raise_and_catch`
// (the wasm function whose prologue last pushed before the raise).
import * as test_assert from "std:test/assert"
import { backtrace } from "std:exn"
import { length } from "std:list"
import * as str from "std:str"

exception TestRaise(msg: string)

let raise_and_catch = fn () -> Exn throws { Exn } do
  try
    raise TestRaise(msg: "intrinsic backtrace coverage")
  catch e ->
    return e
  end
end

let any_frame_ends_with = fn (xs: [string], suffix: string) -> bool do
  match xs do
    | [] -> return false
    | s :: rest ->
      if str.ends_with(s, suffix) then return true end
      return any_frame_ends_with(xs: rest, suffix)
  end
end

let body = fn () -> unit throws { Exn } do
  let e = raise_and_catch()
  let frames = backtrace(exn: e)
  // Non-empty under V1: prologues push a frame for every can_throw fn,
  // so the raise inside raise_and_catch sees at least its own frame.
  test_assert.assert_true(cond: length(xs: frames) > 0,
    label: "backtrace is non-empty after a raise (nexus-i6fj V1)")
  // The raising frame must appear in the snapshot. Canonical names are
  // file-qualified, so match by `#raise_and_catch` suffix.
  test_assert.assert_true(cond: any_frame_ends_with(xs: frames, suffix: "#raise_and_catch"),
    label: "backtrace includes raise_and_catch frame")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
