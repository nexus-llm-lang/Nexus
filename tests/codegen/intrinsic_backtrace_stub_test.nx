// nexus-byiw.3: targeted coverage for the Backtrace / debug intrinsic
// category in src/backend/codegen/intrinsics.nx. `bt_depth` and
// `bt_frame` are `nexus:intrinsic` externals declared in
// nxlib/stdlib/exn.nx (module-private). They emit as inline constants:
//
//   bt-depth          ->  i64.const 0
//   bt-frame(idx)     ->  drop the i64 arg, push i64.const 0
//                         (empty packed string atom)
//   capture-backtrace ->  no-op stub (no frame buffer to fill)
//
// Wasm cannot introspect its own call stack without a host, so these
// arms produce well-defined zero values rather than failing — the
// `backtrace()` API (also in stdlib/exn.nx) is always-empty until a
// host-side stack walker is wired. The intrinsic exists so user-level
// `try / catch` / `raise` keeps working; the test pins the stub
// contract so a partial implementation (e.g. emitting a real depth
// number but no frame table) doesn't break callers that expect [].
//
// Test approach: raise + catch an exception, then call `backtrace(e)`
// and assert the returned list is empty. The internal `bt_depth` /
// `bt_frame` externs are module-private; `backtrace(e)` is the
// stable export and the user-visible surface of the intrinsic.
import * as test_assert from "std:test/assert"
import { backtrace } from "std:exn"
import { length } from "std:list"

exception TestRaise(msg: string)

let raise_and_catch = fn () -> Exn throws { Exn } do
  try
    raise TestRaise(msg: "intrinsic backtrace coverage")
    // Unreachable; satisfies the type checker (the try block's value type
    // matches the catch arm's, both Exn-yielding).
    return TestRaise(msg: "unreachable")
  catch e ->
    return e
  end
end

let body = fn () -> unit throws { Exn } do
  let e = raise_and_catch()
  let frames = backtrace(exn: e)
  // The wasm-side stub returns 0 from bt-depth, so the collected list
  // is empty regardless of call-stack depth. A wrong arm in bt-depth
  // (e.g. emitting an actual count from a stale local) would surface
  // here as a non-zero length.
  test_assert.assert_eq_i64(actual: length(xs: frames), expected: 0,
    label: "bt-depth stub yields empty backtrace list")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
