// nexus-byiw.3 + nexus-i6fj V1: coverage for the Backtrace intrinsics in
// src/backend/codegen/intrinsics.nx. `bt_depth` / `bt_frame` are now
// inlined to direct reads from the page-18 ring buffer:
//
//   bt-depth          ->  i32.atomic.load (saved depth at last throw)
//                         then i64.extend_i32_u
//   bt-frame(idx)     ->  load packed (ptr<<32)|len from ring[idx & 63]
//   capture-backtrace ->  no-op stub (throw sites snapshot inline)
//
// Per nexus-i6fj V1, function prologues atomically push their packed
// name into the ring at function entry (for can_throw functions only).
// Each throw inline-snapshots `depth` -> `saved_depth` so backtrace()
// surfaces the call stack at throw time.
//
// Test approach: do_raise throws directly (can_throw=true, gets prologue
// push). raise_and_catch wraps it in try/catch — under nexus-05k8 the
// body's can_throw is suppressed, so raise_and_catch itself does NOT get
// a prologue push. Assert the backtrace is non-empty and includes #do_raise.
import * as test_assert from "std:test/assert"
import { backtrace } from "std:exn"
import { length } from "std:list"
import * as str from "std:str"

exception TestRaise(msg: string)

// do_raise throws directly (no catch) — can_throw=true, gets a backtrace
// prologue push under nexus-i6fj V1.
let do_raise = fn () -> unit throws { Exn } do
  throw TestRaise(msg: "intrinsic backtrace coverage")
end

// raise_and_catch wraps do_raise in a try/catch and returns the caught
// exception. The trailing throw is unreachable (do_raise always raises)
// but required by the return-type checker.
let raise_and_catch = fn () -> Exn throws { Exn } do
  try
    do_raise()
  catch e ->
    return e
  end
  throw TestRaise(msg: "unreachable")
end

let any_frame_ends_with = fn (xs: [ string ], suffix: string) -> bool do
  match xs do
    | [] -> return false
    | s :: rest ->
      if str.ends_with(s, suffix) then return true end
      return any_frame_ends_with(xs: rest, suffix)
  end
end

let body = fn () -> unit throws { Exn } do
  let e = raise_and_catch()
  let frames = backtrace(exn: e)
  // Non-empty under V1: prologues push a frame for every can_throw fn,
  // so do_raise (which raises directly) sees at least its own frame.
  test_assert.assert_true(cond: length(xs: frames) > 0,
    label: "backtrace is non-empty after a throw (nexus-i6fj V1)")
  // The directly-raising frame must appear. Canonical names are
  // file-qualified, so match by `#do_raise` suffix.
  // Note: raise_and_catch is NOT expected to appear because its body's
  // throw is caught (nexus-05k8 fix: can_throw=false suppresses prologue).
  test_assert.assert_true(cond: any_frame_ends_with(xs: frames, suffix: "#do_raise"),
    label: "backtrace includes do_raise frame")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
