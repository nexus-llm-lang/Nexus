/**
 * Regression test: lambda with `return ()` inside an if or match arm must
 * produce valid wasm.
 *
 * Pre-fix root cause: emit_return_with_tcmc (codegen/ctx/tcmc.nx) NoTcmc
 * branch emitted bare `op_return` after `emit_atom(LirAtomUnit)` +
 * `emit_coercion(TyUnit, _)` — both no-ops — so a unit early-return inside
 * a lifted-lambda body whose declared wasm return slot was i64 (canonical
 * closure-call ABI) tripped wasm validation with
 * `type mismatch: expected i64 but nothing on stack`. The trailing
 * `emit_return_value` correctly inserted a default value, but the in-branch
 * `op_return` fired earlier with an empty stack.
 *
 * Fix: when ret_val is unit and ret_type is non-unit, call
 * emit_default_for_type before op_return so the declared slot is reified.
 *
 * Equivalent top-level fn shape compiles fine — the bug is lambda-lift
 * specific (lifted lambdas always coerce ret_type to i64).
 *
 * Expected: both `if-ok` and `match-ok` print; no validation error,
 * no runtime trap.
 */
import { Console } from "std:stdio"
import * as stdio from "std:stdio"

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let f_if = fn (n: i64) -> unit do
      if n == 0 then return () end
      ()
    end
    f_if(n: 0)
    f_if(n: 1)
    Console.println(val: "if-ok")

    let f_match = fn (n: i64) -> unit do
      match n do
        | 0 -> return ()
        | _ -> ()
      end
    end
    f_match(n: 0)
    f_match(n: 1)
    Console.println(val: "match-ok")
  end
end
