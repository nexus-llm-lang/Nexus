/**
 * nexus-d33l7 regression test (capture variant): a recursive LOCAL closure
 * that ALSO captures another outer local. Both the self-reference (resolved
 * via `__env`) and the genuine capture (resolved via an env slot) must work.
 *
 * Before the fix the self-name occupied capture slot 0 (garbage), which also
 * shifted the real capture's slot. The fix drops the self-name from the
 * capture set entirely, so the real capture lands in slot 0 and the self-ref
 * is bound from `__env`.
 *
 * Expected: all asserts pass, exit 0.
 */
import * as test_assert from "std:test/assert"

// `step` is a genuine outer-local capture; `go` is the self-reference.
let count_by = fn (n: i64, step: i64) -> i64 do
  let go: (i: i64, acc: i64) -> i64 = fn (i: i64, acc: i64) -> i64 do
    if i <= 0 then return acc end
    return go(i: i - 1, acc: acc + step)
  end
  return go(i: n, acc: 0)
end

// Two distinct outer-local captures plus the self-reference, to confirm slot
// ordering survives when self is excluded.
let weighted = fn (n: i64, base: i64, mult: i64) -> i64 do
  let go: (i: i64, acc: i64) -> i64 = fn (i: i64, acc: i64) -> i64 do
    if i <= 0 then return acc end
    return go(i: i - 1, acc: acc + base + i * mult)
  end
  return go(i: n, acc: 0)
end

let main = fn () -> unit throws { Exn } do
  // 5 iterations adding step=7 each time -> 35
  test_assert.assert_eq_i64(
    actual: count_by(n: 5, step: 7),
    expected: 35,
    label: "recursive local closure + outer capture: 5*7 = 35"
  )
  // i = 3,2,1 : sum(base) = 3*10 = 30 ; sum(i*mult) = (3+2+1)*2 = 12 ; total 42
  test_assert.assert_eq_i64(
    actual: weighted(n: 3, base: 10, mult: 2),
    expected: 42,
    label: "recursive local closure + two outer captures = 42"
  )
  return ()
end
