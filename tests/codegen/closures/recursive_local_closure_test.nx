/**
 * nexus-d33l7 regression test: a recursive LOCAL closure
 * (`let go: (i: i64) -> i64 = fn (i) do ... go(...) ... end`) must run
 * without a wasm trap at any depth.
 *
 * Root cause (pre-fix): the lifted lambda captured its own name `go` as env
 * slot 0, but the closure cell was CONSTRUCTED before `go` was bound by the
 * following `let`, so slot 0 held garbage (0). The self-call did
 * `call_indirect` to table index 0 → "undefined element: out of bounds table
 * access" (exit 134), even at depth 3.
 *
 * Fix (src/ir/mir/mir.nx lift_lambda_self): when the let-name shows up as a
 * free var of its own lambda RHS, it is dropped from the capture set and bound
 * in the lifted body from `__env` — the closure object pointer the callee
 * receives IS the self value, so `callcl go(...)` re-extracts the table index
 * from that same object. No by-value capture, no construction-site back-patch.
 *
 * Expected: all asserts pass, exit 0.
 */
import * as test_assert from "std:test/assert"

// (a) shallow recursion (the issue's repro: r=3)
let count_down = fn (n: i64) -> i64 do
  let go: (i: i64) -> i64 = fn (i: i64) -> i64 do
    if i <= 0 then return 0 end
    return 1 + go(i: i - 1)
  end
  return go(i: n)
end

// (a') deeper recursion (count to 100 — proves it is not a stack/depth fluke)
let sum_to = fn (n: i64) -> i64 do
  let go: (acc: i64, i: i64) -> i64 = fn (acc: i64, i: i64) -> i64 do
    if i <= 0 then return acc end
    return go(acc: acc + i, i: i - 1)
  end
  return go(acc: 0, i: n)
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: count_down(n: 3),
    expected: 3,
    label: "recursive local closure depth 3 returns r=3"
  )
  test_assert.assert_eq_i64(
    actual: count_down(n: 100),
    expected: 100,
    label: "recursive local closure depth 100"
  )
  test_assert.assert_eq_i64(
    actual: sum_to(n: 100),
    expected: 5050,
    label: "recursive local closure tail-style sum 1..100 = 5050"
  )
  return ()
end
