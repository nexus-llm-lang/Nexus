/**
 * Regression test: generic HOF instantiated at T=f64 must not trap with
 * `wasm trap: indirect call type mismatch`.
 *
 * Pre-fix root cause: coerce_to_closure_slot (lambda_lift.nx) left TyF64 /
 * TyF32 unchanged, so a closure-wrap function for a `(f64,f64)->f64`
 * target was declared with wasm sig `(i64 f64 f64) -> f64`. The call_indirect
 * at the HOF site uses the canonical closure-call type `(i64 i64 i64) -> i64`,
 * so the signatures disagreed and the wasm trapped at runtime. The same shape
 * at T=i64 worked because i64 already matches the canonical slot.
 *
 * Sibling sub-case: inline (anonymous) lambda with f64 params — after
 * coercion the body's `+.` operator must still emit `f64.add` and
 * bit-reinterpret the i64-erased operands. binary_operand_type was
 * updated to default to TyF64 for float-tagged ops when both operands
 * lower to i64 (the canonical closure-call slot).
 *
 * Expected: both `f64-top ok` and `f64-inline ok` print; no validation
 * error, no runtime trap.
 */
import { Console } from "std:stdio"
import * as stdio from "std:stdio"

let apply2 = fn <T>(x: T, y: T, f: (a: T, b: T) -> T) -> T do
  return f(a: x, b: y)
end

let fadd = fn (a: f64, b: f64) -> f64 do
  return a +. b
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let r1 = apply2(x: 1.5, y: 2.5, f: fadd)
    Console.println(val: "f64-top ok")
    let r2 = apply2(x: 4.0, y: 5.0, f: fn (a: f64, b: f64) -> f64 do return a +. b end)
    Console.println(val: "f64-inline ok")
    let r3 = apply2(x: 10, y: 20, f: fn (a: i64, b: i64) -> i64 do return a + b end)
    Console.println(val: "i64-control ok")
  end
end
