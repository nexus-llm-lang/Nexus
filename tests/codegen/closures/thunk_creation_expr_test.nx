/**
 * Regression test: the `@(expr)` thunk-creation expression.
 *
 * Per the lazy spec, `@(expr)` suspends `expr` and yields a `@T` thunk;
 * forcing it runs the body and produces the value. Pre-fix the parser had no
 * `@(expr)` production: `@(40 + 2)` was mis-parsed as `force (40 + 2)`, which
 * the typechecker rejected ("force: expected lazy type '@T', got non-lazy
 * value"). `@<ident>` stays a force; only `@(` opens a thunk.
 *
 * Expected: the thunk forces to 42 and the program exits cleanly.
 */
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let t: @i64 = @(40 + 2)
  let v = @t
  test_assert.assert_eq_i64(actual: v, expected: 42, label: "thunk-creation @(expr) forces to value")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
