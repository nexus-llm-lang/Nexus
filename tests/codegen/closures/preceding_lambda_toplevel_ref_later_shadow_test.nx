/**
 * nexus-grbmk regression test (qbxqe over-rejection): a lambda that references
 * a TOP-LEVEL fn `g` must keep targeting that top-level binding even when an
 * UNRELATED later `let g` shadow sits in the SAME flat block, AFTER the lambda.
 *
 * Root cause (pre-fix): src/ir/hir/convert/core.nx convert_stmts_go converted a
 * lambda RHS's body with `rename_drop_many(entries, n :: collect_block_let_names
 * (rest))`. collect_block_let_names walked the ENTIRE later flat block and
 * collected every block-level `let` name, so a later `let g` was dropped from a
 * preceding lambda's rename entries — suppressing the top-level canonical rename
 * for `g` and leaving a bare `g` that name resolution reported unbound (E2001).
 *
 * Fix: the drop is narrowed to genuine forward MUTUAL-recursion partners
 * (collect_mutual_sibling_names): a later `let m = fn ...` is dropped only when
 * the preceding lambda refers to `m` AND `m`'s body refers back to the lambda's
 * own name. An unrelated later `let g` does not refer back, so it is no longer
 * dropped and the preceding lambda's `g` keeps resolving to the top-level.
 *
 * The companion negative test
 * tests/negative/typecheck/mutual_recursive_local_let_shadow.nx asserts the
 * qbxqe forward-mutual-recursion routing is preserved (still E2001).
 *
 * Expected: all asserts pass, exit 0.
 */
import * as test_assert from "std:test/assert"

// Top-level g/h that a preceding lambda references; identity-ish helpers.
let g = fn (n: i64) -> i64 do return n + 1 end
let h = fn (n: i64) -> i64 do return n + 2 end

// (a) `useG` references the TOP-LEVEL g (adds 1); a LATER unrelated `let g`
// (adds 1000) sits in the same flat block. useG(5) must be g(5)=6 via the
// top-level, NOT routed to the later local g. The later local g(5)=1005.
// Sum = 6 + 1005 = 1011.
let f = fn () -> i64 do
  let useG = fn (n: i64) -> i64 do return g(n: n) end
  let g = fn (n: i64) -> i64 do return n + 1000 end
  return useG(n: 5) + g(n: 5)
end

// (b) two preceding lambdas reference two top-level fns g/h that are BOTH later
// shadowed by unrelated same-named locals. Each preceding reference must keep
// its top-level target. useG(5)=g(5)=6, useH(5)=h(5)=7; later locals g(0)=1000,
// h(0)=2000. Sum = 6 + 7 + 1000 + 2000 = 3013.
let f2 = fn () -> i64 do
  let useG = fn (n: i64) -> i64 do return g(n: n) end
  let useH = fn (n: i64) -> i64 do return h(n: n) end
  let g = fn (n: i64) -> i64 do return n + 1000 end
  let h = fn (n: i64) -> i64 do return n + 2000 end
  return useG(n: 5) + useH(n: 5) + g(n: 0) + h(n: 0)
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: f(),
    expected: 1011,
    label: "preceding lambda's `g` routes to TOP-LEVEL (g(5)=6) despite later same-block `let g`"
  )
  test_assert.assert_eq_i64(
    actual: f2(),
    expected: 3013,
    label: "two preceding lambdas keep top-level g/h targets despite later same-named shadows"
  )
  // Top-level g/h still directly reachable (identity+1 / identity+2).
  test_assert.assert_eq_i64(actual: g(n: 10), expected: 11, label: "top-level g still reachable")
  test_assert.assert_eq_i64(actual: h(n: 10), expected: 12, label: "top-level h still reachable")
  return ()
end
