/**
 * Regression test: forcing a `@(throw e)` thunk built by the `@(expr)`
 * thunk-creation expression.
 *
 * Pre-fix `@(throw e)` was mis-parsed as `force (throw e)`, lowering to
 * `Force(Raise(e))` — a dead `force` emitted after the non-returning `throw`,
 * which left the wasm value stack imbalanced ("values remaining on stack at
 * end of block") and `wasm-tools validate` rejected the module. With the
 * `@(expr)` production the body is a proper thunk closure whose body is the
 * throw, so forcing runs it and the throw surfaces at the force site.
 *
 * `run` forces the throwing thunk; the throw propagates out and `attempt`
 * catches it, returning 99. If the force were skipped or the throw swallowed,
 * `attempt` would return 0 and `1 / r` would trap with integer divide-by-zero.
 *
 * Expected: throw surfaces, caught, r == 99, program exits cleanly.
 */
let run = fn () -> i64 throws { Exn } do
  let t: @unit = @(throw RuntimeError(val: "boom"))
  @t
  return 0
end

let attempt = fn () -> i64 do
  try run() return 0 catch _ -> return 99 end
end

let main = fn () -> unit do
  let r = attempt()
  1 / r
  return ()
end
