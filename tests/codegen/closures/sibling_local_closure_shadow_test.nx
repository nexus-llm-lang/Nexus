/**
 * nexus-qbxqe regression test (ssbiy sibling): a SIBLING reference between
 * inner-let lambdas must resolve to the LOCAL block binding, not a same-named
 * top-level function.
 *
 * Root cause (pre-fix): src/ir/hir/convert/core.nx convert_stmts_go dropped
 * only the self-name `n` from a lambda RHS's rename entries (the ssbiy
 * self-recursion fix). A reference to a SIBLING local-let lambda whose name
 * collided with a top-level fn was still renamed to the top-level canonical
 * (`…#g`) and routed to the OUTER binding — a silent miscompile.
 *
 * Fix: drop EVERY block-level sibling let name from a lambda RHS's rename
 * entries so sibling references resolve to the local bindings (captured /
 * locally dispatched), shadowing the top-level fns.
 *
 * These cases use BACKWARD sibling references (the named sibling is declared
 * earlier in the block), which resolve at value level and run. Forward mutual
 * recursion of local lets is reported E2001 (it has no forward-cell support;
 * see tests/negative/typecheck/mutual_recursive_local_let_shadow.nx) — the
 * point of THAT companion test is the shadow case must not silently
 * miscompile.
 *
 * Expected: all asserts pass, exit 0.
 */
import * as test_assert from "std:test/assert"

// Top-level g/h that the inner siblings shadow (identity).
let g = fn (n: i64) -> i64 do return n end
let h = fn (n: i64) -> i64 do return n end

// (a) inner `caller` references sibling `g` declared earlier in the same
// block; that `g` adds 1000, so caller(5) = 1005, NOT top-level g(5) = 5.
let f = fn () -> i64 do
  let g = fn (n: i64) -> i64 do return n + 1000 end
  let caller = fn (n: i64) -> i64 do return g(n: n) end
  return caller(n: 5)
end

// (b) two sibling locals h/g chained: local h doubles, local g calls local h
// then adds 1. g(4) = h(4)*2-path → 8, +1 = 9. Top-level h/g (identity) would
// give 4. Proves BOTH sibling names route local, not top-level.
let f2 = fn () -> i64 do
  let h = fn (n: i64) -> i64 do return n * 2 end
  let g = fn (n: i64) -> i64 do return h(n: n) + 1 end
  return g(n: 4)
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: f(),
    expected: 1005,
    label: "inner caller routes sibling `g` to LOCAL (+1000), not top-level identity"
  )
  test_assert.assert_eq_i64(
    actual: f2(),
    expected: 9,
    label: "chained sibling locals h/g both route LOCAL, not top-level identity"
  )
  // top-level g/h still reachable by direct call (identity), proving the
  // shadow is scoped to f/f2 bodies.
  test_assert.assert_eq_i64(
    actual: g(n: 42),
    expected: 42,
    label: "top-level g still reachable by direct call (identity 42)"
  )
  return ()
end
