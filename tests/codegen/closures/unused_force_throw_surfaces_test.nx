/**
 * Regression test (nexus-of5l5): a bare force `@t` whose result is discarded
 * must NOT be eliminated by LIR DCE.
 *
 * Forcing runs the thunk body, which may throw / be effectful, and is a
 * mandatory one-shot on a linear value. Pre-fix, `opt_is_pure` classified
 * `LirExprForce` as pure, so DCE dropped the `LirStmtLet(temp, Force(..))`
 * lowering of an unused bare force — silently swallowing the thunk's
 * exception and skipping the force.
 *
 * Here `boom()` builds a thunk whose body throws. `run` forces it and discards
 * the result, so the throw must surface at the force site and propagate out of
 * `run`; `attempt` catches it and returns 99. If the force is dropped, `run`
 * falls through to `return 0`, `attempt` returns 0, and `1 / r` traps with
 * integer divide-by-zero.
 *
 * Expected: throw surfaces, caught, r == 99, program exits cleanly (no trap).
 */
let boom = fn () -> i64 throws { Exn } do
  throw RuntimeError(val: "forced!")
end

let run = fn () -> i64 throws { Exn } do
  let @t = boom()
  @t
  return 0
end

let attempt = fn () -> i64 do
  try run() return 0 catch _ -> return 99 end
end

let main = fn () -> unit do
  let r = attempt()
  1 / r
  return ()
end
