/**
 * nexus-ssbiy regression test (d33l7 sibling): a recursive inner-let lambda
 * whose name SHADOWS a same-named top-level binding must self-call ITSELF
 * (the inner shadow), not the OUTER top-level function.
 *
 * Root cause (pre-fix): src/ir/mir/lambda_lift.nx::build_known_names populated
 * `known` with every top-level fn name; collect_hir_free_vars filters known
 * names out of raw_captures, so an inner-let lambda whose self-name collided
 * with a top-level fn had its self-reference filtered → is_recursive_self was
 * false → no `let <self> = __env` rebind → the Call lowered as a DIRECT
 * MirCall to the top-level fn (lookup_known_ret_type found it) → self-call
 * routed to the OUTER binding. f() returned 4 (outer g(5-1)) not 100.
 *
 * Fix (src/ir/mir/mir.nx lift_lambda_self): remove self_name from `known`
 * before the free-var walk so a body self-ref surfaces in raw_captures and
 * is_recursive_self fires even under shadowing; register self_name in
 * value_binding_names for body lowering so its call lowers to a closure-call
 * against the __env rebind (MirCallClosure), shadowing the top-level fn.
 *
 * Expected: all asserts pass, exit 0.
 */
import * as test_assert from "std:test/assert"

// Top-level binding that the inner `g` shadows.
let g = fn (n: i64) -> i64 do return n end

// (a) shadow-recursion: inner g recurses 5→…→0→100 (NOT outer g(4)=4).
let f = fn () -> i64 do
  let g = fn (n: i64) -> i64 do
    if n <= 0 then return 100 end
    return g(n: n - 1)
  end
  return g(n: 5)
end

// (b) inner recursion AND an explicit outer-g call coexist: inner h shadows
// the top-level h and recurses to 0→7; a later DIRECT top-level h(n:42) still
// reaches the outer identity fn (42), proving the shadow is scoped to f2's body.
let h = fn (n: i64) -> i64 do return n end

let f2 = fn () -> i64 do
  let h = fn (n: i64) -> i64 do
    if n <= 0 then return 7 end
    return h(n: n - 1)
  end
  return h(n: 3)
end

// (c) guard — d33l7's NON-shadowing recursive local closure still works:
// no top-level `go`, inner go recurses to 0→0 + 1 per level.
let count_down = fn (n: i64) -> i64 do
  let go = fn (i: i64) -> i64 do
    if i <= 0 then return 0 end
    return 1 + go(i: i - 1)
  end
  return go(i: n)
end

let main = fn () -> unit throws { Exn } do
  // (a) inner shadow recurses to base 100, NOT outer g (would be 4)
  test_assert.assert_eq_i64(
    actual: f(),
    expected: 100,
    label: "inner recursive g shadows top-level g (recurses to 100, not outer 4)"
  )
  // (b) inner shadow recurses to 7; outer h reachable by direct call = 42
  test_assert.assert_eq_i64(
    actual: f2(),
    expected: 7,
    label: "inner recursive h shadows top-level h (recurses to 7)"
  )
  test_assert.assert_eq_i64(
    actual: h(n: 42),
    expected: 42,
    label: "outer top-level h still reachable by direct call (identity 42)"
  )
  // (c) non-shadowing recursive local closure (d33l7) unchanged
  test_assert.assert_eq_i64(
    actual: count_down(n: 100),
    expected: 100,
    label: "d33l7 non-shadow recursive local closure depth 100"
  )
  return ()
end
