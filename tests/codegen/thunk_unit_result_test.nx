/**
 * Regression test: @unit thunk codegen soundness.
 *
 * A thunk whose forced result type is `unit` must produce a well-formed wasm
 * function.  The closure-lifted body must push an i64 placeholder before `end`
 * to satisfy the canonical (env:i64)->i64 closure ABI.  Pre-fix,
 * `emit_return_value` saw `rt=TyI64` (widened by is_closure_lift) but the
 * return atom was `LirAtomVar(_,TyUnit)`: `emit_atom_var` silently no-op'd,
 * leaving zero values on the stack so wasm-tools validate rejected the module.
 *
 * Expected: program exits cleanly (no wasm trap, no validate error).
 */
let noop = fn () -> unit do
  return ()
end

let safe_run = fn () -> i64 do
  let @t = noop()
  @t
  return 1
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
