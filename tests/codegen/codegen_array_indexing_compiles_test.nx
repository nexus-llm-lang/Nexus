// Regression for nexus-90e5: `arr[idx]` lowered to LirExprCall("__array_get",
// ...) but standalone codegen never registered the symbol, so any program
// that indexed an array literal ICE'd with E2007 ("call target '__array_get'
// not found in lowered symbols") at `./nexus build`. The fix inlines
// __array_get in src/backend/codegen.nx (emit_array_get) so the call
// dispatches to a `(ptr + (idx + 1) * 8) -> i64.load` sequence directly.
//
// Each index is read from a fresh array literal because owned arrays are
// linear: consuming `a` once via `a[0]` would prevent a second `a[1]` read
// in the same scope. Borrow-and-index (`let r = &a; r[0]`) would skip that
// linear consumption but the self-host typechecker has not yet wired
// TyBorrow->TyArray auto-deref through `infer_index`, so a borrow-form
// fixture would not reach codegen here anyway.
//
// Validation uses `match` rather than `if e then 1 else 0 end`: the
// self-host typechecker currently mis-defaults the integer literal arms
// of the latter, surfacing as `let _: int op rhs: type mismatch` at the
// `1 / denom` line — orthogonal to this fix; tracked separately.
//
// Mismatched element values trap via `1 / denom`; success runs cleanly.

let main = fn () -> unit do
  let v0 = [| 10, 20, 30 |][0]
  let v1 = [| 10, 20, 30 |][1]
  let v2 = [| 10, 20, 30 |][2]
  let d0 = match v0 == 10 do | true -> 1 | false -> 0 end
  let d1 = match v1 == 20 do | true -> 1 | false -> 0 end
  let d2 = match v2 == 30 do | true -> 1 | false -> 0 end
  let _ = 1 / d0
  let _ = 1 / d1
  let _ = 1 / d2
  return ()
end
