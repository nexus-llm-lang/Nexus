import * as test_assert from "std:test/assert"

let direct_field = fn () -> i64 do
  let mk = fn () -> { a: i64, b: i64 } do return { a: 1, b: 2 } end
  let w = mk()
  return w.a + w.b * 10
end

let match_bind = fn () -> i64 do
  let mk = fn () -> { a: i64, b: i64 } do return { a: 3, b: 4 } end
  let w = mk()
  return match w do | { a, b } -> a + b * 10 end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: direct_field(),
    expected: 21,
    label: "local-closure-ret pin1: .field off closure record result (1 + 2*10)"
  )
  test_assert.assert_eq_i64(
    actual: match_bind(),
    expected: 43,
    label: "local-closure-ret pin2: record match-bind off closure result (3 + 4*10)"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
