// nexus-byiw.3: targeted coverage for the SIMD lane-binop intrinsic
// category in src/backend/codegen/intrinsics.nx. `simd_i32x4_add` is a
// `nexus:intrinsic` external from std:simd:
//   i32x4_add(a_addr: i64, b_addr: i64, dst_addr: i64) -> unit
// It lowers to the v128.load → i32x4.add → v128.store sequence
// (kebab key `simd-i32x4-add`).
//
// Strategy: pack two source quads `a = [1, 2, 3, 4]` and `b = [10, 20,
// 30, 40]` into 16-byte regions, call the SIMD add to write the result
// quad to `dst`, then verify each lane via `mem.load_i32`. Distinct
// per-lane sums catch any miscompile that misaddresses the lanes (e.g.
// wrong stride between loads, or a swapped op-code emitting subtract
// instead of add).
//
// Alignment: `alloc_raw` returns 8-byte-aligned pointers. v128.load /
// store accept any alignment per the SIMD spec, with align=4 in the
// emitted code; mis-aligned access is well-defined just possibly
// slower. We bump each base to a 16-byte boundary explicitly so the
// fast path is exercised.
import * as test_assert from "std:test/assert"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"
import * as simd from "std:simd"

let align16 = fn (p: i64) -> i64 do
  let r = p % 16
  if r == 0 then return p end
  return p + (16 - r)
end

let body = fn () -> unit throws { Exn } do
  // Three 16-byte regions, each 16-byte aligned. alloc 48 bytes each so
  // there is always room to slide forward to the next 16-byte boundary.
  let pa = align16(p: arena.alloc_raw(size: 48))
  let pb = align16(p: arena.alloc_raw(size: 48))
  let pd = align16(p: arena.alloc_raw(size: 48))

  // Pack `a = [1, 2, 3, 4]`.
  let _ = mem.store_i32(addr: pa,     val: 1)
  let _ = mem.store_i32(addr: pa + 4, val: 2)
  let _ = mem.store_i32(addr: pa + 8, val: 3)
  let _ = mem.store_i32(addr: pa + 12, val: 4)

  // Pack `b = [10, 20, 30, 40]`.
  let _ = mem.store_i32(addr: pb,     val: 10)
  let _ = mem.store_i32(addr: pb + 4, val: 20)
  let _ = mem.store_i32(addr: pb + 8, val: 30)
  let _ = mem.store_i32(addr: pb + 12, val: 40)

  // SIMD lane-wise add. Expected `dst = [11, 22, 33, 44]`.
  simd.i32x4_add(a_addr: pa, b_addr: pb, dst_addr: pd)

  test_assert.assert_eq_i64(actual: mem.load_i32(addr: pd),      expected: 11, label: "simd-i32x4-add lane 0: 1 + 10 == 11")
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: pd + 4),  expected: 22, label: "simd-i32x4-add lane 1: 2 + 20 == 22")
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: pd + 8),  expected: 33, label: "simd-i32x4-add lane 2: 3 + 30 == 33")
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: pd + 12), expected: 44, label: "simd-i32x4-add lane 3: 4 + 40 == 44")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
