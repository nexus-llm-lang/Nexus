// Port of bootstrap/tests/codegen/errors.rs:
//   codegen_exn_constructor_lowering.
// Original test asserts a `raise RuntimeError(val: ...)` compiles and
// traps; here we verify the same lowering surfaces a catchable
// RuntimeError carrying the labeled `val` payload.
import * as test_assert from "std:test/assert"

let trigger = fn () -> i64 throws { Exn } do
  raise RuntimeError(val: "test error")
  return 0
end

let attempt = fn () -> string throws { Exn } do
  try
    let _ = trigger()
    return ""
  catch
    | RuntimeError(val: v) -> return v
    | _ -> return "wrong-exception"
  end
  return ""
end

let body = fn () -> unit throws { Exn } do
  let observed = attempt()
  test_assert.assert_eq_string(actual: observed, expected: "test error", label: "RuntimeError val payload survives raise")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
