/**
 * Runtime regression test: implicit force-call `f(args)` on a thunk-typed
 * callee must produce a correct value (no wasm `indirect call type mismatch`
 * trap). Validates the MIR-layer fix that inserts MirForce on the callee
 * when the callee is in the thunk_param_names set (nexus-lq3ma codegen fix).
 *
 * Before the fix, `f(x: 1)` where `f : @((x: i64) -> i64)` lowered as
 * MirCallClosure(closure: MirVariable("f"), ...) — calling the thunk value
 * directly as if it were a closure, causing a wasm trap at runtime.
 *
 * After the fix, the thunk is forced first (via MirForce), yielding the
 * closure, which is then called correctly.
 */
import * as test_assert from "std:test/assert"

let apply_thunk_fn = fn (f: @((x: i64) -> i64), n: i64) -> i64 do
  return f(x: n)
end

let main = fn () -> unit throws { Exn } do
  let @t = fn (x: i64) -> i64 do return x * 2 end
  let r1 = apply_thunk_fn(f: t, n: 7)
  test_assert.assert_eq_i64(
    actual: r1,
    expected: 14,
    label: "implicit force-call thunk param: (*2)(7)=14"
  )
  let @t2 = fn (x: i64) -> i64 do return x + 100 end
  let r2 = apply_thunk_fn(f: t2, n: 5)
  test_assert.assert_eq_i64(
    actual: r2,
    expected: 105,
    label: "implicit force-call thunk param: (+100)(5)=105"
  )
  return ()
end
