import * as test_assert from "std:test/assert"

type R = { b: i64, a: i64 }
exception Boom

let nested_if_all_throw = fn (c: bool, d: bool) -> i64 throws { Boom } do
  let r = if c then
    if d then throw Boom else throw Boom end
  else
    { b: 2, a: 200 }
  end
  return r.a
end

let nested_match_all_throw = fn (c: bool, d: i64) -> i64 throws { Boom } do
  let r = if c then
    match d do | 0 -> throw Boom | _ -> return 5 end
  else
    { b: 2, a: 201 }
  end
  return r.a
end

let nested_if_all_return = fn (c: bool, d: bool) -> i64 throws { Boom } do
  let r = if c then
    if d then return 7 else return 9 end
  else
    { b: 2, a: 202 }
  end
  return r.a
end

let nested_with_leading_stmt = fn (c: bool, d: bool) -> i64 throws { Boom } do
  let r = if c then
    let z = d
    if z then throw Boom else throw Boom end
  else
    { b: 2, a: 203 }
  end
  return r.a
end

let inner_else_produces_record = fn (c: bool, d: bool) -> i64 throws { Boom } do
  let r = if c then
    if d then throw Boom else { b: 9, a: 300 } end
  else
    { b: 2, a: 204 }
  end
  return r.a
end

let body = fn () -> unit throws { Exn, Boom } do
  test_assert.assert_eq_i64(
    actual: nested_if_all_throw(c: false, d: false),
    expected: 200,
    label: "nested-diverge pin1: first arm diverges via nested if (all throw), project .a"
  )
  test_assert.assert_eq_i64(
    actual: nested_match_all_throw(c: false, d: 0),
    expected: 201,
    label: "nested-diverge pin2: first arm diverges via nested match (all throw), project .a"
  )
  test_assert.assert_eq_i64(
    actual: nested_if_all_return(c: false, d: false),
    expected: 202,
    label: "nested-diverge pin3: first arm diverges via nested if (all return), project .a"
  )
  test_assert.assert_eq_i64(
    actual: nested_with_leading_stmt(c: false, d: false),
    expected: 203,
    label: "nested-diverge pin4: diverging nested if preceded by a statement, project .a"
  )
  test_assert.assert_eq_i64(
    actual: inner_else_produces_record(c: true, d: false),
    expected: 300,
    label: "nested-diverge pin5: inner else produces a record, project .a through both arms"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
