import * as test_assert from "std:test/assert"

let apply_f32 = fn (g: (y: f32) -> bool, x: f32) -> bool do
  return g(y: x)
end

let apply_mixed = fn (g: (a: i64, b: f32) -> bool, x: f32) -> bool do
  return g(a: 7, b: x)
end

let body = fn () -> unit throws { Exn } do
  let cmp = fn (y: f32) -> bool do return y ==. 2.5 end

  let hit = apply_f32(g: cmp, x: 2.5)
  test_assert.assert_eq_bool(
    actual: hit,
    expected: true,
    label: "f32 indirect: g(2.5) == 2.5 is true"
  )

  let miss = apply_f32(g: cmp, x: 1.25)
  test_assert.assert_eq_bool(
    actual: miss,
    expected: false,
    label: "f32 indirect: g(1.25) == 2.5 is false"
  )

  let cmp_mixed = fn (a: i64, b: f32) -> bool do
    return a == 7 && b ==. 2.5
  end
  let mixed_hit = apply_mixed(g: cmp_mixed, x: 2.5)
  test_assert.assert_eq_bool(
    actual: mixed_hit,
    expected: true,
    label: "mixed indirect: g(7, 2.5) is true"
  )

  let mixed_miss = apply_mixed(g: cmp_mixed, x: 9.0)
  test_assert.assert_eq_bool(
    actual: mixed_miss,
    expected: false,
    label: "mixed indirect: g(7, 9.0) is false"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
