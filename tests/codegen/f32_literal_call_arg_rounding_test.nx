import * as test_assert from "std:test/assert"

/** `16777217.0` is `2^24 + 1`, the first integer not exactly representable in
 *  f32; its nearest f32 value is `16777216.0`. Passing the literal across an
 *  erased-i64 boundary (a generic type-variable parameter, or a
 *  function-typed/closure parameter) must observe it at f32 width — i.e. round
 *  to `16777216.0` — not leak the un-rounded f64. */

let id = fn <T>(x: T) -> T do return x end

let apply = fn (g: (y: f32) -> bool, x: f32) -> bool do
  return g(y: x)
end

let body = fn () -> unit throws { Exn } do
  let via_generic: f32 = id(x: 16777217.0)
  test_assert.assert_true(
    cond: via_generic ==. 16777216.0,
    label: "f32 literal through a generic type-var param rounds to f32 width"
  )

  let cmp = fn (y: f32) -> bool do return y ==. 16777216.0 end
  let via_fn_param = apply(g: cmp, x: 16777217.0)
  test_assert.assert_true(
    cond: via_fn_param,
    label: "f32 literal through a function-typed param rounds to f32 width"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
