// nexus-byiw.3: targeted coverage for the integer-width-cast intrinsic
// category in src/backend/codegen/intrinsics.nx. `cast_to_i32` /
// `cast_to_i64` are `nexus:intrinsic` externals in std:runtime/cast that
// bridge Nexus's i64-domain values with raw i32 FFI args:
//   cast.i32_of(x: i64) -> i32  →  i32.wrap_i64       (kebab: cast-to-i32)
//   cast.i64_of(x: i32) -> i64  →  i64.extend_i32_u   (kebab: cast-to-i64)
//
// `i64_of` is zero-extending — values it receives from WASI (errno
// codes, byte counts, file descriptors) are non-negative. The wrap is
// the inverse only on the low 32 bits; the high 32 bits of the input
// are dropped. The round-trip semantics: for any i64 x with x < 2^32,
// `i64_of(i32_of(x)) == x`. For x >= 2^32, the high bits are truncated
// — the test pins both cases.
//
// A wrong dispatch arm (e.g. emitting i64.extend_i32_S instead of _U)
// would change the round-trip of 0xFFFFFFFF (= 4294967295) from
// 4294967295 (zero-extended) to -1 (sign-extended).
import * as test_assert from "std:test/assert"
import * as cast from "std:runtime/cast"

let body = fn () -> unit throws { Exn } do
  // Small positive: low 32 bits == full value, round-trip identity.
  let r1 = cast.i64_of(x: cast.i32_of(x: 42))
  test_assert.assert_eq_i64(actual: r1, expected: 42, label: "cast i64 → i32 → i64 round-trip for 42")

  // Maximum positive that fits in u32: 2^32 - 1 = 4294967295.
  // Zero-extension here is the key invariant — a sign-extension miscompile
  // would surface as -1 instead.
  let r2 = cast.i64_of(x: cast.i32_of(x: 4294967295))
  test_assert.assert_eq_i64(actual: r2, expected: 4294967295, label: "cast 0xFFFFFFFF round-trip is zero-extended (not -1)")

  // High bits dropped: 0x1_00000000 == 2^32. After wrap to i32 the low
  // 32 bits are all zero; the round-trip surfaces 0.
  let r3 = cast.i64_of(x: cast.i32_of(x: 4294967296))
  test_assert.assert_eq_i64(actual: r3, expected: 0, label: "cast 2^32 → i32 wraps to 0 (high bits dropped)")

  // 0x1_00000001 wraps to 1.
  let r4 = cast.i64_of(x: cast.i32_of(x: 4294967297))
  test_assert.assert_eq_i64(actual: r4, expected: 1, label: "cast 2^32+1 → i32 wraps to 1")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
