// Regression test for SIMD array temp-slot aliasing bug.
//
// `emit_simd_binop_array` previously used temps_base+0/+2/+3/+6 for its
// loop locals (counter, a_ptr, b_ptr, d_ptr).  Those offsets overlap with
// general-purpose scratch temps used by other intrinsic emitters in the
// same function body:
//
//   +0  — packed_tmp  (call.nx string/array external arg)
//   +2  — atomic_bump scratch  (atom.nx emit_atomic_bump)
//   +3  — obj_ptr     (atom.nx emit_alloc_object / heap.nx / codegen.nx)
//   +6  — retptr      (call.nx sret-style external returns)
//
// This test forces a function that (a) allocates heap objects — triggering
// emit_alloc_object and emit_atomic_bump, touching +2 and +3 — and then
// (b) calls a SIMD array intrinsic.  With the old offsets the loop pointer
// locals alias the allocation scratch and the result is silently wrong
// (typically the loop counter or pointer is zeroed mid-loop).
//
// The fixed code uses +1/+9/+10/+11 which are otherwise unused.
import * as test_assert from "std:test/assert"
import * as mem from "std:runtime/mem"
import * as arena from "std:runtime/arena"
import * as simd from "std:simd"

let align16 = fn (p: i64) -> i64 do
  let r = p % 16
  if r == 0 then return p end
  return p + (16 - r)
end

let body = fn () -> unit throws { Exn } do
  // Allocate via arena — forces emit_alloc_object (obj_ptr = temps_base+3)
  // and emit_atomic_bump (scratch = temps_base+2) to fire in this function.
  let pa_raw = arena.alloc_raw(size: 80)
  let pb_raw = arena.alloc_raw(size: 80)
  let pd_raw = arena.alloc_raw(size: 80)

  let pa = align16(p: pa_raw)
  let pb = align16(p: pb_raw)
  let pd = align16(p: pd_raw)

  // Pack a = [10, 20, 30, 40, 50, 60, 70, 80] (two i32x4 quads)
  mem.store_i32(addr: pa,      val: 10)
  mem.store_i32(addr: pa + 4,  val: 20)
  mem.store_i32(addr: pa + 8,  val: 30)
  mem.store_i32(addr: pa + 12, val: 40)
  mem.store_i32(addr: pa + 16, val: 50)
  mem.store_i32(addr: pa + 20, val: 60)
  mem.store_i32(addr: pa + 24, val: 70)
  mem.store_i32(addr: pa + 28, val: 80)

  // Pack b = [1, 2, 3, 4, 5, 6, 7, 8]
  mem.store_i32(addr: pb,      val: 1)
  mem.store_i32(addr: pb + 4,  val: 2)
  mem.store_i32(addr: pb + 8,  val: 3)
  mem.store_i32(addr: pb + 12, val: 4)
  mem.store_i32(addr: pb + 16, val: 5)
  mem.store_i32(addr: pb + 20, val: 6)
  mem.store_i32(addr: pb + 24, val: 7)
  mem.store_i32(addr: pb + 28, val: 8)

  // SIMD array add over 2 quads (8 lanes).
  // Expected dst = [11, 22, 33, 44, 55, 66, 77, 88].
  simd.i32x4_add_array(a_addr: pa, b_addr: pb, dst_addr: pd, n_quads: 2)

  let d0 = mem.load_i32(addr: pd)
  let d1 = mem.load_i32(addr: pd + 4)
  let d2 = mem.load_i32(addr: pd + 8)
  let d3 = mem.load_i32(addr: pd + 12)
  let d4 = mem.load_i32(addr: pd + 16)
  let d5 = mem.load_i32(addr: pd + 20)
  let d6 = mem.load_i32(addr: pd + 24)
  let d7 = mem.load_i32(addr: pd + 28)

  test_assert.assert_eq_i64(
    actual: d0,
    expected: 11,
    label: "simd-array-alias quad0 lane0: 10+1=11"
  )
  test_assert.assert_eq_i64(
    actual: d1,
    expected: 22,
    label: "simd-array-alias quad0 lane1: 20+2=22"
  )
  test_assert.assert_eq_i64(
    actual: d2,
    expected: 33,
    label: "simd-array-alias quad0 lane2: 30+3=33"
  )
  test_assert.assert_eq_i64(
    actual: d3,
    expected: 44,
    label: "simd-array-alias quad0 lane3: 40+4=44"
  )
  test_assert.assert_eq_i64(
    actual: d4,
    expected: 55,
    label: "simd-array-alias quad1 lane0: 50+5=55"
  )
  test_assert.assert_eq_i64(
    actual: d5,
    expected: 66,
    label: "simd-array-alias quad1 lane1: 60+6=66"
  )
  test_assert.assert_eq_i64(
    actual: d6,
    expected: 77,
    label: "simd-array-alias quad1 lane2: 70+7=77"
  )
  test_assert.assert_eq_i64(
    actual: d7,
    expected: 88,
    label: "simd-array-alias quad1 lane3: 80+8=88"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
