// nexus-byiw.3: targeted coverage for the Memory intrinsic category in
// src/backend/codegen/intrinsics.nx, exercising both the raw load/store
// arms (mem-load-i32 / mem-store-i32 / mem-load-i64 / mem-store-i64 /
// mem-load-u8 / mem-store-u8 / mem-size) declared in std:runtime/mem
// and the bump-allocator arms (heap-mark / heap-reset / alloc-raw)
// declared in std:runtime/arena. Both groups share the unified atomic
// bump cell `wdefs.heap_ptr_cell` and lower inline (no host call) under
// the `nexus:intrinsic` namespace.
//
// Memory cell at `heap_ptr_cell` is lazily seeded to
// `memory.size()*65536` on the first allocation (not data-segment
// initialised — see comment in src/backend/wasm/defs.nx). The test
// forces seeding with an alloc_raw before reading heap_mark so the
// post-seed baseline is well-defined.
//
// What each assertion pins:
//
//   - mem store/load round-trip catches dispatch mis-wiring (wrong arm,
//     wrong width). 0x123456789ABCDEF0 == 1311768467463790320 surfaces
//     any accidental i32-truncation.
//   - mem-load-u8 must zero-extend (not sign-extend) — 0x7E should come
//     back as 126, not -2.
//   - mem-size must return > 0 (the linear memory is already non-empty).
//   - heap-mark / alloc-raw / heap-reset: see the per-assert labels.
//     The mark/reset/realloc loop catches any swap of the load/store
//     wiring in `emit_heap_reset` and `emit_alloc_raw`.
import * as test_assert from "std:test/assert"
import * as mem from "std:runtime/mem"
import { heap_mark, heap_reset, alloc_raw } from "std:runtime/arena"

let body = fn () -> unit throws { Exn } do
  // ─── mem-store-i32 / mem-load-i32 round-trip ─────────────────────────
  let p32 = alloc_raw(size: 8)
  mem.store_i32(addr: p32, val: 305419896)  // 0x12345678
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: p32), expected: 305419896,
    label: "mem-store-i32 / mem-load-i32 round-trip")

  // ─── mem-store-i64 / mem-load-i64 round-trip (full 64 bits) ───────────
  // Value chosen so any accidental i32-truncation would change the result.
  let p64 = alloc_raw(size: 8)
  mem.store_i64(addr: p64, val: 1311768467463790320)  // 0x123456789ABCDEF0
  test_assert.assert_eq_i64(actual: mem.load_i64(addr: p64), expected: 1311768467463790320,
    label: "mem-store-i64 / mem-load-i64 round-trip (full 64 bits)")

  // ─── mem-store-u8 / mem-load-u8: zero-extension on load ───────────────
  let pu8 = alloc_raw(size: 8)
  mem.store_u8(addr: pu8, val: 126)  // 0x7E
  test_assert.assert_eq_i64(actual: mem.load_u8(addr: pu8), expected: 126,
    label: "mem-store-u8 / mem-load-u8 round-trip (zero-extended)")

  // ─── mem-size: non-trivial lower bound ───────────────────────────────
  test_assert.assert_true(cond: mem.size() > 0, label: "mem-size returns > 0 pages")

  // ─── heap-mark / heap-reset / alloc-raw: bump-allocator contract ──────
  // Force lazy seeding first; without it heap_mark() returns 0.
  let _seed = alloc_raw(size: 8)
  let mark0 = heap_mark()
  test_assert.assert_true(cond: mark0 > 0, label: "heap-mark after lazy seed > 0")

  let _p1 = alloc_raw(size: 64)
  let mark1 = heap_mark()
  test_assert.assert_eq_i64(actual: mark1 - mark0, expected: 64,
    label: "heap-mark advance == 64 after alloc-raw(64)")

  heap_reset(mark: mark0)
  test_assert.assert_eq_i64(actual: heap_mark(), expected: mark0,
    label: "heap-reset restores the bump pointer exactly")

  let _p2 = alloc_raw(size: 8)
  test_assert.assert_eq_i64(actual: heap_mark() - mark0, expected: 8,
    label: "post-reset alloc-raw(8) reuses the reclaimed region")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
