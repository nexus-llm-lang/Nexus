// Regression test for nexus-xs3dl: `.field` access on a match-bound
// constructor field whose declared type is a NAMED record alias used to
// abort LIR lowering with E6002 ("field access on non-record semantic
// type"). The program typechecked but never reached runtime.
//
// Root cause: `constructor_field_type` returned the field's declared
// `TyUserDefined("Inner", …)` verbatim, so the bound variable's semantic
// type was an unresolved named reference; `resolve_record_field` only
// matched `TyRecord` and threw. The fix expands the named alias to its
// `TyRecord` body (carried on the variant index) at field-type lookup.
//
// Pins (all must REACH runtime — pre-fix they crashed at codegen):
//   1. issue repro: single-field i64 named-alias record, `.a` after match.
//   2. multi-field named alias (i64 / f64 / string) read via `.` after match.
// Guards (these paths already worked; keep them green):
//   3. inline anonymous record field type → `.field` after match.
//   4. nested record-pattern in the arm (the original workaround).
//   5. passing the bound record to a function (no direct `.`).
import * as test_assert from "std:test/assert"

// --- pin 1: issue repro (single-field i64 named alias) ---
type Inner = { a: i64, b: i64 }
type Box = Mk(inner: Inner, tag: i64)

let getA = fn (bx: Box) -> i64 do
  match bx do
    | Mk(inner, tag: 0) -> return inner.a + 1000
    | Mk(inner, tag: _) -> return inner.a
  end
end

// --- pin 2: multi-field named alias, mixed i64 / f64 / string ---
type Mixed = { count: i64, ratio: float, label: string }
type MixedBox = MB(m: Mixed, kind: i64)

let mixed_count = fn (mb: MixedBox) -> i64 do
  match mb do
    | MB(m, kind: _) -> return m.count
  end
end

let mixed_ratio = fn (mb: MixedBox) -> float do
  match mb do
    | MB(m, kind: _) -> return m.ratio
  end
end

let mixed_label = fn (mb: MixedBox) -> string do
  match mb do
    | MB(m, kind: _) -> return m.label
  end
end

// --- pin 3: inline anonymous record field type (already worked) ---
type InlineBox = IB(inner: { a: i64, b: i64 }, tag: i64)

let inline_getA = fn (bx: InlineBox) -> i64 do
  match bx do
    | IB(inner, tag: _) -> return inner.a
  end
end

// --- pin 4: nested record-pattern workaround (already worked) ---
let nested_getA = fn (bx: Box) -> i64 do
  match bx do
    | Mk(inner: { a: va, b: _ }, tag: _) -> return va
  end
end

// --- pin 5: pass bound record to a function, no direct `.` (already worked) ---
let read_inner_a = fn (i: Inner) -> i64 do
  return i.a
end

let func_param_getA = fn (bx: Box) -> i64 do
  match bx do
    | Mk(inner, tag: _) -> return read_inner_a(i: inner)
  end
end

let body = fn () -> unit throws { Exn } do
  // pin 1: tag=1 hits the wildcard arm → inner.a == 42
  let bx = Mk(inner: { a: 42, b: 7 }, tag: 1)
  test_assert.assert_eq_i64(
    actual: getA(bx),
    expected: 42,
    label: "xs3dl pin1: .a on match-bound named-alias field (tag=1)"
  )
  // pin 1b: tag=0 hits the first arm → inner.a + 1000 == 1042
  let bx0 = Mk(inner: { a: 42, b: 7 }, tag: 0)
  test_assert.assert_eq_i64(
    actual: getA(bx: bx0),
    expected: 1042,
    label: "xs3dl pin1b: first arm reaches .a + 1000 (tag=0)"
  )

  // pin 2: multi-field mixed-type named alias
  let mb = MB(m: { count: 9, ratio: 2.5, label: "hi" }, kind: 3)
  test_assert.assert_eq_i64(
    actual: mixed_count(mb: MB(m: { count: 9, ratio: 2.5, label: "hi" }, kind: 3)),
    expected: 9,
    label: "xs3dl pin2: .count (i64) on multi-field named-alias field"
  )
  test_assert.assert_true(
    cond: mixed_ratio(mb: MB(m: { count: 9, ratio: 2.5, label: "hi" }, kind: 3)) ==. 2.5,
    label: "xs3dl pin2: .ratio (f64) on multi-field named-alias field"
  )
  test_assert.assert_eq_string(
    actual: mixed_label(mb),
    expected: "hi",
    label: "xs3dl pin2: .label (string) on multi-field named-alias field"
  )

  // pin 3: inline anonymous record field type
  test_assert.assert_eq_i64(
    actual: inline_getA(bx: IB(inner: { a: 77, b: 1 }, tag: 0)),
    expected: 77,
    label: "xs3dl pin3: inline anonymous record field path still works"
  )

  // pin 4: nested record-pattern workaround
  test_assert.assert_eq_i64(
    actual: nested_getA(bx: Mk(inner: { a: 55, b: 1 }, tag: 0)),
    expected: 55,
    label: "xs3dl pin4: nested record-pattern path still works"
  )

  // pin 5: pass bound record to a function
  test_assert.assert_eq_i64(
    actual: func_param_getA(bx: Mk(inner: { a: 33, b: 1 }, tag: 0)),
    expected: 33,
    label: "xs3dl pin5: function-param path still works"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
