// Regression for nexus-s06g: `arr[idx] <- val` (assignment-via-index) was
// rejected by the self-host parser as "non-variable expression before '<-'"
// (E1001 UnexpectedToken at src/frontend/parser.nx parse_stmt). The fix
// extends parse_stmt to accept ExprIndex on the LHS, lowers it through HIR
// Assign(target: ExprIndex, value: ...) -> MIR -> LIR Call("__array_set",
// [arr, idx, val]), and adds emit_array_set in src/backend/codegen.nx for
// the LIR -> wasm dispatch (mirrors nexus-90e5's emit_array_get pattern).
//
// Each indexed assignment starts from a fresh array literal because owned
// arrays are linear: writing then reading on the same `arr` would require
// the typechecker to model in-place mutation through the linear envelope,
// which is outside this fix's scope. Read-back uses 90e5's `arr[idx]` to
// confirm both intrinsics share a working memory layout.
//
// Validation uses `match` rather than if-as-expression for the same reason
// as the 90e5 fixture (typechecker still mis-defaults int-literal arms in
// `if e then 1 else 0 end`).
//
// Mismatched element values trap via `1 / denom`; success runs cleanly.

let main = fn () -> unit do
  // Write three indices into a fresh array, read back via __array_get.
  let a0 = [| 0, 0, 0 |]
  a0[0] <- 10
  let v0 = a0[0]

  let a1 = [| 0, 0, 0 |]
  a1[1] <- 20
  let v1 = a1[1]

  let a2 = [| 0, 0, 0 |]
  a2[2] <- 30
  let v2 = a2[2]

  let d0 = match v0 == 10 do | true -> 1 | false -> 0 end
  let d1 = match v1 == 20 do | true -> 1 | false -> 0 end
  let d2 = match v2 == 30 do | true -> 1 | false -> 0 end
  let _ = 1 / d0
  let _ = 1 / d1
  let _ = 1 / d2
  return ()
end
