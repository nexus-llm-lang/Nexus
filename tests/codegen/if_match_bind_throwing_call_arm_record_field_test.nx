// Regression: `.field` of an `if`/`match`-bound var whose FIRST arm is a
// record-returning THROWING CALL aborted LIR lowering with E6002
// ("field access on non-record semantic type") even though the program is
// well-typed.
//
// Root cause: `infer_branches_type` (semantic_types.nx) reads the binding's
// type from the first NON-diverging arm. A bare `throw` first arm is detected
// as diverging (MirRaise) and skipped, but a THROWING CALL (`thrower()`) is
// NOT diverging — it produces a value of type `R` — so its type is taken from
// that arm. The `MirCall` arm of `infer_semantic_type` returned the call's
// declared return type WITHOUT resolving a named record alias, so the binding
// carried the unresolved `TyUserDefined("R")` instead of its `TyRecord` body,
// and the later `.field` projection aborted with E6002. The fix resolves the
// recovered call return type through the record-alias table, mirroring the
// `MirFieldAccess` / `resolve_record_field` arms.
//
// Sibling of nexus-pvscf (closure capture) / nexus-n5gub (cons-elem / generic
// field) and the diverging-arm-value test (bare `throw` first arm). Pins below
// all aborted at codegen pre-fix when the throwing-call arm is FIRST.
import * as test_assert from "std:test/assert"

type R = { a: i64 }
type Pt = { x: i64, y: i64 }
exception Boom

let thrower = fn () -> R throws { Boom } do throw Boom end
let pt_thrower = fn () -> Pt throws { Boom } do throw Boom end

// --- pin 1: if-form, throwing-call arm FIRST (then-branch) ---
let if_call_first = fn (c: bool) -> i64 throws { Boom } do
  let r = if c then thrower() else { a: 7 } end
  return r.a
end

// --- pin 2: match-form, throwing-call case FIRST ---
let match_call_first = fn (c: bool) -> i64 throws { Boom } do
  let r = match c do | true -> thrower() | false -> { a: 7 } end
  return r.a
end

// --- pin 3: multi-field record alias, throwing-call arm FIRST, project both ---
let if_call_first_multi = fn (c: bool) -> i64 throws { Boom } do
  let p = if c then pt_thrower() else { x: 3, y: 40 } end
  return p.x + p.y
end

// --- pin 4: control — literal arm FIRST, throwing call in else ---
let if_call_second = fn (c: bool) -> i64 throws { Boom } do
  let r = if c then { a: 9 } else thrower() end
  return r.a
end

let body = fn () -> unit throws { Exn, Boom } do
  test_assert.assert_eq_i64(
    actual: if_call_first(c: false),
    expected: 7,
    label: "throwing-call-arm pin1: if-form first arm is a throwing call, project .a"
  )
  test_assert.assert_eq_i64(
    actual: match_call_first(c: false),
    expected: 7,
    label: "throwing-call-arm pin2: match-form first case is a throwing call, project .a"
  )
  test_assert.assert_eq_i64(
    actual: if_call_first_multi(c: false),
    expected: 43,
    label: "throwing-call-arm pin3: multi-field alias, throwing-call arm first, project .x + .y"
  )
  test_assert.assert_eq_i64(
    actual: if_call_second(c: true),
    expected: 9,
    label: "throwing-call-arm pin4: control — literal arm first, throwing call in else"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
