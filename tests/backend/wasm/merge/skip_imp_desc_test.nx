// Issue nexus-byiw.1: unit-test merge.section_emit.skip_imp_desc — the
// import-descriptor skip used by `copy_imports_with_type_off` to find
// the byte boundary of a non-function import (kind != 0) so the
// descriptor can be bulk-copied verbatim.
//
// WASM import-desc shapes (each prefixed by a `kind` byte at `pos`):
//   kind 0 (func)   : 1 byte + ULEB(type_idx)
//   kind 1 (table)  : 1 byte + reftype(1 byte) + limits
//   kind 2 (memory) : 1 byte + limits
//   kind 3 (global) : 1 byte + valtype(1 byte) + mut(1 byte)
//   kind 4 (tag)    : 1 byte + ULEB(attr) + ULEB(type_idx)
//
// `limits` is itself: flags(1 byte) + min(ULEB) [+ max(ULEB) if flags=1].
//
// Each case below checks that skip_imp_desc returns the position one
// past the LAST byte of the descriptor — equivalently, the start of
// the next import or the section end. A wrong return shifts every
// subsequent import in copy_imports_with_type_off by N bytes and
// corrupts the section.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { skip_imp_desc } from "src/backend/wasm/merge/section_emit.nx"

let body = fn () -> unit throws { Exn } do
  // ── case 1: kind=0 (func), type_idx=7 (single-byte ULEB) ──
  // buf = [0, 7] → skip returns 2.
  let %f0 = bb.empty()
  let %f1 = bb.push_byte(buf: %f0, byte: 0)   // kind: func
  let %f2 = bb.push_byte(buf: %f1, byte: 7)   // type_idx (ULEB, < 0x80 = 1 byte)
  let pos_f = skip_imp_desc(buf: &f2, pos: 0)
  bb.free(buf: %f2)
  test_assert.assert_eq_i64(actual: pos_f, expected: 2,
    label: "skip_imp_desc: func (kind=0) consumes kind + 1-byte ULEB type_idx")

  // ── case 2: kind=2 (memory), limits flags=0 (min only) ──
  // buf = [2, 0, 16] → kind, flags=0, min=16. Skip returns 3.
  let %m0 = bb.empty()
  let %m1 = bb.push_byte(buf: %m0, byte: 2)    // kind: memory
  let %m2 = bb.push_byte(buf: %m1, byte: 0)    // limits flags = 0 (min only)
  let %m3 = bb.push_byte(buf: %m2, byte: 16)   // min
  let pos_m = skip_imp_desc(buf: &m3, pos: 0)
  bb.free(buf: %m3)
  test_assert.assert_eq_i64(actual: pos_m, expected: 3,
    label: "skip_imp_desc: memory (kind=2) consumes kind + flags + min (no max)")

  // ── case 3: kind=2 (memory), limits flags=1 (min + max) ──
  // buf = [2, 1, 1, 4] → kind, flags=1, min=1, max=4. Skip returns 4.
  // The flags=1 branch is the one that bit nexus-3u93's table-limits cousin —
  // forgetting to read the second ULEB shifts every later import.
  let %mm0 = bb.empty()
  let %mm1 = bb.push_byte(buf: %mm0, byte: 2)
  let %mm2 = bb.push_byte(buf: %mm1, byte: 1)   // flags = 1 (min + max)
  let %mm3 = bb.push_byte(buf: %mm2, byte: 1)   // min
  let %mm4 = bb.push_byte(buf: %mm3, byte: 4)   // max
  let pos_mm = skip_imp_desc(buf: &mm4, pos: 0)
  bb.free(buf: %mm4)
  test_assert.assert_eq_i64(actual: pos_mm, expected: 4,
    label: "skip_imp_desc: memory (kind=2) with flags=1 consumes both min AND max")

  // ── case 4: kind=3 (global), fixed 2-byte payload (valtype + mut) ──
  // buf = [3, 127, 0] → kind, vt=i32(0x7F), mut=const(0). Skip returns 3.
  let %g0 = bb.empty()
  let %g1 = bb.push_byte(buf: %g0, byte: 3)
  let %g2 = bb.push_byte(buf: %g1, byte: 127)  // valtype i32
  let %g3 = bb.push_byte(buf: %g2, byte: 0)    // mut: const
  let pos_g = skip_imp_desc(buf: &g3, pos: 0)
  bb.free(buf: %g3)
  test_assert.assert_eq_i64(actual: pos_g, expected: 3,
    label: "skip_imp_desc: global (kind=3) consumes exactly 3 bytes (kind + vt + mut)")

  // ── case 5: kind=4 (tag), attr=0, type_idx=5 (both 1-byte ULEBs) ──
  // buf = [4, 0, 5] → skip returns 3.
  let %t0 = bb.empty()
  let %t1 = bb.push_byte(buf: %t0, byte: 4)
  let %t2 = bb.push_byte(buf: %t1, byte: 0)
  let %t3 = bb.push_byte(buf: %t2, byte: 5)
  let pos_t = skip_imp_desc(buf: &t3, pos: 0)
  bb.free(buf: %t3)
  test_assert.assert_eq_i64(actual: pos_t, expected: 3,
    label: "skip_imp_desc: tag (kind>=4) consumes kind + 2 ULEBs (attr + type_idx)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
