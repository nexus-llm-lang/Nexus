// Issue nexus-dpob: unit-test merge.section_emit.emit_merged_tag_sec —
// merges dep and main tag sections into a single section 13, applying
// separate type-index offsets to each side.
//
// Tag section body layout (id=13):
//   ULEB count
//   For each tag: ULEB(attr), ULEB(type_idx)
//
// `emit_merged_tag_sec(out, d_buf, d_sec, d_off, m_buf, m_sec, m_off)`:
//   * Emits nothing when both sides have no tags (both sec_pk==0).
//   * Emits dep entries (type_idx + d_off) then main entries (type_idx + m_off).
//   * Total count = dep_count + main_count.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { ByteBuffer } from "std:bytebuffer"
import { emit_merged_tag_sec } from "src/backend/wasm/merge/section_emit.nx"
import { pack } from "src/backend/wasm/read.nx"

let read_all = fn (buf: &ByteBuffer) -> [ i64 ] do
  return read_all_go(buf, idx: 0, len: bb.length(buf), acc: [])
end
let read_all_go = fn (buf: &ByteBuffer, idx: i64, len: i64, acc: [ i64 ]) -> [ i64 ] do
  if idx >= len then return reverse(xs: acc, out: []) end
  let b = bb.get_byte(buf, idx)
  return read_all_go(buf, idx: idx + 1, len, acc: b :: acc)
end
let reverse = fn (xs: [ i64 ], out: [ i64 ]) -> [ i64 ] do
  match xs do
    | [] -> return out
    | x :: rest -> return reverse(xs: rest, out: x :: out)
  end
end

// Build a minimal buffer with one tag at sec-body offset 1:
//   [pad=99, count=1, attr, tidx]
let make_tag_buf_1 = fn (attr0: i64, tidx0: i64) -> %ByteBuffer do
  let %b = bb.empty()
  let %b = bb.push_byte(buf: %b, byte: 99)
  let %b = bb.push_byte(buf: %b, byte: 1)
  let %b = bb.push_byte(buf: %b, byte: attr0)
  let %b = bb.push_byte(buf: %b, byte: tidx0)
  return %b
end
// Build a minimal buffer with two tags at sec-body offset 1:
//   [pad=99, count=2, attr0, tidx0, attr1, tidx1]
let make_tag_buf_2 = fn (attr0: i64, tidx0: i64, attr1: i64, tidx1: i64) -> %ByteBuffer do
  let %b = bb.empty()
  let %b = bb.push_byte(buf: %b, byte: 99)
  let %b = bb.push_byte(buf: %b, byte: 2)
  let %b = bb.push_byte(buf: %b, byte: attr0)
  let %b = bb.push_byte(buf: %b, byte: tidx0)
  let %b = bb.push_byte(buf: %b, byte: attr1)
  let %b = bb.push_byte(buf: %b, byte: tidx1)
  return %b
end

let body = fn () -> unit throws { Exn } do
  // sec_pk pointing at offset 1 (past the single pad byte)
  let sec_pk1 = pack(val: 1, p: 0)

  // ── case 1: both absent (sec_pk==0) → nothing emitted ──
  let %e_src = bb.empty()
  let %e_out = bb.empty()
  let %e_out = emit_merged_tag_sec(out: %e_out,
    d_buf: &e_src, d_sec: 0, d_off: 0,
    m_buf: &e_src, m_sec: 0, m_off: 0)
  let e_len = bb.length(buf: &e_out)
  bb.free(buf: %e_out)
  bb.free(buf: %e_src)
  test_assert.assert_eq_i64(actual: e_len, expected: 0,
    label: "emit_merged_tag_sec: both absent emits nothing")

  // ── case 2: dep only (1 tag attr=0 tidx=2 d_off=0), main absent ──
  // Output: [13, 3, 1, 0, 2]
  //   sec_id=13, payload_len=3, count=1, attr=0, tidx=2+0=2
  let %d2 = make_tag_buf_1(attr0: 0, tidx0: 2)
  let %m2 = bb.empty()
  let %o2 = bb.empty()
  let %o2 = emit_merged_tag_sec(out: %o2,
    d_buf: &d2, d_sec: sec_pk1, d_off: 0,
    m_buf: &m2, m_sec: 0, m_off: 10)
  let bytes2 = read_all(buf: &o2)
  bb.free(buf: %o2)
  bb.free(buf: %d2)
  bb.free(buf: %m2)
  test_assert.assert_eq_i64_list(actual: bytes2, expected: [ 13, 3, 1, 0, 2 ],
    label: "emit_merged_tag_sec: dep-only 1 tag (d_off=0)")

  // ── case 3: main only (1 tag attr=0 tidx=1 m_off=5), dep absent ──
  // Output: [13, 3, 1, 0, 6]
  //   sec_id=13, payload_len=3, count=1, attr=0, tidx=1+5=6
  let %d3 = bb.empty()
  let %m3 = make_tag_buf_1(attr0: 0, tidx0: 1)
  let %o3 = bb.empty()
  let %o3 = emit_merged_tag_sec(out: %o3,
    d_buf: &d3, d_sec: 0, d_off: 0,
    m_buf: &m3, m_sec: sec_pk1, m_off: 5)
  let bytes3 = read_all(buf: &o3)
  bb.free(buf: %o3)
  bb.free(buf: %d3)
  bb.free(buf: %m3)
  test_assert.assert_eq_i64_list(actual: bytes3, expected: [ 13, 3, 1, 0, 6 ],
    label: "emit_merged_tag_sec: main-only 1 tag (m_off=5)")

  // ── case 4: both non-empty ──
  // dep: 2 tags (attr=0,tidx=1), (attr=0,tidx=3); d_off=0
  // main: 1 tag (attr=0,tidx=2); m_off=4
  // merged count=3; payload body [3, 0,1, 0,3, 0,6] = 7 bytes
  // Output: [13, 7, 3, 0, 1, 0, 3, 0, 6]
  let %d4 = make_tag_buf_2(attr0: 0, tidx0: 1, attr1: 0, tidx1: 3)
  let %m4 = make_tag_buf_1(attr0: 0, tidx0: 2)
  let %o4 = bb.empty()
  let %o4 = emit_merged_tag_sec(out: %o4,
    d_buf: &d4, d_sec: sec_pk1, d_off: 0,
    m_buf: &m4, m_sec: sec_pk1, m_off: 4)
  let bytes4 = read_all(buf: &o4)
  bb.free(buf: %o4)
  bb.free(buf: %d4)
  bb.free(buf: %m4)
  test_assert.assert_eq_i64_list(actual: bytes4, expected: [ 13, 7, 3, 0, 1, 0, 3, 0, 6 ],
    label: "emit_merged_tag_sec: dep(2)+main(1) merged with offsets")

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
