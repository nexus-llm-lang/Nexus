// Unit test for any_dep_prefix_matches — the key classifier that drives
// iterative pairwise fold correctness for N>1 deps.
//
// In the fold loop, each pass calls merge_one_dep with ONE dep's prefix.
// Imports whose module does NOT match are kept as host imports and resolved
// by a later pass. This test verifies that:
//   1. An import matching dep0's prefix is matched (resolved/dropped in pass 0).
//   2. An import matching dep1's prefix is NOT matched by dep0's prefix list
//      (kept as host import after pass 0, resolved in pass 1).
//   3. The empty module-name ("") rule: matched only when dep_is_first=true.
//      After pass 0 the intermediate has no "" imports (resolved); so pass 1
//      never encounters dep_is_first=true with an "" import from the core.
//   4. env.memory ("env" module, kind=2) is not matched by any dep prefix;
//      the kind==2 guard in count_main_kept_go drops it, and merge_one_dep
//      emits a fresh env.memory in each merged output.
import * as test_assert from "std:test/assert"
import { any_dep_prefix_matches } from "src/backend/wasm/merge.nx"

let body = fn () -> unit throws { Exn } do
  let dep0_pfs = [ "nexus:std/" ]
  let dep1_pfs = [ "nexus:net/" ]

  // ── case 1: dep0-prefix import matched in pass 0 ──
  let r1 = any_dep_prefix_matches(
    mod_name: "nexus:std/allocator",
    prefixes: dep0_pfs,
    dep_is_first: true
  )
  test_assert.assert_true(cond: r1,
    label: "dep0 pass: nexus:std/allocator matches dep0 prefix — resolved in pass 0")

  // ── case 2: dep1-prefix import NOT matched in pass 0 (kept for pass 1) ──
  let r2 = any_dep_prefix_matches(mod_name: "nexus:net/tcp", prefixes: dep0_pfs, dep_is_first: true)
  test_assert.assert_false(cond: r2,
    label: "dep0 pass: nexus:net/tcp does not match dep0 prefix — kept as host import")

  // ── case 3: dep1-prefix import matched in pass 1 ──
  let r3 = any_dep_prefix_matches(mod_name: "nexus:net/tcp", prefixes: dep1_pfs, dep_is_first: true)
  test_assert.assert_true(cond: r3,
    label: "dep1 pass: nexus:net/tcp matches dep1 prefix — resolved in pass 1")

  // ── case 4: anonymous "" import matched only when dep_is_first=true ──
  let r4 = any_dep_prefix_matches(mod_name: "", prefixes: dep0_pfs, dep_is_first: true)
  test_assert.assert_true(cond: r4,
    label: "dep0 pass: empty module name matched (dep_is_first=true)")

  let r5 = any_dep_prefix_matches(mod_name: "", prefixes: dep1_pfs, dep_is_first: false)
  test_assert.assert_false(cond: r5,
    label: "dep_is_first=false: empty module name not matched")

  // ── case 5: env import never matches any dep prefix ──
  // After pass 0, the intermediate imports env.memory (mod_name="env").
  // In pass 1 the kind==2 guard drops it; this verifies the prefix check
  // does not accidentally absorb it.
  let r6 = any_dep_prefix_matches(mod_name: "env", prefixes: dep1_pfs, dep_is_first: true)
  test_assert.assert_false(cond: r6,
    label: "dep1 pass: env (env.memory from intermediate) not matched by dep prefix")

  // ── case 6: unrelated WASI host import not matched by any dep prefix ──
  let r7 = any_dep_prefix_matches(
    mod_name: "wasi_snapshot_preview1",
    prefixes: dep0_pfs,
    dep_is_first: true
  )
  test_assert.assert_false(cond: r7,
    label: "dep0 pass: wasi_snapshot_preview1 not matched — kept as host import")

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
