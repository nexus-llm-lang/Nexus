// Issue nexus-byiw.1: unit-test merge.section_emit.rd_str — the WASM
// string reader (ULEB-length prefix + UTF-8 bytes) used by both
// `copy_imports_with_type_off` (parses module + name) and
// `emit_remapped_exports` (parses export name).
//
// Shape under test: input buffer = [pad..., len:ULEB, bytes:[len]].
// rd_str(buf, pos) must:
//   * decode the ULEB at pos to get `len`
//   * read `len` bytes starting at pos+ULEB-size as a string
//   * return StrPos(s, pos: start_of_bytes + len)
//
// Two cases:
//   1. Short string (len < 0x80, one-byte ULEB) at non-zero offset —
//      verifies pos arithmetic uses the post-ULEB anchor, not pos+1.
//   2. Empty string (len = 0) — degenerate case; result must be ("",
//      pos+1). Catches a regression that would read one phantom byte
//      when len == 0.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { rd_str, StrPos } from "src/backend/wasm/merge/section_emit.nx"

let body = fn () -> unit throws { Exn } do
  // ── case 1: "wasi" at pos=3 ──
  // buf = [0xAA, 0xBB, 0xCC, 4, 'w', 'a', 's', 'i', 0xDD]
  //              pad       len  ── 4 bytes ──    sentinel
  // Expected: s="wasi", end_pos = 3 (start of len) + 1 (ULEB byte) + 4 (str bytes) = 8.
  let %b0 = bb.empty()
  let %b1 = bb.push_byte(buf: %b0, byte: 170)
  let %b2 = bb.push_byte(buf: %b1, byte: 187)
  let %b3 = bb.push_byte(buf: %b2, byte: 204)
  let %b4 = bb.push_byte(buf: %b3, byte: 4)    // ULEB length
  let %b5 = bb.push_byte(buf: %b4, byte: 119)  // 'w'
  let %b6 = bb.push_byte(buf: %b5, byte: 97)   // 'a'
  let %b7 = bb.push_byte(buf: %b6, byte: 115)  // 's'
  let %b8 = bb.push_byte(buf: %b7, byte: 105)  // 'i'
  let %b9 = bb.push_byte(buf: %b8, byte: 221)  // sentinel — must NOT be read
  let StrPos(s: s1, pos: end1) = rd_str(buf: &b9, pos: 3)
  bb.free(buf: %b9)
  test_assert.assert_eq_string(actual: s1, expected: "wasi",
    label: "rd_str: decodes 4-byte ASCII string at non-zero offset")
  test_assert.assert_eq_i64(actual: end1, expected: 8,
    label: "rd_str: end_pos = start + ULEB-size + byte-count (3 + 1 + 4 = 8)")

  // ── case 2: empty string at pos=0 ──
  // buf = [0, 0xEE] — len=0, sentinel must remain untouched.
  let %e0 = bb.empty()
  let %e1 = bb.push_byte(buf: %e0, byte: 0)    // len = 0
  let %e2 = bb.push_byte(buf: %e1, byte: 238)  // sentinel
  let StrPos(s: s2, pos: end2) = rd_str(buf: &e2, pos: 0)
  bb.free(buf: %e2)
  test_assert.assert_eq_string(actual: s2, expected: "",
    label: "rd_str: empty string (len=0) decodes to \"\"")
  test_assert.assert_eq_i64(actual: end2, expected: 1,
    label: "rd_str: empty string advances pos by ULEB size only (0 + 1 + 0 = 1)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
