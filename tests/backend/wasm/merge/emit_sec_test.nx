// Issue nexus-byiw.1: unit-test merge.section_emit.emit_sec and
// emit_stub_bodies — the lowest-level section wrapper and the
// code-section stub generator.
//
// emit_sec(out, sec_id, content) writes: sec_id byte + ULEB(content_len)
//   + content bytes. Every per-section emitter calls into this.
//
// emit_stub_bodies(out, i, n) writes `n` minimal function bodies, each
// of which is a ULEB(3) + [0, 0, op_end]. The leading two zeros are
// the local-vec count + a `nop`-ish padding byte (legacy); op_end is
// 0x0B. Used to pad the merged code section when a dep wasm is
// referenced but has no executable bodies of its own.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { ByteBuffer } from "std:bytebuffer"
import { emit_sec, emit_stub_bodies } from "src/backend/wasm/merge/section_emit.nx"
import { op_end } from "src/backend/wasm/defs.nx"

let read_all = fn (buf: &ByteBuffer) -> [ i64 ] do
  return read_all_go(buf, idx: 0, len: bb.length(buf), acc: [])
end
let read_all_go = fn (buf: &ByteBuffer, idx: i64, len: i64, acc: [ i64 ]) -> [ i64 ] do
  if idx >= len then return reverse(xs: acc, out: []) end
  let b = bb.get_byte(buf, idx)
  return read_all_go(buf, idx: idx + 1, len, acc: b :: acc)
end
let reverse = fn (xs: [ i64 ], out: [ i64 ]) -> [ i64 ] do
  match xs do
    | [] -> return out
    | x :: rest -> return reverse(xs: rest, out: x :: out)
  end
end

let body = fn () -> unit throws { Exn } do
  // ── case 1: emit_sec wraps a 4-byte content as type-section (id=1) ──
  // content = [0x60, 0x00, 0x00, 0x01] (a fake "[]->[]" sketch).
  // Expected output: [1, 4, 0x60, 0x00, 0x00, 0x01].
  let %c0 = bb.empty()
  let %c1 = bb.push_byte(buf: %c0, byte: 96)
  let %c2 = bb.push_byte(buf: %c1, byte: 0)
  let %c3 = bb.push_byte(buf: %c2, byte: 0)
  let %c4 = bb.push_byte(buf: %c3, byte: 1)
  let %o0 = bb.empty()
  let %o1 = emit_sec(out: %o0, sec_id: 1, content: &c4)
  let out_bytes = read_all(buf: &o1)
  let out_len = bb.length(buf: &o1)
  bb.free(buf: %o1)
  bb.free(buf: %c4)
  test_assert.assert_eq_i64(actual: out_len, expected: 6,
    label: "emit_sec: header (id + ULEB len) + 4-byte content = 6 bytes total")
  test_assert.assert_eq_i64_list(actual: out_bytes,
    expected: [ 1, 4, 96, 0, 0, 1 ],
    label: "emit_sec: sec_id, ULEB(4) length prefix, then content verbatim")

  // ── case 2: emit_sec with empty content ──
  // Edge case: ULEB(0) = single zero byte, no content. Output = [id, 0].
  let %e0 = bb.empty()
  let %d0 = bb.empty()
  let %d1 = emit_sec(out: %d0, sec_id: 10, content: &e0)
  let d_bytes = read_all(buf: &d1)
  bb.free(buf: %d1)
  bb.free(buf: %e0)
  test_assert.assert_eq_i64_list(actual: d_bytes, expected: [ 10, 0 ],
    label: "emit_sec: empty content emits [sec_id, 0] (ULEB(0) is one byte)")

  // ── case 3: emit_stub_bodies writes 2 stub bodies ──
  // Each stub = ULEB(3) + [0, 0, op_end] = [3, 0, 0, 0x0B] = 4 bytes.
  // n=2 stubs → 8 bytes total: [3, 0, 0, 0x0B, 3, 0, 0, 0x0B].
  let %s0 = bb.empty()
  let %s1 = emit_stub_bodies(out: %s0, i: 0, n: 2)
  let stub_len = bb.length(buf: &s1)
  let stub_bytes = read_all(buf: &s1)
  bb.free(buf: %s1)
  test_assert.assert_eq_i64(actual: stub_len, expected: 8,
    label: "emit_stub_bodies: 2 stubs × 4 bytes each = 8 bytes")
  test_assert.assert_eq_i64_list(actual: stub_bytes,
    expected: [ 3, 0, 0, op_end(), 3, 0, 0, op_end() ],
    label: "emit_stub_bodies: each stub is ULEB(3) + [0, 0, op_end]")

  // ── case 4: emit_stub_bodies with n=0 produces zero bytes ──
  // i >= n base case — sanity check the recursion terminator.
  let %z0 = bb.empty()
  let %z1 = emit_stub_bodies(out: %z0, i: 0, n: 0)
  let z_len = bb.length(buf: &z1)
  bb.free(buf: %z1)
  test_assert.assert_eq_i64(actual: z_len, expected: 0,
    label: "emit_stub_bodies: n=0 writes nothing (base case)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
