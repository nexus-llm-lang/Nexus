// Issue nexus-byiw.1: unit-test merge.section_emit.scan_custom_secs —
// the pre-pass that discovers ALL custom sections (id=0) in a wasm
// blob so they can be emitted verbatim (or, for "name", remapped)
// in the merge output. scan_secs collapses every custom onto key="0",
// so this dedicated walker is the only way to preserve multiples.
//
// Output: a StringMap where:
//   - "__count" holds the total custom-section count discovered
//   - "0", "1", … hold pack(content_start, sec_size) for each custom
//
// Walks from pos=8 (skipping the wasm magic "0asm" + version 4 bytes),
// reading [sec_id, ULEB(sec_size), payload...] for each section.
// Non-custom sections are advanced over but not recorded.
//
// Fixture is a minimal hand-rolled wasm: 8-byte header + alternating
// custom / type-section / custom layout. We don't validate via wasmtime
// because find_data_end / scan_custom_secs only need byte-level
// consistency, not semantic correctness.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import * as sm from "std:stringmap"
import { ByteBuffer } from "std:bytebuffer"
import { StringMap } from "std:stringmap"
import { scan_custom_secs } from "src/backend/wasm/merge/section_emit.nx"
import { pval, ppos } from "src/backend/wasm/read.nx"

let body = fn () -> unit throws { Exn } do
  // ── case 1: empty module (header only) ──
  // Buf = [0, 'a', 's', 'm', 1, 0, 0, 0] (8 bytes magic+version, no sections).
  // Expected: __count=0, no other keys.
  let %h0 = bb.empty()
  let %h1 = bb.push_byte(buf: %h0, byte: 0)
  let %h2 = bb.push_byte(buf: %h1, byte: 97)
  let %h3 = bb.push_byte(buf: %h2, byte: 115)
  let %h4 = bb.push_byte(buf: %h3, byte: 109)
  let %h5 = bb.push_byte(buf: %h4, byte: 1)
  let %h6 = bb.push_byte(buf: %h5, byte: 0)
  let %h7 = bb.push_byte(buf: %h6, byte: 0)
  let %h8 = bb.push_byte(buf: %h7, byte: 0)
  let %map_h = scan_custom_secs(buf: &h8)
  let count_h = sm.get_or(map: &map_h, key: "__count", default: -1)
  sm.free(map: %map_h)
  bb.free(buf: %h8)
  test_assert.assert_eq_i64(actual: count_h, expected: 0,
    label: "scan_custom_secs: header-only wasm has 0 customs (__count=0)")

  // ── case 2: header + one custom (id=0) + one type (id=1) + one custom (id=0) ──
  // Layout (positions in bytes):
  //   0..7   : header (magic + version)
  //   8      : sec_id=0 (custom)
  //   9      : sec_size=3 (ULEB)
  //   10..12 : payload (3 bytes) — content_start=10
  //   13     : sec_id=1 (type)   — must NOT be recorded
  //   14     : sec_size=2 (ULEB)
  //   15..16 : payload (2 bytes)
  //   17     : sec_id=0 (custom)
  //   18     : sec_size=4 (ULEB)
  //   19..22 : payload (4 bytes) — content_start=19
  //
  // Expected map:
  //   __count = 2
  //   "0"     = pack(10, 3) → pval=10, ppos=3
  //   "1"     = pack(19, 4) → pval=19, ppos=4
  let %m0 = bb.empty()
  let %m1 = bb.push_byte(buf: %m0, byte: 0)
  let %m2 = bb.push_byte(buf: %m1, byte: 97)
  let %m3 = bb.push_byte(buf: %m2, byte: 115)
  let %m4 = bb.push_byte(buf: %m3, byte: 109)
  let %m5 = bb.push_byte(buf: %m4, byte: 1)
  let %m6 = bb.push_byte(buf: %m5, byte: 0)
  let %m7 = bb.push_byte(buf: %m6, byte: 0)
  let %m8 = bb.push_byte(buf: %m7, byte: 0)
  // Custom A
  let %m9 = bb.push_byte(buf: %m8, byte: 0)    // sec_id=0
  let %ma = bb.push_byte(buf: %m9, byte: 3)    // size=3
  let %mb = bb.push_byte(buf: %ma, byte: 10)   // payload
  let %mc = bb.push_byte(buf: %mb, byte: 20)
  let %md = bb.push_byte(buf: %mc, byte: 30)
  // Type sec (must be skipped, not recorded)
  let %me = bb.push_byte(buf: %md, byte: 1)    // sec_id=1
  let %mf = bb.push_byte(buf: %me, byte: 2)    // size=2
  let %mg = bb.push_byte(buf: %mf, byte: 11)
  let %mh = bb.push_byte(buf: %mg, byte: 12)
  // Custom B
  let %mi = bb.push_byte(buf: %mh, byte: 0)    // sec_id=0
  let %mj = bb.push_byte(buf: %mi, byte: 4)    // size=4
  let %mk = bb.push_byte(buf: %mj, byte: 40)
  let %ml = bb.push_byte(buf: %mk, byte: 41)
  let %mm = bb.push_byte(buf: %ml, byte: 42)
  let %mn = bb.push_byte(buf: %mm, byte: 43)
  let %map = scan_custom_secs(buf: &mn)
  let count = sm.get_or(map: &map, key: "__count", default: -1)
  let pk0 = sm.get_or(map: &map, key: "0", default: 0)
  let pk1 = sm.get_or(map: &map, key: "1", default: 0)
  // Type sec was at sec_id=1; verify it did NOT clobber key "1" (which is for
  // the SECOND custom). The classifier key for the type section would never
  // be "1" anyway (key is the custom-index, not sec_id), but assert the value
  // matches the second custom's pack, not the type sec's content_start=15.
  sm.free(map: %map)
  bb.free(buf: %mn)
  test_assert.assert_eq_i64(actual: count, expected: 2,
    label: "scan_custom_secs: 2 customs interleaved with a non-custom section → __count=2")
  test_assert.assert_eq_i64(actual: pval(pk: pk0), expected: 10,
    label: "scan_custom_secs: first custom content_start = 10")
  test_assert.assert_eq_i64(actual: ppos(pk: pk0), expected: 3,
    label: "scan_custom_secs: first custom sec_size = 3")
  test_assert.assert_eq_i64(actual: pval(pk: pk1), expected: 19,
    label: "scan_custom_secs: second custom content_start = 19 (non-custom section skipped, not recorded)")
  test_assert.assert_eq_i64(actual: ppos(pk: pk1), expected: 4,
    label: "scan_custom_secs: second custom sec_size = 4")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
