// Issue nexus-q2g5: unit-test merge.copy_try_handlers — the per-handler
// walker used by both `cls_try_table` (modern 0x1F try_table) and
// `cls_legacy_try` (legacy 0x06 try) inside rw_instrs.
//
// Shape under test: a flat handler-list of mixed kinds —
//   catch / catch_ref (kind 0/1): one ULEB tag, one ULEB label
//   catch_all / catch_all_ref (kind 2/3): one ULEB label only
// copy_try_handlers must copy these verbatim regardless of kind, advancing
// `pos` past every consumed byte. Misclassifying a kind (e.g. treating
// catch_all as catch and reading a phantom tag) was the original nexus-3u93
// failure mode pre-fix.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { ByteBuffer } from "std:bytebuffer"
import { copy_try_handlers, BufPos } from "src/backend/wasm/merge/instruction_rewrite.nx"

// Read all bytes of `buf` into an [i64] list (head-recursive, easy to
// compare via assert_eq_i64_list).
let read_all = fn (buf: &ByteBuffer) -> [ i64 ] do
  return read_all_go(buf, idx: 0, len: bb.length(buf), acc: [])
end
let read_all_go = fn (buf: &ByteBuffer, idx: i64, len: i64, acc: [ i64 ]) -> [ i64 ] do
  if idx >= len then return reverse(xs: acc, out: []) end
  let b = bb.get_byte(buf, idx)
  return read_all_go(buf, idx: idx + 1, len, acc: b :: acc)
end
let reverse = fn (xs: [ i64 ], out: [ i64 ]) -> [ i64 ] do
  match xs do
    | [] -> return out
    | x :: rest -> return reverse(xs: rest, out: x :: out)
  end
end

let body = fn () -> unit throws { Exn } do
  // Build src = [catch(0), tag=5, label=2, catch_all(2), label=7,
  //              catch_ref(1), tag=9, label=4]
  // Expected out (verbatim copy of src bytes 0..8): [0, 5, 2, 2, 7, 1, 9, 4]
  let %s0 = bb.empty()
  let %s1 = bb.push_byte(buf: %s0, byte: 0)   // catch
  let %s2 = bb.push_byte(buf: %s1, byte: 5)   // tag
  let %s3 = bb.push_byte(buf: %s2, byte: 2)   // label
  let %s4 = bb.push_byte(buf: %s3, byte: 2)   // catch_all
  let %s5 = bb.push_byte(buf: %s4, byte: 7)   // label
  let %s6 = bb.push_byte(buf: %s5, byte: 1)   // catch_ref
  let %s7 = bb.push_byte(buf: %s6, byte: 9)   // tag
  let %s8 = bb.push_byte(buf: %s7, byte: 4)   // label
  let %o0 = bb.empty()
  let BufPos(buf: %o1, pos: end_pos) = copy_try_handlers(out: %o0, src: &s8, pos: 0, remaining: 3)

  // Snapshot all observations before any throwable assert so the linear
  // buffers don't outlive a possible throw.
  let out_len = bb.length(buf: &o1)
  let actual = read_all(buf: &o1)
  bb.free(buf: %o1)
  bb.free(buf: %s8)

  test_assert.assert_eq_i64(actual: end_pos, expected: 8,
    label: "copy_try_handlers advances pos past all handler bytes (3 handlers, 8 bytes)")
  test_assert.assert_eq_i64(actual: out_len, expected: 8,
    label: "copy_try_handlers output length matches input length (no operand drop / phantom byte)")
  test_assert.assert_eq_i64_list(actual,
    expected: [ 0, 5, 2, 2, 7, 1, 9, 4 ],
    label: "copy_try_handlers verbatim copy: catch, catch_all, catch_ref")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
