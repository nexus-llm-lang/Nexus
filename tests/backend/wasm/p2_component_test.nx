// Tests for the WASI preview2 component wrapper binary emitters.
//
// Verifies that build_p2_component produces a structurally valid component
// that contains the expected sections and strings.
//
// Preview2 component structure (22 sections):
//   Secs 0-8: Component type/import/alias sections for WASI interfaces
//   Sec 9:  core module 0 = stub (exports non-shared memory)
//   Sec 10: core module 1 = adapter (implements wasi_snapshot_preview1 via p2)
//   Sec 11: core module 2 = nexus core_wasm (dynamic)
//   Sec 12-15: canon lower sections
//   Sec 16: core instance section (4 instances)
//   Sec 17: alias run func
//   Sec 18-21: canon lift, instance, export

import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { ByteBuffer } from "std:bytebuffer"
import { build_p2_component } from "src/backend/wasm/section/component_model.nx"
import * as wdefs from "src/backend/wasm/defs.nx"

let read_all = fn (buf: &ByteBuffer) -> [ i64 ] do
  return read_all_go(buf, idx: 0, len: bb.length(buf), acc: [])
end

let read_all_go = fn (buf: &ByteBuffer, idx: i64, len: i64, acc: [ i64 ]) -> [ i64 ] do
  if idx >= len then return rev_i64(xs: acc, out: []) end
  let b = bb.get_byte(buf, idx)
  return read_all_go(buf, idx: idx + 1, len, acc: b :: acc)
end

let rev_i64 = fn (xs: [ i64 ], out: [ i64 ]) -> [ i64 ] do
  match xs do
    | [] -> return out
    | x :: rest -> return rev_i64(xs: rest, out: x :: out)
  end
end

let nth = fn (xs: [ i64 ], idx: i64) -> i64 do
  match xs do
    | [] -> return -1
    | x :: rest ->
      if idx <= 0 then return x
      else return nth(xs: rest, idx: idx - 1)
      end
  end
end

let list_length = fn (xs: [ i64 ]) -> i64 do
  match xs do
    | [] -> 0
    | _ :: rest -> 1 + list_length(xs: rest)
  end
end

// Minimal core wasm: a module that imports env.memory (non-shared, min=256 max=65536)
// and exports "wasi:cli/run@0.2.6#run" as a func returning i32.
// This mimics what nexus emits in p2 mode.
let minimal_core_wasm = fn () -> %ByteBuffer do
  let %buf = bb.empty()
  // magic + version
  let %buf = bb.push_bytes(buf: %buf, bytes: [ 0, 97, 115, 109, 1, 0, 0, 0 ])
  // type section: id=1, len=5, count=1, func () -> i32
  let %buf = bb.push_bytes(buf: %buf, bytes: [ 1, 5, 1, 96, 0, 1, 127 ])
  // func section: id=3, len=2, count=1, type_idx=0
  let %buf = bb.push_bytes(buf: %buf, bytes: [ 3, 2, 1, 0 ])
  // import section: id=2, count=1: (import "env" "memory" (memory 256 65536))
  // flags=0x01 (has-max, non-shared), min=256 (0x80 0x02), max=65536 (0x80 0x80 0x04)
  let %buf = bb.push_bytes(buf: %buf, bytes: [ 2, 15, 1, 3, 101, 110, 118, 6, 109, 101, 109,
                                              111, 114, 121, 2, 1, 128, 2, 128, 128, 4 ])
  // export section: id=7, count=1: "wasi:cli/run@0.2.6#run" func 0
  let %buf = bb.push_bytes(buf: %buf, bytes: [ 7, 26, 1 ])
  let %buf = bb.push_bytes(buf: %buf, bytes: [ 22, 119, 97, 115, 105, 58, 99, 108, 105, 47 ])
  let %buf = bb.push_bytes(buf: %buf, bytes: [ 114, 117, 110, 64, 48, 46, 50, 46, 54, 35 ])
  let %buf = bb.push_bytes(buf: %buf, bytes: [ 114, 117, 110, 0, 0 ])
  // code section: id=10, len=6, count=1, func_len=4, 0 locals, i32.const 0, end
  return bb.push_bytes(buf: %buf, bytes: [ 10, 6, 1, 4, 0, 65, 0, 11 ])
end

// Find a subsequence in bytes starting at idx.
let find_subseq = fn (haystack: [ i64 ], needle: [ i64 ]) -> bool do
  return find_subseq_go(haystack, needle, offset: 0, total: list_length(xs: haystack))
end

let find_subseq_go = fn (haystack: [ i64 ], needle: [ i64 ], offset: i64, total: i64) -> bool do
  let nlen = list_length(xs: needle)
  if offset + nlen > total then return false end
  if matches_at(haystack, needle, offset) then return true end
  return find_subseq_go(haystack, needle, offset: offset + 1, total)
end

let matches_at = fn (haystack: [ i64 ], needle: [ i64 ], offset: i64) -> bool do
  return matches_at_go(haystack, needle, h_idx: offset, n_idx: 0, nlen: list_length(xs: needle))
end

let matches_at_go = fn (haystack: [ i64 ], needle: [ i64 ], h_idx: i64, n_idx: i64, nlen: i64) -> bool do
  if n_idx >= nlen then return true end
  if nth(xs: haystack, idx: h_idx) != nth(xs: needle, idx: n_idx) then return false end
  return matches_at_go(haystack, needle, h_idx: h_idx + 1, n_idx: n_idx + 1, nlen)
end

let body = fn () -> unit throws { Exn } do
  // Build the preview2 component wrapping the minimal core wasm.
  let %core = minimal_core_wasm()
  let %component = build_p2_component(
    core_wasm: %core,
    wasi_iface: "wasi:cli/run@0.2.0",
    run_func_export: "wasi:cli/run@0.2.6#run",
    has_fs: false,
    has_net: false,
    has_server: false
  )
  let bytes = read_all(buf: &component)
  bb.free(buf: %component)

  // ── Check 1: component magic + version ──
  // Magic: 0x00 0x61 0x73 0x6d
  test_assert.assert_eq_i64(actual: nth(xs: bytes, idx: 0), expected: 0, label: "magic[0]")
  test_assert.assert_eq_i64(actual: nth(xs: bytes, idx: 1), expected: 97, label: "magic[1]")
  test_assert.assert_eq_i64(actual: nth(xs: bytes, idx: 2), expected: 115, label: "magic[2]")
  test_assert.assert_eq_i64(actual: nth(xs: bytes, idx: 3), expected: 109, label: "magic[3]")
  // Component version: 0x0d 0x00 0x01 0x00
  test_assert.assert_eq_i64(actual: nth(xs: bytes, idx: 4), expected: 13, label: "version[0]=0x0d")
  test_assert.assert_eq_i64(actual: nth(xs: bytes, idx: 5), expected: 0, label: "version[1]=0x00")
  test_assert.assert_eq_i64(actual: nth(xs: bytes, idx: 6), expected: 1, label: "version[2]=0x01")
  test_assert.assert_eq_i64(actual: nth(xs: bytes, idx: 7), expected: 0, label: "version[3]=0x00")

  // ── Check 2: byte 8 is component type section (cm_sec_type = 7) ──
  // The first section after the header is a component type section (WASI interfaces).
  test_assert.assert_eq_i64(actual: nth(xs: bytes, idx: 8), expected: 7,
    label: "byte 8 is component type section id (0x07)")

  // ── Check 3: component contains wasm magic in at least one embedded core module ──
  // The stub module starts with wasm magic: 0x00 0x61 0x73 0x6d = 0 97 115 109
  test_assert.assert_true(
    cond: find_subseq(haystack: bytes, needle: [ 0, 97, 115, 109, 1, 0, 0, 0 ]),
    label: "component contains embedded wasm magic (00 61 73 6d 01 00 00 00)")

  // ── Check 4: component contains "fd_write" string (in adapter module) ──
  // "fd_write" ascii: 102 100 95 119 114 105 116 101
  test_assert.assert_true(
    cond: find_subseq(haystack: bytes, needle: [ 102, 100, 95, 119, 114, 105, 116, 101 ]),
    label: "component contains 'fd_write' string (adapter module)")

  // ── Check 5: component contains "get-stdout" string (p2 import name) ──
  // "get-stdout" ascii: 103 101 116 45 115 116 100 111 117 116
  test_assert.assert_true(
    cond: find_subseq(haystack: bytes, needle: [ 103, 101, 116, 45, 115, 116, 100, 111, 117, 116 ]),
    label: "component contains 'get-stdout' import name")

  // ── Check 6: component type section contains result<none,none> ──
  // result<none,none> encoding: 0x6a 0x00 0x00 (106 0 0)
  test_assert.assert_true(
    cond: find_subseq(haystack: bytes, needle: [ 106, 0, 0 ]),
    label: "type section contains result<none,none> (6a 00 00)")

  // ── Check 7: component export section (id=0x0b=11) contains interface name ──
  // "wasi:cli/run@0.2.0" = 18 bytes ascii
  // bytes: 119 97 115 105 58 99 108 105 47 114 117 110 64 48 46 50 46 48
  test_assert.assert_true(
    cond: find_subseq(haystack: bytes, needle: [ 119, 97, 115, 105, 58, 99, 108, 105, 47,
                                                114, 117, 110, 64, 48, 46, 50, 46, 48 ]),
    label: "export section contains 'wasi:cli/run@0.2.0' name")

  // ── Check 8: component contains "run" export name (instance section) ──
  // "run" ascii: 114 117 110
  test_assert.assert_true(
    cond: find_subseq(haystack: bytes, needle: [ 114, 117, 110 ]),
    label: "instance section contains 'run' export name")

  // ── Check 9: canon lower section present (cm_sec_canon = 8) ──
  // Canon lower get-stdout: section_id=8, len=5, count=1, lower=1, func_idx=0, opts=0
  test_assert.assert_true(
    cond: find_subseq(haystack: bytes, needle: [ 8, 5, 1, 1, 0, 0, 0 ]),
    label: "canon section contains lower(get-stdout) entry (08 05 01 01 00 00 00)")

  // ── Check 10: core instance section present (cm_sec_core_instance = 2) ──
  // The stub instantiation: section_id=2, len=4, count=1, kind=Instantiate(0)
  test_assert.assert_true(
    cond: find_subseq(haystack: bytes, needle: [ 2, 4, 1, 0, 0, 0 ]),
    label: "component contains core instance section (02 04 01 00 00 00)")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
