// bd: nexus-hc62 (P3 parallel future<T>)
// Smoke-test: force_all in a --p3-component build produces the correct output.
// When --p3-component is specified the compiler wraps the core wasm in a
// component-model binary; this test verifies the component executes correctly
// via wasmtime -S p3=y.
import * as test_assert from "std:test/assert"
import { force_all } from "std:lazy"

let body = fn () -> unit throws { Exn } do
  let @t1 = 10
  let @t2 = 20
  let @t3 = 30
  let xs = force_all(tasks: [t1, t2, t3])
  test_assert.assert_eq_i64_list(actual: xs, expected: [10, 20, 30],
    label: "force_all preserves input order in p3-component build")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
