// Verify that a RAW (non-escaped) multibyte char literal lexes to its full
// Unicode scalar value, not just its first UTF-8 byte (nexus-iuijv).
//
// Before the fix, the lexer read a single byte for a raw char literal, so
// 'é' (UTF-8 C3 A9) -> 195, '€' (E2 82 AC) -> 226, '😀' (F0 9F 98 80) -> 240.
// The escaped forms ('\u{...}', '\xNN') and string literals were already
// correct, so a raw multibyte char silently disagreed with the same character
// via str.char_at and a `match` against it never fired.
import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as char from "std:char"

let body = fn () -> unit throws { Exn } do
  // Raw multibyte char literals == their Unicode scalar value.
  test_assert.assert_eq_i64(actual: char.ord(c: 'é'),  expected: 233,    label: "'é' == 233 (2-byte)")
  test_assert.assert_eq_i64(actual: char.ord(c: '€'),  expected: 8364,   label: "'€' == 8364 (3-byte)")
  test_assert.assert_eq_i64(actual: char.ord(c: '😀'), expected: 128512, label: "'😀' == 128512 (4-byte)")

  // ASCII char literals (1-byte) must be unchanged.
  test_assert.assert_eq_i64(actual: char.ord(c: 'a'), expected: 97, label: "'a' == 97 (ASCII)")
  test_assert.assert_eq_i64(actual: char.ord(c: 'Z'), expected: 90, label: "'Z' == 90 (ASCII)")

  // An ASCII char literal that FOLLOWS a multibyte one must still be correct
  // (regression guard: the decode must not desync the lexer's byte position).
  test_assert.assert_eq_i64(actual: char.ord(c: '🦀'), expected: 129408, label: "'🦀' == 129408 (4-byte)")
  test_assert.assert_eq_i64(actual: char.ord(c: 'x'),  expected: 120,    label: "'x' == 120 after multibyte")

  // Raw form must equal the escaped form for the same scalar.
  test_assert.assert_eq_i64(actual: char.ord(c: '\u{E9}'),    expected: 233,    label: "'\\u{E9}' == 233")
  test_assert.assert_eq_i64(actual: char.ord(c: '\u{20AC}'),  expected: 8364,   label: "'\\u{20AC}' == 8364")
  test_assert.assert_eq_i64(actual: char.ord(c: '\u{1F600}'), expected: 128512, label: "'\\u{1F600}' == 128512")
  test_assert.assert_eq_i64(actual: char.ord(c: '\xFF'),      expected: 255,    label: "'\\xFF' == 255 (escaped control)")
  test_assert.assert_true(cond: char.ord(c: 'é') == char.ord(c: '\u{E9}'), label: "raw 'é' == escaped '\\u{E9}'")

  // A match on the decoded char from a string must fire against a raw literal.
  let from_str = str.char_at(s: "été", idx: 0)
  let cls = match from_str do | 'é' -> "matched" | _ -> "fell-through" end
  test_assert.assert_eq_string(actual: cls, expected: "matched", label: "match str.char_at(\"été\",0) vs 'é' fires")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
