// Verify that extract_module_doc handles nested block comments inside
// a doc comment (nexus-i87e).  scan_to_close_star_slash must track nesting
// depth so that an inner `*/` does not prematurely close the outer doc.
import * as lexer from "src/frontend/lexer.nx"
import * as test_assert from "std:test/assert"
import { Option, Some, None } from "std:option"

let assert_some_eq = fn (opt: Option<string>, expected: string, label: string) -> unit throws { Exn } do
  match opt do
    | None -> throw RuntimeError(val: "expected Some, got None: " ++ label)
    | Some(val: s) -> test_assert.assert_eq_string(actual: s, expected, label)
  end
end

let assert_none = fn (opt: Option<string>, label: string) -> unit throws { Exn } do
  match opt do
    | None -> return ()
    | Some(val: _) -> throw RuntimeError(val: "expected None, got Some: " ++ label)
  end
end

let body = fn () -> unit throws { Exn } do
  // Non-nested: simple doc comment
  let src1 = "/** hello */"
  assert_some_eq(opt: lexer.extract_module_doc(src: src1), expected: " hello ", label: "simple doc comment")

  // Nested: inner `/* ... */` must not close the outer doc.
  // Body between `/**` and the final `*/` is " outer /* inner */ outer ".
  let src2 = "/** outer /* inner */ outer */"
  assert_some_eq(opt: lexer.extract_module_doc(src: src2), expected: " outer /* inner */ outer ", label: "nested inner comment preserved")

  // Empty-ish block comment `/**/` is not a doc comment (fourth byte is /).
  let src3 = "/**/"
  assert_none(opt: lexer.extract_module_doc(src: src3), label: "/**/ is not a doc comment")

  // Unterminated doc comment returns None.
  let src4 = "/** unterminated"
  assert_none(opt: lexer.extract_module_doc(src: src4), label: "unterminated doc comment")

  // R-5 workaround: keep std:str alive so the bundler links stdlib.
  test_assert.assert_eq_i64(actual: 1, expected: 1, label: "stdlib-link tripwire")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
