// Regression test for nexus-n47aq: nested generic type arguments whose closing
// `>>` (or `>>>`) the lexer fuses into a single right-shift token.
//
// Before the fix, `Option<Option<i64>>` failed to parse with
// `expected >, got '>>'`: the two adjacent closing `>` were lexed as one
// `TkShr` token, which `parse_type_args` (src/frontend/parser/type.nx) never
// recognised as a list terminator. The C++-style workaround `Option<Option<i64> >`
// (with a space) parsed fine, confirming the token-fusion cause.
//
// The fix splits a `>>` at a type-argument close site: it consumes ONE `>` to
// close the current list and rewrites the stream head to a `TkGt` (at the
// second `>`'s position) for the enclosing list. Chained depth `A<B<C<T>>>`
// works because the lexer is greedy two-at-a-time, so `>>>` is `TkShr` + `TkGt`.
//
// This fixture pins BOTH directions:
//   - nested generic signatures (return type, param type, 2- and 3-deep, mixed
//     multi-arg) now parse, type-check, and run; AND
//   - the `>>` / `<<` SHIFT operators in EXPRESSION position are unaffected
//     (the split fires only in type position, after a `<` has been consumed).
import * as test_assert from "std:test/assert"

type Pair<A, B> = MkPair(fst: A, snd: B)

// --- nested generic in return position (2-deep) ---
let make_oo = fn () -> Option<Option<i64>> do
  return Some(val: Some(val: 5))
end

// --- nested generic in PARAM position (2-deep) ---
let unwrap_oo = fn (o: Option<Option<i64>>) -> i64 do
  match o do
    | Some(val: Some(val: n)) -> return n
    | _ -> return 0
  end
end

// --- 3-deep nesting (`>>>` → TkShr + TkGt) ---
let make_ooo = fn () -> Option<Option<Option<i64>>> do
  return Some(val: Some(val: Some(val: 7)))
end

let unwrap_ooo = fn (o: Option<Option<Option<i64>>>) -> i64 do
  match o do
    | Some(val: Some(val: Some(val: n))) -> return n
    | _ -> return 0
  end
end

// --- mixed multi-arg generic ending in a nested generic (`Option<i64>>`) ---
let make_pair = fn () -> Pair<i64, Option<i64>> do
  return MkPair(fst: 3, snd: Some(val: 4))
end

let pair_sum = fn (p: Pair<i64, Option<i64>>) -> i64 do
  match p do
    | MkPair(fst: a, snd: Some(val: b)) -> return a + b
    | MkPair(fst: a, snd: None) -> return a
  end
end

// --- a generic whose inner arg is itself multi-arg, then nested (`Pair<i64, Pair<i64, i64>>`) ---
let nested_pair_sum = fn (p: Pair<i64, Pair<i64, i64>>) -> i64 do
  match p do
    | MkPair(fst: a, snd: MkPair(fst: b, snd: c)) -> return a + b + c
  end
end

let body = fn () -> unit throws { Exn } do
  // Nested generics parse, type-check, and round-trip at runtime.
  test_assert.assert_eq_i64(
    actual: unwrap_oo(o: make_oo()),
    expected: 5,
    label: "n47aq: Option<Option<i64>> (return + param) round-trips"
  )
  test_assert.assert_eq_i64(
    actual: unwrap_ooo(o: make_ooo()),
    expected: 7,
    label: "n47aq: Option<Option<Option<i64>>> (3-deep, >>> split) round-trips"
  )
  test_assert.assert_eq_i64(
    actual: pair_sum(p: make_pair()),
    expected: 7,
    label: "n47aq: Pair<i64, Option<i64>> mixed multi-arg nested generic"
  )
  test_assert.assert_eq_i64(
    actual: nested_pair_sum(p: MkPair(fst: 10, snd: MkPair(fst: 20, snd: 30))),
    expected: 60,
    label: "n47aq: Pair<i64, Pair<i64, i64>> nested multi-arg generic"
  )

  // Regression guard: `>>` and `<<` as SHIFT operators in EXPRESSION position
  // must be completely unaffected by the type-position `>>` split.
  test_assert.assert_eq_i64(
    actual: 256 >> 2,
    expected: 64,
    label: "n47aq guard: 256 >> 2 == 64 (right shift still works)"
  )
  test_assert.assert_eq_i64(
    actual: 1 << 4 >> 1,
    expected: 8,
    label: "n47aq guard: 1 << 4 >> 1 == 8 (left+right shift still works)"
  )
  test_assert.assert_eq_i64(
    actual: 1024 >> 3 >> 2,
    expected: 32,
    label: "n47aq guard: 1024 >> 3 >> 2 == 32 (chained right shift)"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
