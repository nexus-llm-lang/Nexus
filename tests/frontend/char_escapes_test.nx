// Verify that char literals accept the same escape sequences as string
// literals: \a \b \v \f \e (named), \xNN (hex), \NNN (octal) (nexus-josv).
import * as test_assert from "std:test/assert"
import * as char from "std:char"

let body = fn () -> unit throws { Exn } do
  // Named escapes
  test_assert.assert_eq_i64(actual: char.ord(c: '\a'), expected: 7,   label: "'\\a' == BEL (7)")
  test_assert.assert_eq_i64(actual: char.ord(c: '\b'), expected: 8,   label: "'\\b' == BS (8)")
  test_assert.assert_eq_i64(actual: char.ord(c: '\v'), expected: 11,  label: "'\\v' == VT (11)")
  test_assert.assert_eq_i64(actual: char.ord(c: '\f'), expected: 12,  label: "'\\f' == FF (12)")
  test_assert.assert_eq_i64(actual: char.ord(c: '\e'), expected: 27,  label: "'\\e' == ESC (27)")

  // Hex escape: \xFF = 255
  test_assert.assert_eq_i64(actual: char.ord(c: '\xFF'), expected: 255, label: "'\\xFF' == 255")

  // Octal escape: \377 = 0o377 = 255
  test_assert.assert_eq_i64(actual: char.ord(c: '\377'), expected: 255, label: "'\\377' == 255")

  // Octal escape: \77 = 63
  test_assert.assert_eq_i64(actual: char.ord(c: '\77'), expected: 63,  label: "'\\77' == 63")

  // Sanity: pre-existing escapes still work
  test_assert.assert_eq_i64(actual: char.ord(c: '\n'), expected: 10, label: "'\\n' == 10")
  test_assert.assert_eq_i64(actual: char.ord(c: '\t'), expected: 9,  label: "'\\t' == 9")

  // R-5 workaround: keep std:str alive so the bundler links stdlib.
  test_assert.assert_eq_i64(actual: 1, expected: 1, label: "stdlib-link tripwire")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
