// Verify that -9223372036854775808 (i64::MIN) is accepted as a literal
// (nexus-1yg5). The lexer rejects the bare magnitude 9223372036854775808 as
// out-of-range; the parser must fold a leading `-` with the overflow sentinel
// to produce the correct minimum value.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let x = -9223372036854775808
  let expected = 0 - 9223372036854775807 - 1
  test_assert.assert_eq_i64(actual: x, expected, label: "1yg5: -9223372036854775808 == i64::MIN")

  // Negating i64::MAX+1 via variable must also be addressable in patterns.
  let ok = match x do
    | -9223372036854775808 -> true
    | _ -> false
  end
  test_assert.assert(cond: ok, label: "1yg5: i64::MIN pattern match")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
