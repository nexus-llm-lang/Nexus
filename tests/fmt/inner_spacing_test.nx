// Inner-spacing: record literals `{a}` → `{ a }` and list literals
// `[a]` → `[ a ]`. Index expressions `arr[i]` must stay TIGHT. Empty
// `{}` and `[]` must stay TIGHT. All transforms must be IDEMPOTENT.

import * as test_assert from "std:test/assert"
import { format_source } from "src/tools/fmt/fmt.nx"

let check = fn (input: string, expected: string, label: string) -> unit throws { Exn } do
  let actual = format_source(src: input)
  test_assert.assert_eq_string(actual, expected, label)
  return ()
end

let check_idempotent = fn (input: string, label: string) -> unit throws { Exn } do
  let once = format_source(src: input)
  let twice = format_source(src: once)
  test_assert.assert_eq_string(actual: twice, expected: once, label)
  return ()
end

let body = fn () -> unit throws { Exn } do
  // ── Record literal spacing ─────────────────────────────────────────────
  // Tight → spaced.
  check(input: "let r = {x: 1}\n",
        expected: "let r = { x: 1 }\n",
        label: "record tight → spaced")
  // Already spaced → unchanged (idempotence).
  check(input: "let r = { x: 1 }\n",
        expected: "let r = { x: 1 }\n",
        label: "record already spaced → unchanged")
  // Empty record → stays tight.
  check(input: "let r = {}\n",
        expected: "let r = {}\n",
        label: "empty record stays tight")
  // Multiple fields.
  check(input: "let r = {x: 1, y: 2}\n",
        expected: "let r = { x: 1, y: 2 }\n",
        label: "record multi-field tight → spaced")
  // Nested record.
  check(input: "let r = {x: {y: 1}}\n",
        expected: "let r = { x: { y: 1 } }\n",
        label: "nested record tight → spaced")
  // Multiline record that fits in 100 cols: pass 3 (join) collapses it.
  // The pass-1 inner-space rule fires after joining, producing `{ x: 1 }`.
  check(input: "let r = {\n  x: 1\n}\n",
        expected: "let r = { x: 1 }\n",
        label: "short multiline record collapsed by join pass")

  // ── List literal spacing ───────────────────────────────────────────────
  // Single-element list.
  check(input: "let xs = [1]\n",
        expected: "let xs = [ 1 ]\n",
        label: "list single-element tight → spaced")
  // Multi-element list.
  check(input: "let xs = [1, 2, 3]\n",
        expected: "let xs = [ 1, 2, 3 ]\n",
        label: "list multi-element tight → spaced")
  // Already spaced list → unchanged (idempotence).
  check(input: "let xs = [ 1, 2, 3 ]\n",
        expected: "let xs = [ 1, 2, 3 ]\n",
        label: "list already spaced → unchanged")
  // Empty list → stays tight.
  check(input: "let xs = []\n",
        expected: "let xs = []\n",
        label: "empty list stays tight")
  // List type annotation.
  check(input: "let f = fn (xs: [i64]) -> unit do return () end\n",
        expected: "let f = fn (xs: [ i64 ]) -> unit do return () end\n",
        label: "list type annotation tight → spaced")
  // Nested list.
  check(input: "let m = [[1, 2], [3, 4]]\n",
        expected: "let m = [ [ 1, 2 ], [ 3, 4 ] ]\n",
        label: "nested list tight → spaced")

  // ── Index expression stays TIGHT ──────────────────────────────────────
  // Array index: `arr[i]` must NOT get spaces added.
  check(input: "let v = arr[0]\n",
        expected: "let v = arr[0]\n",
        label: "array index stays tight")
  // Index after closing paren: `foo()[i]`.
  check(input: "let v = foo()[0]\n",
        expected: "let v = foo()[0]\n",
        label: "call-result index stays tight")
  // Index after closing bracket: `xs[0][1]`.
  check(input: "let v = xs[0][1]\n",
        expected: "let v = xs[0][1]\n",
        label: "chained index stays tight")
  // Index after identifier with underscore: `my_arr[i]`.
  check(input: "let v = my_arr[i]\n",
        expected: "let v = my_arr[i]\n",
        label: "underscore-identifier index stays tight")

  // ── Array literal `[| ... |]` is left unchanged ───────────────────────
  // `[|` is a distinct token — the formatter does not add a space inside it.
  check(input: "let a = [|1, 2|]\n",
        expected: "let a = [|1, 2|]\n",
        label: "array literal [| ... |] unchanged")
  check(input: "let a = [| 1, 2 |]\n",
        expected: "let a = [| 1, 2 |]\n",
        label: "array literal [| ... |] already spaced unchanged")

  // ── Idempotence checks ─────────────────────────────────────────────────
  check_idempotent(input: "{x: 1}", label: "idempotent: record tight")
  check_idempotent(input: "{ x: 1 }", label: "idempotent: record spaced")
  check_idempotent(input: "{}", label: "idempotent: empty record")
  check_idempotent(input: "[1, 2, 3]", label: "idempotent: list tight")
  check_idempotent(input: "[ 1, 2, 3 ]", label: "idempotent: list spaced")
  check_idempotent(input: "[]", label: "idempotent: empty list")
  check_idempotent(input: "arr[i]", label: "idempotent: index")
  check_idempotent(input: "{x: {y: [1, 2]}}", label: "idempotent: nested mixed")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
