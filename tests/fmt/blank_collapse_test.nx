// Blank-line collapse: 2+ consecutive blank lines collapse to 1 blank line.

import * as test_assert from "std:test/assert"
import { format_source } from "src/tools/fmt/fmt.nx"

let check = fn (input: string, expected: string, label: string) -> unit throws { Exn } do
  let actual = format_source(src: input)
  test_assert.assert_eq_string(actual, expected, label)
  return ()
end

let body = fn () -> unit throws { Exn } do
  // Two blank lines between defs collapse to one.
  check(input: "let a = 1\n\n\nlet b = 2\n",
        expected: "let a = 1\n\nlet b = 2\n",
        label: "two blanks → one")
  // Three blank lines collapse to one.
  check(input: "let a = 1\n\n\n\nlet b = 2\n",
        expected: "let a = 1\n\nlet b = 2\n",
        label: "three blanks → one")
  // Single blank line is preserved (no over-collapse).
  check(input: "let a = 1\n\nlet b = 2\n",
        expected: "let a = 1\n\nlet b = 2\n",
        label: "single blank preserved")
  // Blank lines containing only whitespace are also considered blank
  // (trailing-ws strip runs before the blank-collapse).
  check(input: "let a = 1\n   \n\t\nlet b = 2\n",
        expected: "let a = 1\n\nlet b = 2\n",
        label: "whitespace-only lines treated as blank")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
