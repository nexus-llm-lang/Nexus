// Comments and string literals are byte-preserved. The formatter must not
// touch the interior of strings/comments — only the surrounding whitespace.

import * as test_assert from "std:test/assert"
import { format_source } from "src/tools/fmt.nx"

let check = fn (input: string, expected: string, label: string) -> unit throws { Exn } do
  let actual = format_source(src: input)
  test_assert.assert_eq_string(actual, expected, label)
  return ()
end

let body = fn () -> unit throws { Exn } do
  // Line comments are preserved (including their trailing-ws-stripped tail).
  check(input: "// hello\nlet x = 1\n",
        expected: "// hello\nlet x = 1\n",
        label: "line comment unchanged")
  // Trailing whitespace AFTER a line comment is still stripped — the comment
  // itself ends at the newline, so the strip applies to the post-comment ws.
  check(input: "// hi   \nlet x = 1\n",
        expected: "// hi\nlet x = 1\n",
        label: "trailing ws after line comment stripped")
  // Block comment with internal newlines preserved verbatim. The inner
  // indentation (whatever it is) is left alone because the bytes are in a
  // protected region.
  check(input: "/* one\n   two\n   three */\nlet x = 1\n",
        expected: "/* one\n   two\n   three */\nlet x = 1\n",
        label: "block comment preserved")
  // Nested block comment.
  check(input: "/* outer /* inner */ outer */\nlet x = 1\n",
        expected: "/* outer /* inner */ outer */\nlet x = 1\n",
        label: "nested block comment preserved")
  // String literal containing tab/space patterns must not be rewritten.
  check(input: "let s = \"hello   world\"\n",
        expected: "let s = \"hello   world\"\n",
        label: "trailing-ish spaces inside string preserved")
  // Escapes inside strings preserved (e.g. `\\\"` and `\\\\`).
  check(input: "let s = \"a\\\"b\\\\c\"\n",
        expected: "let s = \"a\\\"b\\\\c\"\n",
        label: "escaped quote and backslash preserved")
  // Char literal preserved.
  check(input: "let c = 'a'\n",
        expected: "let c = 'a'\n",
        label: "char literal preserved")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
