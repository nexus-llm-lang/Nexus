// Multi-line protected regions (block comments and bracket strings) must be
// preserved byte-for-byte by EVERY pass. The pass-1 walk already preserves
// them, but the pass-2 wrap and pass-3 join passes process the source physical
// line by physical line and used to treat a `\n` inside a block comment or
// bracket string as a code-line boundary. Code-shaped text inside such a region
// (a comma group split across lines, or a line over 100 cols) was then re-flowed
// by wrap or collapsed by join — corrupting the literal/comment content while
// still being idempotent (stable corruption). These cases lock the byte-for-byte
// guarantee in for the multi-line case.

import * as test_assert from "std:test/assert"
import { format_source } from "src/tools/fmt.nx"

// Behavior-preserving: format output must equal `expected` (here, the input,
// since nothing outside the protected region changes).
let check = fn (input: string, expected: string, label: string) -> unit throws { Exn } do
  let actual = format_source(src: input)
  test_assert.assert_eq_string(actual, expected, label)
  return ()
end

let check_idempotent = fn (input: string, label: string) -> unit throws { Exn } do
  let once = format_source(src: input)
  let twice = format_source(src: once)
  test_assert.assert_eq_string(actual: twice, expected: once, label)
  return ()
end

let body = fn () -> unit throws { Exn } do
  // A block comment whose body contains a comma group split across lines: the
  // join pass must NOT collapse `foo(\n  a,\n  b\n)` into `foo(a, b)`.
  let cmt_group = "/* note:\nfoo(\n  a,\n  b\n) */\nlet x = 1\n"
  check(input: cmt_group, expected: cmt_group, label: "block comment group body preserved")
  check_idempotent(input: cmt_group, label: "block comment group body idempotent")

  // A bracket string `[=[ ... ]=]` whose body contains the same code shape.
  let bs_group = "let v = [=[\nfoo(\n  a,\n  b\n)\n]=]\nlet w = 2\n"
  check(input: bs_group, expected: bs_group, label: "bracket string group body preserved")
  check_idempotent(input: bs_group, label: "bracket string group body idempotent")

  // A block comment containing a line that exceeds 100 columns: the wrap pass
  // must NOT break it across multiple lines (which would inject newlines into
  // the comment text).
  let cmt_long =
    "let v = 1 /*\nthecall(arg1xxxxxxxx, arg2xxxxxxxx, arg3xxxxxxxx, arg4xxxxxxxx, arg5xxxxxxxx, arg6xxxxxxxx, arg7xxxxxxxx, x)\n*/\n"
  check(input: cmt_long, expected: cmt_long, label: "block comment long line not wrapped")
  check_idempotent(input: cmt_long, label: "block comment long line idempotent")

  // A bracket string body with a multi-line group whose item lines carry
  // interior whitespace: the join pass used to collapse the group AND trim the
  // whitespace. The literal bytes (whitespace included) must be preserved.
  let bs_ws = "let v = [=[\nfoo(\n  arg1   ,\n  arg2   ,\n  arg3\n)\n]=]\nlet w = 2\n"
  check(input: bs_ws, expected: bs_ws, label: "bracket string interior whitespace preserved")
  check_idempotent(input: bs_ws, label: "bracket string interior whitespace idempotent")

  // Code that trails a multi-line block comment on the comment's final line is
  // still formatted normally on subsequent lines (the region ends at `*/`).
  let trailing = "let a = 1 /* c\nmore */\nlet b = foo( x )\n"
  check_idempotent(input: trailing, label: "code after multiline comment idempotent")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
