// Pass-3 join: groups containing inline comments must NOT be collapsed.
//
// A `//` or `/* */` comment on an item line or the closer line causes the
// rest of the line to be treated as a comment by the compiler, so joining
// would corrupt the output (e.g. `foo(a: 1, // note, b: 2)` is invalid —
// `, b: 2)` is commented out). The fix: refuse to join any group whose item
// or closer line contains a real comment (not inside a string literal).
//
// String literals that happen to contain `//` or `/*` must still join fine.

import * as test_assert from "std:test/assert"
import { format_source } from "src/tools/fmt.nx"

let check = fn (input: string, expected: string, label: string) -> unit throws { Exn } do
  let actual = format_source(src: input)
  test_assert.assert_eq_string(actual, expected, label)
  return ()
end

let check_idempotent = fn (input: string, label: string) -> unit throws { Exn } do
  let once = format_source(src: input)
  let twice = format_source(src: once)
  test_assert.assert_eq_string(actual: twice, expected: once, label)
  return ()
end

let body = fn () -> unit throws { Exn } do
  // ── Line comment on non-last item: group stays expanded ───────────────
  let with_comment_mid = "let r = add(\n  a: 1, // note\n  b: 2\n)\n"
  check(
    input: with_comment_mid,
    expected: with_comment_mid,
    label: "// on non-last item: group stays expanded"
  )

  // ── Line comment on last item: group stays expanded ────────────────────
  let with_comment_last = "let r = add(\n  a: 1,\n  b: 2 // last\n)\n"
  check(
    input: with_comment_last,
    expected: with_comment_last,
    label: "// on last item: group stays expanded"
  )

  // ── Block comment on item: group stays expanded ────────────────────────
  let with_block_comment = "let r = add(\n  a: 1, /* x */\n  b: 2\n)\n"
  check(
    input: with_block_comment,
    expected: with_block_comment,
    label: "/* */ on item: group stays expanded"
  )

  // ── Line comment in a list literal: group stays expanded ──────────────
  let list_with_comment = "let xs = [\n  1, // one\n  2,\n  3\n]\n"
  check(
    input: list_with_comment,
    expected: list_with_comment,
    label: "// in list: group stays expanded"
  )

  // ── Line comment in a record/ctor: group stays expanded ───────────────
  let record_with_comment = "let p = Pt(\n  x: 10, // x coord\n  y: 20\n)\n"
  check(
    input: record_with_comment,
    expected: record_with_comment,
    label: "// in record: group stays expanded"
  )

  // ── Non-regression: `//` INSIDE a string literal must still join ──────
  // The `//` is a code character inside a string, not a comment.
  check(
    input: "let r = add(\n  a: \"http://x\",\n  b: 2\n)\n",
    expected: "let r = add(a: \"http://x\", b: 2)\n",
    label: "// inside string literal still joins (no false positive)"
  )

  // ── Idempotency: comment-bearing groups stay stable ───────────────────
  check_idempotent(input: with_comment_mid, label: "idempotent: // on mid item")
  check_idempotent(input: with_comment_last, label: "idempotent: // on last item")
  check_idempotent(input: with_block_comment, label: "idempotent: /* */ on item")
  check_idempotent(input: list_with_comment, label: "idempotent: // in list")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
