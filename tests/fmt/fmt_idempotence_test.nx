// Idempotence: format(format(src)) == format(src) for every source. If this
// breaks, the formatter is unstable and unsafe to wire into CI as `--check`.

import * as test_assert from "std:test/assert"
import { format_source } from "src/fmt.nx"

let check_idempotent = fn (input: string, label: string) -> unit throws { Exn } do
  let once = format_source(src: input)
  let twice = format_source(src: once)
  test_assert.assert_eq_string(actual: twice, expected: once, label)
  return ()
end

let body = fn () -> unit throws { Exn } do
  check_idempotent(input: "let x = 1\n", label: "simple let")
  check_idempotent(input: "let x = 1   \nlet y = 2\t\n", label: "trailing ws")
  check_idempotent(input: "\t\tlet x = 1\n", label: "leading tabs")
  check_idempotent(input: "let a = 1\n\n\n\nlet b = 2\n", label: "blank collapse")
  check_idempotent(input: "// hello\n\n\n// world\nlet x = 1\n", label: "comment + blank")
  check_idempotent(input: "let s = \"a   b\"\nlet c = 'x'\n", label: "string + char")
  check_idempotent(input: "/* block\n   continued */\nlet x = 1\n", label: "block comment")
  check_idempotent(input: "let x = 1", label: "no trailing newline")
  check_idempotent(input: "", label: "empty input")
  check_idempotent(input: "\n\n\n", label: "only newlines")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
