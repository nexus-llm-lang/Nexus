// Regression test for nexus-5c37g.
//
// The pass-3 join collapser must NOT treat a single expression split across
// lines at the canonical +2 indent as a comma-separated list. It previously
// classified every continuation line at `opener_indent + 2` as a list item
// PURELY BY INDENTATION and re-joined with ", ", injecting a spurious comma
// that corrupts valid source into non-parsing code (E1001).
//
// Correct contract (matching what wrap_long_lines emits in emit_items): every
// NON-FINAL item line of a joinable comma group ends in `,`. If any non-final
// item line does not, the group is a single continued expression, not a list,
// and join must leave it untouched.

import * as test_assert from "std:test/assert"
import { format_source } from "src/tools/fmt.nx"

let check = fn (input: string, expected: string, label: string) -> unit throws { Exn } do
  let actual = format_source(src: input)
  test_assert.assert_eq_string(actual, expected, label)
  return ()
end

let check_idempotent = fn (input: string, label: string) -> unit throws { Exn } do
  let once = format_source(src: input)
  let twice = format_source(src: once)
  test_assert.assert_eq_string(actual: twice, expected: once, label)
  return ()
end

let body = fn () -> unit throws { Exn } do
  // ── (a) The 3 corruption shapes: NO comma must be injected ─────────────
  // A parenthesized binary expression broken across lines. The two fragments
  // `1 +` and `2` are one expression, NOT two comma items. join must NOT
  // splice a comma between them. (It may or may not collapse the lines, but
  // it must never produce `(1 +, 2)`.)
  check(
    input: "let x = (\n  1 +\n  2\n)\n",
    expected: "let x = (\n  1 +\n  2\n)\n",
    label: "5c37g: paren continued-expr not comma-joined"
  )

  // List literal where one element is itself a continued binary expression.
  // `1 +` and `2` are fragments of element 0; only the `,` before `10`
  // separates real items. Must not become `[ 1 +, 2, 10 ]`.
  check(
    input: "let x = [\n  1 +\n  2,\n  10\n]\n",
    expected: "let x = [\n  1 +\n  2,\n  10\n]\n",
    label: "5c37g: list continued-expr element not split"
  )

  // Record literal where a field value is a continued binary expression.
  // `2 +` and `3` are fragments of field `b`. Must not become `{ a: 1, b: 2 +, 3 }`.
  check(
    input: "let x = {\n  a: 1,\n  b: 2 +\n  3\n}\n",
    expected: "let x = {\n  a: 1,\n  b: 2 +\n  3\n}\n",
    label: "5c37g: record continued-expr field not split"
  )

  // ── (b) GUARD: genuine comma lists must still join ─────────────────────
  // Every non-final item ends in a comma -> a real list -> join collapses it.
  check(
    input: "let x = foo(\n  a,\n  b\n)\n",
    expected: "let x = foo(a, b)\n",
    label: "5c37g guard: genuine comma call still joins"
  )
  check(
    input: "let xs = [\n  a,\n  b,\n  c\n]\n",
    expected: "let xs = [ a, b, c ]\n",
    label: "5c37g guard: genuine comma list still joins"
  )
  check(
    input: "let r = {\n  x: 1,\n  y: 2\n}\n",
    expected: "let r = { x: 1, y: 2 }\n",
    label: "5c37g guard: genuine comma record still joins"
  )
  // Single-item group (no trailing comma, but it IS the final item) still joins.
  check(
    input: "let x = foo(\n  a\n)\n",
    expected: "let x = foo(a)\n",
    label: "5c37g guard: single-item call still joins"
  )

  // ── (c) Idempotence on the continued-expr shapes ───────────────────────
  check_idempotent(input: "let x = (\n  1 +\n  2\n)\n", label: "5c37g idem: paren continued")
  check_idempotent(input: "let x = [\n  1 +\n  2,\n  10\n]\n", label: "5c37g idem: list continued")
  check_idempotent(
    input: "let x = {\n  a: 1,\n  b: 2 +\n  3\n}\n",
    label: "5c37g idem: record continued"
  )
  // ...and idempotence still holds for the joined genuine-list output.
  check_idempotent(input: "let x = foo(a, b)\n", label: "5c37g idem: joined call")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
