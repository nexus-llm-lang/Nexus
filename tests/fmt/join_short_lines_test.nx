// Pass 3 (join_broken_lines): collapse over-broken groups back to one line.
//
// When a call/list/record is expanded across multiple lines but the joined
// form fits within 100 cols, fmt collapses it. This is the inverse of the
// wrap pass and the two compose to a fixpoint.
//
// Idempotency: format(format(src)) == format(src) for every example.
// Compose-with-wrap: starting from either the one-line or the multi-line form
// must reach the same canonical output.

import * as test_assert from "std:test/assert"
import { format_source } from "src/tools/fmt/fmt.nx"

let check = fn (input: string, expected: string, label: string) -> unit throws { Exn } do
  let actual = format_source(src: input)
  test_assert.assert_eq_string(actual, expected, label)
  return ()
end

let check_idempotent = fn (input: string, label: string) -> unit throws { Exn } do
  let once = format_source(src: input)
  let twice = format_source(src: once)
  test_assert.assert_eq_string(actual: twice, expected: once, label)
  return ()
end

// check_canonical: both the single-line form and the expanded form of the
// same group should produce the same canonical output after formatting.
let check_canonical = fn (
  single_line: string,
  expanded: string,
  expected: string,
  label: string
) -> unit throws { Exn } do
  let from_single = format_source(src: single_line)
  let from_expanded = format_source(src: expanded)
  test_assert.assert_eq_string(actual: from_single, expected, label: label ++ " (from single)")
  test_assert.assert_eq_string(actual: from_expanded, expected, label: label ++ " (from expanded)")
  return ()
end

let body = fn () -> unit throws { Exn } do
  // ── Short function call: unchanged (already fits) ──────────────────────
  check(input: "let x = foo(a, b)\n",
        expected: "let x = foo(a, b)\n",
        label: "short call unchanged")

  // ── Over-broken call: join it back ────────────────────────────────────
  // Expanded form for a call that fits on one line when joined.
  check(
    input: "let x = foo(\n  a,\n  b\n)\n",
    expected: "let x = foo(a, b)\n",
    label: "over-broken call joined back"
  )

  // ── Over-broken list: join with inner spaces ──────────────────────────
  check(
    input: "let xs = [\n  a,\n  b,\n  c\n]\n",
    expected: "let xs = [ a, b, c ]\n",
    label: "over-broken list joined with inner spaces"
  )

  // ── Over-broken record: join with inner spaces ────────────────────────
  check(
    input: "let r = {\n  x: 1,\n  y: 2\n}\n",
    expected: "let r = { x: 1, y: 2 }\n",
    label: "over-broken record joined with inner spaces"
  )

  // ── Single-item group: also joinable ──────────────────────────────────
  check(
    input: "let x = foo(\n  a\n)\n",
    expected: "let x = foo(a)\n",
    label: "single-item call joined"
  )

  // ── Group still > 100 cols when joined: NOT collapsed ─────────────────
  // Items are long enough that the joined form would exceed 100 cols.
  // wrap_long_lines already broke it; join should leave it expanded.
  let long_call_expanded = "let result = some_function(\n  argument_one: value_one,\n  argument_two: value_two,\n  argument_three: value_three\n)\n"
  check(
    input: long_call_expanded,
    expected: long_call_expanded,
    label: "too-long-to-join group stays expanded"
  )

  // ── Indented over-broken call: join preserves indent ──────────────────
  check(
    input: "  let x = foo(\n    a,\n    b\n  )\n",
    expected: "  let x = foo(a, b)\n",
    label: "indented over-broken call joined"
  )

  // ── Closer with suffix: suffix preserved ──────────────────────────────
  // e.g. `)` followed by ` end` or other tokens
  check(
    input: "let x = foo(\n  a,\n  b\n) end\n",
    expected: "let x = foo(a, b) end\n",
    label: "closer with suffix preserved on join"
  )

  // ── Canonical form: single line and expanded form converge ────────────
  check_canonical(
    single_line: "let x = foo(a, b)\n",
    expanded: "let x = foo(\n  a,\n  b\n)\n",
    expected: "let x = foo(a, b)\n",
    label: "call canonical"
  )

  check_canonical(
    single_line: "let xs = [ a, b, c ]\n",
    expanded: "let xs = [\n  a,\n  b,\n  c\n]\n",
    expected: "let xs = [ a, b, c ]\n",
    label: "list canonical"
  )

  check_canonical(
    single_line: "let r = { x: 1, y: 2 }\n",
    expanded: "let r = {\n  x: 1,\n  y: 2\n}\n",
    expected: "let r = { x: 1, y: 2 }\n",
    label: "record canonical"
  )

  // ── Long call: canonical form is always expanded ───────────────────────
  // A call that does NOT fit on one line stays expanded regardless of input.
  let long_single = "let result = some_function(argument_one: value_one, argument_two: value_two, argument_three: value_three)\n"
  check_canonical(
    single_line: long_single,
    expanded: long_call_expanded,
    expected: long_call_expanded,
    label: "long call canonical is always expanded"
  )

  // ── Nested groups: inner joins first, then outer joins ────────────────
  // The join pass loops to fixpoint: first pass joins the inner group
  // (inner(a, b)), second pass joins the outer group since items now fit.
  check(
    input: "let x = outer(\n  inner(\n    a,\n    b\n  ),\n  c\n)\n",
    expected: "let x = outer(inner(a, b), c)\n",
    label: "nested: inner joins then outer joins (fixpoint)"
  )

  // ── Idempotency: single-line inputs unchanged ──────────────────────────
  check_idempotent(input: "let x = foo(a, b)\n", label: "idempotent: short call")
  check_idempotent(input: "let xs = [ a, b, c ]\n", label: "idempotent: short list")
  check_idempotent(input: "let r = { x: 1, y: 2 }\n", label: "idempotent: short record")

  // ── Idempotency: expanded inputs that should stay expanded ────────────
  check_idempotent(input: long_call_expanded, label: "idempotent: long call expanded")

  // ── Idempotency: over-broken → join → stable ──────────────────────────
  check_idempotent(input: "let x = foo(\n  a,\n  b\n)\n", label: "idempotent: over-broken call")
  check_idempotent(input: "let xs = [\n  a,\n  b,\n  c\n]\n", label: "idempotent: over-broken list")

  // ── Empty group inside expanded wrapper: bail out ─────────────────────
  // An item line that is blank should not cause a join.
  check(
    input: "let x = foo(\n  a\n)\n",
    expected: "let x = foo(a)\n",
    label: "single item no trailing comma"
  )

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
