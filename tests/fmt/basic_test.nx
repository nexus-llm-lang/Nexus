// Basic transforms: tab→2-space indent, trailing-whitespace strip, single
// trailing newline. Exercises the four core v1 cleanup rules.

import * as test_assert from "std:test/assert"
import { format_source } from "src/tools/fmt.nx"

let check = fn (input: string, expected: string, label: string) -> unit throws { Exn } do
  let actual = format_source(src: input)
  test_assert.assert_eq_string(actual, expected, label)
  return ()
end

let body = fn () -> unit throws { Exn } do
  // 1. Trailing whitespace stripped.
  check(input: "let x = 1   \nlet y = 2\n",
        expected: "let x = 1\nlet y = 2\n",
        label: "strip trailing space")
  // 2. Trailing tab stripped.
  check(input: "let x = 1\t\nlet y = 2\n",
        expected: "let x = 1\nlet y = 2\n",
        label: "strip trailing tab")
  // 3. Tab leading indent → 2 spaces. (Single tab → 2 spaces.)
  check(input: "fn foo() ->\n\treturn 1\nend\n",
        expected: "fn foo() ->\n  return 1\nend\n",
        label: "leading tab → 2 spaces")
  // 4. Multiple leading tabs each expand to 2 spaces.
  check(input: "do\n\t\treturn 1\nend\n",
        expected: "do\n    return 1\nend\n",
        label: "two leading tabs → 4 spaces")
  // 5. Missing trailing newline is added.
  check(input: "let x = 1",
        expected: "let x = 1\n",
        label: "add missing trailing newline")
  // 6. Multiple trailing newlines collapsed to one.
  check(input: "let x = 1\n\n\n\n",
        expected: "let x = 1\n",
        label: "collapse trailing newlines")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
