// Line-wrapping: lines exceeding 100 columns are broken at the first
// comma-separated group at the outermost nesting level.
//
// Idempotency: format(format(src)) == format(src) for every example.
// Behavior-preserving: only whitespace changes; tokens are identical.

import * as test_assert from "std:test/assert"
import { format_source } from "src/tools/fmt/fmt.nx"

let max_len = 100

let check = fn (input: string, expected: string, label: string) -> unit throws { Exn } do
  let actual = format_source(src: input)
  test_assert.assert_eq_string(actual, expected, label)
  return ()
end

let check_idempotent = fn (input: string, label: string) -> unit throws { Exn } do
  let once = format_source(src: input)
  let twice = format_source(src: once)
  test_assert.assert_eq_string(actual: twice, expected: once, label)
  return ()
end

// Build a long line for testing: 101+ characters.
// "let result = some_function(argument_one: value_one, argument_two: value_two, argument_three: value_three)"
// is 104 chars.
let long_call = "let result = some_function(argument_one: value_one, argument_two: value_two, argument_three: value_three)\n"
let long_call_wrapped =
  "let result = some_function(\n  argument_one: value_one,\n  argument_two: value_two,\n  argument_three: value_three\n)\n"

let body = fn () -> unit throws { Exn } do
  // ── Short lines are unchanged ──────────────────────────────────────────
  check(input: "let x = foo(a, b)\n",
        expected: "let x = foo(a, b)\n",
        label: "short call unchanged")

  check(input: "let x = foo(a, b, c, d, e, f, g, h, i, j, k, l, m, n, o, p)\n",
        expected: "let x = foo(a, b, c, d, e, f, g, h, i, j, k, l, m, n, o, p)\n",
        label: "medium call under 100 unchanged")

  // ── Long function call is wrapped ────────────────────────────────────
  check(input: long_call,
        expected: long_call_wrapped,
        label: "long call wrapped at arguments")

  // ── Already-wrapped output is idempotent ─────────────────────────────
  check(input: long_call_wrapped,
        expected: long_call_wrapped,
        label: "already-wrapped call unchanged (idempotent)")

  // ── Wrapping with leading indent ─────────────────────────────────────
  // A call inside a function body (2-space indent) wraps with cont indent+2=4.
  // The line is 103 chars (> 100) so wrapping is triggered.
  check(input: "  let result = some_function(argument_one: value_one, argument_two: value_two, argument_three: here_x)\n",
        expected: "  let result = some_function(\n    argument_one: value_one,\n    argument_two: value_two,\n    argument_three: here_x\n  )\n",
        label: "long call with 2-space indent wrapped")

  // ── Empty group: not wrapped ──────────────────────────────────────────
  // A function call with no arguments — no commas, nothing to wrap.
  check(input: "let x = a_very_long_function_name_that_exceeds_the_maximum_line_length_completely()\n",
        expected: "let x = a_very_long_function_name_that_exceeds_the_maximum_line_length_completely()\n",
        label: "long call no args not wrapped (no commas)")

  // ── List literal wrapping ─────────────────────────────────────────────
  // 108 chars (> 100) so wrapping is triggered.
  check(input: "let xs = [ element_one, element_two, element_three, element_four, element_five, element_six, element_seven ]\n",
        expected: "let xs = [\n  element_one,\n  element_two,\n  element_three,\n  element_four,\n  element_five,\n  element_six,\n  element_seven\n]\n",
        label: "long list literal wrapped")

  // ── Record literal wrapping ───────────────────────────────────────────
  // 101 chars (> 100) so wrapping is triggered.
  check(input: "let r = { field_one: value_one, field_two: value_two, field_three: value_three, field_four: value4x }\n",
        expected: "let r = {\n  field_one: value_one,\n  field_two: value_two,\n  field_three: value_three,\n  field_four: value4x\n}\n",
        label: "long record literal wrapped")

  // ── Prefix too long: skip wrapping (idempotency guard) ───────────────
  // If the prefix through the opener is already > 100 chars, wrapping is
  // skipped to avoid infinite wrap loops: the first wrapped line would itself
  // exceed 100 chars and trigger wrapping again on the second pass.
  // Here prefix_len=101 (the '(' is at index 100), so wrapping is suppressed.
  let very_long_prefix = "let x = a_very_long_ident_name_that_is_already_over_one_hundred_characters_long_and_really_exceeds_budget(a, b)\n"
  check(input: very_long_prefix,
        expected: very_long_prefix,
        label: "long prefix suppresses wrap (idempotency guard)")

  // ── Idempotency checks ────────────────────────────────────────────────
  check_idempotent(input: long_call, label: "idempotent: long call")
  check_idempotent(input: long_call_wrapped, label: "idempotent: already wrapped")
  check_idempotent(
    input: "let xs = [ element_one, element_two, element_three, element_four, element_five, element_six, element_seven ]\n",
    label: "idempotent: long list")
  check_idempotent(
    input: "  let result = some_function(argument_one: value_one, argument_two: value_two, argument_three: here_x)\n",
    label: "idempotent: indented long call")

  // ── Nested groups: outermost is wrapped first ─────────────────────────
  // foo(inner(a, b, c), bar(x, y, z)) — the outer `(` has 2 commas at depth 1.
  // 102 chars (> 100) so wrapping is triggered.
  check(input: "let x = outer_function_call(inner_function_call(a, b, c), another_call_here(x, y, z), third_arg_value)\n",
        expected: "let x = outer_function_call(\n  inner_function_call(a, b, c),\n  another_call_here(x, y, z),\n  third_arg_value\n)\n",
        label: "nested groups: outermost wrapped")

  // ── String literals inside group are left unchanged ───────────────────
  // 101 chars (> 100) so wrapping is triggered.
  check(input: "let x = fn_call(key: \"value_string_here_x\", other: \"another_string_here\", third: \"yet_another_value\")\n",
        expected: "let x = fn_call(\n  key: \"value_string_here_x\",\n  other: \"another_string_here\",\n  third: \"yet_another_value\"\n)\n",
        label: "string literals inside group preserved")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
