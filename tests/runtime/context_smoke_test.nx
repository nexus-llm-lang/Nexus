// Issue nexus-cgfd — `nexus context <file>` smoke test.
//
// Writes a small source file with imports, exports, a `main` requiring
// capabilities, and a throwing function, then drives `run_context` and
// asserts the rendered summary mentions each surface.
import * as test_assert from "std:test/assert"
import { ContextText, ContextJson, run_context } from "src/tools/context.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"
import * as str from "std:str"

let fixture_source = fn () -> string do
  return "import { Console, system_handler } from \"std:stdio\"\n"
      ++ "import * as str from \"std:str\"\n"
      ++ "\n"
      ++ "export let helper = fn (s: string) -> string do\n"
      ++ "  return s\n"
      ++ "end\n"
      ++ "\n"
      ++ "let risky = fn (n: i64) -> i64 throws { RuntimeError } do\n"
      ++ "  if n < 0 then throw RuntimeError(val: \"neg\") end\n"
      ++ "  return n\n"
      ++ "end\n"
      ++ "\n"
      ++ "let main = fn () -> unit require { PermConsole } do\n"
      ++ "  inject system_handler do\n"
      ++ "    Console.println(val: \"hi\")\n"
      ++ "  end\n"
      ++ "end\n"
end

let fixture_path = fn () -> string do
  return "./.cgfd_context_fixture.nx"
end

let write_fixture = fn () -> unit require { Fs } throws { Exn } do
  Fs.write_string(path: fixture_path(), content: fixture_source())
  return ()
end

let cleanup_fixture = fn () -> unit require { Fs } do
  try
    Fs.remove_file(path: fixture_path())
    return ()
  catch _ -> return ()
  end
end

let test_context_text = fn () -> unit require { Console, Fs } throws { Exn } do
  let out = run_context(file: fixture_path(), format: ContextText)
  // Imports section must include both import paths.
  test_assert.assert(
    cond: str.index_of(s: out, sub: "std:stdio") >= 0,
    label: "context lists std:stdio import"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "std:str") >= 0,
    label: "context lists std:str import"
  )
  // Exports must include `helper` (public). `risky` and `main` are not
  // public, so they should not appear under exports.
  test_assert.assert(
    cond: str.index_of(s: out, sub: "helper") >= 0,
    label: "context lists public 'helper' export"
  )
  // Main capabilities.
  test_assert.assert(
    cond: str.index_of(s: out, sub: "PermConsole") >= 0,
    label: "context surfaces main's PermConsole capability"
  )
  // Throwing functions.
  test_assert.assert(
    cond: str.index_of(s: out, sub: "RuntimeError") >= 0,
    label: "context surfaces risky's throws RuntimeError"
  )
  return ()
end

let test_context_json = fn () -> unit require { Console, Fs } throws { Exn } do
  let out = run_context(file: fixture_path(), format: ContextJson)
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"imports\":") >= 0,
    label: "context json carries \"imports\""
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"exports\":") >= 0,
    label: "context json carries \"exports\""
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"main_capabilities\":") >= 0,
    label: "context json carries \"main_capabilities\""
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"throwing_functions\":") >= 0,
    label: "context json carries \"throwing_functions\""
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "PermConsole") >= 0,
    label: "context json mentions PermConsole"
  )
  return ()
end

let body = fn () -> unit require { Console, Fs } throws { Exn } do
  write_fixture()
  try
    test_context_text()
    test_context_json()
    cleanup_fixture()
    return ()
  catch e ->
    cleanup_fixture()
    throw e
  end
end

let safe_run = fn () -> i64 require { Console, Fs } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole, PermFs } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
