// Regression: `==` on a generic enum at a CONCRETE structural instantiation
// (`Option<Color>`, user `Box<T>` at `Box<Color>`, nested `Option<Option<Color>>`,
// `[Option<Color>]`) compared the type-parameter payload by POINTER IDENTITY
// instead of structurally, so `Some(Red(7)) == Some(Red(7))` was `false`.
// Spec § T-Cmp mandates structural payload equality at the concrete instantiation.
import { Some, None, Option } from "std:option"
import * as test_assert from "std:test/assert"

type Color = Red(shade: i64) | Blue(depth: i64)
type Point = { x: i64, y: i64 }
type Box<T> = Wrap(v: T) | Nada

let body = fn () -> unit throws { Exn } do
  // ── Option<sum> ──
  let a = Some(val: Red(shade: 7))
  let b = Some(val: Red(shade: 7))
  let c = Some(val: Blue(depth: 9))
  test_assert.assert_eq_bool(actual: a == b, expected: true,  label: "Option<Color> equal")
  test_assert.assert_eq_bool(actual: a == c, expected: false, label: "Option<Color> differ (payload)")
  test_assert.assert_eq_bool(actual: a != c, expected: true,  label: "Option<Color> != differ")
  test_assert.assert_eq_bool(actual: a != b, expected: false, label: "Option<Color> != equal is false")

  // None vs Some (tag differs). Both operand ORDERS exercise pick_struct_sem's
  // "prefer the concrete side" in each direction (concrete-lhs and concrete-rhs).
  let n1: Option<Color> = None
  let n2: Option<Color> = None
  test_assert.assert_eq_bool(actual: n1 == n2, expected: true,  label: "Option<Color> None==None")
  test_assert.assert_eq_bool(actual: a == n1, expected: false, label: "Option<Color> Some(lhs)!=None(rhs)")
  test_assert.assert_eq_bool(actual: n1 == a, expected: false, label: "Option<Color> None(lhs)!=Some(rhs)")

  // ── Option<record> ──
  let p1 = Some(val: { x: 1, y: 2 })
  let p2 = Some(val: { x: 1, y: 2 })
  let p3 = Some(val: { x: 1, y: 9 })
  test_assert.assert_eq_bool(actual: p1 == p2, expected: true,  label: "Option<Point> equal")
  test_assert.assert_eq_bool(actual: p1 == p3, expected: false, label: "Option<Point> differ")

  // ── user generic enum Box<Color> ──
  let w1 = Wrap(v: Red(shade: 3))
  let w2 = Wrap(v: Red(shade: 3))
  let w3 = Wrap(v: Blue(depth: 3))
  test_assert.assert_eq_bool(actual: w1 == w2, expected: true,  label: "Box<Color> equal")
  test_assert.assert_eq_bool(actual: w1 == w3, expected: false, label: "Box<Color> differ")

  // ── nested Option<Option<Color>> ──
  let o1 = Some(val: Some(val: Red(shade: 5)))
  let o2 = Some(val: Some(val: Red(shade: 5)))
  let o3 = Some(val: Some(val: Blue(depth: 5)))
  test_assert.assert_eq_bool(actual: o1 == o2, expected: true,  label: "Option<Option<Color>> equal")
  test_assert.assert_eq_bool(actual: o1 == o3, expected: false, label: "Option<Option<Color>> differ")

  // ── list of Option<Color> ──
  let l1 = [Some(val: Red(shade: 1)), None]
  let l2 = [Some(val: Red(shade: 1)), None]
  let l3 = [Some(val: Red(shade: 2)), None]
  test_assert.assert_eq_bool(actual: l1 == l2, expected: true,  label: "[Option<Color>] equal")
  test_assert.assert_eq_bool(actual: l1 == l3, expected: false, label: "[Option<Color>] differ")

  // ── CONTROL: Option<i64> (primitive payload) must stay correct ──
  let i1 = Some(val: 7)
  let i2 = Some(val: 7)
  let i3 = Some(val: 8)
  test_assert.assert_eq_bool(actual: i1 == i2, expected: true,  label: "Option<i64> equal (control)")
  test_assert.assert_eq_bool(actual: i1 == i3, expected: false, label: "Option<i64> differ (control)")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
