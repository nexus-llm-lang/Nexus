// Regression test for nexus-zl2n3:
// The concrete type of a record returned through a stdlib GENERIC function must
// be recovered from the call's argument types, not only for a user-defined
// `idg<T>(x:T)->T`. Exercises two recovery shapes:
//   - `opt.unwrap_or(opt: Option<T>, default: T) -> T`  (T bound via a `T` arg)
//   - `list.head(xs: [T]) -> T`                         (T bound inside `[T]`)
// Before the fix, destructuring either result read every field from offset 0.
//
// Distinct values + NON-alphabetical declared field order (z, a, m) avoid
// masking (storage is alphabetical [a, m, z]).
import * as test_assert from "std:test/assert"
import * as opt from "std:option"
import * as list from "std:list"
import { Some } from "std:option"

type R = { z: i64, a: i64, m: i64 }

let body = fn () -> unit throws { Exn } do
  // unwrap_or: recover T from `default: T` / `opt: Option<T>`.
  let r1 = opt.unwrap_or(opt: Some(val: { z: 30, a: 1, m: 200 }), default: { z: 0, a: 0, m: 0 })
  let { z: z1, a: a1, m: m1 } = r1
  test_assert.assert_eq_i64(actual: z1, expected: 30, label: "unwrap_or-return-destructure .z")
  test_assert.assert_eq_i64(actual: a1, expected: 1, label: "unwrap_or-return-destructure .a")
  test_assert.assert_eq_i64(actual: m1, expected: 200, label: "unwrap_or-return-destructure .m")

  // head: recover T from the `[T]` element type.
  let xs = [ { z: 70, a: 8, m: 900 }, { z: 1, a: 1, m: 1 } ]
  let r2 = list.head(xs: xs)
  let { z: z2, a: a2, m: m2 } = r2
  test_assert.assert_eq_i64(actual: z2, expected: 70, label: "head-return-destructure .z")
  test_assert.assert_eq_i64(actual: a2, expected: 8, label: "head-return-destructure .a")
  test_assert.assert_eq_i64(actual: m2, expected: 900, label: "head-return-destructure .m")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
