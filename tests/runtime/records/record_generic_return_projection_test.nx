// Regression test for nexus-zl2n3:
// Field projection (`r.field`) on a record returned from a GENERIC function at
// a concrete type. The callee returns a bare type variable `T`; before the fix
// this was a HARD LIR reject (E6002 "field access on non-record semantic type")
// — the detected face of the same erasure that made record-destructure read
// offset 0. It must now COMPILE and read the correct per-field value.
//
// Distinct values + NON-alphabetical declared field order (z, a, m) avoid
// masking (storage is alphabetical [a, m, z]).
import * as test_assert from "std:test/assert"

type R = { z: i64, a: i64, m: i64 }

let idg = fn <T>(x: T) -> T do
  return x
end

let body = fn () -> unit throws { Exn } do
  let r = idg(x: { z: 30, a: 1, m: 200 })
  test_assert.assert_eq_i64(actual: r.z, expected: 30, label: "generic-return-projection .z")
  test_assert.assert_eq_i64(actual: r.a, expected: 1, label: "generic-return-projection .a")
  test_assert.assert_eq_i64(actual: r.m, expected: 200, label: "generic-return-projection .m")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
