// Regression test for nexus-7k3x2:
// Structural record returned from a function call must be destructurable
// with correct per-field values. Before the fix, all bindings collapsed
// to the first field's value (all gave offset 0) because the TyRecord
// semantic type was not preserved across the call-return boundary.
import * as test_assert from "std:test/assert"

type Trip = { a: i64, b: i64, c: i64 }

let mk = fn () -> Trip do
  return { a: 1, b: 2, c: 3 }
end

let body = fn () -> unit throws { Exn } do
  let t = mk()
  let { a: x, b: y, c: z } = t
  test_assert.assert_eq_i64(actual: x, expected: 1, label: "record-call-destructure .a")
  test_assert.assert_eq_i64(actual: y, expected: 2, label: "record-call-destructure .b")
  test_assert.assert_eq_i64(actual: z, expected: 3, label: "record-call-destructure .c")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
