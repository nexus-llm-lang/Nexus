// Regression test for nexus-zl2n3:
// A record returned from a GENERIC function at a concrete type — the callee's
// declared return type is a bare type variable `T` — must be destructurable
// with correct per-field values. Before the fix the record-ness was erased by
// the type variable, so LIR pattern lowering could not resolve field-name →
// slot offset and read EVERY field projection from offset 0 (here all three
// bindings collapsed to the alphabetically-first field `a`).
//
// Distinct values + NON-alphabetical declared field order (z, a, m) are
// deliberate: identical values or alphabetical field names would coincidentally
// mask the offset-0 scramble. Records are laid out alphabetically, so storage
// is [a, m, z] — `vz` reads slot 2, `va` slot 0, `vm` slot 1.
import * as test_assert from "std:test/assert"

type R = { z: i64, a: i64, m: i64 }

let idg = fn <T>(x: T) -> T do
  return x
end

let body = fn () -> unit throws { Exn } do
  let r = idg(x: { z: 30, a: 1, m: 200 })
  let { z: vz, a: va, m: vm } = r
  test_assert.assert_eq_i64(actual: vz, expected: 30, label: "generic-return-destructure .z")
  test_assert.assert_eq_i64(actual: va, expected: 1, label: "generic-return-destructure .a")
  test_assert.assert_eq_i64(actual: vm, expected: 200, label: "generic-return-destructure .m")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
