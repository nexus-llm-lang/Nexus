// Structural equality for `==` / `!=` on a LET-BOUND record whose FIELD is a
// sum/ADT type (spec § T-Cmp). Two independently-built equal records must
// compare TRUE by recursing into the sum field via `__streq_<enum>`, not by
// pointer identity.
//
// Regression: a constructor bound through `bind_expr_to_temp` defaulted its
// semantic type to TyI64, so the let-bound record carried `color: TyI64` and
// the field compared by heap-pointer identity. Two distinct `Green()` /
// `Circle(r:5)` allocations have different pointers → always wrongly unequal.
// The DIRECT-LITERAL operand path already worked; this covers the var-bound gap.
//
// Field values are distinct and field names are non-alphabetical (shade before
// color, but `color` < `shade` alphabetically) so a field-order scramble could
// not coincidentally mask a wrong compare.
import * as test_assert from "std:test/assert"

type Color = Red | Green | Blue
type Paint = { shade: i64, color: Color }

// Sum with a payload variant, used as a record field.
type Shape = Circle(r: i64) | Square(side: i64)
type Figure = { weight: i64, shape: Shape }

let body = fn () -> unit throws { Exn } do
  // Let-bound record with a nullary-sum field: two independent builds.
  let a = { shade: 7, color: Green }
  let b = { shade: 7, color: Green }
  let c = { shade: 7, color: Blue }
  let d = { shade: 9, color: Green }
  test_assert.assert_eq_bool(actual: a == b, expected: true, label: "record sum field equal")
  test_assert.assert_eq_bool(
    actual: a == c,
    expected: false,
    label: "record sum field unequal ctor"
  )
  test_assert.assert_eq_bool(
    actual: a == d,
    expected: false,
    label: "record sum field unequal prim"
  )
  test_assert.assert_eq_bool(actual: a != b, expected: false, label: "record sum field != equal")
  test_assert.assert_eq_bool(actual: a != c, expected: true, label: "record sum field != unequal")

  // Let-bound record with a PAYLOAD-sum field: recurse into the variant payload.
  let f1 = { weight: 4, shape: Circle(r: 5) }
  let f2 = { weight: 4, shape: Circle(r: 5) }
  let f3 = { weight: 4, shape: Circle(r: 6) }
  let f4 = { weight: 4, shape: Square(side: 5) }
  test_assert.assert_eq_bool(
    actual: f1 == f2,
    expected: true,
    label: "record payload-sum field equal"
  )
  test_assert.assert_eq_bool(
    actual: f1 == f3,
    expected: false,
    label: "record payload-sum field unequal payload"
  )
  test_assert.assert_eq_bool(
    actual: f1 == f4,
    expected: false,
    label: "record payload-sum field unequal variant"
  )
  test_assert.assert_eq_bool(
    actual: f1 != f2,
    expected: false,
    label: "record payload-sum field != equal"
  )
  test_assert.assert_eq_bool(
    actual: f1 != f3,
    expected: true,
    label: "record payload-sum field != unequal"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
