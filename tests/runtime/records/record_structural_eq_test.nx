// Structural equality for `==` / `!=` on RECORD operands (spec § T-Cmp).
// Records compare by VALUE (all fields structurally equal), not by heap-pointer
// identity. Before the fix `==` on records lowered to an i32 pointer compare, so
// two distinct-but-equal record literals wrongly reported `false`.
//
// Field values are distinct and field names are non-alphabetical (zeta/alpha,
// y/x) so a field-order scramble could not coincidentally mask a wrong compare.
import * as test_assert from "std:test/assert"

type R = { zeta: i64, alpha: i64 }
type Inner = { y: i64, x: i64 }
type Outer = { tag: i64, inner: Inner }
type Person = { age: i64, name: string }

let body = fn () -> unit throws { Exn } do
  // Equal-valued distinct literals: structurally TRUE.
  let a = { zeta: 700, alpha: 9 }
  let b = { zeta: 700, alpha: 9 }
  let c = { zeta: 700, alpha: 8 }
  test_assert.assert_eq_bool(actual: a == b, expected: true, label: "record equal")
  test_assert.assert_eq_bool(actual: a == c, expected: false, label: "record unequal field")
  test_assert.assert_eq_bool(actual: a != b, expected: false, label: "record != equal")
  test_assert.assert_eq_bool(actual: a != c, expected: true, label: "record != unequal")

  // Nested record-of-record: recurse into the inner record field.
  let o1 = { tag: 5, inner: { y: 2, x: 9 } }
  let o2 = { tag: 5, inner: { y: 2, x: 9 } }
  let o3 = { tag: 5, inner: { y: 2, x: 8 } }
  test_assert.assert_eq_bool(actual: o1 == o2, expected: true, label: "nested record equal")
  test_assert.assert_eq_bool(
    actual: o1 == o3,
    expected: false,
    label: "nested record unequal inner"
  )

  // String field: must route through the value-compare (string contents), not
  // packed-handle identity.
  let p1 = { age: 30, name: "alice" }
  let p2 = { age: 30, name: "alice" }
  let p3 = { age: 30, name: "bob" }
  test_assert.assert_eq_bool(actual: p1 == p2, expected: true, label: "record string field equal")
  test_assert.assert_eq_bool(
    actual: p1 == p3,
    expected: false,
    label: "record string field unequal"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
