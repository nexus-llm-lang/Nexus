// Regression test for nexus-7k3x2:
// Structural record returned from a function call must support field projection
// (`p.field`) with correct per-field values. Before the fix, field projection
// produced E6002 ("non-record semantic type") because the TyRecord semantic type
// was lost across the call-return boundary.
import * as test_assert from "std:test/assert"

type Pair = { lo: i64, hi: i64 }

let make_pair = fn (n: i64) -> Pair do
  return { lo: n, hi: n * 10 }
end

let body = fn () -> unit throws { Exn } do
  let p = make_pair(n: 5)
  test_assert.assert_eq_i64(actual: p.lo, expected: 5, label: "record-call-projection .lo")
  test_assert.assert_eq_i64(actual: p.hi, expected: 50, label: "record-call-projection .hi")
  // Two-field pair with different values (catches all-same-value bugs)
  let q = make_pair(n: 7)
  test_assert.assert_eq_i64(actual: q.lo, expected: 7, label: "record-call-projection .lo (q)")
  test_assert.assert_eq_i64(actual: q.hi, expected: 70, label: "record-call-projection .hi (q)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
