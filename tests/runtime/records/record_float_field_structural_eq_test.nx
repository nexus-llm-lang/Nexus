// Structural equality (`==`/`!=`) on aggregates containing FLOAT fields must use
// IEEE float comparison for those fields — identically to the scalar `==.`
// operator — NOT a raw i64 BIT compare of the float's representation
// (spec § T-Cmp). The bit compare disagrees with IEEE on exactly two values:
//   - NaN == NaN  is FALSE under IEEE, but bit-equal (true) on identical bits.
//   - -0.0 == 0.0 is TRUE under IEEE, but bit-UNequal (false) — different sign bit.
// Before the fix struct_eq loaded a float field as i64 and emitted `i64.eq`, so
// a record/enum/list carrying a NaN or -0.0 float field reported the inverted
// result versus the scalar `==.`. This test pins the structural path to match
// the scalar path for both pathological values, in a record field, an enum
// payload field, and a list element.
import * as test_assert from "std:test/assert"

type Box = { v: f64 }
type Opt = Wrap(f: f64) | Empty
type WBox = { w: f32 }

let body = fn () -> unit throws { Exn } do
  // Construct NaN and -0.0 at run time (not literals) so constant folding cannot
  // pre-decide the compare; these are the exact values the codegen path sees.
  let nan: f64 = 0.0 /. 0.0
  let neg_zero: f64 = (0.0 -. 1.0) *. 0.0   // -0.0
  let pos_zero: f64 = 0.0

  // ── Scalar baseline (the oracle the structural path must match). ──
  test_assert.assert_eq_bool(actual: nan ==. nan, expected: false, label: "scalar NaN ==. NaN")
  test_assert.assert_eq_bool(
    actual: neg_zero ==. pos_zero,
    expected: true,
    label: "scalar -0.0 ==. 0.0"
  )

  // ── Record float field: structural == must match scalar. ──
  let a = { v: nan }
  let b = { v: nan }
  test_assert.assert_eq_bool(actual: a == b, expected: false, label: "record {NaN} == {NaN}")
  let c = { v: neg_zero }
  let d = { v: pos_zero }
  test_assert.assert_eq_bool(actual: c == d, expected: true, label: "record {-0.0} == {0.0}")
  // A plain-value control: two ordinary equal floats still compare equal.
  let e = { v: 1.5 }
  let f = { v: 1.5 }
  let g = { v: 2.5 }
  test_assert.assert_eq_bool(actual: e == f, expected: true, label: "record {1.5} == {1.5}")
  test_assert.assert_eq_bool(actual: e == g, expected: false, label: "record {1.5} == {2.5}")

  // ── Enum payload float field: structural == must match scalar. ──
  let wa = Wrap(f: nan)
  let wb = Wrap(f: nan)
  test_assert.assert_eq_bool(actual: wa == wb, expected: false, label: "Wrap(NaN) == Wrap(NaN)")
  let wc = Wrap(f: neg_zero)
  let wd = Wrap(f: pos_zero)
  test_assert.assert_eq_bool(actual: wc == wd, expected: true, label: "Wrap(-0.0) == Wrap(0.0)")
  let we = Wrap(f: 3.25)
  let wf = Wrap(f: 3.25)
  test_assert.assert_eq_bool(actual: we == wf, expected: true, label: "Wrap(3.25) == Wrap(3.25)")

  // ── List of floats: each element compares with IEEE semantics. ──
  let la = [ nan, neg_zero ]
  let lb = [ nan, pos_zero ]
  // Element 0: NaN vs NaN -> false  => whole list false.
  test_assert.assert_eq_bool(actual: la == lb, expected: false, label: "[NaN,-0.0] == [NaN,0.0]")
  let lc = [ neg_zero, 1.0 ]
  let ld = [ pos_zero, 1.0 ]
  // Element 0: -0.0 vs 0.0 -> true; element 1 equal => whole list true.
  test_assert.assert_eq_bool(actual: lc == ld, expected: true, label: "[-0.0,1.0] == [0.0,1.0]")

  // ── f32 record field: the f32 cell (stored promoted to f64) must also use
  //    IEEE float compare, not a bit compare. ──
  let f32_zero: f32 = 0.0
  let f32_one: f32 = 1.0
  let f32_nan: f32 = f32_zero /. f32_zero
  let f32_neg_zero: f32 = (f32_zero -. f32_one) *. f32_zero   // -0.0
  let f32_pos_zero: f32 = f32_zero
  let xa = { w: f32_nan }
  let xb = { w: f32_nan }
  test_assert.assert_eq_bool(actual: xa == xb, expected: false, label: "record f32 {NaN} == {NaN}")
  let xc = { w: f32_neg_zero }
  let xd = { w: f32_pos_zero }
  test_assert.assert_eq_bool(actual: xc == xd, expected: true, label: "record f32 {-0.0} == {0.0}")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
