// Spec P-Ctor {ℓ'} = {ℓ} (set equality, type-system-formal.md:1038/1044): a
// constructor pattern may list its field labels in ANY permutation of the
// declared order. `canonicalize_c` reorders the sub-pattern list into the
// constructor's declared field order, so each binder maps to its LABEL's
// field — never to the field that happens to sit at the same surface position.
//
// Regression (over-rejection): the P-Ctor binding walk in
// src/typecheck/infer/statements.nx matched labels positionally and rejected
// any permutation with E2001, even though the identical P-Record clause
// already accepted label permutations correctly.
//
// Field values are DISTINCT and the surface label order (aa, mm, zz) is a
// PERMUTATION of the declared order (zz, aa, mm), so a positional misbind
// would yield a different number — the assert catches it.
import * as test_assert from "std:test/assert"

type S = First(zz: i64, aa: i64, mm: i64) | Other

let body = fn () -> unit throws { Exn } do
  let t = First(zz: 1, aa: 2, mm: 3)

  // Permuted labels with EXPLICIT binders distinct from the labels: each
  // binder must take the value of its LABEL's field, not its position.
  //   z <- zz (1), a <- aa (2), m <- mm (3)  =>  1*10000 + 2*100 + 3 = 10203
  let v = match t do
    | First(aa: a, mm: m, zz: z) -> z * 10000 + a * 100 + m
    | Other -> -1
  end
  test_assert.assert_eq_i64(
    actual: v,
    expected: 10203,
    label: "permuted explicit binders bind by label"
  )

  // Pun shorthand in declared order still binds positionally-and-by-label.
  let w = match t do
    | First(zz, aa, mm) -> zz * 10000 + aa * 100 + mm
    | Other -> -1
  end
  test_assert.assert_eq_i64(actual: w, expected: 10203, label: "declared-order pun shorthand")

  // Pun shorthand in PERMUTED order: each punned binder still names its label.
  let x = match t do
    | First(mm, zz, aa) -> zz * 10000 + aa * 100 + mm
    | Other -> -1
  end
  test_assert.assert_eq_i64(
    actual: x,
    expected: 10203,
    label: "permuted pun shorthand binds by label"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
