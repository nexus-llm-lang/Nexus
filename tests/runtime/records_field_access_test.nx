// Port of bootstrap/tests/runtime/records.rs::codegen_record_field_access.
// Verifies `.field` access on a record literal returns the literal value.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let r = { y: 2, x: 40 }
  test_assert.assert_eq_i64(actual: r.x, expected: 40, label: "record .x")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
