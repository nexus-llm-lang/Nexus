// Port of bootstrap/tests/runtime/control_flow.rs::codegen_match_literal_*,
// codegen_match_variable_*, codegen_match_or_pattern_literal_*,
// codegen_match_with_pipe_arm_separator_runs.
import * as test_assert from "std:test/assert"

let check_literal = fn (x: i64) -> i64 do
  match x do
    | 1 -> return 10
    | 2 -> return 20
    | _ -> return 30
  end
  return 0
end

let check_var_only = fn (x: i64) -> i64 do
  match x do
    | v -> return v
  end
  return 0
end

let check_literal_then_var = fn (x: i64) -> i64 do
  match x do
    | 0 -> return 0
    | other -> return other
  end
  return -1
end

let check_or_literal = fn (x: i64) -> i64 do
  match x do
    | 1 | 2 | 3 -> return 100
    | _ -> return 0
  end
  return -1
end

let check_pipe_arms = fn (x: i64) -> i64 do
  match x do
    | 1 -> return 11
    | 2 -> return 22
    | _ -> return 99
  end
  return -1
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: check_literal(x: 2), expected: 20, label: "match literal 2")
  test_assert.assert_eq_i64(actual: check_literal(x: 1), expected: 10, label: "match literal 1")
  test_assert.assert_eq_i64(actual: check_literal(x: 99), expected: 30, label: "match literal _")
  test_assert.assert_eq_i64(actual: check_var_only(x: 42), expected: 42, label: "match var-only")
  test_assert.assert_eq_i64(actual: check_literal_then_var(x: 7), expected: 7, label: "literal-then-var(7)")
  test_assert.assert_eq_i64(actual: check_literal_then_var(x: 0), expected: 0, label: "literal-then-var(0)")
  test_assert.assert_eq_i64(actual: check_or_literal(x: 1), expected: 100, label: "or-literal(1)")
  test_assert.assert_eq_i64(actual: check_or_literal(x: 2), expected: 100, label: "or-literal(2)")
  test_assert.assert_eq_i64(actual: check_or_literal(x: 3), expected: 100, label: "or-literal(3)")
  test_assert.assert_eq_i64(actual: check_or_literal(x: 4), expected: 0, label: "or-literal(4)")
  test_assert.assert_eq_i64(actual: check_pipe_arms(x: 1), expected: 11, label: "pipe-arms(1)")
  test_assert.assert_eq_i64(actual: check_pipe_arms(x: 5), expected: 99, label: "pipe-arms(_)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
