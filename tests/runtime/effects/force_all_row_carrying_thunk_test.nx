// force_all admits a row-carrying (throwing) thunk and bundles its throws into
// the caller's row: a bare `@T` is effect-polymorphic, so a list of thunks one
// of which throws Boom makes force_all throw Boom, caught at the call site.
import { force_all } from "std:lazy"
import * as list from "std:collection/list"
import * as test_assert from "std:test/assert"

exception Boom(n: i64)

let sum_or_throw = fn (do_throw: bool) -> i64 throws { Boom } do
  let @t1 = 10
  let @t2 = if do_throw then throw Boom(n: 7) else 20 end
  let r = force_all(tasks: [ t1, t2 ])
  return list.fold_left(xs: r, init: 0, f: fn (acc: i64, val: i64) -> i64 do return acc + val end)
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: sum_or_throw(do_throw: false),
    expected: 30,
    label: "force_all sums non-throwing thunks"
  )
  try
    let s = sum_or_throw(do_throw: true)
    test_assert.assert_eq_i64(actual: s, expected: 0, label: "unreachable")
    return ()
  catch
    | Boom(n: nn) -> test_assert.assert_eq_i64(
      actual: nn,
      expected: 7,
      label: "force_all bundled the thunk Boom to caller"
    )
  end
  return ()
end
