// Acceptance: the value an `inject H do <body> end` yields must be the body's
// real trailing value even when H captures a continuation (`with @k`) and the
// inject therefore routes through the stack-switching resume frame.
//
// Predecessor (nexus-oq3tj) wired LirExprResume/ContNew so a `with @k` body
// suspends/resumes and round-trips, but hardcoded the inject EXPRESSION's value
// to unit: the lifted `__inject_N` body was declared `() -> ()`, so its trailing
// `return <value>` was dropped and `let total = inject ...` bound 0/"" instead
// of the real value.
//
// Fix (nexus-h4v70): the lifted body keeps the single program cont type
// `() -> ()` (oq3tj invariant), but stores its trailing value out-of-band into
// the ss_inject_value global on completion; the inject dispatcher reads it back
// after the resume frame exits and leaves it on the value stack as the inject
// expression's result.
//
// Each `Gen.tick()` SUSPENDS into the handler, whose `@k` arm RESUMES the
// captured continuation so the body continues to the next statement. The body's
// final expression (a sum / a string built across the suspend/resume boundaries)
// must surface as the enclosing function's return value.
//
// Cases:
//   1. i64 inject-site value across three resume boundaries (10+20+30 = 60)
//   2. string (heap-handle) inject-site value across resumes
//   3. unit-body control — must still yield unit and leave nothing on the stack
//
// Each case throws RuntimeError on mismatch; exit 0 means all pass.
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import * as str from "std:str"

cap Gen do
  fn tick() -> i64
end

// `@k` resumes the suspended continuation (resume value is unit today — there
// is no surface syntax for `@k(v)`), so the body simply continues after each
// tick. The inject-site value comes from the body's own trailing computation.
let gen_h = handler Gen do
  fn tick() -> i64 with @k do
    @k
  end
end

// Case 1: i64 trailing value, accumulated across suspend/resume boundaries.
let sum_value = fn () -> i64 throws { RuntimeError } do
  inject gen_h do
    let _a = Gen.tick()
    let s1 = 10
    let _b = Gen.tick()
    let s2 = s1 + 20
    let _c = Gen.tick()
    let total = s2 + 30
    return total
  end
end

// Case 2: string (heap-handle) trailing value through the i64 value channel.
let label_value = fn () -> string throws { RuntimeError } do
  inject gen_h do
    let _a = Gen.tick()
    let p = "kont"
    let _b = Gen.tick()
    let q = p ++ "-value"
    return q
  end
end

// Case 3: unit-body control — the inject yields unit and the side effect runs.
let unit_body = fn () -> unit require { Console } throws { RuntimeError } do
  inject gen_h do
    let _a = Gen.tick()
    let _b = Gen.tick()
    Console.println(val: "unit-body-ran")
  end
end

let assert_i64 = fn (label: string, got: i64, want: i64) -> unit throws { RuntimeError } do
  if !(got == want) then
    throw RuntimeError(val: label ++ ": got " ++ str.from_i64(val: got) ++ ", want " ++ str.from_i64(val: want))
  end
end

let assert_str = fn (label: string, got: string, want: string) -> unit throws { RuntimeError } do
  if !(got == want) then
    throw RuntimeError(val: label ++ ": got '" ++ got ++ "', want '" ++ want ++ "'")
  end
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    // Case 1: i64 inject-site value (was 0 before the fix)
    let n1 = sum_value()
    assert_i64(label: "kont-inject-i64", got: n1, want: 60)

    // Case 2: string inject-site value (was "" before the fix)
    let s2 = label_value()
    assert_str(label: "kont-inject-string", got: s2, want: "kont-value")

    // Case 3: unit-body control (must run side effect, yield unit)
    unit_body()

    Console.println(val: "ok")
  end
end
