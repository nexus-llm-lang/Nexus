// Generic-capability soundness, ACCEPT side: a generic cap method called
// DIRECTLY inside an `inject` body (not laundered through a generic producer)
// must still type-check and run when the call's element type MATCHES the
// injected handler's instantiation.
//
// This is the positive counterpart of
// tests/negative/typecheck/generic_cap_call_handler_type_mismatch.nx: inside an
// inject body, `Box.wrap` is shadowed with the concrete instantiation of the
// in-scope handler. A MATCHING call (i64 under the i64 handler, string under the
// string handler) unifies cleanly; only a MISMATCHED call is newly rejected.
//
// One generic cap, two handlers at distinct element types, each driving a direct
// in-body call. The program exits 0.
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import * as str from "std:str"

cap Box<T> do
  fn wrap(x: T) -> T
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1
  end
end

let box_str = handler Box do
  fn wrap(x: string) -> string do
    return x ++ "!"
  end
end

// Direct i64 call under the i64 handler — matching instantiation, accepted.
// `inject` is statement-only; its trailing value surfaces as the fn's result.
let wrap_i64 = fn () -> i64 do
  inject box_i64 do
    let r = Box.wrap(x: 41)
    r
  end
end

// Direct string call under the string handler — matching instantiation.
let wrap_str = fn () -> string do
  inject box_str do
    let s = Box.wrap(x: "ok")
    s
  end
end

let main = fn () -> unit require { PermConsole } do
  let a = wrap_i64()
  let b = wrap_str()
  inject stdio.system_handler do
    Console.println(val: "generic cap direct in-inject calls: " ++ str.from_i64(val: a) ++ " " ++ b)
  end
end
