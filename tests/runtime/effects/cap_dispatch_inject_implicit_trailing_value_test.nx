// Regression: under runtime dispatch (>=2 handler bindings program-wide for a
// cap), an `inject H do <body> end` whose value came from the body's IMPLICIT
// TRAILING EXPRESSION (no `return`) was silently dropped — the block yielded
// unit/0/"" instead of the body's last expression.
//
// Root cause: wrap_inject_register appended register-restore statements AFTER
// the body, pushing the trailing MirStmtExpr out of tail position so the wasm
// value stack ended with the unit-returning restores, not the body value.
//
// Controls that must stay correct:
//   - single-handler cap (static rewrite, not the runtime-dispatch path) — unaffected
//   - explicit `return Tag.name()` inside the inject — already handled by rewrite_returns_in_stmts
//
// This test covers:
//   1. implicit trailing string value, single-statement inject body
//   2. implicit trailing i64 value
//   3. multi-statement body (`let rr = ...; rr`) — also produced INVALID WASM before the fix
//   4. explicit-return control (must not regress)
//   5. nested inject — inner implicit trailing value preserved through outer inject scope
//
// Each case throws RuntimeError on mismatch; exit 0 means all pass.
import * as stdio from "std:stdio"

cap Tag do
  fn name() -> string
  fn id() -> i64
end

let hA = handler Tag do
  fn name() -> string do return "A" end
  fn id() -> i64 do return 1 end
end

let hB = handler Tag do
  fn name() -> string do return "B" end
  fn id() -> i64 do return 2 end
end

// Case 1: implicit trailing string value (single-statement body)
let get_name_implicit = fn () -> string require { Tag } do
  inject hB do return Tag.name() end
end

// Case 2: implicit trailing i64 value (single-statement body)
let get_id_implicit = fn () -> i64 require { Tag } do
  inject hB do return Tag.id() end
end

// Case 3: multi-statement body with implicit trailing value
let get_name_multistmt = fn () -> string require { Tag } do
  inject hB do
    let rr = Tag.name()
    return rr
  end
end

// Case 4: explicit return — must continue working (control / non-regression)
let get_name_explicit = fn () -> string require { Tag } do
  inject hB do
    return Tag.name()
  end
end

// Case 5: nested inject — inner implicit trailing value propagates through outer
let get_name_nested = fn () -> string require { Tag } do
  inject hA do
    inject hB do
      return Tag.name()
    end
  end
end

let assert_str = fn (label: string, got: string, want: string) -> unit throws { RuntimeError } do
  if !(got == want) then
    throw RuntimeError(val: label ++ ": got '" ++ got ++ "', want '" ++ want ++ "'")
  end
end

let assert_i64 = fn (label: string, got: i64, want: i64) -> unit throws { RuntimeError } do
  if !(got == want) then
    throw RuntimeError(val: label ++ ": wrong value")
  end
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    inject hA do
      // Case 1: implicit trailing string
      let s1 = get_name_implicit()
      assert_str(label: "implicit-string", got: s1, want: "B")

      // Case 2: implicit trailing i64
      let n2 = get_id_implicit()
      assert_i64(label: "implicit-i64", got: n2, want: 2)

      // Case 3: multi-statement body
      let s3 = get_name_multistmt()
      assert_str(label: "multi-stmt", got: s3, want: "B")

      // Case 4: explicit return (control)
      let s4 = get_name_explicit()
      assert_str(label: "explicit-return", got: s4, want: "B")

      // Case 5: nested inject — inner implicit trailing value
      let s5 = get_name_nested()
      assert_str(label: "nested-implicit", got: s5, want: "B")

      // Case 6: outer handler restored correctly after inner scope closes
      let s6 = Tag.name()
      assert_str(label: "outer-restored", got: s6, want: "A")
    end
  end
end
