// Acceptance: two cooperative tasks interleave at their `Coop.yield()` points
// through a SINGLE inject frame, driven by the in-wasm cooperative scheduler
// (std:concurrency/coop) over the stack-switching `with @k` machinery.
//
// This exercises the full in-wasm spawn path: `spawn(task_b)` uses the
// `__nx_sched_spawn` intrinsic to `cont.new` a fresh continuation over the
// scheduler trampoline and enqueue it on the in-wasm run queue (a fixed-offset
// ring in std:runtime/sched — NOT a host import, so it runs under plain
// `wasmtime run`). The inject body runs `task_a`; each `Coop.yield()` suspends
// into the `with @k` scheduler arm, which captures the running task's
// continuation slot (`kont_slot(k)`), enqueues it, and points the dispatcher at
// the next ready slot (FIFO dequeue) via `sched_set_next`. Because both live
// tasks are slots in the same cont table and the same dispatcher loop resumes
// whichever slot is current, the two tasks round-robin at their yield points.
//
// Task A records 1 (A1), yields, records 3 (A2). Task B records 2 (B1), yields,
// records 4 (B2). The shared trace lives at a fixed reserved linear-memory
// offset (a top-level `let = alloc_raw` is a non-memoised thunk that
// re-allocates per reference, so a literal constant offset is the only stable
// shared address across the spawned/yielded continuations). A cooperative
// interleave yields the order [1, 2, 3, 4] (A1 B1 A2 B2); a regression to
// sequential execution would yield [1, 3, 2, 4] and fail the per-slot asserts.
// Exit 0 means the interleave held.
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import * as str from "std:str"
import { Coop, scheduler, spawn } from "std:concurrency/coop"
import * as mem from "std:runtime/mem"

// Shared trace buffer at a fixed reserved offset (page 13, clear of the heap and
// of the scheduler's own page-13 cells): [count:i64, e0, e1, ...].
let trace_base = fn () -> i64 do return 854016 end

let trace_init = fn () -> unit do
  mem.store_i64(addr: trace_base(), val: 0)
  return ()
end

let trace_push = fn (v: i64) -> unit do
  let b = trace_base()
  let n = mem.load_i64(addr: b)
  mem.store_i64(addr: b + 8 + n * 8, val: v)
  mem.store_i64(addr: b, val: n + 1)
  return ()
end

let trace_get = fn (i: i64) -> i64 do
  let b = trace_base()
  return mem.load_i64(addr: b + 8 + i * 8)
end

let trace_len = fn () -> i64 do
  return mem.load_i64(addr: trace_base())
end

// Task A: records 1 (A1), yields, records 3 (A2).
let task_a = fn () -> unit require { Coop } do
  trace_push(v: 1)
  Coop.yield()
  trace_push(v: 3)
  return ()
end

// Task B: records 2 (B1), yields, records 4 (B2).
let task_b = fn () -> unit require { Coop } do
  trace_push(v: 2)
  Coop.yield()
  trace_push(v: 4)
  return ()
end

let assert_i64 = fn (label: string, got: i64, want: i64) -> unit throws { RuntimeError } do
  if !(got == want) then
    throw RuntimeError(val: label ++ ": got " ++ str.from_i64(val: got) ++ ", want " ++ str.from_i64(val: want))
  end
end

let run = fn () -> unit require { Console } throws { RuntimeError } do
  trace_init()
  inject scheduler do
    spawn(task: task_b)
    task_a()
  end
  // Expect the cooperative interleave A1 B1 A2 B2 = [1, 2, 3, 4], NOT the
  // sequential order [1, 3, 2, 4].
  assert_i64(label: "len", got: trace_len(), want: 4)
  assert_i64(label: "A1", got: trace_get(i: 0), want: 1)
  assert_i64(label: "B1", got: trace_get(i: 1), want: 2)
  assert_i64(label: "A2", got: trace_get(i: 2), want: 3)
  assert_i64(label: "B2", got: trace_get(i: 3), want: 4)
  Console.println(val: "coop-interleave-ok")
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    run()
  end
end
