// Positive boundary fixture for the multi-arg-`with @k` rejection.
//
// A cap method with EXACTLY ONE parameter handled by a `with @k` arm is the
// largest payload the wasm `suspend` instruction can carry, so it must still
// typecheck and run. Only cap methods with TWO OR MORE parameters are rejected
// (E5002, see tests/negative/typecheck/cap_method_multi_arg_with_kont.nx).
//
// Here `Log.note(line)` takes a single string argument; the handler arm forces
// `@k`, resuming the suspended body so it runs to completion. The body emits
// two notes around the suspend points, proving the single-arg suspend/resume
// round-trip is intact (handler arms carry no require row, so the observable
// output comes from the body, not the arm).
import { Console } from "std:stdio"
import * as stdio from "std:stdio"

cap Log do
  fn note(line: string) -> unit
end

let log_h = handler Log do
  fn note(line: string) -> unit with @k do
    @k
  end
end

let body = fn () -> unit require { Log, Console } throws { RuntimeError } do
  Log.note(line: "first")
  Console.println(val: "after-first")
  Log.note(line: "second")
  Console.println(val: "after-second")
  Console.println(val: "ok")
end

let run = fn () -> unit require { Console } throws { RuntimeError } do
  inject log_h do
    body()
  end
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    run()
  end
end
