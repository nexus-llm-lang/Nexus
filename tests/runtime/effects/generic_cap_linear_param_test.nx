// Generic capability with a LINEAR method param (`cap Sink<T> do fn put(x: %T)`),
// instantiated at a concrete linear resource type and freed exactly once.
//
// Before this fix, `collect_tp_bindings` (handler_validation.nx) had no
// `TyLinear` arm: the cap-decl param `%T` is `TyLinear(TyVar "T")`, and the
// handler arm param `%Res` is `TyLinear(TyUserDefined "Res")`. With no
// recursion through `TyLinear`, the `T := Res` binding was never derived, the
// substitution stayed empty, and the structural equality check saw
// `%TyVar T != %Res` — wrongly rejecting the well-typed arm with E2001
// ("handler arm 'put' parameter types do not match cap method declaration").
//
// Generic caps are documented to "mirror generic functions", and a generic
// FUNCTION with a `%T` param at a concrete linear type already type-checked and
// ran. This closes the same gap for generic CAP method params.
//
// What this exercises:
//   1. Typecheck: `Sink<T>` at `T := Res` instantiates `put(x: %T)` to
//      `put(x: %Res)`, which matches the handler arm (the over-rejection fix).
//   2. Linearity: the linear `%Res` flows through the cap call into the handler
//      arm, which consumes it EXACTLY once via `free_res` — no drop, no
//      double-free.
//
// twyov: the handler arm is a plain (no `with @k`) consumer; the program takes
// only the success path and exits 0 — failure is never signalled via a
// post-resume trap.
import * as stdio from "std:stdio"
import { Console } from "std:stdio"

/** A linear resource: must be consumed exactly once. */
type Res = Res(id: i64)

/** The sole consumer of a Res — destructures it, ending its linear lifetime. */
let free_res = fn (r: %Res) -> unit do
  let Res(id: _) = r
  return ()
end

/** A generic sink capability whose method takes a LINEAR element `%T`. */
cap Sink<T> do
  fn put(x: %T) -> unit
end

/** Handler instantiating Sink at the linear type Res; frees the resource once. */
let sink_res = handler Sink do
  fn put(x: %Res) -> unit do
    free_res(r: x)
    return ()
  end
end

/** Produces a linear Res and hands it to the cap, which frees it. */
let use_it = fn () -> i64 require { Sink } do
  let r = Res(id: 7)
  Sink.put(x: r)
  return 0
end

let main = fn () -> unit require { PermConsole } do
  inject sink_res do
    let n = use_it()
    ()
  end
  inject stdio.system_handler do
    Console.println(val: "generic cap linear %T param: freed once ok")
  end
end
