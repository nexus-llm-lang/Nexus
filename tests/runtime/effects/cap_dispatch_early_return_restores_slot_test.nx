// Regression: an early `return` out of a multi-handler-cap inject body MUST
// run the register-slot restore on the return path too, not only on normal
// completion and on the throw path. Otherwise the inner handler's id leaks
// into the enclosing dynamic scope and subsequent same-cap calls dispatch
// to the wrong handler.
//
// Scenario: helper `f()` opens `inject inner_h` and returns from inside it
// (early-return tail). After f() returns, a same-cap call at the enclosing
// `inject outer_h` level must see OUTER. Without the return-path restore,
// it incorrectly sees INNER (slot leaked).
//
// The 2-deep nest variant exercises composition: an early return out of a
// doubly-nested inject must run BOTH restores, so the post-return level
// observes the outermost handler.
import * as stdio from "std:stdio"

cap Who do
  fn who() -> string
end

let h_a = handler Who do
  fn who() -> string do
    return "A"
  end
end

let h_b = handler Who do
  fn who() -> string do
    return "B"
  end
end

let h_c = handler Who do
  fn who() -> string do
    return "C"
  end
end

let f = fn () -> string require { Who } throws { RuntimeError } do
  inject h_b do
    return Who.who()
  end
end

let g = fn () -> string require { Who } throws { RuntimeError } do
  inject h_b do
    inject h_c do
      return Who.who()
    end
  end
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    inject h_a do
      let r1 = f()
      if !(r1 == "B") then
        throw RuntimeError(val: "f() returned '" ++ r1 ++ "', expected B (innermost)")
      end
      let r2 = Who.who()
      if !(r2 == "A") then
        throw RuntimeError(val: "after f(): got '" ++ r2 ++ "', expected A (slot leaked on return path)")
      end
      let r3 = g()
      if !(r3 == "C") then
        throw RuntimeError(val: "g() returned '" ++ r3 ++ "', expected C (innermost of 2-deep nest)")
      end
      let r4 = Who.who()
      if !(r4 == "A") then
        throw RuntimeError(val: "after g(): got '" ++ r4 ++ "', expected A (both nested slots must restore on return)")
      end
    end
  end
end
