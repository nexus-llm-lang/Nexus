// Acceptance test for src/backend/effect_analysis.nx (issue nexus-j5zi).
//
// Builds hand-rolled LirPrograms exercising:
//   * a pure function (no caps, no throw, no externs) — expect is_pure=true
//   * a function that raises directly — expect can_throw=true
//   * an external-using function (Console.print) — expect capabilities_used
//     contains "Console" and is_pure=false
//   * a transitive call chain a -> b -> c (where c throws) — expect a's
//     can_throw=true via fixed-point propagation.
import * as test_assert from "std:test/assert"
import { TyI64, TyUnit } from "src/syntax/ast.nx"
import { BinaryOp, OpAdd, OpDiv, OpMod } from "src/types/vocab.nx"
import {
  LirProgram,
  LirFunction,
  LirExternal,
  LirParam,
  LirAtomInt,
  LirAtomUnit,
  LirAtomVar,
  LirExprAtom,
  LirExprBinary,
  LirExprCall,
  LirExprRaise,
  LirCallArg,
  LirStmtLet,
  LirStmtTryCatch
} from "src/ir/lir/types.nx"
import {
  EffectMap,
  EffectSummary,
  lookup_summary,
  effect_map_size,
  free_effect_map
} from "src/ir/shared/effect_map.nx"
import { analyze_effects } from "src/backend/effect_analysis.nx"
import { Some, None } from "std:option"
import {
  mk_lir_fn, mk_lir_pure_stub, mk_lir_raises_stub, mk_lir_chain_stub,
  empty_throw_row
} from "tests/_fixtures/lir.nx"

// Pure function: effect analysis sees only LirExprAtom, so is_pure = true.
let make_pure_fn = fn () -> LirFunction do return mk_lir_pure_stub(name: "pure_fn") end

// Raise function — direct LirExprRaise.
let make_throws_fn = fn () -> LirFunction do return mk_lir_raises_stub(name: "throws_fn") end

// Cap-using function — call __nx_print (Console capability via nexus:std/stdio).
let make_cap_fn = fn () -> LirFunction do
  let stmts = [
    LirStmtLet(
      name: "r",
      typ: TyUnit,
      expr: LirExprCall(
        func: "__nx_print",
        args: [ LirCallArg(label: "msg", value: LirAtomInt(val: 0)) ],
        typ: TyUnit
      )
    )
  ]
  return mk_lir_fn(name: "cap_fn", params: [], ret_type: TyUnit, body: stmts, ret: LirAtomUnit)
end

// Chain a -> b -> c (c raises). Verifies transitive can_throw propagation.
let make_a_fn = fn () -> LirFunction do return mk_lir_chain_stub(
  name: "chain_a",
  callee: "chain_b"
) end
let make_b_fn = fn () -> LirFunction do return mk_lir_chain_stub(
  name: "chain_b",
  callee: "chain_c"
) end
let make_c_fn = fn () -> LirFunction do return mk_lir_raises_stub(name: "chain_c") end

// try-catch-fn: body raises directly, catch body is a no-op (returns unit).
// Because the try/catch catches all exceptions, the function's can_throw
// should be false — the fix for nexus-05k8.
let make_try_catch_fn = fn () -> LirFunction do
  let body_stmts = [
    LirStmtLet(name: "r", typ: TyUnit, expr: LirExprRaise(value: LirAtomInt(val: 0), typ: TyUnit))
  ]
  let catch_stmts = [ LirStmtLet(name: "noop", typ: TyUnit, expr: LirExprAtom(atom: LirAtomUnit)) ]
  let stmts = [
    LirStmtTryCatch(
      body: body_stmts,
      body_ret: None,
      catch_param: "e",
      catch_param_typ: TyUnit,
      catch_body: catch_stmts,
      catch_ret: None
    )
  ]
  return mk_lir_fn(
    name: "try_catch_fn",
    params: [],
    ret_type: TyUnit,
    body: stmts,
    ret: LirAtomUnit
  )
end

// Binary-op functions (nexus-53lkx): a function whose body is `a / b` or
// `a mod b` performs a trap-capable integer op. A trap is an observable
// effect, so such a function must NOT be summarized as pure — otherwise the
// effect-aware DCE could drop an unused-result call to it and swallow a
// guaranteed divide-by-zero / INT_MIN/-1 trap. A function whose body is
// `a + b` (no trap) stays pure as a control.
let mk_binop_fn = fn (name: string, op: BinaryOp) -> LirFunction do
  let stmts = [
    LirStmtLet(
      name: "r",
      typ: TyI64,
      expr: LirExprBinary(
        op,
        lhs: LirAtomVar(name: "a", typ: TyI64),
        rhs: LirAtomVar(name: "b", typ: TyI64),
        typ: TyI64
      )
    )
  ]
  return mk_lir_fn(
    name,
    params: [ LirParam(label: "a", name: "a", typ: TyI64),
              LirParam(label: "b", name: "b", typ: TyI64) ],
    ret_type: TyI64,
    body: stmts,
    ret: LirAtomVar(name: "r", typ: TyI64)
  )
end

let make_div_fn = fn () -> LirFunction do return mk_binop_fn(name: "div_fn", op: OpDiv) end
let make_mod_fn = fn () -> LirFunction do return mk_binop_fn(name: "mod_fn", op: OpMod) end
let make_add_fn = fn () -> LirFunction do return mk_binop_fn(name: "add_fn", op: OpAdd) end

// External: __nx_print wired to nexus:std/stdio (Console capability).
let make_print_external = fn () -> LirExternal do
  return LirExternal(
    name: "__nx_print",
    wasm_module: "nexus:std/stdio",
    wasm_name: "print",
    params: [ LirParam(label: "msg", name: "msg", typ: TyI64) ],
    ret_type: TyUnit,
    throw_row: empty_throw_row()
  )
end

exception NoSuchSummary(name: string)

let summary_or_fail = fn (em: &EffectMap, name: string) -> EffectSummary throws { Exn } do
  match lookup_summary(em, name) do
    | Some(val: s) -> return s
    | None -> throw NoSuchSummary(name)
  end
end

// Snapshot of every value the assertions consume, lifted out of the linear
// EffectMap so the asserts can run after the map is freed.
type EffectSnapshot = EffectSnapshot(
  n_funcs: i64,
  pure_sum: EffectSummary,
  thr: EffectSummary,
  cap_sum: EffectSummary,
  chain_c: EffectSummary,
  chain_b: EffectSummary,
  chain_a: EffectSummary,
  try_catch_sum: EffectSummary,
  div_sum: EffectSummary,
  mod_sum: EffectSummary,
  add_sum: EffectSummary
)

// Take the linear EffectMap by move, read every summary the assertions need,
// then free the map — returning the snapshot. `summary_or_fail` is throwable
// and `%em` is live across each call, so on a raise the map is freed here
// before rethrowing (the E0540 leak the linearity checker now rejects in every
// call position). Taking `%em` by move keeps it out of any live-across position
// in the caller's assertion body.
let snapshot_and_free = fn (em: %EffectMap) -> EffectSnapshot throws { Exn } do
  try
    let n_funcs = effect_map_size(&em)
    let pure_sum = summary_or_fail(&em, name: "pure_fn")
    let thr = summary_or_fail(&em, name: "throws_fn")
    let cap_sum = summary_or_fail(&em, name: "cap_fn")
    let chain_c = summary_or_fail(&em, name: "chain_c")
    let chain_b = summary_or_fail(&em, name: "chain_b")
    let chain_a = summary_or_fail(&em, name: "chain_a")
    let try_catch_sum = summary_or_fail(&em, name: "try_catch_fn")
    let div_sum = summary_or_fail(&em, name: "div_fn")
    let mod_sum = summary_or_fail(&em, name: "mod_fn")
    let add_sum = summary_or_fail(&em, name: "add_fn")
    free_effect_map(%em)
    return EffectSnapshot(
      n_funcs, pure_sum, thr, cap_sum, chain_c, chain_b, chain_a,
      try_catch_sum, div_sum, mod_sum, add_sum)
  catch e ->
    free_effect_map(%em)
    throw e
  end
end

let caps_len = fn (xs: [ string ]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + caps_len(xs: rest)
  end
end

let caps_contains = fn (xs: [ string ], target: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == target then return true end
      return caps_contains(xs: rest, target)
  end
end

let body = fn () -> unit throws { Exn } do
  let prog = LirProgram(
    functions: [
      make_pure_fn(),
      make_throws_fn(),
      make_cap_fn(),
      make_a_fn(),
      make_b_fn(),
      make_c_fn(),
      make_try_catch_fn(),
      make_div_fn(),
      make_mod_fn(),
      make_add_fn()
    ],
    externals: [ make_print_external() ]
  )

  let %em = analyze_effects(program: prog)

  // Snapshot every value the assertions will consume, then drop the linear
  // EffectMap before the throwing assertions run. The assertion framework
  // raises AssertError on failure, and a linear value cannot span a throwing
  // call (E0540). `summary_or_fail` is itself throwable, so the snapshot+free
  // is done in `snapshot_and_free`, which takes %em by move and frees it on
  // both the success and the throw path.
  let EffectSnapshot(
    n_funcs,
    pure_sum,
    thr,
    cap_sum,
    chain_c,
    chain_b,
    chain_a,
    try_catch_sum,
    div_sum,
    mod_sum,
    add_sum
  ) = snapshot_and_free(%em)

  test_assert.assert_eq_i64(actual: n_funcs, expected: 10, label: "size")

  // Test 1: pure function.
  match pure_sum do | EffectSummary(capabilities_used: pc, can_throw: pt, is_pure: pp) ->
    test_assert.assert_false(cond: pt, label: "pure_fn.can_throw")
    test_assert.assert_true(cond: pp, label: "pure_fn.is_pure")
    test_assert.assert_eq_i64(actual: caps_len(xs: pc), expected: 0, label: "pure_fn.caps.len")
  end

  // Test 2: throwing function.
  match thr do | EffectSummary(capabilities_used: tc, can_throw: tt, is_pure: tp) ->
    test_assert.assert_true(cond: tt, label: "throws_fn.can_throw")
    test_assert.assert_false(cond: tp, label: "throws_fn.is_pure (must not be pure)")
    test_assert.assert_eq_i64(actual: caps_len(xs: tc), expected: 0, label: "throws_fn.caps.len")
  end

  // Test 3: cap-using function (Console).
  match cap_sum do | EffectSummary(capabilities_used: cc, can_throw: ct, is_pure: cp) ->
    test_assert.assert_false(cond: cp, label: "cap_fn.is_pure (uses cap)")
    test_assert.assert_false(cond: ct, label: "cap_fn.can_throw (print is non-throwing)")
    test_assert.assert_true(
      cond: caps_contains(xs: cc, target: "Console"),
      label: "cap_fn.caps contains Console"
    )
    test_assert.assert_eq_i64(actual: caps_len(xs: cc), expected: 1, label: "cap_fn.caps.len")
  end

  // Test 4: transitive throw propagation a -> b -> c (raises).
  match chain_c do | EffectSummary(capabilities_used: _, can_throw: cct, is_pure: _) ->
    test_assert.assert_true(cond: cct, label: "chain_c.can_throw (direct)")
  end
  match chain_b do | EffectSummary(capabilities_used: _, can_throw: cbt, is_pure: _) ->
    test_assert.assert_true(cond: cbt, label: "chain_b.can_throw (transitive via c)")
  end
  match chain_a do | EffectSummary(capabilities_used: _, can_throw: cat, is_pure: cap_pure) ->
    test_assert.assert_true(cond: cat, label: "chain_a.can_throw (transitive via b -> c)")
    test_assert.assert_false(
      cond: cap_pure,
      label: "chain_a.is_pure (must not be pure when transitively throws)"
    )
  end

  // Test 5 (nexus-05k8): try/catch suppresses body's can_throw.
  // The body raises directly but the catch catches it — enclosing scope
  // should NOT be marked can_throw.
  match try_catch_sum do | EffectSummary(capabilities_used: _, can_throw: tct, is_pure: tcp) ->
    test_assert.assert_false(cond: tct, label: "try_catch_fn.can_throw (body raise caught)")
    test_assert.assert_true(cond: tcp, label: "try_catch_fn.is_pure (caught raise is pure)")
  end

  // Test 6 (nexus-53lkx): trap-capable integer ops are not pure.
  // `a / b` and `a mod b` can trap (divide-by-zero; INT_MIN / -1), an
  // observable effect, so the function must NOT be summarized is_pure —
  // mirroring opt_is_pure in src/ir/lir/opt/helpers.nx. `a + b` stays pure.
  match div_sum do | EffectSummary(capabilities_used: _, can_throw: _, is_pure: dvp) ->
    test_assert.assert_false(cond: dvp, label: "div_fn.is_pure (OpDiv can trap, must not be pure)")
  end
  match mod_sum do | EffectSummary(capabilities_used: _, can_throw: _, is_pure: mdp) ->
    test_assert.assert_false(cond: mdp, label: "mod_fn.is_pure (OpMod can trap, must not be pure)")
  end
  match add_sum do | EffectSummary(capabilities_used: _, can_throw: _, is_pure: adp) ->
    test_assert.assert_true(cond: adp, label: "add_fn.is_pure (OpAdd cannot trap, stays pure)")
  end

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
