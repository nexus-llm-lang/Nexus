// Round-trip acceptance for `with @k` delimited-continuation handlers
// (nexus-oq3tj). Exercises the codegen for LirExprResume: a handler arm forces
// its captured continuation (`@k`), which must transfer control back to the
// suspended cap-call site so the injected body keeps running past every
// effect call.
//
// Each `Gen.tick()` in the body SUSPENDS into the handler; the arm `@k`
// RESUMES the captured continuation; the body then continues to the next
// statement. A running sum is accumulated ACROSS the suspend/resume
// boundaries — if any resume failed to continue the body (the pre-fix E3002
// stub, or a broken trampoline), the sum would be wrong, the program would
// trap on an unhandled suspend, or no output would appear at all.
//
// The body also prints each step so the round-trip is observable, and asserts
// the final sum == 1+2+3+4+5 = 15. `main` exits 0 only if every resume fired
// and the body ran to completion in order.
//
// Note: the value the inject EXPRESSION yields back to its caller is a
// separate, still-unwired channel (the lifted inject body is `() -> ()`, so
// its return value is dropped at MIR lift time). This test therefore asserts
// the round-trip via the body's own observable computation, which is what the
// Resume codegen actually guarantees.
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import * as str from "std:str"

cap Gen do
  fn tick() -> i64
end

// Handler arm: `@k` resumes the suspended continuation (resume value is unit
// today — there is no surface syntax for `@k(v)`), so the body simply
// continues after each tick.
let gen_h = handler Gen do
  fn tick() -> i64 with @k do
    @k
  end
end

let assert_i64 = fn (label: string, got: i64, want: i64) -> unit throws { RuntimeError } do
  if !(got == want) then
    throw RuntimeError(val: label ++ ": got " ++ str.from_i64(val: got) ++ ", want " ++ str.from_i64(val: want))
  end
end

// Sum 1..5, with a Gen.tick() suspend/resume boundary before each addend.
let sum_across_resumes = fn () -> unit require { Gen, Console } throws { RuntimeError } do
  let _t1 = Gen.tick()
  let s1 = 1
  Console.println(val: "step-1")
  let _t2 = Gen.tick()
  let s2 = s1 + 2
  Console.println(val: "step-2")
  let _t3 = Gen.tick()
  let s3 = s2 + 3
  Console.println(val: "step-3")
  let _t4 = Gen.tick()
  let s4 = s3 + 4
  Console.println(val: "step-4")
  let _t5 = Gen.tick()
  let s5 = s4 + 5
  Console.println(val: "step-5")
  assert_i64(label: "sum-across-resumes", got: s5, want: 15)
  Console.println(val: "ok")
end

let run = fn () -> unit require { Console } throws { RuntimeError } do
  inject gen_h do
    sum_across_resumes()
  end
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    run()
  end
end
