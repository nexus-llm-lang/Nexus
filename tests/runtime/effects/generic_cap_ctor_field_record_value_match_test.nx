// Generic-capability soundness, ACCEPT side — the positive counterpart of
// tests/negative/typecheck/generic_cap_laundered_through_ctor_field_record_value.nx.
//
// A `Box<i64>`-committed closure is laundered through a RECORD-typed VALUE stored
// in a CONSTRUCTOR field `Holder(rec: payload)`, and the value is run under a
// MATCHING `Box<i64>` handler. The committed element type agrees with the handler
// in scope, so the constructor-field coverage must ADMIT it — only a MISMATCHED
// element (i64 commitment under a `Box<string>` handler) is newly rejected. This
// guards against over-rejecting legitimate record values that carry capability
// arrows through constructor fields.
//
// The program exits 0.
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import * as str from "std:str"

cap Box<T> do
  fn wrap(x: T) -> i64
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1000
  end
end

let need_i64 = fn (seed: i64) -> i64 require { Box } do
  return Box.wrap(x: seed)
end

type Holder = Holder(rec: { g: (s: i64) -> i64 require { Box } })

let payload = { g: need_i64 }

let extract = fn (h: Holder, n: i64) -> i64 require { Box } do
  let Holder(rec: r) = h
  return r.g(s: n)
end

let main = fn () -> unit require { PermConsole } do
  inject box_i64 do
    let ok = extract(h: Holder(rec: payload), n: 5)
    inject stdio.system_handler do
      Console.println(val: "generic cap ctor-field record value match: " ++ str.from_i64(val: ok))
    end
  end
end
