// Regression for nexus-bh9o: when a function returning `bool` injects
// `env_mod.system_handler` and is called through an indirection (a wrapper
// fn that just returns the body's result), the body's return value used to
// be miscompiled to a constant `false` (default_atom for TyBool). The shape
// requires `let body = fn () -> bool ... do inject env_mod.system_handler do
// return true end end` plus `let safe_run = fn () -> bool do return body() end`
// plus a `main: -> unit` that branches on the wrapper's result. With the bug,
// `!ok` evaluates to `true` and main raises silently (exit=1, no output).
//
// Root cause: env.nx had three shadowed top-level wrappers
//   let get_env  = fn (..i32..) -> i64 do ... end       // raw
//   let has_env  = fn (..i32..) -> bool do ... end      // raw
//   let set_env  = fn (..i32..) -> unit do ... end      // raw
//   ...
//   let get_env  = fn (key: string) -> string do return ... get_env(..i32..) ... end
//   let has_env  = fn (key: string) -> bool   do return ... has_env(..i32..) ... end
//   let set_env  = fn (key: string, value: string) -> unit do return ... set_env(..i32..) ... end
//
// The recursive references inside the string-version wrappers were supposed
// to bind to the previously-declared i32 versions, but the codegen mis-
// resolved them to the wrappers themselves. The mis-resolution cascaded
// (via some opt pass) into unrelated functions' return atoms being
// replaced with their type's default. Renaming the three string wrappers
// to `_s` suffix in nxlib/stdlib/env.nx avoids the shadow and the cascade.
//
// This fixture pins the smallest failing shape so the regression is caught.
import { Env }, * as env_mod from "std:env"

let body = fn () -> bool require { PermEnv } throws { Exn } do
  inject env_mod.system_handler do
    return true
  end
end

let safe_run = fn () -> bool require { PermEnv } throws { Exn } do
  return body()
end

let main = fn () -> unit require { PermEnv } throws { Exn } do
  let ok = safe_run()
  if !ok then throw RuntimeError(val: "env-inject bool wrapper returned wrong bool") end
  return ()
end
