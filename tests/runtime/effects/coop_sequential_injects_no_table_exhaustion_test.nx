// Regression (nexus-kidtq): MANY sequential `inject scheduler` blocks must not
// accumulate cont-table slots. The de-globalize cur_slot reuse keeps ONE inject's
// yields from growing the table, but ss_next_alloc still bumped per new fiber and
// was never reclaimed — so N sequential coop injects climbed toward the fixed
// 64-slot cap (~32 injects of 1 body + 1 spawn). The inject-exit reset returns
// ss_next_alloc to its entry high-water, reclaiming each inject's slots.
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import * as str from "std:str"
import * as mem from "std:runtime/mem"
import { Coop, scheduler, spawn } from "std:concurrency/coop"

let cell = fn () -> i64 do return 902144 end
let task = fn () -> unit require { Coop } do
  mem.store_i64(addr: cell(), val: mem.load_i64(addr: cell()) + 1)
  Coop.yield()
  mem.store_i64(addr: cell(), val: mem.load_i64(addr: cell()) + 1)
  return ()
end
// one coop inject: scheduler with a spawned task + the body task, each yields once
let one = fn () -> unit do
  inject scheduler do
    spawn(task: task)
    task()
  end
  return ()
end
let loop_n = fn (n: i64) -> unit do
  if n <= 0 then return () end
  one()
  return loop_n(n: n - 1)
end
let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    mem.store_i64(addr: cell(), val: 0)
    loop_n(n: 50)
    let total = mem.load_i64(addr: cell())
    Console.println(val: "seq-injects total=" ++ str.from_i64(val: total))
    // 50 injects × (2 task increments × 2 tasks) = 200
    let ok = if total == 200 then 1 else 0 end
    let _g = 1 / ok
    return ()
  end
end
