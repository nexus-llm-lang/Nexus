// Regression: a Cap.method() reached through a CALLED helper must dispatch to
// the dynamically-innermost (shadowing) handler, not a statically-frozen one.
//
// Two handlers for the same cap are both reachable; a helper `who()` performs
// the cap call. With the old static specialize-inject rewrite, `who()` froze to
// the first-resolved handler at MIR-lowering time and printed OUTER regardless
// of the inject nesting. The runtime handler register makes the cap call read
// the dynamically-active handler, so the inner inject shadows the outer.
//
// This test asserts the dispatched value directly (throws on mismatch); a pass
// is exit 0. It is the cross-function nested-shadow case.
import * as stdio from "std:stdio"

cap Tag do
  fn name() -> string
end

let outer_h = handler Tag do
  fn name() -> string do
    return "OUTER"
  end
end

let inner_h = handler Tag do
  fn name() -> string do
    return "INNER"
  end
end

// The cap call is reached across a function-call boundary, not written
// syntactically inside the inject block.
let who = fn () -> string require { Tag } do
  return Tag.name()
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    inject outer_h do
      inject inner_h do
        let got = who()
        if !(got == "INNER") then
          throw RuntimeError(val: "cross-function cap call hit '" ++ got ++ "', expected INNER")
        end
      end
    end
  end
end
