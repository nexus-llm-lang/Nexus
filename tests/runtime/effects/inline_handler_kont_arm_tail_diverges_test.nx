// A `with @k` handler arm whose body binds the resumed continuation to a local
// (`let r = @k`) and returns it. Two things are verified end-to-end:
//
//   1. The typechecker accepts the arm: its body terminates on all paths via
//      explicit `return`, satisfying T-Continuation's tail(s̄) = ⊥ premise
//      (`infer_stmts_tail_diverges` returns true). A regression in the
//      tail-divergence guard would surface here as an E2001 over-rejection.
//
//   2. The Resume codegen (nexus-oq3tj) round-trips: `@k` in a non-tail
//      let-binding position resumes the suspended continuation, the body
//      continues past the cap call, and the program runs to completion with
//      no unhandled-suspend trap.
//
// Originally a negative fixture asserting E3002 (the codegen gap); repurposed
// as a positive runtime test now that LirExprResume is implemented. Exit 0
// means both guarantees hold.
import { Console } from "std:stdio"
import * as stdio from "std:stdio"

cap Yield do
  fn yield_val() -> unit
end

let yield_handler = handler Yield do
  fn yield_val() -> unit with @k do
    let r = @k
    return r
  end
end

// Body continues past yield_val() after the arm resumes; the trailing Console
// print is observable proof the continuation was resumed rather than dropped.
let body = fn () -> unit require { Yield, Console } do
  Yield.yield_val()
  Console.println(val: "resumed")
end

let run = fn () -> unit require { Console } do
  inject yield_handler do
    body()
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    run()
  end
end
