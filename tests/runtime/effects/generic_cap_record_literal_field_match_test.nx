// Generic-capability soundness, ACCEPT side — the positive counterpart of
// tests/negative/typecheck/generic_cap_laundered_through_record_literal_field.nx.
//
// A `Box<i64>`-committed closure is stored in a STRUCTURAL-RECORD LITERAL field
// `{ g: need_i64 }` and the record is built under a MATCHING `Box<i64>` handler.
// The committed element type agrees with the handler in scope, so the
// record-literal field coverage must ADMIT it — only a MISMATCHED element
// (i64 commitment under a `Box<string>` handler) is newly rejected. This guards
// against over-rejecting legitimate record literals that carry capability arrows.
//
// The program exits 0.
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import * as str from "std:str"

cap Box<T> do
  fn wrap(x: T) -> i64
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1000
  end
end

let need_i64 = fn (seed: i64) -> i64 require { Box } do
  return Box.wrap(x: seed)
end

type Holder = { g: (s: i64) -> i64 require { Box } }

let extract = fn (h: Holder, n: i64) -> i64 require { Box } do
  return h.g(s: n)
end

let main = fn () -> unit require { PermConsole } do
  inject box_i64 do
    let ok = extract(h: { g: need_i64 }, n: 5)
    inject stdio.system_handler do
      Console.println(val: "generic cap record-literal field match: " ++ str.from_i64(val: ok))
    end
  end
end
