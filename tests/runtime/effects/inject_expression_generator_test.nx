// Feature acceptance (brief case 4): the generator pattern written with an
// inject EXPRESSION — a trailing value, NO inner `return`.
//
// Before `inject` became an expression, a generator producer had to surface its
// accumulated list via a `return` INSIDE the inject body:
//   inject collector do … return list.reverse(~acc) end
// Now the same producer can `let`-bind the inject expression whose value is the
// body's trailing value, with no inner `return`:
//   let xs = inject collector do … list.reverse(~acc) end
//   return xs
// and equivalently `return inject collector do … list.reverse(~acc) end`.
//
// This exercises the inject value-channel (ss_inject_value) routed out of a
// with-@k generator frame into an enclosing expression slot. It is the
// expression-form sibling of generator_collect_test.nx (which uses the inner
// `return` statement form). A regression (lost accumulation, mis-ordered emit,
// or a dropped trailing value) changes the list contents; a pass is exit 0.
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import * as list from "std:list"
import * as assert from "std:test/assert"
import { Yield, collector } from "std:concurrency/generator"

// Producer via `let xs = inject … <trailing value> end` (NO inner return), then
// `return xs`. The inject expression's value is the body's trailing value.
let range_gen_letbound = fn (n: i64) -> [ i64 ] throws { Exn } do
  let xs = inject collector do
    let ~acc = list.empty()
    for i = 1 to n + 1 do
      Yield.emit(v: i)
      ~acc <- list.cons(x: i, xs: ~acc)
    end
    list.reverse(xs: ~acc)
  end
  return xs
end

// Producer via `return inject … <trailing value> end` (NO inner return). The
// inject expression flows directly into the function's return operand.
let range_gen_return = fn (n: i64) -> [ i64 ] throws { Exn } do
  return inject collector do
    let ~acc = list.empty()
    for i = 1 to n + 1 do
      Yield.emit(v: i)
      ~acc <- list.cons(x: i, xs: ~acc)
    end
    list.reverse(xs: ~acc)
  end
end

let body = fn () -> unit throws { Exn } do
  // let-bound inject expression generator collects [1, 2, 3, 4, 5]
  assert.assert_eq_i64_list(
    actual: range_gen_letbound(n: 5),
    expected: [ 1, 2, 3, 4, 5 ],
    label: "range_gen_letbound 1..5"
  )

  // single-element range via let-bound inject expression
  assert.assert_eq_i64_list(
    actual: range_gen_letbound(n: 1),
    expected: [ 1 ],
    label: "range_gen_letbound 1..1"
  )

  // return-position inject expression generator collects [1, 2, 3]
  assert.assert_eq_i64_list(
    actual: range_gen_return(n: 3),
    expected: [ 1, 2, 3 ],
    label: "range_gen_return 1..3"
  )

  return ()
end

// Exit 0 only if every assertion passes; trap on failure so the runner sees a
// non-zero exit. Mirrors generator_collect_test.nx (twyov: no host-ward unwind
// after a resume — assert/throw is caught here, the trap is a pure divide).
let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } throws { Exn } do
  inject stdio.system_handler do
    let ok = safe_run()
    if ok == 1 then
      Console.println(val: "ok")
    else
      Console.println(val: "FAILED")
    end
    let _guard = 1 / ok
    return ()
  end
end
