// Generic-capability require-row subtyping, ACCEPT side: a helper
// whose published contract pins a CONCRETE element type (`require { Box<i64> }`,
// derived from its body) is passed into a function-typed parameter whose slot is
// the element-AGNOSTIC bare `require { Box }`. A bare `Box` slot is the
// element-agnostic super-row and must admit any `Box<τ>` — `Box<i64> ⊆ Box`.
//
// Before the fix, the require-row coverage at the call `apply(g: helper, ...)`
// treated the helper's `Box<i64>` as an "extra label" not matched by the bare
// `Box` param slot and rejected the program with E2001 ("caller row has extra
// label(s) { Box<...> } not admitted by callee") — an over-rejection regression
// introduced by the generic-cap contract-derivation feature, which began
// publishing `Box<i64>` on helpers that previously carried a bare `Box`.
//
// The fix makes a concrete generic-cap entry `Box<τ>` admitted by a bare `Box`
// slot in require-row subtyping (directionally: a bare actual is NOT admitted by
// a concrete `Box<τ>` slot, and a `Box<σ>` actual is admitted only by `Box<σ>`
// or bare `Box`). The matching monomorphic, annotated-`Box<i64>`-slot, and
// direct-call forms were never broken; this restores the bare-slot HOF form.
//
// twyov: the handler arm is a plain (no `with @k`) computation; the program
// takes only the success path and exits 0.
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import * as str from "std:str"

cap Box<T> do
  fn wrap(x: T) -> i64
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1
  end
end

// Body commits Box at i64 → published contract `require { Box<i64> }`.
let helper = fn (n: i64) -> i64 require { Box } do
  return Box.wrap(x: n)
end

// The function-typed parameter `g` declares the element-AGNOSTIC bare slot
// `require { Box }`. Passing `helper` (`Box<i64>`) here must be admitted.
let apply = fn (g: (n: i64) -> i64 require { Box }, v: i64) -> i64 require { Box } do
  return g(n: v)
end

let main = fn () -> unit require { PermConsole } do
  inject box_i64 do
    let ok = apply(g: helper, v: 41)
    ()
  end
  inject stdio.system_handler do
    Console.println(val: "generic cap helper into bare Box slot: ok")
  end
end
