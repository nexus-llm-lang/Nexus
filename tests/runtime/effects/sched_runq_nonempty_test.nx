import { Coop, scheduler, spawn } from "std:concurrency/coop"
import { sched_runq_nonempty } from "std:runtime/sched"
import * as mem from "std:runtime/mem"

let ran_flag_addr = fn () -> i64 do return 854096 end

let require_true = fn (b: bool) -> unit do
  let ok = if b then 1 else 0 end
  1 / ok
  return ()
end

let require_false = fn (b: bool) -> unit do
  let ok = if b then 0 else 1 end
  1 / ok
  return ()
end

let noop_task = fn () -> unit require { Coop } do
  mem.store_i64(addr: ran_flag_addr(), val: 1)
  return ()
end

let body = fn () -> unit require { Coop } do
  mem.store_i64(addr: ran_flag_addr(), val: 0)

  require_false(b: sched_runq_nonempty())

  spawn(task: noop_task)
  require_true(b: sched_runq_nonempty())

  Coop.yield()
  require_true(b: mem.load_i64(addr: ran_flag_addr()) == 1)

  require_false(b: sched_runq_nonempty())
  return ()
end

let main = fn () -> unit do
  inject scheduler do
    body()
  end
end
