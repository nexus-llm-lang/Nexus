import { force_all } from "std:lazy"
import * as list from "std:collection/list"
import * as test_assert from "std:test/assert"

cap Counter do
  fn bump(n: i64) -> i64
end

let counter_h = handler Counter do
  fn bump(n: i64) -> i64 do
    return n + 1
  end
end

let collect_one = fn (n: i64) -> i64 require { Counter } do
  return Counter.bump(n: n)
end

let build_thunks = fn (
  ns: [ i64 ],
  acc: [ @(i64 require { Counter }) ]
) -> [ @(i64 require { Counter }) ] require { Counter } do
  match ns do
    | [] -> return list.reverse(xs: acc)
    | n :: rest ->
      let @t = collect_one(n: n)
      return build_thunks(ns: rest, acc: t :: acc)
  end
end

let run = fn () -> i64 require { Counter } do
  let thunks = build_thunks(ns: [ 10, 20, 30 ], acc: [])
  let results = force_all(tasks: thunks)
  return list.fold_left(xs: results, init: 0, f: fn (acc: i64, val: i64) -> i64 do return acc + val end)
end

let main = fn () -> unit throws { Exn } do
  inject counter_h do
    let total = run()
    test_assert.assert_eq_i64(
      actual: total,
      expected: 63,
      label: "force_all forces a list of require-row-carrying thunks, discharging the require row through the polymorphic signature"
    )
  end
  return ()
end
