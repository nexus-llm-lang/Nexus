// Acceptance for the `with @k` generator / `Yield` abstraction
// (nxlib/stdlib/concurrency/generator.nx, epic nexus-og9bo phase 3).
//
// A producer writes straight-line / looping code that `Yield.emit`s a value at
// each step; an `inject collector ... end` frame suspends at every emit and the
// `with @k` handler arm resumes the producer (`@k`) so it continues to its next
// emit. The producer accumulates into a `~`-mutable list declared inside the
// inject body and returns it as the inject's trailing value — the runtime
// channel that survives the suspend/resume lift (the handler itself cannot own
// the list; see the module docstring for the full constraint list).
//
// Two NEW producers, neither a conversion of any existing collect_*/walk_*:
//   1. range_gen(n): a straight-line numeric range generator emitting 1..n.
//      Collects [1, 2, 3, 4, 5].
//   2. odds_until(n, limit): interleaved control flow that fold/map cannot
//      express as cleanly — a nested-conditional loop that emits only odd
//      numbers and EARLY-STOPS (via a `~stop` flag) once a value exceeds
//      `limit`. With n=20, limit=8 it collects [1, 3, 5, 7].
//
// Each emit suspends into `collector` and resumes; a regression (broken resume
// trampoline, lost accumulation, or mis-ordered emit) would change the list
// contents or order, which assert_eq_i64_list catches. A pass is exit 0.
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import * as list from "std:list"
import * as assert from "std:test/assert"
import { Yield, collector } from "std:concurrency/generator"

// Producer 1: numeric range generator. Emits 1..n as straight-line code; the
// inject body accumulates each emitted value and returns the ordered list.
let range_gen = fn (n: i64) -> [ i64 ] throws { Exn } do
  inject collector do
    let ~acc = list.empty()
    for i = 1 to n + 1 do
      Yield.emit(v: i)
      ~acc <- list.cons(x: i, xs: ~acc)
    end
    list.reverse(xs: ~acc)
  end
end

// Producer 2: interleaved control flow — emit only odd numbers, early-stop once
// a value exceeds `limit`. The `~stop` flag + nested conditionals are the kind
// of imperative control flow that a `fold`/`map` over a pre-built list cannot
// express directly; here the body just emits and the generator frame drives it.
let odds_until = fn (n: i64, limit: i64) -> [ i64 ] throws { Exn } do
  inject collector do
    let ~acc = list.empty()
    let ~stop = false
    for i = 1 to n + 1 do
      if !(~stop) then
        if i > limit then
          ~stop <- true
        else
          let is_odd = (i - ((i / 2) * 2)) == 1
          if is_odd then
            Yield.emit(v: i)
            ~acc <- list.cons(x: i, xs: ~acc)
          end
        end
      end
    end
    list.reverse(xs: ~acc)
  end
end

let body = fn () -> unit throws { Exn } do
  // 1. range generator collects [1, 2, 3, 4, 5]
  assert.assert_eq_i64_list(
    actual: range_gen(n: 5),
    expected: [ 1, 2, 3, 4, 5 ],
    label: "range_gen 1..5"
  )

  // 1b. single-element range
  assert.assert_eq_i64_list(
    actual: range_gen(n: 1),
    expected: [ 1 ],
    label: "range_gen 1..1"
  )

  // 2. interleaved control flow: odds <= 8 from 1..20, early-stop at >8
  assert.assert_eq_i64_list(
    actual: odds_until(n: 20, limit: 8),
    expected: [ 1, 3, 5, 7 ],
    label: "odds_until n=20 limit=8 (early-stop)"
  )

  return ()
end

// Exit 0 only if every assertion passes. Mirrors the assert-based shape of the
// other runtime/effects tests; a failed assertion throws and traps `main`.
let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } throws { Exn } do
  inject stdio.system_handler do
    let ok = safe_run()
    if ok == 1 then
      Console.println(val: "ok")
    else
      Console.println(val: "FAILED")
    end
    // Trap (divide-by-zero) on failure so the test runner sees a non-zero exit.
    let _guard = 1 / ok
    return ()
  end
end
