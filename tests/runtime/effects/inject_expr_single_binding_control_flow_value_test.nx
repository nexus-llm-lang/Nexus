// Regression (nexus-hteqm): a SINGLE-handler (static-dispatch) inject used as an
// EXPRESSION whose body's trailing value channel is a control-flow expr (if/match)
// must thread that value out. The single-binding MIR path (wrap_inject_register
// `| [] -> return body`) returned the body unmodified, so a trailing if/match —
// which LIR lowers as a value-DROPPING statement (unlike a trailing binop) — was
// dropped, producing invalid WASM (stack underflow) or a wrong value. The fix
// binds the trailing if/match to a __hval slot and yields the slot.
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import * as str from "std:str"

cap Tag do fn n() -> i64 end
let h = handler Tag do fn n() -> i64 do return 5 end end   // single binding → static dispatch

// trailing `if` value channel
let f_if = fn (b: bool) -> i64 require { Tag } do
  let r = inject h do
    let base = Tag.n()
    if b then base + 1 else base + 2 end
  end
  return r + 1
end

// trailing `match` value channel
let f_match = fn (k: i64) -> i64 require { Tag } do
  let r = inject h do
    let base = Tag.n()
    match k do
      | 0 -> base + 10
      | _ -> base + 20
    end
  end
  return r
end

let main = fn () -> unit require { PermConsole } throws { Exn } do
  inject stdio.system_handler do
    let a = inject h do f_if(b: true) end     // (5+1)+1 = 7
    let b = inject h do f_if(b: false) end    // (5+2)+1 = 8
    let c = inject h do f_match(k: 0) end     // 5+10 = 15
    let d = inject h do f_match(k: 9) end     // 5+20 = 25
    Console.println(val: "hteqm a=" ++ str.from_i64(val: a) ++ " b=" ++ str.from_i64(val: b)
      ++ " c=" ++ str.from_i64(val: c) ++ " d=" ++ str.from_i64(val: d))
    let ok = if a == 7 && b == 8 && c == 15 && d == 25 then 1 else 0 end
    let _g = 1 / ok
    return ()
  end
end
