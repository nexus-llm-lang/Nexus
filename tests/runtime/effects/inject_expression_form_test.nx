// Feature: `inject` as a first-class EXPRESSION (dual to `if`/`match`).
//
// Before this feature, `inject H do … end` was statement-only, so a value had to
// surface via a `return` INSIDE the body: `inject H do … return v end`. Now an
// inject in EXPRESSION position yields its body's trailing value, so it can be
// `let`-bound, `return`ed, or passed as an argument:
//   - `let x = inject H do … v end`
//   - `return inject H do … v end`
//   - `f(inject H do … v end)`
//
// This test covers the brief's acceptance cases 1-3 and 5 (statement-position
// inject still works and yields unit). Case 4 (generator with a trailing value,
// no inner `return`) is in inject_expression_generator_test.nx.
//
// Two handler bindings per cap force the RUNTIME-DISPATCH path (>=2 bindings),
// which is where the inject value-channel is most fragile. Each case throws
// RuntimeError on mismatch; exit 0 means all pass.
import * as stdio from "std:stdio"

cap Tag do
  fn name() -> string
  fn id() -> i64
end

let hA = handler Tag do
  fn name() -> string do return "A" end
  fn id() -> i64 do return 1 end
end

let hB = handler Tag do
  fn name() -> string do return "B" end
  fn id() -> i64 do return 2 end
end

// Case 1: `let x = inject H do … v end` binds x to the inject's trailing value.
let let_bound = fn () -> string require { Tag } do
  let x = inject hB do Tag.name() end
  return x
end

// Case 1b: same, with an i64 channel and a multi-statement body.
let let_bound_i64 = fn () -> i64 require { Tag } do
  let n = inject hB do
    let base = Tag.id()
    base + 40
  end
  return n
end

// Case 2: `return inject H do … v end` returns the inject value directly.
let return_inject = fn () -> string require { Tag } do
  return inject hB do Tag.name() end
end

// Case 3: inject as a function ARGUMENT.
let prefix = fn (s: string) -> string do
  return "got-" ++ s
end

let inject_as_arg = fn () -> string require { Tag } do
  return prefix(s: inject hB do Tag.name() end)
end

// Case 5 helper: statement-position inject (side-effect) still works and yields
// unit. We observe its effect by mutating a ref the body writes through, since
// the inject here is a bare statement, not an expression.
let stmt_side_effect = fn () -> i64 require { Tag } do
  let ~acc = 0
  inject hB do
    ~acc <- Tag.id()
  end
  return ~acc
end

let assert_str = fn (label: string, got: string, want: string) -> unit throws { RuntimeError } do
  if !(got == want) then
    throw RuntimeError(val: label ++ ": got '" ++ got ++ "', want '" ++ want ++ "'")
  end
end

let assert_i64 = fn (label: string, got: i64, want: i64) -> unit throws { RuntimeError } do
  if !(got == want) then
    throw RuntimeError(val: label ++ ": wrong value")
  end
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    inject hA do
      // Case 1: let-bound inject expression
      assert_str(label: "let-bound", got: let_bound(), want: "B")

      // Case 1b: let-bound i64 channel, multi-statement body
      assert_i64(label: "let-bound-i64", got: let_bound_i64(), want: 42)

      // Case 2: return inject expression
      assert_str(label: "return-inject", got: return_inject(), want: "B")

      // Case 3: inject as a call argument
      assert_str(label: "inject-as-arg", got: inject_as_arg(), want: "got-B")

      // Case 5: statement-position inject still works (yields unit; effect observed)
      assert_i64(label: "stmt-side-effect", got: stmt_side_effect(), want: 2)

      // The outer handler is restored after each inner inject scope closes.
      assert_str(label: "outer-restored", got: Tag.name(), want: "A")
    end
  end
end
