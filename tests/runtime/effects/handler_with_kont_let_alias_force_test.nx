// Acceptance: a `with @k` continuation binder forced INDIRECTLY through a bare
// `let`-alias (`let kk = k; @kk`) must resume the captured continuation exactly
// like the syntactically-direct `@k`.
//
// Before the fix the indirect force miscompiled: only the direct `@k` form was
// lowered to `op_resume`; `@kk` (where `kk` is an ordinary local holding the
// continuation's i64 table-slot index) fell through to the generic thunk-force
// path, which dereferenced that slot index as a heap pointer and SIGSEGV'd at
// runtime. Typecheck accepted it (the binder has thunk type `@κ`) and the build
// succeeded, so the crash only surfaced when the program ran.
//
// Fix (option A, let-alias): MIR tracks a bare `let kk = k` whose RHS is a
// current continuation binder and registers `kk` as a continuation binder for
// the rest of the arm scope, so a later `@kk` lowers to `MirResume`/`op_resume`
// just like `@k`. The alias is scoped to the arm body (the arm boundary in
// lower_arms_with_konts restores the binder set), so it never leaks.
//
// `Co.ask()` SUSPENDS into the handler; the arm's `@kk` RESUMES the captured
// continuation so the body continues past the suspend boundary. Both the direct
// and the aliased handler must yield the same value across two suspend/resume
// boundaries. Assertions run AFTER the resume frame has exited (the inject has
// returned), so they never throw across the live continuation — exit 0 means
// the indirect force resumed correctly.
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import * as str from "std:str"

cap Co do
  fn ask() -> i64
end

// Direct form: `@k` (the control case — must keep resuming after the fix).
let direct_h = handler Co do
  fn ask() -> i64 with @k do
    @k
  end
end

// Indirect form: `@kk` where `kk` is a bare `let`-alias of the cont binder `k`.
let alias_h = handler Co do
  fn ask() -> i64 with @k do
    let kk = k
    @kk
  end
end

// A second alias hop (`let a = k; let b = a; @b`) must chain through too.
let alias2_h = handler Co do
  fn ask() -> i64 with @k do
    let a = k
    let b = a
    @b
  end
end

let drive_direct = fn () -> i64 throws { RuntimeError } do
  inject direct_h do
    let _a = Co.ask()
    let s1 = 10
    let _b = Co.ask()
    return s1 + 5
  end
end

let drive_alias = fn () -> i64 throws { RuntimeError } do
  inject alias_h do
    let _a = Co.ask()
    let s1 = 10
    let _b = Co.ask()
    return s1 + 5
  end
end

let drive_alias2 = fn () -> i64 throws { RuntimeError } do
  inject alias2_h do
    let _a = Co.ask()
    let s1 = 10
    let _b = Co.ask()
    return s1 + 5
  end
end

let assert_i64 = fn (label: string, got: i64, want: i64) -> unit throws { RuntimeError } do
  if !(got == want) then
    throw RuntimeError(val: label ++ ": got " ++ str.from_i64(val: got) ++ ", want " ++ str.from_i64(val: want))
  end
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    let d = drive_direct()
    assert_i64(label: "direct-kont", got: d, want: 15)
    let a = drive_alias()
    assert_i64(label: "let-alias-kont", got: a, want: 15)
    let a2 = drive_alias2()
    assert_i64(label: "two-hop-alias-kont", got: a2, want: 15)
    Console.println(val: "ok")
  end
end
