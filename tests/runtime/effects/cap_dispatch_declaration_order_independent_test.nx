// Regression: cross-function cap dispatch must be driven by the dynamic inject
// scope, NOT by source declaration order. The bug's discriminating evidence was
// that swapping the two handlers' declaration order flipped the output while the
// inject nesting stayed identical — proof the helper resolved to whichever
// handler binding was found first, ignoring the dynamic scope.
//
// Here `inner_h` is declared BEFORE `outer_h`, but the inject nesting still puts
// inner_h innermost. The dynamically-innermost handler (inner_h) must win, so
// the helper observes INNER regardless of declaration order. Throws on mismatch;
// a pass is exit 0.
import * as stdio from "std:stdio"

cap Tag do
  fn name() -> string
end

// Declared first — under the old bug this would be the first-resolved handler
// and the helper would print INNER for the wrong reason. The nesting below makes
// inner_h the innermost inject, so INNER is also the dynamically-correct answer;
// the companion test pins the OUTER-innermost direction to rule out coincidence.
let inner_h = handler Tag do
  fn name() -> string do
    return "INNER"
  end
end

let outer_h = handler Tag do
  fn name() -> string do
    return "OUTER"
  end
end

let who = fn () -> string require { Tag } do
  return Tag.name()
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    // outer_h innermost here: dynamic scope says OUTER, even though outer_h was
    // declared LAST. Declaration order must not matter.
    inject inner_h do
      inject outer_h do
        let got = who()
        if !(got == "OUTER") then
          throw RuntimeError(val: "declaration-order leaked: helper hit '" ++ got ++ "', expected OUTER (innermost inject)")
        end
      end
    end
  end
end
