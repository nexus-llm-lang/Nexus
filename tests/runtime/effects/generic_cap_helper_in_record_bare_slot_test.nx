// Generic-capability require-row subtyping, ACCEPT side — the
// helper is stored in a RECORD FIELD typed with the element-agnostic bare
// `require { Box }`, then projected out and called. As with the direct HOF
// parameter form, a concrete generic-cap actual `Box<i64>` (the helper's derived
// contract) must be admitted by the bare `Box` field-slot — the subtyping check
// runs structurally on the function type carried by the field, so the same
// `Box<τ> ⊆ Box` rule applies wherever a function-with-require-row is unified
// against a bare-`Box` slot.
//
// twyov: the handler arm is a plain (no `with @k`) computation; the program
// takes only the success path and exits 0.
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import * as str from "std:str"

cap Box<T> do
  fn wrap(x: T) -> i64
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1
  end
end

// Body commits Box at i64 → published contract `require { Box<i64> }`.
let helper = fn (n: i64) -> i64 require { Box } do
  return Box.wrap(x: n)
end

// A record whose field type is a function with the bare `require { Box }` slot.
type Holder = Holder(g: (n: i64) -> i64 require { Box })

let run = fn (h: Holder, v: i64) -> i64 require { Box } do
  let Holder(g: fn0) = h
  return fn0(n: v)
end

let main = fn () -> unit require { PermConsole } do
  inject box_i64 do
    let ok = run(h: Holder(g: helper), v: 41)
    ()
  end
  inject stdio.system_handler do
    Console.println(val: "generic cap helper in record bare Box slot: ok")
  end
end
