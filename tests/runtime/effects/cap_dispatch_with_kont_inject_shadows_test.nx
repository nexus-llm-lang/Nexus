// Regression: when a cap has BOTH a plain handler AND a `with @k` handler, and
// they are nested so the kont handler is dynamically-innermost, the runtime cap
// dispatcher must select the INNER (kont) handler — inner-shadows-outer.
//
// The runtime dispatcher reads the cap's `__hreg` register slot to pick a
// handler id. The non-kont inject path writes that slot (via
// `wrap_inject_register`) on entry and restores it on exit. The `with @k`
// inject path (the stack-switching resume frame) originally did NOT write the
// slot, so after entering the inner kont inject the slot still held the OUTER
// plain handler's id. A same-cap call reached across a function-call boundary
// (forcing the dispatcher) then forwarded to the outer plain handler — the
// wrong one.
//
// The fix makes the `with @k` inject write the cap's `__hreg` slot to the kont
// handler's id on entry and restore it on exit, mirroring the plain inject path
// (`wrap_inject_resume_register`). With the slot set correctly, the dispatcher's
// with-kont arm fires and `@k` resumes the suspended body.
//
// Assertion is by SIDE EFFECT, not by the inject's trailing value (a nested
// value-producing inject under an outer plain inject drops its trailing value —
// a separate, pre-existing limitation). The OUTER plain handler, if ever
// selected, traps via divide-by-zero; the INNER kont handler resumes cleanly.
// So:
//   - kont serviced emit (correct)  → resumes, "KONT-ran"/"resumed-drive", exit 0
//   - plain serviced emit (the bug) → trap inside plain handler → non-zero exit
//
// The cap call lives in a CALLED helper (`drive`), so it routes through the
// generated `__dispatch_Ev_emit` rather than resolving statically at the inject
// site — this is the path the bug corrupted.

import { Console } from "std:stdio"
import * as stdio from "std:stdio"

cap Ev do
  fn emit() -> unit
end

// First-declared handler for Ev: plain arm. Two handlers for Ev force the
// runtime dispatcher; this one is injected as the OUTER scope. If it is ever
// selected for the inner-injected call, that is the bug — trap loudly.
let plain_ev = handler Ev require { Console } do
  fn emit() -> unit do
    Console.println(val: "PLAIN-ran (WRONG: outer plain shadowed inner kont)")
    let zero = 0
    let _trap = 1 / zero
    return ()
  end
end

// Second handler for Ev: `with @k` arm, injected dynamically-INNERMOST. It must
// shadow the outer plain handler for the same cap. `@k` resumes the body.
let kont_ev = handler Ev require { Console } do
  fn emit() -> unit with @k do
    Console.println(val: "KONT-body-ran")
    @k
  end
end

// The cap call lives here, reached across a function-call boundary so it routes
// through the generated dispatcher rather than resolving statically.
let drive = fn () -> unit require { Ev, Console } do
  Ev.emit()
  Console.println(val: "resumed-drive")
end

// plain_ev outer (both bindings live → dispatcher), kont_ev innermost (must win).
let run = fn () -> unit require { Console } do
  inject plain_ev do
    inject kont_ev do
      drive()
    end
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    run()
    Console.println(val: "ok")
  end
end
