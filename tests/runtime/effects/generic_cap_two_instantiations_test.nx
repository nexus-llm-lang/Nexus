// Generic capabilities (`cap Foo<T>`): a single type-parameterised cap and a
// single generic producer, reused at TWO element types (i64 and string), both
// type-checking and running end-to-end.
//
// Before generic caps existed, `cap Box<T> do ... end` was a parse error
// (E1004, "expected do, got '<'") and every cap was monomorphic — a string
// generator had to be a parallel `cap` + handler duplicating the i64 shape.
//
// What this exercises:
//   1. Parsing: `cap Box<T> do fn put(v: T) -> unit end` (type params on a cap).
//   2. Representation: the cap carries its type params through HIR.
//   3. Typecheck: the cap method `Box.put` is registered as a POLYMORPHIC
//      scheme `forall T. (v: T) -> unit require {Box}` from the cap declaration
//      (mirroring generic functions), so each call instantiates T fresh.
//   4. Handler instantiation: a `handler Box do fn put(v: i64) ...` arm
//      instantiates the cap at i64; a separate arm at `v: string` instantiates
//      at string. The arm signature IS the instantiation site — the cap's T is
//      matched structurally against the concrete arm type before the T-Handler
//      arm/cap equality check.
//   5. One generic producer `produce<T>(v: T)` is injected under the i64 handler
//      AND the string handler. Both monomorphisations build and run.
//
// twyov: every `with @k` resume here takes the success path and the program
// exits 0; failure is never signalled via a post-resume trap.
import * as stdio from "std:stdio"
import { Console } from "std:stdio"

/** A generic sink capability: a producer calls `Box.put(v)` at each step. */
cap Box<T> do
  fn put(v: T) -> unit
end

/** Handler instantiating Box at i64 (resume-only collector). */
let box_i64 = handler Box do
  fn put(v: i64) -> unit with @k do
    @k
  end
end

/** Handler instantiating Box at string (resume-only collector). */
let box_str = handler Box do
  fn put(v: string) -> unit with @k do
    @k
  end
end

/** ONE generic producer, reused at every element type. */
let produce = fn <T> (v: T) -> i64 require { Box } do
  Box.put(v: v)
  return 0
end

let main = fn () -> unit require { PermConsole } do
  inject box_i64 do
    let a = produce(v: 7)
    ()
  end
  inject box_str do
    let b = produce(v: "hello")
    ()
  end
  inject stdio.system_handler do
    Console.println(val: "generic cap: i64 + string instantiations ok")
  end
end
