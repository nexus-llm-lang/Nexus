// Regression: a Cap.method() call inside a thunk body must lower correctly.
// Previously the lifted thunk body treated the cap-method-qualified name
// (e.g. `<mod>#Tag.name`) as a free variable of the lambda, capturing it
// into the closure environment; codegen then failed with E3001
// "variable '<mod>#Tag.name' not found (in emit_atom_var)" because no
// such symbol exists — cap calls are rewritten at lowering time to the
// concrete __handler_<binding>_<method> function call.
//
// This test exercises lazy effect-deferral: the cap call is captured under
// a thunk, then forced inside the inject scope. The dispatched value must
// reflect the handler active at the force site.
import * as stdio from "std:stdio"

cap Tag do
  fn name() -> string
end

let h_a = handler Tag do
  fn name() -> string do
    return "A"
  end
end

let f = fn () -> @(string require { Tag }) do
  let @t = Tag.name()
  return t
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    inject h_a do
      let th = f()
      let got = @th
      if !(got == "A") then
        throw RuntimeError(val: "thunk-deferred cap call dispatched to '" ++ got ++ "', expected A")
      end
    end
  end
end
