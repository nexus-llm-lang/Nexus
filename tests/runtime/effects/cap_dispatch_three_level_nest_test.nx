// Regression: a 3-level inject nest of handlers for the same cap must pick the
// innermost at each call site, and the runtime handler register must be RESTORED
// when each inner inject scope closes so that sibling/outer cap calls observe the
// correct (re-exposed) handler. The cap call is reached through a helper at every
// level. Throws on the first wrong value; a pass is exit 0.
import * as stdio from "std:stdio"

cap Tag do
  fn name() -> string
end

let h1 = handler Tag do
  fn name() -> string do
    return "ONE"
  end
end

let h2 = handler Tag do
  fn name() -> string do
    return "TWO"
  end
end

let h3 = handler Tag do
  fn name() -> string do
    return "THREE"
  end
end

let who = fn () -> string require { Tag } do
  return Tag.name()
end

let expect = fn (got: string, want: string) -> unit throws { RuntimeError } do
  if !(got == want) then
    throw RuntimeError(val: "3-level nest: helper hit '" ++ got ++ "', expected " ++ want)
  end
end

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject stdio.system_handler do
    inject h1 do
      expect(got: who(), want: "ONE")
      inject h2 do
        expect(got: who(), want: "TWO")
        inject h3 do
          expect(got: who(), want: "THREE")
        end
        // h3 scope closed: register restored to h2.
        expect(got: who(), want: "TWO")
      end
      // h2 scope closed: register restored to h1.
      expect(got: who(), want: "ONE")
    end
  end
end
