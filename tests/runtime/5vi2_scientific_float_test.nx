// Regression: lexer must recognize `e`/`E` exponent suffixes inside float
// literals as part of one token, not split off as a trailing identifier
// (nexus-5vi2). Before the fix `1.0e308` lexed as `TkFloat("1.0")` followed
// by `TkIdent("e308")`, producing "unbound variable: e308" at parse time.
import * as test_assert from "std:test/assert"

let abs_f64 = fn (val: f64) -> f64 do
  if val <. 0.0 then return 0.0 -. val end
  return val
end

let body = fn () -> unit throws { Exn } do
  // Each literal exercises a distinct shape of the exponent suffix:
  //   - explicit fractional + lowercase `e` + large positive exponent
  //   - integer-style mantissa + lowercase `e` (no fractional dot)
  //   - explicit `-` sign on the exponent
  //   - uppercase `E`
  //   - exponent of zero (still must lex as one token, not float + ident)
  let a = 1.0e308
  let b = 1e10
  let c = 1.5e-5
  let d = 2.5E308
  let e = 0.0e0

  // Compare against arithmetic-built equivalents so we know the literal
  // was lexed AND parsed AND lowered with the right magnitude. Equality
  // is exact because each rhs is the same f64 the literal denotes.
  test_assert.assert_eq_bool(actual: a >. 0.0, expected: true, label: "1.0e308 positive")
  test_assert.assert_eq_bool(actual: b ==. 10000000000.0, expected: true, label: "1e10 == 1e10")
  test_assert.assert_eq_bool(actual: c >. 0.0, expected: true, label: "1.5e-5 positive")
  test_assert.assert_eq_bool(actual: c <. 1.0, expected: true, label: "1.5e-5 < 1.0")
  test_assert.assert_eq_bool(actual: d >. 0.0, expected: true, label: "2.5E308 positive")
  test_assert.assert_eq_bool(actual: e ==. 0.0, expected: true, label: "0.0e0 == 0.0")
  // Guard against the old buggy lex: e308 used to be an identifier; a
  // working lexer treats the suffix as part of `a` so abs(a) is finite-huge.
  test_assert.assert_eq_bool(actual: abs_f64(val: a) >. 1.0, expected: true, label: "1.0e308 huge")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
