// Port of bootstrap/tests/runtime/functions.rs:
//   tcmc_list_map_produces_correct_result,
//   tcmc_deep_list_build_does_not_overflow.
import * as test_assert from "std:test/assert"

type IntList = INil | ICons(v: i64, rest: IntList)

let map_double = fn (xs: IntList) -> IntList do
  match xs do
    | INil -> return INil
    | ICons(v: v, rest: rest) ->
      return ICons(v: v * 2, rest: map_double(xs: rest))
  end
end

let sum = fn (xs: IntList, acc: i64) -> i64 do
  match xs do
    | INil -> return acc
    | ICons(v: v, rest: rest) -> return sum(xs: rest, acc: acc + v)
  end
end

let iota = fn (n: i64) -> IntList do
  if n <= 0 then return INil end
  return ICons(v: n, rest: iota(n: n - 1))
end

let head = fn (xs: IntList) -> i64 do
  match xs do
    | INil -> return 0
    | ICons(v: v, rest: _) -> return v
  end
end

let length_acc = fn (xs: IntList, acc: i64) -> i64 do
  match xs do
    | INil -> return acc
    | ICons(v: _, rest: rest) -> return length_acc(xs: rest, acc: acc + 1)
  end
end

let body = fn () -> unit throws { Exn } do
  // tcmc_list_map: build [1,2,3], double, sum -> 12.
  let xs = ICons(v: 1, rest: ICons(v: 2, rest: ICons(v: 3, rest: INil)))
  let doubled = map_double(xs: xs)
  test_assert.assert_eq_i64(actual: sum(xs: doubled, acc: 0), expected: 12, label: "sum of doubled [1,2,3]")
  // Deep TCMC: iota(5000) head=5000, length=5000 (no stack overflow).
  let big = iota(n: 5000)
  test_assert.assert_eq_i64(actual: head(xs: big), expected: 5000, label: "head iota(5000)")
  test_assert.assert_eq_i64(actual: length_acc(xs: big, acc: 0), expected: 5000, label: "length iota(5000)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
