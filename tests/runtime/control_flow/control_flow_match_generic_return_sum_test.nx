// Regression test for nexus-zl2n3 (sum sub-case):
// A multi-constructor sum value returned through a GENERIC function at a
// concrete type (callee returns bare `T`) must match the correct arm and bind
// each payload field correctly, including a constructor with a 3+-field
// payload. The matched value carries its concrete sum type so tag dispatch and
// per-field payload extraction resolve correctly.
//
// Distinct payload values are deliberate so an offset-0 / wrong-field scramble
// would surface as a wrong expected sum.
import * as test_assert from "std:test/assert"

type S =
  A(p: i64, q: i64, r: i64)
  | B(x: i64)
  | C(u: i64, v: i64, w: i64)

let idg = fn <T>(v: T) -> T do
  return v
end

let classify = fn (s: S) -> i64 throws { Exn } do
  match s do
    | A(p: pp, q: qq, r: rr) -> return pp + qq * 1000 + rr * 1000000
    | B(x: xx) -> return xx
    | C(u: uu, v: vv, w: ww) -> return uu + vv * 1000 + ww * 1000000
  end
end

let body = fn () -> unit throws { Exn } do
  let sa = idg(v: A(p: 11, q: 22, r: 33))
  let sb = idg(v: B(x: 42))
  let sc = idg(v: C(u: 4, v: 5, w: 6))
  test_assert.assert_eq_i64(
    actual: classify(s: sa),
    expected: 33022011,
    label: "generic-return-sum A"
  )
  test_assert.assert_eq_i64(actual: classify(s: sb), expected: 42, label: "generic-return-sum B")
  test_assert.assert_eq_i64(
    actual: classify(s: sc),
    expected: 6005004,
    label: "generic-return-sum C"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
