// Regression for nexus-4i35e and nexus-ulrva — both concern a bare `|` at the
// tail of a non-last match-arm body that is token-identical to the start of a
// following `<lit> | _ ->` arm. The construct `... -> <expr> | <lit> | _ -> ...`
// is genuinely ambiguous; nexus-ulrva (P1 silent miscompile) settles the
// disambiguation: a depth-0 `|` at arm-body infix position cedes to
// arm-separation whenever the tokens that follow form a valid pattern ending
// in `->`. So `| 0 -> return 1 | 2 | _ -> 0` parses as body `1` and the
// or-pattern arm `2 | _ -> 0` (NOT body `1 | 2` then arm `_`). To intend a
// bitwise-or body before a `_` arm, parenthesize: `return (1 | 2)`.
//
// pipe_scan no longer short-circuits on a downstream `| _ ->`: once a depth-0
// `|` is crossed during the lookahead we are inside a candidate or-pattern arm,
// so reaching `->` proves the queried `|` was a real arm separator.
import * as test_assert from "std:test/assert"

// Parenthesized bitwise-or body before a `_` arm. `(1 | 2)` = 3 stays a body.
let repro = fn (n: i64) -> i64 do
  match n do
    | 0 -> return (1 | 2)
    | _ -> return 0
  end
end

// Parenthesized bitwise-or chain `(a | b | c)` in a non-last arm body.
let chain = fn (n: i64) -> i64 do
  match n do
    | 0 -> return (1 | 2 | 4)
    | _ -> return 0
  end
end

// Expression-statement form (no `return`): `a | b` in a `let` binding is
// unaffected — the next token after the operand is `return` (an abort token),
// so the `|` is bitwise-or regardless of any later `| _ ->`.
let expr_stmt = fn (n: i64) -> i64 do
  match n do
    | 0 ->
      let r = 1 | 2
      return r
    | _ -> return 0
  end
end

// Or-patterns must still work: `| A | B ->` at the arm head is handled by
// parse_pattern_or (not pipe_starts_arm), so this is unaffected.
let or_pat = fn (n: i64) -> i64 do
  match n do
    | 1 | 2 | 3 -> return 100
    | _ -> return 0
  end
end

// Or-patterns after a non-empty arm body using simple literals must still work:
// `| 10 | 20 ->` (inner `|` followed by `20`, not `_`) continues scanning.
let or_pat_after_body = fn (n: i64) -> i64 do
  match n do
    | 0 -> return 99
    | 10 | 20 -> return 200
    | _ -> return 0
  end
end

// Or-pattern with a constructor-with-fields alt followed by `_`:
// `| Ctor(_) | _ ->` — the `(` sets had_transition=true, so the abort check is
// skipped and the or-pattern is recognised correctly.
type Wrapper = Wrap(v: i64) | Other

let ctor_or_wild = fn (w: Wrapper) -> i64 do
  match w do
    | Wrap(v) -> return v
    | Other -> return 42
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: repro(n: 0), expected: 3, label: "repro 0→1|2=3")
  test_assert.assert_eq_i64(actual: repro(n: 1), expected: 0, label: "repro 1→0")
  test_assert.assert_eq_i64(actual: chain(n: 0), expected: 7, label: "chain 1|2|4=7")
  test_assert.assert_eq_i64(actual: chain(n: 1), expected: 0, label: "chain 1→0")
  test_assert.assert_eq_i64(actual: expr_stmt(n: 0), expected: 3, label: "expr_stmt 1|2=3")
  test_assert.assert_eq_i64(actual: or_pat(n: 2), expected: 100, label: "or_pat 2→100")
  test_assert.assert_eq_i64(actual: or_pat(n: 5), expected: 0, label: "or_pat 5→0")
  test_assert.assert_eq_i64(actual: or_pat_after_body(n: 0), expected: 99, label: "or_pat_after 0→99")
  test_assert.assert_eq_i64(actual: or_pat_after_body(n: 10), expected: 200, label: "or_pat_after 10→200")
  test_assert.assert_eq_i64(actual: or_pat_after_body(n: 20), expected: 200, label: "or_pat_after 20→200")
  test_assert.assert_eq_i64(actual: or_pat_after_body(n: 5), expected: 0, label: "or_pat_after 5→0")
  test_assert.assert_eq_i64(actual: ctor_or_wild(w: Wrap(v: 7)), expected: 7, label: "ctor_or_wild Wrap(7)")
  test_assert.assert_eq_i64(actual: ctor_or_wild(w: Other), expected: 42, label: "ctor_or_wild Other")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
