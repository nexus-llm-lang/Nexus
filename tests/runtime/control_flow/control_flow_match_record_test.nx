// Port of bootstrap/tests/runtime/control_flow.rs::codegen_match_record_pattern_*
// and codegen_match_expr_record_pattern.
import * as test_assert from "std:test/assert"

let check_stmt = fn (r: { x: i64, y: i64 }) -> i64 do
  match r do
    | { x: a, y: b } -> return a + b
  end
end

let sum_fields = fn (r: { x: i64, y: i64 }) -> i64 do
  let result = match r do
    | { x: a, y: b } -> a + b
  end
  return result
end

let body = fn () -> unit throws { Exn } do
  let r = { y: 2, x: 40 }
  test_assert.assert_eq_i64(actual: check_stmt(r), expected: 42, label: "match-stmt record")
  let r2 = sum_fields(r: { x: 40, y: 2 })
  test_assert.assert_eq_i64(actual: r2, expected: 42, label: "match-expr record")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
