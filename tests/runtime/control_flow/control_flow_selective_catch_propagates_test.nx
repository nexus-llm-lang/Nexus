// nexus-7hbia: a selective `catch` whose thrown exception matches NO arm must
// RE-THROW (propagate) the original exception out of the function — it must NOT
// fall into an adjacent constructor arm and read a foreign payload.
//
// Before the fix the selective-`catch` desugar (`catch __exn -> match __exn ...`)
// had no residual arm, so an unmatched variant collapsed into the only/last
// ctor arm: the 3-deep case below returned 2100 (= EC.c * 7, EC's payload read
// through EA's binder) instead of 9300 (= EC.c * 31, propagated to the outer
// `| EC ->` arm). The fix appends a synthetic `| __exn_v -> throw __exn_v`
// re-throw arm so unmatched variants propagate via the function's throws row.
import * as test_assert from "std:test/assert"

exception EA(a: i64)
exception EB(b: i64)
exception EC(c: i64)

// `describe` catches only EA/EB. `throw EC` matches no arm → propagates out
// (EC is in `describe`'s declared throws row as the residual).
let describe = fn (which: i64) -> i64 throws { EC } do
  try
    if which == 0 then throw EA(a: 100)
    else if which == 1 then throw EB(b: 200)
    else throw EC(c: 300) end
  catch
    | EA(a: x) -> return x * 7
    | EB(b: y) -> return y * 3
  end
end

// `outer` catches the propagated EC.
let outer = fn (which: i64) -> i64 throws { Exn } do
  try
    return describe(which: which)
  catch
    | EC(c: z) -> return z * 31
  end
end

let body = fn () -> unit throws { Exn } do
  // which=0: EA matches describe's first arm → 100 * 7 = 700.
  test_assert.assert_eq_i64(actual: outer(which: 0), expected: 700, label: "EA matches inner arm")
  // which=1: EB matches describe's second arm → 200 * 3 = 600.
  test_assert.assert_eq_i64(actual: outer(which: 1), expected: 600, label: "EB matches inner arm")
  // which=2: EC matches NO inner arm → propagates to outer → 300 * 31 = 9300.
  test_assert.assert_eq_i64(
    actual: outer(which: 2),
    expected: 9300,
    label: "EC propagates to outer"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
