// Regression test for nexus-wk54x: && must short-circuit (not eager bitwise-and).
// Before the fix, `false && trap_if_zero(0)` would trap with integer divide by zero.
import * as test_assert from "std:test/assert"

let trap_if_zero = fn (i: i64) -> bool do
  return (100 / i) > 0
end

let safe_and = fn (i: i64) -> bool do
  return i != 0 && (100 / i) > 0
end

let body = fn () -> unit throws { Exn } do
  // false && _ must not evaluate the RHS
  let r1 = false && trap_if_zero(i: 0)
  test_assert.assert_eq_bool(actual: r1, expected: false, label: "false && _ skips RHS")

  // true && _ evaluates RHS
  let r2 = true && trap_if_zero(i: 5)
  test_assert.assert_eq_bool(actual: r2, expected: true, label: "true && _ evaluates RHS")

  // guard idiom: i=0 returns false without dividing
  test_assert.assert_eq_bool(
    actual: safe_and(i: 0),
    expected: false,
    label: "&& guard: i=0 short-circuits"
  )
  test_assert.assert_eq_bool(
    actual: safe_and(i: 5),
    expected: true,
    label: "&& guard: i=5 both sides"
  )

  // chained: a && b && c — only evaluates as far as first false
  let r3 = false && trap_if_zero(i: 0) && trap_if_zero(i: 0)
  test_assert.assert_eq_bool(actual: r3, expected: false, label: "false && _ && _ skips both RHS")

  // precedence: !t && true = (!t) && true = false && true = false
  let t = true
  test_assert.assert_eq_bool(actual: !t && true, expected: false, label: "!t && true precedence")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
