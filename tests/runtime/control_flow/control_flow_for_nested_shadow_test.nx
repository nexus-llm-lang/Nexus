// Regression test for nexus-ejani: nested for-loops reusing the same
// loop-variable name must not alias each other's counter / end-bound slots.
// Before the desugar_for hygiene fix, `for i .. for i ..` clobbered the outer
// counter after the inner loop, so nested_count() returned 2 instead of 6 and
// outer_after_inner() read a corrupted outer `i`.
import * as test_assert from "std:test/assert"

// 3 outer iterations * 2 inner iterations = 6 body executions.
let nested_count = fn () -> i64 do
  let ~count = 0
  for i = 0 to 3 do
    for i = 0 to 2 do
      ~count <- ~count + 1
    end
  end
  return ~count
end

// After the inner `for i` finishes, the OUTER `i` must still be intact:
// summing the outer i over its 3 iterations is 0 + 1 + 2 = 3.
let outer_after_inner = fn () -> i64 do
  let ~sum = 0
  for i = 0 to 3 do
    for i = 0 to 2 do
      let ~ignore = i
      ~ignore <- ~ignore
    end
    ~sum <- ~sum + i
  end
  return ~sum
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: nested_count(),
    expected: 6,
    label: "nested for-loop same var: 3*2 body runs"
  )
  test_assert.assert_eq_i64(
    actual: outer_after_inner(),
    expected: 3,
    label: "outer i intact after inner same-name loop"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
