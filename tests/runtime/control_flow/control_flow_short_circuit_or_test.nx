// Regression test for nexus-wk54x: || must short-circuit (not eager bitwise-or).
// Before the fix, `true || trap_if_zero(0)` would trap with integer divide by zero.
import * as test_assert from "std:test/assert"

let trap_if_zero = fn (i: i64) -> bool do
  return (100 / i) > 0
end

let safe_or = fn (i: i64) -> bool do
  return i == 0 || (100 / i) > 0
end

let body = fn () -> unit throws { Exn } do
  // true || _ must not evaluate the RHS
  let r1 = true || trap_if_zero(i: 0)
  test_assert.assert_eq_bool(actual: r1, expected: true, label: "true || _ skips RHS")

  // false || _ evaluates RHS
  let r2 = false || trap_if_zero(i: 5)
  test_assert.assert_eq_bool(actual: r2, expected: true, label: "false || _ evaluates RHS")

  // guard idiom: i=0 returns true without dividing
  test_assert.assert_eq_bool(
    actual: safe_or(i: 0),
    expected: true,
    label: "|| guard: i=0 short-circuits"
  )
  test_assert.assert_eq_bool(
    actual: safe_or(i: 5),
    expected: true,
    label: "|| guard: i=5 both sides (100/5=20 > 0)"
  )

  // chained: a || b || c — only evaluates as far as first true
  let r3 = true || trap_if_zero(i: 0) || trap_if_zero(i: 0)
  test_assert.assert_eq_bool(actual: r3, expected: true, label: "true || _ || _ skips both RHS")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
