// Structural equality for `==` / `!=` on RECURSIVE sum operands (spec § T-Cmp).
// A recursive type (`Tree`, mutually-recursive `Even`/`Odd`, a hand-rolled
// cons-list) unfolds to unbounded depth, so the comparison cannot be expanded
// statically to a fixed depth. The compiler synthesizes a per-type structural
// compare helper (`__streq_<Name>`) that recurses at RUN TIME — calling itself
// at a recursive field position — and terminates on finite values.
//
// Before the runtime-helper approach the recursive field positions fell back to
// heap-pointer identity, so two independently-built EQUAL recursive values
// (whose recursive sub-values live at different addresses) wrongly compared
// `false`. These asserts build each operand independently so equal structures
// never share a pointer.
import * as test_assert from "std:test/assert"

// Self-recursive sum: a binary tree.
type Tree = Leaf | Node(left: Tree, right: Tree, v: i64)

// Mutually recursive sums.
type Even = Zero | ESucc(odd: Odd)
type Odd = OSucc(even: Even)

// Recursive cons-list (LNil/LCons avoid the reserved built-in List ctors).
type IntList = LNil | LCons(head: i64, tail: IntList)

// A recursive type with a string payload, to exercise the string-compare path
// reached THROUGH the runtime recursion.
type SList = SNil | SCons(s: string, rest: SList)

let body = fn () -> unit throws { Exn } do
  // ── Binary tree: independently-built equal trees compare structurally. ──
  let t1 = Node(left: Node(left: Leaf, right: Leaf, v: 1), right: Leaf, v: 2)
  let t2 = Node(left: Node(left: Leaf, right: Leaf, v: 1), right: Leaf, v: 2)
  let t3 = Node(left: Node(left: Leaf, right: Leaf, v: 9), right: Leaf, v: 2)
  let t4 = Node(left: Leaf, right: Leaf, v: 2)
  test_assert.assert_eq_bool(actual: t1 == t2, expected: true, label: "equal trees compare equal")
  test_assert.assert_eq_bool(actual: t1 == t3, expected: false, label: "unequal nested value")
  // Differing SHAPE at a recursive position (Node vs Leaf): must not read the
  // shorter operand's payload — just report false.
  test_assert.assert_eq_bool(actual: t1 == t4, expected: false, label: "unequal nested shape")
  test_assert.assert_eq_bool(actual: t1 != t2, expected: false, label: "equal trees via !=")
  test_assert.assert_eq_bool(actual: t1 != t3, expected: true, label: "unequal trees via !=")
  test_assert.assert_eq_bool(actual: Leaf == Leaf, expected: true, label: "Leaf == Leaf")

  // ── Mutually recursive Even/Odd: helper for Even calls the helper for Odd. ──
  let e1 = ESucc(odd: OSucc(even: Zero))
  let e2 = ESucc(odd: OSucc(even: Zero))
  let e3 = ESucc(odd: OSucc(even: ESucc(odd: OSucc(even: Zero))))
  test_assert.assert_eq_bool(actual: e1 == e2, expected: true, label: "equal Even (mutual rec)")
  test_assert.assert_eq_bool(actual: e1 == e3, expected: false, label: "unequal Even depth")
  test_assert.assert_eq_bool(actual: Zero == Zero, expected: true, label: "Zero == Zero")

  // ── Cons-list of i64. ──
  let l1 = LCons(head: 1, tail: LCons(head: 2, tail: LCons(head: 3, tail: LNil)))
  let l2 = LCons(head: 1, tail: LCons(head: 2, tail: LCons(head: 3, tail: LNil)))
  let l3 = LCons(head: 1, tail: LCons(head: 2, tail: LNil))
  let l4 = LCons(head: 1, tail: LCons(head: 9, tail: LCons(head: 3, tail: LNil)))
  test_assert.assert_eq_bool(actual: l1 == l2, expected: true, label: "equal lists")
  test_assert.assert_eq_bool(actual: l1 == l3, expected: false, label: "unequal list length")
  test_assert.assert_eq_bool(actual: l1 == l4, expected: false, label: "unequal list element")

  // ── Cons-list with string payloads: string compare under the recursion. ──
  let s1 = SCons(s: "a", rest: SCons(s: "b", rest: SNil))
  let s2 = SCons(s: "a", rest: SCons(s: "b", rest: SNil))
  let s3 = SCons(s: "a", rest: SCons(s: "c", rest: SNil))
  test_assert.assert_eq_bool(actual: s1 == s2, expected: true, label: "equal string lists")
  test_assert.assert_eq_bool(
    actual: s1 == s3,
    expected: false,
    label: "unequal string list element"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
