// Structural equality for `==` / `!=` on SUM (ADT) operands (spec § T-Cmp).
// Sums compare by VALUE: same constructor tag AND all payload fields
// structurally equal. Nullary constructors compare by tag alone; different tags
// are unequal. Before the fix `==` on a sum lowered to an i32 pointer compare,
// so two distinct-but-equal constructor applications wrongly reported `false`.
import * as test_assert from "std:test/assert"

type Color = Red | Green | Blue
type Box = Box(n: i64)
type Shape = Circle(r: i64) | Rect(h: i64, w: i64)
type Tagged = Tagged(label: string, n: i64)
// Deep nesting: a constructor whose payload is itself a sum and a sum.
type Wrap = Wrap(c: Color, s: Shape)

let body = fn () -> unit throws { Exn } do
  // Nullary constructors: tag-only equality.
  let r1 = Red
  let r2 = Red
  let g1 = Green
  test_assert.assert_eq_bool(actual: r1 == r2, expected: true, label: "Red == Red")
  test_assert.assert_eq_bool(actual: r1 == g1, expected: false, label: "Red != Green")
  test_assert.assert_eq_bool(actual: r1 != g1, expected: true, label: "Red != Green via !=")

  // Single-payload constructor: compare the payload field.
  let p = Box(n: 700)
  let q = Box(n: 700)
  let s = Box(n: 701)
  test_assert.assert_eq_bool(actual: p == q, expected: true, label: "Box(700) == Box(700)")
  test_assert.assert_eq_bool(actual: p == s, expected: false, label: "Box(700) != Box(701)")

  // Multi-variant enum: same vs different variant, and differing payloads.
  let c1 = Circle(r: 3)
  let c2 = Circle(r: 3)
  let c3 = Circle(r: 4)
  let rect = Rect(h: 3, w: 3)
  test_assert.assert_eq_bool(actual: c1 == c2, expected: true, label: "Circle(3) == Circle(3)")
  test_assert.assert_eq_bool(actual: c1 == c3, expected: false, label: "Circle(3) != Circle(4)")
  test_assert.assert_eq_bool(actual: c1 == rect, expected: false, label: "Circle != Rect (different tag)")

  // String payload: routes through the string value-compare.
  let t1 = Tagged(label: "hi", n: 1)
  let t2 = Tagged(label: "hi", n: 1)
  let t3 = Tagged(label: "ho", n: 1)
  test_assert.assert_eq_bool(actual: t1 == t2, expected: true, label: "Tagged str payload equal")
  test_assert.assert_eq_bool(actual: t1 == t3, expected: false, label: "Tagged str payload unequal")

  // Deep nesting: constructor payload is a sum (Color) and a sum (Shape).
  let w1 = Wrap(c: Red, s: Circle(r: 7))
  let w2 = Wrap(c: Red, s: Circle(r: 7))
  let w3 = Wrap(c: Blue, s: Circle(r: 7))
  let w4 = Wrap(c: Red, s: Circle(r: 8))
  test_assert.assert_eq_bool(actual: w1 == w2, expected: true, label: "Wrap deep equal")
  test_assert.assert_eq_bool(actual: w1 == w3, expected: false, label: "Wrap deep unequal nested color")
  test_assert.assert_eq_bool(actual: w1 == w4, expected: false, label: "Wrap deep unequal nested payload")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
