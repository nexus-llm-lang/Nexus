// nexus-m0f2: For-loop in expression position must emit start/end let-bindings.
// Tests for-loop appearing as a let-value and with an outer-variable bound —
// positions where lower_expr's For branch fires instead of desugar_for.
import * as test_assert from "std:test/assert"

// For in let-value position: side effects (mutations to ~acc) must run.
let for_in_let_value = fn () -> i64 do
  let ~acc = 0
  for i = 0 to 5 do
    ~acc <- ~acc + i
  end
  return ~acc
end

// For with an outer variable as the upper bound — tests free-variable capture
// in the lifted closure.
let for_with_outer_bound = fn (n: i64) -> i64 do
  let ~sum = 0
  for i = 0 to n do
    ~sum <- ~sum + i
  end
  return ~sum
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: for_in_let_value(),
    expected: 10,
    label: "for in let-value: sum 0..5"
  )
  test_assert.assert_eq_i64(
    actual: for_with_outer_bound(n: 5),
    expected: 10,
    label: "for in let-value with outer bound n=5"
  )
  test_assert.assert_eq_i64(
    actual: for_with_outer_bound(n: 0),
    expected: 0,
    label: "for in let-value empty range"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
