// nexus-8xulk: a selective `catch` whose UNCAUGHT residual IS in the enclosing
// declared throws row must (a) typecheck and (b) at runtime propagate the
// residual variant out to the caller's handler — the correct nexus-7hbia
// behavior, now guarded against the catch-all-misdetection regression.
//
// `handle` declares `throws { E2 }`, catches only `E1`, and the try body throws
// `E2`. E2 matches no catch arm → propagates via the synthetic residual arm →
// reaches `outer`'s `| E2 ->` handler. (Contrast the negative fixture
// try_catch_residual_escapes_closed_row.nx where the SAME shape under
// `throws {}` is a type error because E2 is not declared.)
import * as test_assert from "std:test/assert"

exception E1(a: i64)
exception E2(b: i64)

// Catches only E1; throws E2 in the body. E2 is the declared residual.
let handle = fn (which: i64) -> i64 throws { E2 } do
  try
    if which == 0 then throw E1(a: 11) else throw E2(b: 22) end
  catch
    | E1(a: x) -> return x * 7
  end
end

// Catches the propagated E2.
let outer = fn (which: i64) -> i64 throws { Exn } do
  try
    return handle(which: which)
  catch
    | E2(b: y) -> return y * 100
  end
end

let body = fn () -> unit throws { Exn } do
  // which=0: E1 matches handle's only arm → 11 * 7 = 77.
  test_assert.assert_eq_i64(actual: outer(which: 0), expected: 77, label: "E1 caught in handle")
  // which=1: E2 matches NO arm in handle → propagates (declared residual) →
  // caught by outer → 22 * 100 = 2200.
  test_assert.assert_eq_i64(actual: outer(which: 1), expected: 2200, label: "E2 residual propagates to outer")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
