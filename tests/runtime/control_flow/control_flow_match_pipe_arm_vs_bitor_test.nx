// Regression for nexus-ulrva (P1 silent miscompile): when a match-arm body ends
// in a `|`-operand expression (literal OR variable) and a LATER arm has the flat
// shape `<pat> | _ -> ...`, the parser wrongly absorbed that later arm's first
// alternative into the earlier arm's body as bitwise-or, and DROPPED the
// pattern. `| 0 -> return 100 | 5 | _ -> return 200` made `g(0)` return 101
// (= 100 | 5) instead of 100, and the `5` arm vanished (AST showed 2 cases).
//
// Root cause: pipe_scan in src/frontend/parse_core.nx short-circuited on a
// downstream `| _ ->`, concluding the QUERIED `|` (the real arm boundary) was
// bitwise-or. The fix stops the lookahead at the first depth-0 `|` that is
// itself a valid arm separator: once an arm boundary is crossed, a later
// `| _ ->` is part of THAT arm's or-pattern, not evidence about the queried `|`.
import * as test_assert from "std:test/assert"

// Primary bug shape: literal body `100`, then or-pattern arm `5 | _`.
// Pre-fix: g(0) = 101 (= 100 | 5) and the `5` pattern was dropped.
// Post-fix: g(0) = 100 (body is `100`); the `5` arm matches distinctly.
let g = fn (n: i64) -> i64 do
  match n do
    | 0 -> return 100
    | 5 | _ -> return 200
  end
end

// Variable-body variant: body is the variable `base` (= 42), then `5 | _`.
// Pre-fix: gv(0) = 47 (= 42 | 5). Post-fix: gv(0) = 42.
let gv = fn (n: i64) -> i64 do
  let base = 42
  match n do
    | 0 -> return base
    | 5 | _ -> return 200
  end
end

// Guard: a genuine bitwise-or in a (last) arm body still computes `5 | 2` = 7.
let bitor_body = fn (n: i64) -> i64 do
  match n do
    | 0 -> return 1
    | _ -> return 5 | 2
  end
end

// Guard: a bitwise-or chain `1 | 4 | 2` = 7 in a (last) arm body still works.
let bitor_chain = fn (n: i64) -> i64 do
  match n do
    | 0 -> return 1
    | _ -> return 1 | 4 | 2
  end
end

let body = fn () -> unit throws { Exn } do
  // (a) The bug shape: g(0) is the literal body, NOT 100|5.
  test_assert.assert_eq_i64(actual: g(n: 0), expected: 100, label: "g(0)=100 not 101")
  // The `5` arm must actually match (distinct from the wildcard).
  test_assert.assert_eq_i64(actual: g(n: 5), expected: 200, label: "g(5)=200 via 5|_ arm")
  test_assert.assert_eq_i64(actual: g(n: 9), expected: 200, label: "g(9)=200 via wildcard")
  // Variable-body variant.
  test_assert.assert_eq_i64(actual: gv(n: 0), expected: 42, label: "gv(0)=42 not 47")
  test_assert.assert_eq_i64(actual: gv(n: 5), expected: 200, label: "gv(5)=200 via 5|_ arm")
  // (b) Guard: legitimate bitwise-or in an arm body still works.
  test_assert.assert_eq_i64(actual: bitor_body(n: 9), expected: 7, label: "bitor_body 5|2=7")
  test_assert.assert_eq_i64(actual: bitor_chain(n: 9), expected: 7, label: "bitor_chain 1|4|2=7")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
