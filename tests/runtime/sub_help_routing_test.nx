// nexus-svef: `nexus <sub> --help` must return subcommand-specific help,
// not the global usage block.
//
// Root cause: `subcommand_specs()` in src/cli/specs.nx omitted `lint_subspec()`
// and `fix_subspec()`, so `lookup_subcommand_spec` returned None for "lint" and
// "fix" and `try_dispatch_help` fell back to global usage. Additionally,
// `try_dispatch_help` handled `nexus help --help` incorrectly: the `a == "help"`
// arm matched before the `b == "--help"` arm, causing it to look up "--help"
// as a subcommand name (which always fails) instead of "help".
//
// Fix: add lint_subspec() to subcommand_specs(); add an early-exit branch in
// try_dispatch_help for `nexus help --help|h`.
//
// Note: `nexus fix` has been retired (nexus-pro10). Auto-fix is now part of
// `nexus lint --fix` / `nexus lint --fix-diff`. The `fix` subcommand is no
// longer in `subcommand_specs()`.
//
// This test drives lookup_subcommand_spec + render_subcommand_help directly
// (same pipeline that print_subcommand_help executes) for all subcommands
// and asserts the resulting text contains SYNOPSIS and the subcommand name.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import { render_subcommand_help } from "std:argparse"
import { subcommand_specs, lookup_subcommand_spec } from "src/cli/specs.nx"
import { Option, Some, None } from "std:option"

// Assert that lookup_subcommand_spec finds `name` and that the rendered help
// text contains both "SYNOPSIS" and the subcommand name.
let check_sub = fn (name: string) -> unit throws { Exn } do
  match lookup_subcommand_spec(specs: subcommand_specs(), name) do
    | None ->
      test_assert.assert_true(cond: false, label: "svef: lookup_subcommand_spec returned None for " ++ name)
    | Some(val: spec) ->
      let out = render_subcommand_help(prog: "nexus", spec)
      test_assert.assert_true(
        cond: str.contains(s: out, sub: "SYNOPSIS"),
        label: "svef: " ++ name ++ " --help output contains SYNOPSIS"
      )
      test_assert.assert_true(
        cond: str.contains(s: out, sub: name),
        label: "svef: " ++ name ++ " --help output contains subcommand name"
      )
  end
  return ()
end

let body = fn () -> unit throws { Exn } do
  // These were always in subcommand_specs() and should pass at baseline.
  check_sub(name: "build")
  check_sub(name: "run")
  check_sub(name: "typecheck")
  check_sub(name: "ast")
  check_sub(name: "hir")
  check_sub(name: "lir")
  check_sub(name: "types")
  check_sub(name: "caps")
  check_sub(name: "repl")
  check_sub(name: "mcp")
  check_sub(name: "explain")
  check_sub(name: "context")
  check_sub(name: "test")
  check_sub(name: "fmt")
  check_sub(name: "grep")
  check_sub(name: "skill")
  check_sub(name: "help")

  // nexus-svef regression: lint was absent from subcommand_specs().
  check_sub(name: "lint")
  // nexus-pro10: `nexus fix` subcommand retired; auto-fix is now `nexus lint --fix`.
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
