// Regression for nexus-kmib: self-host lazy (`@x`) runtime correctness.
//
// The original bug report observed a wasm trap "undefined element: out of
// bounds table access" when self-host code forced a `@T` thunk. Repro
// investigation confirmed the trap is no longer present: `let @x = expr`
// + `@x` (force) lower correctly through HIR.Thunk -> MIR.MakeClosure ->
// LIR.Force -> wasm call_indirect against the lifted `__closure_*`
// functions registered in the element section.
//
// This fixture exercises the patterns that previously failed (basic bind+
// force, value capture, function call inside thunk, multiple nested
// thunks) so any future regression in the lazy-thunk lowering pipeline
// surfaces here.
import * as test_assert from "std:test/assert"

let compute = fn (a: i64, b: i64) -> i64 do
  return a + b
end

let body = fn () -> unit throws { Exn } do
  // basic bind+force
  let @x1 = 42
  let v1 = @x1
  test_assert.assert_eq_i64(actual: v1, expected: 42, label: "kmib basic force")

  // thunk closes over a local
  let y = 10
  let @x2 = y + 1
  let v2 = @x2
  test_assert.assert_eq_i64(actual: v2, expected: 11, label: "kmib captures variable")

  // thunk body invokes a function over captured args
  let a = 3
  let b = 4
  let @result = compute(a: a, b: b)
  let v3 = @result
  test_assert.assert_eq_i64(actual: v3, expected: 7, label: "kmib thunk fn call")

  // multiple nested thunks share the same fixture call
  let @x4 = 100
  let @x5 = 200
  let v4 = @x4
  let v5 = @x5
  test_assert.assert_eq_i64(actual: v4 + v5, expected: 300, label: "kmib multiple thunks")

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
