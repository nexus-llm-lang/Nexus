// Port of bootstrap/tests/runtime/functions.rs::codegen_module_alias_call_compiles.
// Imports `examples/math.nx` via `as math` and calls `math.add`.
import * as test_assert from "std:test/assert"
import * as math from "examples/math.nx"

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: math.add(a: 19, b: 23), expected: 42, label: "math.add(19, 23)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
