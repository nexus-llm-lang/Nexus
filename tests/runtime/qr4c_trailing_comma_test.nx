// Regression for nexus-qr4c: tree-sitter grammar and the language spec
// already accept a trailing comma in list literals (`[e, ...,]`), array
// literals (`[|e, ...,|]`), and list patterns (`[p, ...,]`). The self-host
// parser at `parse_comma_exprs` rejected the trailing form for the two
// expression shapes (the pattern case in `parse_list_pats` already
// supported it). This test exercises all three shapes to keep the
// self-host parser converged with the grammar/spec.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  // List expr with trailing comma.
  let xs = [1, 2, 3,]
  match xs do
    | a :: b :: c :: [] ->
      test_assert.assert_eq_i64(actual: a, expected: 1, label: "list expr trailing comma elt 0")
      test_assert.assert_eq_i64(actual: b, expected: 2, label: "list expr trailing comma elt 1")
      test_assert.assert_eq_i64(actual: c, expected: 3, label: "list expr trailing comma elt 2")
    | _ -> raise RuntimeError(val: "list expr trailing comma: shape")
  end

  // List expr without trailing comma still works.
  let ys = [10, 20, 30]
  match ys do
    | d :: e :: f :: [] ->
      test_assert.assert_eq_i64(actual: d, expected: 10, label: "list expr no trailing comma elt 0")
      test_assert.assert_eq_i64(actual: e, expected: 20, label: "list expr no trailing comma elt 1")
      test_assert.assert_eq_i64(actual: f, expected: 30, label: "list expr no trailing comma elt 2")
    | _ -> raise RuntimeError(val: "list expr no trailing comma: shape")
  end

  // Array expr with trailing comma. Owned arrays are linear, so each
  // index read uses a fresh literal — same pattern as
  // codegen_array_indexing_compiles_test.nx.
  let av0 = [|7, 8, 9,|][0]
  let av1 = [|7, 8, 9,|][1]
  let av2 = [|7, 8, 9,|][2]
  test_assert.assert_eq_i64(actual: av0, expected: 7, label: "array expr trailing comma elt 0")
  test_assert.assert_eq_i64(actual: av1, expected: 8, label: "array expr trailing comma elt 1")
  test_assert.assert_eq_i64(actual: av2, expected: 9, label: "array expr trailing comma elt 2")

  // Array expr without trailing comma still works.
  let bv0 = [|70, 80, 90|][0]
  let bv2 = [|70, 80, 90|][2]
  test_assert.assert_eq_i64(actual: bv0, expected: 70, label: "array expr no trailing comma elt 0")
  test_assert.assert_eq_i64(actual: bv2, expected: 90, label: "array expr no trailing comma elt 2")

  // List pattern with trailing comma (already worked pre-fix; pinned here
  // as a regression guard for the shared `,`→closer peek shape).
  let zs = [100, 200, 300]
  match zs do
    | [p, q, r,] ->
      test_assert.assert_eq_i64(actual: p, expected: 100, label: "list pat trailing comma elt 0")
      test_assert.assert_eq_i64(actual: q, expected: 200, label: "list pat trailing comma elt 1")
      test_assert.assert_eq_i64(actual: r, expected: 300, label: "list pat trailing comma elt 2")
    | _ -> raise RuntimeError(val: "list pat trailing comma: shape")
  end

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
