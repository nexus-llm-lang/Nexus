// Port of bootstrap/tests/runtime/strings.rs:
//   codegen_string_return_is_supported,
//   codegen_string_concat_operator_is_supported,
//   codegen_string_eq, codegen_string_ne,
//   codegen_string_eq_with_concat.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let _s = "hello"
  let _msg = "foo" ++ "bar"
  // string_eq
  test_assert.assert_true(cond: "hello" == "hello", label: "equal strings ==")
  test_assert.assert_false(cond: "hello" == "world", label: "different strings not ==")
  test_assert.assert_true(cond: "" == "", label: "empty strings ==")
  // string_ne
  test_assert.assert_true(cond: "hello" != "world", label: "different strings !=")
  test_assert.assert_false(cond: "hello" != "hello", label: "equal strings not !=")
  test_assert.assert_true(cond: "abc" != "abd", label: "last-byte differ !=")
  // eq with concat
  let a = "foo" ++ "bar"
  test_assert.assert_eq_string(actual: a, expected: "foobar", label: "concat == literal")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
