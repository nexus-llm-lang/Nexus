// Port of bootstrap/tests/runtime/control_flow.rs:
//   codegen_try_catch_handles_raised_exception,
//   codegen_nested_try_catch_reraise_propagates_to_outer_catch,
//   codegen_try_catch_match_constructor_wildcard_case,
//   codegen_try_catch_match_constructor_binds_payload.
import * as test_assert from "std:test/assert"

// Original Rust source uses `exception Boom(i64)` (positional field) — but
// the type-checker requires labeled fields, so we use `code:` here. Behavior
// is identical (single i64 payload).
exception Boom(code: i64)

let basic_catch = fn () -> i64 throws { Exn } do
  try
    let err = Boom(code: 42)
    raise err
    return 1
  catch e ->
    return 7
  end
  return 0
end

let nested_reraise = fn () -> i64 throws { Exn } do
  try
    try
      raise Boom(code: 1)
      return -1
    catch e ->
      raise e
      return -2
    end
    return -3
  catch outer ->
    return 9
  end
  return 0
end

let match_wildcard = fn () -> i64 throws { Exn } do
  try
    raise Boom(code: 42)
    return -1
  catch
    | Boom(code: _) -> return 1
    | _ -> return 2
  end
  return 0
end

let match_binds_payload = fn () -> i64 throws { Exn } do
  try
    raise Boom(code: 42)
    return -1
  catch
    | Boom(code: c) -> return c
    | _ -> return -2
  end
  return 0
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: basic_catch(), expected: 7, label: "basic try-catch")
  test_assert.assert_eq_i64(actual: nested_reraise(), expected: 9, label: "nested re-raise")
  test_assert.assert_eq_i64(actual: match_wildcard(), expected: 1, label: "catch Boom wildcard")
  test_assert.assert_eq_i64(actual: match_binds_payload(), expected: 42, label: "catch Boom payload")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
