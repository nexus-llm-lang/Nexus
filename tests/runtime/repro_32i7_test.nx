// Regression for nexus-32i7: a fn parameter sharing a name with a top-level
// definition must shadow the toplevel inside the function body.
//
// Pre-fix: typechecker reports a return-type mismatch on `bar`, because the
// inner `foo` resolves to the toplevel `fn () -> i64` (an arrow type) rather
// than the i64 parameter. With shadowing fixed, `bar` returns its parameter
// value 42 and `main` exits cleanly.
import * as test_assert from "std:test/assert"

let foo = fn () -> i64 do return 100 end

let bar = fn (foo: i64) -> i64 do return foo end

let main = fn () -> unit throws { Exn } do
  let r = bar(foo: 42)
  test_assert.assert_eq_i64(
    actual: r,
    expected: 42,
    label: "32i7: param shadows toplevel of same name"
  )
  return ()
end
