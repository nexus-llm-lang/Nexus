// nexus-l1vl: mixed positional + labeled call-site args must end up in
// callee parameter order on the wasm stack regardless of source order.
import * as test_assert from "std:test/assert"

let f3 = fn (a: i64, b: i64, c: i64) -> i64 do
  return a * 100 + b * 10 + c
end

let body = fn () -> unit throws { Exn } do
  // 1) Pure positional (pun) — works on main.
  let a = 1
  let b = 2
  let c = 3
  let r0 = f3(a, b, c)
  test_assert.assert_eq_i64(actual: r0, expected: 123, label: "all-positional pun")

  // 2) Pure labeled in declared order.
  let r1 = f3(a: 1, b: 2, c: 3)
  test_assert.assert_eq_i64(actual: r1, expected: 123, label: "all-labeled in order")

  // 3) Pure labeled reordered.
  let r2 = f3(c: 3, a: 1, b: 2)
  test_assert.assert_eq_i64(actual: r2, expected: 123, label: "all-labeled reordered")

  // 4) Mixed: positional first, then labeled.
  let r3 = f3(a, b: 2, c: 3)
  test_assert.assert_eq_i64(actual: r3, expected: 123, label: "positional + labeled-in-order")

  // 5) Mixed: positional first, labeled reordered.
  let r4 = f3(a, c: 3, b: 2)
  test_assert.assert_eq_i64(actual: r4, expected: 123, label: "positional + labeled-reordered")

  // 6) Mixed: two positional, one labeled.
  let r5 = f3(a, b, c: 3)
  test_assert.assert_eq_i64(actual: r5, expected: 123, label: "two-pun + one-labeled")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
