// L0007 autofix: `nexus lint --fix` rewrites a single-arm match over an
// irrefutable binding into a `let` destructuring.
//
//   match e do | <pat> -> body end   ->   let <pat> = e
//                                         body
//
// Strategy mirrors lint_fix_l0001_l0002_test: write a temporary fixture,
// invoke run_lint_subcommand with --fix, and assert the rewritten content.

import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"
import * as str from "std:str"
import { run_lint_subcommand } from "src/tools/lint.nx"

// A single-arm constructor match that should rewrite to a let.
let fixture_source = fn () -> string do
  return "type Box = Box(v: i64)\n"
    ++ "let f = fn (b: Box) -> i64 do\n"
    ++ "  match b do\n"
    ++ "    | Box(v: n) -> return n + 1\n"
    ++ "  end\n"
    ++ "end\n"
end

let fixture_path = fn () -> string do
  return "./.l0007_fixture.nx"
end

let write_fixture = fn (path: string, src: string) -> unit require { Fs } throws { Exn } do
  Fs.write_string(path: path, content: src)
  return ()
end

let cleanup = fn (path: string) -> unit require { Fs } do
  try
    Fs.remove_file(path: path)
    return ()
  catch _ -> return ()
  end
end

// --fix rewrites the single-arm match into a `let Box(v: n) = b` destructure.
let test_l0007_fix = fn () -> unit require { Console, Fs } throws { Exn } do
  write_fixture(path: fixture_path(), src: fixture_source())
  let code = run_lint_subcommand(args: [ "--fix", fixture_path() ])
  test_assert.assert_eq_i64(actual: code, expected: 0, label: "l0007: --fix exits 0")
  let after = Fs.read_to_string(path: fixture_path())
  // The `match` keyword must be gone.
  test_assert.assert_true(
    cond: !str.contains(s: after, sub: "match b do"),
    label: "l0007: --fix removes the match keyword"
  )
  // A `let` destructuring of the same pattern + target must appear.
  test_assert.assert_true(
    cond: str.contains(s: after, sub: "let Box(v: n) = b"),
    label: "l0007: --fix introduces the let destructuring"
  )
  // The arm body is preserved.
  test_assert.assert_true(
    cond: str.contains(s: after, sub: "return n + 1"),
    label: "l0007: --fix preserves the arm body"
  )
  return ()
end

// After --fix the rewritten file must still compile and re-lint clean of L0007.
let test_l0007_no_finding_after_fix = fn () -> unit require { Console, Fs } throws { Exn } do
  write_fixture(path: fixture_path(), src: fixture_source())
  let code1 = run_lint_subcommand(args: [ "--fix", fixture_path() ])
  code1
  // Plain --check must exit 0 (L0007 is advisory and no longer present anyway).
  let code2 = run_lint_subcommand(args: [ "--check", fixture_path() ])
  test_assert.assert_eq_i64(actual: code2, expected: 0, label: "l0007: after fix, --check exits 0")
  return ()
end

// The wildcard arm must NOT be rewritten (drop discipline): --fix is a no-op.
let test_l0007_wildcard_not_fixed = fn () -> unit require { Console, Fs } throws { Exn } do
  let wc_src = "let g = fn (x: i64) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  write_fixture(path: fixture_path(), src: wc_src)
  let code = run_lint_subcommand(args: [ "--fix", fixture_path() ])
  code
  let after = Fs.read_to_string(path: fixture_path())
  // The match must be untouched (no `let _ =` rewrite).
  test_assert.assert_true(
    cond: str.contains(s: after, sub: "match x do"),
    label: "l0007: --fix leaves the wildcard match untouched"
  )
  test_assert.assert_true(
    cond: !str.contains(s: after, sub: "let _ ="),
    label: "l0007: --fix never produces `let _ =`"
  )
  return ()
end

let body = fn () -> unit require { Console, Fs } throws { Exn } do
  try
    test_l0007_fix()
    cleanup(path: fixture_path())
    test_l0007_no_finding_after_fix()
    cleanup(path: fixture_path())
    test_l0007_wildcard_not_fixed()
    cleanup(path: fixture_path())
    return ()
  catch e ->
    cleanup(path: fixture_path())
    throw e
  end
end

let safe_run = fn () -> i64 require { Console, Fs } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole, PermFs } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
