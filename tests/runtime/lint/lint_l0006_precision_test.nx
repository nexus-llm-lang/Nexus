// L0006 precision regression tests (nexus-2yfhq).
//
// Covers all 4 FP fixes and the true-positive controls:
//   FP1: "must be" is ordinary prose — must be silent.
//   FP2: word-boundary match — "unintended" must not match "intended".
//   FP3: word-boundary match — "non-canonical" must not match "canonical".
//   FP4: string-literal-aware scanner — `//` inside `"https://..."` is not a comment.
//   TP1: bare "canonical" without citation must still fire.
//   TP2: bare "canonical" WITH citation must stay silent.
//   TP3: "counts as" without citation fires.
//   TP4: "sanctioned" without citation fires.
//   SPAN: block comment phrase on line 3 reports span at line 3 (not line 1).

import * as test_assert from "std:test/assert"
import * as list from "std:list"
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import { LintFinding } from "src/lint/types.nx"
import { Span } from "src/types/span.nx"
import { lint_design_authority } from "src/lint/rules/design_authority.nx"

// ─── helpers ─────────────────────────────────────────────────────────────────

let codes_of = fn (fs: [ LintFinding ]) -> [ string ] do
  return codes_of_loop(fs, acc: [])
end

let codes_of_loop = fn (fs: [ LintFinding ], acc: [ string ]) -> [ string ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | LintFinding(code, severity: _, message: _, fix_it: _, span: _) :: rest ->
      return codes_of_loop(fs: rest, acc: code :: acc)
  end
end

let has_code = fn (xs: [ string ], s: string) -> bool do
  match xs do
    | [] -> return false
    | h :: rest ->
      if h == s then return true end
      return has_code(xs: rest, s)
  end
end

let fires = fn (src: string) -> bool do
  return has_code(xs: codes_of(fs: lint_design_authority(src)), s: "L0006")
end

// Return the line number of the first L0006 finding, or -1 if none.
let l0006_line = fn (fs: [ LintFinding ]) -> i64 do
  match fs do
    | [] -> return -1
    | LintFinding(
      code,
      severity: _,
      message: _,
      fix_it: _,
      span: Span(offset: _, line, col: _)
    ) :: rest ->
      if code == "L0006" then return line end
      return l0006_line(fs: rest)
  end
end

// ─── FP1: "must be" is ordinary precondition prose ───────────────────────────

let test_fp1_must_be_silent = fn () -> unit throws { Exn } do
  let src = "// The divisor must be non-zero or this returns -1.\nlet x = 1\n"
  test_assert.assert(cond: !fires(src), label: "FP1: 'must be' precondition prose is silent")
  return ()
end

// ─── FP2: word-boundary — "unintended" must not match "intended" ─────────────

let test_fp2_unintended_silent = fn () -> unit throws { Exn } do
  let src = "// Guard against an unintended overflow.\nlet x = 1\n"
  test_assert.assert(
    cond: !fires(src),
    label: "FP2: 'unintended' does not match authority phrase 'intended'"
  )
  return ()
end

// ─── FP3: word-boundary — "non-canonical" must not match "canonical" ─────────

let test_fp3_non_canonical_silent = fn () -> unit throws { Exn } do
  let src = "// non-canonical form handled below.\nlet x = 1\n"
  test_assert.assert(
    cond: !fires(src),
    label: "FP3: 'non-canonical' does not trigger 'canonical' phrase match"
  )
  return ()
end

// ─── FP4: `//` inside a string literal must not be treated as a comment ──────

let test_fp4_url_in_string_silent = fn () -> unit throws { Exn } do
  // The only `//` in this source is inside the string "https://..."; there is
  // no comment at all.  "canonical" appears only as a URL path segment.
  let src = "let link = \"https://example.com/canonical\"\n"
  test_assert.assert(
    cond: !fires(src),
    label: "FP4: '//' inside a string literal is not a comment opener"
  )
  return ()
end

// ─── TP1: "canonical" without citation must still fire ───────────────────────

let test_tp1_canonical_fires = fn () -> unit throws { Exn } do
  let src = "// This is the canonical way to do X.\nlet x = 1\n"
  test_assert.assert(cond: fires(src), label: "TP1: bare 'canonical' without citation fires L0006")
  return ()
end

// ─── TP2: "canonical" WITH citation stays silent ─────────────────────────────

let test_tp2_canonical_with_citation_silent = fn () -> unit throws { Exn } do
  let src = "// canonical representation — see docs/types.md\nlet x = 1\n"
  test_assert.assert(
    cond: !fires(src),
    label: "TP2: 'canonical' accompanied by a 'see ...' citation is silent"
  )
  return ()
end

// ─── TP3: "counts as" without citation fires ─────────────────────────────────

let test_tp3_counts_as_fires = fn () -> unit throws { Exn } do
  let src = "// A zero byte counts as whitespace here.\nlet x = 1\n"
  test_assert.assert(cond: fires(src), label: "TP3: 'counts as' without citation fires L0006")
  return ()
end

// ─── TP4: "sanctioned" without citation fires ────────────────────────────────

let test_tp4_sanctioned_fires = fn () -> unit throws { Exn } do
  let src = "// This is the sanctioned entry point.\nlet x = 1\n"
  test_assert.assert(cond: fires(src), label: "TP4: 'sanctioned' without citation fires L0006")
  return ()
end

// ─── SPAN: block comment phrase on line 3 reports at line 3 ──────────────────

let test_span_block_comment_phrase_line = fn () -> unit throws { Exn } do
  // Block comment: `/*` on line 1, authority phrase on line 3.
  // The finding must report line 3, not line 1.
  let src = "/*\n * opening line\n * canonical form used here\n */\nlet x = 1\n"
  let findings = lint_design_authority(src)
  let ln = l0006_line(fs: findings)
  test_assert.assert(
    cond: ln == 3,
    label: "SPAN: block-comment L0006 reports the phrase line, not the opening line"
  )
  return ()
end

// ─── runner ───────────────────────────────────────────────────────────────────

let body = fn () -> unit throws { Exn } do
  test_fp1_must_be_silent()
  test_fp2_unintended_silent()
  test_fp3_non_canonical_silent()
  test_fp4_url_in_string_silent()
  test_tp1_canonical_fires()
  test_tp2_canonical_with_citation_silent()
  test_tp3_counts_as_fires()
  test_tp4_sanctioned_fires()
  test_span_block_comment_phrase_line()
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
