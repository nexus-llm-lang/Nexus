// L0007 — single-arm match over an irrefutable binding pattern.
//
// Exercises `lint_program` directly on a parsed AST (Proc.exec is -1 under
// WASI preview1, same pattern as the lint_pack_test).
//
// POSITIVE (L0007 fires): single-arm `match` whose sole arm pattern is an
//   irrefutable binding — a plain variable, a single-variant constructor,
//   a tuple-as-constructor, or a record destructure.
// NEGATIVE (L0007 silent): the bare wildcard `| _ -> body` (drop discipline),
//   a multi-arm match, a refutable literal pattern, and the list
//   constructors `Cons` / `Nil`.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as list from "std:list"
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import * as lexer from "src/frontend/lexer.nx"
import { ParseDiagnostics }, * as parser from "src/frontend/parser.nx"
import { LintFinding, lint_program } from "src/lint/lint.nx"
import { LintSeverity, LintWarning, LintInfo, LintError } from "src/lint/types.nx"

let lint_source = fn (src: string) -> [ LintFinding ] do
  let tokens = lexer.tokenize(src: src)
  let ParseDiagnostics(prog, diags: _) = parser.parse_collect(tokens: tokens, file: "fixture.nx")
  return lint_program(prog: prog)
end

let codes_of = fn (fs: [ LintFinding ]) -> [ string ] do
  return codes_of_loop(fs, acc: [])
end

let codes_of_loop = fn (fs: [ LintFinding ], acc: [ string ]) -> [ string ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | LintFinding(code, severity: _, message: _, fix_it: _, span: _) :: rest ->
      return codes_of_loop(fs: rest, acc: code :: acc)
  end
end

let has_code = fn (xs: [ string ], s: string) -> bool do
  match xs do
    | [] -> return false
    | h :: rest ->
      if h == s then return true end
      return has_code(xs: rest, s)
  end
end

// ── POSITIVE: variable bind ─────────────────────────────────────────────

let test_l0007_var_bind_fires = fn () -> unit throws { Exn } do
  let src = "let f = fn (x: i64) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | y -> return y + 1\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: has_code(xs: codes, s: "L0007"),
    label: "L0007 fires on single-arm var-bind match")
  return ()
end

// ── POSITIVE: single-variant constructor ────────────────────────────────

let test_l0007_ctor_fires = fn () -> unit throws { Exn } do
  let src = "type Box = Box(v: i64)\n"
    ++ "let f = fn (b: Box) -> i64 do\n"
    ++ "  match b do\n"
    ++ "    | Box(v: n) -> return n\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: has_code(xs: codes, s: "L0007"),
    label: "L0007 fires on single-arm single-variant constructor match")
  return ()
end

// ── POSITIVE: record destructure ────────────────────────────────────────

let test_l0007_record_fires = fn () -> unit throws { Exn } do
  let src = "let f = fn (p: { a: i64, b: i64 }) -> i64 do\n"
    ++ "  match p do\n"
    ++ "    | { a: aa, b: bb } -> return aa + bb\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: has_code(xs: codes, s: "L0007"),
    label: "L0007 fires on single-arm record-destructure match")
  return ()
end

// ── NEGATIVE: bare wildcard ─────────────────────────────────────────────

let test_l0007_wildcard_silent = fn () -> unit throws { Exn } do
  // `| _ -> body` must NOT be flagged (rewriting to `let _ = e` is forbidden).
  let src = "let f = fn (x: i64) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0007"),
    label: "L0007 silent on bare wildcard arm")
  return ()
end

// ── NEGATIVE: multi-arm match ───────────────────────────────────────────

let test_l0007_multi_arm_silent = fn () -> unit throws { Exn } do
  let src = "let f = fn (x: i64) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | 0 -> return 0\n"
    ++ "    | y -> return y\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0007"),
    label: "L0007 silent on multi-arm match")
  return ()
end

// ── NEGATIVE: refutable literal pattern ─────────────────────────────────

let test_l0007_literal_silent = fn () -> unit throws { Exn } do
  // A single literal arm is refutable (non-exhaustive); never flagged.
  let src = "let f = fn (x: i64) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | 0 -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0007"),
    label: "L0007 silent on single refutable literal arm")
  return ()
end

// ── NEGATIVE: list constructor ──────────────────────────────────────────

let test_l0007_list_ctor_silent = fn () -> unit throws { Exn } do
  // `Cons` / `Nil` are refutable against a list type; never flagged.
  let src = "let f = fn (xs: [ i64 ]) -> i64 do\n"
    ++ "  match xs do\n"
    ++ "    | h :: t -> return h\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0007"),
    label: "L0007 silent on list cons constructor arm")
  return ()
end

// ── NEGATIVE: expression position (value consumed) ──────────────────────

// A single-arm match whose VALUE is consumed is in expression position; the
// `let pat = e` then `body` rewrite would be invalid syntax there, so L0007
// must stay silent.  Statement position is the ONLY place the rule fires.

let test_l0007_let_rhs_silent = fn () -> unit throws { Exn } do
  // RHS of a `let` binding: the match value is the binding's value.
  let src = "type Box = Box(v: i64)\n"
    ++ "let f = fn (b: Box) -> i64 do\n"
    ++ "  let r = match b do\n"
    ++ "    | Box(v: n) -> n\n"
    ++ "  end\n"
    ++ "  return r\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0007"),
    label: "L0007 silent on a `let x = match ...` (expression position)")
  return ()
end

let test_l0007_return_silent = fn () -> unit throws { Exn } do
  // `return match ...`: the match value is the returned value.
  let src = "type Box = Box(v: i64)\n"
    ++ "let f = fn (b: Box) -> i64 do\n"
    ++ "  return match b do\n"
    ++ "    | Box(v: n) -> n\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0007"),
    label: "L0007 silent on a `return match ...` (expression position)")
  return ()
end

let test_l0007_call_arg_silent = fn () -> unit throws { Exn } do
  // A match used as a function argument is in expression position.
  let src = "type Box = Box(v: i64)\n"
    ++ "let id = fn (x: i64) -> i64 do return x end\n"
    ++ "let f = fn (b: Box) -> i64 do\n"
    ++ "  return id(x: match b do\n"
    ++ "    | Box(v: n) -> n\n"
    ++ "  end)\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0007"),
    label: "L0007 silent on a match passed as a call argument (expression position)")
  return ()
end

// ── Severity: advisory note (never a warning) ───────────────────────────

let test_l0007_is_note_severity = fn () -> unit throws { Exn } do
  let src = "let f = fn (x: i64) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | y -> return y\n"
    ++ "  end\n"
    ++ "end\n"
  let findings = lint_source(src)
  let is_note = check_l0007_note(fs: findings)
  test_assert.assert(cond: is_note, label: "L0007 emitted at note (advisory) severity")
  return ()
end

let check_l0007_note = fn (fs: [ LintFinding ]) -> bool do
  match fs do
    | [] -> return false
    | LintFinding(code, severity, message: _, fix_it: _, span: _) :: rest ->
      if code == "L0007" then
        return severity_is_note(s: severity)
      end
      return check_l0007_note(fs: rest)
  end
end

// LintInfo is the advisory/note severity.
let severity_is_note = fn (s: LintSeverity) -> bool do
  match s do
    | LintInfo -> return true
    | LintWarning -> return false
    | LintError -> return false
  end
end

// ── Runner ──────────────────────────────────────────────────────────────

let body = fn () -> unit throws { Exn } do
  test_l0007_var_bind_fires()
  test_l0007_ctor_fires()
  test_l0007_record_fires()
  test_l0007_wildcard_silent()
  test_l0007_multi_arm_silent()
  test_l0007_literal_silent()
  test_l0007_list_ctor_silent()
  test_l0007_let_rhs_silent()
  test_l0007_return_silent()
  test_l0007_call_arg_silent()
  test_l0007_is_note_severity()
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
