// L0010 — two or more `match` arms with structurally identical bodies, fusable
// into a single or-pattern arm.
//
// Exercises `lint_program` directly on a parsed AST (Proc.exec is -1 under
// WASI preview1, same pattern as lint_l0007_test).
//
// POSITIVE (L0010 fires): two (and the 3+ case) arms whose bodies are
//   structurally equal, including arms with identical no-binder bodies.
// NEGATIVE (L0010 silent): bodies that LOOK alike but reference different
//   binders (`use(x)` vs `use(y)` — genuinely different per SKILL), a match
//   whose arms all have distinct bodies, and a single-arm match.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as list from "std:list"
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import * as lexer from "src/frontend/lexer.nx"
import { ParseDiagnostics }, * as parser from "src/frontend/parser.nx"
import { LintFinding, lint_program } from "src/lint/lint.nx"
import { LintSeverity, LintWarning, LintInfo, LintError } from "src/lint/types.nx"

let lint_source = fn (src: string) -> [ LintFinding ] do
  let tokens = lexer.tokenize(src: src)
  let ParseDiagnostics(prog, diags: _) = parser.parse_collect(tokens: tokens, file: "fixture.nx")
  return lint_program(prog: prog)
end

let codes_of = fn (fs: [ LintFinding ]) -> [ string ] do
  return codes_of_loop(fs, acc: [])
end

let codes_of_loop = fn (fs: [ LintFinding ], acc: [ string ]) -> [ string ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | LintFinding(code, severity: _, message: _, fix_it: _, span: _) :: rest ->
      return codes_of_loop(fs: rest, acc: code :: acc)
  end
end

let has_code = fn (xs: [ string ], s: string) -> bool do
  match xs do
    | [] -> return false
    | h :: rest ->
      if h == s then return true end
      return has_code(xs: rest, s)
  end
end

// ── POSITIVE: two arms with identical no-binder bodies ──────────────────────

let test_l0010_two_arm_fires = fn () -> unit throws { Exn } do
  let src = "type T = A | B | C\n"
    ++ "let f = fn (x: T) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | A -> return 1\n"
    ++ "    | B -> return 1\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: has_code(xs: codes, s: "L0010"),
    label: "L0010 fires on two arms with identical bodies")
  return ()
end

// ── POSITIVE: 3+ arms sharing a body ────────────────────────────────────────

let test_l0010_three_arm_fires = fn () -> unit throws { Exn } do
  let src = "type T = A | B | C | D\n"
    ++ "let f = fn (x: T) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | A -> return 1\n"
    ++ "    | B -> return 1\n"
    ++ "    | C -> return 1\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: has_code(xs: codes, s: "L0010"),
    label: "L0010 fires on three arms sharing a body")
  return ()
end

// ── POSITIVE: identical multi-statement bodies ──────────────────────────────

let test_l0010_multi_stmt_body_fires = fn () -> unit throws { Exn } do
  let src = "type T = A | B | C\n"
    ++ "let g = fn (n: i64) -> i64 do return n end\n"
    ++ "let f = fn (x: T) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | A ->\n"
    ++ "      let n = g(n: 5)\n"
    ++ "      return n + 1\n"
    ++ "    | B ->\n"
    ++ "      let n = g(n: 5)\n"
    ++ "      return n + 1\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: has_code(xs: codes, s: "L0010"),
    label: "L0010 fires on identical multi-statement arm bodies")
  return ()
end

// ── NEGATIVE: bodies look alike but reference different binders ──────────────

let test_l0010_different_binders_silent = fn () -> unit throws { Exn } do
  // `Pos(v: a) -> use(x: a)` vs `Neg(v: b) -> use(x: b)` — the bodies use
  // DIFFERENT variables (a vs b), so they are genuinely different (SKILL's
  // carve-out).  Structural equality distinguishes them → no L0010.
  let src = "type N = Pos(v: i64) | Neg(v: i64) | Zero\n"
    ++ "let use = fn (x: i64) -> i64 do return x end\n"
    ++ "let f = fn (n: N) -> i64 do\n"
    ++ "  match n do\n"
    ++ "    | Pos(v: a) -> return use(x: a)\n"
    ++ "    | Neg(v: b) -> return use(x: b)\n"
    ++ "    | Zero -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0010"),
    label: "L0010 silent when arm bodies reference different binders")
  return ()
end

// ── NEGATIVE: all arms have distinct bodies ─────────────────────────────────

let test_l0010_distinct_bodies_silent = fn () -> unit throws { Exn } do
  let src = "type T = A | B | C\n"
    ++ "let f = fn (x: T) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | A -> return 1\n"
    ++ "    | B -> return 2\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0010"),
    label: "L0010 silent when every arm body is distinct")
  return ()
end

// ── NEGATIVE: single-arm match (nothing to fuse) ────────────────────────────

let test_l0010_single_arm_silent = fn () -> unit throws { Exn } do
  let src = "let f = fn (x: i64) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | y -> return y\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0010"),
    label: "L0010 silent on a single-arm match")
  return ()
end

// ── Severity: advisory note (never a warning) ───────────────────────────────

let test_l0010_is_note_severity = fn () -> unit throws { Exn } do
  let src = "type T = A | B | C\n"
    ++ "let f = fn (x: T) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | A -> return 1\n"
    ++ "    | B -> return 1\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let findings = lint_source(src)
  let is_note = check_l0010_note(fs: findings)
  test_assert.assert(cond: is_note, label: "L0010 emitted at note (advisory) severity")
  return ()
end

let check_l0010_note = fn (fs: [ LintFinding ]) -> bool do
  match fs do
    | [] -> return false
    | LintFinding(code, severity, message: _, fix_it: _, span: _) :: rest ->
      if code == "L0010" then
        return severity_is_note(s: severity)
      end
      return check_l0010_note(fs: rest)
  end
end

let severity_is_note = fn (s: LintSeverity) -> bool do
  match s do
    | LintInfo -> return true
    | LintWarning -> return false
    | LintError -> return false
  end
end

// ── Runner ──────────────────────────────────────────────────────────────────

let body = fn () -> unit throws { Exn } do
  test_l0010_two_arm_fires()
  test_l0010_three_arm_fires()
  test_l0010_multi_stmt_body_fires()
  test_l0010_different_binders_silent()
  test_l0010_distinct_bodies_silent()
  test_l0010_single_arm_silent()
  test_l0010_is_note_severity()
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
