// L0008 — two-arm `match` of a binding constructor + bare wildcard fallback,
// rewritable as `if let`.
//
// Exercises `lint_program` directly on a parsed AST (Proc.exec is -1 under
// WASI preview1, same pattern as the lint_pack_test / lint_l0007_test).
//
// POSITIVE (L0008 fires): a two-arm `match` whose constructor arm binds at
//   least one field and whose other arm is the bare wildcard `_` — in BOTH
//   statement and expression position (the `if let` rewrite is valid in both,
//   per SKILL.md).
// NEGATIVE (L0008 silent): a ctor arm with NO bindings (`F(_)` or empty-field
//   ctor), a non-wildcard second arm, a record/variable/literal first arm,
//   the list constructors (Cons/Nil), single-arm and 3+-arm matches.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as list from "std:list"
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import * as lexer from "src/frontend/lexer.nx"
import { ParseDiagnostics }, * as parser from "src/frontend/parser.nx"
import { LintFinding, lint_program } from "src/lint/lint.nx"
import { LintSeverity, LintWarning, LintInfo, LintError } from "src/lint/types.nx"

let lint_source = fn (src: string) -> [ LintFinding ] do
  let tokens = lexer.tokenize(src: src)
  let ParseDiagnostics(prog, diags: _) = parser.parse_collect(tokens: tokens, file: "fixture.nx")
  return lint_program(prog: prog)
end

let codes_of = fn (fs: [ LintFinding ]) -> [ string ] do
  return codes_of_loop(fs, acc: [])
end

let codes_of_loop = fn (fs: [ LintFinding ], acc: [ string ]) -> [ string ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | LintFinding(code, severity: _, message: _, fix_it: _, span: _) :: rest ->
      return codes_of_loop(fs: rest, acc: code :: acc)
  end
end

let has_code = fn (xs: [ string ], s: string) -> bool do
  match xs do
    | [] -> return false
    | h :: rest ->
      if h == s then return true end
      return has_code(xs: rest, s)
  end
end

// A two-variant type so the constructor arm is genuinely refutable.
let prelude = fn () -> string do
  return "type Tok = TkStr(val: i64) | TkOther\n"
end

// ── POSITIVE: ctor-with-binding + wildcard, statement position ──────────────

let test_l0008_stmt_fires = fn () -> unit throws { Exn } do
  let src = prelude()
    ++ "let f = fn (t: Tok) -> i64 do\n"
    ++ "  match t do\n"
    ++ "    | TkStr(val: s) -> return s\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: has_code(xs: codes, s: "L0008"),
    label: "L0008 fires on a two-arm ctor+wildcard match (statement position)")
  return ()
end

// ── POSITIVE: same shape in EXPRESSION position (if let supports both) ──────

let test_l0008_expr_fires = fn () -> unit throws { Exn } do
  // The match value is bound by a `let` (expression position).  Unlike L0007,
  // L0008 still fires because `if let ... then ... else ... end` is a valid
  // expression form.
  let src = prelude()
    ++ "let f = fn (t: Tok) -> i64 do\n"
    ++ "  let r = match t do\n"
    ++ "    | TkStr(val: s) -> s\n"
    ++ "    | _ -> 0\n"
    ++ "  end\n"
    ++ "  return r\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: has_code(xs: codes, s: "L0008"),
    label: "L0008 fires on a two-arm ctor+wildcard match in expression position")
  return ()
end

// ── NEGATIVE: ctor arm with NO bindings (skip per SKILL) ────────────────────

let test_l0008_no_binding_ctor_silent = fn () -> unit throws { Exn } do
  // `TkOther -> ...` carries no bindings — `if let` adds syntax without payoff.
  let src = prelude()
    ++ "let f = fn (t: Tok) -> i64 do\n"
    ++ "  match t do\n"
    ++ "    | TkOther -> return 1\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0008"),
    label: "L0008 silent on a no-binding constructor arm")
  return ()
end

// ── NEGATIVE: ctor-wildcard arm `F(_)` carries no bindings ──────────────────

let test_l0008_ctor_wildcard_silent = fn () -> unit throws { Exn } do
  let src = prelude()
    ++ "let f = fn (t: Tok) -> i64 do\n"
    ++ "  match t do\n"
    ++ "    | TkStr(_) -> return 1\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0008"),
    label: "L0008 silent on a constructor-wildcard arm (no bindings)")
  return ()
end

// ── NEGATIVE: second arm is not a wildcard ──────────────────────────────────

let test_l0008_no_wildcard_silent = fn () -> unit throws { Exn } do
  let src = prelude()
    ++ "let f = fn (t: Tok) -> i64 do\n"
    ++ "  match t do\n"
    ++ "    | TkStr(val: s) -> return s\n"
    ++ "    | TkOther -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0008"),
    label: "L0008 silent when the second arm is not a bare wildcard")
  return ()
end

// ── NEGATIVE: list constructor (Cons) is the list-peel concern, not if-let ──

let test_l0008_list_ctor_silent = fn () -> unit throws { Exn } do
  let src = "let f = fn (xs: [ i64 ]) -> i64 do\n"
    ++ "  match xs do\n"
    ++ "    | h :: t -> return h\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0008"),
    label: "L0008 silent on a list cons constructor + wildcard")
  return ()
end

// ── NEGATIVE: single-arm match (L0007 territory, not L0008) ─────────────────

let test_l0008_single_arm_silent = fn () -> unit throws { Exn } do
  let src = prelude()
    ++ "let f = fn (t: Tok) -> i64 do\n"
    ++ "  match t do\n"
    ++ "    | TkStr(val: s) -> return s\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0008"),
    label: "L0008 silent on a single-arm match")
  return ()
end

// ── NEGATIVE: three-arm match (not the two-arm shape) ───────────────────────

let test_l0008_three_arm_silent = fn () -> unit throws { Exn } do
  let src = "type Tri = A(v: i64) | B | C\n"
    ++ "let f = fn (t: Tri) -> i64 do\n"
    ++ "  match t do\n"
    ++ "    | A(v: n) -> return n\n"
    ++ "    | B -> return 1\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let codes = codes_of(fs: lint_source(src))
  test_assert.assert(cond: !has_code(xs: codes, s: "L0008"),
    label: "L0008 silent on a three-arm match")
  return ()
end

// ── Severity: advisory note (never a warning) ───────────────────────────────

let test_l0008_is_note_severity = fn () -> unit throws { Exn } do
  let src = prelude()
    ++ "let f = fn (t: Tok) -> i64 do\n"
    ++ "  match t do\n"
    ++ "    | TkStr(val: s) -> return s\n"
    ++ "    | _ -> return 0\n"
    ++ "  end\n"
    ++ "end\n"
  let findings = lint_source(src)
  let is_note = check_l0008_note(fs: findings)
  test_assert.assert(cond: is_note, label: "L0008 emitted at note (advisory) severity")
  return ()
end

let check_l0008_note = fn (fs: [ LintFinding ]) -> bool do
  match fs do
    | [] -> return false
    | LintFinding(code, severity, message: _, fix_it: _, span: _) :: rest ->
      if code == "L0008" then
        return severity_is_note(s: severity)
      end
      return check_l0008_note(fs: rest)
  end
end

let severity_is_note = fn (s: LintSeverity) -> bool do
  match s do
    | LintInfo -> return true
    | LintWarning -> return false
    | LintError -> return false
  end
end

// ── Runner ──────────────────────────────────────────────────────────────────

let body = fn () -> unit throws { Exn } do
  test_l0008_stmt_fires()
  test_l0008_expr_fires()
  test_l0008_no_binding_ctor_silent()
  test_l0008_ctor_wildcard_silent()
  test_l0008_no_wildcard_silent()
  test_l0008_list_ctor_silent()
  test_l0008_single_arm_silent()
  test_l0008_three_arm_silent()
  test_l0008_is_note_severity()
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
