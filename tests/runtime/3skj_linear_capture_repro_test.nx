// nexus-3skj.b -- linear-capture closure runtime path.
//
// Closures that capture a linear binding and are invoked through a
// later let-binding (`let f = mk_capture(b: b); let y = f(z: 0)`)
// must compile, type-check, and run to completion. Required behavior
// across the pipeline:
//   - parse_type.nx: route `TkUnit TkArrow` to a unit-arrow parser
//     so `%() -> i64` parses (`()` lexes as a single TkUnit).
//   - infer.nx (T-App): peel `%`/`@` wrapper on the function side
//     and weaken linear modality on argument unification.
//   - linearity.nx (Lambda): consume outer linears referenced by the
//     lambda body when the closure is constructed.
import * as test_assert from "std:test/assert"

type Box = Box(val: i64)

let mk_capture = fn (b: %Box) -> %(z: i64) -> i64 do
  return fn (z: i64) -> i64 do
    let v = match b do | Box(val: v) -> v end
    return v + z
  end
end

let body = fn () -> unit throws { Exn } do
  let b = Box(val: 42)
  let f = mk_capture(b: b)
  let y = f(z: 3)
  test_assert.assert_eq_i64(actual: y, expected: 45, label: "captured Box yields 45")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
