// nexus-3skj.b -- linear-capture closure runtime path.
//
// Part (a) of the issue (f32 codegen) shipped in R11. Part (b) covers
// closures that capture a linear binding and are invoked through a
// later let-binding (`let f = mk_capture(b); let y = f(z: 0)`).
//
// R11 had reported the path was blocked upstream:
//   1. Self-host parser failed on `%() -> i64` because `()` lexes as
//      a single TkUnit and `is_arrow_start` only inspects '(' / ')'.
//   2. Self-host typecheck rejected `let f = mk_capture(b)` with
//      "user-defined vs other" when the parameter was %Box and the
//      argument was Box.
//   3. Once past the arg-unify, calling `f(z: 0)` reported "f is not
//      a function" because `f` had type `%(arrow)` and the call path
//      did not peel the modality wrapper.
//   4. The linearity checker required `b` to be consumed by the body
//      of `mk_capture`, but body's only use was inside an inner
//      lambda (capture) — bootstrap consumes the captured outer
//      linears at lambda-construction time; self-host did not.
//
// This commit lands those four fixes:
//   - parse_type.nx: route `TkUnit TkArrow` to a unit-arrow parser.
//   - infer.nx (T-App): peel %/@ wrapper on the function side; add
//     linear-modality weakening on argument unification.
//   - linearity.nx (Lambda): consume outer linears referenced by the
//     lambda body when the closure is constructed (bootstrap parity).
//
// The fixture below would have been blocked at every step before;
// it now compiles, type-checks, and runs to completion — proving
// the codegen path was never broken, only never reached.
import * as test_assert from "std:test/assert"

type Box = Box(val: i64)

let mk_capture = fn (b: %Box) -> %(z: i64) -> i64 do
  return fn (z: i64) -> i64 do
    let v = match b do | Box(val: v) -> v end
    return v + z
  end
end

let body = fn () -> unit throws { Exn } do
  let b = Box(val: 42)
  let f = mk_capture(b)
  let y = f(z: 3)
  test_assert.assert_eq_i64(actual: y, expected: 45, label: "captured Box yields 45")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
