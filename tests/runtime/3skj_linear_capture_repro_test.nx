// Reduced repro for nexus-3skj.b -- linear-capture closure runtime
// path (diagnosis only).
//
// nexus-dvr6.6 typecheck_linear_capture_lambda_test kept the
// linear-capture closure as a typecheck-only top-level decl because
// invoking it through `let y = f()` produced a stack-mismatch in the
// self-host codegen. Investigated under 3skj:
//
//   - The typecheck-only declaration form
//
//         let _mk = fn (%x: %i64) -> %() -> i64 do
//           return fn () -> i64 do match %x do | _ -> () end; return 1 end
//         end
//
//     trips a self-host PARSE error at the return-type position. The
//     self-host parser lexes `()` as a single TkUnit token and never
//     reaches `is_arrow_start`'s `(` -> `)` -> `->` lookahead, so the
//     leftover `-> i64` after `%(...)` produces "expected do, got '->'".
//     The source the repro would need does not reach codegen.
//
//   - A `%(z: i64) -> i64` shape (single named arg, no TkUnit) parses
//     cleanly but trips a self-host typecheck "user-defined vs other"
//     mismatch when the caller passes a `%Box` to a `%Box` parameter --
//     the rust front-end accepts the same source.
//
// Both surface as upstream (parser / typecheck) gaps in self-host, not
// the codegen stack-mismatch the issue title described. This fixture
// exercises a non-linear close-equivalent so a regression guard exists;
// the actual linear-capture runtime path is deferred to a follow-up
// (parser TkUnit-as-arrow-LHS + typecheck %UDT propagation) before
// codegen can be re-evaluated.
import * as test_assert from "std:test/assert"

type Box = Box(val: i64)

let mk_capture = fn (b: Box) -> (z: i64) -> i64 do
  return fn (z: i64) -> i64 do
    let v = match b do | Box(val: v) -> v end
    return v + z
  end
end

let body = fn () -> unit throws { Exn } do
  let b = Box(val: 42)
  let f = mk_capture(b: b)
  let y = f(z: 0)
  test_assert.assert_eq_i64(actual: y, expected: 42, label: "captured Box yields 42")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
