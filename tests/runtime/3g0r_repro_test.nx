// Reproducer for nexus-3g0r -- generic function with a closure stored in an
// ADT field where the closure parameter name shadows a return-record field
// name. Bootstrap-Rust codegen ICEs at E2010 ("conflicting wasm local types")
// on this shape; self-host codegen lifts the closure to a top-level function
// (src/ir/mir.nx::lift_lambda) so the closure body becomes its own MIR
// function with its own local-slot map, and `register_local` widens any
// remaining shadow collisions to i64 (src/backend/wasm/collect.nx) instead
// of erroring. The generic shape exercised here is a closure that produces
// `{ rng: Rng, val: T }` and is captured inside an ADT field.
import * as test_assert from "std:test/assert"

type Rng = Rng(state: i64)
type Box<T> = Box(produce: (rng: Rng) -> { rng: Rng, val: T })

let make = fn <T>(val: T) -> Box<T> do
  let g = fn (rng: Rng) -> { rng: Rng, val: T } do
    return { rng, val }
  end
  return Box(produce: g)
end

let body = fn () -> unit throws { Exn } do
  let b = make(val: 42)
  match b do
    | Box(produce: p) ->
      let r0 = Rng(state: 7)
      let result = p(rng: r0)
      let v = result.val
      test_assert.assert_eq_i64(actual: v, expected: 42, label: "Box<i64> closure returns captured val")
      return ()
  end
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
