// Issue nexus-cgfd — `nexus explain <symbol>` smoke test.
//
// Drives the `run_explain` driver directly: write a small Nexus source file
// to disk, invoke `run_explain` against it for a known symbol, and assert
// that the rendered output contains the expected signature/location and
// docstring fragments.
//
// Subprocess (`nexus explain` via Proc.exec) is the moral equivalent and is
// what an agent would invoke; here we drive the in-process entry point
// because `Proc.exec` is a -1 stub under WASI preview1.
import * as test_assert from "std:test/assert"
import { ExplainText, ExplainJson, run_explain } from "src/tools/explain.nx"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"
import * as str from "std:str"

let fixture_source = fn () -> string do
  return "/** Add two i64 values. */\n"
      ++ "let add = fn (x: i64, y: i64) -> i64 do\n"
      ++ "  return x + y\n"
      ++ "end\n"
      ++ "\n"
      ++ "let main = fn () -> unit do\n"
      ++ "  let _ = add(x: 1, y: 2)\n"
      ++ "  return ()\n"
      ++ "end\n"
end

let fixture_path = fn () -> string do
  return "./.cgfd_explain_fixture.nx"
end

let write_fixture = fn () -> unit require { Fs } throws { Exn } do
  Fs.write_string(path: fixture_path(), content: fixture_source())
  return ()
end

let cleanup_fixture = fn () -> unit require { Fs } do
  try
    Fs.remove_file(path: fixture_path())
    return ()
  catch _ -> return ()
  end
end

let test_explain_text = fn () -> unit require { Console, Fs } throws { Exn } do
  let out = run_explain(symbol: "add", file: fixture_path(), format: ExplainText)
  // Sanity: the rendered text must mention the symbol, its arity, and the
  // attached docstring's payload. We do not pin the exact byte layout —
  // only structurally significant substrings.
  test_assert.assert(
    cond: str.index_of(s: out, sub: "add") >= 0,
    label: "explain output contains symbol 'add'"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "x: i64") >= 0,
    label: "explain output contains 'x: i64'"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "-> i64") >= 0,
    label: "explain output contains '-> i64'"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "location:") >= 0,
    label: "explain output contains a location"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "Add two i64 values") >= 0,
    label: "explain output contains the attached docstring"
  )
  return ()
end

let test_explain_json = fn () -> unit require { Console, Fs } throws { Exn } do
  let out = run_explain(symbol: "add", file: fixture_path(), format: ExplainJson)
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"symbol\":\"add\"") >= 0,
    label: "explain json contains \"symbol\":\"add\""
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"signature\":") >= 0,
    label: "explain json contains \"signature\""
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"line\":") >= 0,
    label: "explain json contains \"line\""
  )
  return ()
end

let test_explain_not_found = fn () -> unit require { Console, Fs } throws { Exn } do
  let out = run_explain(symbol: "nonexistent_xyz", file: fixture_path(), format: ExplainText)
  test_assert.assert(
    cond: str.index_of(s: out, sub: "not found") >= 0,
    label: "explain reports missing symbol"
  )
  return ()
end

let body = fn () -> unit require { Console, Fs } throws { Exn } do
  write_fixture()
  try
    test_explain_text()
    test_explain_json()
    test_explain_not_found()
    cleanup_fixture()
    return ()
  catch e ->
    cleanup_fixture()
    throw e
  end
end

let safe_run = fn () -> i64 require { Console, Fs } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole, PermFs } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
