// Port of bootstrap/tests/runtime/records.rs::codegen_record_field_access_then_arithmetic.
// Bind two field accesses to locals, then add. Distinct from
// `records_field_access_multiple_test.nx` (inline access) — covers the path
// where the compiler must spill `.a` / `.b` to bindings before use.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let r = { x: 20, y: 22 }
  let a = r.x
  let b = r.y
  test_assert.assert_eq_i64(actual: a + b, expected: 42, label: "let a = r.x; let b = r.y; a + b")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
