// Reproducer for nexus-4ues: an i64 `return` immediately following a
// `raise` inside a `try` body, with no fall-through return after the
// `end`, must not produce a codegen error.
//
// Shape:
//
//     try
//       raise Boom(code: 42)
//       return -1     // unreachable (raise is divergent)
//     catch
//       | _ -> return 1
//     end
//     // <- no fall-through return
//
// Invariant: when `strip_unreachable_stmts` truncates a TryCatch /
// IfReturn / Switch body whose trailing block diverges, the associated
// `body_ret` / `then_ret` / `else_ret` / `default_ret` / `case.ret`
// must be cleared since their referent atom may have been stripped;
// the trailing value is unreachable anyway. At the function level, if
// `func.ret` references a name no longer defined anywhere in the body
// or params, it must be replaced with a default atom of the function's
// return type.
//
// `register_local` (src/backend/wasm/collect.nx) widens conflicting
// registrations to i64, so this shape must compile cleanly.
import * as test_assert from "std:test/assert"

exception Boom(code: i64)
exception Oops(msg: string)

// Pure single-arm wildcard catch — minimal repro shape.
let raise_then_dead_neg = fn () -> i64 do
  try
    raise Boom(code: 42)
    return -1
  catch
    | _ -> return 1
  end
end

// Selective constructor catch with payload binding (the original shape
// that hit this in dvr6.6 batch10's typecheck_effects_selective_catch
// port).
let classify_boom = fn () -> i64 do
  try
    raise Boom(code: 42)
    return -1
  catch
    | Boom(code: code) ->
      let x: i64 = code
      return x
    | _ -> return -1
  end
end

// Multi-exception catch.
let classify_oops = fn () -> i64 do
  try
    raise Oops(msg: "hi")
    return -1
  catch
    | Boom(code: c) -> return c
    | Oops(msg: m) -> return 2
    | _ -> return -1
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: raise_then_dead_neg(), expected: 1,
    label: "raise then dead neg-return -- wildcard catch")
  test_assert.assert_eq_i64(actual: classify_boom(), expected: 42,
    label: "raise then dead neg-return -- ctor catch binds payload")
  test_assert.assert_eq_i64(actual: classify_oops(), expected: 2,
    label: "raise then dead neg-return -- multi-arm catch routes")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
