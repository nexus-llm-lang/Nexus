// Structural equality for `==` / `!=` on LIST operands (spec § T-Cmp).
// A `[elem]` list compares by VALUE — same length AND element-wise structurally
// equal — not by the heap-pointer identity a plain `LirExprBinary(OpEq)` on the
// i32 list pointer produces. Before the fix `==` on lists fell through to that
// identity compare (no TyList arm in struct_eq), so two distinct-but-equal list
// literals wrongly reported `false`, and any record/sum with a list-typed field
// silently reverted to identity for that field.
//
// Each operand is built from a SEPARATE allocation so identity can never
// coincidentally pass; element VALUES are distinct so an element-order scramble
// could not mask a wrong compare. The string and nested-list cases exercise the
// element recursion (string-compare path / inner-list helper) reached THROUGH
// the generated list helper, not just the spine.
import * as test_assert from "std:test/assert"

// Record / sum carrying a list-typed field. Fields are declared in
// non-alphabetical order (`tag` before `items`, but `items` < `tag`) so a
// field-order scramble in extraction would surface as a wrong compare.
type Bag = { tag: i64, items: [ i64 ] }
type Words = WithList(xs: [ string ]) | Bare(n: i64)

let body = fn () -> unit throws { Exn } do
  // ── i64 lists: equality, inequality, length mismatch. ──
  let a = [ 1, 2, 3 ]
  let b = [ 1, 2, 3 ]
  let c = [ 1, 2, 4 ]
  let d = [ 1, 2 ]
  test_assert.assert_eq_bool(actual: a == b, expected: true,  label: "[1,2,3] == [1,2,3]")
  test_assert.assert_eq_bool(actual: a == c, expected: false, label: "[1,2,3] == [1,2,4] (element)")
  test_assert.assert_eq_bool(actual: a == d, expected: false, label: "[1,2,3] == [1,2] (length)")
  test_assert.assert_eq_bool(actual: a != c, expected: true,  label: "[1,2,3] != [1,2,4]")
  test_assert.assert_eq_bool(actual: a != b, expected: false, label: "[1,2,3] != [1,2,3] is false")

  // ── Empty lists: structurally equal; empty vs non-empty differs on length. ──
  let e1: [ i64 ] = []
  let e2: [ i64 ] = []
  test_assert.assert_eq_bool(actual: e1 == e2, expected: true,  label: "[] == []")
  test_assert.assert_eq_bool(actual: e1 == a,  expected: false, label: "[] == [1,2,3]")

  // ── Nested list-of-list: recurse into the inner list helper. ──
  let n1 = [ [ 1 ], [ 2 ] ]
  let n2 = [ [ 1 ], [ 2 ] ]
  let n3 = [ [ 1 ], [ 3 ] ]
  let n4 = [ [ 1, 2 ], [ 2 ] ]
  test_assert.assert_eq_bool(actual: n1 == n2, expected: true,  label: "[[1],[2]] == same")
  test_assert.assert_eq_bool(actual: n1 == n3, expected: false, label: "[[1],[2]] == [[1],[3]]")
  test_assert.assert_eq_bool(
    actual: n1 == n4,
    expected: false,
    label: "[[1],[2]] == [[1,2],[2]] (inner length)"
  )

  // ── List of string: element compare must use string contents, not handle id. ──
  let s1 = [ "foo", "bar" ]
  let s2 = [ "foo", "bar" ]
  let s3 = [ "foo", "baz" ]
  test_assert.assert_eq_bool(actual: s1 == s2, expected: true,  label: "string list equal")
  test_assert.assert_eq_bool(
    actual: s1 == s3,
    expected: false,
    label: "string list unequal element"
  )

  // ── Record with a list field: the field now compares structurally too. ──
  let r1 = { tag: 7, items: [ 10, 20 ] }
  let r2 = { tag: 7, items: [ 10, 20 ] }
  let r3 = { tag: 7, items: [ 10, 21 ] }
  let r4 = { tag: 8, items: [ 10, 20 ] }
  test_assert.assert_eq_bool(actual: r1 == r2, expected: true,  label: "record list field equal")
  test_assert.assert_eq_bool(
    actual: r1 == r3,
    expected: false,
    label: "record list field element differs"
  )
  test_assert.assert_eq_bool(
    actual: r1 == r4,
    expected: false,
    label: "record non-list field differs"
  )

  // ── Sum with a (string) list field: structural through tag + payload. ──
  let u1 = WithList(xs: [ "a", "b" ])
  let u2 = WithList(xs: [ "a", "b" ])
  let u3 = WithList(xs: [ "a", "c" ])
  test_assert.assert_eq_bool(actual: u1 == u2, expected: true,  label: "sum list field equal")
  test_assert.assert_eq_bool(
    actual: u1 == u3,
    expected: false,
    label: "sum list field element differs"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
