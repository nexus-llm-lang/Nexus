// Structural equality for `==` / `!=` on a LIST of ANONYMOUS records
// (`[{...}]`) — spec § T-Cmp. The element is an anonymous record (no declared
// type name), so its `__streq_List$Rec$...` helper cannot be seeded from the
// program's EnumDef / RecordDef tables; it is harvested structurally from the
// MIR and keyed by the (alphabetically sorted) field name=type set. Before the
// fix the compare fell through to the generic erased list helper
// (`__streq_List$T`), whose head compare was a single `==` on the record
// HANDLE — i.e. pointer identity — so two distinct-but-equal anon-record lists
// wrongly reported `false`. (Sibling of the named/primitive list-element cases
// in list_structural_eq_test.nx.)
//
// Test design (this bug class has been falsely "disproved" by masking repros):
//   - Each operand is built from a SEPARATE allocation, so identity can never
//     coincidentally pass.
//   - Every field carries a DISTINCT value, so an element/field-order scramble
//     could never be masked by a coincidental equal value.
//   - Fields are declared in NON-alphabetical order (`z` before `a` before `m`)
//     while the heap layout is alphabetical — so a field-order scramble in
//     extraction would surface as a wrong compare.
// The string / nested-list / nested-record field cases exercise the element
// recursion (string-compare path, inner list/record helper) reached THROUGH the
// generated anon-record list helper, not just the list spine.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  // ── Anon record with three distinct-valued fields in non-alpha order. ──
  let a = [{ z: 10, a: 20, m: 30 }, { z: 40, a: 50, m: 60 }]
  let b = [{ z: 10, a: 20, m: 30 }, { z: 40, a: 50, m: 60 }]
  test_assert.assert_eq_bool(actual: a == b, expected: true,  label: "anon-rec list equal")
  test_assert.assert_eq_bool(actual: a != b, expected: false, label: "anon-rec list != is false")

  // A difference in EACH field position must be caught — including `z`, which is
  // declared first but sorts LAST in the alphabetical heap layout.
  let diff_z = [{ z: 99, a: 20, m: 30 }, { z: 40, a: 50, m: 60 }]
  let diff_a = [{ z: 10, a: 99, m: 30 }, { z: 40, a: 50, m: 60 }]
  let diff_m = [{ z: 10, a: 20, m: 99 }, { z: 40, a: 50, m: 60 }]
  test_assert.assert_eq_bool(actual: a == diff_z, expected: false, label: "differs in z (declared first)")
  test_assert.assert_eq_bool(actual: a == diff_a, expected: false, label: "differs in a (sorts first)")
  test_assert.assert_eq_bool(actual: a == diff_m, expected: false, label: "differs in m (sorts middle)")

  // Length mismatch: same prefix, extra element.
  let longer = [{ z: 10, a: 20, m: 30 }, { z: 40, a: 50, m: 60 }, { z: 1, a: 2, m: 3 }]
  test_assert.assert_eq_bool(actual: a == longer, expected: false, label: "anon-rec list length mismatch")

  // Single-element list (exercises the Cons head compare without a tail recursion
  // step finding the difference first).
  let one1 = [{ z: 7, a: 8 }]
  let one2 = [{ z: 7, a: 8 }]
  let one3 = [{ z: 7, a: 9 }]
  test_assert.assert_eq_bool(actual: one1 == one2, expected: true,  label: "single-elem anon-rec equal")
  test_assert.assert_eq_bool(actual: one1 == one3, expected: false, label: "single-elem anon-rec differ")

  // ── String field: must compare contents, not the string handle. ──
  let s1 = [{ word: "foo", idx: 1 }, { word: "bar", idx: 2 }]
  let s2 = [{ word: "foo", idx: 1 }, { word: "bar", idx: 2 }]
  let s3 = [{ word: "foo", idx: 1 }, { word: "baz", idx: 2 }]
  test_assert.assert_eq_bool(actual: s1 == s2, expected: true,  label: "anon-rec string field equal")
  test_assert.assert_eq_bool(actual: s1 == s3, expected: false, label: "anon-rec string field differs")

  // ── Nested LIST field inside the anon record: recurse into the inner list
  //    helper through the record field (non-alpha: `vals` before `key`). ──
  let n1 = [{ vals: [7, 8], key: 1 }]
  let n2 = [{ vals: [7, 8], key: 1 }]
  let n3 = [{ vals: [7, 9], key: 1 }]
  test_assert.assert_eq_bool(actual: n1 == n2, expected: true,  label: "anon-rec nested list field equal")
  test_assert.assert_eq_bool(actual: n1 == n3, expected: false, label: "anon-rec nested list field differs")

  // ── Nested anon-RECORD field inside the anon record (non-alpha at both
  //    levels): the inner record compares structurally too. ──
  let r1 = [{ outer: 1, inner: { y: 2, x: 3 } }]
  let r2 = [{ outer: 1, inner: { y: 2, x: 3 } }]
  let r3 = [{ outer: 1, inner: { y: 2, x: 9 } }]
  test_assert.assert_eq_bool(actual: r1 == r2, expected: true,  label: "anon-rec nested record field equal")
  test_assert.assert_eq_bool(actual: r1 == r3, expected: false, label: "anon-rec nested record field differs")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
