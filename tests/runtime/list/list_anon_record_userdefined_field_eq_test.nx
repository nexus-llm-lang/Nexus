// Regression (nexus-qgnoi): `==` on a list of anonymous records whose field has
// a USER-DEFINED type (sum or record) used to abort codegen with E3001
// (`__streq_List$Rec$col=Color~n=i64` not found). The 6mu59 anon-record list-eq
// fix harvested the element shape via mir_field_type, which classified a field
// whose value is a user-defined-sum constructor (`Red(...)`) as TyI64 — so the
// synthesized helper name keyed the field `i64` while the CALL site keyed it
// `Color` (the semantic type) → name divergence → missing helper. The harvester
// now threads the program's EnumDefs and resolves a constructor to its enum, so
// both sides key by the user-defined type and the helper is synthesized.
import { Console, system_handler } from "std:stdio"
type Color = Red(shade: i64) | Blue(depth: i64)
type Pt = P(x: i64, y: i64)
let main = fn () -> unit require { PermConsole } throws { Exn } do
  inject system_handler do
    // sum-typed field
    let a = [ { col: Red(shade: 7), n: 1 } ]
    let b = [ { col: Red(shade: 7), n: 1 } ]
    let c = [ { col: Blue(depth: 9), n: 1 } ]
    // record-typed field
    let d = [ { p: P(x: 1, y: 2), m: 3 } ]
    let e = [ { p: P(x: 1, y: 2), m: 3 } ]
    let f = [ { p: P(x: 1, y: 9), m: 3 } ]
    let ok = (a == b) && !(a == c) && (d == e) && !(d == f)
    Console.println(val: if ok then "qgnoi-ok" else "FAIL" end)
    let _g = 1 / (if ok then 1 else 0 end)
    return ()
  end
end
