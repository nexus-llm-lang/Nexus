// Regression: `==` on a list of ANONYMOUS records whose field VALUE is NON-LITERAL
// (a call, a variable, a match-expression, a field-access) used to abort codegen
// with E3001 (`__streq_List$Rec$col=Color~n=i64` not found).
//
// The anon-record list-element helper is harvested from the MIR (the element has
// no declared type name). The previous harvest recovered a field's type with a
// best-effort `mir_field_type` whose catch-all erased every non-literal value form
// (call / variable / match / field-access) to `TyI64`. So the harvested helper
// keyed the field `…col=i64…` while the `==` CALL site keyed it `…col=Color…` (the
// field's semantic type, recovered by `infer_semantic_type`) — name divergence →
// the helper was never synthesized → E3001. The harvest now recovers each element
// type with the SAME `infer_semantic_type` the call site uses (a semantic-env walk
// over function params + `let` bindings), so both sides key by the real field type
// and the helper is generated for every value form.
//
// (Extension of the literal-constructor case in
// list_anon_record_userdefined_field_eq_test.nx.)
import * as test_assert from "std:test/assert"

type Color = Red(shade: i64) | Blue(depth: i64)
type Holder = { c: Color, k: i64 }
let mk = fn (s: i64) -> Color do return Red(shade: s) end

let body = fn () -> unit throws { Exn } do
  // ── Field value is a CALL (`mk(7)` : Color). ──
  let a1 = [{ col: mk(s: 7), n: 1 }]
  let b1 = [{ col: mk(s: 7), n: 1 }]
  let c1 = [{ col: mk(s: 8), n: 1 }]
  test_assert.assert_eq_bool(actual: a1 == b1, expected: true,  label: "call-valued field equal")
  test_assert.assert_eq_bool(actual: a1 == c1, expected: false, label: "call-valued field differs")

  // ── Field value is a VARIABLE bound to a sum value. ──
  let cv = mk(s: 7)
  let a2 = [{ col: cv, n: 1 }]
  let b2 = [{ col: cv, n: 1 }]
  test_assert.assert_eq_bool(actual: a2 == b2, expected: true, label: "variable-valued field equal")

  // ── Field value is a MATCH expression. ──
  let a3 = [{ col: match 1 do | 1 -> Red(shade: 7) | _ -> Blue(depth: 0) end, n: 1 }]
  let b3 = [{ col: match 1 do | 1 -> Red(shade: 7) | _ -> Blue(depth: 0) end, n: 1 }]
  let c3 = [{ col: match 1 do | 1 -> Blue(depth: 9) | _ -> Red(shade: 0) end, n: 1 }]
  test_assert.assert_eq_bool(actual: a3 == b3, expected: true,  label: "match-valued field equal")
  test_assert.assert_eq_bool(actual: a3 == c3, expected: false, label: "match-valued field differs")

  // ── Field value is a FIELD-ACCESS (`h.c` : Color). ──
  let h: Holder = { c: Red(shade: 7), k: 9 }
  let a4 = [{ col: h.c, n: 1 }]
  let b4 = [{ col: h.c, n: 1 }]
  test_assert.assert_eq_bool(actual: a4 == b4, expected: true, label: "field-access-valued field equal")

  // ── `!=` negation on the call form. ──
  test_assert.assert_eq_bool(actual: a1 != c1, expected: true,  label: "call-valued field != differs")
  test_assert.assert_eq_bool(actual: a1 != b1, expected: false, label: "call-valued field != equal is false")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
