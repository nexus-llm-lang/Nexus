// Regression: `==` / `!=` on a list of ANONYMOUS records whose field VALUE is a
// FIELD-ACCESS (`h.c`) or a MATCH-ARM-BOUND variable used to compare the field by
// POINTER IDENTITY (silent wrong `==`) or — when the field-access was let-bound
// first — abort codegen with E3001 (`__streq_List$Rec$col=Color~n=i64` not found).
//
// Residual of the non-literal-field fix (anon_record_list_nonliteral_field_eq_test):
// that fix recovered a field's type with `infer_semantic_type`, but
// `infer_semantic_type` had NO `MirFieldAccess` arm (it fell through to the
// catch-all `TyI64`) and did not register match-arm pattern binders. So a field
// VALUE that was a `.field` access — or a binder bound by a match arm — erased its
// field type to `i64`, keying the structural-compare helper `…col=i64…` (identity
// compare) instead of `…col=Color…` (structural), or diverging the harvested helper
// name from the `==` call site (E3001) when let-bound.
//
// CRITICAL: the field-access case must compare TWO DISTINCT holder values (`h1.c`
// vs `h2.c`), not the same `h.c` twice — comparing the same heap object passes even
// under the broken identity compare, masking the bug (cf. the field-access case in
// anon_record_list_nonliteral_field_eq_test.nx, which used one shared `h`).
import * as test_assert from "std:test/assert"

type Color = Red(shade: i64) | Blue(depth: i64)
type Holder = { c: Color, k: i64 }
type Wrap = Wrapped(h: Holder)

let body = fn () -> unit throws { Exn } do
  // Distinct holders carrying equal payloads — so an equal compare must be
  // STRUCTURAL (their `c` fields are different heap objects with the same value).
  let h1: Holder = { c: Red(shade: 7), k: 9 }
  let h2: Holder = { c: Red(shade: 7), k: 9 }
  let h3: Holder = { c: Blue(depth: 7), k: 9 } // differs (Blue vs Red)

  // ── Mode A: field value is an INLINE field-access (`h1.c` : Color). ──
  let a = [ { col: h1.c, n: 1 } ]
  let b = [ { col: h2.c, n: 1 } ]
  let c = [ { col: h3.c, n: 1 } ]
  test_assert.assert_eq_bool(
    actual: a == b,
    expected: true,
    label: "inline field-access equal (distinct holders)"
  )
  test_assert.assert_eq_bool(actual: a == c, expected: false, label: "inline field-access differs")
  test_assert.assert_eq_bool(
    actual: a != b,
    expected: false,
    label: "inline field-access != equal is false"
  )
  test_assert.assert_eq_bool(
    actual: a != c,
    expected: true,
    label: "inline field-access != differs"
  )

  // ── Mode B: field value is a LET-BOUND field-access (built E3001 pre-fix). ──
  let cv1 = h1.c
  let cv2 = h2.c
  let cv3 = h3.c
  let lb_a = [ { col: cv1, n: 1 } ]
  let lb_b = [ { col: cv2, n: 1 } ]
  let lb_c = [ { col: cv3, n: 1 } ]
  test_assert.assert_eq_bool(
    actual: lb_a == lb_b,
    expected: true,
    label: "let-bound field-access equal"
  )
  test_assert.assert_eq_bool(
    actual: lb_a == lb_c,
    expected: false,
    label: "let-bound field-access differs"
  )
  test_assert.assert_eq_bool(
    actual: lb_a != lb_c,
    expected: true,
    label: "let-bound field-access != differs"
  )

  // ── Mode M: field value uses a MATCH-ARM-BOUND variable's field-access. ──
  let w1 = Wrapped(h: { c: Red(shade: 7), k: 9 })
  let w2 = Wrapped(h: { c: Red(shade: 7), k: 9 })
  let w3 = Wrapped(h: { c: Blue(depth: 7), k: 9 })
  let m_a = match w1 do | Wrapped(h: hh) -> [ { col: hh.c, n: 1 } ] end
  let m_b = match w2 do | Wrapped(h: hh) -> [ { col: hh.c, n: 1 } ] end
  let m_c = match w3 do | Wrapped(h: hh) -> [ { col: hh.c, n: 1 } ] end
  test_assert.assert_eq_bool(
    actual: m_a == m_b,
    expected: true,
    label: "match-arm-bound field-access equal"
  )
  test_assert.assert_eq_bool(
    actual: m_a == m_c,
    expected: false,
    label: "match-arm-bound field-access differs"
  )
  test_assert.assert_eq_bool(
    actual: m_a != m_c,
    expected: true,
    label: "match-arm-bound field-access != differs"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
