// Regression for nexus-tt5a: a Variable reference to a top-level fn name
// must produce a closure pointer (MirMakeClosure), not auto-invoke via
// op_call.
//
// Pre-fix `let f = pure_fn` stored `pure_fn`'s RETURN VALUE because MIR
// kept arity-0 fn references as MirVariable, and codegen's emit_atom_var
// matched the name against the function table and emitted op_call.
import * as test_assert from "std:test/assert"

let pure_fn = fn () -> i64 do return 42 end

let apply = fn (g: () -> i64) -> i64 do
  return g()
end

let body = fn () -> unit throws { Exn } do
  let f = pure_fn
  test_assert.assert_eq_i64(actual: f(), expected: 42, label: "value-load arity-0 local f()")
  test_assert.assert_eq_i64(actual: apply(g: pure_fn), expected: 42, label: "apply(g: pure_fn)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
