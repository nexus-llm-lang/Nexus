// Port of bootstrap/tests/runtime/wasm_eh.rs::wasm_eh_cross_function_unwind
// (language-level analogue).
//
// The original Rust test builds a 2-function WASM module where `thrower`
// throws and `main` catches via try_table — exercising cross-frame unwinding
// of the WASM EH machinery. The language-level equivalent is a Nexus call
// chain `caller -> thrower` where `caller` wraps the call in `try ... catch`
// and verifies the i64 payload propagated through the unwound frame.
import * as test_assert from "std:test/assert"

exception WasmEhPayload(val: i64)

let thrower = fn () -> unit throws { Exn } do
  raise WasmEhPayload(val: 123)
  return ()
end

let caller = fn () -> i64 throws { Exn } do
  try
    thrower()
    return -1
  catch
    | WasmEhPayload(val: v) -> return v
    | _ -> return -2
  end
  return -3
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: caller(), expected: 123, label: "cross-function throw/catch propagates payload")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
