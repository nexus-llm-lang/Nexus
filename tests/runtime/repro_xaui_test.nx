// Regression test for nexus-xaui: a `main` that uses only language
// constructs (no std imports, no `__nx_*` externals) must compile to a
// component that exports `wasi:cli/run@0.2.6` and runs cleanly via
// `wasmtime run`.
//
// Pre-fix: the compose pipeline fed the no-imports core through the WASI
// reactor adapter, so the resulting component had no `run()` entry. The
// bundler was effectively gating wasi:cli/run on transitive
// `__nx_*`-external reach, but the correct gate is "main returns unit".
//
// Post-fix: the standalone path uses the WASI command adapter (after
// injecting a memory section the adapter binds to), so wasi:cli/run is
// always wired through when main returns unit.

let main = fn () -> unit do
  let _ = 1 + 1
  return ()
end
