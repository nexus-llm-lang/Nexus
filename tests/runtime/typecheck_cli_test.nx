// nexus-m8ey smoke: `nexus typecheck FILE` CLI threading. Regression for
// main.nx:774 where `strip_typecheck_subcommand`'s remaining-args output
// was discarded, so `strip_run_subcommand` re-saw the literal `typecheck`
// token and downstream parsers bound the input-file slot to `"typecheck"`,
// surfacing as E4004 "file not found: 'typecheck'".
//
// We can't exec the host binary from a runtime test (`Proc.exec` is a -1
// stub under WASI preview1), so we drive the strip-functions in-process in
// the exact same order the driver does and assert the threading produces
// the canonical "[prog, file]" shape — never a stray `typecheck` token.
//
// Pre-fix behaviour: `args_after_run` for input `[nexus, typecheck, foo.nx]`
// would be `[nexus, typecheck, foo.nx]` (run-mode false, no token stripped
// because `strip_run_subcommand` was being passed `args_after_output`, not
// `args_after_tc`). Post-fix: `args_after_run` is `[nexus, foo.nx]`.

import * as test_assert from "std:test/assert"
import * as list from "std:list"
import {
  ParsedTypecheckSubcommand, strip_typecheck_subcommand,
  ParsedRunSubcommand, strip_run_subcommand
} from "src/cli/subcommands.nx"

let assert_strs = fn (actual: [ string ], expected: [ string ], label: string) -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: list.length(xs: actual), expected: list.length(xs: expected), label: label ++ " (length)")
  assert_strs_zip(actual, expected, idx: 0, label)
  return ()
end

let assert_strs_zip = fn (actual: [ string ], expected: [ string ], idx: i64, label: string) -> unit throws { Exn } do
  match actual do
    | [] -> return ()
    | a :: arest ->
      match expected do
        | [] -> return ()
        | e :: erest ->
          test_assert.assert_eq_string(actual: a, expected: e, label: label ++ "[" ++ str_from_i64(n: idx) ++ "]")
          return assert_strs_zip(actual: arest, expected: erest, idx: idx + 1, label)
      end
  end
end

let str_from_i64 = fn (n: i64) -> string do
  if n == 0 then return "0" end
  return loop_digits(n, acc: "")
end

let loop_digits = fn (n: i64, acc: string) -> string do
  if n == 0 then return acc end
  let d = n - (n / 10) * 10
  let c = digit_char(d)
  return loop_digits(n: n / 10, acc: c ++ acc)
end

let digit_char = fn (d: i64) -> string do
  if d == 0 then return "0" end
  if d == 1 then return "1" end
  if d == 2 then return "2" end
  if d == 3 then return "3" end
  if d == 4 then return "4" end
  if d == 5 then return "5" end
  if d == 6 then return "6" end
  if d == 7 then return "7" end
  if d == 8 then return "8" end
  return "9"
end

let body = fn () -> unit throws { Exn } do
  // 1. `nexus typecheck foo.nx`: strip_typecheck_subcommand peels the
  //    `typecheck` token and sets typecheck_only=true. The threaded
  //    remaining must be [prog, file] so the downstream run-parser sees
  //    a clean argv and doesn't bind the input file to the literal
  //    `"typecheck"`.
  let ParsedTypecheckSubcommand(remaining: tc_rem, typecheck_only: tc_flag) =
    strip_typecheck_subcommand(xs: [ "nexus", "typecheck", "foo.nx" ])
  test_assert.assert_eq_bool(actual: tc_flag, expected: true, label: "typecheck → typecheck_only")
  assert_strs(actual: tc_rem, expected: [ "nexus", "foo.nx" ], label: "typecheck strips 'typecheck' token")

  // 2. Thread the result through strip_run_subcommand exactly the way
  //    main.nx does. The post-fix sequence must NOT see `typecheck` and
  //    must NOT enter run_mode. Pre-fix this received the raw input and
  //    `args_after_run` ended up with `typecheck` as positional arg 1.
  let ParsedRunSubcommand(remaining: run_rem, run_mode, run_args: _) =
    strip_run_subcommand(xs: tc_rem)
  test_assert.assert_eq_bool(actual: run_mode, expected: false, label: "typecheck path → no run_mode")
  assert_strs(actual: run_rem, expected: [ "nexus", "foo.nx" ], label: "run-strip leaves typecheck remaining intact")

  // 3. Non-typecheck input must pass through both strips unchanged.
  let ParsedTypecheckSubcommand(remaining: pt_rem, typecheck_only: pt_flag) =
    strip_typecheck_subcommand(xs: [ "nexus", "build", "foo.nx" ])
  test_assert.assert_eq_bool(actual: pt_flag, expected: false, label: "build → no typecheck_only")
  assert_strs(actual: pt_rem, expected: [ "nexus", "build", "foo.nx" ], label: "build passthrough")

  // 4. `typecheck` with no positional file: remaining is [prog] only.
  //    Downstream catches the missing-input. Parser stays permissive.
  let ParsedTypecheckSubcommand(remaining: t4_rem, typecheck_only: t4_flag) =
    strip_typecheck_subcommand(xs: [ "nexus", "typecheck" ])
  test_assert.assert_eq_bool(actual: t4_flag, expected: true, label: "typecheck-alone → typecheck_only")
  assert_strs(actual: t4_rem, expected: [ "nexus"], label: "typecheck-alone → program name only")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
