import * as test_assert from "std:test/assert"

type Option<T> = Some(val: T) | None
type Pair = MkPair(fst: i64, snd: i64) | EmptyPair

let check = fn (opt: Option<i64>) -> i64 do
  let result = 0
  if let Some(val: v) = opt then
    return v
  end
  return result
end

let body = fn () -> unit throws { Exn } do
  let opt: Option<i64> = Some(val: 42)
  let result_some = if let Some(val: v) = opt then v else 0 end
  test_assert.assert_eq_i64(actual: result_some, expected: 42, label: "if-let Some")
  let opt2: Option<i64> = None
  let result_none = if let Some(_) = opt2 then 1 else 0 end
  test_assert.assert_eq_i64(actual: result_none, expected: 0, label: "if-let None branch")
  test_assert.assert_eq_i64(actual: check(opt: Some(val: 10)), expected: 10, label: "if-let stmt no-else")
  let p: Pair = MkPair(fst: 3, snd: 4)
  let r = if let MkPair(fst: a, snd: b) = p then a + b else 0 end
  test_assert.assert_eq_i64(actual: r, expected: 7, label: "if-let record pattern")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
