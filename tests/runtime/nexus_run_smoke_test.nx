// nexus-tr79 smoke: `nexus run` subcommand parser. Exercises
// `strip_run_subcommand` so a regression that breaks the CLI shape
// (e.g. wrong default, `--` not splitting, run-after-flag swallow)
// surfaces in the standard test loop. The actual end-to-end build+exec
// path is shell-driven (header.sh) and is covered by manual smoke runs
// — runtime tests can't exec wasmtime under preview1 anyway.

import * as test_assert from "std:test/assert"
import * as list from "std:list"
import { ParsedRunSubcommand, strip_run_subcommand } from "src/cli/subcommands.nx"

let assert_strs = fn (actual: [ string ], expected: [ string ], label: string) -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: list.length(xs: actual), expected: list.length(xs: expected), label: label ++ " (length)")
  assert_strs_zip(actual, expected, idx: 0, label)
  return ()
end

let assert_strs_zip = fn (actual: [ string ], expected: [ string ], idx: i64, label: string) -> unit throws { Exn } do
  match actual do
    | [] -> return ()
    | a :: arest ->
      match expected do
        | [] -> return ()
        | e :: erest ->
          test_assert.assert_eq_string(actual: a, expected: e, label: label ++ "[" ++ str_from_i64(n: idx) ++ "]")
          return assert_strs_zip(actual: arest, expected: erest, idx: idx + 1, label)
      end
  end
end

let str_from_i64 = fn (n: i64) -> string do
  if n == 0 then return "0" end
  return loop_digits(n, acc: "")
end

let loop_digits = fn (n: i64, acc: string) -> string do
  if n == 0 then return acc end
  let d = n - (n / 10) * 10
  let c = digit_char(d)
  return loop_digits(n: n / 10, acc: c ++ acc)
end

let digit_char = fn (d: i64) -> string do
  if d == 0 then return "0" end
  if d == 1 then return "1" end
  if d == 2 then return "2" end
  if d == 3 then return "3" end
  if d == 4 then return "4" end
  if d == 5 then return "5" end
  if d == 6 then return "6" end
  if d == 7 then return "7" end
  if d == 8 then return "8" end
  return "9"
end

let body = fn () -> unit throws { Exn } do
  // 1. Non-run input: pass through unchanged, run_mode=false.
  let ParsedRunSubcommand(remaining: r1, run_mode: m1, run_args: a1) =
    strip_run_subcommand(xs: [ "nexus", "build", "foo.nx" ])
  test_assert.assert_eq_bool(actual: m1, expected: false, label: "build → no run")
  assert_strs(actual: r1, expected: [ "nexus", "build", "foo.nx" ], label: "build passthrough")
  assert_strs(actual: a1, expected: [], label: "build → empty run_args")

  // 2. `run FILE.nx` with no `--`: remaining keeps program name + file,
  //    run_args is empty.
  let ParsedRunSubcommand(remaining: r2, run_mode: m2, run_args: a2) =
    strip_run_subcommand(xs: [ "nexus", "run", "foo.nx" ])
  test_assert.assert_eq_bool(actual: m2, expected: true, label: "run → run_mode")
  assert_strs(actual: r2, expected: [ "nexus", "foo.nx" ], label: "run strips 'run' token")
  assert_strs(actual: a2, expected: [], label: "no -- → empty run_args")

  // 3. `run FILE.nx -- arg1 arg2`: prefix has the file, run_args has the tail.
  let ParsedRunSubcommand(remaining: r3, run_mode: m3, run_args: a3) =
    strip_run_subcommand(xs: [ "nexus", "run", "foo.nx", "--", "arg1", "arg2" ])
  test_assert.assert_eq_bool(actual: m3, expected: true, label: "run+-- → run_mode")
  assert_strs(actual: r3, expected: [ "nexus", "foo.nx" ], label: "-- splits off run args")
  assert_strs(actual: a3, expected: [ "arg1", "arg2" ], label: "-- forwards args verbatim")

  // 4. `run` with no positional file is still run_mode (downstream raises
  //    InvalidUsage on missing input file).
  let ParsedRunSubcommand(remaining: r4, run_mode: m4, run_args: _) =
    strip_run_subcommand(xs: [ "nexus", "run" ])
  test_assert.assert_eq_bool(actual: m4, expected: true, label: "run alone → run_mode")
  assert_strs(actual: r4, expected: [ "nexus"], label: "run alone → program name only")

  // 5. `run -- arg`: empty file slot, run_args populated. Downstream
  //    catches the missing-input — parser stays permissive.
  let ParsedRunSubcommand(remaining: r5, run_mode: _, run_args: a5) =
    strip_run_subcommand(xs: [ "nexus", "run", "--", "x" ])
  assert_strs(actual: r5, expected: [ "nexus"], label: "run -- x → no file in remaining")
  assert_strs(actual: a5, expected: [ "x"], label: "run -- x → arg forwarded")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
