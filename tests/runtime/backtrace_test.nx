// Acceptance test for issue nexus-i6fj V1 (function-name call stacks on raise).
//
// `f` calls `g` calls `h`; `h` raises Boom. Catch the exception in `body`
// and call `exn.backtrace`; assert the returned `[string]` contains each
// of `f`, `g`, `h` (compared by suffix because canonical names are
// file-qualified, e.g. `tests_runtime_i6fj_backtrace_test_nx#h`).
//
// Order: `backtrace()` returns frames outermost-first (slot 0 is the
// oldest live frame). With a depth of ~6 (main → __nx_user_main → body
// → f → g → h) we are well below the 64-slot ring buffer's wrap-around
// threshold, so every frame is present. Presence-based assertions stay
// robust if the wasi/main_wrap frame names shift later.
import * as test_assert from "std:test/assert"
import * as exn from "std:exn"
import * as str from "std:str"

exception Boom(code: i64)

let h = fn () -> unit throws { Exn } do
  raise Boom(code: 1)
end

let g = fn () -> unit throws { Exn } do
  h()
  return ()
end

let f = fn () -> unit throws { Exn } do
  g()
  return ()
end

let list_contains_suffix = fn (xs: [string], suffix: string) -> bool do
  match xs do
    | [] -> return false
    | s :: rest ->
      if str.ends_with(s, suffix) then return true end
      return list_contains_suffix(xs: rest, suffix)
  end
end

let body = fn () -> unit throws { Exn } do
  try
    f()
    return ()
  catch _ ->
    let frames = exn.backtrace(exn: Boom(code: 0))
    test_assert.assert_true(cond: list_contains_suffix(xs: frames, suffix: "#h"),
                              label: "backtrace contains raising frame h")
    test_assert.assert_true(cond: list_contains_suffix(xs: frames, suffix: "#g"),
                              label: "backtrace contains intermediate frame g")
    test_assert.assert_true(cond: list_contains_suffix(xs: frames, suffix: "#f"),
                              label: "backtrace contains outer frame f")
    return ()
  end
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
