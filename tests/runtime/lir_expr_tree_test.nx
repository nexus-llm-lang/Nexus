// Issue nexus-stj8 — V2 LIR JSON dump: structured expr tree.
//
// Walks several LIR variants through `lir_to_json`:
//   - LirStmtLet wrapping a LirExprBinary (covers BinOp + atoms)
//   - LirStmtLet wrapping a LirExprCall (covers function call + call-args)
//   - LirStmtIf carrying a cond atom + branch stmts
//   - LirExprAtom on a LirAtomVar (var-ref leaf) — encoded via `ret`
//
// Same in-process driver invocation pattern as ud6j_lir_dump_test.nx.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as list from "std:list"
import * as ir_dump from "src/tools/dump/ir_dump.nx"
import * as json from "std:json"
import { JsonValue } from "std:json"
import {
  LirFunction, LirParam, LirStmt, LirExpr, LirAtom, LirCallArg,
  LirAtomVar, LirAtomInt, LirExprBinary, LirExprCall, LirStmtLet, LirStmtIf
} from "src/ir/lir/types.nx"
import { TyI64, TyBool, OpAdd } from "src/common/ast.nx"
import { dummy_span } from "tests/_fixtures/span.nx"
import { mk_lir_fn } from "tests/_fixtures/lir.nx"
import {
  expect_array, expect_string, require_field, nth_or_fail
} from "tests/_fixtures/json_helpers.nx"

// ─── Fixture: synth multi-stmt LIR function ────────────────────────────────
//
//   fn compute(x: i64) -> i64 {
//     let __t0: i64 = x + 1            ; LirExprBinary OpAdd
//     let __t1: i64 = mul(x: x, y: __t0)  ; LirExprCall
//     if __t1 then { /* empty */ } else { /* empty */ }  ; LirStmtIf
//     return __t1
//   }

let synth_func = fn () -> LirFunction do
  let av_x = LirAtomVar(name: "x", typ: TyI64)
  let av_one = LirAtomInt(val: 1)
  let av_t0 = LirAtomVar(name: "__t0", typ: TyI64)
  let av_t1 = LirAtomVar(name: "__t1", typ: TyI64)

  let s0 = LirStmtLet(
    name: "__t0",
    typ: TyI64,
    expr: LirExprBinary(op: OpAdd, lhs: av_x, rhs: av_one, typ: TyI64)
  )
  let s1 = LirStmtLet(name: "__t1", typ: TyI64, expr: LirExprCall(
    func: "mul",
    args: [ LirCallArg(label: "x", value: av_x), LirCallArg(label: "y", value: av_t0) ],
    typ: TyI64
  ))
  let s2 = LirStmtIf(cond: av_t1, then_body: [], else_body: [])

  return mk_lir_fn(
    name: "compute",
    params: [ LirParam(label: "x", name: "x", typ: TyI64) ],
    ret_type: TyI64,
    body: [ s0, s1, s2 ],
    ret: av_t1
  )
end

let test_lir_tree = fn () -> unit throws { Exn } do
  let f = synth_func()
  let out = ir_dump.lir_to_json(funcs: [ f ])
  let obj = json.parse(s: out)
  let funcs = expect_array(
    v: require_field(obj, key: "functions", label: "stj8 lir root"),
    label: "stj8 lir funcs"
  )
  let fv = nth_or_fail(xs: funcs, i: 0, label: "stj8 lir f0")

  let body_v = require_field(obj: fv, key: "body", label: "stj8 lir f0")
  let stmts = expect_array(
    v: require_field(obj: body_v, key: "stmts", label: "stj8 lir body"),
    label: "stj8 lir stmts"
  )
  test_assert.assert_eq_i64(actual: list.length(xs: stmts), expected: 3, label: "stj8: 3 stmts")

  // stmt0: LirStmtLet wrapping LirExprBinary
  let s0 = nth_or_fail(xs: stmts, i: 0, label: "stj8 s0")
  let s0k = expect_string(
    v: require_field(obj: s0, key: "kind", label: "stj8 s0"),
    label: "stj8 s0 kind"
  )
  test_assert.assert_eq_string(
    actual: s0k,
    expected: "LirStmtLet",
    label: "stj8: stmt0 is LirStmtLet"
  )
  let s0c = expect_array(
    v: require_field(obj: s0, key: "children", label: "stj8 s0"),
    label: "stj8 s0 children"
  )
  let s0e = nth_or_fail(xs: s0c, i: 0, label: "stj8 s0 child")
  let s0ek = expect_string(
    v: require_field(obj: s0e, key: "kind", label: "stj8 s0 expr"),
    label: "stj8 s0 expr kind"
  )
  test_assert.assert_eq_string(
    actual: s0ek,
    expected: "LirExprBinary",
    label: "stj8: child expr = LirExprBinary"
  )
  let s0op = expect_string(
    v: require_field(obj: s0e, key: "op", label: "stj8 binary"),
    label: "stj8 op"
  )
  test_assert.assert_eq_string(actual: s0op, expected: "+", label: "stj8: op = +")
  let s0_lhs = require_field(obj: s0e, key: "lhs", label: "stj8 binary")
  let s0_lhs_k = expect_string(
    v: require_field(obj: s0_lhs, key: "kind", label: "stj8 lhs"),
    label: "stj8 lhs kind"
  )
  test_assert.assert_eq_string(
    actual: s0_lhs_k,
    expected: "LirAtomVar",
    label: "stj8: lhs.kind = LirAtomVar"
  )
  let s0_lhs_name = expect_string(
    v: require_field(obj: s0_lhs, key: "name", label: "stj8 lhs"),
    label: "stj8 lhs name"
  )
  test_assert.assert_eq_string(actual: s0_lhs_name, expected: "x", label: "stj8: lhs.name = x")
  let s0_rhs = require_field(obj: s0e, key: "rhs", label: "stj8 binary")
  let s0_rhs_k = expect_string(
    v: require_field(obj: s0_rhs, key: "kind", label: "stj8 rhs"),
    label: "stj8 rhs kind"
  )
  test_assert.assert_eq_string(
    actual: s0_rhs_k,
    expected: "LirAtomInt",
    label: "stj8: rhs.kind = LirAtomInt"
  )

  // stmt1: LirStmtLet wrapping LirExprCall
  let s1 = nth_or_fail(xs: stmts, i: 1, label: "stj8 s1")
  let s1c = expect_array(
    v: require_field(obj: s1, key: "children", label: "stj8 s1"),
    label: "stj8 s1 children"
  )
  let s1e = nth_or_fail(xs: s1c, i: 0, label: "stj8 s1 child")
  let s1ek = expect_string(
    v: require_field(obj: s1e, key: "kind", label: "stj8 s1 expr"),
    label: "stj8 s1 expr kind"
  )
  test_assert.assert_eq_string(
    actual: s1ek,
    expected: "LirExprCall",
    label: "stj8: stmt1 expr = LirExprCall"
  )
  let s1_func = expect_string(
    v: require_field(obj: s1e, key: "func", label: "stj8 call"),
    label: "stj8 call func"
  )
  test_assert.assert_eq_string(actual: s1_func, expected: "mul", label: "stj8: call func = mul")
  let s1_args = expect_array(
    v: require_field(obj: s1e, key: "args", label: "stj8 call"),
    label: "stj8 call args"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: s1_args),
    expected: 2,
    label: "stj8: 2 call args"
  )
  let arg1 = nth_or_fail(xs: s1_args, i: 1, label: "stj8 arg1")
  let arg1_label = expect_string(
    v: require_field(obj: arg1, key: "label", label: "stj8 arg1"),
    label: "stj8 arg1 label"
  )
  test_assert.assert_eq_string(actual: arg1_label, expected: "y", label: "stj8: arg1.label = y")
  let arg1_value = require_field(obj: arg1, key: "value", label: "stj8 arg1")
  let arg1_vk = expect_string(
    v: require_field(obj: arg1_value, key: "kind", label: "stj8 arg1 value"),
    label: "stj8 arg1 value kind"
  )
  test_assert.assert_eq_string(
    actual: arg1_vk,
    expected: "LirAtomVar",
    label: "stj8: arg1.value = LirAtomVar"
  )

  // stmt2: LirStmtIf
  let s2 = nth_or_fail(xs: stmts, i: 2, label: "stj8 s2")
  let s2k = expect_string(
    v: require_field(obj: s2, key: "kind", label: "stj8 s2"),
    label: "stj8 s2 kind"
  )
  test_assert.assert_eq_string(
    actual: s2k,
    expected: "LirStmtIf",
    label: "stj8: stmt2 is LirStmtIf"
  )
  let s2cond = require_field(obj: s2, key: "cond", label: "stj8 s2")
  let s2cond_k = expect_string(
    v: require_field(obj: s2cond, key: "kind", label: "stj8 s2 cond"),
    label: "stj8 cond kind"
  )
  test_assert.assert_eq_string(
    actual: s2cond_k,
    expected: "LirAtomVar",
    label: "stj8: if.cond is LirAtomVar"
  )

  // body.ret = LirAtomVar(__t1)
  let ret_v = require_field(obj: body_v, key: "ret", label: "stj8 body")
  let ret_k = expect_string(
    v: require_field(obj: ret_v, key: "kind", label: "stj8 ret"),
    label: "stj8 ret kind"
  )
  test_assert.assert_eq_string(
    actual: ret_k,
    expected: "LirAtomVar",
    label: "stj8: ret.kind = LirAtomVar"
  )
  let ret_name = expect_string(
    v: require_field(obj: ret_v, key: "name", label: "stj8 ret"),
    label: "stj8 ret name"
  )
  test_assert.assert_eq_string(actual: ret_name, expected: "__t1", label: "stj8: ret.name = __t1")
  return ()
end

let main = fn () -> unit throws { Exn } do
  test_lir_tree()
  return ()
end
