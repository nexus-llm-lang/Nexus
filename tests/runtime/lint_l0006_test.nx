// L0006 design-authority comment rule smoke test.
//
// Exercises `lint_design_authority` directly on source strings.
//
// Positive: a comment with an authority phrase and no citation fires L0006.
// Negative: same phrase WITH a citation does not fire; a plain comment
// with no authority phrase does not fire; a block comment with a citation
// does not fire.

import * as test_assert from "std:test/assert"
import * as list from "std:list"
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import { LintFinding, LintInfo, LintWarning } from "src/lint/types.nx"
import { lint_design_authority } from "src/lint/rules/design_authority.nx"

let codes_of = fn (fs: [ LintFinding ]) -> [ string ] do
  return codes_of_loop(fs, acc: [])
end

let codes_of_loop = fn (fs: [ LintFinding ], acc: [ string ]) -> [ string ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | LintFinding(code, severity: _, message: _, fix_it: _, span: _) :: rest ->
      return codes_of_loop(fs: rest, acc: code :: acc)
  end
end

let list_has_str = fn (xs: [ string ], s: string) -> bool do
  match xs do
    | [] -> return false
    | h :: rest ->
      if h == s then return true end
      return list_has_str(xs: rest, s)
  end
end

// Fires: authority phrase "sanctioned", no citation.
let test_l0006_fires_authority_no_citation = fn () -> unit throws { Exn } do
  let src = "// This is sanctioned behaviour in the runtime.\nlet x = 1\n"
  let findings = lint_design_authority(src)
  let codes = codes_of(fs: findings)
  test_assert.assert(
    cond: list_has_str(xs: codes, s: "L0006"),
    label: "L0006 fires on authority phrase without citation"
  )
  return ()
end

// Fires: authority phrase "canonical", no citation.
let test_l0006_fires_canonical = fn () -> unit throws { Exn } do
  let src = "// canonical representation used throughout.\nlet x = 1\n"
  let findings = lint_design_authority(src)
  let codes = codes_of(fs: findings)
  test_assert.assert(
    cond: list_has_str(xs: codes, s: "L0006"),
    label: "L0006 fires on 'canonical' without citation"
  )
  return ()
end

// Silent: authority phrase present BUT citation also present ("see ").
let test_l0006_silent_when_citation_present = fn () -> unit throws { Exn } do
  let src = "// canonical — see docs/spec/types.md for details.\nlet x = 1\n"
  let findings = lint_design_authority(src)
  let codes = codes_of(fs: findings)
  test_assert.assert(
    cond: !list_has_str(xs: codes, s: "L0006"),
    label: "L0006 silent when authority phrase accompanied by citation"
  )
  return ()
end

// Silent: plain behavioural comment, no authority phrase.
let test_l0006_silent_plain_comment = fn () -> unit throws { Exn } do
  let src = "// walk the list and accumulate results.\nlet x = 1\n"
  let findings = lint_design_authority(src)
  let codes = codes_of(fs: findings)
  test_assert.assert(
    cond: !list_has_str(xs: codes, s: "L0006"),
    label: "L0006 silent on plain behavioural comment"
  )
  return ()
end

// Silent: block comment with authority phrase AND a citation (https://).
let test_l0006_silent_block_comment_with_url = fn () -> unit throws { Exn } do
  let src = "/* intended per the spec: https://example.com/spec */\nlet x = 1\n"
  let findings = lint_design_authority(src)
  let codes = codes_of(fs: findings)
  test_assert.assert(
    cond: !list_has_str(xs: codes, s: "L0006"),
    label: "L0006 silent on block comment with URL citation"
  )
  return ()
end

// Fires: block comment with "by design" and no citation.
let test_l0006_fires_block_comment_no_citation = fn () -> unit throws { Exn } do
  let src = "/* This behaviour is by design and not a bug. */\nlet x = 1\n"
  let findings = lint_design_authority(src)
  let codes = codes_of(fs: findings)
  test_assert.assert(
    cond: list_has_str(xs: codes, s: "L0006"),
    label: "L0006 fires on block comment with 'by design' and no citation"
  )
  return ()
end

// L0006 findings must have LintInfo severity (NOT LintWarning).
let test_l0006_severity_is_info = fn () -> unit throws { Exn } do
  let src = "// This is sanctioned behaviour.\nlet x = 1\n"
  let findings = lint_design_authority(src)
  return check_l0006_severity(fs: findings)
end

let check_l0006_severity = fn (fs: [ LintFinding ]) -> unit throws { Exn } do
  match fs do
    | [] -> throw RuntimeError(val: "l0006: expected at least one L0006 finding")
    | LintFinding(code, severity, message: _, fix_it: _, span: _) :: rest ->
      if code == "L0006" then
        match severity do
          | LintInfo -> return ()
          | LintWarning ->
            throw RuntimeError(val: "l0006: L0006 finding has LintWarning severity, expected LintInfo")
        end
      end
      return check_l0006_severity(fs: rest)
  end
end

let body = fn () -> unit throws { Exn } do
  test_l0006_fires_authority_no_citation()
  test_l0006_fires_canonical()
  test_l0006_silent_when_citation_present()
  test_l0006_silent_plain_comment()
  test_l0006_silent_block_comment_with_url()
  test_l0006_fires_block_comment_no_citation()
  test_l0006_severity_is_info()
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
