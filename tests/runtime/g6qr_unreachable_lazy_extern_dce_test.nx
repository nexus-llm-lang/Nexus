// Pins that importing std:lazy without invoking any of its parallel
// primitives (lazy.race / lazy.spawn / lazy.join) does not pull
// unreachable externals or runtime-thread plumbing into the produced
// wasm. Today the inlined stdlib's `nxlib/stdlib/runtime/lazy.nx`
// declares `wasi:thread-spawn` plus `force_closure`/`thunk_addr`
// intrinsics, and `wasi_thread_start` is anchored unconditionally as a
// reachability seed (see `collect_intrinsic_seeds` in
// src/ir/hir/reachability.nx). That drags `lazy_run_task` into the
// emitted wasm; without any closures elsewhere, codegen emits no table
// section, and wasmtime fails to instantiate with:
//   unknown table 0: table index out of bounds.
//
// Wiring a reachability-aware filter onto the externals list (and
// pruning the intrinsic seed when no caller demands it) lets this
// fixture build and run.
import * as lazy from "std:lazy"
import * as ta from "std:test/assert"

let main = fn () -> unit throws { Exn } do
  ta.assert_eq_i64(label: "g6qr_smoke", expected: 42, actual: 42)
  return ()
end
