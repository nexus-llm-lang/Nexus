// nexus-gycd: smoke test that a program with a mix of called and uncalled
// functions still passes when compiled without --coverage. The actual
// --coverage build-time instrumentation is exercised by the in-shell test
// runner (header.sh) when invoked as `./nexus test --coverage`, which is
// out-of-band from this fixture itself — see the runner's coverage-summary
// section for the instrumentation count check.
//
// This fixture is intentionally minimal: under --coverage, codegen still
// produces a valid wasm with the per-function atomic-counter prologue at
// page 17 (offset 1114112+) and a `nx.coverage.functions` custom section.
// The runner aggregates those custom sections across all fixtures.
import * as test_assert from "std:test/assert"

let called_a = fn () -> i64 do
  return 1
end

let called_b = fn () -> i64 do
  return called_a() + 1
end

// Intentionally defined-but-uncalled. Under --coverage the per-function
// counter for this function stays at 0; without --coverage it's dead code
// and may be DCE'd.
let never_called = fn () -> i64 do
  return 99
end

let body = fn () -> unit throws { Exn } do
  let _ = never_called  // suppress unused-let warning; not invoked
  test_assert.assert_eq_i64(actual: called_b(), expected: 2, label: "called_b() = called_a() + 1")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
