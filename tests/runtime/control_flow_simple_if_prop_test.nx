// Port of bootstrap/tests/runtime/control_flow.rs::prop_codegen_simple_if.
// Proptest used a fuzzer over 0..10; here we sample a few representative
// values directly.
import * as test_assert from "std:test/assert"

let check = fn (x: i64) -> i64 do
  if x > 5 then
    return 1
  else
    return 2
  end
  return 0
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: check(x: 0), expected: 2, label: "check(0)")
  test_assert.assert_eq_i64(actual: check(x: 5), expected: 2, label: "check(5)")
  test_assert.assert_eq_i64(actual: check(x: 6), expected: 1, label: "check(6)")
  test_assert.assert_eq_i64(actual: check(x: 9), expected: 1, label: "check(9)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
