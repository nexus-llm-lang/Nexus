// Port of bootstrap/tests/runtime/control_flow.rs:
//   codegen_match_or_pattern_constructor_alternates,
//   codegen_match_or_pattern_with_shared_binding,
//   codegen_match_pipe_arms_with_or_pattern.
import * as test_assert from "std:test/assert"

type Sign = Pos | Neg | Zero
type Either = Left(v: i64) | Right(v: i64)

let classify_sign = fn (s: Sign) -> i64 do
  match s do
    | Pos | Neg -> return 1
    | Zero -> return 0
  end
  return -1
end

let extract = fn (e: Either) -> i64 do
  match e do
    | Left(v: v) | Right(v: v) -> return v
  end
  return -1
end

let pipe_or = fn (x: i64) -> i64 do
  match x do
    | 1 | 2 | 3 -> return 100
    | _ -> return 0
  end
  return -1
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: classify_sign(s: Pos), expected: 1, label: "or-ctor Pos")
  test_assert.assert_eq_i64(actual: classify_sign(s: Neg), expected: 1, label: "or-ctor Neg")
  test_assert.assert_eq_i64(actual: classify_sign(s: Zero), expected: 0, label: "or-ctor Zero")
  test_assert.assert_eq_i64(actual: extract(e: Left(v: 7)), expected: 7, label: "shared binding Left")
  test_assert.assert_eq_i64(actual: extract(e: Right(v: 99)), expected: 99, label: "shared binding Right")
  test_assert.assert_eq_i64(actual: pipe_or(x: 2), expected: 100, label: "pipe or 2")
  test_assert.assert_eq_i64(actual: pipe_or(x: 7), expected: 0, label: "pipe or 7")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
