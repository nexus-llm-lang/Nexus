// Port of bootstrap/tests/runtime/records.rs::codegen_let_destructure_record_multiple_uses.
// 3-field destructuring + sum.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let r = { a: 10, b: 20, c: 12 }
  let {a: x, b: y, c: z} = r
  test_assert.assert_eq_i64(actual: x + y + z, expected: 42, label: "let-destructure {a, b, c}")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
