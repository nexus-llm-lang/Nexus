// nexus-uc0h: apply_fixit / slice_old_text / find_name_at must use byte-offset
// string operations, not char-offset ones, so that source files with
// multi-byte UTF-8 characters before a binding site are not corrupted.
//
// Regression scenario: "// café\nlet x = 42\n"
//   é encodes as two UTF-8 bytes (0xC3 0xA9), so:
//     byte length of the whole string = 20
//     char length                     = 19
//     byte offset of 'x'             = 13
//     char offset of 'x'             = 12
//   The old str.substring / str.length code used char offsets, so splicing at
//   byte position 13 would corrupt the source (keep the 'x', eat the space).

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import { Option, Some, None } from "std:option"
import {
  Fixit, apply_fixit, slice_old_text,
  fixit_for_linear_unused
} from "src/tools/fix.nx"
import { Span } from "src/common/token.nx"

// "// café\nlet x = 42\n"
// byte layout:
//   0  '/'  1  '/'  2  ' '  3  'c'  4  'a'  5  'f'
//   6  0xC3  7  0xA9  (é, 2 bytes)
//   8  '\n'
//   9  'l'  10  'e'  11  't'  12  ' '
//   13 'x'  14  ' '  15 '='  16 ' '  17 '4'  18 '2'  19 '\n'
let src_with_nonascii = fn () -> string do
  return "// caf\u{e9}\nlet x = 42\n"
end

// ─── apply_fixit: byte-correct splice ─────────────────────────────────────

let test_apply_fixit_byte_splice = fn () -> unit throws { Exn } do
  let src = src_with_nonascii()
  // Sanity: confirm the source has the expected byte layout.
  test_assert.assert_eq_i64(
    actual: str.byte_length(s: src),
    expected: 20,
    label: "uc0h: byte_length of src_with_nonascii is 20"
  )
  // The fix replaces byte 13 ('x', len=1) with '_'.
  let fix = Fixit(start: 13, len: 1, replacement: "_", code: "E2007", message: "test")
  let result = apply_fixit(src, fix)
  test_assert.assert_eq_string(
    actual: result,
    expected: "// caf\u{e9}\nlet _ = 42\n",
    label: "uc0h: apply_fixit splices at byte offset 13, not char offset 13"
  )
  return ()
end

// ─── slice_old_text: byte-correct extract ─────────────────────────────────

let test_slice_old_text_byte_extract = fn () -> unit throws { Exn } do
  let src = src_with_nonascii()
  let fix = Fixit(start: 13, len: 1, replacement: "_", code: "E2007", message: "test")
  let old = slice_old_text(src, fix)
  test_assert.assert_eq_string(
    actual: old,
    expected: "x",
    label: "uc0h: slice_old_text extracts 'x' at byte offset 13"
  )
  return ()
end

// ─── fixit_for_linear_unused: scan finds the right byte position ───────────

let test_fixit_for_linear_unused_nonascii = fn () -> unit throws { Exn } do
  let src = src_with_nonascii()
  // Span points to the 'let' keyword at byte offset 9.
  let sp = Span(offset: 9, line: 2, col: 1)
  let opt = fixit_for_linear_unused(src, name: "x", sp)
  match opt do
    | None -> throw RuntimeError(val: "uc0h: expected Some(Fixit), got None")
    | Some(val: fix) ->
      match fix do | Fixit(start, len, replacement, code: _, message: _) ->
        test_assert.assert_eq_i64(
          actual: start,
          expected: 13,
          label: "uc0h: fixit_for_linear_unused yields byte start=13"
        )
        test_assert.assert_eq_i64(
          actual: len,
          expected: 1,
          label: "uc0h: fixit_for_linear_unused yields len=1"
        )
        test_assert.assert_eq_string(
          actual: replacement,
          expected: "_",
          label: "uc0h: fixit_for_linear_unused yields replacement=_"
        )
      end
  end
  return ()
end

// ─── Runner ─────────────────────────────────────────────────────────────

let body = fn () -> unit throws { Exn } do
  test_apply_fixit_byte_splice()
  test_slice_old_text_byte_extract()
  test_fixit_for_linear_unused_nonascii()
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
