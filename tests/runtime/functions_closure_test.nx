// Port of bootstrap/tests/runtime/functions.rs:
//   closure_captures_single_variable,
//   closure_captures_multiple_variables,
//   closure_and_non_closure_same_type.
import * as test_assert from "std:test/assert"

let make_adder = fn (n: i64) -> (x: i64) -> i64 do
  return fn (x: i64) -> i64 do
    return x + n
  end
end

let make_linear = fn (a: i64, b: i64) -> (x: i64) -> i64 do
  return fn (x: i64) -> i64 do
    return a * x + b
  end
end

let double = fn (x: i64) -> i64 do
  return x * 2
end

let apply = fn (f: (x: i64) -> i64, val: i64) -> i64 do
  return f(x: val)
end

let body = fn () -> unit throws { Exn } do
  // Single variable capture.
  let add5 = make_adder(n: 5)
  test_assert.assert_eq_i64(actual: add5(x: 37), expected: 42, label: "add5(37)")
  // Multiple variable capture.
  let f = make_linear(a: 2, b: 10)
  test_assert.assert_eq_i64(actual: f(x: 16), expected: 42, label: "linear(2, 10)(16)")
  // Closure and non-closure share the same fn type.
  let r1 = apply(f: double, val: 21)
  test_assert.assert_eq_i64(actual: r1, expected: 42, label: "apply(double, 21)")
  let add10 = make_adder(n: 10)
  let r2 = apply(f: add10, val: 32)
  test_assert.assert_eq_i64(actual: r2, expected: 42, label: "apply(closure, 32)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
