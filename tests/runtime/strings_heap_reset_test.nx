// Port of bootstrap/tests/runtime/strings.rs::heap_reset_reclaims_string_allocations_in_loop.
// Loop wrapped in heap_mark/heap_reset; verifies the working set stays
// bounded across iterations and the program completes cleanly.
import * as test_assert from "std:test/assert"
import { heap_mark, heap_reset } from "std:arena"
import { length, substring, concat, repeat } from "std:str"

let body = fn () -> unit throws { Exn } do
  let ~i = 0
  while ~i < 200 do
    let mark = heap_mark()
    let base = repeat(s: "ab", n: 16)
    let prefixed = concat(a: "n=", b: base)
    let middle = substring(s: prefixed, start: 0, len: 10)
    let combined = concat(a: middle, b: prefixed) ++ "!"
    test_assert.assert_true(cond: length(s: combined) > length(s: base), label: "combined grows")
    heap_reset(mark: mark)
    ~i <- ~i + 1
  end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
