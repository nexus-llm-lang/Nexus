// Negative companion to qr4c_trailing_comma_test.nx: `[1, , 2]` (empty
// slot between commas) must still be rejected by the self-host parser.
// The trailing-comma fix peeks for the closer immediately after a comma
// — if the next token is another comma, it falls through to a normal
// recursive `parse_expr` call which rejects the comma as an unexpected
// token. This file is named without `_test.nx` to keep `nexus test`
// discovery from picking it up; drive it manually via
// `nexus typecheck tests/runtime/qr4c_empty_slot_negative.nx` to observe
// the parser error.

let main = fn () -> unit do
  let bad = [1, , 2]
  let _ = bad
  return ()
end
