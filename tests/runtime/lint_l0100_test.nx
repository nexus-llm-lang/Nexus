// L0100 cognitive-complexity rule smoke test.
//
// Exercises `lint_program` on a parsed AST to verify:
//   - L0100 fires on a function whose cognitive complexity exceeds 15
//   - L0100 is silent on a function whose complexity is below the threshold
//   - L0100 is `LintInfo` (not `LintWarning`) so the --check gate does
//     not trip on it
//
// Uses the same direct-parse strategy as lint_pack_test.nx.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as list from "std:list"
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import { LintFinding, LintSeverity, LintWarning, LintInfo, lint_program } from "src/lint/lint.nx"
import * as lexer from "src/frontend/lexer.nx"
import { ParseDiagnostics }, * as parser from "src/frontend/parser.nx"

let lint_source = fn (src: string) -> [ LintFinding ] do
  let tokens = lexer.tokenize(src: src)
  let ParseDiagnostics(prog, diags: _) = parser.parse_collect(tokens: tokens, file: "fixture.nx")
  return lint_program(prog: prog)
end

let codes_of = fn (fs: [ LintFinding ]) -> [ string ] do
  return codes_of_loop(fs, acc: [])
end

let codes_of_loop = fn (fs: [ LintFinding ], acc: [ string ]) -> [ string ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | LintFinding(code, severity: _, message: _, fix_it: _, span: _) :: rest ->
      return codes_of_loop(fs: rest, acc: code :: acc)
  end
end

let list_has_str = fn (xs: [ string ], s: string) -> bool do
  match xs do
    | [] -> return false
    | h :: rest ->
      if h == s then return true end
      return list_has_str(xs: rest, s)
  end
end

// Build a function source with many nested ifs that exceed complexity 15.
// Each nested if costs 1+depth. Two levels deep alone gives 1+0 + 1+1 = 3.
// We need total > 15: chain multiple ifs at various depths.
//
// The following fixture has this control-flow shape (each line = one if):
//   if a then                        depth=0: cost 1+0=1
//     if b then                      depth=1: cost 1+1=2
//       if c then                    depth=2: cost 1+2=3
//         if d then                  depth=3: cost 1+3=4
//           if e then                depth=4: cost 1+4=5
//             if f then              depth=5: cost 1+5=6
//   total = 1+2+3+4+5+6 = 21 > 15
let high_complexity_src = fn () -> string do
  return "let f = fn (a: bool, b: bool, c: bool, d: bool, e: bool, g: bool) -> i64 do\n"
    ++ "  if a then\n"
    ++ "    if b then\n"
    ++ "      if c then\n"
    ++ "        if d then\n"
    ++ "          if e then\n"
    ++ "            if g then\n"
    ++ "              return 1\n"
    ++ "            end\n"
    ++ "            return 2\n"
    ++ "          end\n"
    ++ "          return 3\n"
    ++ "        end\n"
    ++ "        return 4\n"
    ++ "      end\n"
    ++ "      return 5\n"
    ++ "    end\n"
    ++ "    return 6\n"
    ++ "  end\n"
    ++ "  return 0\n"
    ++ "end\n"
end

// A simple function with complexity well below the threshold (just a match).
let low_complexity_src = fn () -> string do
  return "let f = fn (x: i64) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | 0 -> return 1\n"
    ++ "    | 1 -> return 2\n"
    ++ "    | _ -> return 3\n"
    ++ "  end\n"
    ++ "end\n"
end

// L0100 fires on the high-complexity fixture.
let test_l0100_fires_on_high_complexity = fn () -> unit throws { Exn } do
  let findings = lint_source(src: high_complexity_src())
  let codes = codes_of(fs: findings)
  test_assert.assert(cond: list_has_str(xs: codes, s: "L0100"),
    label: "ucfla: L0100 fires when cognitive complexity exceeds threshold")
  return ()
end

// L0100 is silent on a simple match (low complexity).
let test_l0100_silent_on_low_complexity = fn () -> unit throws { Exn } do
  let findings = lint_source(src: low_complexity_src())
  let codes = codes_of(fs: findings)
  test_assert.assert(cond: !list_has_str(xs: codes, s: "L0100"),
    label: "ucfla: L0100 silent when complexity is below threshold")
  return ()
end

// L0100 findings have LintInfo severity (not LintWarning).
let test_l0100_severity_is_info = fn () -> unit throws { Exn } do
  let findings = lint_source(src: high_complexity_src())
  return check_l0100_severity(fs: findings)
end

let check_l0100_severity = fn (fs: [ LintFinding ]) -> unit throws { Exn } do
  match fs do
    | [] -> throw RuntimeError(val: "ucfla: expected at least one L0100 finding")
    | LintFinding(code, severity, message: _, fix_it: _, span: _) :: rest ->
      if code == "L0100" then
        match severity do
          | LintInfo -> return ()
          | LintWarning ->
            throw RuntimeError(val: "ucfla: L0100 finding has LintWarning severity, expected LintInfo")
        end
      end
      return check_l0100_severity(fs: rest)
  end
end

// A 3-arm match should NOT fire L0100 (match costs only +1, not +1 per arm).
let test_l0100_match_costs_1_not_per_arm = fn () -> unit throws { Exn } do
  // A function with only a large match — all arms at depth 0.
  // cost = +1 (for the match dispatch). Well below 15.
  let src = "let f = fn (x: i64) -> i64 do\n"
    ++ "  match x do\n"
    ++ "    | 0 -> return 0\n"
    ++ "    | 1 -> return 1\n"
    ++ "    | 2 -> return 2\n"
    ++ "    | 3 -> return 3\n"
    ++ "    | 4 -> return 4\n"
    ++ "    | 5 -> return 5\n"
    ++ "    | 6 -> return 6\n"
    ++ "    | 7 -> return 7\n"
    ++ "    | 8 -> return 8\n"
    ++ "    | 9 -> return 9\n"
    ++ "    | _ -> return 10\n"
    ++ "  end\n"
    ++ "end\n"
  let findings = lint_source(src)
  let codes = codes_of(fs: findings)
  test_assert.assert(cond: !list_has_str(xs: codes, s: "L0100"),
    label: "ucfla: L0100 silent on flat match with many arms (match costs +1 not +N)")
  return ()
end

// Runner

let body = fn () -> unit throws { Exn } do
  test_l0100_fires_on_high_complexity()
  test_l0100_silent_on_low_complexity()
  test_l0100_severity_is_info()
  test_l0100_match_costs_1_not_per_arm()
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
