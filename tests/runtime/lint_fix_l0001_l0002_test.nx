// nexus-kyvpl: `nexus lint --fix` must apply L0001 and L0002 fix-its in place.
//
// L0001: empty `inject … do … end` wrapper with no body statements — fix removes
//        the entire inject wrapper (leaving nothing, since body is empty).
// L0002: capability in `require { … }` that is never called — fix drops the cap
//        name (and the whole require clause when it is the only entry).
//
// Strategy: write temporary fixture files, invoke run_lint_subcommand with --fix,
// and assert the file content after the fix.

import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"
import * as str from "std:str"
import { run_lint_subcommand } from "src/tools/lint.nx"

// ---------- L0001 fixture: empty inject body ----------

// A function whose body is ONLY an inject with no statements inside.
// After --fix, the inject wrapper should be removed entirely.
let l0001_fixture_source = fn () -> string do
  return "import { Console } from \"std:stdio\"\n"
    ++ "import * as stdio from \"std:stdio\"\n"
    ++ "let main = fn () -> unit require { PermConsole } do\n"
    ++ "  inject stdio.system_handler do\n"
    ++ "  end\n"
    ++ "  return ()\n"
    ++ "end\n"
end

let l0001_fixture_path = fn () -> string do
  return "./.kyvpl_l0001_fixture.nx"
end

// ---------- L0002 fixture: single unused require cap ----------

// A function with require { Console } but the body never calls Console.*.
// After --fix the require clause should be removed entirely.
let l0002_single_fixture_source = fn () -> string do
  return "import { Console } from \"std:stdio\"\n"
    ++ "let foo = fn () -> unit require { Console } do\n"
    ++ "  return ()\n"
    ++ "end\n"
end

let l0002_single_fixture_path = fn () -> string do
  return "./.kyvpl_l0002_single_fixture.nx"
end

// ---------- L0002 fixture: multi-cap, remove first ----------

// require { Console, Fs } but only Fs is (hypothetically) used.
// We exploit L0002's narrowness: it fires only when the body has NO calls at all.
// So Console fires because neither cap is used and there are no calls.
// After fixing Console, we should have `require { Fs }`.
// NOTE: L0002 fires for EACH unused cap, so both Console and Fs will fire.
// The fix loop applies one at a time; after both passes the require clause is gone.
// We just verify that the first pass removes one cap.
let l0002_multi_fixture_source = fn () -> string do
  return "import { Console } from \"std:stdio\"\n"
    ++ "import { Fs } from \"std:fs\"\n"
    ++ "let foo = fn () -> unit require { Console, Fs } do\n"
    ++ "  return ()\n"
    ++ "end\n"
end

let l0002_multi_fixture_path = fn () -> string do
  return "./.kyvpl_l0002_multi_fixture.nx"
end

// ---------- helpers ----------

let write_fixture = fn (path: string, src: string) -> unit require { Fs } throws { Exn } do
  Fs.write_string(path: path, content: src)
  return ()
end

let cleanup = fn (path: string) -> unit require { Fs } do
  try
    Fs.remove_file(path: path)
    return ()
  catch _ -> return ()
  end
end

// ---------- tests ----------

// L0001: inject wrapper is deleted after --fix.
let test_l0001_fix = fn () -> unit require { Console, Fs } throws { Exn } do
  write_fixture(path: l0001_fixture_path(), src: l0001_fixture_source())
  let code = run_lint_subcommand(args: [ "--fix", l0001_fixture_path() ])
  test_assert.assert_eq_i64(
    actual: code,
    expected: 0,
    label: "kyvpl: L0001 --fix exits 0"
  )
  let after = Fs.read_to_string(path: l0001_fixture_path())
  // The inject wrapper must be gone: neither `inject` nor `end` (closing it)
  // should appear inside the function any more. Easiest check: the word
  // `inject` is no longer present.
  let has_inject = str.contains(s: after, sub: "inject stdio.system_handler do")
  test_assert.assert_true(
    cond: !has_inject,
    label: "kyvpl: L0001 --fix removes inject wrapper"
  )
  return ()
end

// L0002 single cap: require clause is dropped entirely after --fix.
let test_l0002_single_fix = fn () -> unit require { Console, Fs } throws { Exn } do
  write_fixture(path: l0002_single_fixture_path(), src: l0002_single_fixture_source())
  let code = run_lint_subcommand(args: [ "--fix", l0002_single_fixture_path() ])
  test_assert.assert_eq_i64(
    actual: code,
    expected: 0,
    label: "kyvpl: L0002 single --fix exits 0"
  )
  let after = Fs.read_to_string(path: l0002_single_fixture_path())
  // The require clause must be gone.
  let has_require = str.contains(s: after, sub: "require { Console }")
  test_assert.assert_true(
    cond: !has_require,
    label: "kyvpl: L0002 single --fix removes require clause"
  )
  return ()
end

// L0002 multi cap: one cap is removed per pass; the require block shrinks.
let test_l0002_multi_fix = fn () -> unit require { Console, Fs } throws { Exn } do
  write_fixture(path: l0002_multi_fixture_path(), src: l0002_multi_fixture_source())
  let code = run_lint_subcommand(args: [ "--fix", l0002_multi_fixture_path() ])
  test_assert.assert_eq_i64(
    actual: code,
    expected: 0,
    label: "kyvpl: L0002 multi --fix exits 0"
  )
  let after = Fs.read_to_string(path: l0002_multi_fixture_path())
  // The original `require { Console, Fs }` must no longer be present.
  let has_both = str.contains(s: after, sub: "require { Console, Fs }")
  test_assert.assert_true(
    cond: !has_both,
    label: "kyvpl: L0002 multi --fix removes at least one cap"
  )
  return ()
end

// L0001 re-lint: after --fix, running lint again must find no L0001.
let test_l0001_no_finding_after_fix = fn () -> unit require { Console, Fs } throws { Exn } do
  // Fixture was already fixed in test_l0001_fix (same path).
  // Re-write a fresh copy.
  write_fixture(path: l0001_fixture_path(), src: l0001_fixture_source())
  let code1 = run_lint_subcommand(args: [ "--fix", l0001_fixture_path() ])
  let _ = code1
  // Now plain lint should exit 0 (no findings).
  let code2 = run_lint_subcommand(args: [ "--check", l0001_fixture_path() ])
  test_assert.assert_eq_i64(
    actual: code2,
    expected: 0,
    label: "kyvpl: after L0001 fix, --check exits 0 (no findings)"
  )
  return ()
end

// ---------- orchestration ----------

let body = fn () -> unit require { Console, Fs } throws { Exn } do
  try
    test_l0001_fix()
    cleanup(path: l0001_fixture_path())
    test_l0002_single_fix()
    cleanup(path: l0002_single_fixture_path())
    test_l0002_multi_fix()
    cleanup(path: l0002_multi_fixture_path())
    test_l0001_no_finding_after_fix()
    cleanup(path: l0001_fixture_path())
    return ()
  catch e ->
    cleanup(path: l0001_fixture_path())
    cleanup(path: l0002_single_fixture_path())
    cleanup(path: l0002_multi_fixture_path())
    throw e
  end
end

let safe_run = fn () -> i64 require { Console, Fs } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole, PermFs } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
