// nexus-817q — `nexus lint --check` must exit 1 when findings are present;
// without `--check`, findings are warnings only (exit 0).
//
// Root: `run_lint_subcommand` was matching `LintOptions(check_mode: _, paths)`
// which discarded `check_mode`, so both modes exited 0 (or 1 only when Fs
// errors occurred). Fixed by binding `check_mode` and using it:
//   `if check_mode && total > 0 then return 1 else return 0 end`.
//
// Strategy: write a fixture with a known L0002 finding (unused require cap),
// invoke `run_lint_subcommand` with and without `--check`, assert exit codes.

import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"
import { run_lint_subcommand } from "src/tools/lint.nx"

// A fixture with an unused `Console` require — fires L0002.
let fixture_source = fn () -> string do
  return "import { Console } from \"std:stdio\"\n"
    ++ "let main = fn () -> unit require { Console } do\n"
    ++ "  return ()\n"
    ++ "end\n"
end

let fixture_path = fn () -> string do
  return "./.817q_lint_check_fixture.nx"
end

let write_fixture = fn () -> unit require { Fs } throws { Exn } do
  Fs.write_string(path: fixture_path(), content: fixture_source())
  return ()
end

let cleanup_fixture = fn () -> unit require { Fs } do
  try
    Fs.remove_file(path: fixture_path())
    return ()
  catch _ -> return ()
  end
end

// --check with a finding: must exit 1 (CI gate).
let test_check_mode_exits_1_on_finding = fn () -> unit require { Console, Fs } throws { Exn } do
  let code = run_lint_subcommand(args: ["--check", fixture_path()])
  test_assert.assert_eq_i64(
    actual: code,
    expected: 1,
    label: "817q: --check exits 1 when finding present"
  )
  return ()
end

// Default mode (no --check) with a finding: must exit 0 (warning only).
let test_no_check_mode_exits_0_on_finding = fn () -> unit require { Console, Fs } throws { Exn } do
  let code = run_lint_subcommand(args: [fixture_path()])
  test_assert.assert_eq_i64(
    actual: code,
    expected: 0,
    label: "817q: without --check exits 0 even when finding present"
  )
  return ()
end

// Both modes must exit 0 on a clean file (no findings).
let test_clean_file_exits_0_both_modes = fn () -> unit require { Console, Fs } throws { Exn } do
  // Temporarily overwrite fixture with a clean source.
  let clean = "let add = fn (a: i64, b: i64) -> i64 do return a + b end\n"
  Fs.write_string(path: fixture_path(), content: clean)
  let code_check = run_lint_subcommand(args: ["--check", fixture_path()])
  let code_plain = run_lint_subcommand(args: [fixture_path()])
  Fs.write_string(path: fixture_path(), content: fixture_source())
  test_assert.assert_eq_i64(
    actual: code_check,
    expected: 0,
    label: "817q: --check exits 0 on clean file"
  )
  test_assert.assert_eq_i64(
    actual: code_plain,
    expected: 0,
    label: "817q: no-check exits 0 on clean file"
  )
  return ()
end

let body = fn () -> unit require { Console, Fs } throws { Exn } do
  write_fixture()
  try
    test_check_mode_exits_1_on_finding()
    test_no_check_mode_exits_0_on_finding()
    test_clean_file_exits_0_both_modes()
    cleanup_fixture()
    return ()
  catch e ->
    cleanup_fixture()
    throw e
  end
end

let safe_run = fn () -> i64 require { Console, Fs } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole, PermFs } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
