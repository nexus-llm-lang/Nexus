// Port of bootstrap/tests/runtime/functions.rs:
//   codegen_tail_recursive_function_executes_correctly,
//   codegen_deep_tail_recursion_does_not_overflow,
//   codegen_deep_mutual_tail_recursion_does_not_overflow.
import * as test_assert from "std:test/assert"

let sum_tail = fn (n: i64, acc: i64) -> i64 do
  if n <= 0 then return acc end
  return sum_tail(n: n - 1, acc: acc + n)
end

let loop_n = fn (n: i64) -> i64 do
  if n <= 0 then return 0 end
  return loop_n(n: n - 1)
end

let is_even = fn (n: i64) -> bool do
  if n == 0 then return true end
  return is_odd(n: n - 1)
end

let is_odd = fn (n: i64) -> bool do
  if n == 0 then return false end
  return is_even(n: n - 1)
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: sum_tail(n: 100, acc: 0), expected: 5050, label: "sum_tail(100)")
  test_assert.assert_eq_i64(actual: loop_n(n: 1000000), expected: 0, label: "deep tail recursion 1M")
  test_assert.assert_eq_bool(actual: is_even(n: 1000000), expected: true, label: "mutual tail recursion 1M")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
