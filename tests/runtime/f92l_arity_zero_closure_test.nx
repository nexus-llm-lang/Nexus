// Regression for nexus-f92l: zero-arity top-level fns referenced as values
// (e.g. passed to higher-order fns) must be wrapped as closures so the
// codegen call_indirect path can find an arity-0 entry in the closure-type
// table. Pre-fix this raised `closure arity '0' not found [E3001]`.
import * as test_assert from "std:test/assert"

let pure_fn = fn () -> i64 do return 42 end

let apply = fn (f: () -> i64) -> i64 do
  return f()
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: pure_fn(), expected: 42, label: "pure_fn() direct")
  test_assert.assert_eq_i64(actual: apply(f: pure_fn), expected: 42, label: "apply(pure_fn)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
