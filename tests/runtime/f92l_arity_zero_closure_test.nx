// Regression for nexus-f92l: codegen must seed arity 0 in the closure type
// table so any `LirExprCallClosure(args: [])` site
// (`lookup_closure_type_idx_pairs(arity: 0, ...)`) resolves. Pre-fix the
// arity table was seeded only from `__closure_*` / sched-trampoline funcs,
// so a 0-arity closure call site raised E3001 during `nexus build`.
//
// Discovered while tracking nexus-ijp7 fix work: copying a `() -> T`
// top-level let into a local and invoking it forces a 0-arg call_indirect.
//
// This fixture exercises only the codegen path, not runtime correctness:
// value-passing of arity-0 fn refs currently auto-invokes via op_call
// (separate latent issue), so the dead branch below is gated behind a
// false predicate to compile-test the indirect call without executing it.
import * as test_assert from "std:test/assert"

let pure_fn = fn () -> i64 do return 42 end

let touch_arity0 = fn (run: bool) -> i64 do
  if run then
    let f = pure_fn
    return f()  // 0-arg call_indirect — needs arity 0 in type table.
  end
  return 0
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: pure_fn(), expected: 42, label: "pure_fn() direct")
  test_assert.assert_eq_i64(actual: touch_arity0(run: false), expected: 0, label: "0-arity site compiles")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
