// Issue nexus-2v8n — `nexus caps --diff <rev>` capability widening detector.
//
// Drives `compute_caps_diff` / `diff_is_widening` / `diff_to_text` /
// `diff_to_json` directly on hand-built [string] capability lists, plus an
// end-to-end check that the closure→diff pipeline composes correctly on a
// synthesised HirProgram. Same subprocess-avoidance rationale as
// 8fzi_caps_test.nx — Proc.exec is unreachable under WASI preview1 so we
// can't shell out to `nexus caps --diff` from inside a test binary.
//
// Coverage:
//   1. compute_caps_diff classifies added/removed correctly against an empty
//      base, an empty current, and a partially-overlapping base.
//   2. diff_is_widening fires iff `added` is non-empty (removed alone does
//      not count as widening — this is the CI-contract bit).
//   3. The closure→diff pipeline composes: build two CapsClosures from two
//      synthesised HirPrograms (one Fs-using, one Fs-removed) and confirm
//      the resulting diff names Fs as added in the forward direction and
//      Fs as removed in the reverse direction.
//   4. diff_to_text renders the WIDENING verdict for an added-cap diff and
//      the "narrowing" verdict for a removed-cap diff.
//   5. diff_to_json round-trips through std:json with `kind:"caps_diff"`
//      and `widening:true|false` matching the boolean predicate.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as list from "std:list"
import {
  CapsDiff, compute_caps_diff, diff_is_widening,
  diff_to_text, diff_to_json,
  compute_caps_closure, closure_capabilities
} from "src/tools/dump/caps_dump.nx"
import {
  HirProgram, HirFunction, HirBody, EagerBody,
  HirExternal, HirStmt, HirStmtKind, HirExpr, HirExprKind
} from "src/ir/hir/types.nx"
import {
  mk_function,
  mk_external,
  empty_hir,
  call_stmt,
  empty_row
} from "tests/_fixtures/hir_programs.nx"

// ─── Set helpers ───────────────────────────────────────────────────────────

let list_has = fn (xs: [ string ], s: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true end
      return list_has(xs: rest, s)
  end
end

// ─── Test cases ────────────────────────────────────────────────────────────

let test_diff_added_against_empty_base = fn () -> unit throws { Exn } do
  // A symbol that previously didn't exist (empty base) and now has caps
  // reads as a complete widening: every current cap is "added".
  let d = compute_caps_diff(symbol: "f", base: [], current: [ "Console", "Fs" ])
  match d do | CapsDiff(symbol: _, base: _, current: _, added, removed) ->
    test_assert.assert(
      cond: list_has(xs: added, s: "Console"),
      label: "2v8n: empty-base diff lists Console as added"
    )
    test_assert.assert(
      cond: list_has(xs: added, s: "Fs"),
      label: "2v8n: empty-base diff lists Fs as added"
    )
    test_assert.assert(
      cond: list.length(xs: removed) == 0,
      label: "2v8n: empty-base diff has no removals"
    )
  end
  test_assert.assert(
    cond: diff_is_widening(d: d),
    label: "2v8n: empty-base + non-empty current is widening"
  )
  return ()
end

let test_diff_removed_against_empty_current = fn () -> unit throws { Exn } do
  // Symbol deletion / cap loss: every base cap becomes a removal, and the
  // diff is *not* a widening (removal is informational only per the CI
  // contract — narrowing PRs don't need cap review).
  let d = compute_caps_diff(symbol: "f", base: [ "Console", "Fs" ], current: [])
  match d do | CapsDiff(symbol: _, base: _, current: _, added, removed) ->
    test_assert.assert(
      cond: list.length(xs: added) == 0,
      label: "2v8n: empty-current diff has no additions"
    )
    test_assert.assert(
      cond: list_has(xs: removed, s: "Console"),
      label: "2v8n: removed lists Console"
    )
    test_assert.assert(cond: list_has(xs: removed, s: "Fs"), label: "2v8n: removed lists Fs")
  end
  test_assert.assert(
    cond: !diff_is_widening(d: d),
    label: "2v8n: removal-only diff is NOT widening"
  )
  return ()
end

let test_diff_partial_overlap = fn () -> unit throws { Exn } do
  // The interesting case: base and current share some caps, each side has a
  // unique. Both `added` and `removed` should be non-empty and disjoint.
  let d = compute_caps_diff(symbol: "f", base: [ "Console", "Fs" ], current: [ "Console", "Net" ])
  match d do | CapsDiff(symbol: _, base: _, current: _, added, removed) ->
    test_assert.assert(cond: list_has(xs: added, s: "Net"), label: "2v8n: Net classified as added")
    test_assert.assert(
      cond: !list_has(xs: added, s: "Console"),
      label: "2v8n: shared Console NOT in added"
    )
    test_assert.assert(
      cond: list_has(xs: removed, s: "Fs"),
      label: "2v8n: Fs classified as removed"
    )
    test_assert.assert(
      cond: !list_has(xs: removed, s: "Console"),
      label: "2v8n: shared Console NOT in removed"
    )
  end
  test_assert.assert(
    cond: diff_is_widening(d: d),
    label: "2v8n: any added cap counts as widening even alongside removals"
  )
  return ()
end

let test_diff_unchanged = fn () -> unit throws { Exn } do
  // Identical sides: the empty-added / empty-removed shape is what
  // `nexus caps --diff` returns in the most common no-op CI run, and
  // diff_is_widening must report false to keep exit 0.
  let d = compute_caps_diff(symbol: "f", base: [ "Console"], current: [ "Console"])
  match d do | CapsDiff(symbol: _, base: _, current: _, added, removed) ->
    test_assert.assert(
      cond: list.length(xs: added) == 0,
      label: "2v8n: identical sides → no added"
    )
    test_assert.assert(
      cond: list.length(xs: removed) == 0,
      label: "2v8n: identical sides → no removed"
    )
  end
  test_assert.assert(cond: !diff_is_widening(d: d), label: "2v8n: identical sides not widening")
  return ()
end

let test_pipeline_closure_to_diff_widening = fn () -> unit throws { Exn } do
  // End-to-end: build two HirPrograms (current uses Fs+Console, base uses
  // Console only), compute caps closures, run them through compute_caps_diff.
  // This is the shape the in-driver caps --diff path actually executes.
  let ext_fs = mk_external(name: "fs_call", wasm_module: "nexus:std/fs", wasm_name: "path_exists")
  let curr_entry = mk_function(
    name: "fixture_nx#entry",
    body_stmts: [
      call_stmt(func: "nxlib_stdlib_stdio_nx#Console.println"),
      call_stmt(func: "fs_call")
    ]
  )
  let curr_prog = empty_hir(fs: [ curr_entry ], exts: [ ext_fs ])

  let base_entry = mk_function(
    name: "fixture_nx#entry",
    body_stmts: [ call_stmt(func: "nxlib_stdlib_stdio_nx#Console.println") ]
  )
  let base_prog = empty_hir(fs: [ base_entry ], exts: [])

  let curr_caps = closure_capabilities(cl: compute_caps_closure(prog: curr_prog, symbol: "entry"))
  let base_caps = closure_capabilities(cl: compute_caps_closure(prog: base_prog, symbol: "entry"))
  let d = compute_caps_diff(symbol: "entry", base: base_caps, current: curr_caps)
  match d do | CapsDiff(symbol: _, base: _, current: _, added, removed: _) ->
    test_assert.assert(cond: list_has(xs: added, s: "Fs"), label: "2v8n: pipeline detects Fs added")
  end
  test_assert.assert(cond: diff_is_widening(d: d), label: "2v8n: forward pipeline = widening")
  // Reverse direction: same two programs, swapped — Fs should appear as
  // removed and the diff should NOT be a widening.
  let d_rev = compute_caps_diff(symbol: "entry", base: curr_caps, current: base_caps)
  match d_rev do | CapsDiff(symbol: _, base: _, current: _, added, removed) ->
    test_assert.assert(
      cond: list_has(xs: removed, s: "Fs"),
      label: "2v8n: reverse pipeline lists Fs as removed"
    )
    test_assert.assert(
      cond: list.length(xs: added) == 0,
      label: "2v8n: reverse pipeline has no additions"
    )
  end
  test_assert.assert(
    cond: !diff_is_widening(d: d_rev),
    label: "2v8n: reverse pipeline NOT widening"
  )
  return ()
end

let test_diff_text_render_widening = fn () -> unit throws { Exn } do
  let d = compute_caps_diff(symbol: "f", base: [ "Console"], current: [ "Console", "Fs" ])
  let txt = diff_to_text(d: d)
  test_assert.assert(
    cond: str.contains(s: txt, sub: "WIDENING"),
    label: "2v8n: text render shows WIDENING verdict"
  )
  test_assert.assert(
    cond: str.contains(s: txt, sub: "Added:   Fs"),
    label: "2v8n: text render lists Fs in Added"
  )
  test_assert.assert(
    cond: str.contains(s: txt, sub: "f"),
    label: "2v8n: text render mentions symbol name"
  )
  return ()
end

let test_diff_text_render_narrowing = fn () -> unit throws { Exn } do
  let d = compute_caps_diff(symbol: "f", base: [ "Console", "Fs" ], current: [ "Console"])
  let txt = diff_to_text(d: d)
  test_assert.assert(
    cond: str.contains(s: txt, sub: "narrowing"),
    label: "2v8n: text render shows narrowing verdict"
  )
  test_assert.assert(
    cond: str.contains(s: txt, sub: "Removed: Fs"),
    label: "2v8n: text render lists Fs in Removed"
  )
  test_assert.assert(
    cond: !str.contains(s: txt, sub: "WIDENING"),
    label: "2v8n: narrowing render NOT flagged WIDENING"
  )
  return ()
end

let test_diff_json_envelope = fn () -> unit throws { Exn } do
  let d = compute_caps_diff(symbol: "f", base: [ "Console"], current: [ "Console", "Fs" ])
  let payload = diff_to_json(d: d)
  test_assert.assert(
    cond: str.contains(s: payload, sub: "\"kind\":\"caps_diff\""),
    label: "2v8n: JSON kind:caps_diff"
  )
  test_assert.assert(
    cond: str.contains(s: payload, sub: "\"symbol\":\"f\""),
    label: "2v8n: JSON carries symbol"
  )
  test_assert.assert(
    cond: str.contains(s: payload, sub: "\"widening\":true"),
    label: "2v8n: JSON widening:true for added-cap diff"
  )
  test_assert.assert(
    cond: str.contains(s: payload, sub: "\"added\":[\"Fs\"]"),
    label: "2v8n: JSON added array contains Fs"
  )
  // narrowing case: widening must be false even when removed is non-empty.
  let d_nar = compute_caps_diff(symbol: "f", base: [ "Console", "Fs" ], current: [ "Console"])
  let payload_nar = diff_to_json(d: d_nar)
  test_assert.assert(
    cond: str.contains(s: payload_nar, sub: "\"widening\":false"),
    label: "2v8n: JSON widening:false for narrowing-only diff"
  )
  return ()
end

let body = fn () -> unit throws { Exn } do
  test_diff_added_against_empty_base()
  test_diff_removed_against_empty_current()
  test_diff_partial_overlap()
  test_diff_unchanged()
  test_pipeline_closure_to_diff_widening()
  test_diff_text_render_widening()
  test_diff_text_render_narrowing()
  test_diff_json_envelope()
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
