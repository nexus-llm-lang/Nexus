// nexus-m8ey smoke: `nexus typecheck FILE` CLI threading. Regression for
// the path where `strip_typecheck_subcommand`'s remaining-args output was
// discarded and a downstream parser re-saw the literal `typecheck` token,
// binding the input-file slot to `"typecheck"` (surfacing as E4004
// "file not found: 'typecheck'").
//
// We can't exec the host binary from a runtime test (`Proc.exec` is a -1
// stub under WASI preview1), so we drive the strip function in-process and
// assert the threading produces the canonical "[prog, file]" shape — never
// a stray `typecheck` token. main.nx feeds this `remaining` straight into
// `clean_args` for the typecheck branch, so a clean shape is load-bearing.

import * as test_assert from "std:test/assert"
import * as list from "std:list"
import { ParsedTypecheckSubcommand, strip_typecheck_subcommand } from "src/cli/subcommands.nx"

let assert_strs = fn (
  actual: [ string ],
  expected: [ string ],
  label: string
) -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: list.length(xs: actual),
    expected: list.length(xs: expected),
    label: label ++ " (length)"
  )
  assert_strs_zip(actual, expected, idx: 0, label)
  return ()
end

let assert_strs_zip = fn (
  actual: [ string ],
  expected: [ string ],
  idx: i64,
  label: string
) -> unit throws { Exn } do
  match actual do
    | [] -> return ()
    | a :: arest ->
      match expected do
        | [] -> return ()
        | e :: erest ->
          test_assert.assert_eq_string(
            actual: a,
            expected: e,
            label: label ++ "[" ++ str_from_i64(n: idx) ++ "]"
          )
          return assert_strs_zip(actual: arest, expected: erest, idx: idx + 1, label)
      end
  end
end

let str_from_i64 = fn (n: i64) -> string do
  if n == 0 then return "0" end
  return loop_digits(n, acc: "")
end

let loop_digits = fn (n: i64, acc: string) -> string do
  if n == 0 then return acc end
  let d = n - (n / 10) * 10
  let c = digit_char(d)
  return loop_digits(n: n / 10, acc: c ++ acc)
end

let digit_char = fn (d: i64) -> string do
  if d == 0 then return "0" end
  if d == 1 then return "1" end
  if d == 2 then return "2" end
  if d == 3 then return "3" end
  if d == 4 then return "4" end
  if d == 5 then return "5" end
  if d == 6 then return "6" end
  if d == 7 then return "7" end
  if d == 8 then return "8" end
  return "9"
end

let body = fn () -> unit throws { Exn } do
  // 1. `nexus typecheck foo.nx`: strip_typecheck_subcommand peels the
  //    `typecheck` token and sets typecheck_only=true. The threaded
  //    remaining must be [prog, file] so the downstream argv is clean and
  //    no parser binds the input file to the literal `"typecheck"`.
  let ParsedTypecheckSubcommand(remaining: tc_rem, typecheck_only: tc_flag) =
    strip_typecheck_subcommand(xs: [ "nexus", "typecheck", "foo.nx" ])
  test_assert.assert_eq_bool(actual: tc_flag, expected: true, label: "typecheck → typecheck_only")
  assert_strs(
    actual: tc_rem,
    expected: [ "nexus", "foo.nx" ],
    label: "typecheck strips 'typecheck' token"
  )

  // 2. Non-typecheck input must pass through the strip unchanged.
  let ParsedTypecheckSubcommand(remaining: pt_rem, typecheck_only: pt_flag) =
    strip_typecheck_subcommand(xs: [ "nexus", "build", "foo.nx" ])
  test_assert.assert_eq_bool(actual: pt_flag, expected: false, label: "build → no typecheck_only")
  assert_strs(actual: pt_rem, expected: [ "nexus", "build", "foo.nx" ], label: "build passthrough")

  // 3. `typecheck` with no positional file: remaining is [prog] only.
  //    Downstream catches the missing-input. Parser stays permissive.
  let ParsedTypecheckSubcommand(remaining: t4_rem, typecheck_only: t4_flag) =
    strip_typecheck_subcommand(xs: [ "nexus", "typecheck" ])
  test_assert.assert_eq_bool(
    actual: t4_flag,
    expected: true,
    label: "typecheck-alone → typecheck_only"
  )
  assert_strs(actual: t4_rem, expected: [ "nexus"], label: "typecheck-alone → program name only")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
