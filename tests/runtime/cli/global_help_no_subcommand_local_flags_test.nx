// nexus-qpuz: `nexus help` global options block must NOT leak subcommand-
// local flags. Regression for main.nx:cli_specs() where -o, --format,
// --explain-capabilities, --explain-capabilities-format, --coverage,
// --dump-imports were all listed under the top-level "Options:" block
// alongside the genuinely global --verbose, misleading users (and LLMs)
// about which flags apply at each level.
//
// `cli_specs()` retains every flag because argparse's permissive
// pre-subcommand parse needs the full schema. Help rendering switched
// to `global_help_specs()`, which exposes only true-global entries.
// This test drives `global_help_specs()` + `render_usage` in-process
// (the same pipeline `print_usage()` runs) and asserts the resulting
// "Options:" block contains ONLY --verbose, while the subcommands
// block still lists every routing arm so user-discoverability is
// preserved. It also reconstructs the pre-fix `cli_specs()` shape
// inline and asserts the same substring probes DO hit it, proving the
// assertion shape is load-bearing rather than vacuously satisfied.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import { ArgSpec, render_usage, spec_flag, spec_opt, spec_subcommand } from "std:argparse"
import { global_help_specs } from "src/cli/specs.nx"

// Reconstructs the pre-fix `cli_specs()` shape so we can prove the
// assertion-shape we use below actually fires on the bug, not just
// passes vacuously on the fixed code. Mirrors main.nx:cli_specs()
// at the point the bug was filed.
let buggy_help_specs = fn () -> [ ArgSpec ] do
  return [
    spec_subcommand(
      name: "build",
      help: "<input.nx> [-o output.wasm]"
    ),
    spec_subcommand(name: "run", help: "<input.nx> [-- ARGS...]"),
    spec_subcommand(name: "help", help: "[subcommand]"),
    spec_flag(name: "verbose", short: "", long: "--verbose", help: "enable per-pass timing output"),
    spec_opt(
      name: "output",
      short: "-o",
      long: "--output",
      required: false,
      help: "output wasm path"
    ),
    spec_opt(
      name: "format",
      short: "",
      long: "--format",
      required: false,
      help: "diagnostic format (text|json)"
    ),
    spec_opt(
      name: "explain-capabilities",
      short: "",
      long: "--explain-capabilities",
      required: false,
      help: "capability reporting (yes|none|wasmtime)"
    ),
    spec_opt(
      name: "explain-capabilities-format",
      short: "",
      long: "--explain-capabilities-format",
      required: false,
      help: "capability report format (text|json)"
    ),
    spec_flag(
      name: "coverage",
      short: "",
      long: "--coverage",
      help: "emit coverage counters and custom section"
    ),
    spec_flag(
      name: "dump-imports",
      short: "",
      long: "--dump-imports",
      help: "print the import graph and exit"
    )
  ]
end

let body = fn () -> unit throws { Exn } do
  let out = render_usage(
    summary: "Usage: nexus <subcommand> [options] <args>",
    specs: global_help_specs()
  )

  // 1. True-global flag is present.
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "--verbose"),
    label: "global help lists --verbose"
  )

  // 2. Subcommands block survives unchanged — every routing arm shows up
  //    so `nexus help` remains a discovery surface. Spot-check three
  //    representative entries (one build-pipeline, one tool, one help).
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "build"),
    label: "subcommands block includes build"
  )
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "typecheck"),
    label: "subcommands block includes typecheck"
  )
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "repl"),
    label: "subcommands block includes repl"
  )
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "help"),
    label: "subcommands block includes help"
  )

  // 3. Subcommand-local FLAGS must NOT appear in the top-level Options
  //    block. The bug-shape rendered each as its own line in the Options
  //    section; argparse formats option lines as `\n  <flag>` (newline +
  //    two-space indent + flag spelling), padded with spaces before the
  //    help text. Asserting against that shape avoids false positives on
  //    subcommand-synopsis prose (e.g. the literal `[--format=text|json]`
  //    inside a subcommand synopsis line, which is a different render path).
  //    For OptValue flags we anchor on the `<flag> VALUE` suffix that
  //    `render_opt_line` appends (and which only appears in the Options
  //    block — synopses use `=text|json` instead).
  test_assert.assert_false(
    cond: str.contains(s: out, sub: "-o, --output VALUE"),
    label: "no -o/--output VALUE in global Options"
  )
  test_assert.assert_false(
    cond: str.contains(s: out, sub: "\n  --coverage"),
    label: "no --coverage line in global Options"
  )
  test_assert.assert_false(
    cond: str.contains(s: out, sub: "\n  --dump-imports"),
    label: "no --dump-imports line in global Options"
  )
  test_assert.assert_false(
    cond: str.contains(s: out, sub: "--explain-capabilities VALUE"),
    label: "no --explain-capabilities VALUE in global Options"
  )
  test_assert.assert_false(
    cond: str.contains(s: out, sub: "--explain-capabilities-format VALUE"),
    label: "no --explain-capabilities-format VALUE in global Options"
  )
  // --format is the trickiest: `--format` appears in some subcommand
  // synopsis strings ([--format=text|json]). Anchor on `--format VALUE`,
  // the OptValue render shape — only emitted in the Options block.
  test_assert.assert_false(
    cond: str.contains(s: out, sub: "--format VALUE"),
    label: "no --format VALUE in global Options"
  )

  // 5. Inverse sanity check: against the pre-fix spec shape, the same
  //    substring probes MUST hit. Catches a refactor where the assertion
  //    shape silently stops matching the bug (e.g. argparse changes its
  //    `<flag> VALUE` rendering) and the test stays green for the wrong
  //    reason.
  let buggy = render_usage(
    summary: "Usage: nexus <subcommand> [options] <args>",
    specs: buggy_help_specs()
  )
  test_assert.assert_true(
    cond: str.contains(s: buggy, sub: "-o, --output VALUE"),
    label: "buggy shape has -o/--output VALUE"
  )
  test_assert.assert_true(
    cond: str.contains(s: buggy, sub: "\n  --coverage"),
    label: "buggy shape has --coverage line"
  )
  test_assert.assert_true(
    cond: str.contains(s: buggy, sub: "\n  --dump-imports"),
    label: "buggy shape has --dump-imports line"
  )
  test_assert.assert_true(
    cond: str.contains(s: buggy, sub: "--explain-capabilities VALUE"),
    label: "buggy shape has --explain-capabilities VALUE"
  )
  test_assert.assert_true(
    cond: str.contains(s: buggy, sub: "--explain-capabilities-format VALUE"),
    label: "buggy shape has --explain-capabilities-format VALUE"
  )
  test_assert.assert_true(
    cond: str.contains(s: buggy, sub: "--format VALUE"),
    label: "buggy shape has --format VALUE"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
