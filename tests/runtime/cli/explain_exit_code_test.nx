// Issue nexus-iqg39 — `nexus explain` exit-code contract on read/parse failure.
//
// `run_explain_subcommand` must return 1 (not 0) when the input file is
// missing or fails to parse, matching the documented "1 = compilation or
// runtime failure" contract and the sibling `context` subcommand. A
// successful explain on an existing file with a found symbol must still
// return 0, and a missing symbol must still return 1.
//
// We drive `run_explain_subcommand` directly (it returns the process exit
// code and runs its own `inject`) because `Proc.exec` is a -1 stub under
// WASI preview1, so a true subprocess assertion is not available here.
import * as test_assert from "std:test/assert"
import { run_explain_subcommand } from "src/tools/explain.nx"
import { Fs } from "std:fs"
import * as fs_mod from "std:fs"

let ok_source = fn () -> string do
  return "/** Add two i64 values. */\n"
      ++ "let add = fn (x: i64, y: i64) -> i64 do\n"
      ++ "  return x + y\n"
      ++ "end\n"
end

let parse_err_source = fn () -> string do
  // A truncated `let` — lexes but fails to parse.
  return "let x =\n"
end

let ok_path = fn () -> string do
  return "./.iqg39_ok_fixture.nx"
end

let parse_err_path = fn () -> string do
  return "./.iqg39_parse_err_fixture.nx"
end

let missing_path = fn () -> string do
  return "./.iqg39_definitely_absent_fixture.nx"
end

let write_fixtures = fn () -> unit require { PermFs } do
  inject fs_mod.system_handler do
    try
      Fs.write_string(path: ok_path(), content: ok_source())
      Fs.write_string(path: parse_err_path(), content: parse_err_source())
      return ()
    catch _ -> return ()
    end
  end
end

let cleanup_fixtures = fn () -> unit require { PermFs } do
  inject fs_mod.system_handler do
    try
      Fs.remove_file(path: ok_path())
      Fs.remove_file(path: parse_err_path())
      return ()
    catch _ -> return ()
    end
  end
end

// Each case asserts the exact exit code returned by the subcommand driver.
// `run_explain_subcommand` injects its own Console/Fs handlers internally,
// so it is called with the ambient Perm capabilities only.
let test_exit_codes = fn () -> unit require { PermConsole, PermFs } throws { Exn } do
  // Read/parse failure: missing file, text format -> 1.
  let ec_missing_text = run_explain_subcommand(args: [ "any_symbol", "--file", missing_path() ])
  test_assert.assert(cond: ec_missing_text == 1, label: "explain on missing file (text) exits 1")

  // Read/parse failure: missing file, json format -> 1.
  let ec_missing_json = run_explain_subcommand(args: [ "any_symbol", "--file", missing_path(), "--format", "json" ])
  test_assert.assert(cond: ec_missing_json == 1, label: "explain on missing file (json) exits 1")

  // Read/parse failure: parse error, text format -> 1.
  let ec_parse_text = run_explain_subcommand(args: [ "foo", "--file", parse_err_path() ])
  test_assert.assert(cond: ec_parse_text == 1, label: "explain on parse-error file (text) exits 1")

  // Read/parse failure: parse error, json format -> 1.
  let ec_parse_json = run_explain_subcommand(args: [ "foo", "--file", parse_err_path(), "--format", "json" ])
  test_assert.assert(cond: ec_parse_json == 1, label: "explain on parse-error file (json) exits 1")

  // Symbol not found in a valid file -> 1 (unchanged contract).
  let ec_not_found = run_explain_subcommand(args: [ "no_such_symbol", "--file", ok_path() ])
  test_assert.assert(cond: ec_not_found == 1, label: "explain on missing symbol exits 1")

  // Successful explain (valid file + found symbol), text -> 0.
  let ec_ok_text = run_explain_subcommand(args: [ "add", "--file", ok_path() ])
  test_assert.assert(cond: ec_ok_text == 0, label: "successful explain (text) exits 0")

  // Successful explain, json -> 0.
  let ec_ok_json = run_explain_subcommand(args: [ "add", "--file", ok_path(), "--format", "json" ])
  test_assert.assert(cond: ec_ok_json == 0, label: "successful explain (json) exits 0")
  return ()
end

let body = fn () -> unit require { PermConsole, PermFs } throws { Exn } do
  write_fixtures()
  try
    test_exit_codes()
    cleanup_fixtures()
    return ()
  catch e ->
    cleanup_fixtures()
    throw e
  end
end

let safe_run = fn () -> i64 require { PermConsole, PermFs } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole, PermFs } do
  let ok = safe_run()
  1 / ok
  return ()
end
