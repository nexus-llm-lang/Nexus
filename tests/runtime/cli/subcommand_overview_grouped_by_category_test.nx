// nexus-bmu7: `nexus help` must surface subcommands grouped by their
// SubcommandCategory (Build / Context / Safety / Tooling) so an LLM or
// human reading the top-level overview can pick the right routing arm
// from its functional layer. Pre-fix the listing was one flat block of
// `spec_subcommand(...)` entries; this test drives the new
// `render_subcommand_overview` directly with a synthetic spec list and
// asserts:
//
//   (1) every non-empty category renders its own labelled section header,
//   (2) the section header for each category appears in the canonical
//       declaration order (Build, Context, Safety, Tooling),
//   (3) each member subcommand is listed under its own category and
//       NOT under a sibling category,
//   (4) categories with zero members are elided (Safety has none in
//       this fixture — the literal "Safety & Diffing:" header must NOT
//       appear),
//   (5) the truly-global options block from `qpuz` is still appended
//       (--verbose, no per-sub flags leaking in),
//   (6) inverse sanity: running the SAME assertion shape against
//       `render_usage(specs: flat_specs)` (the pre-bmu7 flat shape) the
//       category-header probes do NOT hit — proves the shape we anchor
//       on is load-bearing and not a vacuous true.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import {
  ArgSpec, SubcommandSpec, SubcommandCategory,
  CategoryBuild, CategoryContext, CategorySafety, CategoryTooling,
  spec_flag, spec_subcommand,
  subspec, render_subcommand_overview, render_usage
} from "std:argparse"

// Build a representative SubcommandSpec list spanning three of the four
// categories so we can verify both rendered groups and the elision of
// an empty group (Safety). Synopsis/description/etc. are minimal —
// only the name and category matter for the grouping contract.
let make_specs = fn () -> [ SubcommandSpec ] do
  return [
    subspec(
      name: "build",
      synopsis: "<input.nx>",
      description: "",
      flags: [],
      examples: [],
      see_also: [],
      exit_codes: [],
      category: CategoryBuild
    ),
    subspec(
      name: "run",
      synopsis: "<input.nx>",
      description: "",
      flags: [],
      examples: [],
      see_also: [],
      exit_codes: [],
      category: CategoryBuild
    ),
    subspec(
      name: "ast",
      synopsis: "<input.nx>",
      description: "",
      flags: [],
      examples: [],
      see_also: [],
      exit_codes: [],
      category: CategoryContext
    ),
    subspec(
      name: "types",
      synopsis: "<input.nx>",
      description: "",
      flags: [],
      examples: [],
      see_also: [],
      exit_codes: [],
      category: CategoryContext
    ),
    subspec(
      name: "mcp",
      synopsis: "",
      description: "",
      flags: [],
      examples: [],
      see_also: [],
      exit_codes: [],
      category: CategoryTooling
    ),
    subspec(
      name: "help",
      synopsis: "[<subcommand>]",
      description: "",
      flags: [],
      examples: [],
      see_also: [],
      exit_codes: [],
      category: CategoryTooling
    )
    // intentionally NO CategorySafety member — covers the empty-group
    // elision assertion below.
  ]
end

let globals = fn () -> [ ArgSpec ] do
  return [
    spec_flag(name: "verbose", short: "", long: "--verbose", help: "enable per-pass timing output")
  ]
end

let flat_specs = fn () -> [ ArgSpec ] do
  return [
    spec_subcommand(name: "build", help: "<input.nx>"),
    spec_subcommand(name: "run", help: "<input.nx>"),
    spec_subcommand(name: "ast", help: "<input.nx>"),
    spec_subcommand(name: "types", help: "<input.nx>"),
    spec_subcommand(name: "mcp", help: ""),
    spec_subcommand(name: "help", help: "[<subcommand>]"),
    spec_flag(name: "verbose", short: "", long: "--verbose", help: "enable per-pass timing output")
  ]
end

// Substring index helper: returns -1 when not found. Used for the
// declaration-order assertion (`idx(out, A) < idx(out, B)`).
let find_sub = fn (s: string, sub: string, i: i64) -> i64 do
  let n = str.length(s)
  let m = str.length(s: sub)
  if m == 0 then return 0 end
  if i + m > n then return -1 end
  if str.substring(s, start: i, len: m) == sub then return i end
  return find_sub(s, sub, i: i + 1)
end

let index_of = fn (s: string, sub: string) -> i64 do
  return find_sub(s, sub, i: 0)
end

let body = fn () -> unit throws { Exn } do
  let out = render_subcommand_overview(
    summary: "Usage: nexus <subcommand> [options] <args>",
    subs: make_specs(),
    globals: globals()
  )

  // (1) Each non-empty category emits a labelled section header.
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "Build & Run:"),
    label: "Build & Run group header present"
  )
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "Context & Introspection:"),
    label: "Context & Introspection group header present"
  )
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "Tooling & Integration:"),
    label: "Tooling & Integration group header present"
  )

  // (4) Empty group is elided — no Safety members in fixture.
  test_assert.assert_false(
    cond: str.contains(s: out, sub: "Safety & Diffing:"),
    label: "Safety & Diffing group elided when empty"
  )

  // (2) Group ordering: Build < Context < Tooling (Safety skipped).
  let i_build = index_of(s: out, sub: "Build & Run:")
  let i_ctx = index_of(s: out, sub: "Context & Introspection:")
  let i_tool = index_of(s: out, sub: "Tooling & Integration:")
  test_assert.assert_true(cond: i_build >= 0, label: "Build header located")
  test_assert.assert_true(cond: i_ctx > i_build, label: "Context appears after Build")
  test_assert.assert_true(cond: i_tool > i_ctx, label: "Tooling appears after Context")

  // (3) Members appear under their own category. Anchor on the
  //     two-space-indent + name pad shape produced by render_overview_sub_line
  //     (16-char label width). For names < 16 chars the line begins
  //     "\n  <name>" then padding spaces. Anchoring on "\n  build" et al.
  //     also rules out any false hit from prose elsewhere in the output.
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "\n  build "),
    label: "build listed in subcommands block"
  )
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "\n  run "),
    label: "run listed in subcommands block"
  )
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "\n  ast "),
    label: "ast listed in subcommands block"
  )
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "\n  types "),
    label: "types listed in subcommands block"
  )
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "\n  mcp"),
    label: "mcp listed in subcommands block"
  )
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "\n  help "),
    label: "help listed in subcommands block"
  )

  //     `build` must live in the Build block, NOT in the Context block.
  //     Compute the substring offset of `build` and verify it sits in
  //     [i_build, i_ctx). Same for `ast` ∈ [i_ctx, i_tool) and
  //     `mcp` ∈ [i_tool, +∞).
  let i_member_build = index_of(s: out, sub: "\n  build ")
  let i_member_ast = index_of(s: out, sub: "\n  ast ")
  let i_member_mcp = index_of(s: out, sub: "\n  mcp")
  test_assert.assert_true(
    cond: i_member_build > i_build && i_member_build < i_ctx,
    label: "build sits in Build group span"
  )
  test_assert.assert_true(
    cond: i_member_ast > i_ctx && i_member_ast < i_tool,
    label: "ast sits in Context group span"
  )
  test_assert.assert_true(cond: i_member_mcp > i_tool, label: "mcp sits in Tooling group span")

  // (5) Truly-global options block still appended.
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "Options:"),
    label: "Options block still rendered"
  )
  test_assert.assert_true(
    cond: str.contains(s: out, sub: "--verbose"),
    label: "--verbose flag rendered in Options"
  )

  // (6) Inverse sanity: the pre-bmu7 flat render path does NOT emit
  //     any category header. If render_subcommand_overview ever silently
  //     degenerates to the flat shape, these assertions catch it.
  let flat = render_usage(
    summary: "Usage: nexus <subcommand> [options] <args>",
    specs: flat_specs()
  )
  test_assert.assert_false(
    cond: str.contains(s: flat, sub: "Build & Run:"),
    label: "flat shape has no Build header"
  )
  test_assert.assert_false(
    cond: str.contains(s: flat, sub: "Context & Introspection:"),
    label: "flat shape has no Context header"
  )
  test_assert.assert_false(
    cond: str.contains(s: flat, sub: "Tooling & Integration:"),
    label: "flat shape has no Tooling header"
  )
  // Sanity: the flat shape does still list the same subcommand names,
  // just under one generic "Subcommands:" header — proves the
  // category-header probes (not the names) are what's load-bearing.
  test_assert.assert_true(
    cond: str.contains(s: flat, sub: "Subcommands:"),
    label: "flat shape has the legacy Subcommands header"
  )
  test_assert.assert_true(
    cond: str.contains(s: flat, sub: "build"),
    label: "flat shape still lists build"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
