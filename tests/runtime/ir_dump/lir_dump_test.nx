// Issue nexus-ud6j — LIR dump (`nexus lir <file> --format=json|text`).
// Updated under nexus-stj8 for the V2 envelope: each LirFunction record's
// `body_pp` string is replaced by `{stmts: [...], ret: <atom-json>}`.
//
// Drives `lir_to_text` / `lir_to_json` directly with a hand-rolled
// LirFunction fixture. Same subprocess-avoidance rationale as the HIR
// counterpart and kmel_json_format_test.nx.
//
// Coverage:
//   1. Text dump starts with the "=== LIR dump" banner.
//   2. JSON dump parses through std:json and carries
//      `{kind: "lir", functions: [...]}` at the top level.
//   3. A single-statement fixture function round-trips its name and
//      ret_type; the V2 `body` carries one LirStmtLet whose child
//      LirExprAtom wraps LirAtomInt 7, and `ret` is a LirAtomVar(__t0).

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as list from "std:list"
import * as ir_dump from "src/tools/dump/ir_dump.nx"
import * as json from "std:json"
import { JsonValue, JsonInt } from "std:json"
import { LirFunction, LirExprAtom, LirAtomInt, LirAtomVar } from "src/ir/lir/types.nx"
import { TyI64 } from "src/syntax/ast.nx"
import { mk_lir_fn, mk_lir_let_stmt } from "tests/_fixtures/lir.nx"
import {
  expect_object, expect_array, expect_string, require_field
} from "tests/_fixtures/json_helpers.nx"

// ─── Fixture: synthesise a single LIR function ─────────────────────────────

let synth_func = fn () -> LirFunction do
  // body: let __t0: i64 = 7  -> ret = __t0
  let let_stmt = mk_lir_let_stmt(
    name: "__t0",
    typ: TyI64,
    expr: LirExprAtom(atom: LirAtomInt(val: 7))
  )
  return mk_lir_fn(
    name: "seven",
    params: [],
    ret_type: TyI64,
    body: [ let_stmt ],
    ret: LirAtomVar(name: "__t0", typ: TyI64)
  )
end

// ─── Test 1: text dump banner ──────────────────────────────────────────────

let test_text_banner = fn () -> unit throws { Exn } do
  let f = synth_func()
  let out = ir_dump.lir_to_text(funcs: [ f ])
  let starts_with_banner = str.starts_with(s: out, prefix: "=== LIR dump")
  test_assert.assert_eq_bool(
    actual: starts_with_banner,
    expected: true,
    label: "ud6j: LIR text dump starts with banner"
  )
  return ()
end

// ─── Test 2: JSON dump shape ───────────────────────────────────────────────

let test_json_shape = fn () -> unit throws { Exn } do
  let f = synth_func()
  let out = ir_dump.lir_to_json(funcs: [ f ])
  let starts_with_brace = str.starts_with(s: out, prefix: "{")
  test_assert.assert_eq_bool(
    actual: starts_with_brace,
    expected: true,
    label: "ud6j: LIR JSON output starts with '{'"
  )
  let obj = json.parse(s: out)
  let kind_v = require_field(obj, key: "kind", label: "ud6j lir json")
  let kind = expect_string(v: kind_v, label: "ud6j lir kind")
  test_assert.assert_eq_string(actual: kind, expected: "lir", label: "ud6j: kind = lir")
  let funcs_v = require_field(obj, key: "functions", label: "ud6j lir json")
  let funcs = expect_array(v: funcs_v, label: "ud6j lir functions")
  let n = list.length(xs: funcs)
  test_assert.assert_eq_i64(actual: n, expected: 1, label: "ud6j: 1 synthesised function")
  match funcs do
    | [] -> throw RuntimeError(val: "expected one function")
    | fv :: _ ->
      let name_v = require_field(obj: fv, key: "name", label: "ud6j lir func")
      let name = expect_string(v: name_v, label: "ud6j lir func name")
      test_assert.assert_eq_string(actual: name, expected: "seven", label: "ud6j: name round-trips")
      let ret_v = require_field(obj: fv, key: "ret_type", label: "ud6j lir func")
      let ret = expect_string(v: ret_v, label: "ud6j lir ret_type")
      test_assert.assert_eq_string(actual: ret, expected: "i64", label: "ud6j: ret_type = i64")
      // V2: body is a structured JSON object with `stmts` and `ret`.
      let body_v = require_field(obj: fv, key: "body", label: "ud6j lir func")
      let stmts_v = require_field(obj: body_v, key: "stmts", label: "ud6j lir body")
      let stmts = expect_array(v: stmts_v, label: "ud6j lir stmts")
      let ns = list.length(xs: stmts)
      test_assert.assert_eq_i64(actual: ns, expected: 1, label: "ud6j: 1 stmt")
      match stmts do
        | [] -> throw RuntimeError(val: "expected 1 stmt")
        | stmt :: _ ->
          let sk_v = require_field(obj: stmt, key: "kind", label: "ud6j lir stmt")
          let sk = expect_string(v: sk_v, label: "ud6j lir stmt kind")
          test_assert.assert_eq_string(
            actual: sk,
            expected: "LirStmtLet",
            label: "ud6j: stmt.kind = LirStmtLet"
          )
          let name_v2 = require_field(obj: stmt, key: "name", label: "ud6j lir stmt")
          let n2 = expect_string(v: name_v2, label: "ud6j lir stmt name")
          test_assert.assert_eq_string(
            actual: n2,
            expected: "__t0",
            label: "ud6j: stmt name = __t0"
          )
          let children_v = require_field(obj: stmt, key: "children", label: "ud6j lir stmt")
          let children = expect_array(v: children_v, label: "ud6j lir stmt children")
          match children do
            | [] -> throw RuntimeError(val: "expected child expr")
            | child :: _ ->
              let ck_v = require_field(obj: child, key: "kind", label: "ud6j lir expr")
              let ck = expect_string(v: ck_v, label: "ud6j lir expr kind")
              test_assert.assert_eq_string(
                actual: ck,
                expected: "LirExprAtom",
                label: "ud6j: expr.kind = LirExprAtom"
              )
              let atom_v = require_field(obj: child, key: "atom", label: "ud6j lir expr")
              let ak_v = require_field(obj: atom_v, key: "kind", label: "ud6j lir atom")
              let ak = expect_string(v: ak_v, label: "ud6j lir atom kind")
              test_assert.assert_eq_string(
                actual: ak,
                expected: "LirAtomInt",
                label: "ud6j: atom.kind = LirAtomInt"
              )
              let av = require_field(obj: atom_v, key: "value", label: "ud6j lir atom")
              match av do
                | JsonInt(val: n) -> test_assert.assert_eq_i64(
                  actual: n,
                  expected: 7,
                  label: "ud6j: atom value = 7"
                )
                | _ -> throw RuntimeError(val: "expected JsonInt for atom value")
              end
          end
      end
      let ret_v = require_field(obj: body_v, key: "ret", label: "ud6j lir body")
      let rk_v = require_field(obj: ret_v, key: "kind", label: "ud6j lir ret")
      let rk = expect_string(v: rk_v, label: "ud6j lir ret kind")
      test_assert.assert_eq_string(
        actual: rk,
        expected: "LirAtomVar",
        label: "ud6j: ret.kind = LirAtomVar"
      )
  end
  return ()
end

let main = fn () -> unit throws { Exn } do
  test_text_banner()
  test_json_shape()
  return ()
end
