// Port of bootstrap/tests/runtime/arithmetic.rs::codegen_negate_function.
// Verifies std:core::negate flips a bool.
import * as test_assert from "std:test/assert"
import { negate } from "std:core"

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_bool(actual: negate(val: true), expected: false, label: "negate(true)")
  test_assert.assert_eq_bool(actual: negate(val: false), expected: true, label: "negate(false)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
