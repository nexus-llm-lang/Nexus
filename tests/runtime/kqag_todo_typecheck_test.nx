// nexus-kqag (subset): `todo` literal — a polymorphic-return placeholder for
// incomplete programs. Mirrors Rust `todo!()` / Haskell `undefined`.
//
// This fixture verifies both halves of the contract:
//   1. `todo()` typechecks at any return position (here an `i64` body).
//   2. Calling it raises `NotImplemented`, which a `catch` arm can recover.
import * as test_assert from "std:test/assert"
import { todo, NotImplemented } from "std:exn"

// (1) Typecheck-only: `todo()` unifies with the declared `-> i64` return.
//     The function is never called from a context that doesn't catch — it
//     exists to prove the polymorphic-return half compiles.
let f = fn (n: i64) -> i64 throws { NotImplemented } do
  return todo()
end

// (2) Runtime: invoking `todo()` raises NotImplemented and the catch arm
//     recovers with a sentinel value.
let call_todo = fn () -> i64 throws { Exn } do
  try
    let _ = f(n: 0)
    return -1
  catch
    | NotImplemented(msg: _) -> return 42
    | _ -> return -2
  end
  return -3
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: call_todo(),
    expected: 42,
    label: "todo() raises NotImplemented at runtime"
  )
  return ()
end
