// Issue nexus-swzh — doc block @intent/@invariant/@complexity/@alternatives/@owner tag parsing.
//
// Drives `parse_doc_tags` and `run_explain` directly:
//   1. parse_doc_tags correctly extracts each tag from raw doc block text.
//   2. run_explain --format=json surfaces the tags object in its output.
//   3. A symbol with no @-tags produces an all-null tags object.
//   4. Unknown @-tags are silently ignored (no crash, other tags intact).

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import {
  ExplainJson, ExplainText,
  run_explain, parse_doc_tags, DocTags
} from "src/explain/main.nx"
import { Option, Some, None } from "std:option"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"

// Helper: assert that an Option<string> is Some with the given value.
let assert_some_eq = fn (opt: Option<string>, expected: string, label: string) -> unit throws { Exn } do
  match opt do
    | Some(val: v) ->
      test_assert.assert(
        cond: v == expected,
        label: label ++ " (got: " ++ v ++ ")"
      )
    | None -> test_assert.assert(cond: false, label: label ++ " (expected Some, got None)")
  end
  return ()
end

// Helper: assert that an Option<string> is None.
let assert_none = fn (opt: Option<string>, label: string) -> unit throws { Exn } do
  match opt do
    | None -> test_assert.assert(cond: true, label)
    | Some(val: v) -> test_assert.assert(cond: false, label: label ++ " (expected None, got Some(\"" ++ v ++ "\"))")
  end
  return ()
end

// ─── 1. Unit tests for parse_doc_tags ────────────────────────────────────────

let test_parse_all_tags = fn () -> unit throws { Exn } do
  let raw = "\n @intent  do the thing\n @invariant  x > 0\n @complexity  O(n)\n @alternatives  tried recursion\n @owner  platform-team\n"
  let DocTags(intent, invariant, complexity, alternatives, owner) = parse_doc_tags(raw: raw)
  assert_some_eq(opt: intent, expected: "do the thing", label: "@intent extracted")
  assert_some_eq(opt: invariant, expected: "x > 0", label: "@invariant extracted")
  assert_some_eq(opt: complexity, expected: "O(n)", label: "@complexity extracted")
  assert_some_eq(opt: alternatives, expected: "tried recursion", label: "@alternatives extracted")
  assert_some_eq(opt: owner, expected: "platform-team", label: "@owner extracted")
  return ()
end

let test_parse_empty_doc = fn () -> unit throws { Exn } do
  let raw = " Just a plain prose docstring with no tags. "
  let DocTags(intent, invariant, complexity, alternatives, owner) = parse_doc_tags(raw: raw)
  assert_none(opt: intent, label: "no @intent -> None")
  assert_none(opt: invariant, label: "no @invariant -> None")
  assert_none(opt: complexity, label: "no @complexity -> None")
  assert_none(opt: alternatives, label: "no @alternatives -> None")
  assert_none(opt: owner, label: "no @owner -> None")
  return ()
end

let test_parse_unknown_tag_ignored = fn () -> unit throws { Exn } do
  let raw = "@intent real intent\n@unknown something\n@owner core"
  let DocTags(intent, invariant: _, complexity: _, alternatives: _, owner) = parse_doc_tags(raw: raw)
  assert_some_eq(opt: intent, expected: "real intent", label: "@intent survives unknown tag")
  assert_some_eq(opt: owner, expected: "core", label: "@owner survives unknown tag")
  return ()
end

// ─── 2. Integration: explain --format=json surfaces tags field ────────────────

let tagged_fixture_source = fn () -> string do
  return "/**\n * Adds two integers.\n * @intent provide a trivial addition for demo purposes\n * @complexity O(1)\n * @owner test-team\n */\n"
      ++ "let add = fn (x: i64, y: i64) -> i64 do\n"
      ++ "  return x + y\n"
      ++ "end\n"
      ++ "\n"
      ++ "let main = fn () -> unit do\n"
      ++ "  let _ = add(x: 1, y: 2)\n"
      ++ "  return ()\n"
      ++ "end\n"
end

let fixture_path = fn () -> string do
  return "./.swzh_doc_tags_fixture.nx"
end

let write_fixture = fn () -> unit require { Fs } throws { Exn } do
  Fs.write_string(path: fixture_path(), content: tagged_fixture_source())
  return ()
end

let cleanup_fixture = fn () -> unit require { Fs } do
  try
    Fs.remove_file(path: fixture_path())
    return ()
  catch _ -> return ()
  end
end

let test_json_has_tags = fn () -> unit require { Console, Fs } throws { Exn } do
  let out = run_explain(symbol: "add", file: fixture_path(), format: ExplainJson)
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"tags\":") >= 0,
    label: "explain json contains \"tags\" field"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"intent\":") >= 0,
    label: "tags object contains \"intent\""
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "provide a trivial addition") >= 0,
    label: "intent value is present in output"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"complexity\":\"O(1)\"") >= 0,
    label: "complexity tag value is O(1)"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"owner\":\"test-team\"") >= 0,
    label: "owner tag value is test-team"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"invariant\":null") >= 0,
    label: "absent invariant tag is null"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "\"alternatives\":null") >= 0,
    label: "absent alternatives tag is null"
  )
  return ()
end

let test_text_has_tag_lines = fn () -> unit require { Console, Fs } throws { Exn } do
  let out = run_explain(symbol: "add", file: fixture_path(), format: ExplainText)
  test_assert.assert(
    cond: str.index_of(s: out, sub: "@intent:") >= 0,
    label: "text output contains @intent: line"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "@complexity:") >= 0,
    label: "text output contains @complexity: line"
  )
  test_assert.assert(
    cond: str.index_of(s: out, sub: "@owner:") >= 0,
    label: "text output contains @owner: line"
  )
  return ()
end

// ─── Body ─────────────────────────────────────────────────────────────────────

let body = fn () -> unit require { Console, Fs } throws { Exn } do
  // Unit tests (no Fs needed for parse_doc_tags itself)
  test_parse_all_tags()
  test_parse_empty_doc()
  test_parse_unknown_tag_ignored()

  // Integration tests (need Fs to write fixture)
  write_fixture()
  try
    test_json_has_tags()
    test_text_has_tag_lines()
    cleanup_fixture()
    return ()
  catch e ->
    cleanup_fixture()
    throw e
  end
end

let safe_run = fn () -> i64 require { Console, Fs } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole, PermFs } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
