// Port of bootstrap/tests/runtime/functions.rs:
//   codegen_labeled_args_reordered_function_call,
//   codegen_labeled_args_reordered_constructor,
//   codegen_labeled_args_constructor_pattern_match_same_result,
//   codegen_labeled_args_tail_call_reordered.
import * as test_assert from "std:test/assert"

type Pair = MkPair(fst: i64, snd: i64)

let sub = fn (a: i64, b: i64) -> i64 do
  return a - b
end

let sub_tail = fn (a: i64, b: i64) -> i64 do
  if b == 0 then return a end
  return sub_tail(b: b - 1, a: a)
end

let body = fn () -> unit throws { Exn } do
  // Reordered function call.
  test_assert.assert_eq_i64(actual: sub(b: 10, a: 52), expected: 42, label: "sub(b: 10, a: 52)")
  // Reordered constructor.
  let p = MkPair(snd: 10, fst: 32)
  let sum = match p do
    | MkPair(fst: a, snd: b) -> a + b
  end
  test_assert.assert_eq_i64(actual: sum, expected: 42, label: "MkPair reordered")
  // Two equal pairs constructed in different field order.
  let p1 = MkPair(fst: 1, snd: 2)
  let p2 = MkPair(snd: 2, fst: 1)
  let p1a = match p1 do | MkPair(fst: a, snd: _) -> a end
  let p2a = match p2 do | MkPair(fst: a, snd: _) -> a end
  let p1b = match p1 do | MkPair(fst: _, snd: b) -> b end
  let p2b = match p2 do | MkPair(fst: _, snd: b) -> b end
  test_assert.assert_eq_i64(actual: p1a, expected: p2a, label: "fst equal across reorder")
  test_assert.assert_eq_i64(actual: p1b, expected: p2b, label: "snd equal across reorder")
  // Reordered tail call.
  test_assert.assert_eq_i64(actual: sub_tail(a: 42, b: 0), expected: 42, label: "sub_tail")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
