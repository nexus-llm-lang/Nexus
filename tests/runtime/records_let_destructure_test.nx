// Port of bootstrap/tests/runtime/records.rs::codegen_let_destructure_record.
// Verifies `let {x: a, y: b} = r` destructuring binding.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let r = { x: 20, y: 22 }
  let {x: a, y: b} = r
  test_assert.assert_eq_i64(actual: a + b, expected: 42, label: "let-destructure {x, y}")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
