// Port of bootstrap/tests/runtime/records.rs::codegen_record_field_access_multiple.
// Two field accesses + arithmetic.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let r = { a: 10, b: 32 }
  test_assert.assert_eq_i64(actual: r.a + r.b, expected: 42, label: "r.a + r.b")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
