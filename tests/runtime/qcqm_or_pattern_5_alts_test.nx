// Regression for nexus-qcqm: pipe_starts_arm's 64-token fuel cap caused the
// disambiguator to misread `|` as bitwise-or when the next match arm's `->` was
// > 64 tokens away — which happens easily with an or-pattern that has many
// alternatives where every alt binds via field syntax (e.g. the defs.nx
// `expr_type` staircase, where each `LirExpr*` alt expands to a dozen-plus
// tokens before the next `|`).  The misclassification caused the leading alts
// to be sucked into the *previous* arm's body as `t | LirExpr...(...)`
// expressions, leaving only the trailing alts in the actual or-pattern.
// Downstream, the `_` field-wildcards parsed as expressions surfaced at
// codegen as `variable '_' not found (in emit_atom_var) [E3001]`.
import * as test_assert from "std:test/assert"

type Box =
  B0(only: i64)
  | B1(op: i64, lhs: i64, rhs: i64, typ: i64)
  | B2(func: i64, args: i64, typ: i64)
  | B3(func: i64, args: i64, typ: i64)
  | B4(name: i64, args: i64, typ: i64)
  | B5(fields: i64, typ: i64)
  | B6(value: i64, typ: i64)
  | B7(value: i64, index: i64, typ: i64)
  | B8(value: i64, typ: i64)
  | B9(value: i64, typ: i64)
  | B10(func_name: i64, captures: i64, typ: i64)
  | B11(closure: i64, args: i64, typ: i64)
  | B12(tag_name: i64, payload: i64, typ: i64)
  | B13(cont: i64, value: i64, typ: i64)
  | B14(func_ref: i64, typ: i64)
  | B15(body_fn: i64, arm_fns: i64, arm_tags: i64, typ: i64)

// Single match arm whose pattern is a 15-alt or-pattern with field-binding
// syntax.  Pre-fix, only the last 4 alts were recognised as the or-pattern;
// the first 11 were absorbed into the lexically preceding arm's body.  The
// fixture has a *preceding* arm (B0) so the disambiguation site is hit.
let extract = fn (b: Box) -> i64 do
  match b do
    | B0(only: v) -> v
    | B1(op: _, lhs: _, rhs: _, typ: t)
    | B2(func: _, args: _, typ: t)
    | B3(func: _, args: _, typ: t)
    | B4(name: _, args: _, typ: t)
    | B5(fields: _, typ: t)
    | B6(value: _, typ: t)
    | B7(value: _, index: _, typ: t)
    | B8(value: _, typ: t)
    | B9(value: _, typ: t)
    | B10(func_name: _, captures: _, typ: t)
    | B11(closure: _, args: _, typ: t)
    | B12(tag_name: _, payload: _, typ: t)
    | B13(cont: _, value: _, typ: t)
    | B14(func_ref: _, typ: t)
    | B15(body_fn: _, arm_fns: _, arm_tags: _, typ: t) -> t
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: extract(b: B0(only: 99)), expected: 99, label: "B0")
  test_assert.assert_eq_i64(actual: extract(b: B1(op: 0, lhs: 0, rhs: 0, typ: 1)), expected: 1, label: "B1 (head)")
  test_assert.assert_eq_i64(actual: extract(b: B6(value: 0, typ: 6)), expected: 6, label: "B6 (mid)")
  test_assert.assert_eq_i64(actual: extract(b: B11(closure: 0, args: 0, typ: 11)), expected: 11, label: "B11 (lost-before-fix)")
  test_assert.assert_eq_i64(actual: extract(b: B14(func_ref: 0, typ: 14)), expected: 14, label: "B14")
  test_assert.assert_eq_i64(actual: extract(b: B15(body_fn: 0, arm_fns: 0, arm_tags: 0, typ: 15)), expected: 15, label: "B15 (tail)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
