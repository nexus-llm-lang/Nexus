// Regression for nexus-xa7f: in_bounds used `addr + access_size` without
// an overflow guard.  A near-i64::MAX address would wrap the addition to a
// small positive value, pass the `<= total` comparison, and let an
// out-of-bounds access slip through.
//
// Fix: added `if addr > i64_max - access_size then return false end` in
// mem.nx before the addition.  This test exercises both sides of that guard:
//
//   1. A legitimate in-bounds address (first allocated page) must still work.
//   2. i64::MAX - 1 = 9223372036854775806 (access_size 4) must be caught:
//      the addition would overflow to a negative number without the guard.
//   3. i64::MAX = 9223372036854775807 (access_size 1) must be caught.

import * as mem from "std:runtime/mem"
import { MemoryOutOfBounds } from "std:runtime/mem"
import * as test_assert from "std:test/assert"

// Returns true if safe_load_i32(addr) raises MemoryOutOfBounds, false if it
// returns normally.  Helper needed because try..catch is statement-only.
let load_i32_raises_oob = fn (addr: i64) -> bool throws { Exn } do
  try
    mem.safe_load_i32(addr)
    return false
  catch
    | MemoryOutOfBounds(op: _, addr: _, access_size: _) -> return true
  end
end

// Returns true if safe_load_u8(addr) raises MemoryOutOfBounds.
let load_u8_raises_oob = fn (addr: i64) -> bool throws { Exn } do
  try
    mem.safe_load_u8(addr)
    return false
  catch
    | MemoryOutOfBounds(op: _, addr: _, access_size: _) -> return true
  end
end

let body = fn () -> unit throws { Exn } do
  // ── 1. Normal in-bounds access still works after the fix ─────────────
  // Grow a fresh page and do a round-trip so we know the wrapper is live.
  let base = mem.grow(delta: 1) * 65536
  mem.safe_store_i32(addr: base, val: 42)
  test_assert.assert_eq_i64(
    actual: mem.safe_load_i32(addr: base),
    expected: 42,
    label: "safe round-trip on a valid address still works after overflow fix")

  // ── 2. addr = i64_max - 1 = 9223372036854775806, access_size = 4 ─────
  // Without the overflow guard, addr + 4 wraps to a small positive number
  // and passes the <= total check.
  // i64_max - 1 = 9223372036854775806
  let near_max = 9223372036854775806
  test_assert.assert_true(
    cond: load_i32_raises_oob(addr: near_max),
    label: "near-MAX addr (i64_max-1, access_size=4) must raise MemoryOutOfBounds")

  // ── 3. addr = i64_max = 9223372036854775807, access_size = 1 ─────────
  // Exactly at MAX; addr + 1 wraps to i64::MIN without the guard.
  let at_max = 9223372036854775807
  test_assert.assert_true(
    cond: load_u8_raises_oob(addr: at_max),
    label: "addr = i64_max, access_size = 1 must raise MemoryOutOfBounds")

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  1 / ok
  return ()
end
