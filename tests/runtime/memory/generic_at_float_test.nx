// Regression: a generic function or container instantiated at a FLOAT type
// (f64/f32) must bit-reinterpret the value across the i64 erasure boundary.
// Type variables are erased to the i64 value channel; a float argument lives in
// an f64/f32 wasm slot, so emit_coercion must emit i64.reinterpret_f64 when a
// float enters an i64-erased generic slot and f64.reinterpret_i64 when a
// concrete float is consumed back out. Before the fix emit_coercion's final
// branch was `else return %buf`, emitting NOTHING for the i64<->f64/f32
// mismatch -> invalid wasm ("type mismatch: expected i64, found f64") even
// though the program typechecks. f32 round-trips through an i32 reinterpret hop.
//
// Reinterpret (bit-cast), NOT convert: a numeric convert would change the
// value, so each round-trip is checked against the exact source literal with
// `==.` -- a garbage bit-reinterpret would make these comparisons false.
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import { Some, None } from "std:option"
import * as map from "std:collection/map"
import * as sm from "std:stringmap"

// Identity generic instantiated at f64 and f32.
let id = fn <T>(x: T) -> T do
  return x
end

let body = fn () -> unit throws { Exn } do
  // Bare generic identity at f64 / f32.
  test_assert.assert_eq_bool(
    actual: id(x: 2.5) ==. 2.5,
    expected: true,
    label: "id<f64>(2.5) == 2.5"
  )
  test_assert.assert_eq_bool(
    actual: id(x: 3.14) ==. 3.14,
    expected: true,
    label: "id<f64>(3.14) == 3.14"
  )
  let f: f32 = 1.5
  test_assert.assert_eq_bool(actual: id(x: f) == f, expected: true, label: "id<f32>(1.5) == 1.5")

  // Option<f64>: Some carries a float through the i64-erased payload.
  let opt = Some(val: 6.28)
  match opt do
    | Some(val: v) -> test_assert.assert_eq_bool(
      actual: v ==. 6.28,
      expected: true,
      label: "Option<f64> Some(6.28)"
    )
    | None -> test_assert.assert_true(cond: false, label: "Option<f64> unexpectedly None")
  end

  // [f64]: list elements flow through the erased element channel.
  let xs: [ f64 ] = [ 1.1, 2.2, 3.3 ]
  test_assert.assert_eq_bool(
    actual: list.nth(xs, n: 0) ==. 1.1,
    expected: true,
    label: "[f64] nth 0 == 1.1"
  )
  test_assert.assert_eq_bool(
    actual: list.nth(xs, n: 1) ==. 2.2,
    expected: true,
    label: "[f64] nth 1 == 2.2"
  )
  test_assert.assert_eq_bool(
    actual: list.nth(xs, n: 2) ==. 3.3,
    expected: true,
    label: "[f64] nth 2 == 3.3"
  )

  // Persistent Map<string, f64>: insert 3.14, read it back.
  let m = map.insert(m: map.string_map(), k: "pi", v: 3.14)
  let m = map.insert(m, k: "e", v: 2.718)
  test_assert.assert_eq_bool(
    actual: map.get_or(m, k: "pi", default: 0.0) ==. 3.14,
    expected: true,
    label: "Map<string,f64> get pi == 3.14"
  )
  test_assert.assert_eq_bool(
    actual: map.get_or(m, k: "e", default: 0.0) ==. 2.718,
    expected: true,
    label: "Map<string,f64> get e == 2.718"
  )
  test_assert.assert_eq_bool(
    actual: map.get_or(m, k: "absent", default: 9.99) ==. 9.99,
    expected: true,
    label: "Map<string,f64> absent default"
  )

  // Linear %StringMap<f64>: insert 3.14, read it back, then free.
  let lm0 = sm.empty()
  let lm1 = sm.put(map: lm0, key: "pi", value: 3.14)
  let lm2 = sm.put(map: lm1, key: "tau", value: 6.28)
  // Read the (borrowed) values into primitive booleans, then free the
  // linear map *before* the throwable asserts: holding `%lm2` live across
  // a throwable call would leak it on the throw path (E0540).
  let pi_ok = sm.get_or(map: &lm2, key: "pi", default: 0.0) ==. 3.14
  let tau_ok = sm.get_or(map: &lm2, key: "tau", default: 0.0) ==. 6.28
  sm.free(map: lm2)
  test_assert.assert_eq_bool(actual: pi_ok, expected: true, label: "%StringMap<f64> get pi == 3.14")
  test_assert.assert_eq_bool(
    actual: tau_ok,
    expected: true,
    label: "%StringMap<f64> get tau == 6.28"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
