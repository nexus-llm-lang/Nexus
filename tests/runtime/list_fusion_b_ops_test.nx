// Acceptance test for build/foldr-form list ops (nexus-kyii).
//
// Verifies *correctness* (not bytecode-level fusion firing): each `_b`
// variant must produce the same result as the un-fused reference. The
// fusion pass (nexus-00lw) is exercised at LIR level by
// tests/runtime/list_fusion_test.nx; here we focus on observable behavior
// through the stdlib surface so that any regression in the build/foldr
// expansion (closure capture for `cons`/`nil`, foldr arg labels, CPS-form
// function-typed accumulators) is caught at runtime.
import { concat_b, filter_b, take_b, length } from "std:list"
import * as test_assert from "std:test/assert"

let main = fn () -> unit throws { Exn } do
  // ─── concat_b basic ─────────────────────────────────────────────────
  let r1 = concat_b(xs: [ 1, 2, 3 ], ys: [ 4, 5 ])
  test_assert.assert_eq_i64_list(actual: r1, expected: [ 1, 2, 3, 4, 5 ], label: "concat_b basic")

  // ─── concat_b empty xs ──────────────────────────────────────────────
  let r2 = concat_b(xs: [], ys: [ 10, 20 ])
  test_assert.assert_eq_i64_list(actual: r2, expected: [ 10, 20 ], label: "concat_b empty xs")

  // ─── concat_b empty ys ──────────────────────────────────────────────
  let r3 = concat_b(xs: [ 10, 20 ], ys: [])
  test_assert.assert_eq_i64_list(actual: r3, expected: [ 10, 20 ], label: "concat_b empty ys")

  // ─── concat_b both empty ────────────────────────────────────────────
  let r4 = concat_b(xs: [], ys: [])
  test_assert.assert_eq_i64_list(actual: r4, expected: [], label: "concat_b both empty")

  // ─── filter_b: even-numbers filter ──────────────────────────────────
  let r_filt = filter_b(xs: [ 1, 2, 3, 4, 5, 6 ], p: fn (val: i64) -> bool do return val % 2 == 0 end)
  test_assert.assert_eq_i64_list(actual: r_filt, expected: [ 2, 4, 6 ], label: "filter_b evens")

  // ─── filter_b: empty input ──────────────────────────────────────────
  let r_filt_empty = filter_b(xs: [], p: fn (val: i64) -> bool do return true end)
  test_assert.assert_eq_i64_list(actual: r_filt_empty, expected: [], label: "filter_b empty input")

  // ─── filter_b: keep none ────────────────────────────────────────────
  let r_filt_none = filter_b(xs: [ 1, 2, 3 ], p: fn (val: i64) -> bool do return false end)
  test_assert.assert_eq_i64_list(actual: r_filt_none, expected: [], label: "filter_b keep none")

  // ─── take_b: take 3 of 5 ────────────────────────────────────────────
  let r_take = take_b(xs: [ 10, 20, 30, 40, 50 ], n: 3)
  test_assert.assert_eq_i64_list(actual: r_take, expected: [ 10, 20, 30 ], label: "take_b 3 of 5")

  // ─── take_b: take 0 ─────────────────────────────────────────────────
  let r_take_zero = take_b(xs: [ 10, 20, 30 ], n: 0)
  test_assert.assert_eq_i64_list(actual: r_take_zero, expected: [], label: "take_b 0")

  // ─── take_b: take more than length ──────────────────────────────────
  let r_take_over = take_b(xs: [ 1, 2 ], n: 10)
  test_assert.assert_eq_i64_list(actual: r_take_over, expected: [ 1, 2 ], label: "take_b over length")

  return ()
end
