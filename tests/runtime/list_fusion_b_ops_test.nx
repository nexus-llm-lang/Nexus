// Acceptance test for build/foldr-form list ops added in nexus-kyii.
//
// Verifies *correctness* (not bytecode-level fusion firing): each `_b`
// variant must produce the same result as the un-fused reference. The
// fusion pass added in nexus-00lw is exercised at LIR level by
// tests/runtime/list_fusion_test.nx; here we focus on observable behavior
// through the stdlib surface so that any regression in the build/foldr
// expansion (closure capture for `cons`/`nil`, foldr arg labels, CPS-form
// function-typed accumulators) is caught at runtime.
import { concat_b, filter_b, take_b, length } from "std:list"

let body = fn () -> i64 throws { Exn } do
  // ─── concat_b basic ─────────────────────────────────────────────────
  let r1 = concat_b(xs: [1, 2, 3], ys: [4, 5])
  if length(xs: r1) != 5 then return 0 end

  // ─── concat_b empty xs ──────────────────────────────────────────────
  let r2 = concat_b(xs: [], ys: [10, 20])
  if length(xs: r2) != 2 then return 0 end

  // ─── concat_b empty ys ──────────────────────────────────────────────
  let r3 = concat_b(xs: [10, 20], ys: [])
  if length(xs: r3) != 2 then return 0 end

  // ─── concat_b both empty ────────────────────────────────────────────
  let r4 = concat_b(xs: [], ys: [])
  if length(xs: r4) != 0 then return 0 end

  // ─── Element-order check via match (concrete int list) ──────────────
  match concat_b(xs: [1, 2, 3], ys: [4, 5]) do
    | [1, 2, 3, 4, 5] -> ()
    | _ -> return 0
  end

  // ─── filter_b: even-numbers filter ──────────────────────────────────
  let r_filt = filter_b(xs: [1, 2, 3, 4, 5, 6], p: fn (val: i64) -> bool do return val % 2 == 0 end)
  if length(xs: r_filt) != 3 then return 0 end
  match r_filt do
    | [2, 4, 6] -> ()
    | _ -> return 0
  end

  // ─── filter_b: empty input ──────────────────────────────────────────
  let r_filt_empty = filter_b(xs: [], p: fn (val: i64) -> bool do return true end)
  if length(xs: r_filt_empty) != 0 then return 0 end

  // ─── filter_b: keep none ────────────────────────────────────────────
  let r_filt_none = filter_b(xs: [1, 2, 3], p: fn (val: i64) -> bool do return false end)
  if length(xs: r_filt_none) != 0 then return 0 end

  // ─── take_b: take 3 of 5 ────────────────────────────────────────────
  let r_take = take_b(xs: [10, 20, 30, 40, 50], n: 3)
  if length(xs: r_take) != 3 then return 0 end
  match r_take do
    | [10, 20, 30] -> ()
    | _ -> return 0
  end

  // ─── take_b: take 0 ─────────────────────────────────────────────────
  let r_take_zero = take_b(xs: [10, 20, 30], n: 0)
  if length(xs: r_take_zero) != 0 then return 0 end

  // ─── take_b: take more than length ──────────────────────────────────
  let r_take_over = take_b(xs: [1, 2], n: 10)
  if length(xs: r_take_over) != 2 then return 0 end
  match r_take_over do
    | [1, 2] -> ()
    | _ -> return 0
  end

  return 1
end

let safe_run = fn () -> i64 do
  try
    return body()
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  // Trap on failure — non-zero exit signals FAIL to the runtime test runner.
  let _ = 1 / ok
  return ()
end
