// Reduced repro for nexus-3skj.a -- i32/f32 codegen gap.
//
// The dvr6.6 batch8 typecheck_inference tests had to lift i32 and f32
// sites to typecheck-only top-level declarations because runtime
// exercise traps. The 5rjf fix landed for the closure RETURN slot
// (bool/i32/char coerced to TyI64). The remaining gap was f32:
//
//   - i32 path: top-level fn taking/returning i32, called from main and
//     branched on. Already runs cleanly under self-host post-5rjf.
//
//   - f32 path: top-level fn taking f32 args, called from main. Was
//     emitting `f64.const` + `f64.lt` against an `(f32, f32) -> i32`
//     wasm signature, so wasm-tools compose validation rejected the
//     core module with "type mismatch: expected f32, found f64". Fix:
//     - codegen emit_binary now branches on TyF32 -> op_f32_{add,sub,
//       mul,div,eq,ne,lt,le,gt,ge}; falls back to f64 ops for f64.
//     - emit_coercion bridges f64 <-> f32 via op_f32_demote_f64 /
//       op_f64_promote_f32 so f64 literals coerce at call sites.
//
// This fixture compiles, composes, and runs to completion only when
// both paths are correct.
import * as test_assert from "std:test/assert"

let i32_arith = fn (a: i32) -> i32 do
  let b = a + 2
  return b
end

let f32_compare = fn (a: f32, b: f32) -> bool do
  return a <. b
end

let body = fn () -> unit throws { Exn } do
  let r32: i32 = i32_arith(a: 40)
  let ok_i32: bool = r32 == 42
  test_assert.assert_eq_bool(actual: ok_i32, expected: true, label: "i32 arith returns 42")

  let f_lt: bool = f32_compare(a: 1.25, b: 2.5)
  test_assert.assert_eq_bool(actual: f_lt, expected: true, label: "f32 lt: 1.25 <. 2.5")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
