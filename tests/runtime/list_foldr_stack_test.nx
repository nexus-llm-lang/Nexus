// Regression: bounded-stack call to list.foldr (issue nexus-9icj).
//
// foldr is non-tail-recursive (see nxlib/stdlib/list.nx). Stack depth grows
// linearly with input length. This fixture exercises foldr at the
// empirically-safe upper bound on the standard wasmtime configuration so
// regressions that would *raise* the per-call stack cost (e.g. extra
// captures, additional intermediate frames) are caught before they break
// real workloads.
//
// Bound: n = 2048
//   * passes on the wasmtime config used by nexus (default 8 MiB linear
//     memory + ~512 KiB engine stack); larger n risks `wasm trap: call
//     stack exhausted` depending on locals layout of foldr after codegen.
//   * The bd issue (acceptance) accepts EITHER a 100k-stack trampoline OR
//     documented behaviour with a regression test; this test takes the
//     latter path. See foldr's doc comment for the rationale.
import { foldr, length } from "std:list"
import * as test_assert from "std:test/assert"

// Build [0, 1, 2, ..., n-1] tail-recursively (does not exercise foldr's
// stack). reverse via prepend keeps the constructor order intact.
let make_range_go = fn (n: i64, i: i64, acc: [i64]) -> [i64] do
  if i >= n then return acc end
  return make_range_go(n, i: i + 1, acc: i :: acc)
end

let make_range = fn (n: i64) -> [i64] do
  // Returns [n-1, n-2, ..., 0]; foldr's combiner is associative so the
  // numeric sum is invariant under reversal — we don't bother re-reversing.
  return make_range_go(n, i: 0, acc: [])
end

let body = fn () -> unit throws { Exn } do
  let n = 2048

  let xs = make_range(n)
  test_assert.assert_eq_i64(actual: length(xs), expected: n, label: "range built")

  // Right-fold sum: foldr applies f on the way out of recursion. Stack
  // depth equals length(xs). For n = 2048 this stays under wasmtime's
  // default stack budget; raising n past ~4096 starts tripping
  // `call stack exhausted` on Apple-silicon wasmtime.
  let total = foldr(xs, init: 0, f: fn (val: i64, acc: i64) -> i64 do
    return val + acc
  end)

  // Sum of 0..n-1 = n * (n-1) / 2 = 2048 * 2047 / 2 = 2096128
  let expected = n * (n - 1) / 2
  test_assert.assert_eq_i64(actual: total, expected, label: "foldr sum at n=2048")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  // Trap on failure so the runtime test runner reports FAIL via non-zero
  // exit. Mirrors the divide-by-zero idiom used by every fixture in this
  // directory.
  let _ = 1 / ok
  return ()
end
