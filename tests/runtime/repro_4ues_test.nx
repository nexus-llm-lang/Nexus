// Reproducer for nexus-4ues -- bootstrap-Rust codegen ICE'd at E2010
// ("variable '__t2' has conflicting wasm local types") when an i64
// `return` immediately followed a `raise` inside a `try` body and the
// function had no trailing-return after `end`.
//
// Shape:
//
//     try
//       raise Boom(code: 42)
//       return -1     // unreachable (raise is divergent)
//     catch
//       | _ -> return 1
//     end
//     // <- no fall-through return
//
// Root cause: `lir_opt::strip_unreachable_stmts` truncated the try body
// at the divergent `Let __t1 = LirExpr::Raise`, dropping the `Let __t2 =
// LirExpr::Binary(Sub, 0, 1)` that desugared from `return -1`. But
// `body_ret` (set during LIR lowering, before optimization) still
// referenced `__t2`, and so did `func.ret` (extracted from the
// TryCatch's body_ret as the function-level return atom). At codegen,
// `compile_atom(&func.ret)` issued `local.get __t2` against a name no
// longer in `local_map` â€” the missing-local path mistakenly raises
// `CodegenError::ConflictingLocalTypes`.
//
// Fix (bootstrap/src/compiler/passes/lir_opt.rs::strip_unreachable_stmts
// and optimize_function): when stripping the body of a TryCatch / IfReturn
// / Switch case after which the trailing-block diverges, also clear the
// associated `body_ret` / `then_ret` / `else_ret` / `default_ret` /
// `case.ret` since their referent atom may have been the stripped Let;
// the trailing value is unreachable anyway. Function-level: if `func.ret`
// references a name no longer defined anywhere in the body or params,
// replace it with a default atom of the function's return type.
//
// Self-host codegen widens conflicting registrations to i64 in
// `register_local` (src/backend/wasm/collect.nx), so the same shape
// compiled cleanly via the self-host backend pre-fix. The bootstrap-Rust
// register_local errors instead, which is the path this fixture exercises.
import * as test_assert from "std:test/assert"

exception Boom(code: i64)
exception Oops(msg: string)

// Pure single-arm wildcard catch â€” minimal repro shape.
let raise_then_dead_neg = fn () -> i64 do
  try
    raise Boom(code: 42)
  catch
    | _ -> return 1
  end
end

// Selective constructor catch with payload binding (the original shape
// that hit this in dvr6.6 batch10's typecheck_effects_selective_catch
// port).
let classify_boom = fn () -> i64 do
  try
    raise Boom(code: 42)
  catch
    | Boom(code) ->
      let x: i64 = code
      return x
    | _ -> return -1
  end
end

// Multi-exception catch.
let classify_oops = fn () -> i64 do
  try
    raise Oops(msg: "hi")
  catch
    | Boom(code: c) -> return c
    | Oops(msg: m) -> return 2
    | _ -> return -1
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: raise_then_dead_neg(), expected: 1,
    label: "raise then dead neg-return -- wildcard catch")
  test_assert.assert_eq_i64(actual: classify_boom(), expected: 42,
    label: "raise then dead neg-return -- ctor catch binds payload")
  test_assert.assert_eq_i64(actual: classify_oops(), expected: 2,
    label: "raise then dead neg-return -- multi-arm catch routes")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
