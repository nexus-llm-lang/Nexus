// Port of bootstrap/tests/runtime/control_flow.rs:
//   codegen_stmt_after_nested_match_is_reachable,
//   codegen_recursive_call_after_match_is_reachable.
import * as test_assert from "std:test/assert"

type Color = Red | Green | Blue
type Shape = Circle | Square

let describe = fn (c: Color, s: Shape) -> i64 do
  let _x = 0
  match c do
    | Red ->
      match s do
        | Circle -> let _y = 1
        | Square -> let _y = 2
      end
    | Green ->
      let _y = 10
    | Blue ->
      let _y = 20
  end
  let after = 100
  return after
end

let count = fn (xs: [Color], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | c :: rest ->
      let inc = match c do
        | Red -> 1
        | Green -> 2
        | Blue -> 3
      end
      let next = acc + inc
      return count(xs: rest, acc: next)
  end
  return acc
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: describe(c: Red, s: Circle), expected: 100, label: "stmt after nested match")
  let items = Red :: Blue :: Green :: []
  test_assert.assert_eq_i64(actual: count(xs: items, acc: 0), expected: 6, label: "recursive after match")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
