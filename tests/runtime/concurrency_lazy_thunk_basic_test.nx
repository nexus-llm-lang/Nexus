// Port of bootstrap/tests/runtime/concurrency.rs::test_lazy_thunk_basic_force,
// test_lazy_thunk_captures_variable, test_lazy_thunk_with_function_call.
//
// Exercises the `let @x = expr` lazy-thunk binding and `@x` force operator
// at runtime. The original Rust tests only assert that the code compiles
// and runs without trapping; this port adds value-level checks via
// assert_eq_i64 to also catch silent miscompilations of the force op.
import * as test_assert from "std:test/assert"

let compute = fn (a: i64, b: i64) -> i64 do
  return a + b
end

let body = fn () -> unit throws { Exn } do
  // basic_force: thunk with constant body.
  let @x1 = 42
  let v1 = @x1
  test_assert.assert_eq_i64(actual: v1, expected: 42, label: "lazy thunk basic force")

  // captures_variable: thunk closes over a local.
  let y = 10
  let @x2 = y + 1
  let v2 = @x2
  test_assert.assert_eq_i64(actual: v2, expected: 11, label: "lazy thunk captures variable")

  // with_function_call: thunk body invokes another fn over captured args.
  let a = 3
  let b = 4
  let @result = compute(a: a, b: b)
  let v3 = @result
  test_assert.assert_eq_i64(actual: v3, expected: 7, label: "lazy thunk with function call")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
