// nexus-elxhg positive control: the ambiguous-import diagnostic (E4006) must
// NOT fire when the colliding bare name is disambiguated with `as`, and must
// NOT fire for distinct (non-colliding) names imported from the two modules.
// Imports `dup_val` from a and `dup_val as dup_val_b` from b (so the bare
// names differ: dup_val vs dup_val_b), plus the non-colliding `other_val`.
import * as test_assert from "std:test/assert"
import { dup_val } from "tests/_fixtures/dup_import_a.nx"
import { dup_val as dup_val_b, other_val } from "tests/_fixtures/dup_import_b.nx"

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: dup_val(), expected: 100, label: "a.dup_val")
  test_assert.assert_eq_i64(actual: dup_val_b(), expected: 200, label: "b.dup_val as dup_val_b")
  test_assert.assert_eq_i64(actual: other_val(), expected: 200, label: "b.other_val")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
