// Port of bootstrap/tests/runtime/control_flow.rs:
//   sra_immediate_match_eliminates_allocation,
//   sra_multi_field_destructure,
//   linear_reuse_match_reconstruct_same_constructor,
//   linear_reuse_multi_field_partial_update,
//   linear_reuse_chained_updates.
import * as test_assert from "std:test/assert"

type Box = Box(value: i64)
type Pair = Pair(fst: i64, snd: i64)
type Triple = Triple(a: i64, b: i64, c: i64)

let immediate_match = fn () -> i64 do
  let result = match Box(value: 99) do
    | Box(value: v) -> v
  end
  return result
end

let multi_field = fn () -> i64 do
  let p = Pair(fst: 10, snd: 20)
  let sum = match p do
    | Pair(fst: a, snd: b) -> a + b
  end
  return sum
end

let update_box = fn (b: %Box) -> Box do
  match b do
    | Box(value: v) -> return Box(value: v + 1)
  end
end

let update_fst = fn (p: %Pair) -> Pair do
  match p do
    | Pair(fst: a, snd: b) -> return Pair(fst: a * 10, snd: b)
  end
end

let inc_a = fn (t: %Triple) -> Triple do
  match t do
    | Triple(a: x, b: y, c: z) -> return Triple(a: x + 1, b: y, c: z)
  end
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: immediate_match(), expected: 99, label: "SRA immediate match")
  test_assert.assert_eq_i64(actual: multi_field(), expected: 30, label: "SRA multi-field")
  let %b = Box(value: 42)
  let result = update_box(b: %b)
  let v = match result do
    | Box(value: v) -> v
  end
  test_assert.assert_eq_i64(actual: v, expected: 43, label: "linear reuse box")
  let %p = Pair(fst: 3, snd: 7)
  let result_p = update_fst(p: %p)
  let pa = match result_p do
    | Pair(fst: a, snd: _) -> a
  end
  let pb = match result_p do
    | Pair(fst: _, snd: b) -> b
  end
  test_assert.assert_eq_i64(actual: pa, expected: 30, label: "linear reuse pair fst")
  test_assert.assert_eq_i64(actual: pb, expected: 7, label: "linear reuse pair snd")
  let %t = Triple(a: 0, b: 10, c: 20)
  let %t2 = inc_a(t: %t)
  let %t3 = inc_a(t: %t2)
  let result_t = inc_a(t: %t3)
  let ta = match result_t do
    | Triple(a: a, b: _, c: _) -> a
  end
  let tb = match result_t do
    | Triple(a: _, b: b, c: _) -> b
  end
  let tc = match result_t do
    | Triple(a: _, b: _, c: c) -> c
  end
  test_assert.assert_eq_i64(actual: ta, expected: 3, label: "linear reuse triple a")
  test_assert.assert_eq_i64(actual: tb, expected: 10, label: "linear reuse triple b")
  test_assert.assert_eq_i64(actual: tc, expected: 20, label: "linear reuse triple c")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
