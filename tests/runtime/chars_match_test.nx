// Port of bootstrap/tests/runtime/chars.rs::char_match.
import * as test_assert from "std:test/assert"

let classify = fn (c: char) -> i64 do
  match c do
    | 'a' -> return 1
    | 'x' -> return 2
    | _ -> return 99
  end
  return -1
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: classify(c: 'x'), expected: 2, label: "match 'x'")
  test_assert.assert_eq_i64(actual: classify(c: 'a'), expected: 1, label: "match 'a'")
  test_assert.assert_eq_i64(actual: classify(c: 'z'), expected: 99, label: "match wildcard")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
