// nexus-in6i: parser error recovery. The self-host parser used to abort on
// the first parse failure; this fixture pins the multi-error contract.
//
// The synthetic source below contains three unrelated top-level parse
// errors interleaved with three well-formed declarations. After recovery,
// the parser should return all three formatted diagnostics and the three
// good definitions (the first `good_a`, `good_b`, `good_c` lets) — proving
// (a) recovery resynchronises at the next column-1 top-level keyword and
// (b) per-decl failure does not poison subsequent decls.
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import * as str from "std:str"
import * as parser from "src/frontend/parser.nx"
import { CompilerDiagnostic } from "src/diagnostics/error.nx"
import { Program } from "src/syntax/ast.nx"

// Source with 3 unrelated parse errors interleaved between 3 valid decls.
// Each error is engineered to fail inside parse_top_level so the recovery
// path is exercised on a real-shaped break, not a contrived single-token
// stub:
//   1. `let bad1 = 1 +` — expression parse breaks on the missing RHS.
//   2. `type Bad2 =` — variant list expected after `=`, gets `let`.
//   3. `let bad3 = fn () -> i64 do return 42` — body unterminated (no
//      `end`), parse fails when it walks into the next top-level decl.
let make_bad_source = fn () -> string do
  return "let good_a = 1\n"
    ++ "let bad1 = 1 +\n"
    ++ "let good_b = 2\n"
    ++ "type Bad2 =\n"
    ++ "let good_c = 3\n"
    ++ "let bad3 = fn () -> i64 do return 42\n"
end

let body = fn () -> unit throws { Exn } do
  let src = make_bad_source()
  match parser.parse_source_collect(
    src,
    file: "test.nx"
  ) do | parser.ParseDiagnostics(prog, diags) ->
    let n = list.length(xs: diags)
    test_assert.assert_eq_i64(
      actual: n,
      expected: 3,
      label: "in6i: 3 parse diagnostics accumulated"
    )

    // Surviving Program should retain at least the three well-formed lets
    // (good_a / good_b / good_c). Asserting >= 3 keeps the test resilient
    // to future parser changes that might recover even more aggressively
    // than the current heuristic (e.g. salvaging a partial bad3).
    match prog do | Program(definitions: defs, module_doc: _) ->
      let n_defs = list.length(xs: defs)
      test_assert.assert_eq_bool(
        actual: n_defs >= 3,
        expected: true,
        label: "in6i: at least 3 good defs survived recovery"
      )
    end

    // Every diagnostic should have an E1xxx parse-error code. After the
    // nexus-kmel migration to structured CompilerDiagnostics, the code lives in
    // its own field rather than the message tail, so check it directly.
    assert_all_have_e1_code(diags, idx: 0)
  end
  return ()
end

let assert_all_have_e1_code = fn (diags: [ CompilerDiagnostic ], idx: i64) -> unit throws { Exn } do
  match diags do
    | [] -> return ()
    | d :: rest ->
      match d do | CompilerDiagnostic(
        code: c,
        severity: _,
        file: _,
        line: _,
        column: _,
        message: _
      ) ->
        let has_e1 = str.starts_with(s: c, prefix: "E1")
        test_assert.assert_eq_bool(
          actual: has_e1,
          expected: true,
          label: "in6i: diag carries E1xxx code"
        )
      end
      return assert_all_have_e1_code(diags: rest, idx: idx + 1)
  end
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
