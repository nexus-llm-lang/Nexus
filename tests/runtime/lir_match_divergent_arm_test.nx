// Regression test for nexus-b0kz:
// lir_infer_match_result_type must not infer a non-unit result type from a
// match arm whose last statement is MirStmtReturn (diverging arm).
//
// Before the fix, lir_last_mir_expr treated [MirStmtReturn(e)] the same as
// [MirStmtExpr(e)], causing the match-result temp to be allocated with the
// type of `e` (e.g., i64) even though the arm never falls through to assign
// it.  This could produce a wasm local with a wider type than needed.
//
// After the fix, return-ending arms are treated as contributing TyUnit,
// so only non-diverging arms influence the inferred result type.
import * as test_assert from "std:test/assert"

// match used in statement position with one diverging return arm (non-unit
// return expression) and one non-diverging unit arm.
// The match-result temp must be unit; the function must reach the assertion.
let check_early_return = fn (x: i64) -> i64 do
  match x do
    | 0 ->
      return 42
    | _ ->
      ()
  end
  return 99
end

// All arms diverge via return — result temp must be unit.
let all_diverge = fn (x: i64) -> i64 do
  match x do
    | 0 -> return 10
    | 1 -> return 20
    | _ -> return 30
  end
end

// Diverging arm returns a non-unit value; non-diverging arm produces unit
// via expression.  The match is in expression position with an outer return.
let mixed_arms = fn (x: i64) -> i64 do
  let v = match x do
    | 0 ->
      return 0
    | _ ->
      7
  end
  return v
end

let main = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: check_early_return(x: 0), expected: 42, label: "diverge arm returns 42")
  test_assert.assert_eq_i64(actual: check_early_return(x: 1), expected: 99, label: "fall-through arm returns 99")
  test_assert.assert_eq_i64(actual: all_diverge(x: 0), expected: 10, label: "all diverge 0")
  test_assert.assert_eq_i64(actual: all_diverge(x: 1), expected: 20, label: "all diverge 1")
  test_assert.assert_eq_i64(actual: all_diverge(x: 2), expected: 30, label: "all diverge 2")
  test_assert.assert_eq_i64(actual: mixed_arms(x: 0), expected: 0,  label: "mixed diverge branch")
  test_assert.assert_eq_i64(actual: mixed_arms(x: 5), expected: 7,  label: "mixed non-diverge branch")
  return ()
end
