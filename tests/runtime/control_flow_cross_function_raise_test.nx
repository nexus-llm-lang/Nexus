// Port of bootstrap/tests/runtime/control_flow.rs:
//   codegen_cross_function_raise_caught_by_caller_try_catch,
//   codegen_cross_function_raise_with_return_value_caught,
//   codegen_cross_function_raise_propagates_through_intermediate.
import * as test_assert from "std:test/assert"

// Original Rust source uses `exception Boom(i64)` (positional field) — the
// integration harness bypasses the type-checker, but the type-checker
// requires labeled fields, so we use `code:` here. Behavior is identical.
exception Boom(code: i64)

let thrower_unit = fn () -> unit throws { Exn } do
  raise Boom(code: 42)
  return ()
end

let thrower_i64 = fn () -> i64 throws { Exn } do
  raise Boom(code: 99)
  return 0
end

let deep_thrower = fn () -> unit throws { Exn } do
  raise Boom(code: 7)
  return ()
end

let middle = fn () -> unit throws { Exn } do
  deep_thrower()
  return ()
end

let caller_unit = fn () -> i64 throws { Exn } do
  try
    thrower_unit()
    return -1
  catch
    | Boom(code: c) -> return c
    | _ -> return -2
  end
  return -3
end

let caller_i64 = fn () -> i64 throws { Exn } do
  try
    let _ = thrower_i64()
    return -1
  catch
    | Boom(code: c) -> return c
    | _ -> return -2
  end
  return -3
end

let caller_intermediate = fn () -> i64 throws { Exn } do
  try
    middle()
    return -1
  catch
    | Boom(code: c) -> return c
    | _ -> return -2
  end
  return -3
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: caller_unit(), expected: 42, label: "raise from unit fn")
  test_assert.assert_eq_i64(actual: caller_i64(), expected: 99, label: "raise from i64 fn")
  test_assert.assert_eq_i64(actual: caller_intermediate(), expected: 7, label: "raise through intermediate")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
