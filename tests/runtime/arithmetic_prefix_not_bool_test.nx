// Port of bootstrap/tests/runtime/arithmetic.rs::codegen_prefix_unary_not_bool.
// Verifies `!` boolean negation, double-negation, and precedence vs `&&`.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let t = true
  test_assert.assert_eq_bool(actual: !t, expected: false, label: "!true")

  let f = false
  test_assert.assert_eq_bool(actual: !!f, expected: false, label: "!!false")

  // Precedence: !t && true must parse as (!t) && true → false.
  test_assert.assert_eq_bool(actual: !t && true, expected: false, label: "!t && true precedence")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
