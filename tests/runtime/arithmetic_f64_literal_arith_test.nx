// Port of bootstrap/tests/runtime/arithmetic.rs::codegen_f64_literal_and_arithmetic.
// Exercises f64 +., *., -. with epsilon-based equality.
//
// `abs` is implemented inline (sign-flip when negative) instead of importing
// std:math::abs_float — the latter lowers to `nexus:runtime/math::f64-abs`,
// a host import the standalone wasmtime CLI does not provide. The Rust
// integration harness wires that stub in via `define_component_runtime_stubs`;
// the self-hosted runner does not.
import * as test_assert from "std:test/assert"

let abs_f64 = fn (val: f64) -> f64 do
  if val <. 0.0 then return 0.0 -. val end
  return val
end

let close = fn (a: f64, b: f64) -> bool do
  let d = a -. b
  return abs_f64(val: d) <. 0.0001
end

let body = fn () -> unit throws { Exn } do
  let x = 3.14
  let y = 2.0
  // `assert_eq_bool` (instead of `assert_true`) keeps `std:str::from_bool`
  // live so the bundler links stdlib, ensuring the produced component
  // exports `wasi:cli/run` like the rest of the runner-driven fixtures.
  test_assert.assert_eq_bool(actual: close(a: x +. y, b: 5.14), expected: true, label: "f64 add 3.14 + 2.0")
  test_assert.assert_eq_bool(actual: close(a: x *. y, b: 6.28), expected: true, label: "f64 mul 3.14 * 2.0")
  test_assert.assert_eq_bool(actual: close(a: x -. y, b: 1.14), expected: true, label: "f64 sub 3.14 - 2.0")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
