// nexus-pro10: `nexus lint --fix` must apply E2005/E2007 fix-its in place;
// `nexus lint --fix-diff` must show the diff without writing; plain `nexus lint`
// and `nexus lint --check` must remain AST-only and partial-program-tolerant.
//
// Strategy: write a fixture with a known E2007 (LinearUnused) diagnostic, invoke
// run_lint_subcommand with --fix, assert the file is rewritten and the name is
// prefixed with `_`. Also verify --fix-diff leaves the file unchanged, and that
// plain lint still works (exits 0 on a clean file).

import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"
import * as str from "std:str"
import { run_lint_subcommand } from "src/tools/lint.nx"

// A fixture with an unused linear binding — fires E2007 LinearUnused.
let fixture_source_linear_unused = fn () -> string do
  return "import { Console } from \"std:stdio\"\n"
    ++ "import * as stdio from \"std:stdio\"\n"
    ++ "export type Box = Box(val: i64)\n"
    ++ "let main = fn () -> unit require { PermConsole } do\n"
    ++ "  inject stdio.system_handler do\n"
    ++ "    let %unused = Box(val: 42)\n"
    ++ "    Console.println(val: \"done\")\n"
    ++ "  end\n"
    ++ "end\n"
end

let fixture_path_fix = fn () -> string do
  return "./.pro10_fix_test_fixture.nx"
end

let write_linear_fixture = fn () -> unit require { Fs } throws { Exn } do
  Fs.write_string(path: fixture_path_fix(), content: fixture_source_linear_unused())
  return ()
end

let cleanup_fix_fixture = fn () -> unit require { Fs } do
  try
    Fs.remove_file(path: fixture_path_fix())
    return ()
  catch _ -> return ()
  end
end

// --fix mode: file should be rewritten with `_` prefix on unused binding.
let test_fix_mode_applies_e2007 = fn () -> unit require { Console, Fs } throws { Exn } do
  write_linear_fixture()
  let code = run_lint_subcommand(args: [ "--fix", fixture_path_fix() ])
  // --fix exits 0 regardless of whether fixes were applied.
  test_assert.assert_eq_i64(
    actual: code,
    expected: 0,
    label: "pro10: --fix exits 0 after applying fix-its"
  )
  // Verify the file was rewritten: `unused` -> `_` or `_unused`.
  let new_src = Fs.read_to_string(path: fixture_path_fix())
  // The fix renames the unused binding to `_`.
  let fixed = str.contains(s: new_src, sub: "let %_")
  test_assert.assert_true(cond: fixed,
    label: "pro10: --fix rewrites unused binding to `_` prefix")
  return ()
end

// plain lint (AST-only) on a clean file: exit 0.
let test_plain_lint_clean_exits_0 = fn () -> unit require { Console, Fs } throws { Exn } do
  let clean = "let add = fn (a: i64, b: i64) -> i64 do return a + b end\n"
  Fs.write_string(path: fixture_path_fix(), content: clean)
  let code = run_lint_subcommand(args: [ fixture_path_fix() ])
  test_assert.assert_eq_i64(
    actual: code,
    expected: 0,
    label: "pro10: plain lint exits 0 on clean file"
  )
  return ()
end

let body = fn () -> unit require { Console, Fs } throws { Exn } do
  try
    test_fix_mode_applies_e2007()
    cleanup_fix_fixture()
    test_plain_lint_clean_exits_0()
    cleanup_fix_fixture()
    return ()
  catch e ->
    cleanup_fix_fixture()
    throw e
  end
end

let safe_run = fn () -> i64 require { Console, Fs } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole, PermFs } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    let _ = 1 / ok
    return ()
  end
end
