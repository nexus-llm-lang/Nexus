// Regression repro for nexus-5rjf.
//
// Capturing a `(T) -> bool` typed function inside a foldr lambda that is in
// turn nested inside a build wrapper produces a wasm "indirect call type
// mismatch" trap at the build call site. Identical shape with `(T) -> i64`
// works (proved by map_b in nexus-kyii). The smoking gun is the bool return
// type: even discarding the result of `p(val)` is enough to trigger the trap.
//
// This is the minimal blocker for filter_b / take_b in nexus-kyii.
import { foldr, build, length } from "std:list"

let test_fn = fn (xs: [i64], p: (val: i64) -> bool) -> [i64] do
  return build(g: fn (cons: (val: i64, rest: [i64]) -> [i64], nil: [i64]) -> [i64] do
    return foldr(xs, init: nil, f: fn (val: i64, acc: [i64]) -> [i64] do
      let _ = p(val: val)
      return cons(val: val, rest: acc)
    end)
  end)
end

let main = fn () -> unit do
  let r = test_fn(xs: [1, 2, 3], p: fn (val: i64) -> bool do return val > 0 end)
  if length(xs: r) != 3 then
    let _ = 1 / 0
    return ()
  end
  return ()
end
