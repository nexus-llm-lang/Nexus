// Static-check tail: `nexus build` / `nexus typecheck` run lint after
// typecheck.  Default findings are non-fatal warnings (gating count 0);
// `--lint-level=error` and `--deny=Lxxxx` promote findings to gating errors
// (positive count → driver halts before codegen); `--no-lint` skips the pass.
//
// Strategy: parse a fixture whose `require { Console }` cap is never consumed
// (fires L0002 at warning severity), then drive run_lint_on_build under each
// policy and assert the returned gating-error count.  Advisory L0006 must not
// be promoted by --lint-level=error (note severity + advisory), only by an
// explicit --deny=L0006.

import * as test_assert from "std:test/assert"
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import { None, Some } from "std:option"
import * as lexer from "src/frontend/lexer.nx"
import { ParseDiagnostics }, * as parser from "src/frontend/parser.nx"
import { Program } from "src/syntax/ast.nx"
import { make_lint_build_policy, run_lint_on_build } from "src/cli/lint_on_build.nx"

// Fixture with an unused `Console` require on a helper — fires L0002 (warning).
let l0002_source = fn () -> string do
  return "import { Console } from \"std:stdio\"\n"
    ++ "let helper = fn () -> i64 require { Console } do\n"
    ++ "  return 42\n"
    ++ "end\n"
    ++ "let main = fn () -> unit do\n"
    ++ "  return ()\n"
    ++ "end\n"
end

let parse_fixture = fn (src: string) -> Program do
  let tokens = lexer.tokenize(src)
  match parser.parse_collect(tokens, file: "fixture.nx") do
    | ParseDiagnostics(prog, diags: _) -> return prog
  end
end

// (a) Default policy: warning surfaces but does not gate (count == 0).
let test_default_is_nonfatal = fn () -> unit require { Console } throws { Exn } do
  let src = l0002_source()
  let prog = parse_fixture(src)
  let policy = make_lint_build_policy(no_lint: false, level_error: false, deny: None)
  let n = run_lint_on_build(prog, src, file: "fixture.nx", policy)
  test_assert.assert_eq_i64(
    actual: n,
    expected: 0,
    label: "zglqq: default lint policy does not gate the build"
  )
  return ()
end

// (b1) --lint-level=error promotes the L0002 warning → gating count > 0.
let test_lint_level_error_gates = fn () -> unit require { Console } throws { Exn } do
  let src = l0002_source()
  let prog = parse_fixture(src)
  let policy = make_lint_build_policy(no_lint: false, level_error: true, deny: None)
  let n = run_lint_on_build(prog, src, file: "fixture.nx", policy)
  test_assert.assert_eq_i64(
    actual: n,
    expected: 1,
    label: "zglqq: --lint-level=error gates on the L0002 warning"
  )
  return ()
end

// (b2) --deny=L0002 promotes the named code → gating count > 0.
let test_deny_code_gates = fn () -> unit require { Console } throws { Exn } do
  let src = l0002_source()
  let prog = parse_fixture(src)
  let policy = make_lint_build_policy(no_lint: false, level_error: false, deny: Some(val: "L0002"))
  let n = run_lint_on_build(prog, src, file: "fixture.nx", policy)
  test_assert.assert_eq_i64(
    actual: n,
    expected: 1,
    label: "zglqq: --deny=L0002 gates on the named rule"
  )
  return ()
end

// (b3) --deny naming an unrelated code does NOT gate this fixture.
let test_deny_other_code_no_gate = fn () -> unit require { Console } throws { Exn } do
  let src = l0002_source()
  let prog = parse_fixture(src)
  let policy = make_lint_build_policy(no_lint: false, level_error: false, deny: Some(val: "L0099"))
  let n = run_lint_on_build(prog, src, file: "fixture.nx", policy)
  test_assert.assert_eq_i64(
    actual: n,
    expected: 0,
    label: "zglqq: --deny of an unrelated code leaves the build ungated"
  )
  return ()
end

// (c) --no-lint skips the pass entirely (count == 0 even with a warning present).
let test_no_lint_skips = fn () -> unit require { Console } throws { Exn } do
  let src = l0002_source()
  let prog = parse_fixture(src)
  let policy = make_lint_build_policy(no_lint: true, level_error: true, deny: Some(val: "L0002"))
  let n = run_lint_on_build(prog, src, file: "fixture.nx", policy)
  test_assert.assert_eq_i64(
    actual: n,
    expected: 0,
    label: "zglqq: --no-lint skips lint even with escalation flags set"
  )
  return ()
end

// (d) Advisory L0006 (design-authority, note severity) is NOT promoted by the
// blanket --lint-level=error switch — only an explicit --deny would gate it.
let test_advisory_not_blanket_promoted = fn () -> unit require { Console } throws { Exn } do
  let src = "// the only way to do this is by design\n"
    ++ "let main = fn () -> unit do\n"
    ++ "  return ()\n"
    ++ "end\n"
  let prog = parse_fixture(src)
  let policy = make_lint_build_policy(no_lint: false, level_error: true, deny: None)
  let n = run_lint_on_build(prog, src, file: "fixture.nx", policy)
  test_assert.assert_eq_i64(
    actual: n,
    expected: 0,
    label: "zglqq: --lint-level=error does not promote advisory L0006"
  )
  return ()
end

let body = fn () -> unit require { Console } throws { Exn } do
  test_default_is_nonfatal()
  test_lint_level_error_gates()
  test_deny_code_gates()
  test_deny_other_code_no_gate()
  test_no_lint_skips()
  test_advisory_not_blanket_promoted()
  return ()
end

let safe_run = fn () -> i64 require { Console } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
