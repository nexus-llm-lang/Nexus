// Issue nexus-stj8 — V2 HIR JSON dump: structured expr tree.
//
// The V1 dump emitted `body_pp` as a stringified pretty-print; V2 emits
// `body: <tree>` where every node carries
//   {kind: "<VariantName>", <flat-fields>, children: [<sub-node>, ...]}.
// This test exercises the walker across a representative sample of
// HirExprKind variants: Literal, Variable, BinOp, Call, If, Match (the
// fixture covers let-binding via a HirStmt Let).
//
// Same subprocess-avoidance rationale as ud6j_hir_dump_test.nx: we drive
// `hir_to_json` in-process and parse the result with std:json.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as list from "std:list"
import * as ir_dump from "src/tools/dump/ir_dump.nx"
import * as json from "std:json"
import { JsonValue } from "std:json"
import { None } from "std:option"
import {
  HirProgram, HirFunction, HirParam, HirBody, EagerBody,
  HirStmt, HirStmtKind, HirExpr, HirExprKind,
  HirMatchCase, HirPatternKind, HirCallArg
} from "src/ir/hir/types.nx"
import {
  SigilImmutable, LitInt, LitBool, TyI64, TyBool, TyUnit, OpAdd, OpEq, TyRow
} from "src/syntax/ast.nx"
import {
  expect_array, expect_string, require_field, nth_or_fail
} from "tests/_fixtures/json_helpers.nx"

// ─── Fixture: build a non-trivial HIR program ──────────────────────────────
//
// Synthesised function `compute(x: i64) -> i64` with body:
//   let y = (x + 1)
//   if (y == 0) then return 0 end
//   return mul(x: y, y: 2)
//
// Covers: HirStmt Let, BinOp, Call, If, Literal (Int + Bool via the cond
// path), Variable. Not all variants are emitted (we don't need exhaustive
// coverage to test the walker shape) but we want at least the five
// V2-required kinds: let, function call, if, literal, var-ref.

let mk_sp = fn () -> Span do
  return Span(offset: 0, line: 1, col: 1)
end

let var_expr = fn (name: string) -> HirExpr do
  return HirExpr(node: Variable(name, sigil: SigilImmutable), span: mk_sp())
end

let lit_int = fn (n: i64) -> HirExpr do
  return HirExpr(node: Literal(lit: LitInt(val: n)), span: mk_sp())
end

let synth_program = fn () -> HirProgram do
  // body stmts (in order):
  //   stmt0: let y = (x + 1)
  //   stmt1: Expr(If(y == 0, [Return 0], None))
  //   stmt2: Return mul(x: y, y: 2)
  let plus = HirExpr(
    node: BinOp(left: var_expr(name: "x"), op: OpAdd, right: lit_int(n: 1)),
    span: mk_sp()
  )
  let stmt0 = HirStmt(
    node: Let(name: "y", sigil: SigilImmutable, typ: None, value: plus),
    span: mk_sp()
  )

  let eq0 = HirExpr(
    node: BinOp(left: var_expr(name: "y"), op: OpEq, right: lit_int(n: 0)),
    span: mk_sp()
  )
  let ret0 = HirStmt(node: Return(expr: lit_int(n: 0)), span: mk_sp())
  let if_e = HirExpr(node: If(cond: eq0, then_branch: [ ret0 ], else_branch: None), span: mk_sp())
  let stmt1 = HirStmt(node: Expr(expr: if_e), span: mk_sp())

  let call_e = HirExpr(node: Call(func: "mul", args: [
    HirCallArg(label: "x", value: var_expr(name: "y")),
    HirCallArg(label: "y", value: lit_int(n: 2))
  ]), span: mk_sp())
  let stmt2 = HirStmt(node: Return(expr: call_e), span: mk_sp())

  let body = EagerBody(stmts: [ stmt0, stmt1, stmt2 ])
  let f = HirFunction(
    name: "compute",
    type_params: [],
    params: [ HirParam(label: "x", name: "x", sigil: SigilImmutable, typ: TyI64) ],
    ret_type: TyI64,
    throw_row: TyUnit,
    body,
    span: mk_sp(),
    file: "<synth>",
    requires: TyRow(types: [], rest: None)
  )
  return HirProgram(
    caps: [],
    functions: [ f ],
    externals: [],
    handler_bindings: [],
    enum_defs: [],
    exception_groups: [],
    value_binding_names: [],
    type_defs: [],
    visible_enum_names: []
  )
end

// ─── Test: walk through the structured body ────────────────────────────────

let test_structured_body = fn () -> unit throws { Exn } do
  let prog = synth_program()
  let out = ir_dump.hir_to_json(prog)
  let obj = json.parse(s: out)

  let funcs_v = require_field(obj, key: "functions", label: "stj8 root")
  let funcs = expect_array(v: funcs_v, label: "stj8 funcs")
  let f = nth_or_fail(xs: funcs, i: 0, label: "stj8 f0")

  // body envelope
  let body_v = require_field(obj: f, key: "body", label: "stj8 f0")
  let body_kind = expect_string(
    v: require_field(obj: body_v, key: "kind", label: "stj8 body"),
    label: "stj8 body kind"
  )
  test_assert.assert_eq_string(
    actual: body_kind,
    expected: "EagerBody",
    label: "stj8: body.kind = EagerBody"
  )

  let stmts = expect_array(
    v: require_field(obj: body_v, key: "stmts", label: "stj8 body"),
    label: "stj8 stmts"
  )
  test_assert.assert_eq_i64(actual: list.length(xs: stmts), expected: 3, label: "stj8: 3 stmts")

  // stmt0: Let
  let stmt0 = nth_or_fail(xs: stmts, i: 0, label: "stj8 stmt0")
  let s0k = expect_string(
    v: require_field(obj: stmt0, key: "kind", label: "stj8 stmt0"),
    label: "stj8 s0 kind"
  )
  test_assert.assert_eq_string(actual: s0k, expected: "Let", label: "stj8: stmt0 is Let")
  let s0n = expect_string(
    v: require_field(obj: stmt0, key: "name", label: "stj8 stmt0"),
    label: "stj8 s0 name"
  )
  test_assert.assert_eq_string(actual: s0n, expected: "y", label: "stj8: let name = y")
  // child is the BinOp x + 1
  let s0c = expect_array(
    v: require_field(obj: stmt0, key: "children", label: "stj8 stmt0"),
    label: "stj8 s0 children"
  )
  let s0c0 = nth_or_fail(xs: s0c, i: 0, label: "stj8 s0 child")
  let s0c0k = expect_string(
    v: require_field(obj: s0c0, key: "kind", label: "stj8 s0 child"),
    label: "stj8 s0 child kind"
  )
  test_assert.assert_eq_string(actual: s0c0k, expected: "BinOp", label: "stj8: let.value is BinOp")
  let s0c0op = expect_string(
    v: require_field(obj: s0c0, key: "op", label: "stj8 binop"),
    label: "stj8 binop op"
  )
  test_assert.assert_eq_string(actual: s0c0op, expected: "+", label: "stj8: binop op = +")
  // left child is Variable("x"), right child is Literal Int 1
  let bin_children = expect_array(
    v: require_field(obj: s0c0, key: "children", label: "stj8 binop"),
    label: "stj8 binop children"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: bin_children),
    expected: 2,
    label: "stj8: binop has 2 children"
  )
  let left = nth_or_fail(xs: bin_children, i: 0, label: "stj8 binop left")
  let leftk = expect_string(
    v: require_field(obj: left, key: "kind", label: "stj8 binop left"),
    label: "stj8 binop left kind"
  )
  test_assert.assert_eq_string(
    actual: leftk,
    expected: "Variable",
    label: "stj8: binop.left = Variable"
  )
  let leftn = expect_string(
    v: require_field(obj: left, key: "name", label: "stj8 binop left"),
    label: "stj8 binop left name"
  )
  test_assert.assert_eq_string(actual: leftn, expected: "x", label: "stj8: var-ref name = x")
  let right = nth_or_fail(xs: bin_children, i: 1, label: "stj8 binop right")
  let rightk = expect_string(
    v: require_field(obj: right, key: "kind", label: "stj8 binop right"),
    label: "stj8 binop right kind"
  )
  test_assert.assert_eq_string(
    actual: rightk,
    expected: "Literal",
    label: "stj8: binop.right = Literal"
  )
  let right_lit_kind = expect_string(
    v: require_field(obj: right, key: "lit_kind", label: "stj8 binop right"),
    label: "stj8 right lit_kind"
  )
  test_assert.assert_eq_string(
    actual: right_lit_kind,
    expected: "Int",
    label: "stj8: lit_kind = Int"
  )
  match require_field(obj: right, key: "value", label: "stj8 binop right") do
    | JsonInt(val: n) -> test_assert.assert_eq_i64(
      actual: n,
      expected: 1,
      label: "stj8: literal value = 1"
    )
    | _ -> throw RuntimeError(val: "stj8: expected JsonInt literal")
  end

  // stmt1: Expr(If ...)
  let stmt1 = nth_or_fail(xs: stmts, i: 1, label: "stj8 stmt1")
  let s1k = expect_string(
    v: require_field(obj: stmt1, key: "kind", label: "stj8 stmt1"),
    label: "stj8 s1 kind"
  )
  test_assert.assert_eq_string(actual: s1k, expected: "Expr", label: "stj8: stmt1 is Expr")
  let s1c = expect_array(
    v: require_field(obj: stmt1, key: "children", label: "stj8 stmt1"),
    label: "stj8 s1 children"
  )
  let if_node = nth_or_fail(xs: s1c, i: 0, label: "stj8 s1 child")
  let ifk = expect_string(
    v: require_field(obj: if_node, key: "kind", label: "stj8 if"),
    label: "stj8 if kind"
  )
  test_assert.assert_eq_string(actual: ifk, expected: "If", label: "stj8: child kind = If")
  // If carries cond as the single member of `children`, plus then_branch flat field
  let if_children = expect_array(
    v: require_field(obj: if_node, key: "children", label: "stj8 if"),
    label: "stj8 if children"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: if_children),
    expected: 1,
    label: "stj8: If has 1 cond child"
  )
  let then_v = require_field(obj: if_node, key: "then_branch", label: "stj8 if")
  let then_stmts = expect_array(v: then_v, label: "stj8 if then")
  test_assert.assert_eq_i64(
    actual: list.length(xs: then_stmts),
    expected: 1,
    label: "stj8: then branch has 1 stmt"
  )

  // stmt2: Return mul(x: y, y: 2)
  let stmt2 = nth_or_fail(xs: stmts, i: 2, label: "stj8 stmt2")
  let s2k = expect_string(
    v: require_field(obj: stmt2, key: "kind", label: "stj8 stmt2"),
    label: "stj8 s2 kind"
  )
  test_assert.assert_eq_string(actual: s2k, expected: "Return", label: "stj8: stmt2 is Return")
  let s2c = expect_array(
    v: require_field(obj: stmt2, key: "children", label: "stj8 stmt2"),
    label: "stj8 s2 children"
  )
  let call_n = nth_or_fail(xs: s2c, i: 0, label: "stj8 s2 child")
  let callk = expect_string(
    v: require_field(obj: call_n, key: "kind", label: "stj8 call"),
    label: "stj8 call kind"
  )
  test_assert.assert_eq_string(actual: callk, expected: "Call", label: "stj8: child kind = Call")
  let callf = expect_string(
    v: require_field(obj: call_n, key: "func", label: "stj8 call"),
    label: "stj8 call func"
  )
  test_assert.assert_eq_string(actual: callf, expected: "mul", label: "stj8: call func = mul")
  let call_args = expect_array(
    v: require_field(obj: call_n, key: "args", label: "stj8 call"),
    label: "stj8 call args"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: call_args),
    expected: 2,
    label: "stj8: call has 2 args"
  )
  let arg0 = nth_or_fail(xs: call_args, i: 0, label: "stj8 arg0")
  let arg0_label = expect_string(
    v: require_field(obj: arg0, key: "label", label: "stj8 arg0"),
    label: "stj8 arg0 label"
  )
  test_assert.assert_eq_string(actual: arg0_label, expected: "x", label: "stj8: arg0 label = x")
  let arg0_v = require_field(obj: arg0, key: "value", label: "stj8 arg0")
  let arg0_vk = expect_string(
    v: require_field(obj: arg0_v, key: "kind", label: "stj8 arg0 value"),
    label: "stj8 arg0 value kind"
  )
  test_assert.assert_eq_string(
    actual: arg0_vk,
    expected: "Variable",
    label: "stj8: arg0 value = Variable"
  )
  return ()
end

// ─── Test: match expression structure ──────────────────────────────────────
//
// Match coverage is awkward (HIR match takes a target expr + cases),
// so we synthesise a small `match x do | 0 -> return 0 | _ -> return 1 end`
// in its own one-stmt function.

let synth_match_program = fn () -> HirProgram do
  let target = var_expr(name: "x")
  let ret0 = HirStmt(node: Return(expr: lit_int(n: 0)), span: mk_sp())
  let ret1 = HirStmt(node: Return(expr: lit_int(n: 1)), span: mk_sp())
  let case0 = HirMatchCase(pattern: PLit(lit: LitInt(val: 0)), body: [ ret0 ])
  let case_w = HirMatchCase(pattern: PWild, body: [ ret1 ])
  let m_expr = HirExpr(node: Match(target, cases: [ case0, case_w ]), span: mk_sp())
  let stmt = HirStmt(node: Expr(expr: m_expr), span: mk_sp())
  let m_body = EagerBody(stmts: [ stmt ])
  let f = HirFunction(
    name: "tag",
    type_params: [],
    params: [ HirParam(label: "x", name: "x", sigil: SigilImmutable, typ: TyI64) ],
    ret_type: TyI64,
    throw_row: TyUnit,
    body: m_body,
    span: mk_sp(),
    file: "<synth>",
    requires: TyRow(types: [], rest: None)
  )
  return HirProgram(
    caps: [],
    functions: [ f ],
    externals: [],
    handler_bindings: [],
    enum_defs: [],
    exception_groups: [],
    value_binding_names: [],
    type_defs: [],
    visible_enum_names: []
  )
end

let test_match_structure = fn () -> unit throws { Exn } do
  let prog = synth_match_program()
  let out = ir_dump.hir_to_json(prog)
  let obj = json.parse(s: out)
  let funcs = expect_array(
    v: require_field(obj, key: "functions", label: "stj8 match root"),
    label: "stj8 match funcs"
  )
  let f = nth_or_fail(xs: funcs, i: 0, label: "stj8 match f0")
  let body_v = require_field(obj: f, key: "body", label: "stj8 match f0")
  let stmts = expect_array(
    v: require_field(obj: body_v, key: "stmts", label: "stj8 match body"),
    label: "stj8 match stmts"
  )
  let s0 = nth_or_fail(xs: stmts, i: 0, label: "stj8 match s0")
  let s0c = expect_array(
    v: require_field(obj: s0, key: "children", label: "stj8 match s0"),
    label: "stj8 match s0 children"
  )
  let m = nth_or_fail(xs: s0c, i: 0, label: "stj8 match expr")
  let mk = expect_string(
    v: require_field(obj: m, key: "kind", label: "stj8 match expr"),
    label: "stj8 match kind"
  )
  test_assert.assert_eq_string(actual: mk, expected: "Match", label: "stj8: child is Match")
  // children: [target]
  let m_children = expect_array(
    v: require_field(obj: m, key: "children", label: "stj8 match"),
    label: "stj8 match children"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: m_children),
    expected: 1,
    label: "stj8: match has 1 target child"
  )
  let cases = expect_array(
    v: require_field(obj: m, key: "cases", label: "stj8 match"),
    label: "stj8 match cases"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: cases),
    expected: 2,
    label: "stj8: 2 match cases"
  )
  let c0 = nth_or_fail(xs: cases, i: 0, label: "stj8 c0")
  let p0 = require_field(obj: c0, key: "pattern", label: "stj8 c0")
  let p0k = expect_string(
    v: require_field(obj: p0, key: "kind", label: "stj8 c0 pat"),
    label: "stj8 p0 kind"
  )
  test_assert.assert_eq_string(actual: p0k, expected: "PLit", label: "stj8: case0 is PLit")
  let c1 = nth_or_fail(xs: cases, i: 1, label: "stj8 c1")
  let p1 = require_field(obj: c1, key: "pattern", label: "stj8 c1")
  let p1k = expect_string(
    v: require_field(obj: p1, key: "kind", label: "stj8 c1 pat"),
    label: "stj8 p1 kind"
  )
  test_assert.assert_eq_string(actual: p1k, expected: "PWild", label: "stj8: case1 is PWild")
  return ()
end

let main = fn () -> unit throws { Exn } do
  test_structured_body()
  test_match_structure()
  return ()
end
