// Regression: nexus-2cb5 — `throw` is an accepted synonym for `raise`.
//
// Pre-fix: `throw e` parsed as a discarded expression statement
// (`throw` lexed as an identifier in call position, followed by an
// argument expression that became a discarded value), silently no-op'ing
// what the user clearly intended as an exception escape. Programmers
// coming from Java / JS / C++ / Python expect `throw` to do the same job
// as Nexus's `raise`.
//
// Post-fix: `throw` is mapped to TkRaise at the lexer level, so the parser
// sees the same token it would for `raise` and runs parse_raise_expr.
// Behavior is identical to `raise`.
//
// This fixture exercises both forms — they must be observationally
// indistinguishable. Pre-fix, `thrower_throw` would fall through to
// `return 0` (returning 0 to the caller's try), and the assertion would
// see 0 instead of 7.
import * as test_assert from "std:test/assert"

exception Boom(code: i64)

// Uses `throw` instead of `raise`. Pre-fix this compiled silently and
// fell through to `return 0`, so the catcher would observe 0 (not 7).
let thrower_throw = fn () -> i64 throws { Exn } do
  throw Boom(code: 7)
end

// Uses `raise` — the baseline form, must keep working.
let thrower_raise = fn () -> i64 throws { Exn } do
  raise Boom(code: 7)
end

let catch_throw = fn () -> i64 throws { Exn } do
  try
    let _ = thrower_throw()
    return -1
  catch
    | Boom(code: c) -> return c
    | _ -> return -2
  end
  return -3
end

let catch_raise = fn () -> i64 throws { Exn } do
  try
    let _ = thrower_raise()
    return -1
  catch
    | Boom(code: c) -> return c
    | _ -> return -2
  end
  return -3
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: catch_throw(), expected: 7, label: "`throw` raises (synonym for `raise`)")
  test_assert.assert_eq_i64(actual: catch_raise(), expected: 7, label: "`raise` still works (baseline)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
