// Regression for nexus-m2wy: when an `fn(T) -> bool` closure is stored in
// a record field and invoked via `call_indirect`, codegen used to allocate
// an `i32` local to receive the result (because `type_to_valtype(TyBool) =
// vt_i32`), while the function-table signature always returns `i64`. The
// wasm validator then rejected the local.set/binop as a type mismatch.
//
// Direct calls to `fn(T) -> bool` work fine because they coerce/widen
// inline. Only the call_indirect path was wrong, and only when the result
// flowed into a `let` binding of statically-`bool` type.
import * as test_assert from "std:test/assert"

type Predicate = Predicate(run: (x: i64) -> bool)

let single_call = fn () -> unit throws { Exn } do
  let p = Predicate(run: fn (x: i64) -> bool do return x > 0 end)
  let Predicate(run: pred) = p
  let pos = pred(x: 5)
  test_assert.assert_eq_bool(actual: pos, expected: true, label: "Predicate.run(5)")
  let neg = pred(x: 0 - 1)
  test_assert.assert_eq_bool(actual: neg, expected: false, label: "Predicate.run(-1)")
  return ()
end

let sequenced_calls = fn () -> unit throws { Exn } do
  // Stack hygiene: multiple indirect calls chained via && / || / if.
  let p = Predicate(run: fn (x: i64) -> bool do return x > 0 end)
  let Predicate(run: pred) = p
  let both_pos = pred(x: 5) && pred(x: 7)
  test_assert.assert_eq_bool(actual: both_pos, expected: true, label: "r(5) && r(7)")
  let either = pred(x: 5) || pred(x: 0 - 3)
  test_assert.assert_eq_bool(actual: either, expected: true, label: "r(5) || r(-3)")
  let neither = pred(x: 0) && pred(x: 0 - 1)
  test_assert.assert_eq_bool(actual: neither, expected: false, label: "r(0) && r(-1)")
  return ()
end

let apply_pred = fn (p: Predicate, x: i64) -> bool do
  let Predicate(run: pred) = p
  return pred(x: x)
end

let generic_context = fn () -> unit throws { Exn } do
  // Calling Predicate.run from a separate helper must not re-introduce
  // the mismatch — the function-table signature stays (i64,i64) -> i64.
  let p = Predicate(run: fn (x: i64) -> bool do return x >= 100 end)
  let big = apply_pred(p: p, x: 200)
  test_assert.assert_eq_bool(actual: big, expected: true, label: "apply_pred big")
  let small = apply_pred(p: p, x: 1)
  test_assert.assert_eq_bool(actual: small, expected: false, label: "apply_pred small")
  return ()
end

let main = fn () -> unit throws { Exn } do
  single_call()
  sequenced_calls()
  generic_context()
  return ()
end
