// Port of bootstrap/tests/runtime/wasm_eh.rs::wasm_eh_throw_catch_roundtrip,
// wasm_eh_catch_all (language-level analogues).
//
// The original Rust tests build raw WASM modules via wasm_encoder and call
// wasmtime APIs directly to verify the WASM Exception-Handling proposal is
// supported by wasmtime. The language-level equivalent — that Nexus's
// `raise` / `try ... catch` lowers to those same `throw` / `try_table`
// instructions and round-trips an i64 payload — is what we exercise here.
import * as test_assert from "std:test/assert"

exception WasmEhPayload(val: i64)

// Throw and catch in the same function; verify the i64 payload is preserved
// (mirrors build_throw_catch_module — payload 42).
let throw_catch_roundtrip = fn () -> i64 throws { Exn } do
  try
    raise WasmEhPayload(val: 42)
    return -1
  catch
    | WasmEhPayload(val: v) -> return v
    | _ -> return -2
  end
  return -3
end

// catch _ wildcard (mirrors build_catch_all_module): catch_all delivers no
// payload — the body just needs to survive without trapping.
let catch_all = fn () -> i64 throws { Exn } do
  try
    raise WasmEhPayload(val: 77)
    return -1
  catch _ ->
    return 1
  end
  return -2
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: throw_catch_roundtrip(), expected: 42, label: "throw/catch roundtrip i64 payload")
  test_assert.assert_eq_i64(actual: catch_all(), expected: 1, label: "catch _ survives")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
