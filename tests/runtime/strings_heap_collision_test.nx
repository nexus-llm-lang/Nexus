// Port of bootstrap/tests/runtime/strings.rs:
//   diag_heap_g0_g2_collision_corrupts_constructor_tag,
//   diag_heap_g0_g2_collision_all_non_nullary,
//   diag_heap_g0_g2_collision_large_string.
//
// Original used `s64` for field types (a relic the integration harness's
// parser-only path tolerated); we use `i64` since the type-checker requires it.
// Semantics — string concat must not overwrite constructor tags/fields — are
// preserved.
import * as test_assert from "std:test/assert"

type Val = Present(v: i64) | Absent
type Thing = Alpha(x: i64) | Beta(x: i64) | Gamma(x: i64)
type Wrap = Wrap(a: i64, b: i64, c: i64)

let use_string = fn (s: string, label: string) -> unit throws { Exn } do
  test_assert.assert_false(cond: s == "", label: label)
  return ()
end

let val_v = fn (v: Val) -> i64 throws { Exn } do
  match v do
    | Present(v: x) -> return x
    | Absent -> raise AssertionFailed(msg: "tag flipped to Absent")
  end
end

let thing_x = fn (t: Thing) -> i64 throws { Exn } do
  match t do
    | Alpha(x: x) -> return x
    | Beta(x: _) -> raise AssertionFailed(msg: "tag became Beta")
    | Gamma(x: _) -> raise AssertionFailed(msg: "tag became Gamma")
  end
end

let build_long = fn (s: string, n: i64) -> string do
  if n <= 0 then return s end
  return build_long(s: s ++ "x", n: n - 1)
end

let body = fn () -> unit throws { Exn } do
  // 2-variant: nullary + non-nullary; original uses Present(v: 42).
  let x = Present(v: 42)
  let s = "aa" ++ "bb"
  use_string(s: s, label: "string is non-empty")
  test_assert.assert_eq_i64(actual: val_v(v: x), expected: 42, label: "Present.v not corrupted")
  // All-non-nullary, forces tag matching.
  let t = Alpha(x: 42)
  let s2 = "aaaa" ++ "bbbb"
  use_string(s: s2, label: "string2 non-empty")
  test_assert.assert_eq_i64(actual: thing_x(t: t), expected: 42, label: "Alpha.x not corrupted")
  // Large string concat (100 bytes appended) over a 3-field constructor.
  let w = Wrap(a: 11, b: 22, c: 33)
  let _big = build_long(s: "", n: 100)
  let wa = match w do | Wrap(a: a, b: _, c: _) -> a end
  let wb = match w do | Wrap(a: _, b: b, c: _) -> b end
  let wc = match w do | Wrap(a: _, b: _, c: c) -> c end
  test_assert.assert_eq_i64(actual: wa, expected: 11, label: "Wrap.a after large concat")
  test_assert.assert_eq_i64(actual: wb, expected: 22, label: "Wrap.b after large concat")
  test_assert.assert_eq_i64(actual: wc, expected: 33, label: "Wrap.c after large concat")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
