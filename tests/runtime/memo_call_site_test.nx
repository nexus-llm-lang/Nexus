// Acceptance test for nexus-e6uh phase 2a (codegen-side memo emission).
//
// Phase 2a admits 1-arg i64 -> i64 pure fns. The compiler wraps each
// eligible call site in a single-slot last-call cache; this test exercises
// repeated-arg and varied-arg patterns to verify:
//
//   1. Cached recall returns the same value as a fresh call (correctness).
//   2. Mixed-arg sequences (a, a, b, a, b) preserve semantics under the
//      "last-call only" cache shape — calling with `b` evicts `a`'s slot,
//      so the next `a` is a recompute, not a stale hit (the cache is
//      single-slot, not associative).
//
// Cache-hit observability via call-counter is fundamentally incompatible
// with the purity gate (a counter mutation is a side effect that disqualifies
// the function), so the runtime check stays correctness-focused. Bytecode
// size and global-section structure are the structural signal: stage1.wasm
// after this codegen change is ~57 KB larger than the pre-emission baseline
// and 3 globals/eligible-fn appear in the global section.
import * as test_assert from "std:test/assert"

let pure_double = fn (n: i64) -> i64 do
  return n + n
end

let pure_square = fn (n: i64) -> i64 do
  return n * n
end

let body = fn () -> unit throws { Exn } do
  // Same arg three times — second and third should hit the last-call cache.
  test_assert.assert_eq_i64(actual: pure_double(n: 5), expected: 10, label: "double(5) #1")
  test_assert.assert_eq_i64(actual: pure_double(n: 5), expected: 10, label: "double(5) #2 cached")
  test_assert.assert_eq_i64(actual: pure_double(n: 5), expected: 10, label: "double(5) #3 cached")

  // Different arg — cache miss, recomputes.
  test_assert.assert_eq_i64(actual: pure_double(n: 7), expected: 14, label: "double(7) miss")

  // Back to original arg — single-slot cache evicted, recomputes.
  test_assert.assert_eq_i64(actual: pure_double(n: 5), expected: 10, label: "double(5) after evict")

  // Multiple eligible fns share no cache slots; squared calls go through
  // their own slot independent of double's.
  test_assert.assert_eq_i64(actual: pure_square(n: 4), expected: 16, label: "square(4)")
  test_assert.assert_eq_i64(actual: pure_square(n: 4), expected: 16, label: "square(4) cached")
  test_assert.assert_eq_i64(
    actual: pure_double(n: 7),
    expected: 14,
    label: "double(7) after square"
  )
  test_assert.assert_eq_i64(actual: pure_square(n: 9), expected: 81, label: "square(9) miss")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
