// Port of bootstrap/tests/runtime/control_flow.rs::codegen_bool_return_is_i32_flag
// and the `if_else_expr_*` tests. Covers basic if/else as both statement and
// expression.
import * as test_assert from "std:test/assert"

let pick = fn (flag: bool, a: i64, b: i64) -> i64 do
  return if flag then a else b end
end

let greet = fn (formal: bool) -> string do
  return if formal then "Good day" else "Hey"  end
end

let classify_nested = fn (x: i64) -> i64 do
  return if x > 0 then
      if x > 100 then 2 else 1 end
  else 0 end
end

let body = fn () -> unit throws { Exn } do
  // bool_return_is_i32_flag: 10 < 11 is true.
  test_assert.assert_true(cond: 10 < 11, label: "10 < 11")
  // if_else_expr_returns_then_branch_value
  let a = if true then 42 else 0 end
  test_assert.assert_eq_i64(actual: a, expected: 42, label: "if true -> 42")
  // if_else_expr_returns_else_branch_value
  let b = if false then 42 else 99 end
  test_assert.assert_eq_i64(actual: b, expected: 99, label: "if false -> 99")
  // if_else_expr_with_condition_variable
  test_assert.assert_eq_i64(actual: pick(flag: true, a: 10, b: 20), expected: 10, label: "pick true")
  test_assert.assert_eq_i64(actual: pick(flag: false, a: 10, b: 20), expected: 20, label: "pick false")
  // if_else_expr_with_string_type
  test_assert.assert_eq_string(actual: greet(formal: true), expected: "Good day", label: "formal greet")
  // if_else_expr_nested
  test_assert.assert_eq_i64(actual: classify_nested(x: 200), expected: 2, label: "classify 200")
  test_assert.assert_eq_i64(actual: classify_nested(x: 50), expected: 1, label: "classify 50")
  test_assert.assert_eq_i64(actual: classify_nested(x: -5), expected: 0, label: "classify -5")
  // if_else_expr_in_let_binding
  let aa = 10
  let bb = 20
  let max_val = if aa > bb then aa else bb end
  test_assert.assert_eq_i64(actual: max_val, expected: 20, label: "max(10, 20)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
