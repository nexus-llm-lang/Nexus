// Port of bootstrap/tests/runtime/control_flow.rs::codegen_if_expr_returning_list_inside_nested_match.
// Original used `[string]` with a sentinel; we keep that semantic while using
// the modern list literal syntax.
import * as test_assert from "std:test/assert"

type Wrapper = Wrapper(name: string)
type Outer = OuterA(inner: Wrapper) | OuterB

let classify = fn (x: Outer, flag: bool) -> [string] do
  let result = match x do
    | OuterA(inner: w) ->
      match w do | Wrapper(name: n) ->
        if flag then n :: [] else [] end
      end
    | OuterB -> []
  end
  return result
end

let head_or_empty = fn (xs: [string]) -> string do
  match xs do
    | [] -> return ""
    | s :: _ -> return s
  end
end

let len = fn (xs: [string]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + len(xs: rest)
  end
end

let body = fn () -> unit throws { Exn } do
  let r1 = classify(x: OuterA(inner: Wrapper(name: "hello")), flag: true)
  test_assert.assert_eq_i64(actual: len(xs: r1), expected: 1, label: "true => singleton")
  test_assert.assert_eq_string(actual: head_or_empty(xs: r1), expected: "hello", label: "true head")
  let r2 = classify(x: OuterA(inner: Wrapper(name: "hello")), flag: false)
  test_assert.assert_eq_i64(actual: len(xs: r2), expected: 0, label: "false => empty")
  let r3 = classify(x: OuterB, flag: true)
  test_assert.assert_eq_i64(actual: len(xs: r3), expected: 0, label: "OuterB => empty")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
