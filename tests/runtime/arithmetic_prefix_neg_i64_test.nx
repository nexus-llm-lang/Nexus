// Port of bootstrap/tests/runtime/arithmetic.rs::codegen_prefix_unary_neg_i64.
// Covers all spec acceptance shapes for unary `-`: literal, var, paren, call,
// and precedence vs `*`.
import * as test_assert from "std:test/assert"

let one = fn () -> i64 do return 1 end

let body = fn () -> unit throws { Exn } do
  let lit = -1
  test_assert.assert_eq_i64(actual: lit, expected: 0 - 1, label: "-1 literal")

  let y = 5
  test_assert.assert_eq_i64(actual: -y, expected: 0 - 5, label: "-y where y=5")

  let z = -(y + 2)
  test_assert.assert_eq_i64(actual: z, expected: 0 - 7, label: "-(y + 2)")

  let c = -one()
  test_assert.assert_eq_i64(actual: c, expected: 0 - 1, label: "-one()")

  // Precedence: -y * 2 must parse as (-y) * 2.
  let prec = -y * 2
  test_assert.assert_eq_i64(actual: prec, expected: 0 - 10, label: "-y * 2 precedence")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
