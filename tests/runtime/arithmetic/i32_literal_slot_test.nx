// Regression: nexus-qjejm facet 3 -- an integer literal flowing into an
// i32-expecting consumer must be narrowed, not emitted as i64.const.
//
// Integer literals are typed TyI64 in LIR (atom_type(LirAtomInt) = TyI64), so
// emit_atom emits `i64.const`. The cast.i64_of intrinsic (declared (x: i32))
// lowers to `i64.extend_i32_u`, which expects an i32 on the stack. Before the
// fix the intrinsic emitter pushed the atom raw with no coercion, so a literal
// argument left an i64 under `i64.extend_i32_u` ("expected i32, found i64") --
// `./nexus build` reported success but the wasm validator rejected it.
//
// The fix coerces the cast intrinsic's argument to the width its opcode
// expects (emit_coercion narrows a literal via i32.wrap_i64; an i32 variable
// already narrow on the stack coerces as a no-op).
import * as test_assert from "std:test/assert"
import * as cast from "std:runtime/cast"

let body = fn () -> unit throws { Exn } do
  // Literal directly into the i32 parameter slot of cast.i64_of.
  let w: i64 = cast.i64_of(x: 7)
  test_assert.assert_eq_i64(actual: w, expected: 7, label: "i32 literal 7 -> i64")

  // Larger literal that still fits in i32.
  let big: i64 = cast.i64_of(x: 1000000)
  test_assert.assert_eq_i64(actual: big, expected: 1000000, label: "i32 literal 1000000 -> i64")

  // Round-trip through i32_of must still hold (i32_of arg is i64; the literal
  // stays i64 and i32.wrap_i64 consumes it).
  let rt: i64 = cast.i64_of(x: cast.i32_of(x: 255))
  test_assert.assert_eq_i64(actual: rt, expected: 255, label: "i64 255 -> i32 -> i64 round-trip")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
