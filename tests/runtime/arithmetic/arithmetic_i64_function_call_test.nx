// Port of bootstrap/tests/runtime/arithmetic.rs::codegen_i64_function_call_works.
// Verifies a user-defined i64 -> i64 -> i64 function returns the expected sum.
import * as test_assert from "std:test/assert"

let add = fn (x: i64, y: i64) -> i64 do
  return x + y
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: add(x: 40, y: 2), expected: 42, label: "add(40, 2)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
