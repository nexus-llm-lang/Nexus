// Regression test for nexus-ka748: INT_MIN % -1 must build and evaluate to 0.
//
// Before the fix, the const-folder in src/ir/lir/opt/folding.nx evaluated
// `a / b` at compile time for OpMod without guarding the INT_MIN / -1
// signed-overflow edge. Because the compiler runs as wasm, i64.div_s trapped,
// aborting compilation with exit 134 (wasm unreachable / integer overflow).
//
// After the fix, the folder returns None for INT_MIN % -1, deferring to the
// wasm runtime where i64.rem_s handles the case correctly and yields 0.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  // i64::MIN expressed without the out-of-range literal 9223372036854775808.
  let i64_min: i64 = 0 - 9223372036854775807 - 1
  // INT_MIN % -1: the const-folder must bail out (return None).
  // At runtime, wasm i64.rem_s returns 0 — it does NOT trap on this input.
  let r: i64 = i64_min % (0 - 1)
  test_assert.assert_eq_i64(actual: r, expected: 0, label: "INT_MIN % -1 == 0")

  // Sanity: INT_MIN / 2 still folds (no overflow on this path).
  let q: i64 = i64_min / 2
  test_assert.assert_eq_i64(
    actual: q,
    expected: -4611686018427387904,
    label: "INT_MIN / 2 == -4611686018427387904"
  )

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
