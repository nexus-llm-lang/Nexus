// Regression: nexus-vmbtk -- a simple top-level fn returning the result of
// an f-prefixed binop on f32 operands must produce wasm that validates and
// runs. Before the fix, infer_binary_type in src/ir/lir/semantic_types.nx
// hardcoded OpF{Add,Sub,Mul,Div} -> TyF64 regardless of operand types, so
// the temp local holding `a *. b` was declared f64 in wasm. The binop
// itself emitted f32.mul (codegen/emit/binop.nx dispatches on operand
// valtype), so `local.set` of an f32 stack value into an f64 local failed
// wasm validation ("expected f64, found f32") at the function tail.
//
// The fix mirrors binary_operand_type's logic: only return TyF32 when
// BOTH operands are TyF32; otherwise default to TyF64 (covers mixed and
// i64-erased cases). This keeps the LirExprBinary's typ field in sync
// with the value the emitted opcode actually produces.
//
// Exercises all four f-prefixed arith ops through build + validate + run
// so the family stops recurring. The f64 path stays unchanged.
import * as test_assert from "std:test/assert"

let f32_mul = fn (a: f32, b: f32) -> f32 do
  return a *. b
end

let f32_add = fn (a: f32, b: f32) -> f32 do
  return a +. b
end

let f32_sub = fn (a: f32, b: f32) -> f32 do
  return a -. b
end

let f32_div = fn (a: f32, b: f32) -> f32 do
  return a /. b
end

let f64_mul = fn (a: f64, b: f64) -> f64 do
  return a *. b
end

let body = fn () -> unit throws { Exn } do
  let m: f32 = f32_mul(a: 1.5, b: 2.0)
  test_assert.assert_eq_bool(actual: m ==. 3.0, expected: true, label: "f32 1.5 *. 2.0 = 3.0")

  let s: f32 = f32_add(a: 1.5, b: 2.5)
  test_assert.assert_eq_bool(actual: s ==. 4.0, expected: true, label: "f32 1.5 +. 2.5 = 4.0")

  let d: f32 = f32_sub(a: 5.0, b: 2.0)
  test_assert.assert_eq_bool(actual: d ==. 3.0, expected: true, label: "f32 5.0 -. 2.0 = 3.0")

  let q: f32 = f32_div(a: 6.0, b: 2.0)
  test_assert.assert_eq_bool(actual: q ==. 3.0, expected: true, label: "f32 6.0 /. 2.0 = 3.0")

  // f64 path must remain correct alongside the f32 fix.
  let m64: f64 = f64_mul(a: 2.0, b: 3.0)
  test_assert.assert_eq_bool(actual: m64 ==. 6.0, expected: true, label: "f64 2.0 *. 3.0 = 6.0")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
