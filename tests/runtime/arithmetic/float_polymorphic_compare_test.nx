// Regression: polymorphic comparison operators (== != < <= > >=) on f64/f32
// operands must emit the float compare opcode, not the i64/i32 one. Before the
// fix emit_binary's OpEq..OpGe arms dispatched only on use_i32 and emitted
// i64.lt_s/etc. against float stack values, producing invalid wasm
// ("type mismatch: expected i64, found f64") even though the program typechecks.
//
// The float-specific `==.`/`<.` family was always fine; only the generic
// comparators on float operands miscompiled. This test exercises all six on
// both f64 and f32 through build + validate + run so the family stops
// recurring (no f64/f32-field type previously existed in the tree to cover it).
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let a: f64 = 1.0
  let b: f64 = 2.0
  // All six comparators on f64 operands.
  test_assert.assert_eq_bool(actual: a < b, expected: true, label: "f64 1.0 < 2.0")
  test_assert.assert_eq_bool(actual: b < a, expected: false, label: "f64 2.0 < 1.0")
  test_assert.assert_eq_bool(actual: a <= a, expected: true, label: "f64 1.0 <= 1.0")
  test_assert.assert_eq_bool(actual: b <= a, expected: false, label: "f64 2.0 <= 1.0")
  test_assert.assert_eq_bool(actual: b > a, expected: true, label: "f64 2.0 > 1.0")
  test_assert.assert_eq_bool(actual: a > b, expected: false, label: "f64 1.0 > 2.0")
  test_assert.assert_eq_bool(actual: b >= b, expected: true, label: "f64 2.0 >= 2.0")
  test_assert.assert_eq_bool(actual: a >= b, expected: false, label: "f64 1.0 >= 2.0")
  test_assert.assert_eq_bool(actual: a == a, expected: true, label: "f64 1.0 == 1.0")
  test_assert.assert_eq_bool(actual: a == b, expected: false, label: "f64 1.0 == 2.0")
  test_assert.assert_eq_bool(actual: a != b, expected: true, label: "f64 1.0 != 2.0")
  test_assert.assert_eq_bool(actual: a != a, expected: false, label: "f64 1.0 != 1.0")

  let c: f32 = 1.5
  let d: f32 = 2.5
  // All six comparators on f32 operands.
  test_assert.assert_eq_bool(actual: c < d, expected: true, label: "f32 1.5 < 2.5")
  test_assert.assert_eq_bool(actual: d < c, expected: false, label: "f32 2.5 < 1.5")
  test_assert.assert_eq_bool(actual: c <= c, expected: true, label: "f32 1.5 <= 1.5")
  test_assert.assert_eq_bool(actual: d <= c, expected: false, label: "f32 2.5 <= 1.5")
  test_assert.assert_eq_bool(actual: d > c, expected: true, label: "f32 2.5 > 1.5")
  test_assert.assert_eq_bool(actual: c > d, expected: false, label: "f32 1.5 > 2.5")
  test_assert.assert_eq_bool(actual: d >= d, expected: true, label: "f32 2.5 >= 2.5")
  test_assert.assert_eq_bool(actual: c >= d, expected: false, label: "f32 1.5 >= 2.5")
  test_assert.assert_eq_bool(actual: c == c, expected: true, label: "f32 1.5 == 1.5")
  test_assert.assert_eq_bool(actual: c == d, expected: false, label: "f32 1.5 == 2.5")
  test_assert.assert_eq_bool(actual: c != d, expected: true, label: "f32 1.5 != 2.5")
  test_assert.assert_eq_bool(actual: c != c, expected: false, label: "f32 1.5 != 1.5")

  // Sanity: the float-specific family must remain correct alongside the fix.
  test_assert.assert_eq_bool(actual: a <. b, expected: true, label: "f64 1.0 <. 2.0")
  test_assert.assert_eq_bool(actual: a ==. a, expected: true, label: "f64 1.0 ==. 1.0")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
