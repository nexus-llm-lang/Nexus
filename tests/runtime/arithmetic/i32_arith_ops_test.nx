// Regression: nexus-qjejm facets 1 & 2 -- bare i32 arithmetic must produce
// wasm that validates and runs. i32 is a first-class value type, but before
// the fix narrow-type arithmetic miscompiled to INVALID wasm (`./nexus build`
// reported success, wasmtime's validator rejected the module):
//
//   * `+ - * /` with an i32 operand and an integer LITERAL widened the result
//     to i64 (literals are typed TyI64 in LIR; binary_operand_type in
//     codegen/emit/binop.nx widened mixed i32/i64 to i64, so an i64 value
//     leaked into the declared-i32 result slot / downstream i32 consumer).
//   * `/ % << >>` emitted the i64 opcode UNCONDITIONALLY (emit_binary had no
//     use_i32 branch for these four, unlike + - * & | ^), so on concrete i32
//     operands an i64 opcode ran over i32 stack values -> validator reject.
//
// The fix makes binary_operand_type / infer_binary_type prefer the i32 type
// when one operand is i32 (the typechecker rejects genuine i32+i64 variable
// mixing, so the i64 side is always a literal that adopts the i32 width), and
// adds the i32 opcode branch to OpDiv/OpMod/OpShl/OpShr.
//
// Each i32 result is widened back to i64 via cast.i64_of so it can be asserted
// with assert_eq_i64. The i64 path stays unchanged (covered elsewhere).
import * as test_assert from "std:test/assert"
import * as cast from "std:runtime/cast"

// All operands are i32; the literal `1` / `2` on the RHS exercises the
// literal-width narrowing. The result is i32 throughout.
let i32_add = fn (x: i32, y: i32) -> i32 do return x + y end
let i32_sub = fn (x: i32, y: i32) -> i32 do return x - y end
let i32_mul = fn (x: i32, y: i32) -> i32 do return x * y end
let i32_div = fn (x: i32, y: i32) -> i32 do return x / y end
let i32_mod = fn (x: i32, y: i32) -> i32 do return x % y end
let i32_shl = fn (x: i32, y: i32) -> i32 do return x << y end
let i32_shr = fn (x: i32, y: i32) -> i32 do return x >> y end

// Literal mixed directly with an i32 variable inside the body.
let i32_add_lit = fn (x: i32) -> i32 do return x + 7 end
let i32_div_lit = fn (x: i32) -> i32 do return x / 3 end

let w = fn (v: i32) -> i64 do return cast.i64_of(x: v) end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(
    actual: w(v: i32_add(x: 40, y: 2)),
    expected: 42,
    label: "i32 40 + 2 = 42"
  )
  test_assert.assert_eq_i64(
    actual: w(v: i32_sub(x: 40, y: 2)),
    expected: 38,
    label: "i32 40 - 2 = 38"
  )
  test_assert.assert_eq_i64(
    actual: w(v: i32_mul(x: 6, y: 7)),
    expected: 42,
    label: "i32 6 * 7 = 42"
  )
  test_assert.assert_eq_i64(actual: w(v: i32_div(x: 7, y: 2)), expected: 3, label: "i32 7 / 2 = 3")
  test_assert.assert_eq_i64(actual: w(v: i32_mod(x: 7, y: 2)), expected: 1, label: "i32 7 % 2 = 1")
  test_assert.assert_eq_i64(
    actual: w(v: i32_shl(x: 1, y: 4)),
    expected: 16,
    label: "i32 1 << 4 = 16"
  )
  test_assert.assert_eq_i64(
    actual: w(v: i32_shr(x: 64, y: 2)),
    expected: 16,
    label: "i32 64 >> 2 = 16"
  )
  test_assert.assert_eq_i64(
    actual: w(v: i32_add_lit(x: 10)),
    expected: 17,
    label: "i32 10 + 7 = 17"
  )
  test_assert.assert_eq_i64(
    actual: w(v: i32_div_lit(x: 30)),
    expected: 10,
    label: "i32 30 / 3 = 10"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
