// Regression for nexus-bvkhi: the LIR constant-folder must not fold an i32
// INT_MIN / -1 to a value (i32.div_s traps on signed overflow), so its
// behavior matches the runtime-operand path. A trap can't be asserted as PASS
// here, so this guards the OTHER direction: the i32 INT_MIN guard must NOT
// over-fire — normal i32 division/modulo (incl. the non-trapping INT_MIN % -1)
// must still fold and evaluate correctly.
import { Console, system_handler } from "std:stdio"
exception Boom(val: string)
let main = fn () -> unit require { PermConsole } throws { Boom } do
  inject system_handler do
    let a: i32 = 100 / 7
    if !(a == 14) then throw Boom(val: "100/7") end
    let b: i32 = 100 % 7
    if !(b == 2) then throw Boom(val: "100%7") end
    // i32.rem_s(INT_MIN, -1) == 0 (rem does not trap on overflow) — must still fold.
    let m: i32 = (0 - 2147483647 - 1) % (0 - 1)
    if !(m == 0) then throw Boom(val: "INT_MIN%-1") end
    // i64 INT_MIN/-1 stays guarded too (no spurious fold change): a normal i64 div folds.
    let l: i64 = 1000000000000 / 7
    if !(l == 142857142857) then throw Boom(val: "i64 div") end
    Console.println(val: "ok")
  end
  return ()
end
