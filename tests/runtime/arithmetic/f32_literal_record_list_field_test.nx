/**
 * An f32 LITERAL used as a record-field or list-element initializer must be
 * stored and read at f32 precision (rounded), not full f64.
 *
 * f32-ness is observed via PRECISION LOSS: 16777217.0 (2^24 + 1) is not
 * f32-representable; the nearest f32 is 16777216.0 (2^24). So an f32-declared
 * field/element initialized with 16777217.0 must compare equal to the
 * properly-rounded 16777216.0, while an f64 field/element keeps the full value.
 */
import * as test_assert from "std:test/assert"

type FieldRec = { zed: f32 }

type Payload = Payload(amount: f32)

/** Opaque f32 identity: rounds its argument to f32 width and blocks the
 *  constant folder so the reference value also comes through the runtime path. */
let round_f32 = fn (n: f32) -> f32 do return n end

let body = fn () -> unit throws { Exn } do
  let rounded: f32 = round_f32(n: 16777216.0)

  let r: FieldRec = { zed: 16777217.0 }
  test_assert.assert_eq_bool(actual: r.zed ==. rounded, expected: true,
    label: "f32 record-field literal rounds to 2^24")

  let xs: [ f32 ] = [ 16777217.0 ]
  let head_val: f32 = match xs do
    | x :: _ -> x
    | [] -> 0.0
  end
  test_assert.assert_eq_bool(actual: head_val ==. rounded, expected: true,
    label: "f32 list-element literal rounds to 2^24")
  test_assert.assert_eq_bool(actual: head_val ==. 16777216.0, expected: true,
    label: "f32 list-element head compares at f32 width vs literal")

  let one_half: f32 = round_f32(n: 1.5)
  let ys: [ f32 ] = [ one_half ]
  let yhead: f32 = match ys do
    | x :: _ -> x
    | [] -> 0.0
  end
  test_assert.assert_eq_bool(actual: yhead ==. 1.5, expected: true,
    label: "f32 list-element variable keeps f32 width")

  let Payload(amount: p) = Payload(amount: 16777217.0)
  test_assert.assert_eq_bool(actual: p ==. rounded, expected: true,
    label: "f32 sum-payload literal rounds to 2^24")

  let scalar: f32 = 16777217.0
  test_assert.assert_eq_bool(actual: scalar ==. rounded, expected: true,
    label: "f32 scalar-let literal rounds to 2^24")

  let lr: { wide: f64 } = { wide: 16777217.0 }
  test_assert.assert_eq_bool(actual: lr.wide ==. 16777217.0, expected: true,
    label: "f64 record-field literal keeps full precision")

  let ws: [ f64 ] = [ 16777217.0 ]
  let whead: f64 = match ws do
    | x :: _ -> x
    | [] -> 0.0
  end
  test_assert.assert_eq_bool(actual: whead ==. 16777217.0, expected: true,
    label: "f64 list-element literal keeps full precision")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
