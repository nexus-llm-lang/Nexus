// Regression: nexus-qjejm facet 1 (f32) -- an f-prefixed binop mixing an f32
// variable with a float LITERAL must produce wasm that validates and runs.
//
// f32_binop_return_type_test.nx (nexus-vmbtk) fixed the BOTH-f32 case:
// infer_binary_type returned TyF32 only when both operands were TyF32. But a
// float literal is typed TyF64 in LIR, so `x +. 1.0` (x: f32) still returned
// TyF64 -> the result temp local was declared f64, while codegen's
// binary_operand_type / emit_binary emitted f32.add (it picks f32 when EITHER
// side is f32 and demotes the literal). The f32 stack value then failed to
// `local.set` into the f64 slot ("expected f64, found f32" at the fn tail).
//
// The fix makes infer_binary_type return TyF32 whenever either operand is f32
// (the typechecker rejects genuine f32/f64 variable mixing, so the f64 side is
// a literal that adopts the f32 width), matching the emitted opcode.
import * as test_assert from "std:test/assert"

let scale_add = fn (x: f32) -> f32 do return x +. 1.0 end
let scale_sub = fn (x: f32) -> f32 do return x -. 1.0 end
let scale_mul = fn (x: f32) -> f32 do return x *. 2.0 end
let scale_div = fn (x: f32) -> f32 do return x /. 2.0 end

let body = fn () -> unit throws { Exn } do
  let a: f32 = scale_add(x: 2.0)
  test_assert.assert_eq_bool(actual: a ==. 3.0, expected: true, label: "f32 2.0 +. 1.0 = 3.0")

  let s: f32 = scale_sub(x: 5.0)
  test_assert.assert_eq_bool(actual: s ==. 4.0, expected: true, label: "f32 5.0 -. 1.0 = 4.0")

  let m: f32 = scale_mul(x: 3.0)
  test_assert.assert_eq_bool(actual: m ==. 6.0, expected: true, label: "f32 3.0 *. 2.0 = 6.0")

  let d: f32 = scale_div(x: 9.0)
  test_assert.assert_eq_bool(actual: d ==. 4.5, expected: true, label: "f32 9.0 /. 2.0 = 4.5")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
