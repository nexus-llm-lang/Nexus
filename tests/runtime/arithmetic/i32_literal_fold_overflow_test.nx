// Regression: nexus-c7pst -- the residual of iap3b. When BOTH operands of a
// narrow (`i32`) arithmetic binding are INLINE LITERALS, the binary node
// defaults to `TyI64` (neither operand carries a narrow width, so
// `int_arith_result` returns i64), so the value is computed -- and the
// constant-folder folds it -- in 64-bit and never wraps to the declared i32
// slot. Three sub-shapes leaked:
//
//   * FOLDED arithmetic (`+ - * /`): `let p: i32 = 65536 * 65536` folded to
//     `4294967296` in i64; `wrap_to_decl_width` saw the i64 binary type and
//     skipped the i32 truncation, then constant-propagation inlined the
//     un-wrapped value into `p == 0`, folding the comparison to `false`.
//   * FOLDED overflow to the sign region: `2147483647 + 1` folded to
//     `2147483648` (positive in i64) instead of i32 INT_MIN.
//   * NON-FOLDED shift: `1 << 31` is not constant-folded, so the binary node
//     typed i64 made codegen emit `i64.shl` -> `2147483648`, and the value
//     flowed wide into the comparison (`i64.lt_s`), reading as positive.
//
// The fix types the binary node at the declared narrow width when it is the
// direct RHS of a narrow `let` (matching iap3b's already-correct
// VARIABLE-operand path, whose operand width forced i32). That makes the
// folder wrap the literal AND makes codegen pick the i32 opcode -- one root
// fix for all three shapes.
//
// i32 sign cannot be observed through `cast.i64_of` (an UNSIGNED zero-extend),
// so the wrap is asserted in the i32 domain via `==` / `<` against i32 values.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let zero: i32 = 0

  // ── folded i32 multiply wraps to 0 (65536 * 65536 = 2^32, i32-wraps to 0) ──
  // BOTH operands inline literals: the folder evaluates the product directly.
  let p: i32 = 65536 * 65536
  test_assert.assert_true(cond: p == zero, label: "inline i32 65536 * 65536 wraps to 0")

  // ── folded i32 INT_MAX + 1 overflows to the most-negative i32 (sign set) ──
  let q: i32 = 2147483647 + 1
  test_assert.assert_true(cond: q < zero, label: "inline i32 INT_MAX + 1 is negative")

  // ── 1 << 31 sets the sign bit (the shift is NOT constant-folded, so this
  //    exercises the codegen-opcode side of the same root cause) ──
  let s: i32 = 1 << 31
  test_assert.assert_true(cond: s < zero, label: "inline i32 1 << 31 sets the sign bit")

  // INT_MAX + 1 and 1 << 31 both equal i32 INT_MIN (folded + non-folded paths
  // must agree on the exact wrap value, which is otherwise unwritable as a
  // positive literal -- it is out of i32 range before the unary minus).
  test_assert.assert_true(cond: q == s, label: "inline i32 INT_MAX+1 == 1<<31 (both INT_MIN)")

  // ── folded i32 subtraction underflow wraps to the most-positive i32 ──
  // INT_MIN - 1 == INT_MAX; expressed via the two overflow forms (no literal
  // for INT_MIN itself). q is INT_MIN, so q - 1 underflows to INT_MAX > 0.
  let one: i32 = 1
  let under: i32 = q - one
  test_assert.assert_true(
    cond: under > zero,
    label: "i32 INT_MIN - 1 underflows positive (INT_MAX)"
  )
  let imax: i32 = 2147483647
  test_assert.assert_true(cond: under == imax, label: "i32 INT_MIN - 1 == INT_MAX")

  // ── in-range inline i32 arithmetic still computes the ordinary value ──
  let sum: i32 = 40000 * 2
  let expect: i32 = 80000
  test_assert.assert_true(cond: sum == expect, label: "inline i32 40000 * 2 = 80000 (no wrap)")

  // ── i64 lets are UNAFFECTED: the same inline product stays 4294967296 ──
  let lp: i64 = 65536 * 65536
  test_assert.assert_eq_i64(
    actual: lp,
    expected: 4294967296,
    label: "inline i64 65536 * 65536 unchanged"
  )
  let lq: i64 = 2147483647 + 1
  test_assert.assert_eq_i64(
    actual: lq,
    expected: 2147483648,
    label: "inline i64 INT_MAX + 1 unchanged"
  )

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
