// Regression: nexus-iap3b (f32 analog) -- a narrow (`f32`) `let`-binding whose
// RHS is a float LITERAL must keep its declared width so downstream arithmetic
// rounds at f32 precision, not f64.
//
// Sibling of the i32 case: `let x: f32 = <float literal>` bound an f64 LOCAL
// (the binding's LIR type came from `atom_type(<float literal atom>)` = TyF64,
// dropping the declared `f32`), so `x +. y` ran as `f64.add`. After
// propagation rewrote two narrow `let`s back into f64 literals,
// `binary_operand_type` also chose `f64.add` for a declared-f32 node, leaking
// an f64 into an f32 consumer -> invalid wasm.
//
// f32-ness is observed via PRECISION LOSS: 16777216.0 is 2^24, where the f32
// gap to the next value is 2.0, so `16777216.0 +. 1.0` rounds back to
// 16777216.0 in f32 but would be 16777217.0 in f64. Equality against the f32
// operand therefore holds only if the addition genuinely ran at f32 width.
import * as test_assert from "std:test/assert"

// Opaque f32 identity: blocks constant folding so the arithmetic is exercised
// on the runtime (un-folded) codegen path too.
let noopt = fn (n: f32) -> f32 do return n end

let body = fn () -> unit throws { Exn } do
  // ── ordinary f32 literal-let arithmetic computes the f32 value ──
  let a: f32 = 1.5
  let b: f32 = 2.25
  let s: f32 = a +. b
  test_assert.assert_eq_bool(actual: s ==. 3.75, expected: true, label: "f32 1.5 +. 2.25 = 3.75")

  // ── f32 precision: 2^24 +. 1.0 rounds back to 2^24 at f32 width ──
  let big: f32 = 16777216.0
  let one: f32 = 1.0
  let sum: f32 = big +. one
  // If the add ran at f64, sum would be 16777217.0 and this would fail.
  test_assert.assert_eq_bool(actual: sum ==. big, expected: true,
    label: "f32 2^24 +. 1.0 rounds to 2^24 (folded)")
  // runtime path: laundered through noopt() so the folder can't pre-compute.
  let rsum: f32 = noopt(n: 16777216.0) +. noopt(n: 1.0)
  test_assert.assert_eq_bool(actual: rsum ==. big, expected: true,
    label: "f32 2^24 +. 1.0 rounds to 2^24 (runtime)")

  // ── f64 lets are UNAFFECTED: 2^24 +. 1.0 keeps the +1 at f64 width ──
  let lbig: f64 = 16777216.0
  let lone: f64 = 1.0
  let lsum: f64 = lbig +. lone
  test_assert.assert_eq_bool(actual: lsum ==. 16777217.0, expected: true,
    label: "f64 2^24 +. 1.0 = 2^24+1 unchanged")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
