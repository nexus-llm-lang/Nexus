// Regression: an f-suffixed comparison (==. !=. <. <=. >. >=.) on an f32
// value must evaluate at f32 precision even when constant propagation has
// collapsed an `f32` variable bound to a bare float LITERAL into the literal.
//
// `LirAtomFloat` is width-less (its atom type is always f64). When a
// `let g: f32 = 16777217.0` binding was propagated, codegen saw the literal at
// f64 in the comparison; with the OTHER operand also a literal, the binary node
// carried no surviving f32 type and the comparison emitted `f64.eq` on the
// UNROUNDED f64 constants. 16777217.0 (2^24+1) is not representable in f32 and
// rounds to 16777216.0 (2^24), so `g ==. 16777216.0` wrongly answered false at
// f64 precision. (The f32-field load/store fix it siblings only tested
// exactly-representable values, so the precision loss never surfaced there; the
// iap3b literal-let test only exercised f32 ARITHMETIC, whose result-typed
// binary node already kept its f32 width.)
//
// The fix keeps an `f32`-declared name bound to a bare float literal alive (it
// is no longer recorded for copy propagation), so the value flows through a
// real f32 local whose store demotes the literal to f32 — every read, and the
// comparison opcode, then operate at f32 width.
import * as test_assert from "std:test/assert"

// Opaque f32 identity: forces the runtime (un-propagated) comparison path so
// the same checks are covered when the value is genuinely a runtime f32.
let noopt = fn (n: f32) -> f32 do return n end

let body = fn () -> unit throws { Exn } do
  // 2^24+1 -> rounds to 2^24 in f32.
  let g: f32 = 16777217.0
  // 2^24+2 -> exactly representable in f32 (even mantissa step).
  let h: f32 = 16777218.0

  // ── ==. : the unrepresentable literal rounds to 2^24 and matches ──
  test_assert.assert_eq_bool(actual: g ==. 16777216.0, expected: true, label: "==. rounds")
  test_assert.assert_eq_bool(actual: g ==. 16777217.0, expected: true, label: "==. self-rounds")
  // distinct representable f32 value must NOT compare equal
  test_assert.assert_eq_bool(actual: h ==. 16777216.0, expected: false, label: "==. distinct")

  // ── !=. ──
  test_assert.assert_eq_bool(actual: g !=. 16777216.0, expected: false, label: "!=. equal-is-false")
  test_assert.assert_eq_bool(actual: g !=. 16777218.0, expected: true, label: "!=. distinct")

  // ── <. <=. ──
  test_assert.assert_eq_bool(actual: g <. 16777218.0, expected: true, label: "<. less")
  test_assert.assert_eq_bool(actual: g <=. 16777216.0, expected: true, label: "<=. equal")
  test_assert.assert_eq_bool(actual: h <. 16777216.0, expected: false, label: "<. not-less")

  // ── >. >=. ──
  test_assert.assert_eq_bool(actual: g >. 16777215.0, expected: true, label: ">. greater")
  test_assert.assert_eq_bool(actual: g >=. 16777216.0, expected: true, label: ">=. equal")
  test_assert.assert_eq_bool(actual: g >. 16777218.0, expected: false, label: ">. not-greater")

  // ── two propagated f32 literal-vars compared to each other ──
  let a: f32 = 16777217.0    // -> 2^24
  let b: f32 = 16777216.0    // -> 2^24
  test_assert.assert_eq_bool(actual: a ==. b, expected: true, label: "var-var rounded-equal")
  test_assert.assert_eq_bool(actual: a <. h, expected: true, label: "var-var <.")

  // ── runtime path: laundered through noopt() so the value is a true f32 ──
  let rg: f32 = noopt(n: 16777217.0)
  test_assert.assert_eq_bool(actual: rg ==. 16777216.0, expected: true, label: "runtime ==. rounds")
  test_assert.assert_eq_bool(actual: rg !=. 16777218.0, expected: true, label: "runtime !=. distinct")

  // ── control: f64 comparison of the same magnitudes stays at f64 ──
  let gd: f64 = 16777217.0
  test_assert.assert_eq_bool(actual: gd == 16777216.0, expected: false, label: "f64 stays f64")
  test_assert.assert_eq_bool(actual: gd == 16777217.0, expected: true, label: "f64 equals self")

  // ── control: f32 arithmetic on the same literal still rounds correctly ──
  let s: f32 = 16777217.0 +. 0.0
  let t: f32 = 16777216.0
  test_assert.assert_eq_bool(actual: s ==. t, expected: true, label: "arith rounds")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
