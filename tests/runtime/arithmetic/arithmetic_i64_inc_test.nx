// Port of bootstrap/tests/runtime/arithmetic.rs::codegen_i32_arithmetic_works.
// The Rust comment notes wasm i32 functions are unsupported; the original
// fixture exercises i64 increment via a user fn — same semantics here.
import * as test_assert from "std:test/assert"

let inc = fn (x: i64) -> i64 do
  return x + 1
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: inc(x: 41), expected: 42, label: "inc(41)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
