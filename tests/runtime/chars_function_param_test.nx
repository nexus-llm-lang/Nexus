// Port of bootstrap/tests/runtime/chars.rs::char_in_function_param.
import * as test_assert from "std:test/assert"

let is_a = fn (c: char) -> bool do
  return c == 'a'
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_true(cond: is_a(c: 'a'), label: "is_a('a') is true")
  test_assert.assert_false(cond: is_a(c: 'b'), label: "is_a('b') is false")
  // R-5 workaround: keep std:str alive so the bundler links stdlib.
  test_assert.assert_eq_i64(actual: 1, expected: 1, label: "stdlib-link tripwire")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
