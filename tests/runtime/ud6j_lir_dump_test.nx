// Issue nexus-ud6j — LIR dump (`nexus lir <file> --format=json|text`) V1.
//
// Drives `lir_to_text` / `lir_to_json` directly with a hand-rolled
// LirFunction fixture. Same subprocess-avoidance rationale as the HIR
// counterpart and kmel_json_format_test.nx.
//
// Coverage:
//   1. Text dump starts with the "=== LIR dump" banner.
//   2. JSON dump parses through std:json and carries
//      `{kind: "lir", functions: [...]}` at the top level.
//   3. A single-statement fixture function round-trips its name and
//      ret_type, and its `body_pp` mentions the let-bound atom.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as list from "std:list"
import * as ir_dump from "src/tools/ir_dump.nx"
import * as json from "std:json"
import { JsonValue, JsonObject, JsonArray, JsonString, get_field } from "std:json"
import { Some, None } from "std:option"
import { Span } from "src/common/token.nx"
import {
  LirFunction, LirParam, LirStmt, LirExpr, LirAtom
} from "src/ir/lir/types.nx"
import { TyI64 } from "src/common/ast.nx"

// ─── Fixture: synthesise a single LIR function ─────────────────────────────

let synth_func = fn () -> LirFunction do
  let sp = Span(offset: 0, line: 1, col: 1)
  // body: let __t0: i64 = 7  -> ret = __t0
  let lit_atom = LirAtomInt(val: 7)
  let let_stmt = LirStmtLet(name: "__t0", typ: TyI64, expr: LirExprAtom(atom: lit_atom))
  let ret_atom = LirAtomVar(name: "__t0", typ: TyI64)
  return LirFunction(
    name: "seven",
    params: [],
    ret_type: TyI64,
    body: [let_stmt],
    ret: ret_atom,
    span: sp
  )
end

// ─── JSON helpers (mirror the hir-dump test) ───────────────────────────────

let expect_object = fn (v: JsonValue, label: string) -> [json.JsonField] throws { Exn } do
  match v do
    | JsonObject(fields) -> return fields
    | _ -> raise RuntimeError(val: label ++ ": expected JsonObject")
  end
end

let expect_array = fn (v: JsonValue, label: string) -> [JsonValue] throws { Exn } do
  match v do
    | JsonArray(items) -> return items
    | _ -> raise RuntimeError(val: label ++ ": expected JsonArray")
  end
end

let expect_string = fn (v: JsonValue, label: string) -> string throws { Exn } do
  match v do
    | JsonString(val: s) -> return s
    | _ -> raise RuntimeError(val: label ++ ": expected JsonString")
  end
end

let require_field = fn (obj: JsonValue, key: string, label: string) -> JsonValue throws { Exn } do
  match get_field(obj, key) do
    | Some(val: v) -> return v
    | None -> raise RuntimeError(val: label ++ ": missing field '" ++ key ++ "'")
  end
end

// ─── Test 1: text dump banner ──────────────────────────────────────────────

let test_text_banner = fn () -> unit throws { Exn } do
  let f = synth_func()
  let out = ir_dump.lir_to_text(funcs: [f])
  let starts_with_banner = str.starts_with(s: out, prefix: "=== LIR dump")
  test_assert.assert_eq_bool(actual: starts_with_banner, expected: true, label: "ud6j: LIR text dump starts with banner")
  return ()
end

// ─── Test 2: JSON dump shape ───────────────────────────────────────────────

let test_json_shape = fn () -> unit throws { Exn } do
  let f = synth_func()
  let out = ir_dump.lir_to_json(funcs: [f])
  let starts_with_brace = str.starts_with(s: out, prefix: "{")
  test_assert.assert_eq_bool(actual: starts_with_brace, expected: true, label: "ud6j: LIR JSON output starts with '{'")
  let obj = json.parse(s: out)
  let kind_v = require_field(obj, key: "kind", label: "ud6j lir json")
  let kind = expect_string(v: kind_v, label: "ud6j lir kind")
  test_assert.assert_eq_string(actual: kind, expected: "lir", label: "ud6j: kind = lir")
  let funcs_v = require_field(obj, key: "functions", label: "ud6j lir json")
  let funcs = expect_array(v: funcs_v, label: "ud6j lir functions")
  let n = list.length(xs: funcs)
  test_assert.assert_eq_i64(actual: n, expected: 1, label: "ud6j: 1 synthesised function")
  match funcs do
    | [] -> raise RuntimeError(val: "expected one function")
    | fv :: _ ->
      let name_v = require_field(obj: fv, key: "name", label: "ud6j lir func")
      let name = expect_string(v: name_v, label: "ud6j lir func name")
      test_assert.assert_eq_string(actual: name, expected: "seven", label: "ud6j: name round-trips")
      let ret_v = require_field(obj: fv, key: "ret_type", label: "ud6j lir func")
      let ret = expect_string(v: ret_v, label: "ud6j lir ret_type")
      test_assert.assert_eq_string(actual: ret, expected: "i64", label: "ud6j: ret_type = i64")
      let body_v = require_field(obj: fv, key: "body_pp", label: "ud6j lir func")
      let body_pp = expect_string(v: body_v, label: "ud6j lir body_pp")
      let has_7 = str.contains(s: body_pp, sub: "7")
      test_assert.assert_eq_bool(actual: has_7, expected: true, label: "ud6j: body_pp mentions 7")
  end
  return ()
end

let main = fn () -> unit throws { Exn } do
  test_text_banner()
  test_json_shape()
  return ()
end
