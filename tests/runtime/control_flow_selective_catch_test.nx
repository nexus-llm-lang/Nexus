// Port of bootstrap/tests/runtime/control_flow.rs:
//   codegen_selective_catch_matches_correct_arm,
//   codegen_selective_catch_wildcard_catches_unmatched,
//   codegen_selective_catch_labeled_fields,
//   codegen_legacy_catch_still_works,
//   codegen_selective_catch_labeled_string_fields_used_in_concat,
//   codegen_selective_catch_nested_try_routes_exceptions,
//   codegen_catch_or_pattern_handles_either_exception.
import * as test_assert from "std:test/assert"

// Original Rust source uses positional-field exceptions (`Boom(i64)`) — the
// type-checker requires labeled fields, so we use `code:`/`v:` here. Behavior
// is identical (single i64 payload).
exception Boom(code: i64)
exception Oops(v: i64)
exception DbError(code: i64, msg: string)
exception Parse(expected: string, got: string)
exception ErrA(v: i64)
exception ErrB(v: i64)

let matches_correct_arm = fn () -> i64 throws { Exn } do
  try
    raise Boom(code: 42)
    return -1
  catch
    | Boom(code: c) -> return c
    | Oops(v: n) -> return n + 100
    | _ -> return -2
  end
  return -3
end

let wildcard_unmatched = fn () -> i64 throws { Exn } do
  try
    raise Oops(v: 99)
    return -1
  catch
    | Boom(code: c) -> return c
    | _ -> return 77
  end
  return -3
end

let labeled_fields = fn () -> i64 throws { Exn } do
  try
    raise DbError(code: 404, msg: "not found")
    return -1
  catch
    | DbError(code: c, msg: _) -> return c
    | _ -> return -2
  end
  return -3
end

let legacy_catch = fn () -> i64 throws { Exn } do
  try
    raise Boom(code: 55)
    return -1
  catch
    | Boom(code: c) -> return c
    | _ -> return -2
  end
  return -3
end

let parse_concat = fn () -> string throws { Exn } do
  try
    raise Parse(expected: "comma", got: "semicolon")
    return ""
  catch
    | Parse(expected: e, got: g) -> return "expected " ++ e ++ ", got " ++ g
    | _ -> return ""
  end
  return ""
end

let nested_routes = fn () -> i64 throws { Exn } do
  try
    try
      raise Oops(v: 10)
      return -1
    catch
      | Boom(code: c) -> return c
      | _ -> raise RuntimeError(val: "inner fallthrough")
    end
    return -2
  catch
    | RuntimeError(val: _) -> return 77
    | _ -> return -3
  end
  return -4
end

let throws_a = fn () -> i64 throws { Exn } do
  raise ErrA(v: 11)
  return 0
end

let throws_b = fn () -> i64 throws { Exn } do
  raise ErrB(v: 22)
  return 0
end

let safe_or_pattern = fn (which: i64) -> i64 throws { Exn } do
  try
    if which == 0 then return throws_a() end
    return throws_b()
  catch
    | ErrA(v: _) | ErrB(v: _) -> return 555
  end
  return 0
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: matches_correct_arm(), expected: 42, label: "selective Boom arm")
  test_assert.assert_eq_i64(actual: wildcard_unmatched(), expected: 77, label: "wildcard catches unmatched")
  test_assert.assert_eq_i64(actual: labeled_fields(), expected: 404, label: "labeled-field catch")
  test_assert.assert_eq_i64(actual: legacy_catch(), expected: 55, label: "legacy catch syntax")
  test_assert.assert_eq_string(actual: parse_concat(), expected: "expected comma, got semicolon", label: "string field concat (regression nexus-y91m)")
  test_assert.assert_eq_i64(actual: nested_routes(), expected: 77, label: "nested try routes via outer")
  test_assert.assert_eq_i64(actual: safe_or_pattern(which: 0), expected: 555, label: "or-pattern catches ErrA")
  test_assert.assert_eq_i64(actual: safe_or_pattern(which: 1), expected: 555, label: "or-pattern catches ErrB")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
