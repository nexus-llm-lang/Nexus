// Port of bootstrap/tests/runtime/control_flow.rs:
//   codegen_for_loop_basic, codegen_for_loop_empty_range, codegen_for_loop_with_computation.
import * as test_assert from "std:test/assert"

let sum_for_5 = fn () -> i64 do
  let ~sum = 0
  for i = 0 to 5 do
    ~sum <- ~sum + i
  end
  return ~sum
end

let for_empty = fn () -> i64 do
  let ~x = 0
  for i = 5 to 5 do
    ~x <- 999
  end
  return ~x
end

let factorial5 = fn () -> i64 do
  let ~product = 1
  for i = 1 to 6 do
    ~product <- ~product * i
  end
  return ~product
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: sum_for_5(), expected: 10, label: "for-loop sum 0..5")
  test_assert.assert_eq_i64(actual: for_empty(), expected: 0, label: "for-loop empty range")
  test_assert.assert_eq_i64(actual: factorial5(), expected: 120, label: "for-loop 5!")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
