// Regression for nexus-ybda: f32/f64 mem.load_*/mem.store_* primitives.
//
// Verifies bitwise-stable roundtrip of f32 and f64 stores by storing a
// known float, reading back via the typed load, and comparing the raw
// 32-/64-bit byte payload via the i32/i64 loads. Direct float equality
// would not detect endian / alignment / promote-demote bugs.
//
// f32 invariant: store_f32(addr, X) followed by load_f32(addr) returns
// the same value bit-for-bit when X is exactly f32-representable. Since
// 1.5 / -2.25 / 0.0 all are, the i32 byte readback proves the wasm
// encoding is correct.
//
// f64 invariant: store_f64(addr, X) followed by load_f64(addr) is
// always bitwise-identical (no demote step).

import * as mem from "std:runtime/mem"
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  // Reserve a fresh wasm page for scratch memory.
  let prev_pages = mem.grow(delta: 1)
  let base = prev_pages * 65536

  // ── f32 roundtrip ────────────────────────────────────────────────────
  let _ = mem.store_f32(addr: base, val: 1.5)
  let bits_15 = mem.load_i32(addr: base)
  // 1.5 in IEEE-754 binary32 is 0x3FC00000 = 1069547520
  test_assert.assert_eq_i64(actual: bits_15, expected: 1069547520,
    label: "f32 store 1.5 -> i32 byte readback")

  let _ = mem.store_f32(addr: base + 4, val: -.2.25)
  let bits_neg = mem.load_i32(addr: base + 4)
  // -2.25 binary32 = 0xC0100000; i32 sign-extended -> i64 = 0xFFFFFFFFC0100000
  // -1072693248 == 0xFFFFFFFFC0100000 as signed i64
  test_assert.assert_eq_i64(actual: bits_neg, expected: -1072693248,
    label: "f32 store -2.25 -> i32 byte readback (sign-extended)")

  let _ = mem.store_f32(addr: base + 8, val: 0.0)
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: base + 8),
    expected: 0, label: "f32 store 0.0 -> i32 byte readback")

  // ── f64 roundtrip via i64 byte readback ──────────────────────────────
  let _ = mem.store_f64(addr: base + 16, val: 1.5)
  // 1.5 in IEEE-754 binary64 is 0x3FF8000000000000
  test_assert.assert_eq_i64(actual: mem.load_i64(addr: base + 16),
    expected: 4609434218613702656,
    label: "f64 store 1.5 -> i64 byte readback")

  let _ = mem.store_f64(addr: base + 24, val: 0.0)
  test_assert.assert_eq_i64(actual: mem.load_i64(addr: base + 24),
    expected: 0, label: "f64 store 0.0 -> i64 byte readback")

  // ── f32 / f64 typed-load self-consistency ────────────────────────────
  // Store via typed store, load via typed load, compare via separate i32 /
  // i64 byte path. Catches any promote/demote-on-the-wrong-side bug that
  // the byte-readback above might mask if both halves were broken in the
  // same direction.
  let _ = mem.store_f32(addr: base + 32, val: 3.5)
  let f32_back = mem.load_f32(addr: base + 32)
  let _ = mem.store_f32(addr: base + 36, val: f32_back)
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: base + 32),
    expected: mem.load_i32(addr: base + 36),
    label: "f32 store-load-store roundtrip preserves bits")

  let _ = mem.store_f64(addr: base + 40, val: 6.25)
  let f64_back = mem.load_f64(addr: base + 40)
  let _ = mem.store_f64(addr: base + 48, val: f64_back)
  test_assert.assert_eq_i64(actual: mem.load_i64(addr: base + 40),
    expected: mem.load_i64(addr: base + 48),
    label: "f64 store-load-store roundtrip preserves bits")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
