// Port of bootstrap/tests/runtime/control_flow.rs:
//   codegen_if_expr_inside_match_expr_as_let_value,
//   codegen_if_expr_inside_nested_match_expr_as_let_value,
//   codegen_if_expr_with_call_inside_nested_match,
//   codegen_if_call_inside_double_nested_match_as_let.
import * as test_assert from "std:test/assert"

type Wrapper = Wrapper(val: i64)
type Outer = OuterA(inner: Wrapper) | OuterB

type InnerS = InnerS(name: string)
type OuterS = OuterSA(inner: InnerS) | OuterSB

let pick = fn (flag: bool, a: i64, b: i64) -> i64 do
  let result = match flag do
    | true ->
      if a > b then a else b end
    | false -> 0
  end
  return result
end

let classify_nested = fn (x: Outer, threshold: i64) -> i64 do
  let result = match x do
    | OuterA(inner: w) ->
      match w do | Wrapper(val: v) ->
        if v > threshold then v else threshold end
      end
    | OuterB -> 0
  end
  return result
end

let add10 = fn (x: i64) -> i64 do
  return x + 10
end

let compute_call = fn (x: Outer, flag: bool) -> i64 do
  let result = match x do
    | OuterA(inner: w) ->
      match w do | Wrapper(val: v) ->
        if flag then add10(x: v) else v end
      end
    | OuterB -> 0
  end
  return result
end

let prepend = fn (s: string, prefix: string) -> string do
  return prefix ++ s
end

let identity = fn (s: string) -> string do
  return s
end

let classify_strs = fn (x: OuterS, flag: bool) -> string do
  let result = match x do
    | OuterSA(inner: w) ->
      match w do | InnerS(name: n) ->
        if flag then identity(s: n) else prepend(s: n, prefix: "pfx.") end
      end
    | OuterSB -> "none"
  end
  return result
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: pick(flag: true, a: 10, b: 20), expected: 20, label: "pick true 10/20")
  test_assert.assert_eq_i64(actual: pick(flag: true, a: 30, b: 5), expected: 30, label: "pick true 30/5")
  test_assert.assert_eq_i64(actual: pick(flag: false, a: 10, b: 20), expected: 0, label: "pick false")

  test_assert.assert_eq_i64(actual: classify_nested(x: OuterA(inner: Wrapper(val: 100)), threshold: 50), expected: 100, label: "nested >threshold")
  test_assert.assert_eq_i64(actual: classify_nested(x: OuterA(inner: Wrapper(val: 10)), threshold: 50), expected: 50, label: "nested <threshold")
  test_assert.assert_eq_i64(actual: classify_nested(x: OuterB, threshold: 50), expected: 0, label: "nested OuterB")

  test_assert.assert_eq_i64(actual: compute_call(x: OuterA(inner: Wrapper(val: 5)), flag: true), expected: 15, label: "call true")
  test_assert.assert_eq_i64(actual: compute_call(x: OuterA(inner: Wrapper(val: 5)), flag: false), expected: 5, label: "call false")

  test_assert.assert_eq_string(actual: classify_strs(x: OuterSA(inner: InnerS(name: "hello")), flag: true), expected: "hello", label: "strs identity")
  test_assert.assert_eq_string(actual: classify_strs(x: OuterSA(inner: InnerS(name: "hello")), flag: false), expected: "pfx.hello", label: "strs prepend")
  test_assert.assert_eq_string(actual: classify_strs(x: OuterSB, flag: true), expected: "none", label: "strs none")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
