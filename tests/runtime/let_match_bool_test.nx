// nexus-r707 regression guard: let-binding the result of a `match` whose
// arms produce `bool` (mix of literal `true`/`false` and computed values)
// must not double-extend the i32 result to i64 in codegen. The legacy seed
// emitted `i64.extend_i32_s` followed by `i64.extend_i32_u`, producing wasm
// that the wasmtime validator rejected on the next bootstrap stage.
//
// The i6fj agent worked around this by avoiding the natural shape
// (return-from-arm in `resolve_bt_push_packed` / `collect_bt_func_names`).
// This fixture pins the natural shape so the bug can't silently reappear.
import * as test_assert from "std:test/assert"
import { NotImplemented } from "std:exn"

let main = fn () -> unit throws { Exn } do
  let v = 1
  let r = match v do
    | 1 -> true
    | _ -> false
  end
  if r then
    test_assert.assert_eq_i64(actual: 1, expected: 1, label: "r707 let-bind match-bool natural shape")
    return ()
  end
  throw NotImplemented(msg: "unreachable")
end
