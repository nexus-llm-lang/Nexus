// Issue nexus-g5el — `nexus types <file> --format=json|text` V1.
//
// Drives `types_to_text` / `types_to_json` directly via synthesised
// Program + HirProgram fixtures. Same subprocess-avoidance rationale as
// ud6j_hir_dump_test.nx — `Proc.exec` is unreachable under WASI preview1
// so a full `nexus types` invocation never reaches actual driver code.
//
// Coverage:
//   1. Text dump starts with the "=== Type dump" banner.
//   2. JSON dump round-trips through std:json and exposes
//      `{kind: "types", bindings: [...]}` at the top level.
//   3. A 3-binding fixture exercises:
//        - polymorphic function (TyVar in the signature)
//        - capability-using function (non-empty `requires`)
//        - a function with no caps and no throws
//      All three appear under `bindings` with the expected fields
//      (name, type, requires, throws).

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as list from "std:list"
import * as types_dump from "src/tools/types_dump.nx"
import * as json from "std:json"
import { JsonValue, JsonObject, JsonArray, JsonString, get_field } from "std:json"
import { Some, None } from "std:option"
import { Span } from "src/common/token.nx"
import {
  Program, SpannedTopLevel, TopLevel, TLLet, GlobalLet,
  SpannedExpr, Expr, ExprLambda, Param, Sigil, SigilImmutable,
  TypeExpr, TyI64, TyUnit, TyVar, TyUserDefined, TyRow,
  Stmt, SpannedStmt, StmtReturn, Literal, LitInt, ExprLiteral
} from "src/common/ast.nx"
import {
  HirProgram, HirFunction, HirParam, HirBody, EagerBody,
  HirStmt, HirStmtKind, HirExpr, HirExprKind
} from "src/ir/hir/types.nx"

let sp = fn () -> Span do return Span(offset: 0, line: 1, col: 1) end

// ─── AST Program fixture ───────────────────────────────────────────────────
//
// Three top-level lets:
//   identity = fn <T>(x: T) -> T do return x end
//   greet    = fn () -> () require { Console } do ... end
//   add      = fn (a: i64, b: i64) -> i64 do return 0 end
// The HIR fixture below mirrors these names so the `requires` lookup hits.

let mk_lambda = fn (params: [Param], ret_type: TypeExpr, requires: TypeExpr, throw_row: TypeExpr) -> SpannedExpr do
  // body: return 0 — irrelevant for the types dump, only the signature matters.
  let body_expr = SpannedExpr(node: ExprLiteral(lit: LitInt(val: 0)), span: sp())
  let body = [SpannedStmt(node: StmtReturn(value: body_expr), span: sp())]
  return SpannedExpr(node: ExprLambda(type_params: [], params, ret_type, requires, throw_row, body), span: sp())
end

let empty_row = fn () -> TypeExpr do return TyRow(types: [], rest: None) end

let console_row = fn () -> TypeExpr do
  return TyRow(types: [TyUserDefined(name: "Console", args: [])], rest: None)
end

let synth_program = fn () -> Program do
  let identity_lam = mk_lambda(
    params: [Param(name: "x", sigil: SigilImmutable, typ: TyVar(name: "T"))],
    ret_type: TyVar(name: "T"),
    requires: empty_row(),
    throw_row: empty_row()
  )
  let greet_lam = mk_lambda(
    params: [],
    ret_type: TyUnit,
    requires: console_row(),
    throw_row: empty_row()
  )
  let add_lam = mk_lambda(
    params: [Param(name: "a", sigil: SigilImmutable, typ: TyI64),
             Param(name: "b", sigil: SigilImmutable, typ: TyI64)],
    ret_type: TyI64,
    requires: empty_row(),
    throw_row: empty_row()
  )
  let mk_tl = fn (name: string, value: SpannedExpr) -> SpannedTopLevel do
    return SpannedTopLevel(node: TLLet(def: GlobalLet(name, is_public: true, typ: None, value)), span: sp())
  end
  return Program(definitions: [
    mk_tl(name: "identity", value: identity_lam),
    mk_tl(name: "greet", value: greet_lam),
    mk_tl(name: "add", value: add_lam)
  ], module_doc: None)
end

// ─── HIR Program fixture ───────────────────────────────────────────────────

let mk_hir_fn = fn (name: string, params: [HirParam], ret_type: TypeExpr, throw_row: TypeExpr) -> HirFunction do
  // body: return 0 — same rationale as AST fixture.
  let body_expr = HirExpr(node: Literal(lit: LitInt(val: 0)), span: sp())
  let body = EagerBody(stmts: [HirStmt(node: Return(expr: body_expr), span: sp())])
  return HirFunction(name, type_params: [], params, ret_type, throw_row, body, span: sp(), file: "<synth>")
end

let synth_hir = fn () -> HirProgram do
  let identity_fn = mk_hir_fn(
    name: "identity",
    params: [HirParam(label: "x", name: "x", sigil: SigilImmutable, typ: TyVar(name: "T"))],
    ret_type: TyVar(name: "T"),
    throw_row: empty_row()
  )
  let greet_fn = mk_hir_fn(
    name: "greet",
    params: [],
    ret_type: TyUnit,
    throw_row: empty_row()
  )
  let add_fn = mk_hir_fn(
    name: "add",
    params: [HirParam(label: "a", name: "a", sigil: SigilImmutable, typ: TyI64),
             HirParam(label: "b", name: "b", sigil: SigilImmutable, typ: TyI64)],
    ret_type: TyI64,
    throw_row: empty_row()
  )
  return HirProgram(
    ports: [],
    functions: [identity_fn, greet_fn, add_fn],
    externals: [],
    handler_bindings: [],
    enum_defs: [],
    exception_groups: [],
    value_binding_names: [],
    type_defs: []
  )
end

// ─── JSON helpers (mirror the ud6j ir-dump tests) ──────────────────────────

let expect_array = fn (v: JsonValue, label: string) -> [JsonValue] throws { Exn } do
  match v do
    | JsonArray(items) -> return items
    | _ -> raise RuntimeError(val: label ++ ": expected JsonArray")
  end
end

let expect_string = fn (v: JsonValue, label: string) -> string throws { Exn } do
  match v do
    | JsonString(val: s) -> return s
    | _ -> raise RuntimeError(val: label ++ ": expected JsonString")
  end
end

let require_field = fn (obj: JsonValue, key: string, label: string) -> JsonValue throws { Exn } do
  match get_field(obj, key) do
    | Some(val: v) -> return v
    | None -> raise RuntimeError(val: label ++ ": missing field '" ++ key ++ "'")
  end
end

// ─── Test 1: text dump banner + names present ──────────────────────────────

let test_text_banner = fn () -> unit throws { Exn } do
  let prog = synth_program()
  let hir = synth_hir()
  let out = types_dump.types_to_text(prog, hir)
  let starts_with_banner = str.starts_with(s: out, prefix: "=== Type dump")
  test_assert.assert_eq_bool(actual: starts_with_banner, expected: true, label: "g5el: text dump starts with banner")
  let has_identity = str.contains(s: out, sub: "identity")
  let has_greet = str.contains(s: out, sub: "greet")
  let has_add = str.contains(s: out, sub: "add")
  test_assert.assert_eq_bool(actual: has_identity, expected: true, label: "g5el: text mentions identity")
  test_assert.assert_eq_bool(actual: has_greet, expected: true, label: "g5el: text mentions greet")
  test_assert.assert_eq_bool(actual: has_add, expected: true, label: "g5el: text mentions add")
  // Capability-using function should show its `require` clause.
  let has_require_console = str.contains(s: out, sub: "require {Console}")
  test_assert.assert_eq_bool(actual: has_require_console, expected: true, label: "g5el: greet shows require {Console}")
  return ()
end

// ─── Test 2: JSON dump shape ───────────────────────────────────────────────

let find_binding_by_name = fn (items: [JsonValue], name: string) -> Option<JsonValue> throws { Exn } do
  match items do
    | [] -> return None
    | b :: rest ->
      let name_v = require_field(obj: b, key: "name", label: "g5el binding")
      let n = expect_string(v: name_v, label: "g5el binding name")
      if n == name then return Some(val: b) end
      return find_binding_by_name(items: rest, name)
  end
end

let test_json_shape = fn () -> unit throws { Exn } do
  let prog = synth_program()
  let hir = synth_hir()
  let out = types_dump.types_to_json(prog, hir)
  let starts_with_brace = str.starts_with(s: out, prefix: "{")
  test_assert.assert_eq_bool(actual: starts_with_brace, expected: true, label: "g5el: JSON output starts with '{'")
  let obj = json.parse(s: out)
  let kind_v = require_field(obj, key: "kind", label: "g5el types kind")
  let kind = expect_string(v: kind_v, label: "g5el kind value")
  test_assert.assert_eq_string(actual: kind, expected: "types", label: "g5el: kind = types")
  let bindings_v = require_field(obj, key: "bindings", label: "g5el types bindings")
  let bindings = expect_array(v: bindings_v, label: "g5el bindings array")
  let n = list.length(xs: bindings)
  test_assert.assert_eq_i64(actual: n, expected: 3, label: "g5el: 3 synthesised bindings")
  // Probe each binding individually so order doesn't matter.
  match find_binding_by_name(items: bindings, name: "identity") do
    | None -> raise RuntimeError(val: "g5el: missing 'identity' binding")
    | Some(val: ib) ->
      let type_v = require_field(obj: ib, key: "type", label: "g5el identity type")
      let type_str = expect_string(v: type_v, label: "g5el identity type str")
      // Polymorphic: parameter and return both mention T.
      let has_t = str.contains(s: type_str, sub: "T")
      test_assert.assert_eq_bool(actual: has_t, expected: true, label: "g5el: identity type mentions T")
  end
  match find_binding_by_name(items: bindings, name: "greet") do
    | None -> raise RuntimeError(val: "g5el: missing 'greet' binding")
    | Some(val: gb) ->
      let req_v = require_field(obj: gb, key: "requires", label: "g5el greet requires")
      let req_str = expect_string(v: req_v, label: "g5el greet requires str")
      test_assert.assert_eq_string(actual: req_str, expected: "{Console}", label: "g5el: greet requires {Console}")
      let thr_v = require_field(obj: gb, key: "throws", label: "g5el greet throws")
      let thr_str = expect_string(v: thr_v, label: "g5el greet throws str")
      test_assert.assert_eq_string(actual: thr_str, expected: "", label: "g5el: greet throws empty")
  end
  match find_binding_by_name(items: bindings, name: "add") do
    | None -> raise RuntimeError(val: "g5el: missing 'add' binding")
    | Some(val: ab) ->
      let type_v = require_field(obj: ab, key: "type", label: "g5el add type")
      let type_str = expect_string(v: type_v, label: "g5el add type str")
      let has_i64 = str.contains(s: type_str, sub: "i64")
      test_assert.assert_eq_bool(actual: has_i64, expected: true, label: "g5el: add type mentions i64")
      let req_v = require_field(obj: ab, key: "requires", label: "g5el add requires")
      let req_str = expect_string(v: req_v, label: "g5el add requires str")
      test_assert.assert_eq_string(actual: req_str, expected: "", label: "g5el: add requires empty (non-cap binding)")
  end
  return ()
end

let main = fn () -> unit throws { Exn } do
  test_text_banner()
  test_json_shape()
  return ()
end
