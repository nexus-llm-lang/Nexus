// Repro for nexus-eo09: nested match return loses outer fallthrough binding.
//
// Shape (from yvd8 / extend_with_neighbour discovery):
//   match prev
//     | Some(val: TkDot) ->
//         match prev2
//           | Some(val: t) ->
//               match token_name
//                 | Some(val: alias) -> return alias ++ "." ++ name
//                 | None -> ()
//               end
//           | None -> ()
//         end
//     | _ -> ()
//   end
//   return name
//
// Bug: outermost `return name` returns "" for fallthrough paths
// (prev2=None, token_name=None) when the lir pipeline hoists the inner
// conditional `then_ret` up to the outer wrapper, emitting a stale
// op_return after each branch's then_body.
//
// Expected outputs:
//   r1 = "outerName"       (prev = None — falls through outer match)
//   r2 = "innerNoneName"   (prev = Some(Dot), prev2 = Some(_), token_name = None)
//   r3 = "alias.aliasName" (all Some — inner return fires)
//   r4 = "prev2NoneName"   (prev = Some(Dot), prev2 = None)
import * as test_assert from "std:test/assert"

type Tok = TkDot | TkOther
type OTok = OTokSome(val: Tok) | OTokNone
type OStr = OStrSome(val: string) | OStrNone

let extend = fn (prev: OTok, prev2: OTok, token_name: OStr, name: string) -> string do
  match prev do
    | OTokSome(val: t1) ->
      match t1 do
        | TkDot ->
          match prev2 do
            | OTokSome(val: _t2) ->
              match token_name do
                | OStrSome(val: alias) -> return alias ++ "." ++ name
                | OStrNone -> ()
              end
            | OTokNone -> ()
          end
        | TkOther -> ()
      end
    | OTokNone -> ()
  end
  return name
end

let body = fn () -> unit throws { Exn } do
  let r1 = extend(prev: OTokNone, prev2: OTokNone, token_name: OStrNone, name: "outerName")
  let r2 = extend(prev: OTokSome(val: TkDot), prev2: OTokSome(val: TkOther), token_name: OStrNone, name: "innerNoneName")
  let r3 = extend(prev: OTokSome(val: TkDot), prev2: OTokSome(val: TkOther), token_name: OStrSome(val: "alias"), name: "aliasName")
  let r4 = extend(prev: OTokSome(val: TkDot), prev2: OTokNone, token_name: OStrSome(val: "alias"), name: "prev2NoneName")
  test_assert.assert_eq_string(actual: r1, expected: "outerName", label: "r1: prev=None outer fallthrough")
  test_assert.assert_eq_string(actual: r2, expected: "innerNoneName", label: "r2: token_name=None inner fallthrough")
  test_assert.assert_eq_string(actual: r3, expected: "alias.aliasName", label: "r3: all Some inner return")
  test_assert.assert_eq_string(actual: r4, expected: "prev2NoneName", label: "r4: prev2=None mid fallthrough")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
