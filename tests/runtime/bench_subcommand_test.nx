// nexus-mk4q8 — unit tests for src/tools/bench.nx.
//
// Strategy:
//   1. strip_bench_subcommand: purely functional (no caps), test all code paths.
//      Note: detect_subcommand expects args[0]=prog_name, args[1]=subcommand_kw.
//      Tests must include a synthetic program-name token as args[0].
//   2. run_bench_subcommand: under WASI preview1 Proc.exec returns -1 so the
//      function exits early with code 1 when bench files are found.  We verify
//      the no-files-found path (exit 1) and the nonexistent-dir throw path.
//
// Pure helpers (within_20pct, sort_i64, percentile, parse_bench_options) are
// not exported; they are exercised indirectly through run_bench_subcommand.

import * as test_assert from "std:test/assert"
import * as stdio from "std:stdio"
import * as fs_mod from "std:fs"
import { Console } from "std:stdio"
import { Fs } from "std:fs"
import * as str from "std:str"
import {
  ParsedBenchSubcommand,
  strip_bench_subcommand,
  run_bench_subcommand
} from "src/tools/bench.nx"

// ─── strip_bench_subcommand tests ───────────────────────────────────────────

// No args at all → is_bench=false, remaining=[].
let test_strip_no_args = fn () -> unit throws { Exn } do
  let ParsedBenchSubcommand(remaining, is_bench) = strip_bench_subcommand(xs: [])
  test_assert.assert_false(cond: is_bench,
    label: "mk4q8/bench: strip on [] → is_bench=false")
  test_assert.assert_eq_i64(
    actual: list_len(xs: remaining),
    expected: 0,
    label: "mk4q8/bench: strip on [] → remaining is empty"
  )
  return ()
end

// Only prog-name, no subcommand → is_bench=false.
let test_strip_prog_name_only = fn () -> unit throws { Exn } do
  let ParsedBenchSubcommand(remaining, is_bench) = strip_bench_subcommand(xs: [ "nexus" ])
  test_assert.assert_false(cond: is_bench,
    label: "mk4q8/bench: strip on [nexus] → is_bench=false")
  test_assert.assert_eq_i64(
    actual: list_len(xs: remaining),
    expected: 1,
    label: "mk4q8/bench: strip on [nexus] → remaining unchanged"
  )
  return ()
end

// Leading prog-name + "bench" keyword → is_bench=true, remaining has prog-name + rest.
let test_strip_bench_keyword_present = fn () -> unit throws { Exn } do
  let ParsedBenchSubcommand(remaining, is_bench) = strip_bench_subcommand(
    xs: [ "nexus", "bench", "--dir", "examples/feature/" ]
  )
  test_assert.assert_true(cond: is_bench,
    label: "mk4q8/bench: strip sees \"bench\" at pos 1 → is_bench=true")
  // remaining = prog_name :: rest (the --dir ... args)
  test_assert.assert_eq_i64(
    actual: list_len(xs: remaining),
    expected: 3,
    label: "mk4q8/bench: strip \"bench\" → remaining has prog + 2 args"
  )
  return ()
end

// "bench" alone (prog_name + bench, no trailing args) → is_bench=true, remaining=[prog_name].
let test_strip_bench_only = fn () -> unit throws { Exn } do
  let ParsedBenchSubcommand(remaining, is_bench) = strip_bench_subcommand(xs: [ "nexus", "bench" ])
  test_assert.assert_true(cond: is_bench,
    label: "mk4q8/bench: [nexus, bench] → is_bench=true")
  test_assert.assert_eq_i64(
    actual: list_len(xs: remaining),
    expected: 1,
    label: "mk4q8/bench: [nexus, bench] → remaining=[nexus]"
  )
  return ()
end

// Different keyword at pos 1 ("test") → is_bench=false, remaining is unchanged.
let test_strip_other_subcommand = fn () -> unit throws { Exn } do
  let ParsedBenchSubcommand(remaining, is_bench) = strip_bench_subcommand(
    xs: [ "nexus", "test", "--dir", "tests/" ]
  )
  test_assert.assert_false(cond: is_bench,
    label: "mk4q8/bench: [nexus, test, ...] → is_bench=false")
  // remaining must equal the original list (no stripping when not bench).
  test_assert.assert_eq_i64(
    actual: list_len(xs: remaining),
    expected: 4,
    label: "mk4q8/bench: other subcommand → remaining unchanged"
  )
  return ()
end

// Prog-name + "bench" + --iters N → is_bench=true, remaining captures prog + opts.
let test_strip_bench_with_iters = fn () -> unit throws { Exn } do
  let ParsedBenchSubcommand(remaining, is_bench) = strip_bench_subcommand(
    xs: [ "nexus", "bench", "--iters", "10" ]
  )
  test_assert.assert_true(cond: is_bench,
    label: "mk4q8/bench: [nexus, bench, --iters, 10] → is_bench=true")
  // remaining = nexus :: [ --iters, 10 ]
  test_assert.assert_eq_i64(
    actual: list_len(xs: remaining),
    expected: 3,
    label: "mk4q8/bench: [nexus, bench, --iters, 10] → remaining has 3 items"
  )
  return ()
end

// ─── run_bench_subcommand tests (under WASI preview1) ───────────────────────

// Under WASI preview1 Proc.exec returns -1.  When a valid directory is given
// with no bench_*.nx files, run_bench_subcommand returns 1 (no benches found)
// before ever invoking Proc.
let test_run_returns_1_on_empty_dir = fn () -> unit require { Console, Fs } throws { Exn } do
  let code = run_bench_subcommand(args: [ "--dir", "/tmp" ])
  test_assert.assert_eq_i64(
    actual: code,
    expected: 1,
    label: "mk4q8/bench: run on /tmp (no bench_*.nx files) exits 1"
  )
  return ()
end

// A nonexistent directory → run_bench_subcommand throws InvalidUsage
// (discover_benches: Fs.exists returns false → throw).
let test_run_raises_on_nonexistent_dir = fn () -> unit require { Console, Fs } throws { Exn } do
  test_assert.assert_raises(
    label: "mk4q8/bench: run on missing dir raises",
    body: fn () -> bool throws { Exn } do
      run_bench_subcommand(args: [ "--dir", "/tmp/nexus_mk4q8_no_such_dir_zzz" ])
      return false
    end
  )
  return ()
end

// ─── helper ─────────────────────────────────────────────────────────────────

let list_len = fn (xs: [ string ]) -> i64 do
  match xs do
    | [] -> 0
    | _ :: rest -> 1 + list_len(xs: rest)
  end
end

// ─── runner ─────────────────────────────────────────────────────────────────

let body = fn () -> unit require { Console, Fs } throws { Exn } do
  test_strip_no_args()
  test_strip_prog_name_only()
  test_strip_bench_keyword_present()
  test_strip_bench_only()
  test_strip_other_subcommand()
  test_strip_bench_with_iters()
  test_run_returns_1_on_empty_dir()
  test_run_raises_on_nonexistent_dir()
  return ()
end

let safe_run = fn () -> i64 require { Console, Fs } do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole, PermFs } do
  inject stdio.system_handler, fs_mod.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
