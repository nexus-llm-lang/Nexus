// Regression: inner `if c then return X end` (no else, nothing after match
// in the function body) inside a match arm must not fire the wrapped
// function's op_return on fall-through. See nexus-xnob.
import * as test_assert from "std:test/assert"

type Option<a> = Some(val: a) | None

let f = fn (b: bool) -> bool do
  match Some(val: b) do
    | Some(val: x) -> if x then return true end
    | None -> ()
  end
  return false
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_bool(
    actual: f(b: false),
    expected: false,
    label: "f(false) falls through to outer return"
  )
  test_assert.assert_eq_bool(
    actual: f(b: true),
    expected: true,
    label: "f(true) returns true from inner if"
  )
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
