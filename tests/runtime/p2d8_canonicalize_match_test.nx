// Regression / feature test for nexus-p2d8.2: HIR pattern-match
// canonicalization pass.
//
// Tests three observable properties of the canonicalization:
//
// Phase 1 (POr fusion): separate arms with identical literal/variable
// return bodies are fused into a single POr arm.  Semantics identical
// to the original multi-arm form.
//
// Phase 2 (arm sort): PCtor arms sorted by variant name — the decision
// tree sees them in a stable order; the compiled output is identical.
//
// Phase 3 (redundancy elimination): arms after the first wildcard are
// dead and are removed; reachable arms before the wildcard are kept.
//
// All assertions verify observable runtime behaviour — the pass is
// transparent, so correct outputs confirm semantics are preserved.
import * as test_assert from "std:test/assert"

type Color = Red | Green | Blue | Alpha
type Dir = North | South | East | West

// ─── Phase 1 examples ───────────────────────────────────────────────────────

// Before canonicalization this has three arms returning the same literal 1:
//   Red   -> return 1
//   Green -> return 1
//   Blue  -> return 1
// After phase 1 they fuse to: Red | Green | Blue -> return 1
let warm_or_cool = fn (c: Color) -> i64 do
  match c do
    | Red -> return 1
    | Green -> return 1
    | Blue -> return 1
    | Alpha -> return 0
  end
end

// Literal pattern dedup: arms for 1, 2, 3 all return 42.
let many_same = fn (x: i64) -> i64 do
  match x do
    | 1 -> return 42
    | 2 -> return 42
    | 3 -> return 42
    | _ -> return 0
  end
end

// ─── Phase 2 examples ───────────────────────────────────────────────────────

// Arms written in reverse constructor order (West, East, South, North).
// After phase 2 they are sorted; semantics unchanged.
let dir_tag = fn (d: Dir) -> i64 do
  match d do
    | West -> return 3
    | East -> return 2
    | South -> return 1
    | North -> return 0
  end
end

// ─── Phase 3 examples ───────────────────────────────────────────────────────

// Wildcard is NOT the last arm in the source; the arm after it is dead.
// Phase 3 removes the dead arm.
let safe_clamp = fn (c: Color) -> i64 do
  match c do
    | Alpha -> return -1
    | _ -> return 1
  end
end

// ─── Main ───────────────────────────────────────────────────────────────────

let main = fn () -> unit throws { Exn } do
  // Phase 1: POr fusion correctness
  test_assert.assert_eq_i64(actual: warm_or_cool(c: Red),   expected: 1, label: "phase1 Red")
  test_assert.assert_eq_i64(actual: warm_or_cool(c: Green), expected: 1, label: "phase1 Green")
  test_assert.assert_eq_i64(actual: warm_or_cool(c: Blue),  expected: 1, label: "phase1 Blue")
  test_assert.assert_eq_i64(actual: warm_or_cool(c: Alpha), expected: 0, label: "phase1 Alpha")

  test_assert.assert_eq_i64(actual: many_same(x: 1), expected: 42, label: "phase1 lit 1")
  test_assert.assert_eq_i64(actual: many_same(x: 2), expected: 42, label: "phase1 lit 2")
  test_assert.assert_eq_i64(actual: many_same(x: 3), expected: 42, label: "phase1 lit 3")
  test_assert.assert_eq_i64(actual: many_same(x: 9), expected: 0,  label: "phase1 lit other")

  // Phase 2: arm sort correctness (sorted arms must match same inputs)
  test_assert.assert_eq_i64(actual: dir_tag(d: North), expected: 0, label: "phase2 North")
  test_assert.assert_eq_i64(actual: dir_tag(d: South), expected: 1, label: "phase2 South")
  test_assert.assert_eq_i64(actual: dir_tag(d: East),  expected: 2, label: "phase2 East")
  test_assert.assert_eq_i64(actual: dir_tag(d: West),  expected: 3, label: "phase2 West")

  // Phase 3: redundancy elimination correctness
  test_assert.assert_eq_i64(actual: safe_clamp(c: Alpha), expected: -1, label: "phase3 Alpha")
  test_assert.assert_eq_i64(actual: safe_clamp(c: Red),   expected: 1,  label: "phase3 Red")
  test_assert.assert_eq_i64(actual: safe_clamp(c: Green), expected: 1,  label: "phase3 Green")

  return ()
end
