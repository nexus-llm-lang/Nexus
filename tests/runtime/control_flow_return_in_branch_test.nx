// Port of bootstrap/tests/runtime/control_flow.rs:
//   return_if_produces_correct_values,
//   return_match_produces_correct_values,
//   return_if_with_mutual_recursion_executes_correctly,
//   return_in_match_expr_branch_diverges_not_produces_value,
//   return_in_if_expr_branch_diverges_not_produces_value,
//   return_call_in_match_expr_branch_is_tail_call.
import * as test_assert from "std:test/assert"

type Color = Red | Green | Blue

let pick = fn (flag: bool) -> i64 do
  return if flag then 42 else 99 end
end

let to_num = fn (c: Color) -> i64 do
  return match c do
    | Red -> 1
    | Green -> 2
    | Blue -> 3
  end
end

let even = fn (n: i64) -> i64 do
  return if n == 0 then 1 else odd(n: n - 1) end
end

let odd = fn (n: i64) -> i64 do
  return if n == 0 then 0 else even(n: n - 1) end
end

// nexus-tuln regression: `return` inside a match-expr branch diverges and
// must not feed into the match's unified value.
let test_match_return = fn (flag: i64) -> i64 do
  let x = match flag do
    | 1 -> return 99
    | _ -> 0
  end
  return x + 1000
end

// Same regression but via if-expression value-extraction.
let test_if_return = fn (flag: i64) -> i64 do
  let x = if flag == 1 then return 77 else 0 end
  return x + 500
end

let helper = fn (n: i64) -> i64 do
  return n * 3
end

let test_tail_call_in_branch = fn (flag: i64) -> i64 do
  let x = match flag do
    | 1 -> return helper(n: 10)
    | _ -> 0
  end
  return x + 7777
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: pick(flag: true), expected: 42, label: "return if true")
  test_assert.assert_eq_i64(actual: pick(flag: false), expected: 99, label: "return if false")
  test_assert.assert_eq_i64(actual: to_num(c: Red), expected: 1, label: "return match Red")
  test_assert.assert_eq_i64(actual: to_num(c: Green), expected: 2, label: "return match Green")
  test_assert.assert_eq_i64(actual: to_num(c: Blue), expected: 3, label: "return match Blue")
  test_assert.assert_eq_i64(actual: even(n: 10), expected: 1, label: "even(10)")
  test_assert.assert_eq_i64(actual: odd(n: 10), expected: 0, label: "odd(10)")
  test_assert.assert_eq_i64(actual: test_match_return(flag: 1), expected: 99, label: "match early return diverges")
  test_assert.assert_eq_i64(actual: test_match_return(flag: 0), expected: 1000, label: "match fallthrough")
  test_assert.assert_eq_i64(actual: test_if_return(flag: 1), expected: 77, label: "if early return diverges")
  test_assert.assert_eq_i64(actual: test_if_return(flag: 0), expected: 500, label: "if fallthrough")
  test_assert.assert_eq_i64(actual: test_tail_call_in_branch(flag: 1), expected: 30, label: "tail call in match arm")
  test_assert.assert_eq_i64(actual: test_tail_call_in_branch(flag: 0), expected: 7777, label: "fallthrough w/o tail call")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
