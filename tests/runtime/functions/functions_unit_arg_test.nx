// Regression test for nexus-qfo96: passing a unit value as a call argument
// generated invalid wasm ("expected i64 but nothing on stack") because
// emit_atom(LirAtomUnit) is a no-op but the callee's wasm slot expects i64.
//
// Covers:
//   1. unit literal argument: take(x: ())
//   2. unit-typed variable argument: let u: unit = (); take(x: u)
//   3. unit arg through a HOF-style wrapper: id_unit(x: ())
//   4. fold-like recursion with a unit accumulator (idiomatic side-effect iteration)
import * as test_assert from "std:test/assert"

let take_unit_lit = fn (x: unit) -> i64 do return 42 end

let take_unit_var = fn (x: unit) -> i64 do return 99 end

// Returns unit — confirms unit-in / unit-out round-trips at the call boundary
let id_unit = fn (x: unit) -> unit do return () end

// Fold-style recursion with unit accumulator: counts i up to n, returning unit
let fold_unit_go = fn (i: i64, n: i64, acc: unit) -> unit do
  if i >= n then return acc
  else return fold_unit_go(i: i + 1, n, acc: id_unit(x: acc))
  end
end

let body = fn () -> unit throws { Exn } do
  // Case 1: unit literal argument
  test_assert.assert_eq_i64(
    actual: take_unit_lit(x: ()),
    expected: 42,
    label: "unit literal arg → 42"
  )

  // Case 2: unit-typed variable argument
  let u: unit = ()
  test_assert.assert_eq_i64(
    actual: take_unit_var(x: u),
    expected: 99,
    label: "unit var arg → 99"
  )

  // Case 3: unit-returning call used as an argument
  let _r3 = id_unit(x: ())
  test_assert.assert_eq_i64(
    actual: take_unit_lit(x: id_unit(x: ())),
    expected: 42,
    label: "unit-returning-call as arg → 42"
  )

  // Case 4: fold with unit accumulator (5 iterations, result ignored)
  let _r4 = fold_unit_go(i: 0, n: 5, acc: ())
  test_assert.assert_eq_i64(
    actual: take_unit_lit(x: ()),
    expected: 42,
    label: "unit arg after fold → 42"
  )

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
