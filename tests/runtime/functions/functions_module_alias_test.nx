import * as test_assert from "std:test/assert"
import * as math from "examples/math.nx"

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: math.add(a: 19, b: 23), expected: 42, label: "math.add(19, 23)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
