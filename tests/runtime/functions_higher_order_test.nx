// Port of bootstrap/tests/runtime/functions.rs:
//   higher_order_function_passed_as_argument,
//   higher_order_lambda_expression_passed_as_argument,
//   higher_order_function_stored_in_variable,
//   higher_order_function_multiple_params.
import * as test_assert from "std:test/assert"

let double = fn (x: i64) -> i64 do
  return x * 2
end

let add_one = fn (x: i64) -> i64 do
  return x + 1
end

let add = fn (a: i64, b: i64) -> i64 do
  return a + b
end

let apply = fn (f: (x: i64) -> i64, val: i64) -> i64 do
  return f(x: val)
end

let apply2 = fn (f: (a: i64, b: i64) -> i64, x: i64, y: i64) -> i64 do
  return f(a: x, b: y)
end

let body = fn () -> unit throws { Exn } do
  // Function passed as argument.
  test_assert.assert_eq_i64(actual: apply(f: double, val: 21), expected: 42, label: "apply(double, 21)")
  // Lambda passed as argument.
  test_assert.assert_eq_i64(
    actual: apply(f: fn (x: i64) -> i64 do return x + 1 end, val: 41),
    expected: 42,
    label: "apply(lambda, 41)",
  )
  // Stored in variable.
  let f = add_one
  test_assert.assert_eq_i64(actual: f(x: 41), expected: 42, label: "stored fn var")
  // Multiple params.
  test_assert.assert_eq_i64(actual: apply2(f: add, x: 19, y: 23), expected: 42, label: "apply2(add)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
