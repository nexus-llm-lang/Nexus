// Port of bootstrap/tests/runtime/control_flow.rs:
//   codegen_match_expr_literal_cases,
//   codegen_match_expr_variable_binding,
//   codegen_match_expr_with_function_call_in_case,
//   codegen_match_expr_bool_cases,
//   codegen_match_expr_constructor_pattern,
//   codegen_match_expr_nested_in_binop.
import * as test_assert from "std:test/assert"

type Color = Red | Green | Blue

let classify_lit = fn (x: i64) -> i64 do
  let result = match x do
    | 1 -> 10
    | 2 -> 20
    | _ -> 30
  end
  return result
end

let double_var = fn (x: i64) -> i64 do
  let result = match x do
    | v -> v + v
  end
  return result
end

let add = fn (a: i64, b: i64) -> i64 do
  return a + b
end

let compute_with_call = fn (x: i64) -> i64 do
  let result = match x do
    | 0 -> 0
    | n -> add(a: n, b: 100)
  end
  return result
end

let bool_to_int = fn (b: bool) -> i64 do
  let result = match b do
    | true -> 1
    | false -> 0
  end
  return result
end

let color_to_code = fn (c: Color) -> i64 do
  let result = match c do
    | Red -> 1
    | Green -> 2
    | Blue -> 3
  end
  return result
end

let nested_in_binop = fn (x: i64) -> i64 do
  let a = match x do
    | 1 -> 10
    | _ -> 20
  end
  return a + 5
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: classify_lit(x: 1), expected: 10, label: "match-expr lit 1")
  test_assert.assert_eq_i64(actual: classify_lit(x: 2), expected: 20, label: "match-expr lit 2")
  test_assert.assert_eq_i64(actual: classify_lit(x: 99), expected: 30, label: "match-expr lit _")
  test_assert.assert_eq_i64(actual: double_var(x: 21), expected: 42, label: "match-expr var")
  test_assert.assert_eq_i64(actual: compute_with_call(x: 5), expected: 105, label: "match-expr call")
  test_assert.assert_eq_i64(actual: bool_to_int(b: true), expected: 1, label: "match-expr bool true")
  test_assert.assert_eq_i64(actual: bool_to_int(b: false), expected: 0, label: "match-expr bool false")
  test_assert.assert_eq_i64(actual: color_to_code(c: Green), expected: 2, label: "match-expr ctor Green")
  test_assert.assert_eq_i64(actual: nested_in_binop(x: 1), expected: 15, label: "match-expr in binop 1")
  test_assert.assert_eq_i64(actual: nested_in_binop(x: 99), expected: 25, label: "match-expr in binop _")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
