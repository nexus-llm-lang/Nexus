// Boundary coverage for the `\u{...}` unicode-escape validation fix
// (nexus lexer `collect_hex_digits`). Confirms the fix does NOT over-reject
// the legal cases adjacent to the two rejected ones:
//
//   - `\u{10FFFF}` is the maximum valid Unicode scalar value and MUST be
//     accepted (it encodes to the 4 UTF-8 bytes F4 8F BF BF).
//   - `\u{0}` (an explicit single zero hex digit) MUST be accepted as
//     U+0000 — distinct from the now-rejected empty `\u{}` escape.
//
// The just-over case `\u{110000}` (reject) is covered by the negative
// fixture tests/negative/parser/unicode_escape_out_of_range.nx.
import * as str from "std:str"
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  // Max valid scalar value: the escape must resolve to U+10FFFF, identical
  // to building the codepoint directly, and occupy 4 UTF-8 bytes.
  let s_max = "\u{10FFFF}"
  test_assert.assert_eq_string(
    actual: s_max,
    expected: str.from_char_code(code: 1114111),
    label: "\\u{10FFFF} == from_char_code(1114111)"
  )
  test_assert.assert_eq_i64(
    actual: str.byte_length(s: s_max),
    expected: 4,
    label: "\\u{10FFFF} byte_length == 4"
  )

  // Explicit single zero digit: accepted as U+0000 (one-byte NUL string).
  // This must stay accepted even though the empty `\u{}` escape is rejected.
  let s_zero = "\u{0}"
  test_assert.assert_eq_string(
    actual: s_zero,
    expected: str.from_char_code(code: 0),
    label: "\\u{0} == from_char_code(0)"
  )
  test_assert.assert_eq_i64(
    actual: str.byte_length(s: s_zero),
    expected: 1,
    label: "\\u{0} byte_length == 1"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
