// Runtime lexicographic ordering on strings: <, <=, >, >= must compare the
// string payloads byte-wise (shorter prefix is less), NOT the packed
// (ptr<<32)|len handle. The packed-handle compare that codegen previously
// emitted was allocation-dependent and lexicographically wrong; this test
// pins the correct behavior and guards against regression.
import * as test_assert from "std:test/assert"

// Build a string from independent allocations so two equal-content strings
// land at different heap addresses — a packed-pointer compare would then give
// the wrong (allocation-order-dependent) answer.
let mk = fn (parts: [ string ]) -> string do
  match parts do
    | [] -> return ""
    | h :: t -> return h ++ mk(parts: t)
  end
end

let body = fn () -> unit throws { Exn } do
  // --- allocation robustness: equal content, independent allocations ---
  let app_a = mk(parts: [ "a", "p", "p" ])  // "app"
  let app_b = mk(parts: [ "ap", "p" ])      // "app", different address
  test_assert.assert_false(
    cond: app_a < app_b,
    label: "equal content, independent alloc: < is false"
  )
  test_assert.assert_false(
    cond: app_a > app_b,
    label: "equal content, independent alloc: > is false"
  )
  test_assert.assert_true(
    cond: app_a <= app_b,
    label: "equal content, independent alloc: <= is true"
  )
  test_assert.assert_true(
    cond: app_a >= app_b,
    label: "equal content, independent alloc: >= is true"
  )

  // --- less-than ---
  test_assert.assert_true(cond: "apple" < "banana", label: "apple < banana")
  test_assert.assert_false(cond: "banana" < "apple", label: "banana < apple is false")
  test_assert.assert_false(cond: "x" < "x", label: "equal not <")

  // --- prefix (shorter is less) ---
  test_assert.assert_true(cond: "app" < "apple", label: "prefix app < apple")
  test_assert.assert_false(cond: "apple" < "app", label: "apple < app (prefix) is false")
  test_assert.assert_true(cond: "app" <= "apple", label: "prefix app <= apple")

  // --- <= ---
  test_assert.assert_true(cond: "x" <= "x", label: "equal <=")
  test_assert.assert_true(cond: "abc" <= "abd", label: "abc <= abd")
  test_assert.assert_false(cond: "b" <= "a", label: "b <= a is false")

  // --- greater-than / >= ---
  test_assert.assert_true(cond: "banana" > "apple", label: "banana > apple")
  test_assert.assert_false(cond: "apple" > "banana", label: "apple > banana is false")
  test_assert.assert_true(cond: "apple" > "app", label: "apple > app (longer)")
  test_assert.assert_true(cond: "x" >= "x", label: "equal >=")
  test_assert.assert_false(cond: "a" >= "b", label: "a >= b is false")

  // --- single differing byte at the end ---
  test_assert.assert_true(cond: "abc" < "abd", label: "last-byte abc < abd")
  test_assert.assert_false(cond: "abd" < "abc", label: "last-byte abd < abc is false")

  // --- empty-string edges ---
  test_assert.assert_true(cond: "" < "a", label: "empty < a")
  test_assert.assert_false(cond: "a" < "", label: "a < empty is false")
  test_assert.assert_false(cond: "" < "", label: "empty < empty is false")
  test_assert.assert_true(cond: "" <= "", label: "empty <= empty")
  test_assert.assert_true(cond: "" >= "", label: "empty >= empty")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
