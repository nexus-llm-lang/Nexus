// Regression for nexus-s8wn: nested no-else if-let segfaulted at addr
// 0x65736c65 (= ASCII "else"), pointing at uninitialized fall-through
// pointer in lower_match_expr / if-let desugaring path.
//
// Status on current main (post-ssy2): the simple shape from the bd issue
// runs cleanly. This regression test guards the lowered shape against
// future regression by exercising the fall-through path on both inner-
// and outer-Nones plus the let-binding-bearing inner Some arm.
//
// NOTE: a deeper non-determinism (HashMap iteration order in
// `coalesce_wasm_locals`) makes this exact shape flake intermittently
// when imported with `std:test/assert` and multiple asserts. Filed
// separately — this test uses the simpler `let _ = 1 / ok` divergence
// so it survives a single build's local-allocation order; CI re-runs
// are not robust to it.

type Opt = OptSome(val: i64) | OptNone

let nested_use = fn (outer: Opt, inner: Opt) -> i64 do
  if let OptSome(val: x) = outer then
    if let OptSome(val: y) = inner then
      return x + y
    end
  end
  return 0
end

let nested_return = fn (outer: Opt, inner: Opt) -> i64 do
  if let OptSome(val: x) = outer then
    if let OptSome(val: y) = inner then
      let _z = x
      let _w = y
      return 99
    end
  end
  return 0
end

let main = fn () -> unit do
  let r1 = nested_use(outer: OptSome(val: 1), inner: OptSome(val: 2))
  let r2 = nested_use(outer: OptSome(val: 1), inner: OptNone)
  let r3 = nested_use(outer: OptNone, inner: OptSome(val: 2))
  let r4 = nested_return(outer: OptSome(val: 1), inner: OptSome(val: 2))
  // Expected: r1=3, r2=0, r3=0, r4=99. A miscompile lands a non-zero in
  // r2/r3 (fall-through stale slot, the original 0x65736c65 manifestation).
  let total = r1 + r2 + r3 + r4
  // 3 + 0 + 0 + 99 = 102. Anything else divides by zero below.
  let denom = total - 101
  let _ = 1 / denom
  return ()
end
