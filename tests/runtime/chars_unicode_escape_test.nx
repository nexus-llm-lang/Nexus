// Port of bootstrap/tests/runtime/chars.rs::char_unicode.
// The original test exercises '\u{1F600}' (emoji); Nexus chars are ASCII
// (0x00-0x7F), so this port substitutes ASCII codepoints to verify the
// '\u{NN}' hex escape syntax parses and lowers to the matching codepoint.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  let cap_a = '\u{41}'   // 0x41 = 'A'
  let zero = '\u{30}'    // 0x30 = '0'
  let tilde = '\u{7E}'   // 0x7E = '~'
  test_assert.assert_true(cond: cap_a == 'A', label: "'\\u{41}' == 'A'")
  test_assert.assert_true(cond: zero == '0', label: "'\\u{30}' == '0'")
  test_assert.assert_true(cond: tilde == '~', label: "'\\u{7E}' == '~'")
  // R-5 workaround: keep std:str alive so the bundler links stdlib.
  test_assert.assert_eq_i64(actual: 1, expected: 1, label: "stdlib-link tripwire")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
