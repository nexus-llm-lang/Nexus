// Regression for nexus-oxdb + nexus-v0j9: LIR autovectorize pass swaps
// calls to scalar `dst[i] = a[i] OP b[i]` reference loops (defined in
// `nxlib/stdlib/simd.nx`) for the matching SIMD intrinsic.
//
// The pass runs in `optimize_lir_with_effects` (src/ir/lir_opt.nx) after
// fusion+DCE. Detection is suffix-matched on the canonical LIR call
// targets and gated on the matching SIMD external being present in the
// program; both conditions are satisfied here because we import
// `std:simd` and call each `simd.scalar_*_array` directly.
//
// Numeric correctness gate: rewriting a scalar-helper call to its SIMD
// equivalent must preserve every lane bit-for-bit (both routines
// implement `dst[i] = a[i] OP b[i]` over `n_quads * lanes_per_quad`
// lanes with identical wraparound semantics). The byte-equality of the
// two output regions (post-rewrite "scalar" call — which after the pass
// IS the SIMD call — vs explicit SIMD call) is asserted here.
//
// Coverage (one assertion pair per autovectorize-table entry):
//   1. scalar_i32_add_array → i32x4_add_array  (oxdb baseline)
//   2. scalar_i32_mul_array → i32x4_mul_array
//   3. scalar_i32_sub_array → i32x4_sub_array
//   4. scalar_i64_mul_array → i64x2_mul_array
//   5. scalar_i64_sub_array → i64x2_sub_array
//
// The 0xFD-prefixed bytecode emission for the rewritten SIMD calls is
// verified by the build/scan harness alongside the existing simd
// autovectorize coverage.
//
// The test exits 0 on success (via `1 / ok`) and traps on any mismatch.

import * as mem from "std:runtime/mem"
import * as simd from "std:simd"
import * as test_assert from "std:test/assert"

let cmp_bytes = fn (a: i64, b: i64, n: i64) -> i64 do
  return cmp_bytes_go(a, b, n, idx: 0, eq: 0)
end

let cmp_bytes_go = fn (a: i64, b: i64, n: i64, idx: i64, eq: i64) -> i64 do
  if idx >= n then return eq end
  let av = mem.load_u8(addr: a + idx)
  let bv = mem.load_u8(addr: b + idx)
  let inc = if av == bv then 1 else 0 end
  return cmp_bytes_go(a, b, n, idx: idx + 1, eq: eq + inc)
end

let init_i32_seq = fn (base: i64, n: i64) -> unit do
  return init_i32_seq_go(base, n, idx: 0)
end

let init_i32_seq_go = fn (base: i64, n: i64, idx: i64) -> unit do
  if idx >= n then return () end
  let _ = mem.store_i32(addr: base + idx * 4, val: idx + 1)
  return init_i32_seq_go(base, n, idx: idx + 1)
end

let init_i64_seq = fn (base: i64, n: i64) -> unit do
  return init_i64_seq_go(base, n, idx: 0)
end

let init_i64_seq_go = fn (base: i64, n: i64, idx: i64) -> unit do
  if idx >= n then return () end
  let _ = mem.store_i64(addr: base + idx * 8, val: idx + 1)
  return init_i64_seq_go(base, n, idx: idx + 1)
end

let zero_region = fn (base: i64, n: i64) -> unit do
  return zero_region_go(base, n, idx: 0)
end

let zero_region_go = fn (base: i64, n: i64, idx: i64) -> unit do
  if idx >= n then return () end
  let _ = mem.store_i64(addr: base + idx, val: 0)
  return zero_region_go(base, n, idx: idx + 8)
end

let body = fn () -> unit throws { Exn } do
  // Reserve a fresh wasm page for scratch memory.
  let prev_pages = mem.grow(delta: 1)
  let base = prev_pages * 65536

  let a_addr = base
  let b_addr = base + 64
  let scal_addr = base + 128
  let simd_addr = base + 192
  let n_quads = 4

  // ── 1. i32 add: scalar_i32_add_array → i32x4_add_array ─────────────────
  init_i32_seq(base: a_addr, n: 16)
  init_i32_seq(base: b_addr, n: 16)
  zero_region(base: scal_addr, n: 64)
  zero_region(base: simd_addr, n: 64)

  let _ = simd.scalar_i32_add_array(a_addr, b_addr, dst_addr: scal_addr, n_quads)
  let _ = simd.i32x4_add_array(a_addr, b_addr, dst_addr: simd_addr, n_quads)

  test_assert.assert_eq_i64(actual: cmp_bytes(a: scal_addr, b: simd_addr, n: 64),
    expected: 64, label: "i32 add: scalar-rewrite vs explicit SIMD byte-equality")
  // Spot-check lanes: a[i] + b[i] with a[i]=b[i]=i+1.
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: scal_addr),
    expected: 2, label: "i32 add lane 0 == 2")
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: scal_addr + 60),
    expected: 32, label: "i32 add lane 15 == 32")

  // ── 2. i32 mul: scalar_i32_mul_array → i32x4_mul_array ─────────────────
  init_i32_seq(base: a_addr, n: 16)
  init_i32_seq(base: b_addr, n: 16)
  zero_region(base: scal_addr, n: 64)
  zero_region(base: simd_addr, n: 64)

  let _ = simd.scalar_i32_mul_array(a_addr, b_addr, dst_addr: scal_addr, n_quads)
  let _ = simd.i32x4_mul_array(a_addr, b_addr, dst_addr: simd_addr, n_quads)

  test_assert.assert_eq_i64(actual: cmp_bytes(a: scal_addr, b: simd_addr, n: 64),
    expected: 64, label: "i32 mul: scalar-rewrite vs explicit SIMD byte-equality")
  // a[0]*b[0] = 1*1 = 1; a[15]*b[15] = 16*16 = 256.
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: scal_addr),
    expected: 1, label: "i32 mul lane 0 == 1")
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: scal_addr + 60),
    expected: 256, label: "i32 mul lane 15 == 256")

  // ── 3. i32 sub: scalar_i32_sub_array → i32x4_sub_array ─────────────────
  init_i32_seq(base: a_addr, n: 16)
  init_i32_seq(base: b_addr, n: 16)
  zero_region(base: scal_addr, n: 64)
  zero_region(base: simd_addr, n: 64)

  let _ = simd.scalar_i32_sub_array(a_addr, b_addr, dst_addr: scal_addr, n_quads)
  let _ = simd.i32x4_sub_array(a_addr, b_addr, dst_addr: simd_addr, n_quads)

  test_assert.assert_eq_i64(actual: cmp_bytes(a: scal_addr, b: simd_addr, n: 64),
    expected: 64, label: "i32 sub: scalar-rewrite vs explicit SIMD byte-equality")
  // a[i]-b[i] = 0 for every lane (a==b).
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: scal_addr),
    expected: 0, label: "i32 sub lane 0 == 0")
  test_assert.assert_eq_i64(actual: mem.load_i32(addr: scal_addr + 60),
    expected: 0, label: "i32 sub lane 15 == 0")

  // ── 4. i64 mul: scalar_i64_mul_array → i64x2_mul_array ─────────────────
  // i64x2 has 2 lanes per quad, so n_quads=4 → 8 i64 lanes (64 bytes).
  init_i64_seq(base: a_addr, n: 8)
  init_i64_seq(base: b_addr, n: 8)
  zero_region(base: scal_addr, n: 64)
  zero_region(base: simd_addr, n: 64)

  let _ = simd.scalar_i64_mul_array(a_addr, b_addr, dst_addr: scal_addr, n_quads)
  let _ = simd.i64x2_mul_array(a_addr, b_addr, dst_addr: simd_addr, n_quads)

  test_assert.assert_eq_i64(actual: cmp_bytes(a: scal_addr, b: simd_addr, n: 64),
    expected: 64, label: "i64 mul: scalar-rewrite vs explicit SIMD byte-equality")
  // a[0]*b[0] = 1*1 = 1; a[7]*b[7] = 8*8 = 64.
  test_assert.assert_eq_i64(actual: mem.load_i64(addr: scal_addr),
    expected: 1, label: "i64 mul lane 0 == 1")
  test_assert.assert_eq_i64(actual: mem.load_i64(addr: scal_addr + 56),
    expected: 64, label: "i64 mul lane 7 == 64")

  // ── 5. i64 sub: scalar_i64_sub_array → i64x2_sub_array ─────────────────
  init_i64_seq(base: a_addr, n: 8)
  init_i64_seq(base: b_addr, n: 8)
  zero_region(base: scal_addr, n: 64)
  zero_region(base: simd_addr, n: 64)

  let _ = simd.scalar_i64_sub_array(a_addr, b_addr, dst_addr: scal_addr, n_quads)
  let _ = simd.i64x2_sub_array(a_addr, b_addr, dst_addr: simd_addr, n_quads)

  test_assert.assert_eq_i64(actual: cmp_bytes(a: scal_addr, b: simd_addr, n: 64),
    expected: 64, label: "i64 sub: scalar-rewrite vs explicit SIMD byte-equality")
  // a[i]-b[i] = 0 for every lane.
  test_assert.assert_eq_i64(actual: mem.load_i64(addr: scal_addr),
    expected: 0, label: "i64 sub lane 0 == 0")
  test_assert.assert_eq_i64(actual: mem.load_i64(addr: scal_addr + 56),
    expected: 0, label: "i64 sub lane 7 == 0")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
