// Port of bootstrap/tests/runtime/chars.rs:
//   char_literal_basic, char_literal_escape_sequences,
//   char_eq, char_ne, char_comparison.
import * as test_assert from "std:test/assert"

let body = fn () -> unit throws { Exn } do
  // char_literal_basic: bind a char literal.
  let _c = 'a'

  // char_literal_escape_sequences: every supported escape parses & lowers.
  let newline = '\n'
  let tab = '\t'
  let null_c = '\0'
  let backslash = '\\'
  let quote = '\''
  test_assert.assert_true(cond: newline == '\n', label: "escape '\\n'")
  test_assert.assert_true(cond: tab == '\t', label: "escape '\\t'")
  test_assert.assert_true(cond: null_c == '\0', label: "escape '\\0'")
  test_assert.assert_true(cond: backslash == '\\', label: "escape '\\\\'")
  test_assert.assert_true(cond: quote == '\'', label: "escape '\\''")

  // char_eq
  test_assert.assert_true(cond: 'a' == 'a', label: "equal chars are ==")
  test_assert.assert_false(cond: 'a' == 'b', label: "different chars are not ==")

  // char_ne
  test_assert.assert_true(cond: 'a' != 'b', label: "different chars are !=")
  test_assert.assert_false(cond: 'a' != 'a', label: "equal chars are not !=")

  // char_comparison: <, >, <=, >=
  test_assert.assert_true(cond: 'a' < 'b', label: "'a' < 'b'")
  test_assert.assert_true(cond: 'b' > 'a', label: "'b' > 'a'")
  test_assert.assert_true(cond: 'a' <= 'a', label: "'a' <= 'a'")
  test_assert.assert_true(cond: 'a' >= 'a', label: "'a' >= 'a'")
  test_assert.assert_false(cond: 'b' < 'a', label: "'b' not < 'a'")
  test_assert.assert_false(cond: 'a' > 'b', label: "'a' not > 'b'")
  // R-5 workaround: keep std:str alive so the bundler links stdlib
  // (otherwise the produced wasm omits wasi:cli/run).
  test_assert.assert_eq_i64(actual: 1, expected: 1, label: "stdlib-link tripwire")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
