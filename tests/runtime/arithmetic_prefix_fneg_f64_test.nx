// Port of bootstrap/tests/runtime/arithmetic.rs::codegen_prefix_unary_fneg_f64.
// Verifies `-.` (f64 negate) on var, literal, and parenthesized expression.
//
// Inline `abs_f64` instead of std:math::abs_float — see
// arithmetic_f64_literal_arith_test.nx for the rationale.
import * as test_assert from "std:test/assert"

let abs_f64 = fn (val: f64) -> f64 do
  if val <. 0.0 then return 0.0 -. val end
  return val
end

let close = fn (a: f64, b: f64) -> bool do
  let d = a -. b
  return abs_f64(val: d) <. 0.0001
end

let body = fn () -> unit throws { Exn } do
  let x = 3.5
  // `assert_eq_bool` keeps `std:str::from_bool` live so the bundler links
  // stdlib (and the produced component exports `wasi:cli/run`).
  test_assert.assert_eq_bool(actual: close(a: -.x, b: 0.0 -. 3.5), expected: true, label: "fneg var")

  let lit = -.1.5
  test_assert.assert_eq_bool(actual: close(a: lit, b: 0.0 -. 1.5), expected: true, label: "fneg lit")

  let parens = -.(x +. 1.0)
  test_assert.assert_eq_bool(actual: close(a: parens, b: 0.0 -. 4.5), expected: true, label: "fneg parens")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
