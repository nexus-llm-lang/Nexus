// Issue nexus-eoug — divergence detection for `nexus run --replay` (unit test).
//
// This test exercises the JSONL parsing path used by the replay logic:
// it constructs a synthetic "expected" session (from serialize_summary) and
// a "divergent" outcome, then validates that the structural diff fields
// (exit code, stdout content) are correctly extracted from the JSONL lines.
//
// The actual shell-layer assertion (`--replay FILE`) is integration-tested
// by the header.sh replay mode, which is exercised during the bootstrap
// smoke tests. This in-wasm unit test focuses on the correctness of the
// JSONL round-trip that the shell layer depends on.
//
// Coverage:
//   1. A recorded summary with exit_code=0 is parsed correctly.
//   2. A divergent summary (exit_code=1) is parsed correctly.
//   3. The kind field distinguishes entry / summary / stdout / stderr.
//   4. Multiple output lines from serialize_output are independent records.
//   5. A synthetic replay scenario: session exit=0, actual exit=1 → diverge.
//   6. A synthetic replay scenario: session exit=0, actual exit=0 → no diverge.

import * as test_assert from "std:test/assert"
import * as str from "std:str"
import * as list from "std:list"
import * as stdio from "std:stdio"
import { Console } from "std:stdio"
import { Option, Some, None } from "std:option"
import {
  EntryRecord, DiagRecord, DiagError,
  OutputRecord, OutputStdout, OutputStderr, SummaryRecord,
  serialize_entry, serialize_output, serialize_summary,
  jsonl_get_str, jsonl_get_i64, jsonl_get_kind, parse_summary
} from "src/tools/record_replay.nx"

// ── helpers ────────────────────────────────────────────────────────────────

/** Simulate "expected outcome" from a recorded session. */
let make_session = fn (exit_code: i64, stdout_lines: [ string ]) -> [ string ] do
  let entry = EntryRecord(
    source: "examples/hello.nx",
    source_hash: "deadbeef",
    argv: [ "examples/hello.nx", "--seed", "0", "--frozen-clock", "0" ],
    seed: Some(val: "0"),
    frozen_clock: Some(val: "0"),
    caps: [ "Console"],
    nexus_version: "cafebabe"
  )
  let entry_line = serialize_entry(r: entry)
  let out_lines = list.map(xs: stdout_lines, f: fn (line: string) -> string do
    return serialize_output(r: OutputRecord(kind: OutputStdout, ts_ms: 0, line))
  end)
  let summary_line = serialize_summary(r: SummaryRecord(exit_code, wall_ms: 100))
  let mid = list.concat(xs: [ entry_line ], ys: out_lines)
  return list.concat(xs: mid, ys: [ summary_line ])
end

/** Extract summary from the last line of a JSONL session. */
let session_summary = fn (lines: [ string ]) -> Option<SummaryRecord> do
  match list.reverse(xs: lines) do
    | [] -> return None
    | last :: _ -> return parse_summary(line: last)
  end
end

/** Count stdout lines in a JSONL session. */
let count_stdout_lines = fn (lines: [ string ]) -> i64 do
  count_stdout_go(xs: lines, acc: 0)
end

let count_stdout_go = fn (xs: [ string ], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | l :: rest ->
      let kind = jsonl_get_kind(line: l)
      let new_acc = if kind == "stdout" then acc + 1 else acc end
      return count_stdout_go(xs: rest, acc: new_acc)
  end
end

// ── tests ─────────────────────────────────────────────────────────────────

let test_parse_exit_code_0 = fn () -> unit throws { Exn } do
  let lines = make_session(exit_code: 0, stdout_lines: [ "Hello, world!"])
  match session_summary(lines) do
    | None -> throw RuntimeError(val: "eoug-div: session_summary returned None")
    | Some(val: SummaryRecord(exit_code: exit_code, wall_ms: _)) ->
      test_assert.assert_eq_i64(actual: exit_code, expected: 0,
        label: "eoug-div: recorded exit_code=0")
  end
  return ()
end

let test_parse_exit_code_nonzero = fn () -> unit throws { Exn } do
  let lines = make_session(exit_code: 1, stdout_lines: [])
  match session_summary(lines) do
    | None -> throw RuntimeError(val: "eoug-div: session_summary returned None for exit=1")
    | Some(val: SummaryRecord(exit_code: exit_code, wall_ms: _)) ->
      test_assert.assert_eq_i64(actual: exit_code, expected: 1,
        label: "eoug-div: recorded exit_code=1")
  end
  return ()
end

let test_kind_discrimination = fn () -> unit throws { Exn } do
  let lines = make_session(exit_code: 0, stdout_lines: [ "line1", "line2" ])
  // First line is entry, middle lines are stdout, last is summary
  match lines do
    | first :: _ ->
      test_assert.assert_eq_string(
        actual: jsonl_get_kind(line: first),
        expected: "entry",
        label: "eoug-div: first line is entry")
    | [] -> throw RuntimeError(val: "eoug-div: empty session")
  end
  match list.reverse(xs: lines) do
    | last :: _ ->
      test_assert.assert_eq_string(
        actual: jsonl_get_kind(line: last),
        expected: "summary",
        label: "eoug-div: last line is summary")
    | [] -> throw RuntimeError(val: "eoug-div: empty reversed session")
  end
  test_assert.assert_eq_i64(
    actual: count_stdout_lines(lines),
    expected: 2,
    label: "eoug-div: 2 stdout lines in session")
  return ()
end

let test_replay_diverge_exit_code = fn () -> unit throws { Exn } do
  // Session says exit=0; "actual" is exit=1 → diverge
  let session = make_session(exit_code: 0, stdout_lines: [ "output"])
  let session_exit = match session_summary(lines: session) do
    | None -> (0 - 999)  // sentinel
    | Some(val: SummaryRecord(exit_code: ec, wall_ms: _)) -> ec
  end
  let actual_exit = 1
  let diverged = session_exit != actual_exit
  test_assert.assert(cond: diverged, label: "eoug-div: exit code divergence detected")
  return ()
end

let test_replay_no_diverge = fn () -> unit throws { Exn } do
  // Session says exit=0; "actual" is exit=0 → no diverge
  let session = make_session(exit_code: 0, stdout_lines: [ "Hello, world!"])
  let session_exit = match session_summary(lines: session) do
    | None -> (0 - 999)
    | Some(val: SummaryRecord(exit_code: ec, wall_ms: _)) -> ec
  end
  let actual_exit = 0
  let diverged = session_exit != actual_exit
  test_assert.assert(cond: !diverged, label: "eoug-div: same exit codes → no diverge")
  return ()
end

let test_multiple_output_records = fn () -> unit throws { Exn } do
  let lines = make_session(exit_code: 0, stdout_lines: [ "a", "b", "c" ])
  test_assert.assert_eq_i64(
    actual: count_stdout_lines(lines),
    expected: 3,
    label: "eoug-div: 3 independent stdout output records")
  return ()
end

let test_entry_source_field = fn () -> unit throws { Exn } do
  let lines = make_session(exit_code: 0, stdout_lines: [])
  match lines do
    | entry_line :: _ ->
      match jsonl_get_str(line: entry_line, key: "source") do
        | Some(val: src) ->
          test_assert.assert_eq_string(
            actual: src,
            expected: "examples/hello.nx",
            label: "eoug-div: entry source field correct")
        | None -> throw RuntimeError(val: "eoug-div: entry source field absent")
      end
    | [] -> throw RuntimeError(val: "eoug-div: empty session")
  end
  return ()
end

// ── runner ────────────────────────────────────────────────────────────────

let body = fn () -> unit throws { Exn } do
  test_parse_exit_code_0()
  test_parse_exit_code_nonzero()
  test_kind_discrimination()
  test_replay_diverge_exit_code()
  test_replay_no_diverge()
  test_multiple_output_records()
  test_entry_source_field()
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let ok = safe_run()
    1 / ok
    return ()
  end
end
