// Port of bootstrap/tests/runtime/control_flow.rs:
//   codegen_while_loop_basic, codegen_while_loop_false_condition_never_executes.
import * as test_assert from "std:test/assert"

let sum_first_5 = fn () -> i64 do
  let ~sum = 0
  let ~i = 0
  while ~i < 5 do
    ~sum <- ~sum + ~i
    ~i <- ~i + 1
  end
  return ~sum
end

let while_false = fn () -> i64 do
  let ~x = 0
  while false do
    ~x <- 999
  end
  return ~x
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: sum_first_5(), expected: 10, label: "sum 0..5")
  test_assert.assert_eq_i64(actual: while_false(), expected: 0, label: "while false never runs")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
