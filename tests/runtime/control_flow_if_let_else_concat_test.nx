// Port of bootstrap/tests/runtime/control_flow.rs::codegen_if_let_else_string_fn_call_result_concat.
// Regression for nexus-ssy2: `if let Some(val: o) = opt then o else <fn>() end`
// where the match-result type was incorrectly inferred as i64 when bindings
// weren't pre-populated in semantic_vars.
import * as test_assert from "std:test/assert"

type Option<a> = Some(val: a) | None

let get_default = fn () -> string do
  return "default"
end

let resolve = fn (opt: Option<string>) -> string do
  let path = if let Some(val: o) = opt then o else get_default() end
  return "got: " ++ path
end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_string(actual: resolve(opt: None), expected: "got: default", label: "if-let else fn-call (None)")
  test_assert.assert_eq_string(actual: resolve(opt: Some(val: "explicit")), expected: "got: explicit", label: "if-let else fn-call (Some)")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
