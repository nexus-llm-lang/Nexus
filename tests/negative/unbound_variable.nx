// expect-fail: E2001
// expect-msg: unbound variable
//
// Variables must be in scope at the reference site. Typos and missing
// `import` lines both surface as the same "unbound variable" diagnostic
// — fix by adding the binding, correcting the spelling, or importing
// the symbol from the right module.

let main = fn () -> unit do
  let _ = undefined_var
  return ()
end
