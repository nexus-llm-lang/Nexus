// expect-fail: E2001
//
// nexus-987xh: a selectively-imported constructor must bind the constructor of
// the *imported* module, not silently resolve to a same-named constructor of a
// different enum that happens to be visible whole-program.
//
// `MkV` is imported from `ctor_collision_color.nx` (type Color). Passing
// `MkV(n: 5)` to `size_to_int` (which expects `Size` from the other module)
// must therefore be a TYPE ERROR (Color vs Size). Before the fix, `MkV`
// silently resolved to the other module's `Size` ctor (last-import-wins) and
// the program type-checked + ran, printing 2005.

import { Color, MkV } from "tests/_fixtures/ctor_collision_color.nx"
import { Size, size_to_int } from "tests/_fixtures/ctor_collision_size.nx"

let consume = fn (n: i64) -> unit do
  return ()
end

let main = fn () -> unit do
  let v = MkV(n: 5)
  consume(n: size_to_int(s: v))
  return ()
end
