// expect-fail: E2025
// expect-msg: unknown constructor
// expect-msg: ParseStep
//
// D-Export (nexus-8xke): non-exported enum constructors must not be visible
// to importing modules.  `ParseStep` in `std:json` is a non-exported type
// (`type ParseStep = ...` without the `export` keyword).  Attempting to
// construct `ParseStep(...)` from an importing module should fail with an
// "unknown constructor" error (E2025 since nexus-bpjd; previously E2001).

import * as json from "std:json"

let main = fn () -> unit do
  let _ = ParseStep(value: json.null(), pos: 0)
  return ()
end
