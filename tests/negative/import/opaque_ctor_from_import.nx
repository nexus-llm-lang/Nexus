// expect-fail: E2025
// expect-msg: unknown constructor
// expect-msg: HashMap
//
// D-Type-Sum-Opaque (type-system-formal.md §D-Type-Sum-Opaque): when an
// opaque enum is imported, its constructors are withheld from the importing
// module's type environment. Only the type name itself enters typedef (so
// the type can be used as an annotation), but constructor schemes are NOT
// registered, making `Ctor(...)` expressions and `Ctor(...)` patterns
// unreachable for importing code.
//
// `HashMap` in `std:hashmap` is declared `export opaque type HashMap = HashMap(id: i64)`.
// The constructor `HashMap` must be invisible outside `std:hashmap`.
// Attempting to call `HashMap(id: 0)` from a different module should
// throw an "unknown constructor: HashMap" error (E2025 since nexus-bpjd
// added a dedicated UnknownConstructor diagnostic; previously E2001).
//
// nexus-110m

import { HashMap } from "std:hashmap"

let main = fn () -> unit do
  HashMap(id: 0)
  return ()
end
