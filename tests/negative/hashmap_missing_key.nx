// expect-runtime-throw: before lookup
//
// `std:hashmap.get` returns the safe `Lookup = Found(value: i64) |
// Missing` ADT — it never raises. The error path of "value must be
// present" is therefore caller-driven: pattern-match `Missing` and
// decide whether to fall back, fail, or throw. This fixture
// demonstrates the "throw on Missing" idiom: a helper turns a Lookup
// into a value-or-exception, and `main` hits the throw arm because
// key 42 was never inserted. wasmtime swallows the constructor name
// on stderr, so the runner anchors on the captured stdout line
// "before lookup".
//
// Idiomatic alternative: use `get_or(map, key, default)` for a safe
// fallback, or keep the `Lookup` value and pattern-match in-place.

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"
import * as hm from "std:hashmap"
import { Found, Missing } from "std:hashmap"

exception MissingKey(key: i64)

let raise_if_missing = fn (result: hm.Lookup, key: i64) -> i64 throws { MissingKey } do
  match result do
    | Found(value: v) -> return v
    | Missing -> throw MissingKey(key: key)
  end
end

let main = fn () -> unit require { PermConsole } throws { MissingKey } do
  inject system_handler do
    let %m = hm.empty()
    let %m = hm.put(map: m, key: 1, value: 100)
    Console.println(val: "before lookup")
    // Take a safe (non-throwing) `Lookup` snapshot through the borrow, then
    // free the linear map *before* deciding to raise: the throw must not
    // leave `%m` live on the throw path (E0540). The runtime still observes
    // the uncaught `MissingKey` (key 42 was never inserted).
    let result = hm.get(map: &m, key: 42)
    hm.free(map: m)
    raise_if_missing(result: result, key: 42)
    Console.println(val: "should never print")
  end
  return ()
end
