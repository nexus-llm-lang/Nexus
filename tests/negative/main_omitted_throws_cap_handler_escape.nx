// expect-runtime-throw: before throw
//
// Regression for nexus-mtz6c (Part A): when `main` and an intermediate
// caller both OMIT their `throws` clause, a checked exception raised by a
// capability handler arm used to ESCAPE TO THE HOST UNCAUGHT at runtime
// ("thrown Wasm exception"), because src/ir/main_wrap.nx only installed the
// catch-all wrapper for a non-empty DECLARED throws-row — an omitted clause
// reads as the implicit-absent sentinel and was left un-wrapped.
//
// After the fix the main-wrap pass recognises the implicit-absent-throws
// sentinel (for a valid `() -> unit` entry, non-component build) and installs
// the catch-all, so the propagated `RuntimeError` becomes a controlled
// `proc_exit(1)`: a clean non-zero exit instead of a raw host escape (which
// is the twyov fiber-double-free hazard).
//
// `caller` omits `throws`; it calls a cap method whose handler arm throws.
// `main` omits `throws`. Both stay un-annotated on purpose — that is the
// shape the host-escape required.
import * as stdio from "std:stdio"
import { Console } from "std:stdio"

cap Boom do
  fn detonate() -> unit throws { RuntimeError }
end

let h = handler Boom do
  fn detonate() -> unit throws { RuntimeError } do
    throw RuntimeError(val: "boom from handler arm")
  end
end

// Intermediate caller deliberately OMITS its `throws` clause.
let caller = fn () -> unit require { Boom } do
  Boom.detonate()
  return ()
end

// `main` deliberately OMITS its `throws` clause.
let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    inject h do
      Console.println(val: "before throw")
      caller()
      Console.println(val: "should never print")
    end
  end
  return ()
end
