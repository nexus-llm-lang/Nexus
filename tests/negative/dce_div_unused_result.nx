// expect-runtime-throw: integer divide by zero
// expect-msg: before divide
//
// Regression test for unsound DCE: a division-by-zero whose result is
// unused must NOT be eliminated. The bare statement `1 / z` (with z=0
// at runtime) lowers to `i64.div_s` and must still trap even though
// no binding consumes the result.

import { Console, system_handler } from "std:stdio"

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let z = 0
    Console.println(val: "before divide")
    let unused = 1 / z
    Console.println(val: "should never print")
  end
  return ()
end
