// expect-fail: E2001
// expect-msg: exception B raised by callee not admitted by caller's throws row
//
// Negative control for the or-pattern catch-residual fix: an or-pattern catch
// arm that does NOT cover every thrown variant must still be rejected against
// `throws {}`. Here `src` throws { A, B } but the catch only handles A (the
// `A(x: _) | A(x: _)` alternatives are both A), so B escapes the try/catch and
// the closed `throws {}` annotation must fail. This proves the residual
// subtraction is scoped to the alternatives actually present, not the whole
// thrown set.
//
// This file intentionally fails to compile.

exception A(x: i64)
exception B(x: i64)

let src = fn () -> i64 throws { A, B } do
  throw A(x: 1)
end

let safe = fn () -> i64 throws {} do
  try
    return src()
  catch
    | A(x: _) | A(x: _) -> return 0
  end
end

let main = fn () -> unit do
  let _v = safe()
  return ()
end
