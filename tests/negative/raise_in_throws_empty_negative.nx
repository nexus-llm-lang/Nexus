// expect-fail: E2001
// expect-msg: throws {}
// expect-msg: no exceptions are permitted
//
// T-Raise enforcement (nexus-r7gv): a function that explicitly declares
// `throws {}` (closed empty throws-row) must not contain any `raise`
// expression.  The typechecker must reject any such raise with a
// descriptive error message.
//
// Previously the typechecker silently accepted raises inside `throws {}`
// functions due to a P5 carve-out in `check_raise_admitted` that treated
// the closed-empty row `TyRow([], None)` as "unspecified throws".
// The carve-out has been removed; `throws {}` now enforces P5 strictly.

exception Tag(code: i64)

let main = fn () -> unit throws {} do
  raise Tag(code: 42)
end
