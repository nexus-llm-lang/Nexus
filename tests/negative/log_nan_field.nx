// expect-runtime-throw: before render
//
// `std:log.render_record_json` builds a full JSON-Lines record and
// delegates to `std:json.serialize`. When a field carries
// `JsonFloat(NaN)`, the serialiser raises `JsonError` — JSON does not
// permit NaN. The fixture compiles cleanly because `main` widens the
// throws-row with `JsonThrow`, but the exception surfaces as a non-zero
// exit at run time. wasmtime swallows the constructor name on stderr,
// so the runner anchors on the captured stdout line "before render".
//
// Note: the `console_logger` and `json_logger` reference handlers
// catch `JsonThrow` internally (a `try/catch` wraps the formatter call)
// so they never propagate serialisation failures to the caller. This
// fixture bypasses the handler abstraction and calls the exported
// `render_record_json` directly to expose the underlying throw.
//
// Idiomatic alternative: guard NaN fields before attaching them, or
// use `field_str(key, value: from_float(nan_val))` which renders the
// value as the string "NaN" (valid JSON) rather than a bare JSON float.

import { Console, system_handler } from "std:stdio"
import * as log from "std:log"
import * as math from "std:math"
import { JsonThrow } from "std:json"

let main = fn () -> unit require { PermConsole } throws { JsonThrow } do
  inject system_handler do
    Console.println(val: "before render")
    // sqrt of a negative float → IEEE-754 NaN (math.sqrt never throws)
    let neg = 0.0 -. 1.0
    let nan_val = math.sqrt(val: neg)
    let field = log.field_f64(key: "score", value: nan_val)
    let _ = log.render_record_json(level: log.Info, ts: 0, msg: "test", fields: [field])
    Console.println(val: "should never print")
  end
  return ()
end
