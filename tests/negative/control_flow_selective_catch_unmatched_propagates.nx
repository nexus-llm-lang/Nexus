// expect-runtime-throw: before call
//
// nexus-7hbia: a selective `catch` whose thrown exception matches no arm must
// re-throw (propagate) the original exception rather than running the wrong arm
// against a foreign payload. With no outer handler the propagated exception
// reaches the top level and surfaces to wasmtime as a non-zero exit.
//
// Before the fix this returned 105 (`A`'s arm running with `v` read from `B`'s
// payload) and exited 0 — silently swallowing the exception and executing the
// wrong arm. The captured stdout line "before call" is the substring the runner
// matches to confirm the program ran up to (but the throw escaped past) the call.
import { print_str } from "std:runtime/sysio"

exception A(x: i64)
exception B(x: i64)

let f = fn () -> i64 throws { Exn } do
  try throw B(x: 5)
  catch | A(x: v) -> return 100 + v end
end

let main = fn () -> unit throws { Exn } do
  print_str(s: "before call\n")
  let _v = f()
  print_str(s: "after call\n")
  return ()
end
