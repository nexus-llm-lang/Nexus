// expect-runtime-throw: integer divide by zero
// expect-msg: before divide
//
// Integer division by zero is a wasm-level trap (not a user-visible
// `Exn`). `std:math` mediates the safe path through `mod_i64`, which
// raises the `DivisionByZero` exception (so callers can `try/catch`),
// but the bare `/` operator on `i64` lowers straight to `i64.div_s`
// and the runtime has no opportunity to surface a constructor — the
// trap message comes from wasmtime itself.
//
// Idiomatic alternative: guard the divisor (`if b == 0 then ... end`)
// or use a checked helper such as `std:math.mod_i64` and `try` the
// result.

import { Console, system_handler } from "std:stdio"

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: "before divide")
    let quotient = 10 / 0
    Console.println(val: "should never print")
  end
  return ()
end
