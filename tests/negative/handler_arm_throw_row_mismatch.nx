// expect-fail: E2001
// expect-msg: throws row does not match port
// expect-msg: T-Handler
//
// T-Handler spec premise: each arm's throw_row must equal the corresponding
// port method's declared throw_row.  Here the port declares `throws { Exn }`
// on `transform`, but the handler arm declares `throws {}` (empty).  The
// cross-validation in register_handler_bindings must fire E2001.
//
// nexus-rkun

cap Transformer do
  fn transform(x: i64) -> i64 throws { Exn }
end

let bad_transformer = handler Transformer do
  fn transform(x: i64) -> i64 do
    return x + 1
  end
end

let main = fn () -> unit do
  return ()
end
