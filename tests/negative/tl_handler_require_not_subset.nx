// expect-fail: E2016
// expect-msg: requires capability
// expect-msg: PermConsole
// expect-msg: ambient require row
//
// T-Inject ∀i. ρ_i ⊆ ρ_q premise (docs/spec/type-system-formal.md §T-Inject)
// must fire for top-level handler bindings, not just inline handlers.
//
// Before the fix, hir.nx::process_tl_let destructured
//   Handler(port_name: pname, requires: _, arms: handler_arms)
// dropping the `requires` annotation.  synthesize_handler then built a
// HirHandlerBinding with an empty requires row, so register_handler_bindings
// always registered TyHandler with requires={}, and
// check_inject_require_subset saw an empty row — E2016 never fired.
//
// `console_logger` is a *top-level* handler binding that declares
// `require { PermConsole }`.  `main` has an empty require row (default).
// Injecting `console_logger` inside `main` must be rejected with E2016.
//
// nexus-lv2p

cap Logger do fn log(msg: string) -> unit end

let console_logger = handler Logger require { PermConsole } do
  fn log(msg: string) -> unit do return () end
end

let main = fn () -> unit do
  inject console_logger do
    return ()
  end
end
