// expect-fail: E2013
// expect-msg: unknown capability
//
// T-Handler wfCap (nexus-otx1): the `require { … }` row of an inline
// handler expression must satisfy wfCap — every named entry must be a
// system capability (PermFs, PermNet, PermConsole, PermRandom, PermClock,
// PermProc, PermEnv) or a port declared by `cap`.
//
// `NotARealCap` is not in SysCaps and is not a declared port, so the
// inline handler `handler Logger require { NotARealCap }` must be rejected
// with E2013 (UnknownCapability).
//
// Before the fix, wfCap was only called for top-level handler bindings
// in check_program_wf_rows; inline handler expressions in let-RHS
// position were not checked, so the typo silently passed typechecking.
//
// nexus-otx1

cap Logger do fn log(msg: string) -> unit end

let main = fn () -> unit do
  let bad_logger = handler Logger require { NotARealCap } do
    fn log(msg: string) -> unit do return () end
  end
  return ()
end
