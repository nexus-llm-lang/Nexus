// expect-fail: E2015
// expect-msg: inject site lists two handlers for the same cap
// expect-msg: Greeter
//
// T-Inject (docs/spec/type-system-formal.md) carries the premise
// ∀i≠j. P_i ≠ P_j: each cap may appear at most once in an inject
// site. Two handlers for the same cap `Greeter` would make method
// dispatch under `x.say(...)` ambiguous between the two arms.
// The typechecker enforces this statically and rejects with E2015.
//
// nexus-zk02

cap Greeter do fn say() -> unit end

let main = fn () -> unit do
  let h1 = handler Greeter do
    fn say() -> unit do return () end
  end
  let h2 = handler Greeter do
    fn say() -> unit do return () end
  end
  inject h1, h2 do
    return ()
  end
end
