// expect-fail: E2001
// expect-msg: P-Ctor
//
// Spec P-Ctor {ℓ'} = {ℓ}: the label at each field position in a constructor
// pattern must match the label declared on the constructor at that position.
// Reordered labels (e.g. Point(y: a, x: b) for Point(x, y)) silently bind
// `a` to the type of the first field `x` instead of the intended `y`, so
// they must be rejected.

type Point = Point(x: i64, y: i64)

// Reordered labels: `y` appears first but the constructor declares `x` first.
let reordered = fn (p: Point) -> i64 do
  match p do
    | Point(y: a, x: b) -> return a + b
  end
end

let main = fn () -> unit do
  let _ = reordered(p: Point(x: 1, y: 2))
  return ()
end
