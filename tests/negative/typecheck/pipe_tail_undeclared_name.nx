// expect-fail: E2031
// expect-msg: must be a row variable
//
// Negative fixture (wfThrow pipe-tail): an UNDECLARED name in pipe-tail
// position is malformed. `Zzz` is neither a bound `<R>` quantifier nor a
// declared exception, so the pipe form `{ E | Zzz }` cannot open the row over
// a row variable. Before the fix the tail was silently accepted as
// fully-open with no wfThrow applied to it. The diagnostic points the user to
// the comma form `{ E, F }` for an inclusive closed list.

exception E

let g = fn () -> i64 throws { E | Zzz } do throw E end

let main = fn () -> unit do
  return ()
end
