// expect-fail: E2013
// expect-msg: unknown capability
// expect-msg: BogusCap
//
// wfCap (docs/spec/type-system-formal.md §1 line 112) is enforced at
// every introduction site of a require row: the fn-arrow `require {…}`
// on `main` here. The spec's rationale, line 112: "a typo such as
// `require { Logr }` (intended `Logger`) would propagate as an
// uninhabitable row entry and surface only at a use site that happens
// to look it up". `BogusCap` is neither a system capability (the closed
// `PermFs` / `PermConsole` / … set) nor a port declared by `cap X`, so
// the introduction-site check rejects it here rather than letting it
// silently escape into codegen.
//
// nexus-t9cl.24

let main = fn () -> unit require { BogusCap } do
  return ()
end
