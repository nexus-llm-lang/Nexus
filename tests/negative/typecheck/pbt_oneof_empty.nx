// expect-runtime-throw: before oneOf
//
// `std:pbt.oneOf` picks uniformly among a list of generators. Its first
// step is `list.head(gs)` to extract a fallback generator; that partial
// function raises `EmptyList` (member of `ListError`) when the list is
// empty. The fixture compiles cleanly — the throws-row is widened with
// `ListError` — but executing it hits the empty-list arm and surfaces
// the exception as a non-zero exit at run time. wasmtime swallows the
// constructor name on stderr, so the runner anchors on the captured
// stdout line "before oneOf".
//
// Idiomatic alternative: always pass a non-empty list to `oneOf`, or
// guard the list with a length check before calling it. Passing a
// single-element list `[g]` is the degenerate-but-valid form.

import { Console, system_handler } from "std:stdio"
import * as pbt from "std:pbt"
import { ListError } from "std:list"

let main = fn () -> unit require { PermConsole } throws { ListError } do
  inject system_handler do
    Console.println(val: "before oneOf")
    // An empty generator list: oneOf calls list.head([]) → EmptyList.
    let gs : [ pbt.Gen<i64> ] = []
    let _ = pbt.oneOf(gs: gs)
    Console.println(val: "should never print")
  end
  return ()
end
