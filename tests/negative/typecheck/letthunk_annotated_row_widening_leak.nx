// expect-fail: E2001
// expect-msg: throws row mismatch
//
// Soundness test for T-LetThunk annotated-row widening leak (nexus-5djpx),
// the let-binding-site sibling of the T-Force leak (nexus-fy025).
//
// When a thunk binding carries an explicit annotation
// `let @t : @(τ throws {ρ})`, T-LetThunk types the suspended body under a
// fresh collecting throws-row and pins the body's raised exceptions into it
// via T-Raise.  Prior to the fix, `infer_thunk` returned the thunk type with
// the BARE (unsubstituted) collecting throws-row variable, so the downstream
// annotation unify in `infer_let_eval` saw an UNBOUND throw_row and silently
// bound it to the annotation's narrower `throws {}` row — widening the body's
// deferred `{ProbeF}` away.  At runtime the exception then escaped a function
// whose declared throws row is `{}` (P5 exception-containment hole; runtime
// witness threw an uncaught Wasm exception).
//
// After the fix: `infer_thunk` resolves the collecting rows through the
// accumulated substitution before returning the thunk type, so the annotation
// unify sees `{ProbeF}` vs `{}` and rejects (U-Thunk row unification),
// mirroring the concrete-label surfacing of nexus-fy025.

exception ProbeF(why: i64)

// `caller` declares throws {} but binds an annotated thunk whose body raises
// ProbeF under an annotation that also claims throws {}.  Prior to the fix this
// was accepted (unsound) and escaped at runtime; after the fix it must reject.
let caller = fn () -> i64 throws {} do
  let @t: @(i64 throws {}) = throw ProbeF(why: 42)
  let v = @t
  return v
end

let main = fn () -> unit throws {} do
  let n = caller()
  return ()
end
