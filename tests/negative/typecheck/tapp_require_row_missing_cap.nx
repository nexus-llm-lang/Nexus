// expect-fail: E2001
// expect-msg: call f: callee requires capability
// expect-msg: ambient require row
//
// Negative fixture for T-App capability-row enforcement:
// a function `pure_call` with an empty require row calls its parameter `f`
// which declares `require { Net }`. T-App must discharge the callee's require
// row against the ambient require row — the empty `{}` cannot cover `{Net}`,
// so this must be rejected.

cap Net do
  fn fetch() -> i64
end

let pure_call = fn (f: () -> i64 require { Net }) -> i64 require {} do
  return f()
end

let main = fn () -> unit do
  return ()
end
