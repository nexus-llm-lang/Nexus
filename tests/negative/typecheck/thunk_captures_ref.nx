// expect-fail: E2001
// expect-msg: thunk captures mutable ref binding
// expect-msg: x
// expect-msg: stack-confined
//
// Spec T-Lambda (docs/spec/type-system-formal.md) imposes the no-ref-capture
// premise on any deferred computation that may outlive / be forced outside its
// declaring frame:
//   ∀ x ∈ fv(s) ∩ dom(Γ). Γ(x) ≠ ~σ
//
// A `let @t = e` binding suspends `e` into a thunk (`@`). A thunk may be forced
// later, returned out of its frame, or forced in parallel — exactly the escape
// risk that makes T-Lambda reject a closure capturing a `~`-mutable ref. Here
// `~x` is a stack-confined mutable ref bound inside `make_thunk`; the thunk
// `let @t = ~x + 1` reads it. If the thunk escapes (it is returned as the
// function's `@i64` result and forced by the caller), the captured ref would
// dangle / be parallel-forced.
//
// The lambda introduction rule already rejects the analogous case ("lambda
// captures mutable ref binding x (refs are stack-confined)") and the handler
// arm rule mirrors it ("handler arm captures mutable ref binding ..."); the
// thunk-introduction path must reject it too — that's the nexus-vi3v3 fix.
//
// Implementation: src/typecheck/infer/stmt_eval.nx (infer_let_impl) scans the
// `Thunk`-wrapped rhs against the construction-site env via
// capture.scan_thunk_captures and converts a RefCaptureHit into the
// "thunk captures mutable ref binding ..." diagnostic — mirroring infer_lambda's
// rejection path so the introduction rules report identically-shaped errors.
//
// nexus-vi3v3

let make_thunk = fn () -> @i64 do
  let ~x = 42
  let @t = ~x + 1
  return @t
end

let main = fn () -> unit do
  let @r = make_thunk()
  let v = @r
  return ()
end
