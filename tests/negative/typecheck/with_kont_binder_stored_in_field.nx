// expect-fail: E2001
// expect-msg: continuation binder
// expect-msg: forced directly
//
// A second genuinely-unsafe escape of a `with @k` continuation binder: storing
// it in a constructor field, then re-extracting and forcing it. The binder `k`
// is packed into `B(k: k)`; the destructured `kk` is bound by a PATTERN, not by a
// bare `let`-alias, so it is never registered in the MIR cont-binder set. The
// `@kk` therefore lowers to a GENERIC thunk force over the continuation's i64
// table-slot index (dereferenced as a heap pointer) instead of `op_resume` — a
// runtime SIGSEGV (rc 139) before this fix.
//
// Stashing the binder in an aggregate field is exactly the kind of indirection
// MIR cannot follow back to a resume, so it is rejected at TYPECHECK
// (check_cont_no_escape: the Ctor case walks the binder argument and flags it).
// Only a direct `@k`, a bare `let`-alias `@kk`, and passing the binder to a
// non-forcing slot-reading intrinsic (`kont_slot`) are supported.

cap Co do
  fn ask() -> i64
end

type Box = B(k: @i64)

let h = handler Co do
  fn ask() -> i64 with @k do
    let bx = B(k: k)
    let B(k: kk) = bx
    @kk
  end
end

let drive = fn () -> i64 do
  inject h do
    let v = Co.ask()
    v
  end
end

let main = fn () -> unit do
  let r = drive()
  return ()
end
