// expect-fail: E2001
// expect-msg: must include a catch-all arm
//
// nexus-tgv4k: T-Match requires a syntactic catch-all when matching an
// `Exn`-typed value — there is no residual channel, so an unmatched value is a
// stuck dispatch. This holds even inside a catch body.
//
// Previously the typechecker suppressed the `hasCatchAll` premise whenever it
// was inside a catch body (on the false premise that unmatched variants would
// propagate via WASM EH), so this bare `match e` on the catch param `e: Exn`
// was wrongly admitted. The selective-`catch` desugar now appends its OWN
// synthetic catch-all re-throw arm, so the *desugared* catch match is exhaustive
// without any suppression — and a USER's bare `match e` like the one below has
// no such arm and is correctly rejected.
exception NotFound
exception PermDenied
exception IOError

let inner = fn () -> unit throws { NotFound, PermDenied, IOError } do
  throw IOError
end

let handle = fn () -> i64 throws { Exn } do
  try
    inner()
    return 0
  catch e ->
    match e do
      | NotFound -> return 1
      | PermDenied -> return 2
    end
  end
end

let main = fn () -> unit throws { Exn } do
  let _v = handle()
  return ()
end
