// expect-fail: E2001
// expect-msg: does not match any parameter name
//
// Spec §T-App label-set premise (positional-shorthand case): when a call
// argument is written as a bare identifier `f(prev, n: 5)`, the parser
// desugars it to `f(prev: prev, n: 5)` using the variable name as the
// label. If that label does not match any declared parameter name, the
// call must be rejected. This guards against the silent miscompile where
// `list_nth_i64(prev, n: 1)` (param is `lst`, not `prev`) compiled to wasm
// that always read index 0 (nexus-u1l6).

let list_nth_i64 = fn (lst: [ i64 ], n: i64) -> i64 do
  if n == 0 then
    match lst do
      | [] -> return 0
      | x :: _ -> return x
    end
  end
  match lst do
    | [] -> return 0
    | _ :: rest -> return list_nth_i64(lst: rest, n: n - 1)
  end
end

let main = fn () -> unit do
  let prev = [ 10, 20, 30 ]
  // Positional pun: 'prev' desugars to label 'prev', but param is named 'lst'.
  // This must be rejected at typecheck time.
  let _ = list_nth_i64(prev, n: 1)
  return ()
end
