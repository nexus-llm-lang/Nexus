// expect-fail: E2001
// expect-msg: ordering operators
//
// Sum types have no defined operational ordering: T-Cmp gives sums a
// structural reduction for equality only (tag + payload). The ordering
// operators `<`, `<=`, `>`, `>=` must be REJECTED on sum operands, even
// though `==` / `!=` are accepted. The fix routes ordering through
// `orderable(τ)` (numeric / char / string only) instead of `comparable(τ)`.

type Color = Red | Green | Blue

let lt = fn (x: Color, y: Color) -> bool do
  return x < y
end

let main = fn () -> unit do
  let r = lt(x: Red, y: Green)
  return ()
end
