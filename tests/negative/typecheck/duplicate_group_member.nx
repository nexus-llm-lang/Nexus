// expect-fail: E2030
// expect-msg: duplicate member
// expect-msg: IOError
// expect-msg: NotFound
//
// D-ExceptionGroup (docs/spec/type-system-formal.md §D-ExceptionGroup):
// distinct(C_1..C_n) — every member of an exception group must appear
// at most once. "NotFound" appears twice in the group, which would
// expand a catch arm into two identical PCtor arms — making one arm
// unreachable and confusing exhaustiveness analysis. The typechecker
// enforces the distinctness premise at registration time (E2030).
//
// nexus-v3xa.11

exception NotFound(path: string)
exception PermDenied(path: string)
exception group IOError = NotFound | PermDenied | NotFound

let main = fn () -> unit do
  return ()
end
