// expect-fail: E2001
// expect-msg: cannot unify int literal with non-integer type
//
// Generic-capability soundness (regression for the generic-caps feature):
// a generic cap `Box<T>` registers its call-site method `Box.wrap` as a
// polymorphic `forall T` scheme decoupled from any handler. Without the fix,
// a call at one element type under a handler instantiated at a DIFFERENT
// element type type-checked (rc 0) and miscompiled: the i64 argument flowed
// into the string handler arm, which read it as a string pointer and
// dereferenced it — an out-of-bounds memory access (wasm trap) in a
// "well-typed" program (P1 soundness / memory-unsafety).
//
// The fix shadows `Box.wrap` inside an `inject` body with the CONCRETE
// instantiation of the handler actually in scope (here: `wrap(x: string)`),
// so the i64 literal `7` fails to unify against `x: string` and the program
// is rejected at typecheck instead of trapping at run time.
//
// The matching-type use (handler element type == call element type) is still
// accepted; see tests/runtime/effects/generic_cap_two_instantiations_test.nx.
cap Box<T> do
  fn wrap(x: T) -> T
end

let box_str = handler Box do
  fn wrap(x: string) -> string do
    return x ++ "X"
  end
end

let confused = fn () -> i64 do
  inject box_str do
    // i64 call site under a STRING handler — the element type is fixed to
    // `string` by the injected handler, so `7 : i64` must be rejected.
    let r = Box.wrap(x: 7)
    r
  end
end

let main = fn () -> unit do
  let n = confused()
  return ()
end
