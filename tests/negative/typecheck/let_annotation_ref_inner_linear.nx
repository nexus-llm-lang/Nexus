// expect-fail: E2023
// expect-msg: linear
// expect-msg: ref
//
// wfRef at the T-Let explicit type-annotation site (spec §wfRef table, T-Let):
// a let binding annotated with ref(%T) is rejected because each deref (~x)
// would yield a fresh copy of the linear payload, duplicating the resource
// (wfRef(~σ) ⟺ ¬linear(σ)).
//
// Before the fix, walk_body_let_annots called only enforce_no_linear_type_args
// for the explicit annotation and omitted enforce_wf_ref_one, so ref(%Box<i64>)
// on a let-binding annotation was silently accepted.
//
// Spec: docs/spec/type-system-formal.md §wfRef table, T-Let row.

type Box<T> = Box(val: T)

let main = fn () -> unit do
  let ~r : ref(%Box<i64>) = Box(val: 0)
  return ()
end
