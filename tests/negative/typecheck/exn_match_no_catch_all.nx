// expect-fail: E2001
// expect-msg: match on `Exn` must include a catch-all arm
//
// T-Match hasCatchAll premise: when the scrutinee is the open `Exn` type,
// at least one arm must be a wildcard (`_`) or variable pattern.  This
// ensures that future exception constructors (added by library authors or
// user code) are handled rather than silently bypassed.
//
// Unlike `try ... catch | E -> ...`, which uses WASM EH to route unmatched
// exceptions to the enclosing handler, a direct `match e: Exn do ... end`
// has no such mechanism: an unmatched arm means a runtime trap.  The
// typechecker therefore requires at least one catch-all arm.
//
// nexus-z1pk

exception MyError(msg: string)
exception OtherError(code: i64)

let describe = fn (e: Exn) -> string do
  match e do
    | MyError(msg: m) -> return m
  end
end

let main = fn () -> unit do
  let e: Exn = MyError(msg: "hello")
  let _ = describe(e: e)
  return ()
end
