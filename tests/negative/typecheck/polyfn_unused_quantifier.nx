// expect-fail: E2011
// expect-msg: type parameter
// expect-msg: never used
//
// Spec §"Polymorphism Introduction" (type-system-formal.md L548–L571):
// kindOf(T, σ) is undefined when neither occurs_τ(T, σ) nor occurs_ρ(T, σ)
// holds — the "unused" case. The spec classifies this as a static error
// at T-Let-PolyFn: a malformed quantifier list must be rejected at the
// binding site, not silently accepted and left as dead weight in the scheme.
//
// Here T is declared in the quantifier list but never appears in the
// parameter types, return type, or throws row of `foo`.
//
// nexus-t9cl.21

let foo = fn <T>(x: i64) -> i64 do
  return x
end

let main = fn () -> unit do
  let _ = foo(x: 42)
  return ()
end
