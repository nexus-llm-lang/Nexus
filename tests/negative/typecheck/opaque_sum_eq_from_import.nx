// expect-fail: E2001
// expect-msg: cannot compare values of type
//
// Regression guard: opaque sum == outside the defining module must remain
// rejected. build_enum_entries strips variants to [] for imported opaque
// enums; enum_lookup returns None for them, keeping them incomparable.
//
// Color is declared `export opaque type Color = Red | Blue` in
// tests/_fixtures/opaque_color.nx. Its variants are invisible here (only
// make_red/make_blue are exported for value construction), so == must fail.

import { Color, make_red, make_blue } from "tests/_fixtures/opaque_color.nx"

let main = fn () -> unit do
  let a: Color = make_red()
  let b: Color = make_blue()
  a == b
  return ()
end
