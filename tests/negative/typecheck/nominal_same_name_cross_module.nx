// expect-fail: E2001
// expect-msg: type mismatch
//
// Two modules each declare `type Box`, a DISTINCT nominal type per module.
// Passing `nominal_box_a.Box` (a raw i64 payload) where `nominal_box_b.Box`
// (a [i64] list payload) is expected must be rejected: accepting it would
// reinterpret the i64 as a list pointer at runtime (memory-unsafe type
// confusion). Same-name enums in different modules are NOT the same type.

import { mk_a } from "tests/_fixtures/nominal_box_a.nx"
import { take_b } from "tests/_fixtures/nominal_box_b.nx"

let main = fn () -> unit do
  let n = take_b(x: mk_a())
  return ()
end
