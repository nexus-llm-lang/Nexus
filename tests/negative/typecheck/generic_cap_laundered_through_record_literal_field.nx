// expect-fail: E2001
// expect-msg: is used at an element type incompatible with the handler in scope
//
// Generic-capability soundness, REJECT side — a `Box<i64>`-committed closure
// stored in a STRUCTURAL-RECORD LITERAL field. The nominal counterpart
// (generic_cap_laundered_through_ctor_field.nx) is already rejected by the
// constructor-field coverage; this exercises the parallel record-literal field
// path. The record literal `{ g: need_i64 }` is built under a `Box<string>`
// handler, but `need_i64` commits `Box<i64>`; projecting `g` out and invoking it
// would run the i64-committed closure under the string handler (memory-unsafe
// type confusion — a raw i64 read as a string descriptor). Must be rejected at
// the construction site.
import * as str from "std:str"

cap Box<T> do
  fn wrap(x: T) -> i64
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1
  end
end

let box_str = handler Box do
  fn wrap(x: string) -> i64 do
    return str.length(s: x)
  end
end

let need_i64 = fn (seed: i64) -> i64 require { Box } do
  return Box.wrap(x: seed)
end

type Holder = { g: (s: i64) -> i64 require { Box } }

let extract = fn (h: Holder, n: i64) -> i64 require { Box } do
  return h.g(s: n)
end

let main = fn () -> unit do
  inject box_i64 do
    let ok = extract(h: { g: need_i64 }, n: 5)
  end
  inject box_str do
    let bad = extract(h: { g: need_i64 }, n: 1234567)
  end
  return ()
end
