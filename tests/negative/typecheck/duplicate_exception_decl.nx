// expect-fail: E2029
// expect-msg: already declared
// expect-msg: exception
// expect-msg: MyError
//
// D-Exception (docs/spec/type-system-formal.md §D-Exception):
// C ∉ variants(Exn) — the name "MyError" may only be registered once
// as an exception constructor. A second `exception MyError` declaration
// silently overwrites the first in the Exn enum, leaving the first
// variant inaccessible and producing confusing "constructor argument
// label" errors at any subsequent catch site. The typechecker
// enforces the freshness premise at registration time (E2029).
//
// nexus-v3xa.11

exception MyError(msg: string)
exception MyError(code: i64)

let main = fn () -> unit do
  return ()
end
