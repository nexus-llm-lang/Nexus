// expect-fail: E2024
// expect-msg: did you mean
//
// "did you mean?" suggestion framework (nexus-edp4): when an undefined
// variable is referenced, the typechecker collects in-scope binding names,
// computes Levenshtein distances, and suggests up to 3 candidates with
// distance <= 2.  Here `consle` is 2 edits from `console` (the in-scope
// binding), so the error message should include a suggestion.

let main = fn () -> unit do
  let console = "Console"
  let _ = consle
  return ()
end
