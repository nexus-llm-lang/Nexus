// expect-fail: E2001
// expect-msg: does not end with a `return` or `throw`
//
// Strict T-Lambda (spec: τ_r ≠ unit ⟹ tail(s†) = ⊥): a trailing `match` used
// as a non-unit function's implicit return value is rejected. The match is a
// bare expression statement whose arms yield values but do not `return`/`throw`,
// so the function falls off the end without diverging on all paths.
//
// (`return match n do … end` — an explicit return of the match as an
// EXPRESSION — is accepted; see the positive control in
// tests/typecheck/value_fn_return_required_test.nx.)

let trailing_match = fn (n: i64) -> i64 do
  match n do
    | 0 -> 100
    | _ -> 200
  end
end

let main = fn () -> unit do
  return ()
end
