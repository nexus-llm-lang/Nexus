// expect-fail: E2001
// expect-msg: requires capability 'Hidden'
// expect-msg: ambient require row
//
// Negative fixture for T-CapCall require-row enforcement inside a handler arm
// body (nexus-4twfh).
//
// The arm body's ambient require row ρ_q is the handler's declared `require {…}`
// row (spec §T-Handler / §T-CapCall: x ∈ ρ_q). Here the `Logger` handler
// declares `require { }`, but its `log` arm calls `Hidden.h()`. The cap name
// `Hidden` resolves (an enclosing `inject hid_handler` provides it at the call
// site in `main`), so this is NOT a name-resolution error — it is purely a
// require-row violation: Hidden ∉ {} for the arm body.
//
// Before the fix, `check_arm_body` only pinned env + throw-row and never called
// `state_with_require_row`, and `check_arm_bodies` skipped non-kont arms
// entirely — so the arm body was never typechecked and the cap call leaked
// through to a downstream MIR "no handler bound for cap Hidden" failure at run
// instead of being rejected at typecheck as the spec promises (P4: T-CapCall's
// x ∈ ρ_q premise is intrinsically discharged at typecheck).
//
// nexus-4twfh

cap Logger do
  fn log(msg: string) -> unit
end

cap Hidden do
  fn h() -> unit
end

let hid_handler = handler Hidden require { } do
  fn h() -> unit do
    return ()
  end
end

// `another`'s declared require row is `{}` but its arm body calls `Hidden.h()`.
// Hidden is bound at the call site (via the enclosing `inject hid_handler`), so
// the name resolves; the rejection is the require-row check inside the arm body.
let another = handler Logger require { } do
  fn log(msg: string) -> unit do
    Hidden.h()
    return ()
  end
end

let main = fn () -> unit do
  inject hid_handler do
    inject another do
      Logger.log(msg: "x")
      return ()
    end
  end
end
