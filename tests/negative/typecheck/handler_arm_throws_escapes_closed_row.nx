// expect-fail: E2001
// expect-msg: throws {}
// expect-msg: no exceptions are permitted
//
// T-Handler throws reconciliation (throws-side sibling of nexus-4twfh).
//
// A handler arm IS the runtime implementation of a cap method, dispatched
// through the cap table. Its body's throws must therefore stay within the cap
// method's declared `throws` row. The cap method `Logger.log` declares no
// `throws` clause — which for a declaration site means "raises nothing"
// (closed `throws {}`). The arm body, however, raises `Boom`.
//
// Before this fix, an absent `throws` clause parsed to the open `__implicit`
// row (legacy effect-polymorphism for un-annotated function arrows), so the
// arm body's throw row was effect-polymorphic and admitted ANY throw. The
// exception then escaped invisibly: the main-wrap pass only wraps exceptions
// present in a body's *inferred* throw row, so `Boom` leaked straight to the
// host as an uncaught Wasm exception under the closed `throws {}` entry point.
//
// The fix pins the arm body's ambient throw row to the cap method's declared
// row (closing the implicit tail), so `throw Boom` is rejected here at
// typecheck instead of escaping at runtime.

exception Boom

cap Logger do
  fn log(msg: string) -> unit
end

let bad_handler = handler Logger require { } do
  fn log(msg: string) -> unit do
    throw Boom
  end
end

let main = fn () -> unit do
  inject bad_handler do
    Logger.log(msg: "x")
    return ()
  end
end
