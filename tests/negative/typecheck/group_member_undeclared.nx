// expect-fail: E2030
// expect-msg: not a declared exception constructor
// expect-msg: IOError
// expect-msg: Undeclared
//
// D-ExceptionGroup (docs/spec/type-system-formal.md §D-ExceptionGroup):
// ∀i. C_i ∈ variants(Exn) — every member of an exception group must be
// a declared exception constructor (a variant of the Exn enum). "Undeclared"
// is not declared anywhere as an `exception`, so the group declaration is
// rejected at registration time (E2030). This also rejects nesting of
// groups: a group name is not an Exn variant constructor.
//
// nexus-v3xa.11

exception NotFound(path: string)
exception group IOError = NotFound | Undeclared

let main = fn () -> unit do
  return ()
end
