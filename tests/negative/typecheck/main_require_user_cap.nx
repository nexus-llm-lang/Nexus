// expect-fail: E2017
// expect-msg: require-row contains user-declared cap
//
// Spec P9 wfMain: rho_q <= SysCaps -- main's require row may only contain
// system capabilities. A user-declared cap has no enclosing inject to
// provide it at the program entry point.

cap MyLogger do
  fn log(msg: string) -> unit
end

// The require row is intentionally never consumed; under the default
// lint-level=error the L0002 unused-cap finding would halt the build before
// validate_main raises the E2017 this fixture asserts, so suppress it here.
// lint:allow-next L0002
let main = fn () -> unit require { MyLogger } do
  return ()
end
