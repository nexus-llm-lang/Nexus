// expect-fail: E2001
// expect-msg: force: thunk requires capability
// expect-msg: ambient require row
//
// Negative fixture for T-Force require_row discharge (nexus-8tgwr item 1):
// a function that forces @(i64 require { Logger }) must surface the deferred
// require_row at the force site; when the enclosing function has an empty
// ambient require row (no inject), the T-Force require discharge must reject
// the force.

cap Logger do
  fn log(msg: string) -> unit
end

// `consume` has an empty require row (no `require { Logger }` annotation)
// but forces a thunk annotated `@(i64 require { Logger })`.
// T-Force must detect that Logger is missing from the ambient row and reject.

let consume = fn (th: @(i64 require { Logger })) -> i64 do
  return @th
end

let main = fn () -> unit do
  return ()
end
