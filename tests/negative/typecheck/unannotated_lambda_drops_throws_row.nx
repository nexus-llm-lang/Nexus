// expect-fail: E2001
// expect-msg: throws row mismatch
//
// Negative fixture (T-Lambda containment): an UNANNOTATED lambda whose body
// throws `E`, returned at a `throws { F }` slot, must NOT silently drop `E`.
//
// A lambda is a new function: its body's raises / calls / forces are charged
// against the LAMBDA's own throws-row, not the enclosing fn's active row. The
// body is typed under a fresh collecting throws-row that T-Raise pins with `E`,
// so the unannotated lambda's arrow row reflects `{ E | ... }`. Returning `g`
// at the declared `() -> i64 throws { F }` slot must then REJECT — otherwise a
// caller that handles only `F` (the declared row) misses `E` at runtime.
//
// Before the fix the body was typed under the enclosing fn's (open) row, so
// `throw E` was admitted and the arrow's implicit row absorbed the narrower
// `{ F }` slot at the return, laundering a wider-throwing body into a narrower
// declared arrow row. The inline-annotated control
// (`fn () -> i64 throws { E } do throw E end`) already rejected at the return.

exception E
exception F

let mk = fn () -> (() -> i64 throws { F }) do
  let g = fn () -> i64 do throw E end
  return g
end

let main = fn () -> unit throws { F } do
  let h = mk()
  let r = h()
  return ()
end
