// expect-fail: E2033
// expect-msg: let binding 'm'
// expect-msg: type argument #2 of 'Map' is linear
//
// Type-formation rule: a let-binding annotation
// `let m: Map<string, %ByteBuffer> = ...` instantiates the generic
// `Map<K, V>` at a linear `V = %ByteBuffer`. Rejected at the annotation
// site before the linearity pass would catch the inevitable downstream
// unconsumed-linear violation.
//
// Spec: type-system-formal §Linearity (linear inspects type arguments).

import * as bb from "std:bytebuffer"
import * as map from "std:collection/map"

let main = fn () -> unit do
  let m: Map<string, %ByteBuffer> = map.string_map()
  return ()
end
