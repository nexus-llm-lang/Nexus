// expect-fail: E2001
// expect-msg: requires row mismatch
// expect-msg: not admitted by callee

cap Worker do
  fn step() -> unit
end

cap Logger do
  fn note(msg: string) -> unit
end

let accept = fn (task: () -> unit require { Worker }) -> unit do
  return ()
end

let task = fn () -> unit require { Worker, Logger } do
  Worker.step()
  Logger.note(msg: "x")
  return ()
end

let bad = fn () -> unit do
  accept(task: task)
end

let main = fn () -> unit do
  return ()
end
