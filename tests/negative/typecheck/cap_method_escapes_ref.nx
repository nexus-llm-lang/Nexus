// expect-fail: E2022
// expect-msg: mutable reference
// expect-msg: escapes
//
// escapesRef on D-Cap method return types (spec §escapesRef table, D-Cap):
// a cap method may not declare a ref(T) return type; ref cells are
// stack-confined and returning one would let it outlive the stack frame
// that owns the mutable storage (gravity rule: ¬escapesRef(κ_j)).
//
// Before the fix, walk_port_methods discarded typ_ret and never called
// enforce_no_escapes_ref, so ref(T) return types were silently accepted.
//
// Spec: docs/spec/type-system-formal.md §escapesRef table (line 472), D-Cap.
// nexus-sfwm

cap BadCap do
  fn smuggle_out() -> ref(i64)
end

let main = fn () -> unit do
  return ()
end
