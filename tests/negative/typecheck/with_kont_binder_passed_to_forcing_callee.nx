// expect-fail: E2001
// expect-msg: continuation binder
// expect-msg: forced directly
//
// A `with @k` continuation binder is a control-flow handle, not an ordinary
// value. Only a syntactically-direct force `@k` (or `@kk` bound by a bare
// `let`-alias and forced there) is lowered to the wasm `op_resume` that transfers
// control back to the suspended caller.
//
// Here the binder `k` is passed as an argument to `force_it`, an ordinary
// function that FORCES its `@i64` parameter (`@t`). Inside `force_it`, `t` is a
// plain thunk parameter with no connection to the arm's cont-binder set, so MIR
// lowers `@t` to a GENERIC thunk force that dereferences the continuation's i64
// table-slot index as a heap pointer — a runtime SIGSEGV (rc 139). Tracking the
// binder into the callee would require interprocedural flow analysis, so this
// escape is rejected at TYPECHECK (check_cont_no_escape / check_cont_call_args in
// typecheck/check.nx) before it can reach codegen.
//
// NOTE the deliberately narrow rule: passing the binder as a VALUE to a
// slot-reading intrinsic — an external whose wasm symbol is `value_of_i64`, e.g.
// std:runtime/sched's `kont_slot(k: k)` — IS allowed, because such an intrinsic
// reinterprets the binder's bits as a raw i64 and never forces it. The
// cooperative scheduler relies on that (see the runtime fixture
// tests/runtime/effects/coop_scheduler_interleave_test.nx). It is specifically a
// FORCING callee (a thunk-typed parameter the callee can `@`) that is unsafe and
// rejected here. The other supported indirect force is the bare `let`-alias,
// which IS lowered to resume (see handler_with_kont_let_alias_force_test.nx).

cap Co do
  fn ask() -> i64
end

let force_it = fn (t: @i64) -> i64 do
  @t
end

let h = handler Co do
  fn ask() -> i64 with @k do
    force_it(t: k)
  end
end

let drive = fn () -> i64 do
  inject h do
    let v = Co.ask()
    v
  end
end

let main = fn () -> unit do
  let r = drive()
  return ()
end
