// expect-fail: E2001
// expect-msg: throws row mismatch
//
// Negative fixture (T-Force containment): a suspended thunk's collecting body
// that surfaces exceptions by FORCING an inner thunk must NOT silently drop
// the surfaced row when the result is narrowed at the return slot.
//
// `mk` binds `let @t = @inner`. T-LetThunk types the suspended body under a
// fresh collecting throws-row; the body coerces `inner` (a thunk declaring
// `throws { E }`) to the i64 inner type, which forces it and surfaces `{ E }`.
// Per the unified inference-row pinning, T-Force must pin the surfaced `E`
// into the collecting row, so `t` carries `@(i64 throws { E | ... })`. Returning
// `t` at the declared `@(i64 throws { F })` slot must then REJECT: an
// E-surfacing thunk cannot narrow into a slot that admits only `F`, else `E`
// escapes `mk`'s declared `{ F }` deferred row at force time (a P5 hole).
//
// Counterpart of the raise form (`throw E`) and the call form, which already
// rejected; only the force path differs. The annotated control
// (`let @t: @(i64 throws { E }) = @inner`) already rejected before this fix.

exception E
exception F

let mk = fn (inner: @(i64 throws { E })) -> @(i64 throws { F }) throws { } do
  let @t = @inner
  return t
end

let main = fn () -> unit do
  return ()
end
