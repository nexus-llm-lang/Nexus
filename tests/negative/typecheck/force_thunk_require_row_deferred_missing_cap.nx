// expect-fail: E2001
// expect-msg: force: thunk requires capability
// expect-msg: ambient require row
//
// Soundness test for T-App require-row deferral: a thunk whose deferred
// require_row includes a capability must be rejected at the force site when
// the capability is absent from the forcing context's ambient require row.
//
// The thunk @(i64 require { Console }) carries Console as its deferred
// require row.  Forcing it inside a function with an empty ambient require
// row (no `require { Console }`, no inject providing Console) must be
// rejected by T-Force's require-row discharge check.
//
// This verifies that the deferral introduced to fix the over-rejection
// (nch0x regression) does NOT silently drop the require check — it merely
// moves it from creation time to force time, and the force-site rejection
// still fires when the capability is genuinely absent.

import { Console, system_handler } from "std:stdio"

let expensive = fn (label: string) -> i64 require { Console } do
  Console.println(val: label)
  return 7 * 6
end

// `consume_thunk` has an empty require row but tries to force a thunk
// that declares `require { Console }`.  T-Force must reject this.
let consume_thunk = fn (th: @(i64 require { Console })) -> i64 do
  return @th
end

let main = fn () -> unit do
  return ()
end
