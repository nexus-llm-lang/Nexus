// expect-fail: E2001
// expect-msg: ordering operators
//
// Records have no defined operational ordering: the spec's T-Cmp gives
// records a STRUCTURAL reduction for equality only. The ordering operators
// `<`, `<=`, `>`, `>=` must therefore be REJECTED on record operands, even
// though `==` / `!=` are accepted (structural equality). Previously the six
// comparison ops all shared the `comparable(τ)` predicate, so `<` on a record
// typechecked and silently lowered to a packed/pointer compare. The fix routes
// ordering through `orderable(τ)` (numeric / char / string only).

type Pair = MkPair(a: i64, b: i64)

let lt = fn (x: Pair, y: Pair) -> bool do
  return x < y
end

let main = fn () -> unit do
  let p = MkPair(a: 1, b: 2)
  let q = MkPair(a: 3, b: 4)
  let r = lt(x: p, y: q)
  return ()
end
