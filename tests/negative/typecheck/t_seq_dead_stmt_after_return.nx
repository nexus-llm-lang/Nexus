// expect-fail: E2021
// expect-msg: unreachable code after diverging statement
//
// T-Seq dead-code check: `return` is also a diverging statement.
// Any statement following a `return` in the same block is unreachable.
//
// nexus-10lu

let trigger = fn () -> i64 do
  return 42
  return 0   // dead code — return diverges; E2021
end

let main = fn () -> unit do
  trigger()
  return ()
end
