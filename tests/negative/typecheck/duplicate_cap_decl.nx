// expect-fail: E2029
// expect-msg: already declared
// expect-msg: cap
// expect-msg: Logger
//
// D-Cap (docs/spec/type-system-formal.md §D-Cap):
// X ∉ dom(caps) — a cap name may only be declared once. A second
// `cap Logger` declaration would create two cap env entries for the
// same name, making handler dispatch ambiguous. The typechecker
// enforces the freshness premise at registration time (E2029).
//
// nexus-v3xa.11

cap Logger do
  fn log(msg: string) -> unit
end

cap Logger do
  fn log(msg: string) -> unit
end

let main = fn () -> unit do
  return ()
end
