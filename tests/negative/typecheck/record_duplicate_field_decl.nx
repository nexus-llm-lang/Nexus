// expect-fail: E2029
// expect-msg: already declared
// expect-msg: field label in record type
// expect-msg: R
//
// D-Type-Record (docs/spec/type-system-formal.md §D-Type-Record):
// distinct(ℓ̄) — field labels within a record type declaration must be
// pairwise distinct. A duplicate label makes field projection `r.x`
// against the declaration ambiguous (which `x`?). The use-site T-Record
// check only catches duplicate labels in record *literals*; the decl-site
// premise must be enforced separately. The typechecker rejects the
// ill-formed declaration at registration time (E2029), mirroring the
// D-Type-Sum constructor/field distinctness checks.
//
// nexus-i2ttp (sibling of nexus-8iyii)

type R = { x: i64, x: bool }

let main = fn () -> unit do
  return ()
end
