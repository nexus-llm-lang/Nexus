// expect-fail: E2001
// expect-msg: is used at an element type incompatible with the handler in scope
//
// Generic-capability soundness (P1, memory-unsafety) — TRANSITIVE laundering.
// A generic cap `Box<T>` is laundered past the inject-body shadow not by a
// direct cap call but by a CHAIN of `require { Box }` functions: `forwarder`
// calls `leaf`, and `leaf` is the one that actually calls `Box.wrap(x: n)` with
// `n: i64`. The element type `forwarder` commits Box to (`i64`) must propagate
// from `leaf`'s published contract through the call into `forwarder`'s, so that
// calling `forwarder` under `inject box_str` (Box<string>) is rejected — it
// would deliver an i64 where the string handler arm expects a string pointer.
//
// The committed instantiation is derived by REAL inference over the call graph:
// `leaf`'s require row resolves to `Box<i64>` (from its own cap call), and the
// fixpoint propagates that into `forwarder`'s require row (`leaf`'s contract is
// finalised before `forwarder`'s is derived). The call-site coverage then
// unifies `forwarder`'s `Box<i64>` against the injected `Box<string>` and
// rejects the mismatch at typecheck instead of trapping at run time.
//
// The matching-handler chain (forwarder/leaf under a Box<i64> handler) is still
// accepted — see tests/runtime/effects/generic_cap_two_instantiations_test.nx.
import * as str from "std:str"

cap Box<T> do
  fn wrap(x: T) -> i64
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1
  end
end

let box_str = handler Box do
  fn wrap(x: string) -> i64 do
    return str.length(s: x)
  end
end

// `leaf` directly commits Box to i64; `forwarder` only FORWARDS to `leaf`.
let leaf = fn (n: i64) -> i64 require { Box } do
  return Box.wrap(x: n)
end

let forwarder = fn (n: i64) -> i64 require { Box } do
  return leaf(n: n)
end

let main = fn () -> unit do
  // box_i64 keeps the program otherwise well-formed; the box_str call is the
  // transitively-laundered type confusion and must be rejected.
  inject box_i64 do
    let ok = forwarder(n: 5)
  end
  inject box_str do
    let bad = forwarder(n: 999999)
  end
  return ()
end
