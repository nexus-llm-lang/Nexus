// expect-fail: E2021
// expect-msg: unreachable code after diverging statement
//
// T-Seq (spec tail(s) = ⊥): `let p = throw e'` diverges — the bound name
// is unreachable, so subsequent statements are dead code (E2021).
//
// nexus-wgj7

import * as test_assert from "std:test/assert"

exception Boom(code: i64)

let trigger = fn () -> i64 throws { Exn, Boom } do
  let _ = throw Boom(code: 1)
  return 0   // dead code — let-with-throw diverges; E2021
end

let main = fn () -> unit throws { Exn, Boom } do
  let _ = trigger()
  return ()
end
