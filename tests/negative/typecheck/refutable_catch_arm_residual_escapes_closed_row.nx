// expect-fail: E2001
// expect-msg: exception A raised by callee not admitted by caller's throws row

/** A catch arm whose constructor pattern carries a REFUTABLE nested field
 *  pattern (here the literal `0`) must NOT subtract that constructor from the
 *  try body's residual throws-row. The arm only handles `A(x: 0)`; an
 *  `A(x: 5)` value falls through to the synthetic residual rethrow and
 *  escapes. So `f` cannot be `throws {}` and the call to `src` (which raises
 *  `A`) must be rejected against the closed empty row.
 *
 *  The irrefutable forms `| A(x) ->`, `| A(x: _) ->`, `| A(x: y) ->` DO fully
 *  catch `A` and stay admissible at `throws {}`. */

exception A(x: i64)

let src = fn () -> i64 throws { A } do
  throw A(x: 5)
end

let f = fn () -> i64 throws {} do
  try
    return src()
  catch
    | A(x: 0) -> return 0
  end
end

let main = fn () -> unit do
  let r = f()
  return ()
end
