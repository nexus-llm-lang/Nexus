// expect-fail: E2001
// expect-msg: throws row mismatch
//
// U-Row-Exn directionality (nexus-v3xa.1, P5 exception containment).
//
// `g` may throw any Exn (throws { Exn }). `apply` declares its argument
// `h: () -> i64 throws { NotFound }` — a NARROWER row. Passing `g` for `h`
// unifies g's actual throws-row { Exn } against the expected { NotFound }.
//
// Before the fix, U-Row-Exn was symmetric, so { Exn } (actual) was absorbed
// by { NotFound } (expected) and this was ACCEPTED — but then `apply` is
// typed throws { NotFound } while it may actually throw Boom, so Boom
// escapes the declared row uncaught (a P5 violation).
//
// After the fix, U-Row-Exn is directional (Exn admissible only on the
// expected/right side), so this falls through to U-Row-Closed-Closed and
// the multiset { Exn } != { NotFound } is rejected. The companion positive
// case — a specific row {NotFound} flowing into an expected {Exn} — still
// type-checks (see tests/typecheck/check/exn_row_subsume_specific_test.nx).

exception NotFound(path: string)
exception Boom

let main = fn () -> unit do
  let g = fn () -> i64 throws { Exn } do throw Boom end
  let apply = fn (h: () -> i64 throws { NotFound }) -> i64 throws { NotFound } do return h() end
  let r = apply(h: g)
  return ()
end
