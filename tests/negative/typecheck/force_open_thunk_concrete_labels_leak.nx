// expect-fail: E2001
// expect-msg: exception E raised by callee not admitted by caller's throws row
//
// Soundness test for T-Force open-row label leak (nexus-fy025).
//
// When `let @t = throwy()` suspends a call to a function declaring
// `throws { E }` in a thunk body, T-LetThunk types the body under a fresh
// collecting throws-row and pins E into it via T-App.  After substitution the
// thunk carries an OPEN deferred throws-row `{ E | ?fresh }` (concrete label E
// plus a fresh inference-variable tail).
//
// At the force site `return @t`, T-Force must check that every CONCRETE label
// in the thunk's (possibly open) deferred throws-row is admitted by the forcing
// function's declared throws-row.  Prior to the fix, `check_call_throw_row_admitted`
// treated the entire open row as "effect-polymorphic" (only the tail was
// checked, not the concrete labels), silently dropping E and admitting a
// `throws {}` forcing context — a P5 containment hole.
//
// After the fix: concrete labels in an open callee row are still checked
// against the caller's declared row; only the trailing inference-variable is
// treated as polymorphic.  This program must now be rejected because `creator`
// declares `throws {}` but its body forces a thunk that can raise E.

exception E(msg: string)

let throwy = fn () -> i64 throws { E } do
  throw E(msg: "x")
end

// `creator` declares throws {} but forces a thunk that surfaced E.
// Prior to the fix this was accepted (unsound); after the fix it must reject.
let creator = fn () -> i64 throws { } do
  let @t = throwy()
  return @t
end

let main = fn () -> unit do
  return ()
end
