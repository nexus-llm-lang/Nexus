// expect-fail: E2001
// expect-msg: exception group IOError
// expect-msg: not fully admitted
//
// A GROUP label in a CALLEE's `throws { G }` row expands to ALL its members
// at the call site. The caller must admit EVERY member; listing only some of
// them is insufficient. Here the callee declares `throws { IOError }` (members
// NotFound and PermDenied) but the caller declares only `throws { NotFound }`,
// leaving PermDenied uncovered -> the call must be rejected (no over-admission
// of the group-expansion fix).

exception NotFound(path: string)
exception PermDenied(path: string)
exception group IOError = NotFound | PermDenied

let open_file = fn (path: string) -> i64 throws { IOError } do
  throw NotFound(path: path)
end

let caller = fn (path: string) -> i64 throws { NotFound } do
  return open_file(path: path)
end

let main = fn () -> unit throws { Exn } do
  let _x = caller(path: "/x")
  return ()
end
