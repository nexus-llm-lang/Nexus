// expect-fail: E2024
// expect-msg: undefined variable 'x'
//
// Negative fixture for nexus-skcf (T-While scope leak):
// A binding introduced inside a `while` body must not be visible after
// the loop exits.  Before the fix, `infer_while` failed to restore the
// outer env after typechecking the body, so `x` leaked into the
// enclosing scope.  With the fix the env is restored to the pre-loop
// snapshot, and the reference `x` below is correctly rejected as
// "unbound variable".

let main = fn () -> unit do
  let i = 0
  while i < 0 do
    let x = 42
    x
    i
  end
  // `x` was declared inside the while body; it must not be visible here.
  x
  return ()
end
