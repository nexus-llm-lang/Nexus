// expect-fail: E2001
// expect-msg: P-Ctor
//
// Spec P-Ctor {ℓ'} = {ℓ} is a SET equality on field labels. A permutation of
// the declared labels is fine (and accepted — see
// tests/runtime/records/ctor_pattern_label_permutation_test.nx), but a label
// SET that differs from the declared one (here an UNKNOWN label `z` in place
// of `y`) violates {ℓ'} = {ℓ} and must be rejected.

type Point = Point(x: i64, y: i64)

// `{x, z}` is not the declared label set `{x, y}` — `z` is unknown.
let wrong_set = fn (p: Point) -> i64 do
  match p do
    | Point(x: a, z: b) -> return a + b
  end
end

let main = fn () -> unit do
  wrong_set(p: Point(x: 1, y: 2))
  return ()
end
