// expect-fail: E2001
// expect-msg: is used at an element type incompatible with the handler in scope
import * as str from "std:str"

cap Box<T> do
  fn wrap(x: T) -> i64
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1
  end
end

let box_str = handler Box do
  fn wrap(x: string) -> i64 do
    return str.length(s: x)
  end
end

let need_i64 = fn (seed: i64) -> i64 require { Box } do
  return Box.wrap(x: seed)
end

type Wrapper = Wrapper(g: (s: i64) -> i64 require { Box })

let extract = fn (w: Wrapper, n: i64) -> i64 require { Box } do
  let Wrapper(g: f) = w
  return f(s: n)
end

let main = fn () -> unit do
  inject box_i64 do
    let ok = extract(w: Wrapper(g: need_i64), n: 5)
  end
  inject box_str do
    let bad = extract(w: Wrapper(g: need_i64), n: 1234567)
  end
  return ()
end
