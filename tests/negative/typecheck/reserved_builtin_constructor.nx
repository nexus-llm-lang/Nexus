// expect-fail: E2038
// expect-msg: Nil
// expect-msg: List
//
// A user type declaration whose constructor name collides with a built-in
// constructor (Nil/Cons from List, None/Some from Option, Ok/Err from Result)
// must be rejected at the declaration site with a clear diagnostic naming the
// reserved constructor and the built-in type that owns it.
//
// Without this check the variant index silently retains the built-in List's
// Cons(v, rest) entry (first-defined-wins), while the type environment gets
// the user's Cons(head, tail) type.  Uses of the user's Cons then produce a
// confusing 'field rest' phantom E2001 at the call site instead of a clear
// error here.

type T = Nil | Cons(head: i64, tail: i64)

let main = fn () -> unit do
  return ()
end
