// expect-fail: E2001
// expect-msg: throws row mismatch
//
// Negative fixture: an unannotated `let @th = thrower()` must NOT silently
// drop the thunk's deferred throws-row.
//
// `thrower` declares `throws { E }`. Binding `let @th = thrower()` suspends
// the call in a thunk; T-LetThunk types the suspended body under a fresh
// collecting throws-row. Per T-Raise that throwing call must pin the
// collecting row to include E, so `th` has type `@(i64 throws { E | ... })`.
// Forcing it through `force_f`, whose parameter declares `@(i64 throws { F })`
// (T-Force), must reject because the thunk can raise E but the callee slot
// admits only F — otherwise E would escape `caller`'s declared row uncaught.
//
// Counterpart of the annotated form (`let @th: @(i64 throws { E }) = ...`),
// which already rejected; only the absence of the annotation differs.

exception E
exception F

let force_f = fn (t: @(i64 throws { F })) -> i64 throws { F } do
  return @t
end

let thrower = fn () -> i64 throws { E } do
  throw E
end

let caller = fn () -> i64 throws { E, F } do
  let @th = thrower()
  return force_f(t: th)
end

let main = fn () -> unit do
  return ()
end
