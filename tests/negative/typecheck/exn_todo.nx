// expect-runtime-throw: before todo
//
// `std:exn.todo` is a polymorphic "not yet implemented" marker that
// always raises `NotImplemented(msg: "not yet implemented")` at run
// time. Like Rust's `todo!()` it unifies with any return type, so the
// call site compiles regardless of what the surrounding context expects.
// The fixture compiles cleanly because `main` widens the throws-row with
// `NotImplemented`, but executing it hits the throw and surfaces the
// exception as a non-zero exit. wasmtime swallows the constructor name
// on stderr, so the runner anchors on the captured stdout line
// "before todo".
//
// Idiomatic alternative: replace `todo()` with a real implementation
// before shipping. Stubbing with `todo()` is intentionally a
// "fails at runtime" marker, not a silent no-op, so accidental calls
// to unfinished functions surface immediately in tests.

import { Console, system_handler } from "std:stdio"
import { todo, NotImplemented } from "std:exn"

let main = fn () -> unit require { PermConsole } throws { NotImplemented } do
  inject system_handler do
    Console.println(val: "before todo")
    let result : i64 = todo()
    Console.println(val: "should never print")
  end
  return ()
end
