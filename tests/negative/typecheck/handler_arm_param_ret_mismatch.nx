// expect-fail: E2001
// expect-msg: parameter types do not match cap
// expect-msg: T-Handler
//
// T-Handler spec premise (nexus-00j4): each arm's params and ret_type must
// equal the corresponding cap method's declaration. Here the cap declares
// `fn transform(x: i64) -> i64` but the handler arm declares the wrong
// parameter type `(x: string) -> i64`.  The cross-validation in
// register_handler_bindings must fire E2001.
//
// nexus-00j4

cap Transformer do
  fn transform(x: i64) -> i64
end

let bad_transformer = handler Transformer do
  fn transform(x: string) -> i64 do
    return 0
  end
end

let main = fn () -> unit do
  return ()
end
