// expect-fail: E2036
// expect-msg: method
// expect-msg: doit
// expect-msg: Foo
//
// D-Cap (docs/spec/type-system-formal.md §D-Cap):
// distinct(ℓ_j | j ∈ J) — method names within a cap must be pairwise
// distinct. A duplicate method label makes T-CapCall's methods(x).ℓ
// lookup ambiguous and breaks the 1-1 arm/method correspondence of
// T-Handler. The typechecker enforces the distinctness premise at the
// cap declaration site (E2036).

cap Foo do
  fn doit() -> unit
  fn doit() -> unit
end

let main = fn () -> unit do
  return ()
end
