// expect-fail: E2001
// expect-msg: does not match any parameter name
//
// Spec §T-App label-set premise: caller argument labels must match the
// callee's declared parameter labels by name (with permutation allowed
// for ordering). Passing arguments under labels that do not appear in the
// function declaration must be rejected — silently accepting mismatched
// labels would route arguments to wrong parameter slots at runtime when
// the argument types happen to be identical.

let add = fn (x: i64, y: i64) -> i64 do
  return x + y
end

let main = fn () -> unit do
  // Correct call: add(x: 1, y: 2)
  // Wrong labels: 'a' and 'b' are not declared parameter names.
  let _ = add(a: 1, b: 2)
  return ()
end
