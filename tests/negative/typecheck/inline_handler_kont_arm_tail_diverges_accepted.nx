// expect-fail: E3002
// expect-msg: stack-switching IR node
//
// Regression guard: a `with @k` handler arm whose body terminates on
// all paths via explicit `return` satisfies T-Continuation's tail(s̄) = ⊥
// premise and must be accepted by the typechecker.
//
// The typechecker accepts this program (the arm body ends with `return r`,
// so `infer_stmts_tail_diverges` returns true). The test reaches codegen
// where @k (LirExprResume) is not yet implemented, producing E3002. If the
// tail-divergence guard were incorrectly over-rejecting valid arms, the
// error would be E2001 here instead.

cap Yield do
  fn yield_val() -> i64
end

let yield_handler = handler Yield do
  fn yield_val() -> i64 with @k do
    let r = @k
    return r
  end
end

let main = fn () -> unit do
  inject yield_handler do
    Yield.yield_val()
  end
  return ()
end
