// expect-fail: E2001
// expect-msg: callee requires capability
// expect-msg: ambient require row
//
// Negative fixture for T-CapCall require-row discharge (nexus-iff93):
// the env'd require row of a cap method must be `{cap} ∪ α`, so a function
// that calls a cap method without that cap in its ambient require row (and
// without an enclosing `inject`) must be rejected.
//
// Before the fix, register_handler_methods hardcoded the cap-method arrow's
// `requires` to the empty closed row `{}`, so `first_missing_cap` never found
// a missing cap and the call was silently admitted — a capability-soundness
// hole (only the throws-row side of T-CapCall was enforced).

cap Logger do
  fn log(msg: string) -> unit
end

let system_handler = handler Logger require { PermConsole } do
  fn log(msg: string) -> unit do
    return ()
  end
end

// `bad` declares an empty require row but calls `Logger.log`. With the fix the
// cap-method arrow carries `requires: { Logger }`, so the call against an empty
// ambient require row must be rejected.
let bad = fn () -> unit require { } do
  Logger.log(msg: "hi")
  return ()
end

let main = fn () -> unit do
  return ()
end
