// expect-fail: E2001
// expect-msg: throws row mismatch
//
// Negative fixture (T-Throw-Val containment): a `throw e` where `e : Exn`
// inside a suspended thunk body must NOT silently drop the thunk's deferred
// throws-row.
//
// `mk` binds `let @th = throw e`. T-LetThunk types the suspended body under a
// fresh collecting throws-row; per T-Raise the value-throw must pin that row
// with the universal `Exn` sentinel, because the thrown value can be ANY
// variant. So `th` carries `@(i64 throws { Exn | ... })`. Forcing it through
// `force_f`, whose parameter declares `@(i64 throws { F })` (T-Force), must
// reject: an `Exn`-throwing thunk cannot narrow into a slot that admits only
// `F`, otherwise an arbitrary exception escapes `mk`'s declared `{ F }` row.
//
// Counterpart of the constructor form (`throw E`), which already rejected;
// only the value-throw (name_opt = None) path differs.

exception F

let force_f = fn (t: @(i64 throws { F })) -> i64 throws { F } do
  return @t
end

let mk = fn (e: Exn) -> i64 throws { F } do
  let @th = throw e
  return force_f(t: th)
end

let main = fn () -> unit do
  return ()
end
