// expect-fail: E2001
// expect-msg: is used at an element type incompatible with the handler in scope
import * as str from "std:str"

cap Box<T> do
  fn make(x: i64) -> T
end

let box_i64 = handler Box do
  fn make(x: i64) -> i64 do
    return 2000000000
  end
end

let confused = fn () -> string require { Box } do
  let r = Box.make(x: 0)
  return r
end

let main = fn () -> unit do
  inject box_i64 do
    let leaked = confused()
    let n = str.length(s: leaked)
    ()
  end
  return ()
end
