// expect-fail: E2001
// expect-msg: cannot borrow
// expect-msg: linear
//
// Spec §T-App-BorrowLin: the borrow-arg-position carve-out (skip T-Borrow's
// x:^ω check) must only fire when the expected parameter type is `&σ`.
// When P ≠ &σ (e.g. i64), passing `&x` must route through ordinary T-Borrow,
// which rejects linear bindings.  A `_`-named linear binding additionally
// bypasses LinearUnused (linearity.nx skips n == "_"), so without this
// param-shape guard the call silently succeeds — the bug nexus-kdfb.

let take_int = fn (n: i64) -> i64 do return n end

let main = fn () -> unit do
  let %_ = 42
  let _ = take_int(n: &_)
  return ()
end
