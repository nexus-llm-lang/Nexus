// expect-fail: E2001
// expect-msg: type mismatch
/**
 * Strict char/int discipline: `cast.i64_of` declares an `i32` parameter and
 * must NOT silently accept a `char`. The sound char->int path is
 * `cast.i64_of_char` / `char.ord` (see
 * tests/typecheck/char_int_cast_test.nx); passing a bare `char` to the
 * i32-typed `cast.i64_of` stays a type error so the conversion is always
 * explicit, never coincidental.
 */
import * as cast from "std:runtime/cast"

let main = fn () -> unit do
  let c: char = 'A'
  let _n: i64 = cast.i64_of(x: c)
  return ()
end
