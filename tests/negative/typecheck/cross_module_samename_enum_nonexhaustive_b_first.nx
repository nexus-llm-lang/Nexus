// expect-fail: E2001
// expect-msg: non-exhaustive
// expect-msg: Blue
//
// Import-order-INDEPENDENT exhaustiveness across two modules that each declare
// an enum named `Color`. `color_two.Color` has `Red | Green`; `color_three.Color`
// has `Red | Green | Blue`. The two-variant `Color` is imported (and so
// registered) FIRST. `f` matches a value of the THREE-variant `Color` but omits
// `Blue`, so the match is genuinely non-exhaustive.
//
// Before the fix, the scrutinee reached exhaustiveness as the bare name `Color`
// and the registry resolved it to the FIRST same-name entry — here the
// two-variant `color_two.Color` — so `Red | Green` wrongly looked exhaustive and
// the match was ACCEPTED. At runtime `mk_blue()` (== Blue) was then misdispatched
// to the `Green` arm. The fix qualifies the parameter's enum reference with its
// declaring module so exhaustiveness resolves the true (three-variant) `Color`
// and demands `Blue`, independent of import order.

import { touch } from "tests/_fixtures/color_two.nx"
import { Color, mk_blue } from "tests/_fixtures/color_three.nx"

let f = fn (c: Color) -> i64 do
  match c do
    | Red -> return 1
    | Green -> return 2
  end
end

let main = fn () -> unit do
  let _ignore = touch()
  let _r = f(c: mk_blue())
  return ()
end
