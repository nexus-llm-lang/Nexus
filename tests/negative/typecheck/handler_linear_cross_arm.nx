// expect-fail: E2035
// expect-msg: linear binding
// expect-msg: token
// expect-msg: cross-arm
//
// T-Handler cross-arm uniqueness premise:
//   ∀ y ∈ dom(Γ_cap). |{ j ∈ J | y ∈ fv(e_j) }| = 1
//
// A handler's closure environment binds each captured linear value exactly
// once.  When two arms both reference the same linear binding, both arms'
// T-Lambda derivations would consume it — double-consuming a single-use
// resource.  The typechecker must reject this at the handler construction site
// where the outer env is still available.
//
// Here %token is a linear binding in the outer env.  Both the `info` arm and
// the `error` arm capture it, violating the uniqueness premise.

type Token = Token(id: i64)

cap Logger do
  fn info(msg: string) -> unit
  fn error(msg: string) -> unit
end

let consume_token = fn (%tok: Token) -> unit do
  let Token(id: _) = %tok
  return ()
end

let main = fn () -> unit do
  let %token = Token(id: 42)
  let bad = handler Logger do
    fn info(msg: string) -> unit do
      consume_token(tok: %token)
      return ()
    end
    fn error(msg: string) -> unit do
      consume_token(tok: %token)
      return ()
    end
  end
  return ()
end
