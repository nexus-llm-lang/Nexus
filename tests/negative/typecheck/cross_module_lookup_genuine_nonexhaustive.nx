// expect-fail: E2001
// expect-msg: non-exhaustive
// expect-msg: Missing
//
// Companion to tests/typecheck/exhaustive/cross_module_lookup_collision_test.nx.
// The cross-module same-name `Lookup` disambiguation must NOT mask a genuine
// coverage hole: omitting the `Missing` arm of stringmap's `Lookup` is still a
// non-exhaustive match and must be rejected, even with hashmap's `Lookup`
// (whose `Found`/`Missing` are differently module-qualified) also in scope.
//
// Filename omits `_test` so `nexus test` does not pick it up as a runnable test.

import { StringMap, Found, Missing }, * as sm from "std:stringmap"
import { Lookup }, * as hm from "std:hashmap"

let probe = fn (m: &StringMap<i64>, key: string) -> i64 do
  match sm.get(map: m, key) do
    | Found(value: v) -> return v
  end
end

let main = fn () -> unit do
  return ()
end
