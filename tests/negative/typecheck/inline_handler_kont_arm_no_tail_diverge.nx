// expect-fail: E2001
// expect-msg: return type is non-unit
// expect-msg: tail
//
// T-Continuation premise: for a `with @k` handler arm, every control path
// through the arm body must terminate divergently — explicit `return`, `throw`,
// or loop. An implicit-unit fall-through is unsound because κ may be non-unit
// and the arm is obligated to produce one.
//
// The inline-handler path (handler expression used directly, rather than
// bound via top-level `let h = handler ...`) goes through check_arm_body,
// which was missing the tail-divergence guard present in check_function.
// This fixture exercises that inline path: the arm declares `-> i64`, forces
// @k (satisfying linearity), but never returns the result — the body falls
// off the end with unit type. Must be rejected with E2001.

cap Yield do
  fn yield_val() -> i64
end

let main = fn () -> unit do
  let my_handler = handler Yield do
    fn yield_val() -> i64 with @k do
      let r = @k
    end
  end
  return ()
end
