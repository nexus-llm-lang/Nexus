// expect-fail: E2001
// expect-msg: does not end with a `return` or `throw`
//
// Strict T-Lambda (spec: τ_r ≠ unit ⟹ tail(s†) = ⊥): a trailing `if/else`
// used as a non-unit function's implicit return value is rejected. The if is a
// bare expression statement that "falls off the end" — neither branch is an
// explicit `return`/`throw`, so the function does not diverge on all paths.
//
// (`return if c then 1 else 2 end` — an explicit return of the if as an
// EXPRESSION — is a different, accepted shape; see the positive control in
// tests/typecheck/value_fn_return_required_test.nx.)

let trailing_if = fn (c: bool) -> i64 do
  if c then 1 else 2 end
end

let main = fn () -> unit do
  return ()
end
