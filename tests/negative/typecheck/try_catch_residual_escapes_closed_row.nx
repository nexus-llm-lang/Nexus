// expect-fail: E2001
// expect-msg: exception not in throws row
//
// nexus-8xulk: a selective `catch` whose UNCAUGHT residual is not in the
// enclosing declared throws row must be REJECTED. Here `handle` declares
// `throws {}`, the try body throws `E2`, but the catch only handles `E1` —
// so the residual `{E2}` escapes a `throws {}` function and must be a type
// error at the `throw E2` site.
//
// Regression: the selective-`catch` desugar appends a synthetic
// `| __exn_v -> throw __exn_v` re-throw arm. The catch-all detector
// (`is_synthetic_rethrow_arm`) failed to recognise that arm (it compared the
// arm body — a `Raise(Variable __exn_v)` — against the *unwrapped* var), so
// the selective catch was mistaken for a catch-all. That opened the try body's
// throws-row, admitting `throw E2` and silently leaking E2 at runtime (an
// uncaught Wasm exception out of a `throws {}` function). The fix unwraps the
// `Raise` before the synthetic-arm check, keeping the catch SELECTIVE so the
// body row stays `{E1}` and `throw E2` is rejected.

exception E1
exception E2

let handle = fn () -> i64 throws {} do
  try
    throw E2
  catch
    | E1 -> return 1
  end
end

let main = fn () -> unit do
  let _v = handle()
  return ()
end
