// expect-fail: E2001
// expect-msg: is used at an element type incompatible with the handler in scope
//
// Generic-capability soundness (P1, memory-unsafety): a generic cap `Box<T>`
// whose method is called from a `require { Box }`-annotated helper LAUNDERS the
// element type past the inject-body shadow. The shadow
// (handler_validation.apply_injected_handler_instances) only re-binds
// `Box.wrap` inside the inject body's DIRECT scope; `helper` is type-checked
// standalone, decoupled from any inject, so `Box.wrap(x: n)` with `n: i64`
// unifies the cap's `T = i64` unchecked. Under `inject box_str` (Box<string>),
// calling `helper` would deliver an i64 where the string handler arm expects a
// string pointer — an out-of-bounds memory access in a "well-typed" program.
//
// The fix pins the element type a function commits to onto its require contract
// (`helper` publishes `require { Box<i64> }`), and the call-site coverage
// (T-CapCall) unifies that against the injected handler's `Box<string>`, so the
// mismatched call is rejected at typecheck instead of trapping at run time.
//
// The matching-type uses (helper under a Box<i64> handler, or a polymorphic
// `fn <T>` helper under either handler) are still accepted — see
// tests/runtime/effects/generic_cap_two_instantiations_test.nx.
import * as str from "std:str"

cap Box<T> do
  fn wrap(x: T) -> i64
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1
  end
end

let box_str = handler Box do
  fn wrap(x: string) -> i64 do
    return str.length(s: x)
  end
end

// Monomorphic helper that COMMITS Box to i64 in its body, but declares only a
// bare `require { Box }`.
let helper = fn (n: i64) -> i64 require { Box } do
  return Box.wrap(x: n)
end

let main = fn () -> unit do
  // Under a Box<string> handler, calling `helper` (which uses Box at i64) is the
  // laundered type confusion and must be rejected. (box_i64 keeps the handler
  // referenced so the program is otherwise well-formed.)
  inject box_i64 do
    let ok = helper(n: 5)
  end
  inject box_str do
    let bad = helper(n: 999999)
  end
  return ()
end
