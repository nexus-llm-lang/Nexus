// expect-fail: E2013
// expect-msg: unknown capability
// expect-msg: BogusPortCap
//
// D-Cap wfCap (docs/spec/type-system-formal.md §D-Cap line 1647):
// ∀j∈J. wfCap(α_j) ∧ wfThrow(β_j) for every declared method signature.
// `BogusPortCap` is neither a system capability nor a declared cap, so
// the typechecker must reject the `cap Logger` declaration.
//
// Before the fix, convert_cap_sigs_go dropped all fields except `name`,
// meaning HirCapMethod carried no require/throw rows — the D-Cap
// introduction-site wfCap premise could never fire.
//
// nexus-o8ir

cap Logger do
  fn log(msg: string) -> unit require { BogusPortCap }
end

let main = fn () -> unit do
  return ()
end
