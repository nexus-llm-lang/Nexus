// expect-fail: E2033
// expect-msg: type argument #1 of 'Pair' is linear
// expect-msg: generic instantiation at a linear type is not supported
//
// Type-formation rule: a function parameter annotation
// `(p: Pair<%bb, i64>)` instantiates the generic `Pair<A, B>` at a linear
// `A = %ByteBuffer`. Persistent generic containers deliver their payload
// by alias on every read (e.g. two `let Pair(left: x, right: _) = p`
// unpacks), which would duplicate the linear value.
//
// Spec: type-system-formal §Linearity (worked example
// linear(Pair<%i64,i64>) = true; structural over type arguments).

import * as bb from "std:bytebuffer"
import { Pair } from "std:tuple"

let f = fn (p: Pair<%ByteBuffer, i64>) -> unit do
  return ()
end

let main = fn () -> unit do
  return ()
end
