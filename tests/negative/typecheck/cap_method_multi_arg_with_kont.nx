// expect-fail: E5002
// expect-msg: multi-arg suspend payload is unspecified
// expect-msg: Logger.log
//
// A `with @k` handler arm lowers to a wasm `suspend`, which packs exactly one
// payload value across the suspend/resume boundary. A cap method declaring two
// or more parameters therefore has no defined multi-arg suspend ABI.
//
// This is rejected at TYPECHECK (handler arm/cap signature cross-validation in
// check/handler_validation.nx): when an arm carries a continuation binder and
// the cap method it implements declares >= 2 parameters, a clean E5002
// (MultiArgSuspendArm) diagnostic is raised.
//
// The rejection must happen before MIR build: MIR still carries a defensive
// `throw MirMultiArgSuspend` (also E5002), but because the compiler itself now
// compiles with `with @k`, throwing that exception at MIR-build time unwinds
// across the compiler's own stack-switching resume frame and hits an upstream
// wasmtime fiber-stack double-free, crashing the compiler instead of producing
// a diagnostic. Catching the case at typecheck keeps well-typed user programs
// from ever reaching the MIR throw.

cap Logger do
  fn log(msg: string, level: i64) -> unit
end

let my_handler = handler Logger do
  fn log(msg: string, level: i64) -> unit with @k do
    @k
  end
end

let main = fn () -> unit do
  inject my_handler do
    Logger.log(msg: "hello", level: 1)
  end
  return ()
end
