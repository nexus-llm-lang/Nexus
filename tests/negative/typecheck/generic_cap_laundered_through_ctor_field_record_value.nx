// expect-fail: E2001
// expect-msg: is used at an element type incompatible with the handler in scope
//
// Generic-capability soundness, REJECT side — a `Box<i64>`-committed closure
// laundered through a RECORD-typed VALUE stored in a CONSTRUCTOR field. This is
// the residual sibling of:
//   - generic_cap_laundered_through_ctor_field.nx (the cap ARROW directly in a
//     ctor field), and
//   - generic_cap_laundered_through_record_literal_field.nx (xy1se: the cap
//     arrow in a structural-record LITERAL passed as a fn argument).
//
// Here the constructor field's declared type is a RECORD carrying the cap arrow:
//   `type Holder = Holder(rec: { g: (..) -> .. require { Box } })`.
// The record value is built ONCE at a top-level binding (under the empty ambient
// row, so the record-literal coverage admits it) and then placed into the
// constructor field `Holder(rec: payload)` under a MISMATCHED `Box<string>`
// handler. A bare reference to the value-binding registers with a nullary-thunk
// placeholder shape, so the inner record value — which still carries its
// concrete `Box<i64>` commitment — was hidden one arrow-layer deep and the
// constructor-field cap coverage failed to descend into it: the i64-committed
// closure could be projected out and invoked under the string handler (a raw
// i64 read as a string descriptor — memory-unsafe type confusion). Must be
// rejected at the construction site.
import * as str from "std:str"

cap Box<T> do
  fn wrap(x: T) -> i64
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1
  end
end

let box_str = handler Box do
  fn wrap(x: string) -> i64 do
    return str.length(s: x)
  end
end

let need_i64 = fn (seed: i64) -> i64 require { Box } do
  return Box.wrap(x: seed)
end

type Holder = Holder(rec: { g: (s: i64) -> i64 require { Box } })

// Built under the empty top-level ambient row; the `g` field arrow keeps its
// concrete `Box<i64>` commitment.
let payload = { g: need_i64 }

let extract = fn (h: Holder, n: i64) -> i64 require { Box } do
  let Holder(rec: r) = h
  return r.g(s: n)
end

let main = fn () -> unit do
  inject box_i64 do
    let ok = extract(h: Holder(rec: payload), n: 5)
  end
  inject box_str do
    let bad = extract(h: Holder(rec: payload), n: 1234567)
  end
  return ()
end
