// expect-fail: E2001
// expect-msg: non-exhaustive match
//
// Pattern matches must cover every variant of the sum type they scrutinize.
// Omitting one (`Blue` here) is caught at typecheck time. Add the missing
// arm or insert a wildcard `_ -> ...` to silence the warning intentionally.

type Color = Red | Green | Blue

let main = fn () -> unit do
  let c = Red
  let _ = match c do
    | Red -> 1
    | Green -> 2
  end
  return ()
end
