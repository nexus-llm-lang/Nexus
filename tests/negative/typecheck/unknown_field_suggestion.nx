// expect-fail: E2026
// expect-msg: did you mean
//
// "did you mean?" suggestion for UnknownField (nexus-bpjd): when a field
// access references a field that does not exist on the record type, the
// typechecker collects field names from the record and suggests near-matches.
// `nme` has edit-distance 1 from `name` (deletion of `a`), so the error
// should include a suggestion.

let main = fn () -> unit do
  let p = { name: "Alice", age: 30 }
  p.nme
  return ()
end
