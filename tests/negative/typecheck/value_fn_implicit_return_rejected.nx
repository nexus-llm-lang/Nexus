// expect-fail: E2001
// expect-msg: does not end with a `return` or `throw`
//
// Strict T-Lambda (spec: τ_r ≠ unit ⟹ tail(s†) = ⊥): a non-unit function may
// NOT supply its return value via an implicit trailing expression. A bare
// literal as the function's tail "falls off the end" with a value but no
// `return`/`throw`, and must be rejected with E2001.
//
// (Sibling fixtures cover the trailing-`if` and trailing-`match` shapes of the
// same hole: value_fn_trailing_if_implicit_return_rejected.nx /
// value_fn_trailing_match_implicit_return_rejected.nx. The accepting shapes —
// `return`-terminated bodies, `-> unit` fall-through, a `with @k do @k end`
// arm tail, and a `return` inside an `inject` body — are exercised as a
// positive control in tests/typecheck/value_fn_return_required_test.nx.)

let bare_literal = fn () -> i64 do
  42
end

let main = fn () -> unit do
  return ()
end
