// expect-fail: E2021
// expect-msg: unreachable code after diverging statement
//
// T-Seq (spec type-system-formal.md): when a statement has type ⊥
// (diverges — throw or return), all subsequent statements in the same
// block are unreachable and must be rejected (E2021).
//
// nexus-10lu

import * as test_assert from "std:test/assert"

exception Boom(code: i64)

let trigger = fn () -> i64 throws { Exn } do
  throw Boom(code: 1)
  return 0   // dead code — throw diverges; E2021
end

let main = fn () -> unit throws { Exn } do
  trigger()
  return ()
end
