// expect-fail: E2001
// expect-msg: two incompatible element types in the same require scope
//
// Generic-capability soundness (P1, memory-unsafety) — DOUBLE-COMMIT at two
// incompatible element types in ONE require scope. A function declaring a bare
// `require { Box }` for the generic cap `Box<T>` commits, in its body, to a
// SINGLE element type. Here `confused` commits Box at BOTH i64 (`Box.wrap(x: n)`)
// and string (`Box.wrap(x: s)`). The two commits contradict: no single handler
// can satisfy both, so the function has no sound contract.
//
// Before the fix, the contract-derivation pass (cap_contract.nx) re-pinned the
// cap's fresh element variable independently per cap call (the ambient require
// row was not threaded through the per-statement substitution), so the FIRST
// commit silently won and the function published `require { Box<i64> }`. Under
// the matching `inject box_i64`, the unchecked SECOND commit
// (`Box.wrap(x: s)` with `s: string`) delivered a string heap pointer into the
// i64 handler arm, which added 1 to it and returned it as an i64 — a laundered
// value of the wrong type leaking out of a "well-typed" program.
//
// The fix threads the ambient require row through inference so the second commit
// unifies against the already-pinned `Box<i64>` and FAILS. A contradiction is a
// type error (rejected here) rather than a silently-dropped commit; a single
// concrete commit (`Box<string>` only) or a genuinely polymorphic helper
// (`fn <T> ... Box.wrap(x: x)` → `Box<T>`) is still accepted — see
// tests/runtime/effects/generic_cap_two_instantiations_test.nx and
// tests/negative/typecheck/generic_cap_call_laundered_through_helper.nx.
cap Box<T> do
  fn wrap(x: T) -> i64
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1
  end
end

// Commits Box at i64 AND string in the same scope — an unsatisfiable contract.
let confused = fn (n: i64, s: string) -> i64 require { Box } do
  let a = Box.wrap(x: n)
  let b = Box.wrap(x: s)
  return b
end

let main = fn () -> unit do
  inject box_i64 do
    let leaked = confused(n: 1, s: "hi")
    ()
  end
  return ()
end
