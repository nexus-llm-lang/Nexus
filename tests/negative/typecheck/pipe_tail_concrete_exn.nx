// expect-fail: E2031
// expect-msg: must be a row variable
//
// Negative fixture (wfThrow pipe-tail): the pipe form `{ ... | T }` opens a
// throws row over a row VARIABLE (a bound `<R>` quantifier). A CONCRETE
// exception in tail position is malformed — it would otherwise be treated as
// a fully-open row, silently dropping the tail member from containment.
//
// Here `g` declares `throws { E | F }` and throws `F`. If the tail `F` were
// accepted as fully-open, `h` (declaring only `throws { E }`) could call `g`
// and `F` would escape `h`'s declared row uncaught. The inclusive closed
// multi-member form is the comma list `{ E, F }`.

exception E
exception F

let g = fn () -> i64 throws { E | F } do throw F end

let h = fn () -> i64 throws { E } do return g() end

let main = fn () -> unit do
  return ()
end
