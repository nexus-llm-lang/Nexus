// expect-fail: E2001
// expect-msg: supplies arm
// expect-msg: not declared as a method
// expect-msg: T-Handler arm/method 1-1 correspondence
//
// T-Handler spec (nexus-v3xa.8): inline handler literals must not supply extra
// arms that are not declared as cap methods.
//
// The cap Logger declares one method: `log`. The inline handler inside `main`
// additionally supplies `debug`, which is not a declared method of Logger.
// The typechecker must reject this at the handler construction site with a
// TypeMismatch (E2001).
//
// Before the fix, extra arms in inline handlers were silently admitted as
// unreachable dead code with no diagnostic.

cap Logger do
  fn log(msg: string) -> unit
end

let main = fn () -> unit do
  let h = handler Logger do
    fn log(msg: string) -> unit do return () end
    fn debug(msg: string) -> unit do return () end
  end
  let _ = h
  return ()
end
