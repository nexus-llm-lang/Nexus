// expect-fail: E2001
// expect-msg: is used at an element type incompatible with the handler in scope
//
// Generic-capability soundness (P1, memory-unsafety) — COMPLEX-ARG laundering.
// A generic cap `Box<T>` is laundered when the cap-method argument is NOT a
// direct parameter reference or literal but a value computed in the body:
// `let m = n + 1; Box.wrap(x: m)`. The committed element type (`i64`, the type
// the body infers for `m`) must still be pinned onto `helper`'s published
// contract (`require { Box<i64> }`) so that calling `helper` under
// `inject box_str` (Box<string>) is rejected — it would deliver an i64 where the
// string handler arm expects a string pointer.
//
// The committed instantiation is derived by REAL inference: the typechecker
// already infers `m : i64` when checking the body, and the cap-call coverage
// unifies the cap method's instantiated type-arg against the function's ambient
// require row, resolving it to `Box<i64>`. The pre-pass captures that resolved
// row and publishes it. (A purely syntactic body scan could only see param-ref
// or literal arguments and would miss `m`, leaving the entry element-agnostic.)
//
// The matching-handler use (helper under a Box<i64> handler) is still accepted —
// see tests/runtime/effects/generic_cap_two_instantiations_test.nx.
import * as str from "std:str"

cap Box<T> do
  fn wrap(x: T) -> i64
end

let box_i64 = handler Box do
  fn wrap(x: i64) -> i64 do
    return x + 1
  end
end

let box_str = handler Box do
  fn wrap(x: string) -> i64 do
    return str.length(s: x)
  end
end

// The cap-method argument `m` is a body-local binding, not a parameter ref.
let helper = fn (n: i64) -> i64 require { Box } do
  let m = n + 1
  return Box.wrap(x: m)
end

let main = fn () -> unit do
  inject box_i64 do
    let ok = helper(n: 5)
  end
  inject box_str do
    let bad = helper(n: 999999)
  end
  return ()
end
