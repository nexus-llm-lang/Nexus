// expect-fail: E2001
// expect-msg: missing arm for declared method
// expect-msg: T-Handler arm/method 1-1 correspondence
//
// T-Handler spec (nexus-v3xa.8): the arm/method 1-1 correspondence check must
// apply to inline handler literals (inside a function body) as well as to
// top-level handler bindings.
//
// The cap Logger declares two methods: `log` and `warn`. The inline handler
// inside `main` supplies only `log`, omitting `warn`. The typechecker must
// reject this at the handler construction site with a TypeMismatch (E2001).
//
// Before the fix, inline handler arm sets were not validated — the missing arm
// was silently admitted and produced a confusing "unbound function" error at
// runtime when `warn` was called via inject.

cap Logger do
  fn log(msg: string) -> unit
  fn warn(msg: string) -> unit
end

let main = fn () -> unit do
  let h = handler Logger do
    fn log(msg: string) -> unit do return () end
  end
  let _ = h
  return ()
end
