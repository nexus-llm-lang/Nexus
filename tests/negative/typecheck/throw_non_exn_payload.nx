// expect-fail: E2001
// expect-msg: throw: payload must have type Exn
//
// T-Throw-Val enforcement (nexus-emjp): the thrown value must unify with
// Exn. Previously infer_raise inferred the inner expression type but
// discarded it (bound to `_`), so any non-Exn payload — integers,
// strings, booleans, records — silently type-checked. The fix adds a
// unify(τ, TyUserDefined("Exn", [])) step after infer_expr, matching
// the T-Throw-Val premise in the spec.

let main = fn () -> unit throws { Exn } do
  throw 42
end
