// expect-fail: E2001
// expect-msg: expected lazy type
//
// Negative fixture for nexus-16rto: a bare @-token binding used as the
// return value of a non-lazy function must be rejected.  The binding `t` has
// type @i64 (TyLazy) but the declared return type is i64; `return t` fails
// unification at the return slot with E2001.
//
// (Under strict T-Lambda there is no implicit return of a trailing expression,
// so the value must be supplied with an explicit `return`; the type mismatch
// that originally guarded against a leaked thunk pointer still fires there.)
//
// Before the fix, this compiled and the built wasm printed a thunk pointer
// (e.g. 16777216) instead of the forced value — a miscompile.

let leak = fn (n: i64) -> i64 do
  let @t = n + 7
  return t
end

let main = fn () -> unit do
  return ()
end
