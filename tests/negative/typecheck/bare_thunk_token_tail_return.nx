// expect-fail: E2001
// expect-msg: implicit tail return type mismatch
//
// Negative fixture for nexus-16rto: a bare @-token binding used as the
// implicit tail return of a non-lazy function must be rejected.
// The body type is @i64 (TyLazy) but the declared return type is i64;
// unification at the tail-return slot must fail with E2001.
//
// Before the fix, this compiled and `./nexus run` printed a thunk pointer
// (e.g. 16777216) instead of the forced value — a miscompile.

let leak = fn (n: i64) -> i64 do
  let @t = n + 7
  t
end

let main = fn () -> unit do
  return ()
end
