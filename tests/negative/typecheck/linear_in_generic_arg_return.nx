// expect-fail: E2033
// expect-msg: type argument #2 of 'Map' is linear
// expect-msg: return type
//
// Type-formation rule: a declared return type
// `fn () -> Map<string, %ByteBuffer>` instantiates the generic
// `Map<K, V>` at a linear `V = %ByteBuffer`. The persistent map would
// alias the linear payload across `map.get` calls, duplicating it on
// every read.
//
// Spec: type-system-formal §Linearity (linear inspects type arguments).

import * as bb from "std:bytebuffer"
import * as map from "std:collection/map"

let mk = fn () -> Map<string, %ByteBuffer> do
  return map.string_map()
end

let main = fn () -> unit do
  return ()
end
