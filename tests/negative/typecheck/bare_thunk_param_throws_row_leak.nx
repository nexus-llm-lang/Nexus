// expect-fail: E2001
// expect-msg: not admitted by caller
//
// Negative fixture (T-Force / P5 exception containment): a BARE shorthand
// thunk parameter `@i64` carries an OPEN `__implicit` deferred throws row
// (effect-polymorphic, so it can bundle a passed thunk's throws). A function
// that FORCES such a param must surface the passed thunk's deferred exceptions
// into ITS caller — they cannot silently vanish through a `throws {}` caller.
//
// Here `myforce` has a single bare `@i64` param (NO accompanying arrow param)
// and forces it (`return @a`). At the call `myforce(a: t)` in `go`, the
// argument `t : @(i64 throws { E })` unifies the deferred `{ E }` into the
// param's open `__implicit` row. Row unification leaves the callee throws row
// in a NESTED shape `TyRow([], Some(TyRow([E], Some(?r))))` — the concrete `E`
// buried one level deep in the tail. The call-admission check must flatten that
// row so `E` is visible, then REJECT it against `go`'s closed `throws {}` row.
//
// Before the fix the buried `E` slipped through the empty-head admission
// shortcut and `go` type-checked as `throws {}` while an uncaught `E` escaped
// at runtime. This is the bare-shorthand sibling of
// thunk_force_arrow_param_throws_row_mismatch.nx (which only rejected because
// of an incidental arrow param); removing the arrow param exposed the leak.

exception E(msg: string)

let thrower = fn () -> i64 throws { E } do
  throw E(msg: "boom")
end

let myforce = fn (a: @i64) -> i64 do
  return @a
end

let go = fn () -> i64 throws { } do
  let @t = thrower()
  return myforce(a: t)
end

let main = fn () -> unit do
  return ()
end
