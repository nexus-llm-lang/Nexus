// expect-fail: E2021
// expect-msg: unreachable code after diverging statement
//
// T-Seq (spec tail(s) = ⊥): `if c then THROW else THROW end` as an
// expression statement diverges when both arms diverge — subsequent
// statements are dead code (E2021).
//
// nexus-wgj7

import * as test_assert from "std:test/assert"

exception Boom(code: i64)

let trigger = fn (flag: bool) -> i64 throws { Exn, Boom } do
  if flag then
    throw Boom(code: 1)
  else
    throw Boom(code: 2)
  end
  return 0   // dead code — both if-arms diverge; E2021
end

let main = fn () -> unit throws { Exn, Boom } do
  trigger(flag: true)
  return ()
end
