// expect-fail: E2001
// expect-msg: T-Ctor
//
// Spec T-Ctor {ℓ} = {ℓ'}: the label at each argument position in a constructor
// expression must match the label declared on the constructor at that position.
// Reordered or misspelled labels (e.g. Box(content: 99) for Box(value: i64))
// silently produce wrong runtime values when the field types match, so they
// must be rejected.

type Box = Box(value: i64)

// Wrong label: declared field is `value`, user wrote `content`.
let main = fn () -> unit do
  let _ = Box(content: 99)
  return ()
end
