// expect-fail: E2033
// expect-msg: type argument #1 of 'Pair' is linear
// expect-msg: field 'x' of variant 'R' in type 'R'
//
// Type-formation rule: a record / variant field type that instantiates a
// generic at a linear (`x: Pair<%ByteBuffer, i64>`) is rejected. The
// containing record/enum would otherwise be observable as a path that
// duplicates the embedded linear value across pattern unpacks.
//
// Spec: type-system-formal §Linearity (worked example
// linear(Pair<%i64,i64>) = true).

import * as bb from "std:bytebuffer"
import { Pair } from "std:tuple"

type R = R(x: Pair<%ByteBuffer, i64>)

let main = fn () -> unit do
  return ()
end
