// expect-fail: E2001
// expect-msg: unbound function
//
// nexus-qbxqe regression (ssbiy sibling). A pair of inner-let lambdas that
// MUTUALLY recurse must resolve each sibling reference to the LOCAL block
// binding, NOT to a same-named top-level function.
//
// Before the fix (src/ir/hir/convert/core.nx convert_stmts_go), only the
// self-name `n` was dropped from the lambda RHS rename entries (the ssbiy
// self-recursion fix). A sibling reference (`b` inside `a`) stayed in the
// rename map and was renamed to the top-level canonical `…#b`, so the call
// SILENTLY routed to the OUTER identity `b` instead of the local one —
// `outer()` returned 3 (top-level `b(4-1)`) rather than the inner mutual
// recursion bottoming at 999/888. A silent miscompile.
//
// The fix drops EVERY block-level sibling let name (not just the self name)
// from a lambda RHS's rename entries, so the sibling reference no longer
// captures the top-level. Because local mutual recursion is a FORWARD
// reference (`a` names `b` before `b`'s `let` is processed by the sequential
// inference pass), the reference is now correctly reported as an unbound
// LOCAL function — identical to the non-shadowing control
// (no top-level `a`/`b`), which has always errored E2001. The point of this
// regression test is that the shadowing case must NOT silently miscompile to
// the wrong top-level binding; it must behave the same as the no-shadow case.
//
// (Self-recursive and backward sibling references under shadowing continue to
//  work; those are covered by tests/codegen/closures/
//  recursive_local_closure_shadow_test.nx.)

let a = fn (n: i64) -> i64 do return n end
let b = fn (n: i64) -> i64 do return n end

let outer = fn () -> i64 do
  let a = fn (n: i64) -> i64 do
    if n <= 0 then return 999 end
    return b(n: n - 1)
  end
  let b = fn (n: i64) -> i64 do
    if n <= 0 then return 888 end
    return a(n: n - 1)
  end
  return a(n: 4)
end

let main = fn () -> i64 do
  return outer()
end
