// expect-fail: E2001
// expect-msg: not admitted by caller's throws row
//
// nexus-d1gkw over-clearing guard: making a single-variable catch arm
// `catch e -> ...` a catch-all (clearing ρ_residual = {}) must NOT bleed into
// the SELECTIVE multi-arm path. A selective catch with specific-constructor
// arms and NO catch-all still leaves a residual throws-row for uncaught
// variants, which must be rejected against a `throws {}` caller.
//
// Here `handle` declares `throws {}`; `thrower` throws `B`; the catch only
// handles `A`. The residual `{B}` escapes the `throws {}` function and must be
// a type error at the call site (the multi-arm desugar uses catch_param
// "__exn", so it is NOT mistaken for the single-var catch-all).

exception A(num: i64)
exception B(num: i64)

let thrower = fn () -> i64 throws { A, B } do throw B(num: 100) end

let handle = fn () -> i64 throws {} do
  try
    return thrower()
  catch
  | A(num: n) -> return n
  end
end

let main = fn () -> unit do
  let _v = handle()
  return ()
end
