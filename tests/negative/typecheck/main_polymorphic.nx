// The entry point `main` must be monomorphic (P9 wfMain: Γ(main) = (ω, mono(...))).
// A polymorphic entry point has no caller that can specialise the type parameter,
// so its scheme must be ∀∅. τ. Declaring `main` with a type parameter is rejected
// regardless of the parameter's usage in the signature.

let main = fn <T> (x: T) -> unit do
  return ()
end
