// expect-fail: E2001
// expect-msg: non-exhaustive match
// expect-msg: O2(I2(_))
//
// Regression for nexus-hzlqc: when a nested constructor match leaves a gap
// inside the SECOND outer constructor (here `O2(i: I2(_))`), the
// non-exhaustiveness witness must name the genuinely-uncovered case, not the
// first (fully-covered) outer constructor `O1`.
//
// Before the fix the witness read `missing pattern for 'O1'` even though
// arms 1-2 cover all of `O1`; the only uncovered value is `O2(I2(_))`.

type Inner = I1(v: i64) | I2(v: i64)
type Outer = O1(i: Inner) | O2(i: Inner)

let f = fn (o: Outer) -> i64 do
  match o do
    | O1(i: I1(v)) -> return v + 1
    | O1(i: I2(v)) -> return v + 2
    | O2(i: I1(v)) -> return v + 3
  end
end

let main = fn () -> unit do
  let r = f(o: O1(i: I1(v: 0)))
  return ()
end
