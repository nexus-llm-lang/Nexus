// expect-fail: E2021
// expect-msg: unreachable code after diverging statement
//
// T-Seq (spec tail(s) = ⊥): `match e { p_i -> THROW }` as an expression
// statement diverges when all arms diverge — subsequent statements are
// dead code (E2021).
//
// nexus-wgj7

import * as test_assert from "std:test/assert"

exception Boom(code: i64)

type Tag = A | B

let trigger = fn (t: Tag) -> i64 throws { Exn, Boom } do
  match t do
    | A -> throw Boom(code: 1)
    | B -> throw Boom(code: 2)
  end
  return 0   // dead code — all match-arms diverge; E2021
end

let main = fn () -> unit throws { Exn, Boom } do
  trigger(t: A)
  return ()
end
