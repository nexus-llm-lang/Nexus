// expect-fail: E2001
// expect-msg: callee has no throws annotation
// expect-msg: caller declares a closed throws row
//
// nexus-w2x4: a `throws {}` function calling an unannotated function that
// throws must be rejected.  The unannotated callee gets an open throws-row
// `TyRow([], Some(TyVar("__implicit")))`, meaning its actual throws set is
// unknown.  The caller declares a closed empty row, so no exception can
// escape — but since we cannot verify the callee's throws set at compile
// time, the call must be rejected.
//
// Previously `check_call_throw_row_admitted` unconditionally returned RaiseOk
// for any open callee row, conflating the `__implicit` absent-annotation
// placeholder with a genuine effect-polymorphic variable (`<R>`-bound).

exception Boom

let leaky = fn () -> unit do
  throw Boom
end

let strict = fn () -> unit throws {} do
  leaky()
  return ()
end

let main = fn () -> unit do
  strict()
  return ()
end
