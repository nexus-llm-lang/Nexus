// expect-fail: E2001
// expect-msg: does not match any parameter name
//
// Negative fixture for nexus-z1258 (lambda-body scope leak — accept side).
// A `let` introduced inside a sibling lambda body must NOT leak into the
// enclosing block's typecheck Γ.
//
// `helper`'s body declares an inner shadow `let useG = fn (n: i64) ...`.
// Before the fix, that inner binding leaked back into `driver`'s block env,
// so a later call to the OUTER `useG` using the INNER label `n`
// (`useG(n: 3)`) was wrongly ACCEPTED — checked against the leaked inner
// signature (param `n`) instead of the outer one (param `a`).
//
// With the fix the inner shadow's scheme is confined to `helper`'s body, so
// `driver`'s `useG` is the outer one (param `a`); calling it with label `n`
// must be rejected as a label mismatch.  This is the reject-side guard for
// the accept fixture tests/typecheck/check/lambda_body_scope_no_leak_test.nx.

let driver = fn () -> i64 do
  let useG = fn (a: i64) -> i64 do return a + 10 end
  let helper = fn (k: i64) -> i64 do
    let useG = fn (n: i64) -> i64 do return n + 1 end
    return useG(n: k)
  end
  // `useG` here is the OUTER one (param `a`). Calling it with the inner
  // label `n` must NOT be silently accepted via a leaked inner scheme.
  return useG(n: 3) + helper(k: 0)
end

let main = fn () -> i64 do
  return driver()
end
