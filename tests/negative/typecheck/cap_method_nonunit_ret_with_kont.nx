// expect-fail: E2001
// expect-msg: returns a non-unit value
// expect-msg: no value channel
//
// A `with @k` handler arm resumes the suspended cap call via the bare
// continuation `@k`. There is no value channel back into the suspension — the
// parser already rejects the complementary `@k(v)` form (E1006, "resume with
// value is not supported"). If the cap method declares a NON-unit return type,
// the suspended `Cap.m()` call site expects a value of that type, but the bare
// `@k` resume supplies none. Before this check the missing return value was
// silently fabricated (zero-initialised: 0 / false / "" / a synthesized ctor),
// so the binding `let b = Choose.pick()` below received a garbage `false`
// instead of the intended resume value, silently taking the wrong branch.
//
// This is rejected at TYPECHECK (handler arm/cap signature cross-validation in
// check/handler_validation.nx): when an arm carries a continuation binder
// (`with @k`) and the cap method it implements declares a non-unit return type,
// a clean E2001 (TypeMismatch) diagnostic is raised, mirroring the parser's
// `@k(v)` rejection.
//
// Unit-returning `with @k` arms (the normal cooperative case, e.g.
// `Coop.yield() -> unit`) are STILL accepted: there is no value to channel back.

cap Choose do
  fn pick() -> bool
end

let yes_h = handler Choose do
  fn pick() -> bool with @k do
    @k
  end
end

let f = fn () -> string throws { RuntimeError } do
  inject yes_h do
    let b = Choose.pick()
    if b then return "TRUE-branch" else return "FALSE-branch" end
  end
end

let main = fn () -> unit do
  let s = f()
  return ()
end
