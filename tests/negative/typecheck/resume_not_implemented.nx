// expect-fail: E3002
// expect-msg: stack-switching IR node
// expect-msg: cont.resume
//
// LirExprResume is not implemented — the `with @k` / `@k` continuation-force
// path reaches codegen and must throw StackSwitchingNotImplemented (E3002)
// rather than silently emitting wrong wasm (pre-fix: stored the cont atom
// into a global slot and returned, leaving the wasm value stack short).
//
// The fix replaces the stub body in codegen.nx's LirExprResume arm with
// `throw StackSwitchingNotImplemented(node: "cont.resume")`, matching the
// LirExprContNew arm pattern on the adjacent line.
//
// nexus-ctgq

cap Logger do fn log(msg: string) -> unit end

let my_handler = handler Logger do
  fn log(msg: string) -> unit with @k do
    @k
  end
end

let main = fn () -> unit do
  inject my_handler do
    Logger.log(msg: "hello")
  end
  return ()
end
