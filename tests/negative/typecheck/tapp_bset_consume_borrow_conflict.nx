// Negative fixture for nexus-lo64 — T-App B-set premise violation.
//
// Spec §T-App B-set:
//   B = { x ∈ dom(Γ) | Γ(x) = (1,_) ∧ ∃i. e_i = &x ∧ ∀j. x ∈ fv(e_j) ⟹ e_j = &x }
//
// The ∀j condition requires that x appears ONLY as &x in the arg list.
// If another arg has a consuming use of x (Variable(x), non-Borrow), then
// x is NOT in B, and the &x goes through T-Borrow → x:^ω check → reject
// (x is linear, so q = 1, not ^ω).
//
// This fixture passes x as both a consuming arg and a borrow in the same call.
// expect-fail: E2001
// expect-msg: B-set
// expect-msg: consuming

import * as bb from "std:bytebuffer"

let consume_and_borrow = fn (p: bb.ByteBuffer, q: &bb.ByteBuffer) -> unit do
  bb.free(buf: p)
  let _ = q
  return ()
end

let main = fn () -> unit do
  let %x = bb.empty()
  // x appears as consuming arg 'p' and as borrow arg 'q' — B-set violation.
  consume_and_borrow(p: %x, q: &x)
  return ()
end
