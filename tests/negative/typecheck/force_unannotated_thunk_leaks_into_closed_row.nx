// expect-fail: E2001
// expect-msg: victim
// expect-msg: callee has no throws annotation
// expect-msg: caller declares a closed throws row
//
// A function that FORCES a throwing thunk must not be misclassified as
// provably-non-throwing.  Forcing is the discharge point of a deferred
// thunk: if the thunk's deferred body throws, the exception is raised at
// the force site.
//
// Here `victim` is UNANNOTATED (implicit open throws row).  It binds the
// result of `inner_throws()` (a thunk deferring a Boom) to a lazy `@t` and
// then forces it, so Boom is raised inside `victim` at runtime.  Because
// the forced thunk is held in a variable, its deferred throws row is opaque
// to the syntactic purity walk, so `victim` must NOT enter `fn_pure_set`.
//
// `strict` declares a closed empty throws row `throws {}` and calls
// `victim`.  Since `victim` is unannotated (open `__implicit` row) and not
// provably pure, the closed-row caller cannot admit the call and must be
// rejected.  Without the fix, `victim` was wrongly classified pure and the
// call short-circuited, letting Boom escape the closed boundary at runtime.
//
// Distinct from `force_throwing_thunk_in_pure_fn.nx`, where the forcing
// function ITSELF declares `throws {}` and T-Force discharge rejects it;
// here the forcing function is unannotated and the leak surfaces one frame
// up, at the `throws {}` caller.

exception Boom

let inner_throws = fn () -> i64 throws { Boom } do
  throw Boom
end

let victim = fn () -> i64 do
  let @t = inner_throws()
  let v = @t
  return v
end

let strict = fn () -> i64 throws {} do
  return victim()
end

let main = fn () -> unit do
  return ()
end
