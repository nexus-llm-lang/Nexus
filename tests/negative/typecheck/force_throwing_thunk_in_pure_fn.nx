// expect-fail: E2001
// expect-msg: ThunkError
//
// Negative fixture for nexus-v3xa.15: a function that forces a
// `@(i64 throws { ThunkError })` thunk must surface the deferred
// ThunkError at the force site; when the enclosing function declares
// `throws {}`, the T-Force throw_row discharge must reject the force.

exception ThunkError

// `consume` declares `throws {}` and forces its argument.  The argument
// is annotated `@(i64 throws { ThunkError })` — a thunk that defers a
// ThunkError.  T-Force checks the thunk's throw_row (`{ThunkError}`)
// against the caller's `throws {}` (closed empty) and rejects.

let consume = fn (th: @(i64 throws { ThunkError })) -> i64 throws {} do
  return @th
end

let main = fn () -> unit do
  return ()
end
