// expect-fail: E2001
// expect-msg: throw Exn: exception not in throws row
//
// T-Throw-Val (catch-bound rethrow): `throw e` where e : Exn emits the
// catch-all sentinel {Exn} into the throws row.  U-Row-Exn is directional:
// {Exn} on the actual side cannot subsume a narrower declared row, so a
// function declaring `throws { NotFound }` with a `catch e -> throw e` body
// must be rejected (Disk could escape past the declared row uncaught).

exception NotFound(path: string)

let f_rethrow = fn () -> unit throws { NotFound } do
  try
    throw NotFound(path: "x")
  catch e ->
    throw e
  end
  return ()
end

let main = fn () -> unit do return () end
