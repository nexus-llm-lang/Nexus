// expect-fail: E2001
// expect-msg: throw Exn: exception not in throws row
//
// T-Throw-Val (catch-bound rethrow): a catch-all `catch e -> throw e` re-raises
// whatever the try body threw. When the try body throws an exception OUTSIDE
// the declared row (here `Disk`, while the function declares only
// `throws { NotFound }`), the catch-all swallows `Disk` and the rethrow re-emits
// it, so `Disk` escapes past the narrower declared row uncaught. The
// catch-binder admission only relaxes the strict check when the body's ACTUAL
// thrown set is a subset of the declared row; here it is not, so the rethrow
// must still be rejected.

exception NotFound(path: string)
exception Disk(code: i64)

let g = fn () -> unit throws { Disk } do throw Disk(code: 5) end

let f_rethrow = fn () -> unit throws { NotFound } do
  try
    g()
  catch e ->
    throw e
  end
  return ()
end

let main = fn () -> unit do return () end
