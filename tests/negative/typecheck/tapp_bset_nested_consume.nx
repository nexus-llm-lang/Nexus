// Negative fixture for nexus-m5ek — T-App B-set recursive scan.
//
// Spec §T-App B-set:
//   x ∈ B  iff  (∃i. e_i = &x)  ∧  (∀j. x ∈ fv(e_j) → e_j = &x)
//
// The ∀j condition requires that x appears ONLY as &x across all args.
// When x appears inside a sub-expression arg (e.g. id_buf(y: x)), that is a
// consuming use of x — x is NOT in B, so the &x borrow is invalid.
//
// Bug (pre-fix): args_has_consuming_use_of only checked top-level Variable(x)
// nodes. A nested call like id_buf(y: x) has top-level Call(...), not
// Variable(x), so x was missed and the violation was silently accepted.
//
// expect-fail: E2001
// expect-msg: B-set
// expect-msg: consuming

import * as bb from "std:bytebuffer"

// Identity function: takes and returns a linear ByteBuffer.
let id_buf = fn (y: bb.ByteBuffer) -> bb.ByteBuffer do
  return y
end

// Takes a borrow and a consuming linear arg.
let use_both = fn (p: &bb.ByteBuffer, q: bb.ByteBuffer) -> unit do
  q
  p
  return ()
end

let main = fn () -> unit do
  let %x = bb.empty()
  // &x appears as a borrow arg 'p', while id_buf(y: x) consumes x inside
  // a nested call for arg 'q'.  This is a B-set violation: x ∈ fv(id_buf(y: x))
  // but the arg is not &x.
  use_both(p: &x, q: id_buf(y: x))
  return ()
end
