// expect-fail: E1001
// expect-msg: parse error
//
// \u{} escapes that name a codepoint above U+10FFFF are invalid Unicode and
// must be rejected at lex time. The lexer sets TkError on the enclosing
// string literal, which the parser surfaces as a parse error (E1001).

let main = fn () -> unit do
  let _ = "\u{110000}"
  return ()
end
