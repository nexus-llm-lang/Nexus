// expect-fail: E2017
// expect-msg: require-row contains user-declared port
//
// Spec P9 wfMain: rho_q <= SysCaps -- main's require row may only contain
// system capabilities. A user-declared port has no enclosing inject to
// provide it at the program entry point.

cap MyLogger do
  fn log(msg: string) -> unit
end

let main = fn () -> unit require { MyLogger } do
  return ()
end
