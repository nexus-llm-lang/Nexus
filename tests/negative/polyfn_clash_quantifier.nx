// expect-fail: E2012
// expect-msg: type parameter
// expect-msg: row-tail position
//
// Spec §"Polymorphism Introduction" (type-system-formal.md L548–L571):
// kindOf(R, σ) is undefined when R appears at BOTH a type position
// (occurs_τ) AND as a row tail (occurs_ρ) — the "kind clash" case.
// The spec requires rejection at the binding site (T-Let-PolyFn) with
// E2012, not a confusing downstream unification error at a use site.
//
// Here R is used as a type in `x: R` (occurs_τ = true) and also as
// the row tail of `f`'s requires row `require { PermConsole | R }`
// (occurs_ρ = true). These two occurrences conflict — R cannot be
// simultaneously a Type-kind and a Row-kind quantifier.
//
// nexus-t9cl.21 (clash sub-case)

import { Console, system_handler } from "std:stdio"

let bad = fn <R>(x: R, f: () -> unit require { PermConsole | R }) -> R do
  return x
end

let trigger = fn () -> unit require { PermConsole } do
  let _ = bad(x: 1, f: fn () -> unit require { PermConsole } do return () end)
  return ()
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    trigger()
    return ()
  end
end
