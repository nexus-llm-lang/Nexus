// expect-fail: E1005
// expect-msg: duplicate parameter label
// expect-msg: distinct
//
// A function declaration (and fn expression) must have distinct parameter
// names. Duplicate parameter labels make the second binding unreachable
// and shadow the first, which is always a programming error.
//
// nexus-rdq4

let foo = fn (x: i64, x: bool) -> unit do
  return ()
end

let main = fn () -> unit do
  return ()
end
