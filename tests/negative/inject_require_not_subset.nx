// expect-fail: E2016
// expect-msg: requires capability
// expect-msg: PermConsole
// expect-msg: ambient require row
//
// T-Inject (docs/spec/type-system-formal.md) carries the premise
// ∀i. ρ_i ⊆ ρ_q: each injected handler's declared require row must be
// a subset of the enclosing function's ambient require row.
//
// `console_logger` is a handler that requires `PermConsole`.
// `main` is declared with an empty require row (`require {}`).
// Therefore `PermConsole` is not in the ambient row at the inject site,
// and the typechecker rejects with E2016.
//
// nexus-1hmr

cap Logger do fn log(msg: string) -> unit end

let main = fn () -> unit do
  let console_logger = handler Logger require { PermConsole } do
    fn log(msg: string) -> unit do return () end
  end
  inject console_logger do
    return ()
  end
end
