// expect-fail: E5002
// expect-msg: multi-arg suspend payload is unspecified
// expect-msg: Logger.log
//
// lower_port_call in mir.nx builds a MirSuspend node when the handler arm
// carries a cont_binder (`with @k`). MirSuspend carries a single payload
// value; the wasm `suspend` instruction has no defined ABI for packing
// multiple arguments across the suspend/resume boundary.
//
// Before the fix, lower_port_call silently dropped all args past the first
// (mir_args head), producing wrong runtime behaviour with no diagnostic.
// After the fix (nexus-i3gl), lower_port_call throws MirMultiArgSuspend
// (E5002) when len(mir_args) > 1, so the user gets a clear error instead
// of a silent value drop.
//
// nexus-i3gl

cap Logger do
  fn log(msg: string, level: i64) -> unit
end

let my_handler = handler Logger do
  fn log(msg: string, level: i64) -> unit with @k do
    @k
  end
end

let main = fn () -> unit do
  inject my_handler do
    Logger.log(msg: "hello", level: 1)
  end
  return ()
end
