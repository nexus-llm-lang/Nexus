// expect-fail: E2007
// expect-msg: linear binding
// expect-msg: never consumed
//
// A linear binding introduced inside a divergent match arm (one that ends with
// `return`) must be consumed before the divergence.  Previously the linearity
// pass discarded the arm's LinState without checking for inner-scope leaks,
// so `%h` below was silently accepted despite never being consumed (nexus-bxzy).

type Handle = Handle(fd: i64)

let consume_handle = fn (h: %Handle) -> unit do
  let Handle(fd: _) = h
  return ()
end

let main = fn () -> unit do
  let cond = true
  match cond do
    | true ->
      let %h = Handle(fd: 0)
      return ()    // %h leaks here — must be E2007
    | false ->
      let %h2 = Handle(fd: 0)
      consume_handle(h: h2)
      return ()
  end
end
