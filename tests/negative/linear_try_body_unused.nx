// expect-fail: E2007
// expect-msg: linear binding
// expect-msg: never consumed
//
// A linear binding introduced inside a try body that is never consumed must
// fire E2007 (LinearUnused), not E2009 (LinearMismatch). Previously the
// linearity pass reached the arms-consistency check and reported "try/catch
// arms diverge on linear set" instead of identifying the root cause: the
// binding %h was never consumed inside the try body (nexus-uf8v).

exception Boom(code: i64)

type Handle = Handle(fd: i64)

let might_throw = fn () -> unit throws { Exn } do
  throw Boom(code: 1)
end

let main = fn () -> unit throws { Exn } do
  try
    let %h = Handle(fd: 0)
    might_throw()
    // %h is never consumed — must be E2007, not E2009
  catch e ->
    throw e
  end
  return ()
end
