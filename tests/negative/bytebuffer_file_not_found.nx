// expect-runtime-throw: before read
//
// `std:bytebuffer.read_binary_file` raises `FileNotFound(path)` (from
// `std:fs`) when the path does not resolve under the wasm sandbox.
// The fixture compiles cleanly because `main` widens the throws-row
// with `FileNotFound`, then surfaces the constructor as a non-zero
// exit at run time. wasmtime swallows the constructor name on
// stderr, so the runner anchors on the captured stdout line "before
// read".
//
// Idiomatic alternative: `try ... catch | FileNotFound(path) -> ... end`
// to surface a user-readable diagnostic, or stage the path through
// `Option` / `Result` so callers can recover.

import { Console, system_handler } from "std:stdio"
import * as bb from "std:bytebuffer"
import { FileNotFound } from "std:fs"

let main = fn () -> unit require { PermConsole, PermFs } throws { FileNotFound } do
  inject system_handler do
    Console.println(val: "before read")
    let %buf = bb.read_binary_file(path: "/this/path/does/not/exist")
    bb.free(buf)
    Console.println(val: "should never print")
  end
  return ()
end
