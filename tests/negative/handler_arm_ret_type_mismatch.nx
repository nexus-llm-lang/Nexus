// expect-fail: E2001
// expect-msg: return type does not match cap
// expect-msg: T-Handler
//
// T-Handler spec premise (nexus-00j4): each arm's ret_type must equal the
// corresponding cap method's declaration. Here the cap declares
// `fn transform(x: i64) -> i64` but the handler arm declares `-> string`.
// The cross-validation in register_handler_bindings must fire E2001.
//
// nexus-00j4

cap Converter do
  fn convert(x: i64) -> i64
end

let bad_converter = handler Converter do
  fn convert(x: i64) -> string do
    return "wrong"
  end
end

let main = fn () -> unit do
  return ()
end
