// expect-runtime-throw: before parse
//
// `std:str.to_f64` is the partial parse: it returns `f64` on success
// and raises `InvalidF64(s)` carrying the offending input. The fixture
// compiles cleanly because `main` widens the throws-row, then surfaces
// the constructor as a non-zero exit at run time. wasmtime does not
// echo the exception name, so the runner anchors on the captured
// stdout line "before parse".
//
// Idiomatic alternative: use `parse_f64_checked(s)` which returns
// `Option<f64>` instead of raising — caller pattern-matches `None`
// for the bad-input case.

import { Console, system_handler } from "std:stdio"
import { to_f64 } from "std:str"

let main = fn () -> unit require { PermConsole } throws { InvalidF64 } do
  inject system_handler do
    Console.println(val: "before parse")
    to_f64(s: "not a number")
    Console.println(val: "should never print")
  end
  return ()
end
