// expect-fail: E2001
// expect-msg: label mismatch
//
// Spec §U-Record premise ∀i. ℓᵢ¹ = ℓᵢ²: structural record fields must match
// by label name, not merely by position and type. A function expecting
// { x: i64, y: i64 } must not silently accept { a: i64, b: i64 } even
// when the field types are identical. unify_named_types must detect the
// label mismatch and reject this.

let use_xy = fn (p: { x: i64, y: i64 }) -> i64 do
  return p.x + p.y
end

let main = fn () -> unit do
  // Structural record { a: i64, b: i64 } has different labels than
  // { x: i64, y: i64 }. The positional types are identical (i64, i64)
  // but the label names differ — unify_named_types must reject this.
  let _: i64 = use_xy(p: { a: 1, b: 2 })
  return ()
end
