// expect-runtime-throw: integer overflow
// expect-msg: before divide
//
// Regression test for nexus-ka748: INT_MIN / -1 must BUILD cleanly (no
// compiler crash) and then trap at runtime with a wasm signed-overflow fault.
//
// Before the fix, the const-folder in src/ir/lir/opt/folding.nx eagerly
// evaluated `a / b` at compile time for OpDiv without guarding the
// INT_MIN / -1 edge.  The compiler itself runs as wasm, so i64.div_s
// trapped inside the compiler process, aborting compilation (exit 134)
// instead of producing a wasm binary.
//
// After the fix, the folder returns None for this input, deferring to the
// wasm runtime, which correctly traps with "integer overflow" exactly as it
// would for the non-constant (unfolded) form.

import { Console, system_handler } from "std:stdio"

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: "before divide")
    // i64::MIN / -1 via literal constants: the fixed folder defers to runtime.
    let i64_min: i64 = 0 - 9223372036854775807 - 1
    let quotient: i64 = i64_min / (0 - 1)
    Console.println(val: "should never print")
  end
  return ()
end
