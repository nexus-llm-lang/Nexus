// expect-fail: E1001
// expect-msg: invalid numeric literal
//
// `0xFF` must be rejected at lex time: the lexer sees `0` as an integer
// then `x` immediately follows with no separator, producing a TkError.
// This closes nexus-dzdn3 (was silently TkInt(0) + identifier `xFF`).

let main = fn () -> unit do
  let _x = 0xFF
  return ()
end
