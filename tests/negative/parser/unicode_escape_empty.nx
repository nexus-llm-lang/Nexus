// expect-fail: E1001
// expect-msg: at least one hex digit
//
// An empty `\u{}` escape is invalid: the grammar requires HEX_DIGIT+
// (one or more), so an empty run must be rejected at lex time rather than
// silently accepted as U+0000 (NUL). The lexer sets TkError on the
// enclosing string literal, which the parser surfaces as E1001.

let main = fn () -> unit do
  "\u{}"
  return ()
end
