// expect-fail: E1001
// expect-msg: expected ), got 'throws'
//
// Negative fixture for nexus-8tgwr item 2: bare effect rows in a parameter
// type position are a parse error (spec §Row Types: "effect rows are admissible
// ONLY on an arrow or as @'s operand").
//
// A bare `U throws { E }` in a param slot has no grammar production; the
// parser sees `throws` after the param type and rejects it.

exception BareErr

let fn_with_bare_throws = fn (x: i64 throws { BareErr }) -> i64 do
  return x
end

let main = fn () -> unit do
  return ()
end
