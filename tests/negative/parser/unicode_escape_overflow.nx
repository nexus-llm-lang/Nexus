// expect-fail: E1001
// expect-msg: must be at most U+10FFFF
//
// A `\u{...}` hex run of 17+ digits exceeds 2^64 and would wrap the i64
// accumulator. The lexer must detect over-range AS digits accumulate, so
// the run cannot wrap mod 2^64 past the closing-`}` range guard and slip
// through with a low-bits codepoint (e.g. `\u{10000000000000041}` wrapping
// to 0x41 = 'A'). It is rejected at lex time with the same diagnostic class
// as the non-overflowing over-range case (`\u{200000}`).

let main = fn () -> unit do
  "\u{10000000000000041}"
  return ()
end
