// expect-fail: E2020
// expect-msg: duplicate field label
// expect-msg: distinct
//
// P-Record (docs/spec/type-system-formal.md) carries the premise
// distinct(ℓ̄): each label in a record pattern must appear at most once.
// {a: x, a: y} violates this because 'a' appears twice — the second
// binding would either shadow or corrupt the first at the match site.
// The typechecker enforces this statically and rejects with E2020.
//
// nexus-43s9

let main = fn () -> unit do
  let r = { a: 1 }
  match r do
    | { a: x, a: _y } -> return ()
  end
end
