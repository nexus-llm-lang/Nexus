// expect-fail: E1006
// expect-msg: resume-with-value
// expect-msg: not supported
//
// `@k(v)` resume-with-value is rejected at parse time. A continuation
// captured by a `with @k` handler arm can only be resumed with unit:
// there is no value channel back into the suspended cap call, so `@k(v)`
// would silently drop `v` and resume with unit. The parser rejects an
// `@ident` immediately followed by a call argument list rather than
// accept the misleading no-op.

cap Co do
  fn ask() -> i64
end

let h = handler Co do
  fn ask() -> i64 with @k do
    @k(42)
  end
end

let drive = fn () -> i64 do
  inject h do
    let v = Co.ask()
    v
  end
end

let main = fn () -> unit do
  let r = drive()
  return ()
end
