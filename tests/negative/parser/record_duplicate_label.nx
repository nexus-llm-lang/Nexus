// expect-fail: E2019
// expect-msg: duplicate field label
// expect-msg: distinct
//
// T-Record (docs/spec/type-system-formal.md) carries the premise
// distinct(ℓ̄): each label in a record literal must appear at most once.
// {a: 1, a: 2} violates this because 'a' appears twice — the resulting
// TyRecord would have an ambiguous T-Proj lookup for field 'a'.
// The typechecker enforces this statically and rejects with E2019.
//
// nexus-70ng

let main = fn () -> unit do
  let _r = { a: 1, a: 2 }
  return ()
end
