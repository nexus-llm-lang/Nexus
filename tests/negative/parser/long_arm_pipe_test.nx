// expect-runtime-throw: reached arm two
//
// Regression for nexus-cmm0 — pipe_starts_arm had an arbitrary 4096-token
// fuel cap. When the lookahead from a `|` to the nearest depth-0 `->` required
// scanning more tokens than the cap, the scan returned false and the `|` was
// misclassified as OpBitOr. In practice this fires when arm bodies are long
// enough that the arm-separator `|` for the NEXT arm is encountered only after
// the cap is exhausted during scanning.
//
// The fix removes the cap entirely (always scan to `->` or TkEof). This
// fixture verifies that a match with a long first arm body compiles correctly
// and that the second arm (`| _ ->`) is reachable. Post-fix the program
// compiles, enters arm two, prints "reached arm two", and throws `Unreachable`
// — wasmtime exits non-zero and the runner anchors on "reached arm two".

import { Console, system_handler } from "std:stdio"

exception Unreachable

// The first match arm has a long body (many let-bindings), followed by a
// second arm `| _ -> "nonzero"`. When the parser processes the first arm
// and then encounters the `|` that begins the second arm, it calls
// pipe_starts_arm to check whether the `|` is an arm-separator or
// bitwise-or. The scan must traverse the second arm's pattern (`_`) to
// reach `->`. Removing the fuel cap ensures this works regardless of
// how large the first arm body grows.
let classify = fn (n: i64) -> string do
  match n do
    | 0 ->
      let a = "zero"
      let b = "zero"
      let c = "zero"
      let d = "zero"
      let e = "zero"
      let f = "zero"
      let g = "zero"
      let h = "zero"
      let i = "zero"
      let j = "zero"
      let k = "zero"
      let l = "zero"
      let m = "zero"
      let n2 = "zero"
      let o = "zero"
      let p = "zero"
      let q = "zero"
      let r = "zero"
      let s2 = "zero"
      let t = "zero"
      let u = "zero"
      let v = "zero"
      let w = "zero"
      let x = "zero"
      let y = "zero"
      let z = "zero"
      return a ++ b ++ c ++ d ++ e ++ f ++ g ++ h ++ i ++ j ++ k ++ l ++ m ++ n2 ++ o ++ p ++ q ++ r ++ s2 ++ t ++ u ++ v ++ w ++ x ++ y ++ z
    | _ -> return "nonzero"
  end
end

let main = fn () -> unit require { PermConsole } throws { Unreachable } do
  inject system_handler do
    // classify(1) takes the `| _ ->` arm. pipe_starts_arm must scan past the
    // long first arm to identify `| _` as an arm separator, not a bitwise-or.
    let result = classify(n: 1)
    let ok = result == "nonzero"
    match ok do
      | true ->
        Console.println(val: "reached arm two")
        throw Unreachable
      | false ->
        Console.println(val: "wrong arm")
    end
  end
  return ()
end
