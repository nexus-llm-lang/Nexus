// expect-runtime-throw: before unwrap
//
// `std:option.unwrap` is the partial dual of `unwrap_or`: it tears the
// `T` out of `Some(val: T)` and raises `RuntimeError` on `None`. The
// fixture compiles cleanly (the throws-row is closed by `main`'s
// `throws { RuntimeError }`), but executing it walks the `None` arm
// and surfaces the exception to wasmtime as a non-zero exit. The
// captured stdout line "before unwrap" is the substring the runner
// anchors on — wasmtime itself does not surface the exception
// constructor name on stderr.
//
// Idiomatic alternative: pattern-match on `Some/None` or use
// `unwrap_or(opt, default)` to supply a fallback.

import { Console, system_handler } from "std:stdio"
import { None, unwrap } from "std:option"

let main = fn () -> unit require { PermConsole } throws { RuntimeError } do
  inject system_handler do
    let absent: Option<i64> = None
    Console.println(val: "before unwrap")
    unwrap(opt: absent)
    Console.println(val: "should never print")
  end
  return ()
end
