// expect-runtime-throw: before parse
//
// `std:json.parse` raises `JsonError(msg, pos)` (a member of the
// `JsonThrow` group) on syntactically invalid input. The fixture
// compiles cleanly because `main` widens the throws-row, then surfaces
// the constructor as a non-zero exit at run time. wasmtime swallows
// the constructor name on stderr, so the runner anchors on the
// captured stdout line "before parse".
//
// Idiomatic alternative: wrap the call in `try ... catch | JsonError(msg, pos) -> ... end`
// to recover with a user-readable diagnostic that includes both the
// offending position and the original payload.

import { Console, system_handler } from "std:stdio"
import * as json from "std:json"

let main = fn () -> unit require { PermConsole } throws { json.JsonThrow } do
  inject system_handler do
    Console.println(val: "before parse")
    // Trailing comma + missing closing brace: the lexer drives off a
    // cliff a few tokens in and `parse` raises JsonError.
    json.parse(s: "{\"name\": \"nexus\",")
    Console.println(val: "should never print")
  end
  return ()
end
