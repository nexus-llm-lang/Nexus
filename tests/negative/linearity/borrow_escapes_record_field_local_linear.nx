// expect-fail: E2022
// expect-msg: escapes
//
// Gravity rule (nexus-ymx7u, opd38 Form B): a `&σ` borrow STORED in a
// record/ADT field escapes its owner when the record is RETURNED and the
// borrowed owner is a LOCAL linear binding (a `%`-binding this function
// must consume by function-end). Reading the field after the owner is freed
// returns freed memory (use-after-free).
//
// A DIRECT `Wrap(b: &b1)` over a linear `b1` is already rejected at T-Borrow
// (E2001). The residual hole closed here is the CALL-LAUNDERED path: a helper
// `mk(c: &ByteBuffer) -> Wrap` takes the borrow in argument position (T-Borrow
// permits this) and stores it in the returned `Wrap`; `leak` then frees the
// local owner and returns the record holding the now-dangling borrow.
//
// The owner-locality heuristic flags this because the borrowed owner `%b1` is
// a local linear consumed inside `leak`. Borrows of NON-linear `&`-typed
// owners stored in a returned record (the CompileCtx/CodegenCtx idiom) stay
// permitted — see the positive test borrow_field_local_inscope_test.nx.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule".
// nexus-ymx7u

import * as bb from "std:bytebuffer"

type Wrap = Wrap(b: &ByteBuffer)

let mk = fn (c: &ByteBuffer) -> Wrap do return Wrap(b: c) end

let leak = fn () -> Wrap throws { Exn } do
  let %b0 = bb.empty()
  let %b1 = bb.push_byte(buf: %b0, byte: 200)
  let w = mk(c: &b1)
  bb.free(buf: %b1)
  return w
end

let use_it = fn () -> i64 throws { Exn } do
  let w = leak()
  match w do | Wrap(b: bw) -> return bb.get_byte(buf: bw, idx: 0) end
end

let main = fn () -> unit throws { Exn } do
  let _r = use_it()
  return ()
end
