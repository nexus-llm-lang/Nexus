// expect-fail: E2007
// expect-msg: never consumed
//
// nexus-eai4: an enum whose variant carries a %T field is structurally linear.
// A binding of that type that falls out of scope without being consumed must
// raise LinearUnused.  Here Wrapper's Box variant holds a %Handle field, so
// Wrapper is structurally linear.  The annotation makes the binding site check
// is_linear_binding_type(Wrapper, enum_defs) → true, tracking w as linear.

type Handle = Handle(fd: i64)

type Wrapper =
  Box(inner: %Handle)
  | Empty

let make_handle = fn () -> %Handle do
  return Handle(fd: 0)
end

let make_wrapper = fn () -> Wrapper do
  return Box(inner: make_handle())
end

let main = fn () -> unit do
  let w: Wrapper = make_wrapper()
  return ()
end
