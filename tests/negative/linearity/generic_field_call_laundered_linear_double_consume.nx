// expect-fail: E2008
// expect-msg: linear binding '%gg' is consumed more than once
//
// Double-use witness for the laundered-through-call linear field. `gen: A` is
// filled by `pick(x: p)` (generic identity over the linear `%Box`), so the
// match binder `gg` carries a linear value. Consuming it twice (two `sink`
// calls) is a double-free and must be rejected with E2008.
//
// Sibling of generic_field_call_laundered_linear_drop.nx: the demote in the
// 7umo8 logic must not untrack a generic field laundered through a call, or
// this program type-checks and double-uses the same `%Box` at runtime.

type Box = Box(val: i64)
type Mix<A> = Mix(tag: i64, gen: A)

let pick = fn <T>(x: T) -> T do return x end

let sink = fn (b: %Box) -> i64 do
  match b do
    | Box(val: v) -> return v
  end
end

let main = fn () -> unit do
  let %p = Box(val: 5)
  let w = Mix(tag: 1, gen: pick(x: p))
  match w do
    | Mix(tag: tt, gen: gg) ->
      let a = sink(b: gg)
      let c = sink(b: gg)
      return ()
  end
end
