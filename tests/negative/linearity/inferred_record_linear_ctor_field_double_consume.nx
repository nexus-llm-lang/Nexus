// expect-fail: E2008
// expect-msg: linear binding '%r' is consumed more than once
//
// Companion to inferred_pair_linear_ctor_field_double_consume.nx for
// records. The linearity pass tracks
//   `let r = { val: Holder(buf: %ByteBuffer) }`
// as linear because the field expression is a Ctor whose owning enum
// has a shallow-linear (TyLinear) field — the outer record therefore
// carries a linear payload and must be use-once.
//
// Without this propagation, `r` would be untracked (the record type's
// `val` slot is TyVar, not shallow-linear), and destructuring twice
// would double-free the wrapped ByteBuffer at runtime.
//
// Spec: type-system-formal §Linearity — linear({ val: %T, .. }) = true.

import * as bb from "std:bytebuffer"

type Holder = Holder(buf: %ByteBuffer)
type Box<T> = { val: T }

let consume = fn (h: %Holder) -> i64 do
  match h do
    | Holder(buf: %buffer) ->
      let n = bb.length(buf: &buffer)
      bb.free(buf: %buffer)
      return n
  end
end

let main = fn () -> unit do
  let r = { val: Holder(buf: bb.empty()) }
  let { val: h1 } = r
  let _v1 = consume(h: h1)
  let { val: h2 } = r
  let _v2 = consume(h: h2)
  return ()
end
