// expect-fail: E2001
// expect-msg: wildcard pattern
// expect-msg: cannot discard linear type
//
// P-Wild: a wildcard `_` pattern cannot silently discard a non-auto-droppable
// linear type.  The match scrutinee `h` has type `%Handle`; using `_` to
// discard it violates the linearity no-silent-drop guarantee.

type Handle = Handle(fd: i64)

let make_handle = fn () -> %Handle do
  return Handle(fd: 42)
end

let main = fn () -> unit do
  let %h = make_handle()
  match h do
    | _ -> return ()
  end
end
