// expect-fail: E2007
// expect-msg: never consumed
//
// nexus-ans4: a `let w = MkW(inner: %b)` without any type annotation must
// be tracked as a linear binding when the enum containing MkW has a variant
// whose field type is directly linear.  Previously `let_binds_linear` fell
// through to the `| _ -> false` default for Ctor RHS nodes, so `w` was not
// added to the live set and the unused linear resource was silently dropped.

type Box = Box(val: i64)
type W = MkW(inner: %Box)

let main = fn () -> unit do
  let %b = Box(val: 1)
  let w = MkW(inner: %b)
  return ()
end
