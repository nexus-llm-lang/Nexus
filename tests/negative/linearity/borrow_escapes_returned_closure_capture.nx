// expect-fail: E2022
// expect-msg: escapes
//
// Gravity rule (closure-capture residual of nexus-quuuq / ymx7u): a `&σ` borrow
// also escapes its owner when it is captured by a RETURNED CLOSURE. The
// closure's free variables outlive this frame via the returned arrow value, so
// a captured borrow of a binding owned by THIS function dangles after the
// function returns — exactly the use-after-scope the record-field rule already
// rejects.
//
// Here `leak` binds a frame-local `x`, takes a borrow `b = &x`, and returns a
// closure `g` whose body references `b`. After `leak` returns, the local `x` is
// gone, so the closure's captured borrow of `x` dangles. The owner-locality
// mandate is identical to the record-field case (the borrow of a local cannot
// outlive the function), so this must be rejected with the same E2022 gravity
// diagnostic as the returned-record companion.
//
// The closure's `escapesRef` arrow return type is borrow-FREE (it returns
// `i64`), so the type-level gravity rule never fires; the linearity pass must
// inspect the captured free variables directly.
//
// Positive companions (must STILL typecheck): a closure capturing a borrow of a
// `&`-PARAMETER (owner outlives the frame) stays permitted — see
// borrow_returned_closure_param_owner_test.nx.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule".

let leak = fn () -> (() -> i64) do
  let x = 1
  let b = &x
  let g = fn () -> i64 do return b end
  return g
end

let main = fn () -> unit do
  let g = leak()
  return ()
end
