// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall) for a CHAINED INDIRECT call
// `(mk())()`: the inner `mk()` returns a closure and the outer application
// invokes it. This lowers to a `CallExpr` whose callee is itself a `Call`. The
// indirect-throwable-leak guard previously handled only `Variable` and inline
// `Lambda` callees; a `Call` (chained) callee fell through the silent
// fallthrough arm, so a linear held live across the throwing outer application
// leaked with no runtime drop.
//
// The OUTER application's throws row is the throws row of `mk`'s RETURN arrow
// (the closure it produces), so the guard resolves it from `mk`'s signature.
// `%h` is bound before `(mk())()` and consumed only after it (`close(h: %h)`);
// on the throw path `close` is never reached, so `%h` leaks → E0540.

exception Boom(code: i64)

type Handle = Handle(fd: i64)

let close = fn (h: %Handle) -> i64 do
  let r = match h do | Handle(fd: i) -> i end
  return r
end

let mk = fn () -> (() -> i64 throws { Boom }) do
  return fn () -> i64 throws { Boom } do throw Boom(code: 1) end
end

let f = fn () -> i64 throws { Boom } do
  let %h = Handle(fd: 0)
  // Throwable chained call while `%h` is live → E0540.
  let r = (mk())()
  return close(h: %h)
end

let main = fn () -> unit throws {} do
  try
    let v = f()
  catch
    | Boom(code: _) -> ()
  end
  return ()
end
