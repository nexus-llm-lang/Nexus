// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall) for a linear passed as an EARLIER
// argument of a call while a LATER sibling argument is a throwable call.
//
// `check_call_args` folds the argument list left-to-right: the `Variable` arg
// `%b` is `lin_remove`d (consumed) BEFORE the throwable-call leak guard fires
// on the later throwable argument `thr()`. So the guard's live set no longer
// contained `%b`, and the leak was missed — the call ACCEPTED.
//
// But `%b`'s consumer (`use2` / its `free` call) only runs once the enclosing
// call is actually invoked, and the enclosing call never runs if a sibling
// argument raises first. So on the throw path of `thr()` the call `use2(...)`
// is never reached and `%b` leaks with no runtime drop → E0540.
//
// The swapped-order form `use2(n: thr(), b: %b)` was already correctly rejected
// (the guard walks `thr()` while `%b` is still live); the two forms are
// equivalent up to argument order, which isolates the blind spot. The fix keeps
// a linear consumed by an earlier sibling argument LIVE for the leak check of a
// later throwable sibling.

exception E(code: i64)

type Box = Box(val: i64)

let free = fn (r: %Box) -> unit do
  let Box(val: _) = r
  return ()
end

let thr = fn () -> i64 throws { E } do
  throw E(code: 1)
end

let use2 = fn (b: %Box, n: i64) -> unit do
  free(r: %b)
  return ()
end

let main = fn () -> unit throws { E } do
  let %b = Box(val: 1)
  // `%b` consumed as arg1; `thr()` throws as arg2 → use2/free never run → %b leaks.
  use2(b: %b, n: thr())
  return ()
end
