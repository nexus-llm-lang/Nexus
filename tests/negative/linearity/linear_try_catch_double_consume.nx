// expect-fail: E2008
// expect-msg: consumed more than once
//
// nexus-hjh2: a linear binding consumed inside a try body before a throw must
// NOT be re-consumable in the catch arm. The runtime does not roll back heap
// operations, so the typecheck must conservatively treat any linear the try
// body consumed as unavailable in all catch arms.

type Box = Box(val: i64)
exception X

let consume = fn (%b: Box) -> unit do
  match b do | Box(val: _) -> return () end
end

let main = fn () -> unit throws { Exn } do
  let %a = Box(val: 1)
  try
    consume(b: %a)     // consumes %a on the success path
    throw X            // always throws after consuming %a
  catch _ ->
    consume(b: %a)     // %a was consumed in try body — must fire E2008
  end
  return ()
end
