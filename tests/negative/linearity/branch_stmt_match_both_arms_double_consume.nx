// expect-fail: E2008
// expect-msg: linear binding '%p' is consumed more than once
//
// Match-statement variant of branch_stmt_if_both_arms_double_consume.nx: the
// linear `%p` is consumed in BOTH arms of a `match` STATEMENT, so it is dead at
// the join, and the trailing `sink(b: p)` is a double-free. The match-statement
// join (check_match_cases_go terminal) restores the pre-match state and drops
// the arm-consumed linear from both the live and consumed sets; the consumed-set
// repair recovers it so the reuse is rejected with E2008.

type Box = Box(val: i64)
type Tag = A | B

let sink = fn (b: %Box) -> i64 do
  let Box(val: v) = b
  return v
end

let main = fn () -> unit do
  let %p = Box(val: 5)
  let t = A
  match t do
    | A -> let _a = sink(b: p)
    | B -> let _b = sink(b: p)
  end
  let c = sink(b: p)
  let _d = c
  return ()
end
