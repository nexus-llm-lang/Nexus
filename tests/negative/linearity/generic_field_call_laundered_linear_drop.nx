// expect-fail: E2007
// expect-msg: linear binding '%gg' is never consumed
//
// A linear value laundered through a GENERIC-FUNCTION CALL into a generic
// field must STILL be tracked at the match site. Here `gen: A` is filled by
// `pick(x: p)` where `pick<T>(x: T) -> T` returns its (linear) argument: the
// runtime value flowing into the `gen` slot is the linear `%Box`. Dropping
// `gg` is a leak and must be rejected with E2007.
//
// Regression guard for the 7umo8 demote logic (commit 4886ffe5): that fix
// re-classifies a generic field's construction arg at the MATCH site, but read
// the call's arg-liveness STALE — `p` was already consumed by the enclosing
// `Mix(...)` construction, so the call was misclassified non-linear and the
// field wrongly demoted (silent drop accepted). The demote must fire ONLY for
// PROVABLY non-linear args; an opaque/generic call result that launders a
// linear stays tracked.

type Box = Box(val: i64)
type Mix<A> = Mix(tag: i64, gen: A)

let pick = fn <T>(x: T) -> T do return x end

let main = fn () -> unit do
  let %p = Box(val: 5)
  // Inferred Mix<%Box>: `gen` is filled by the linear `%p` laundered through
  // the generic identity call `pick`.
  let w = Mix(tag: 1, gen: pick(x: p))
  match w do
    | Mix(tag: tt, gen: gg) -> return ()
  end
end
