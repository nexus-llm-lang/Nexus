// expect-fail: E2008
// expect-msg: linear binding '%q' is consumed more than once
//
// Return-arm sibling of branch_stmt_if_both_arms_double_consume.nx: the linear
// `%q` is consumed inside BOTH arms of an `if` STATEMENT, then consumed a third
// time in the trailing `return sink(b: q)`. Once the if-statement join correctly
// records `%q` as consumed (folding the live-set delta into the consumed set),
// the `return` expression's use of `q` is recognised as a reuse and rejected
// with E2008.
//
// The double-consume lives in a helper (not `main`) because `build` enforces
// `main : () -> unit` (E2004) before the linearity pass; routing through a
// helper keeps the return-after-both-arms structure under linearity scrutiny.

type Box = Box(val: i64)

let sink = fn (b: %Box) -> i64 do
  let Box(val: v) = b
  return v
end

let consume_then_return = fn (cond: bool) -> i64 do
  let %q = Box(val: 7)
  if cond then let _a = sink(b: q) else let _b = sink(b: q) end
  return sink(b: q)
end

let main = fn () -> unit do
  let _r = consume_then_return(cond: true)
  return ()
end
