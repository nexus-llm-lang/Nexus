// expect-fail: E2007
// expect-msg: linear binding
// expect-msg: never consumed
//
// A handler arm with `with @k` introduces a one-shot continuation that must
// be forced on EVERY exit path (T-Continuation: k :^1 @kappa_j).
// If k is forced in the else-branch but the then-branch exits via `return`
// without forcing k, the continuation leaks on the return path.
//
// Pre-fix, `check_handler_arm_konts` in the IR linearity pass used a simple
// count check: count_refs_stmts(k) == 1 passes because k is referenced once
// (in the else-branch). The TC linearity pass discarded cont_binder entirely.
// Post-fix, the TC pass seeds k into the must_consume set and the Return
// handler verifies k is consumed before exit.
//
// nexus-j0cw

cap Logger do fn log(msg: string) -> unit end

let main = fn () -> unit do
  let my_handler = handler Logger do
    fn log(msg: string) -> unit with @k do
      if msg == "skip" then
        return ()  // k NOT forced here — leaked on this path
      else
        @k         // k forced here only
      end
    end
  end
  my_handler
  return ()
end
