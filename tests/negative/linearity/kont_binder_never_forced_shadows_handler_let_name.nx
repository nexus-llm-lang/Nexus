// expect-fail: E2005
// expect-msg: lazy binding
// expect-msg: never forced
//
// Guard for the fix to nexus-frz7i: namespacing the arm-local `@k`
// continuation binder so a same-named outer `let k` no longer clobbers its
// force record must NOT weaken the genuine "continuation never forced" check.
//
// Here the handler is again bound to `let k` (same name as the `@k` binder),
// but the arm body NEVER forces `@k` on its only exit path. The force-once
// obligation (type-system-formal §with-continuation arms :1556) is violated,
// so this must still be rejected with E2005 "lazy binding @k is never forced".

import { Console } from "std:stdio"
import * as stdio from "std:stdio"

cap Ev do fn emit() -> unit end

let k = handler Ev require { Console } do
  fn emit() -> unit with @k do
    Console.println(val: "in-arm")
    // `@k` is never forced — the continuation leaks. Must reject E2005.
  end
end

let drive = fn () -> unit require { Ev, Console } do Ev.emit() end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do inject k do drive() end end
end
