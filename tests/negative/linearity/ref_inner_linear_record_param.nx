// expect-fail: E2023
// expect-msg: linear
// expect-msg: ref
//
// wfRef(~σ) ⟺ ¬linear(σ) — structural check: a function parameter of
// type ~R where R is a record with a linear field must be rejected.
// The inner type R is not `%R` at the outer level, but it is structurally
// linear because one of its fields has type %Handle.
//
// Pre-fix: enforce_wf_ref_one called is_linear(typ: i) which only matched
// an outer TyLinear wrapper, so ref(R) slipped through when R's linearity
// was structural (a field of R had type %Handle).
// Post-fix: uses is_linear_binding_type which recurses through TyRecord /
// TyUserDefined fields.
//
// Contrast: `let ~r = { h: make_handle() }` correctly yields E2001 via
// the T-Let structural guard. This test pins the wfRef param-site guard.
//
// nexus-351x

type Handle = Handle(fd: i64)
let make_handle = fn () -> %Handle do return Handle(fd: 42) end
type R = { h: %Handle }

let bad = fn (x: ref(R)) -> unit do
  return ()
end

let main = fn () -> unit do
  return ()
end
