// expect-fail: E2008
// expect-msg: consumed more than once
/**
 * Reading a linear element out of a linear-element array (`a[i]`) is a
 * move-out: it registers the array's use-once obligation. Reading the same
 * array a second time via `a[i]` then aliases the moved element and must be
 * rejected as LinearReuse (E2008).
 *
 * Before the fix the `Index` arm of the linearity pass never walked the
 * target subtree, so the second `a[0]` was invisible and the double-consume
 * of the underlying `%Box` was silently admitted (runtime aliasing).
 */
import { Console } from "std:stdio"
import * as stdio from "std:stdio"
import { from_i64 } from "std:str"

type Box = Box(val: i64)

let unwrap = fn (b: %Box) -> i64 do
  match b do
    | Box(val: v) -> return v
  end
end

let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    let %b1 = Box(val: 10)
    let %b2 = Box(val: 20)
    let a = [| b1, b2 |]
    let e0 = a[0]
    let e0b = a[0]
    Console.println(val: from_i64(val: unwrap(b: e0)))
    Console.println(val: from_i64(val: unwrap(b: e0b)))
    a
  end
end
