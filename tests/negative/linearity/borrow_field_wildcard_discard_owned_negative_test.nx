// expect-fail: E2001
// expect-msg: wildcard pattern
// expect-msg: cannot discard linear type
//
// Companion to tests/typecheck/linearity/borrow_field_wildcard_discard_test.nx.
// The borrow exemption for a wildcard discard of a linear field must NOT leak
// into the OWNED case: destructuring an owned (`%`) value and discarding its
// linear field with `_` silently drops the resource and must still be rejected
// by the P-Wild premise. Only a `&`-borrowed scrutinee is exempt.

opaque type Holder = Holder(tag: i64, payload: %ByteBuffer)

let drop_owned = fn (h: %Holder) -> i64 do
  let Holder(tag, payload: _) = h
  return tag
end

let main = fn () -> unit do
  return ()
end
