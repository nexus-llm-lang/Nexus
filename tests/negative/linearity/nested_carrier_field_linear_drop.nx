// expect-fail: E2007
// expect-msg: linear binding '%xs' is never consumed
//
// A linear value routed through a NESTED GENERIC CARRIER field — record/sum
// field `items: [A]` instantiated with `A = %Box` — must be tracked as linear.
// Per spec type-system-formal §Linearity, `linear(τ)` holds if any transitive
// component is linear, INCLUDING the element type of a list, so
// `linear(Wrap<%Box>)` (field `items: [%Box]`) is true and the binder of the
// carrier field must be consumed exactly once (P-FnEnd).
//
// Pre-fix: the name-based field-linearity probe only recognised a BARE type
// param slot (`Pair<A,_>`), not a carrier OF a param (`[A]` → TyList). So
// destructuring `Wrap(items: xs)` left `xs : [%Box]` UNTRACKED, and silently
// dropping it type-checked — a leak (double-free for a resource-bearing linear,
// since the untracked binder is equally free to be consumed twice).
//
// Post-fix: `xs` is tracked linear; dropping it is rejected with E2007.

type Box = Box(x: i64)
type Wrap<A> = Wrap(items: [ A ])

let body = fn () -> i64 do
  let %b = Box(x: 42)
  let w = Wrap(items: [ b ])
  // `xs : [%Box]` binds the carrier field but is never consumed.
  return match w do
    | Wrap(items: xs) -> 7
  end
end

let main = fn () -> unit do
  let r = body()
  r
  return ()
end
