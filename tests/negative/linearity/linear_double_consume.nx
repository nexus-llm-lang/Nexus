// expect-fail: E2008
// expect-msg: consumed more than once
//
// nexus-6pff: a linear binding consumed twice must raise LinearReuse (E2008).
// Here %b is passed to consume() twice; the second call uses it after it has
// already been consumed on the same execution path.

type Box = Box(val: i64)

let consume = fn (%b: Box) -> unit do
  let _ = %b
  return ()
end

let main = fn () -> unit do
  let %b = Box(val: 42)
  consume(b: %b)
  consume(b: %b)
  return ()
end
