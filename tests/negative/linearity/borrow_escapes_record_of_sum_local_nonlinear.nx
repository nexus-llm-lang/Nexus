// expect-fail: E2022
// expect-msg: escapes
//
// Gravity rule (nexus-37bav, quuuq residual): a `&σ` borrow of a LOCAL
// NON-LINEAR owner buried inside a SUM variant that is itself a record field
// escapes when the outer record is returned. The carrier nesting here is
// record-of-sum: `{ p: Yes(b: &x) }`.
//
// The escape walk must recurse from the record field into the Ctor payload to
// find the borrow of the local `x`; otherwise the borrow dangles after `leak`
// returns the `Outer` record (use-after-scope).
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule". nexus-37bav

type Pay = Yes(b: &i64) | NA
type Outer = { p: Pay }

let leak = fn () -> Outer do
  let x = 1
  return { p: Yes(b: &x) }
end

let main = fn () -> unit do
  let r = leak()
  return ()
end
