// expect-fail: E2008
// expect-msg: linear binding '%r' is consumed more than once
//
// Companion to inferred_pair_linear_alias_double_consume.nx for records.
// The linearity pass tracks `let r = { val: b }` as linear when `b` is a
// linear binding, even though the record's declared field is generic
// (TyVar, not shallow-linear) — so structural-linearity T-Proj never
// fires, but the runtime field carries a use-once value. Without this
// propagation, `r` would be untracked and the two destructures below
// would each consume the inner linear payload, double-freeing it.
//
// Spec: type-system-formal §Linearity — linear({ val: %T, .. }) = true;
// an outer container of a linear payload is itself linear and use-once.

type Bb = Bb(x: i64)
type Box<T> = { val: T }

let take_bb = fn (b: %Bb) -> i64 do
  match b do
    | Bb(x: v) -> return v
  end
end

let main = fn () -> unit do
  let %b = Bb(x: 42)
  let r = { val: b }
  let { val: b1 } = r
  let _v1 = take_bb(b: b1)
  let { val: b2 } = r
  let _v2 = take_bb(b: b2)
  return ()
end
