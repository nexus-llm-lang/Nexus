// expect-fail: E2022
// expect-msg: escapes
//
// Gravity rule (closure-in-aggregate-field residual of nexus-drerq): a `&σ`
// borrow captured by a returned CLOSURE escapes its owner just as much when the
// closure is buried inside a RETURNED Record field as when it is returned
// directly. drerq rejected the directly-returned closure (`return g`) and the
// tainted-let-then-returned form; the residual hole was a closure stored INSIDE
// a returned record/ADT field, which the aggregate-carrier walk did not descend
// into.
//
// Here `leak` binds a frame-local `x`, takes a borrow `b = &x`, builds a closure
// `g` whose body reads `b`, and returns the record `{ f: g }`. After `leak`
// returns, the local `x` is gone, so the closure's captured borrow of `x`
// dangles. The owner-locality mandate is identical to the directly-returned
// closure case, so this must be rejected with the same E2022 gravity diagnostic.
//
// The closure's `escapesRef` arrow return type is borrow-FREE (it returns
// `i64`), so the type-level gravity rule never fires; the linearity pass must
// inspect the captured free variables of the closure stored in the field.
//
// Positive companion (must STILL typecheck): a closure capturing a borrow of a
// `&`-PARAMETER stored in a returned record stays permitted — see
// borrow_closure_in_record_param_owner_test.nx.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule".

type W = { f: (() -> i64) }

let leak = fn () -> W do
  let x = 1
  let b = &x
  let g = fn () -> i64 do return b end
  return { f: g }
end

let main = fn () -> unit do
  let w = leak()
  return ()
end
