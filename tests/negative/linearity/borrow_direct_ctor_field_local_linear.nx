// expect-fail: E2001
// expect-msg: cannot borrow
// expect-msg: linear
import * as bb from "std:bytebuffer"

type Ctx = Ctx(a: &ByteBuffer)

let driver = fn () -> i64 throws { Exn } do
  let %a0 = bb.empty()
  let %a1 = bb.push_byte(buf: %a0, byte: 7)
  let cx = Ctx(a: &a1)
  let r = match cx do | Ctx(a: x) -> bb.get_byte(buf: x, idx: 0) end
  bb.free(buf: %a1)
  return r
end

let main = fn () -> unit throws { Exn } do
  let _r = driver()
  return ()
end
