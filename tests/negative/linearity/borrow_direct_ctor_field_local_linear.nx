// expect-fail: E2001
// expect-msg: cannot borrow
// expect-msg: linear
//
// A DIRECT constructor-field borrow of a LOCAL linear binding is rejected at
// T-Borrow: Ctor/record-field position is not argument position, so the
// `&a1` borrow of the local linear `%a1` has no discharge point. The
// sanctioned idiom routes the borrow through a laundering helper that takes
// it in argument position (see the positive companion
// borrow_field_multi_linear_launder_inscope_test.nx). This fixture guards
// that the helper route does not relax the direct-position rule.
//
// Spec: docs/spec/type-system-formal.md §T-Borrow.
import * as bb from "std:bytebuffer"

type Ctx = Ctx(a: &ByteBuffer)

let driver = fn () -> i64 throws { Exn } do
  let %a0 = bb.empty()
  let %a1 = bb.push_byte(buf: %a0, byte: 7)
  let cx = Ctx(a: &a1)
  let r = match cx do | Ctx(a: x) -> bb.get_byte(buf: x, idx: 0) end
  bb.free(buf: %a1)
  return r
end

let main = fn () -> unit throws { Exn } do
  let _r = driver()
  return ()
end
