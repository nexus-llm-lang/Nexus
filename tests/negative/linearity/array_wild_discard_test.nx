// expect-fail: E2001
// expect-msg: wildcard pattern
// expect-msg: cannot discard linear type
//
// P-Wild: arrays are unconditionally linear (spec §Linearity: linear([|σ|]) = true
// regardless of element type). A wildcard match on [|i64|] must be rejected:
// the allocated cells are not auto-droppable and the resource escapes silently.

let main = fn () -> unit do
  let arr: [| i64 |] = [| 1, 2, 3 |]
  match arr do
    | _ -> return ()
  end
end
