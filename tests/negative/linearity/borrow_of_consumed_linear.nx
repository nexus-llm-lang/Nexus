// expect-fail: E2032
// expect-msg: already been consumed
// expect-msg: use-after-move
//
// T-App-BorrowLin liveness premise: a borrow `&x` of a linear binding is
// admitted only when the target is still LIVE (x:^1 in Gamma, "survives the
// call unconsumed"). Here `bb.free` moves/consumes the linear ByteBuffer, and
// the subsequent `bb.length(buf: &b)` borrows the already-moved binding — a
// use-after-move that the linearity pass must reject.
//
// Spec: type-system-formal §T-App-BorrowLin (borrow target liveness).

import * as bb from "std:bytebuffer"

let body = fn () -> i64 throws { Exn } do
  let %b = bb.empty()
  bb.free(buf: %b)
  // Borrow AFTER the consuming move — use-after-move.
  let n = bb.length(buf: &b)
  return n
end

let main = fn () -> unit throws { Exn } do
  let r = body()
  return ()
end
