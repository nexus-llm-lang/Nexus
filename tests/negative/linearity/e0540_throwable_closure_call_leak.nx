// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall) for an INDIRECT call through a LOCAL
// let-bound CLOSURE. The yet90 fix added the leak guard to expression position
// but resolved the callee's throws row only via the global sig-map, which holds
// top-level functions / externals / handler arms — NOT local let-bound lambdas.
// So a throwable LOCAL closure call (`mt()` where `mt = fn () -> ... throws ...`)
// slipped through: `sig_lookup` missed `mt` and the guard stayed silent.
//
// `%h` is bound before the throwable closure call `mt()` and consumed only
// after it (`close(h: %h)`). On the throw path control never reaches `close`,
// so `%h` leaks → E0540. The guard must now resolve the closure's throws row
// from the local binding env and fire here.

exception Boom(code: i64)

type Handle = Handle(fd: i64)

let close = fn (h: %Handle) -> i64 do
  let r = match h do | Handle(fd: i) -> i end
  return r
end

let f = fn () -> i64 throws { Boom } do
  let mt = fn () -> i64 throws { Boom } do throw Boom(code: 1) end
  let %h = Handle(fd: 0)
  // Throwable LOCAL-closure call while `%h` is live. On the throw path `close`
  // is never reached, so `%h` leaks → E0540.
  let r = mt()
  return close(h: %h)
end

let main = fn () -> unit throws {} do
  try
    let v = f()
  catch
    | Boom(code: _) -> ()
  end
  return ()
end
