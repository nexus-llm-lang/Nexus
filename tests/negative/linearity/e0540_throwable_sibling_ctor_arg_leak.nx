// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall) for a linear consumed by an EARLIER
// CONSTRUCTOR argument while a LATER constructor argument is a throwable call.
//
// Constructor arguments do NOT route through `check_call_args` — they go through
// the multi-operand element walker (`check_exprs`). Before the fix, that walker
// was a plain left-to-right fold with NO sibling-leak logic, so it consumed `%b`
// (`free(r: %b)` as element1) BEFORE any leak guard could see it against the
// later throwable element `thr()`. The constructed value `Pair(...)` is built
// only after the WHOLE element list has evaluated, so on `thr()`'s throw path
// the constructor never runs and `%b` leaks with no runtime drop → E0540.
//
// The equivalent direct-CALL form (`use2(b: %b, n: thr())`) was already rejected
// (tests/negative/linearity/e0540_throwable_sibling_arg_leak.nx); this pins the
// fix on the constructor-argument element path, which shares one sibling-leak
// helper with the call-argument walker.

exception E(code: i64)

type Box = Box(val: i64)

type Pair = Pair(p: i64, q: i64)

let free = fn (r: %Box) -> i64 do
  let Box(val: v) = r
  return v
end

let thr = fn () -> i64 throws { E } do
  throw E(code: 1)
end

let main = fn () -> unit throws { E } do
  let %b = Box(val: 1)
  // `%b` consumed by element1; `thr()` throws as element2 → ctor never built → %b leaks.
  let p = Pair(p: free(r: %b), q: thr())
  return ()
end
