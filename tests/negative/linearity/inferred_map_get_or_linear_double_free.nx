// expect-fail: E2008
// expect-msg: linear binding '%m1' is consumed more than once
//
// Real double-free exploit: a generic-collection insert that stores a
// linear value, followed by TWO `get_or` calls that each unwrap it, then
// two `bb.free` on the same buffer id. Without param→result-slot linear
// propagation, the linearity pass never tracks `m1` (the map carrying
// the linear payload), each `get_or` call is silently accepted, and the
// two `bb.free` calls operate on the same buffer id.
//
// `bb.free` currently happens to return `true` for the second-free case
// (stub-style), but the same pattern with any real resource (file handle,
// socket, allocation) would be a genuine double-free.

import * as bb from "std:bytebuffer"
import * as map from "std:collection/map"
import * as str from "std:text/str"

let str_hash = fn (k: string) -> i64 do return str.length(s: k) end
let str_eq = fn (a: string, b: string) -> bool do return a == b end

let main = fn () -> unit do
  let m0 = map.empty(hash: str_hash, eq: str_eq)
  let %b = bb.empty()
  let m1 = map.insert(m: m0, k: "a", v: b)
  let x1 = map.get_or(m: m1, k: "a", default: bb.empty())
  let x2 = map.get_or(m: m1, k: "a", default: bb.empty())
  let _r1 = bb.free(buf: %x1)
  let _r2 = bb.free(buf: %x2)
  return ()
end
