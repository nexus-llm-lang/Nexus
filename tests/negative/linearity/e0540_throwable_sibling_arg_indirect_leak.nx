// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall) for the INDIRECT-call form of the
// sibling-argument consumption-order blind spot. The enclosing call is through
// a local function-typed binding (`let g = consume`), so it lowers to the
// `CallExpr` (indirect) HIR arm rather than the directly-named `Call` arm. The
// argument-list walk is shared between both arms, so the same left-to-right
// fold consumed `%b` (arg1) before the leak guard fired on the throwable
// sibling `thr()` (arg2).
//
// `%b`'s consumer runs only when `g(...)` is invoked, and `g(...)` never runs
// if `thr()` raises first → on the throw path `%b` leaks with no runtime drop.
// This pins the fix on the indirect (`CallExpr`) enclosing-call path.

exception E(code: i64)

type Box = Box(val: i64)

let free = fn (r: %Box) -> unit do
  let Box(val: _) = r
  return ()
end

let thr = fn () -> i64 throws { E } do
  throw E(code: 1)
end

let consume = fn (b: %Box, n: i64) -> unit do
  free(r: %b)
  return ()
end

let main = fn () -> unit throws { E } do
  let g = consume
  let %b = Box(val: 1)
  // Indirect enclosing call `g(...)`. `%b` consumed as arg1; `thr()` throws as
  // arg2 → g/free never run → %b leaks.
  g(b: %b, n: thr())
  return ()
end
