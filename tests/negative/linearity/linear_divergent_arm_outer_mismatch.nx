// expect-fail: E2009
// expect-msg: match arms diverge on outer-linear consumption
//
// When a divergent arm (throw) does not consume an outer linear that a
// non-divergent arm DOES consume, the code must be rejected.  The divergent
// path leaks the linear resource without consuming it.

type Box = Box(val: i64)
exception E

let consume = fn (%b: Box) -> unit do
  match b do | Box(val: _) -> return () end
end

let main = fn () -> unit throws { Exn } do
  let %h = Box(val: 1)
  // then-branch diverges (throw) without consuming %h.
  // else-branch (non-divergent) consumes %h.
  // The divergent path leaks %h — must fire E2009.
  if false then
    throw E
  else
    consume(b: %h)
  end
  return ()
end
