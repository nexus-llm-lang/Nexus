// expect-fail: E2007
// expect-msg: linear binding '%gg' is never consumed
//
// Guard for the generic-field-instantiation fix (approach (a)): a bare
// type-parameter field whose slot is INSTANTIATED to a LINEAR concrete type
// must STILL be tracked. Here `gen: A` is filled by `%q : %Box` at
// construction, so `gg` binds a linear value — dropping it is a leak and must
// be rejected with E2007.
//
// This is the under-fire companion to
// tests/typecheck/linearity/generic_field_nonlinear_instantiation_test.nx:
// only NON-linear instantiations stop being marked; linear ones (this case)
// stay use-once-tracked.

type Box = Box(val: i64)
type Mix<A> = Mix(payload: %Box, gen: A)

let sink = fn (b: %Box) -> i64 do
  match b do
    | Box(val: v) -> return v
  end
end

let body = fn () -> i64 do
  let %p = Box(val: 5)
  let %q = Box(val: 9)
  // Inferred Mix<%Box>: `gen` is filled by the linear `%q`.
  let m = Mix(payload: %p, gen: %q)
  return match m do
    | Mix(payload: pp, gen: gg) ->
      // `pp : %Box` is consumed; `gg : %Box` is dropped — a leak (E2007).
      let r = sink(b: pp)
      r
  end
end

let main = fn () -> unit do
  let v = body()
  return ()
end
