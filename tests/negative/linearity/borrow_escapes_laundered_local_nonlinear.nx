// expect-fail: E2022
// expect-msg: escapes
//
// Gravity rule (nexus-quuuq, ymx7u residual): the CALL-LAUNDERED path over a
// LOCAL NON-LINEAR owner. `mk(c: &i64) -> R` takes the borrow in argument
// position (T-Borrow permits) and stores it in the returned `R`; `leak` then
// returns the record holding a borrow of the local non-linear `x`, which is
// gone after `leak` returns (use-after-scope).
//
// This mirrors the ymx7u linear-owner laundering case, extended to non-linear
// local owners (nexus-quuuq).
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule". nexus-quuuq

type R = { b: &i64 }

let mk = fn (c: &i64) -> R do return { b: c } end

let leak = fn () -> R do
  let x = 1
  let r = mk(c: &x)
  return r
end

let main = fn () -> unit do
  let r = leak()
  return ()
end
