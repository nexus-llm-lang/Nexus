// expect-fail: E2022
// expect-msg: mutable reference
// expect-msg: escapes
//
// Gravity rule: ¬escapesRef(τ_r) — a function may not declare `ref(i64)` as
// its return type. Ref cells are stack-confined; returning one would let it
// outlive the stack frame that owns the mutable storage.
//
// The check fires at the declaration site (T-Let-PolyFn) on the annotated
// return type, before any body is examined.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule" + §T-Lambda.
// nexus-xqc5

let leak = fn () -> ref(i64) do
  let ~x = 42
  return x
end

let main = fn () -> unit do
  return ()
end
