// expect-fail: E2022
// expect-msg: escapes
//
// Gravity rule (nexus-37bav, quuuq residual): a `&σ` borrow of a LOCAL
// NON-LINEAR owner buried inside a NESTED record carrier escapes when the
// outer record is returned. The quuuq fix handled only the flat single-level
// `{ b: &x }` field; here the borrow is one level deeper, `{ i: { b: &x } }`.
//
// The escape walk must recurse through nested record/ADT carriers: the inner
// record's borrow of the local `x` dangles after `leak` returns the outer
// record (use-after-scope), exactly as the flat case does.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule". nexus-37bav

type Inner = { b: &i64 }
type Outer = { i: Inner }

let leak = fn () -> Outer do
  let x = 1
  let r: Outer = { i: { b: &x } }
  return r
end

let main = fn () -> unit do
  let r = leak()
  return ()
end
