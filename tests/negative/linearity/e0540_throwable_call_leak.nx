// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall): a body-local linear bound and held
// live across a throwable call, with no covering catch, leaks on the throw
// path — the linear is never freed if the call raises. This pins that E0540
// fires for the genuine-leak shape (the guard was
// silently disabled by an or-pattern match-reorder miscompile in
// `row_is_throwable`; restoring the match fix re-enables it).
//
// `%h` is bound *before* the throwable `might_throw()` and consumed only
// after it. On the throw path control never reaches `close`, so `%h` leaks.

exception Boom(code: i64)

type Handle = Handle(fd: i64)

let might_throw = fn () -> unit throws { Exn } do
  throw Boom(code: 1)
end

let close = fn (h: %Handle) -> i64 do
  let r = match h do | Handle(fd: i) -> i end
  return r
end

let main = fn () -> unit throws { Exn } do
  let %h = Handle(fd: 0)
  might_throw()
  close(h: %h)
  return ()
end
