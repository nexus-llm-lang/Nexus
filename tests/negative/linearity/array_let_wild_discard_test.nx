// expect-fail: E2001
// expect-msg: wildcard pattern
// expect-msg: cannot discard linear type
//
// P-Wild via let binding: `let _ = expr` where expr : [|i64|] must be
// rejected because arrays are unconditionally linear (spec §Linearity:
// linear([|σ|]) = true) and the wildcard pattern silently discards the
// allocated cells without releasing them.
//
// This uses a `match` on an inline array literal so the scrutinee type
// [|i64|] flows directly into the wildcard arm — equivalent to the let form.

let make_array = fn () -> [| i64 |] do
  return [| 10, 20, 30 |]
end

let main = fn () -> unit do
  match make_array() do
    | _ -> return ()
  end
end
