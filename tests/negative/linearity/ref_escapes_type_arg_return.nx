// expect-fail: E2022
// expect-msg: mutable reference
// expect-msg: escapes
//
// Gravity rule: not escapesRef(tau_r). A ref cell reachable through a named
// type's TYPE ARGUMENT escapes its frame just as a ref in a record/variant
// field does. Returning `Box<ref(i64)>` would let the stack-confined ref cell
// outlive the frame that owns its storage. escapesRef is structural and must
// recurse into the type arguments of named types.
//
// Spec: type-system-formal §"Gravity Rule" (escapesRef structural reach).

type Box<T> = Box(val: T)

let leak = fn () -> Box<ref(i64)> do
  let ~x = 42
  return Box(val: x)
end

let main = fn () -> unit do
  return ()
end
