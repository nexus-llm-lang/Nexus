// expect-fail: E2023
// expect-msg: linear
// expect-msg: ref
//
// wfRef(~sigma) iff not linear(sigma): a parameter of type ref(Box<%Handle>)
// must be rejected. `linear` is structural over type arguments, so the
// wrapper `Box<%Handle>` is linear; each deref of the ref cell would yield a
// fresh copy of the wrapper and thus duplicate the inner `%Handle`. The check
// fires at the declaration site even though the inner linear sits at a
// type-argument position rather than directly under the ref.
//
// Spec: type-system-formal §wfRef + §Linearity (structural; type arguments).

type Handle = Handle(fd: i64)
type Box<T> = Box(val: T)

let bad = fn (x: ref(Box<%Handle>)) -> unit do
  return ()
end

let main = fn () -> unit do
  return ()
end
