// expect-fail: E2008
// expect-msg: linear binding '%bx' is consumed more than once
//
// As match_scrutinee_if_laundered_linear_double_consume.nx but the laundering
// scrutinee is a `match` EXPRESSION rather than `if` (nexus-qdq93). Both branch
// forms must propagate the linear classification to the match binder.
type Box = Box(val: i64)
let sink = fn (b: %Box) -> i64 do match b do | Box(val: v) -> return v end end
let main = fn () -> unit do
  let %p = Box(val: 5)
  match (match 0 do | 0 -> %p | _ -> %p end) do
    | bx ->
      let a = sink(b: bx)
      let c = sink(b: bx)
      let _d = a + c
      return ()
  end
end
