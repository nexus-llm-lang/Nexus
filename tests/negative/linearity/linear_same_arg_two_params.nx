// expect-fail: E2008
// expect-msg: consumed more than once
//
// nexus-6pff: T-App ⊎ premise — passing the same linear binding to two
// different parameters of a single call must raise LinearReuse (E2008).
// The args are walked left-to-right; the first use of %b consumes it, so
// the second use finds it in the consumed set.

type Box = Box(val: i64)

let combine = fn (%a: Box, %b: Box) -> i64 do
  match %a do | _ -> () end
  match %b do | _ -> () end
  return 0
end

let main = fn () -> unit do
  let %b = Box(val: 42)
  combine(a: %b, b: %b)
  return ()
end
