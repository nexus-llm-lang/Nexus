// expect-fail: E2009
// expect-msg: match arms diverge on outer-linear consumption
//
// A match where one arm diverges without consuming an outer linear resource
// that a non-divergent arm DOES consume must be rejected.

type Box = Box(val: i64)
type Cond = MT | MF
exception E

let consume = fn (%b: Box) -> unit do
  match b do | Box(val: _) -> return () end
end

let main = fn () -> unit throws { Exn } do
  let %h = Box(val: 1)
  let c = MT
  match c do
    | MT -> throw E             // diverges, does not consume %h
    | MF -> consume(b: %h)      // non-divergent, consumes %h
  end
  return ()
end
