// expect-fail: E2007
// expect-msg: linear binding
// expect-msg: never consumed
//
// When both if/else branches diverge (both end with return/throw), the outer
// linear param must still be consumed before divergence.  Previously
// check_expr_kind(If) returned lin_set_vars(st: st1, vs: []) wiping the outer
// vars, so P-FnEnd never saw `h` as unconsumed (nexus-eeb4).

type Handle = Handle(fd: i64)

let test_diverge = fn (h: %Handle, cond: bool) -> unit do
  if cond then
    return ()    // h never consumed
  else
    return ()    // h never consumed
  end
end

let main = fn () -> unit do
  let %h = Handle(fd: 0)
  test_diverge(h: %h, cond: true)
end
