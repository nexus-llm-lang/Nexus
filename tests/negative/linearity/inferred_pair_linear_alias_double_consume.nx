// expect-fail: E2008
// expect-msg: linear binding '%p' is consumed more than once
//
// Companion to the type-formation rule (E2033): the linearity pass tracks
// `let p = Pair(fst: 0, snd: b)` as linear when `b` is a linear binding,
// even though Pair's variant fields are generic (TyVar, not shallow-
// linear). Without this propagation, `p` would be untracked and the two
// match arms below would each consume the inner linear payload via the
// pattern-bound `b1` / `b2`, double-freeing it at runtime.
//
// Spec: type-system-formal §Linearity — linear(Pair<%T, U>) = true; an
// outer container of a linear payload is itself linear and use-once.

type Bb = Bb(x: i64)
type Pair<A, B> = Pair(fst: A, snd: B)

let take_bb = fn (b: %Bb) -> i64 do
  match b do
    | Bb(x: v) -> return v
  end
end

let main = fn () -> unit do
  let %b = Bb(x: 42)
  let p = Pair(fst: 0, snd: b)
  let _v1 = match p do
    | Pair(fst: _, snd: b1) -> take_bb(b: b1)
  end
  let _v2 = match p do
    | Pair(fst: _, snd: b2) -> take_bb(b: b2)
  end
  return ()
end
