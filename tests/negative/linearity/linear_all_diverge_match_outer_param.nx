// expect-fail: E2007
// expect-msg: linear binding
// expect-msg: never consumed
//
// When every match arm diverges (all end with return/throw), the outer linear
// param must still be consumed before divergence.  Previously check_match_cases_go
// returned lin_set_vars(st, vs: []) wiping the outer vars, so P-FnEnd never
// saw `h` as unconsumed (nexus-eeb4).

type Handle = Handle(fd: i64)

let test_diverge = fn (h: %Handle, cond: bool) -> unit do
  match cond do
    | true -> return ()    // h never consumed
    | false -> return ()   // h never consumed
  end
end

let main = fn () -> unit do
  let %h = Handle(fd: 0)
  test_diverge(h: %h, cond: true)
end
