// expect-fail: E2022
// expect-msg: mutable reference
// expect-msg: escapes
//
// Gravity rule: not escapesRef(tau). A record field whose type reaches a ref
// cell through a named type's TYPE ARGUMENT (`Box<ref(i64)>`) escapes just as
// a direct `ref(i64)` field does. escapesRef is structural and must recurse
// into the type arguments of named types.
//
// Spec: type-system-formal §"Gravity Rule" (escapesRef table, record field
// row).

type Box<T> = Box(val: T)
type LeakyRec = { cell: Box<ref(i64)> }

let main = fn () -> unit do return () end
