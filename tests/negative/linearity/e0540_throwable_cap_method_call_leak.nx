// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall) for a CAP-METHOD call `Failer.boom()`.
// A cap-method call lowers to a DIRECT `Call` whose mangled func name is
// `<cap_qname>.<method>` (register_cap_method_schemes). That name is not in the
// linearity sig-map (built only from functions / externals / handler arms), so
// `resolve_callee_throw_row` returned None and the leak guard stayed silent —
// a linear held live across a throwing cap call leaked with no runtime drop.
//
// `%h` is bound before the throwable cap call `Failer.boom()` and consumed only
// after it (`close(h: %h)`). On the throw path `close` is never reached, so
// `%h` leaks → E0540. Seeding cap methods into the sig-map lets the existing
// direct-call leak guard resolve the cap method's declared throws row and fire.

exception Boom(code: i64)

type Handle = Handle(fd: i64)

let close = fn (h: %Handle) -> i64 do
  let r = match h do | Handle(fd: i) -> i end
  return r
end

cap Failer do
  fn boom() -> i64 throws { Boom }
end

let fh = handler Failer do
  fn boom() -> i64 throws { Boom } do throw Boom(code: 1) end
end

let f = fn () -> i64 require { Failer } throws { Boom } do
  let %h = Handle(fd: 0)
  // Throwable cap-method call while `%h` is live → E0540.
  let r = Failer.boom()
  return close(h: %h)
end

let main = fn () -> unit throws {} do
  inject fh do
    try
      let v = f()
    catch
      | Boom(code: _) -> ()
    end
  end
  return ()
end
