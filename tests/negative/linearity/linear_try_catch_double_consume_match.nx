// expect-fail: E2008
// expect-msg: consumed more than once
//
// nexus-hjh2: variant of the try/catch double-consume repro using match
// instead of a function call. A linear destructured in the try body must
// not be destructured again in the catch arm.

type Token = Token(id: i64)
exception BadToken(msg: string)

let validate = fn () -> unit throws { Exn } do
  throw BadToken(msg: "bad")
end

let main = fn () -> unit throws { Exn } do
  let %tok = Token(id: 42)
  try
    match %tok do | Token(id: _) -> () end   // consumes %tok
    validate()                               // always throws after consume
  catch _ ->
    match %tok do | Token(id: _) -> () end   // %tok consumed in try body — E2008
  end
  return ()
end
