// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall) for a linear consumed by an EARLIER
// RECORD-LITERAL field while a LATER field is a throwable call.
//
// Record-literal fields do NOT route through `check_call_args` — they go through
// the multi-operand element walker (`check_named_exprs`). Before the fix, that
// walker was a plain left-to-right fold with NO sibling-leak logic, so it
// consumed `%b` (`free(r: %b)` as field `p`) BEFORE any leak guard could see it
// against the later throwable field `thr()` (field `q`). The record value is
// built only after the WHOLE field list has evaluated, so on `thr()`'s throw
// path the record is never built and `%b` leaks with no runtime drop → E0540.
//
// The equivalent direct-CALL form (`use2(b: %b, n: thr())`) was already rejected
// (tests/negative/linearity/e0540_throwable_sibling_arg_leak.nx); this pins the
// fix on the record-literal-field element path, which shares one sibling-leak
// helper with the call-argument and constructor-argument walkers.

exception E(code: i64)

type Box = Box(val: i64)

type Pair = { p: i64, q: i64 }

let free = fn (r: %Box) -> i64 do
  let Box(val: v) = r
  return v
end

let thr = fn () -> i64 throws { E } do
  throw E(code: 1)
end

let main = fn () -> unit throws { E } do
  let %b = Box(val: 1)
  // `%b` consumed by field `p`; `thr()` throws as field `q` → record never built → %b leaks.
  let p = { p: free(r: %b), q: thr() }
  return ()
end
