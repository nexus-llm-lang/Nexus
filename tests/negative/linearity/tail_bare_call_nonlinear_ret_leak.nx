// expect-fail: E2007
// expect-msg: never consumed
//
// Shape B: the TAIL bare statement of a function whose declared return type is
// NON-linear (`unit`). The tail `mk()` produces a fresh non-auto-droppable
// linear %B, but the function returns unit — the produced %B flows NOWHERE
// (it is not returned to the caller, since the return type is not linear), so
// it is silently discarded. A leak, symmetric to `let x = mk()` (E2007).
//
// Before the fix the tail-statement leak check was skipped on the premise that
// the last statement's result always flows to the caller. That premise is
// false when the enclosing function returns a non-linear type.

type B = B(n: i64)

let mk = fn () -> %B do return B(n: 1) end

let sink = fn () -> unit do mk() end

let main = fn () -> unit do
  sink()
  return ()
end
