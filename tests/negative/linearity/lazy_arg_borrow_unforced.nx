// expect-fail: E2001
// expect-msg: expected lazy type
//
// Borrow of an UNFORCED thunk in argument position is rejected at the TYPE
// level — NOT with a force-count error.
//
// Spec §stripBorrow: stripBorrow deliberately does NOT peel @ (thunk):
// stripBorrow(@σ) = @σ. A thunk's result does not exist until T-Force forces
// it, so a thunk must be forced (`let v = @x`) before its value can be
// borrowed. The arg-position borrow `&x` of a `@σ` binding therefore produces
// `&(@σ)`, and T-App-BorrowLin's unify(stripBorrow(τ'), σ) degenerates to
// unify(@σ, σ) against the `&σ` parameter slot and fails.
//
// The diagnostic MUST be the type-unification rejection ("expected lazy
// type") — a non-consuming borrow is not a force, so the lazy "forced exactly
// once" check must not count it and must not report "forced more than once".
//
// Filename omits `_test` and lives under `negative/` so the runner classifies
// it as a compile-fail fixture (see header expect-fail/expect-msg).

let peek = fn (p: &i64) -> i64 do
  p
  return 0
end

let main = fn () -> unit throws { Exn } do
  let @x = 9
  // Arg-position borrow of the unforced thunk `@x`: rejected at the type
  // level because stripBorrow(@i64) = @i64 fails to unify with `&i64`'s `i64`.
  let r = peek(p: &x)
  let v = @x
  let _sum = r + v
  return ()
end
