// expect-fail: E2007
// expect-msg: linear binding '%bb' is never consumed
//
// nexus-xim2n (inner-pattern-binder sibling of nexus-atsly): a `match` arm
// binder for a generic field of an inferred-linear `Pair<%T, _>` must inherit
// linear from the scrutinee even WITHOUT an explicit `%` sigil on the binder.
//
// `pp` is tracked as linear (its ctor routes the linear `%p` into a generic
// `fst: A` slot — the round-21 outer-let propagation). When matched, the inner
// binder `bb` lands in that same generic slot, so it owns the linear payload
// and must be consumed exactly once. Dropping it is a real `%Box` leak; before
// the fix this slipped through with no diagnostic (exit 0). The pattern pass is
// name-based and has no instantiation map, so it recognises the generic slot
// structurally: a field whose declared type names one of the enum's
// `type_params` inherits the scrutinee's linearity.
//
// Spec: type-system-formal §T-Match — `Γ_b ⊢ p_i : strip(τ) ⇒ Γ_i` with
// `τ = Pair<%Box, i64>` binds `bb : %Box`; §Linearity `linear(Pair<%T,U>)`.

type Box = Box(val: i64)
type Pair<A, B> = Pair(fst: A, snd: B)

let main = fn () -> unit do
  let %p = Box(val: 5)
  let pp = Pair(fst: %p, snd: 7)
  match pp do
    | Pair(fst: bb, snd: ss) ->
      return ()
  end
end
