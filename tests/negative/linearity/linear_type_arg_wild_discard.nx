// expect-fail: E2033
// expect-msg: type argument #1 of 'Box' is linear
// expect-msg: generic instantiation at a linear type is not supported
//
// Type-formation rule: a generic type parameter cannot be instantiated with
// a linear type (spec worked example linear(Pair<%i64,i64>) = true). The
// parameter `p: Box<%Handle>` introduces a `Box<...>` whose type argument
// `%Handle` is structurally linear, so the param-type annotation is
// rejected at the function declaration site — before the body's P-Wild
// would otherwise have caught the silent-drop. A persistent generic
// container that aliases its payload across reads would duplicate the
// linear value, so rejection is the safe disposition.
//
// Spec: type-system-formal §Linearity (structural; type arguments of named
// types).

type Handle = Handle(fd: i64)
type Box<T> = Box(val: T)

let mk = fn () -> %Handle do return Handle(fd: 42) end

let discard = fn (p: Box<%Handle>) -> unit do
  match p do
    | _ -> return ()
  end
end

let main = fn () -> unit do
  let %h = mk()
  discard(p: Box(val: %h))
  return ()
end
