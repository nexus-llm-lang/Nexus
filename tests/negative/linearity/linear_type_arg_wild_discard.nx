// expect-fail: E2001
// expect-msg: wildcard pattern
// expect-msg: cannot discard linear type
//
// P-Wild + structural linearity: `linear` inspects the TYPE ARGUMENTS of a
// named type (spec worked example linear(Pair<%i64,i64>) = true). A value of
// type `Box<%Handle>` carries a linear payload at a type-argument position,
// so discarding it with a wildcard `_` is the same silent-drop violation as
// discarding a bare `%Handle`. The wildcard must be rejected.
//
// Spec: type-system-formal §Linearity (structural; type arguments of named
// types) + P-Wild premise linear(tau) and not autoDrop(tau).

type Handle = Handle(fd: i64)
type Box<T> = Box(val: T)

let mk = fn () -> %Handle do return Handle(fd: 42) end

let discard = fn (p: Box<%Handle>) -> unit do
  match p do
    | _ -> return ()
  end
end

let main = fn () -> unit do
  let %h = mk()
  discard(p: Box(val: %h))
  return ()
end
