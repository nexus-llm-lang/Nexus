// expect-fail: E2001
// expect-msg: or-pattern
// expect-msg: linear
//
// Spec P-Or: Γ₁ \ Γ = Γ₂ \ Γ requires identical names, types, AND usage
// annotations (q=1 vs q=ω) across both alternatives.
//
// Case 1 (structural): one arm binds `x` as %i64, the other as i64.
// The types are structurally incompatible so unification fails.
//
// Case 2 (type-variable smuggling — what the explicit linearity check
// catches): a polymorphic enum whose variants carry `A` and `%B`
// respectively; in an or-pattern both bind `v`, but after unification
// succeeds (A ≔ %B), linear(A) = false ≠ linear(%B) = true.
// The type_carries_linear guard in unify_or_envs rejects this before
// the body would see ambiguous linearity for `v`.
//
// This fixture exercises the structural case; the type-variable case
// requires the P-Or check added in nexus-fz9l.

type Mixed = WithLinear(%i64) | WithPlain(i64)

let main = fn () -> unit do
  let v: Mixed = WithPlain(val: 42)
  match v do
  | WithLinear(x) | WithPlain(x) -> return ()
  end
end
