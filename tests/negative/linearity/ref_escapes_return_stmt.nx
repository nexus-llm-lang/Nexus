// expect-fail: E2022
// expect-msg: mutable reference
// expect-msg: escapes
//
// Gravity rule: ¬escapesRef(τ) — a `return` statement may not return a
// mutable reference value. T-Return checks the inferred type of the returned
// expression and rejects it when it is (or contains) a TyRef.
//
// Here `main` declares `-> unit` and there is no declared-return-type escape,
// but returning the raw ref cell `x` (accessed without the `~` dereference
// sigil) produces a TyRef(i64) inferred type that triggers the gravity check
// before the subsequent unit-mismatch unification.
//
// Spec: docs/spec/type-system-formal.md §T-Return.
// nexus-xqc5

let main = fn () -> unit do
  let ~x = 99
  return x
end
