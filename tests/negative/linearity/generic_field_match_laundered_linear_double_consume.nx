// expect-fail: E2008
// expect-msg: linear binding '%gg' is consumed more than once
//
// Double-use witness for a linear laundered through a `match` EXPRESSION into a
// generic field. `gen: A` is filled by `match c do | true -> pick(x: p) | _ ->
// pick(x: p) end`, where every arm returns the linear `%Box` via the generic
// identity `pick`. The match binder `gg` therefore carries a linear value;
// consuming it twice (two `sink` calls) is a double-free and must be E2008.
//
// Sibling of generic_field_if_laundered_linear_double_consume.nx: the demote in
// the 7umo8 logic must recurse into the `match`-expression arm bodies with the
// liveness-independent classifier, not drop to the stale-liveness fallback
// (which would untrack the field and accept the double-use).

type Box = Box(val: i64)
type Mix<A> = Mix(tag: i64, gen: A)

let pick = fn <T>(x: T) -> T do return x end

let sink = fn (b: %Box) -> i64 do
  match b do
    | Box(val: v) -> return v
  end
end

let main = fn () -> unit do
  let %p = Box(val: 5)
  let w = Mix(tag: 1, gen: match true do | true -> pick(x: p) | _ -> pick(x: p) end)
  match w do
    | Mix(tag: tt, gen: gg) ->
      let a = sink(b: gg)
      let c = sink(b: gg)
      return ()
  end
end
