// expect-fail: E2007
// expect-msg: linear binding '%gg' is never consumed
//
// A linear laundered through an `if` EXPRESSION into a generic field must STILL
// be tracked at the match site. `gen: A` is filled by `if c then pick(x: p)
// else pick(x: p) end` where `pick<T>(x: T) -> T` returns its (linear) argument
// along every branch: the runtime value flowing into the `gen` slot is the
// linear `%Box`. Dropping `gg` is a leak and must be rejected with E2007.
//
// Regression guard for the branch-launder hole (sibling of the direct-call
// guard generic_field_call_laundered_linear_drop.nx): the 7umo8 demote
// re-classifies a generic field's construction arg at the MATCH site, but an
// `if`/`match` EXPRESSION arg fell through to the stale-liveness fallback and
// was misclassified non-linear → the field was wrongly demoted (silent drop
// accepted). The demote must fire ONLY for PROVABLY non-linear args; a branch
// expression whose value launders a linear stays tracked.

type Box = Box(val: i64)
type Mix<A> = Mix(tag: i64, gen: A)

let pick = fn <T>(x: T) -> T do return x end

let main = fn () -> unit do
  let %p = Box(val: 5)
  // Inferred Mix<%Box>: `gen` is filled by the linear `%p` laundered through
  // the generic identity call `pick` inside an `if` expression.
  let w = Mix(tag: 1, gen: if true then pick(x: p) else pick(x: p) end)
  match w do
    | Mix(tag: tt, gen: gg) -> return ()
  end
end
