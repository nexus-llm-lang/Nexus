// expect-fail: E2008
// expect-msg: linear binding '%p' is consumed more than once
//
// Param→result-slot linear propagation through a CALL: `mk<A,B>(a:A, b:B) ->
// Pair<A,B>` flows the linear `%b` into the result's B slot. Even though
// `mk` is a wrapper around `Pair(...)` and the variant fields are TyVar
// (no shallow-linear field), `let p = mk(a:0, b:b)` must track `p` as
// linear — without this, the two match arms below each consume the inner
// linear payload via `b1`/`b2`, double-freeing it at runtime.
//
// Companion to the inferred-Pair-of-linear test (jpn2e) for the Ctor branch:
// here the call is a function (Call branch of `let_binds_linear`).

type Bb = Bb(x: i64)
type Pair<A, B> = Pair(fst: A, snd: B)

let mk = fn <A, B>(a: A, b: B) -> Pair<A, B> do
  return Pair(fst: a, snd: b)
end

let take_bb = fn (b: %Bb) -> i64 do
  match b do
    | Bb(x: v) -> return v
  end
end

let main = fn () -> unit do
  let %b = Bb(x: 42)
  let p = mk(a: 0, b: b)
  let _v1 = match p do
    | Pair(fst: _, snd: b1) -> take_bb(b: b1)
  end
  let _v2 = match p do
    | Pair(fst: _, snd: b2) -> take_bb(b: b2)
  end
  return ()
end
