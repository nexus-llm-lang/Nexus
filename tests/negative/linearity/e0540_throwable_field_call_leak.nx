// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall) for an INDIRECT call through a RECORD
// FIELD callee `rec.fn0()`. This lowers to a `CallExpr` whose callee is a
// `FieldAccess` node. The indirect-throwable-leak guard previously handled only
// `Variable` and inline `Lambda` callees; a `FieldAccess` callee fell through
// the silent fallthrough arm, so a linear held live across a throwing field
// call leaked with no runtime drop.
//
// `%h` is bound before the throwable field call `rec.fn0()` and consumed only
// after it (`close(h: %h)`). On the throw path `close` is never reached, so
// `%h` leaks → E0540. The guard must resolve the field's bound-lambda throws
// row from the local record binding and fire here.

exception Boom(code: i64)

type Handle = Handle(fd: i64)

let close = fn (h: %Handle) -> i64 do
  let r = match h do | Handle(fd: i) -> i end
  return r
end

let f = fn () -> i64 throws { Boom } do
  let rec = { fn0: fn () -> i64 throws { Boom } do throw Boom(code: 1) end }
  let %h = Handle(fd: 0)
  // Throwable record-field call while `%h` is live → E0540.
  let r = rec.fn0()
  return close(h: %h)
end

let main = fn () -> unit throws {} do
  try
    let v = f()
  catch
    | Boom(code: _) -> ()
  end
  return ()
end
