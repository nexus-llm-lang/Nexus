// expect-fail: E2022
// expect-msg: escapes
//
// Gravity rule (nexus-quuuq, ymx7u residual): same as
// borrow_escapes_record_field_local_nonlinear.nx but via a DIRECT ADT
// constructor `R(b: &x)` over a LOCAL NON-LINEAR owner, returned. The
// owner-locality heuristic must reject the escape regardless of whether the
// borrow-bearing aggregate is a record literal or a constructor call.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule". nexus-quuuq

type R = R(b: &i64)

let leak = fn () -> R do
  let x = 1
  let r = R(b: &x)
  return r
end

let main = fn () -> unit do
  let r = leak()
  return ()
end
