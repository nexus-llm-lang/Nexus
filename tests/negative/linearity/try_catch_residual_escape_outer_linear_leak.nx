// expect-fail: E2009
// expect-msg: match arms diverge on outer-linear consumption
//
// nexus-c3lk0 (T-TryCatch ρ_residual uncaught-throw escape): an all-divergent
// try/catch whose residual is non-empty leaks an outer linear on the uncaught-
// throw escape path.
//
// `wrapper` binds `%h`, then a `try` whose body is all-divergent (`let _x =
// inner(); throw E1`) and whose catch arm is also divergent (`consume_h(%h);
// throw E2`). Here `inner()` throws { E1, E3 }; the catch arm catches only E1,
// so E3 forms ρ_residual ≠ ∅. On the E3 path control leaves `try` (and
// `wrapper`) without running the catch arm, and `%h` — never consumed in the
// try body before the `inner()` throw point — leaks.
//
// Since nexus-7hbia, the selective-`catch` desugar appends a synthetic residual
// re-throw arm `| __exn_v -> throw __exn_v` so unmatched variants PROPAGATE at
// runtime instead of falling into the wrong arm. That synthetic arm is now the
// literal residual escape path, and it does NOT consume `%h` while the `E1` arm
// does — so the linear-arm-agreement check rejects the leak directly (E2009:
// match arms diverge on outer-linear consumption). This is the same leak the
// c3lk0 residual-escape clause caught, surfaced one layer earlier now that the
// escape path is a real match arm rather than an implicit fall-through.

exception E1
exception E2
exception E3

type H = H(n: i64)

let make_h = fn () -> H do return H(n: 1) end

let consume_h = fn (h: %H) -> unit do
  match h do | H(n: _) -> return () end
end

let inner = fn () -> i64 throws { E1, E3 } do throw E3 end

let wrapper = fn () -> unit throws { E2, E3 } do
  let %h = make_h()
  try
    let _x = inner()
    throw E1
  catch
  | E1 ->
      consume_h(h: %h)
      throw E2
  end
end

let main = fn () -> unit do
  try wrapper() catch | E2 -> () | E3 -> () end
end
