// expect-fail: E2007
// expect-msg: never consumed
//
// nexus-c3lk0 (T-TryCatch ρ_residual uncaught-throw escape): an all-divergent
// try/catch whose residual is non-empty leaks an outer linear on the uncaught-
// throw escape path.
//
// `wrapper` binds `%h`, then a `try` whose body is all-divergent (`let _x =
// inner(); throw E1`) and whose catch arm is also divergent (`consume_h(%h);
// throw E2`). Spec §T-TryCatch all-divergent clause (A = ∅) requires the try-
// body itself to consume every outer linear before its divergence:
//   {x | Γ(x) = (1,S)} ⊆ linConsumed(s̄_try, Γ)
// Here `inner()` throws { E1, E3 }; the catch arm catches only E1, so E3 forms
// ρ_residual ≠ ∅. On the E3 path control leaves `try` (and `wrapper`) without
// running the catch arm, and `%h` — never consumed in the try body before the
// `inner()` throw point — leaks.
//
// Before the fix the `try_body_diverges` shortcut returned the catch-arm exit
// state unconditionally, skipping the try-body-consumption clause and silently
// admitting the leak.

exception E1
exception E2
exception E3

type H = H(n: i64)

let make_h = fn () -> H do return H(n: 1) end

let consume_h = fn (h: %H) -> unit do
  match h do | H(n: _) -> return () end
end

let inner = fn () -> i64 throws { E1, E3 } do throw E3 end

let wrapper = fn () -> unit throws { E2, E3 } do
  let %h = make_h()
  try
    let _x = inner()
    throw E1
  catch
  | E1 ->
      consume_h(h: %h)
      throw E2
  end
end

let main = fn () -> unit do
  try wrapper() catch | E2 -> () | E3 -> () end
end
