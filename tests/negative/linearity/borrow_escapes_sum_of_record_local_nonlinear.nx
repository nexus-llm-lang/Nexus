// expect-fail: E2022
// expect-msg: escapes
//
// Gravity rule (nexus-37bav, quuuq residual): a `&σ` borrow of a LOCAL
// NON-LINEAR owner buried inside a record that is itself a SUM variant payload
// escapes when the sum value is returned. The carrier nesting here is
// sum-of-record: `Wrap(i: { b: &x })`.
//
// The escape walk must recurse from the Ctor argument into the nested record
// to find the borrow of the local `x`; otherwise the borrow dangles after
// `leak` returns the `Box` (use-after-scope).
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule". nexus-37bav

type Inner = { b: &i64 }
type Box = Wrap(i: Inner) | Empty

let leak = fn () -> Box do
  let x = 1
  return Wrap(i: { b: &x })
end

let main = fn () -> unit do
  let r = leak()
  return ()
end
