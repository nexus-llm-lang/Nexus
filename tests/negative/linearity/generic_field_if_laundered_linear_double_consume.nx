// expect-fail: E2008
// expect-msg: linear binding '%gg' is consumed more than once
//
// Double-use witness for a linear laundered through an `if` EXPRESSION into a
// generic field. `gen: A` is filled by `if c then pick(x: p) else pick(x: p)
// end`, where every branch returns the linear `%Box` via the generic identity
// `pick`. The match binder `gg` therefore carries a linear value; consuming it
// twice (two `sink` calls) is a double-free and must be rejected with E2008.
//
// Sibling of generic_field_call_laundered_linear_double_consume.nx (the direct
// `gen: pick(x: p)` form): the demote in the 7umo8 logic must recurse into the
// `if`-expression branches with the liveness-independent classifier, not drop
// to the stale-liveness fallback (which would untrack the field and accept the
// double-use). The branch-laundered linear's consumed-ness is recovered at the
// `let w = ...` binding boundary.

type Box = Box(val: i64)
type Mix<A> = Mix(tag: i64, gen: A)

let pick = fn <T>(x: T) -> T do return x end

let sink = fn (b: %Box) -> i64 do
  match b do
    | Box(val: v) -> return v
  end
end

let main = fn () -> unit do
  let %p = Box(val: 5)
  let w = Mix(tag: 1, gen: if true then pick(x: p) else pick(x: p) end)
  match w do
    | Mix(tag: tt, gen: gg) ->
      let a = sink(b: gg)
      let c = sink(b: gg)
      return ()
  end
end
