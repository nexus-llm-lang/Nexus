// expect-fail: E2001
// expect-msg: borrow
// expect-msg: linear
//
// Spec §U-Borrow premise ¬linear(τ₂): a borrow &σ must not satisfy a
// linear parameter slot %T. Passing &x where %T is expected would let the
// callee consume the resource while the caller still holds the borrow's
// source, violating the ownership model. The typechecker must reject this.

let consume = fn (p: %i64) -> unit do
  let _ = p
  return ()
end

let main = fn () -> unit do
  let x: i64 = 42
  consume(p: &x)
  return ()
end
