// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall) in EXPRESSION position. The reference
// fixture (e0540_throwable_call_leak.nx) exercises a throwable call at
// STATEMENT level. This one pins the let-RHS / expression-position case: the
// throwable-call leak guard must fire regardless of statement position,
// because a throwable call in a let-RHS abandons any still-live linear on its
// throw path with no runtime drop just the same.
//
// `%h` is bound *before* the throwable `might_throw()` and consumed only after
// it. `might_throw()` is called in let-RHS position (`let v = might_throw()`),
// so on the throw path control never reaches `close`, and `%h` leaks. Before
// the ungate this slipped through because the guard only ran at statement
// level.

exception Boom(code: i64)

type Handle = Handle(fd: i64)

let might_throw = fn () -> i64 throws { Exn } do
  throw Boom(code: 1)
end

let close = fn (h: %Handle) -> unit do
  let r = match h do | Handle(fd: i) -> i end
  return ()
end

let main = fn () -> unit throws { Exn } do
  let %h = Handle(fd: 0)
  // Throwable call in let-RHS (expression) position while `%h` is live. On the
  // throw path `close` is never reached, so `%h` leaks → E0540. The guard must
  // fire here even though the throwable call is not at statement level.
  let v = might_throw()
  close(h: %h)
  return ()
end
