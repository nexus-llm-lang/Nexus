// expect-fail: E2008
// expect-msg: linear binding '%bx' is consumed more than once
//
// Double-use witness (nexus-qdq93): a linear laundered through an `if`
// EXPRESSION consumed DIRECTLY as a match scrutinee (no intermediate `let`).
// `if true then %p else %p end` yields the linear `%Box`; the match binder `bx`
// therefore carries a linear value, so consuming it twice (two `sink` calls) is
// a double-free and must be rejected with E2008. Sibling of b1o38, whose fix
// classified the launder only at the `let`-binding boundary — the scrutinee-
// linear gate at the match site (linearity/walk.nx) now also classifies a
// laundering if/match scrutinee via let_binds_linear.
type Box = Box(val: i64)
let sink = fn (b: %Box) -> i64 do match b do | Box(val: v) -> return v end end
let main = fn () -> unit do
  let %p = Box(val: 5)
  match if true then %p else %p end do
    | bx ->
      let a = sink(b: bx)
      let c = sink(b: bx)
      let _d = a + c
      return ()
  end
end
