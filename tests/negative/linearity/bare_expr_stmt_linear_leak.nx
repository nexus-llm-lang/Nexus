// expect-fail: E2007
// expect-msg: never consumed
//
// A bare expression statement that PRODUCES a fresh non-auto-droppable linear
// value (`mk() -> %B`) silently discards it: no binding names the result and
// no consumer takes it. Symmetric to the `let x = mk()` rejection — the
// produced linear is never consumed (E2007). The statement is non-tail (a
// `return ()` follows), so the result flows nowhere.
//
// Before the fix the bare form was accepted (the `let`-bound and `let _ = e`
// forms were already rejected), an asymmetry that let a linear resource leak.

type B = B(n: i64)

let mk = fn () -> %B do return B(n: 1) end

let main = fn () -> unit do
  mk()
  return ()
end
