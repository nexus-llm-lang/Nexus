// expect-fail: E2008
// expect-msg: linear binding '%p' is consumed more than once
//
// Companion to the type-formation rule (E2033): the linearity pass tracks
// `let p = Pair(fst: 0, snd: Holder(buf: %ByteBuffer))` as linear because
// the inner `Holder` ctor has a shallow-linear (TyLinear) field — the
// outer Pair therefore carries a linear payload and must be use-once.
//
// Without this propagation, `p` would be untracked (Pair's own variant
// fields are TyVar, not shallow-linear), and matching twice would
// double-free the wrapped ByteBuffer at runtime.
//
// Spec: type-system-formal §Linearity — linear(Pair<%T, U>) = true.

import * as bb from "std:bytebuffer"

type Holder = Holder(buf: %ByteBuffer)
type Pair<A, B> = Pair(fst: A, snd: B)

let consume = fn (h: %Holder) -> i64 do
  match h do
    | Holder(buf: %buffer) ->
      let n = bb.length(buf: &buffer)
      bb.free(buf: %buffer)
      return n
  end
end

let main = fn () -> unit do
  let p = Pair(fst: 0, snd: Holder(buf: bb.empty()))
  let _v1 = match p do
    | Pair(fst: _, snd: h1) -> consume(h: h1)
  end
  let _v2 = match p do
    | Pair(fst: _, snd: h2) -> consume(h: h2)
  end
  return ()
end
