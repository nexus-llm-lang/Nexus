// expect-fail: E2022
// expect-msg: escapes
//
// Gravity rule (nexus-quuuq, ymx7u residual): a `&σ` borrow STORED in a
// record/ADT field escapes its owner when the record is RETURNED and the
// borrowed owner is a LOCAL NON-LINEAR binding (a `let x = ...` in THIS
// function body). After `leak` returns, the local `x` is gone, so the
// returned record's `b` field is a dangling borrow (use-after-scope).
//
// ymx7u closed the LINEAR-owner case (a `let %x` consumed by function-end);
// quuuq is the residual NON-LINEAR-owner case. The owner-locality principle
// is identical: a borrow of any LOCAL binding (linear or not) cannot soundly
// outlive the function via a returned record.
//
// Borrows of NON-LINEAR `&`-typed PARAMETERS stored in a returned record (the
// CompileCtx/CodegenCtx idiom — owner outlives the function) stay permitted;
// see the positive companion borrow_field_nonlinear_owner_test.nx.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule".
// nexus-quuuq

type R = { b: &i64 }

let leak = fn () -> R do
  let x = 1
  let r: R = { b: &x }
  return r
end

let main = fn () -> unit do
  let r = leak()
  return ()
end
