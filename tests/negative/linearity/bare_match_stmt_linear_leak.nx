// expect-fail: E2007
// expect-msg: never consumed
//
// Shape A (match form): a bare `match … do | _ -> mk() end` STATEMENT
// (non-tail) whose every case produces a fresh non-auto-droppable linear
// (`mk() -> %B`). The match result is a fresh %B that nothing binds or
// consumes — the produced linear leaks (E2007). Identical in spirit to the
// `if` form and to the bare `mk()` call form.
//
// Before the fix only the bare `Call` head was inspected; the `Match` result
// shape slipped through, leaving this leak accepted (rc=0).

type B = B(n: i64)

let mk = fn () -> %B do return B(n: 1) end

let main = fn () -> unit do
  match 1 do | _ -> mk() end
  return ()
end
