// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall) for an INDIRECT call through a
// FUNCTION-TYPED PARAMETER. The callee `mt` is a parameter whose declared type
// is `() -> i64 throws { Boom }`; its throws row lives in the param's type
// annotation, not the global sig-map, so the leak guard previously stayed
// silent for `mt()`.
//
// `%h` is bound before the throwable param call `mt()` and consumed only after
// it. On the throw path `close` is never reached, so `%h` leaks → E0540. The
// guard must resolve the throws row from the function-typed param.

exception Boom(code: i64)

type Handle = Handle(fd: i64)

let close = fn (h: %Handle) -> i64 do
  let r = match h do | Handle(fd: i) -> i end
  return r
end

let f = fn (mt: () -> i64 throws { Boom }) -> i64 throws { Boom } do
  let %h = Handle(fd: 0)
  // Throwable function-typed-PARAM call while `%h` is live → E0540.
  let r = mt()
  return close(h: %h)
end

let g = fn () -> i64 throws { Boom } do throw Boom(code: 1) end

let main = fn () -> unit throws {} do
  try
    let v = f(mt: g)
  catch
    | Boom(code: _) -> ()
  end
  return ()
end
