// expect-fail: E2007
// expect-msg: never consumed
//
// nexus-ans4: a plain `let w2 = w1` alias where w1 is a live linear binding
// must inherit linear tracking so w2 is use-once.  Previously the Variable
// RHS case fell through to the `| _ -> false` default in `let_binds_linear`,
// so the alias was not tracked and the underlying resource was silently dropped.

type Box = Box(val: i64)
type W = MkW(inner: %Box)

let main = fn () -> unit do
  let %b = Box(val: 1)
  let %w1 = MkW(inner: %b)
  let w2 = w1
  return ()
end
