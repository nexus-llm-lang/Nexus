// expect-fail: E2007
// expect-msg: never consumed
//
// nexus-xd8ko (flow-sensitive divergent-throw leak): a bare `if cond then
// throw E end` (no else) before a consumer abandons an outer-scope linear on
// the throw path. When the thrown variant is catchable somewhere in the whole
// program (here `main` has a catch-all `| _ ->`, contributing Exn to
// caught_variants(Π) via U-Row-Exn subsumption), the throw may be received
// upstream — so the abandoned linear `%r` is a real leak and must be rejected.
//
// Before the fix the divergent-if path used the relaxed inner-scope-only check
// and silently admitted, leaking `%r` across the catchable throw.

exception Boom(msg: string)

type Res = Res(n: i64)

let free_res = fn (r: %Res) -> unit do
  let Res(n: _) = r
  return ()
end

let g = fn (r: %Res, b: bool) -> unit throws { Boom } do
  // `%r` is live here; the throw abandons it on the divergent path.
  if b then throw Boom(msg: "early") end
  free_res(r: r)
  return ()
end

// The catch-all arm makes Boom catchable whole-program → g's throw is strict.
let main = fn () -> unit do
  let %r = Res(n: 1)
  try
    g(r: %r, b: false)
    return ()
  catch
    | _ -> return ()
  end
end
