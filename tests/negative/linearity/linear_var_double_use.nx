// expect-fail: E2007
// expect-msg: never consumed
//
// P-Var: a plain `| x ->` pattern on a linear scrutinee must track x as
// linear (q = 1).  The body does not consume x (no lin_remove), so
// LinearUnused must fire at function-end (after the match).
//
// Previously, only the `%` sigil triggered linearity tracking in the pattern;
// plain-variable patterns were silently not tracked even when the scrutinee
// was linear, so leaving x in the arm body without consuming it passed
// silently instead of raising E2007.

type Handle = Handle(fd: i64)

let make_handle = fn () -> %Handle do
  return Handle(fd: 42)
end

let noop = fn (x: i64) -> unit do
  x
  return ()
end

let main = fn () -> unit do
  let %h = make_handle()
  let result = match h do
    | x ->
      // x is not consumed here (only a non-consuming reference via noop).
      // With the fix: x is tracked as linear and must be consumed.
      // Without the fix: x is not tracked so this passes silently.
      noop(x: 0)
  end
  result
  return ()
end
