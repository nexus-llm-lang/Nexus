// expect-fail: E2022
// expect-msg: escapes
//
// Gravity rule (nexus-opd38, Form A): a `&σ` borrow is a non-owning view with
// the same stack-confined lifetime hazard as `~σ`. Returning a borrow lets it
// outlive the owner whose storage it views → use-after-free (read freed
// memory after the owner is `free`d).
//
// The repro that motivated this: `leak` returns its borrowed `&ByteBuffer`
// parameter; the caller frees the owner, then reads through the escaped borrow.
// The fix rejects `&σ` in RETURN-TYPE position (here) while still permitting it
// as a parameter type and as a record/ADT field (field-stored borrows are an
// intentional idiom — see the positive test borrow_field_record_test.nx).
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule".
// nexus-opd38

import * as bb from "std:bytebuffer"

let leak = fn (c: &ByteBuffer) -> &ByteBuffer do return c end

let main = fn () -> unit do return () end
