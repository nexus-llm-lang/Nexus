// expect-fail: E2022
// expect-msg: escapes
//
// Gravity rule (closure-in-aggregate-field residual of nexus-drerq): the Ctor
// analog of borrow_escapes_closure_in_record_field.nx. A closure capturing a
// frame-local borrow escapes when stored inside a RETURNED ADT field, exactly as
// when it is returned directly.
//
// `leak` binds a frame-local `x`, takes a borrow `b = &x`, builds a closure `g`
// that reads `b`, and returns `W(f: g)`. After `leak` returns the local `x` is
// gone, so the captured borrow of `x` in the constructed value's `f` field
// dangles (use-after-scope). The owner-locality rule is the same as the
// record-field and directly-returned-closure cases, so this must be rejected
// with E2022.
//
// Spec: docs/spec/type-system-formal.md §"Gravity Rule".

type W = W(f: (() -> i64))

let leak = fn () -> W do
  let x = 1
  let b = &x
  let g = fn () -> i64 do return b end
  return W(f: g)
end

let main = fn () -> unit do
  let w = leak()
  return ()
end
