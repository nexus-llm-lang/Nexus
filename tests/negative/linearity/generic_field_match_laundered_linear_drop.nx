// expect-fail: E2007
// expect-msg: linear binding '%gg' is never consumed
//
// A linear laundered through a `match` EXPRESSION into a generic field must
// STILL be tracked at the match site. `gen: A` is filled by `match c do | true
// -> pick(x: p) | _ -> pick(x: p) end` where `pick<T>(x: T) -> T` returns its
// (linear) argument along every arm: the runtime value flowing into the `gen`
// slot is the linear `%Box`. Dropping `gg` is a leak and must be E2007.
//
// Regression guard for the branch-launder hole (sibling of the if-expression
// guard generic_field_if_laundered_linear_drop.nx): a `match` EXPRESSION arg
// must not fall through to the stale-liveness fallback and be misclassified
// non-linear → wrongly demoted (silent drop accepted). The demote must fire
// ONLY for PROVABLY non-linear args.

type Box = Box(val: i64)
type Mix<A> = Mix(tag: i64, gen: A)

let pick = fn <T>(x: T) -> T do return x end

let main = fn () -> unit do
  let %p = Box(val: 5)
  // Inferred Mix<%Box>: `gen` is filled by the linear `%p` laundered through
  // the generic identity call `pick` inside a `match` expression.
  let w = Mix(tag: 1, gen: match true do | true -> pick(x: p) | _ -> pick(x: p) end)
  match w do
    | Mix(tag: tt, gen: gg) -> return ()
  end
end
