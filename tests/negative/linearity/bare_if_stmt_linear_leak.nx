// expect-fail: E2007
// expect-msg: never consumed
//
// Shape A (if form): a bare `if … then mk() else mk() end` STATEMENT (non-tail)
// whose every arm produces a fresh non-auto-droppable linear (`mk() -> %B`).
// The `if` result is itself a fresh %B, but nothing binds or consumes it — the
// produced linear leaks. Symmetric to `let x = if … then mk() else mk() end`
// (which IS rejected because %x is then left unconsumed) and to the bare
// `mk()` call form. Both arms are uniformly linear, so the result is uniformly
// a discarded fresh linear (E2007).
//
// Before the fix only the bare `Call` head was inspected; `If`/`Match` result
// shapes slipped through, leaving this leak accepted (rc=0).

type B = B(n: i64)

let mk = fn () -> %B do return B(n: 1) end

let main = fn () -> unit do
  if true then mk() else mk() end
  return ()
end
