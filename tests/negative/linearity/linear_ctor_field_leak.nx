// expect-fail: E2007
// expect-msg: linear binding
// expect-msg: never consumed
//
// P-Var (nexus-udnk): a plain pattern variable that binds a constructor field
// whose declared type is `%T` must be tracked as a linear binding, even if the
// pattern variable carries no explicit `%` sigil.  Here `inner: x` destructures
// a field of type `%Handle`; `x` therefore receives a linear value and must be
// consumed exactly once.  The arm never consumes `x`, so the linearity pass
// should fire E2007 (LinearUnused).

type Handle = Handle(fd: i64)
type Wrapper = Wrapper(inner: %Handle)

let make_handle = fn () -> %Handle do
  return Handle(fd: 42)
end

let make_wrapper = fn () -> %Wrapper do
  return Wrapper(inner: make_handle())
end

let main = fn () -> unit do
  let %w = make_wrapper()
  // The arm binds `x` which has type %Handle (a linear value).
  // Since `x` is never consumed in this arm, E2007 should fire.
  match w do
    | Wrapper(inner: x) -> 0
  end
  return ()
end
