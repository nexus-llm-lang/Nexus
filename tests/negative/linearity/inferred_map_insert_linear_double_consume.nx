// expect-fail: E2008
// expect-msg: linear binding '%m1' is consumed more than once
//
// Param→result-slot linear propagation through a generic-collection call:
// `map.insert<K,V>(m: Map<K,V>, k: K, v: V) -> Map<K,V>` flows the linear
// `%b` into the result's V slot. Inferred-form `let m1 = map.insert(...)`
// must track `m1` as linear — without this, two `match m1` arms each
// destructure the map and double-consume the embedded linear value.
//
// Companion to the annotation-site E2033 check (atsly): the annotated form
// `let m: Map<string,%ByteBuffer> = ...` already rejects via wf-formation;
// this test covers the inferred form that bypasses annotation.

import * as bb from "std:bytebuffer"
import * as map from "std:collection/map"
import * as str from "std:text/str"

let str_hash = fn (k: string) -> i64 do return str.length(s: k) end
let str_eq = fn (a: string, b: string) -> bool do return a == b end

let main = fn () -> unit do
  let m0 = map.empty(hash: str_hash, eq: str_eq)
  let %b = bb.empty()
  let m1 = map.insert(m: m0, k: "a", v: b)
  let _v1 = match map.get_or(m: m1, k: "a", default: bb.empty()) do
    | r -> bb.free(buf: %r)
  end
  let _v2 = match map.get_or(m: m1, k: "a", default: bb.empty()) do
    | r -> bb.free(buf: %r)
  end
  return ()
end
