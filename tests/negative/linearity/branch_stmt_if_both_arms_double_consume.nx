// expect-fail: E2008
// expect-msg: linear binding '%p' is consumed more than once
//
// Double-use witness for a linear consumed inside BOTH arms of an `if`
// STATEMENT, then reused afterwards. Each arm of `if true then ... else ...`
// consumes `%p` via `sink`; the linear is therefore consumed exactly once on
// every path through the `if`, so it is dead at the join. A later `sink(b: p)`
// is a second consume of an already-moved linear — a double-free that must be
// rejected with E2008.
//
// Statement-body dual of generic_field_if_laundered_linear_double_consume.nx
// (the if-EXPRESSION launder, b1o38) and the qdq93 match-scrutinee form. The
// branch-join restores the pre-branch state and overwrites only the live set,
// so a linear consumed inside the arms is dropped from BOTH the live and the
// consumed sets; the consumed-set repair at the statement join recovers its
// consumed-ness so the reuse is caught.

type Box = Box(val: i64)

let sink = fn (b: %Box) -> i64 do
  let Box(val: v) = b
  return v
end

let main = fn () -> unit do
  let %p = Box(val: 5)
  if true then let _a = sink(b: p) else let _b = sink(b: p) end
  let c = sink(b: p)
  let _d = c
  return ()
end
