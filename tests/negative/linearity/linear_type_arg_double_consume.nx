// expect-fail: E2033
// expect-msg: type argument #1 of 'Box' is linear
// expect-msg: generic instantiation at a linear type is not supported
//
// Type-formation rule: the param annotation `p: Box<%Handle>` instantiates
// the generic `Box<T>` at a linear `T = %Handle`. The persistent generic
// container would alias the wrapped linear across reads (e.g. two
// `let Box(val: %h) = p` unpacks), duplicating a single-use resource. The
// rule rejects at the parameter-type introduction site, before the
// linearity pass would have caught the double-consume in the body.
//
// Spec: type-system-formal §Linearity (worked example
// linear(Pair<%i64,i64>) = true; structural over type arguments).

type Handle = Handle(fd: i64)
type Box<T> = Box(val: T)

let mk = fn () -> %Handle do return Handle(fd: 42) end
let sink = fn (%h: Handle) -> unit do
  %h
  return ()
end

let dbl = fn (p: Box<%Handle>) -> unit do
  let Box(val: %h1) = p
  sink(h: %h1)
  let Box(val: %h2) = p
  sink(h: %h2)
  return ()
end

let main = fn () -> unit do
  let %h = mk()
  dbl(p: Box(val: %h))
  return ()
end
