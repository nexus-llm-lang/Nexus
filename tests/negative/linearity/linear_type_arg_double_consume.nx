// expect-fail: E2008
// expect-msg: consumed more than once
//
// Structural linearity over type arguments: a binding of type `Box<%Handle>`
// is linear because its type argument is linear (spec worked example
// linear(Pair<%i64,i64>) = true). Unpacking it twice consumes the wrapped
// `%Handle` twice, which the linearity pass must reject as a double-consume.
//
// Spec: type-system-formal §Linearity (structural; type arguments of named
// types).

type Handle = Handle(fd: i64)
type Box<T> = Box(val: T)

let mk = fn () -> %Handle do return Handle(fd: 42) end
let sink = fn (%h: Handle) -> unit do
  %h
  return ()
end

let dbl = fn (p: Box<%Handle>) -> unit do
  let Box(val: %h1) = p
  sink(h: %h1)
  let Box(val: %h2) = p
  sink(h: %h2)
  return ()
end

let main = fn () -> unit do
  let %h = mk()
  dbl(p: Box(val: %h))
  return ()
end
