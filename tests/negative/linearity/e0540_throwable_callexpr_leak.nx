// expect-fail: E0540
// expect-msg: linear value
// expect-msg: throwable call
//
// E0540 (LinearLeakAcrossThrowableCall) for a parenthesised INDIRECT call that
// lowers to the `CallExpr` (indirect-call) HIR arm rather than the directly-
// named `Call` arm. The yet90 fix only ran the leak guard on the `Call` arm; a
// `CallExpr` callee (here `(mt)()`) ran no leak check at all, so a linear held
// live across an indirect throwable call leaked silently.
//
// `%h` is bound before the throwable parenthesised closure call `(mt)()` and
// consumed only after it. On the throw path `close` is never reached, so `%h`
// leaks → E0540. The guard must now also run on the `CallExpr` arm.

exception Boom(code: i64)

type Handle = Handle(fd: i64)

let close = fn (h: %Handle) -> i64 do
  let r = match h do | Handle(fd: i) -> i end
  return r
end

let f = fn () -> i64 throws { Boom } do
  let mt = fn () -> i64 throws { Boom } do throw Boom(code: 1) end
  let %h = Handle(fd: 0)
  // Parenthesised callee → CallExpr arm. Throwable while `%h` is live → E0540.
  let r = (mt)()
  return close(h: %h)
end

let main = fn () -> unit throws {} do
  try
    let v = f()
  catch
    | Boom(code: _) -> ()
  end
  return ()
end
