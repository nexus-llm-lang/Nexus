// expect-fail: E2008
// expect-msg: consumed more than once
//
// nexus-ajwla: a closure that captures a linear binding is itself one-shot
// (linear). Calling it a second time would double-free the captured linear.
// The linearity pass must treat such a closure as linear and reject any
// call site that invokes it more than once.
//
// Previously: admitted; triple-free at runtime.
// Now: E2008 (LinearReuse) on the second call to `f`.

type Res = Res(tag: i64)

let free_res = fn (r: %Res) -> unit do
  let Res(tag: _) = r
  return ()
end

let main = fn () -> unit do
  let %r = Res(tag: 8)
  let f = fn () -> unit do
    free_res(r: %r)
    return ()
  end
  f()
  f()   // E2008: f is one-shot (captures %r); cannot call twice
  return ()
end
