// expect-fail: E2007
// expect-msg: linear binding
// expect-msg: never consumed
//
// P-Wild / autoDrop(@σ)=false: discarding an unforced thunk via wildcard
// `let _ = t` silently drops the suspended computation — the thunk body
// never runs. This violates the one-shot consumption guarantee of lazy
// bindings: autoDrop(@σ) = false requires every lazy binding to be observed
// exactly once (forced, not silently dropped).
//
// Contrast with `let _ = @t` (force-then-discard), which IS permitted:
// the thunk IS forced; only the resulting primitive value is discarded.

let side = fn () -> i64 do
  return 42
end

let main = fn () -> unit do
  let @t = side()
  let _ = t
  return ()
end
