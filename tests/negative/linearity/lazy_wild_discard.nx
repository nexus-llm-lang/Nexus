// expect-fail: E2005
// expect-msg: never forced
//
// A lazy binding that is never forced (never `@t`) leaks — the thunk body
// never runs. The linearity checker must catch this via LazyNotForced.

let side = fn () -> i64 do
  return 42
end

let main = fn () -> unit do
  let @t = side()
  return ()
end
