// expect-fail: E2007
// expect-msg: is never consumed
//
// nexus-w1l79 (T-TryCatch catch-all masks try-body normal-exit linear leak):
// a try/catch whose try-body EXITS NORMALLY (here via `return ()`, a
// return-style divergence that throws nothing) leaks an outer linear that is
// ONLY consumed in the catch-all arm. The catch arm is unreachable — the
// try-body never throws — so `%h` is never consumed on the actual (normal-
// exit) path.
//
// Previously the linearity pass took the "try body diverges" branch and
// credited the catch-all arm's consumption for ALL paths, masking the leak.
// A return-style divergence (`divergence_throw_variant` = None) abandons the
// function continuation WITHOUT running any catch arm, so the outer linear
// still live at the return point must be rejected (E2007 never consumed).
//
// The selective-catch form of the same shape was already rejected (E2009);
// only the catch-all `_` arm slipped through.

type H = H(n: i64)

let consume_h = fn (h: %H) -> unit do
  let H(n: _) = h
  return ()
end

let leak = fn () -> unit do
  let %h = H(n: 7)
  try
    return ()
  catch _ -> consume_h(h: %h)
  end
end

let main = fn () -> unit do
  leak()
  return ()
end
