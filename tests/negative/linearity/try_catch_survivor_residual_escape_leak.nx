// expect-fail: E2007
// expect-msg: never consumed
//
// nexus-c3lk0 (T-TryCatch ρ_residual escape — survivor variant): the try-body
// has a normal-completion (success) path AND a non-empty residual. Both the
// success tail and the catch arm consume `%h`, so the arm-agreement check
// passes — yet the uncaught-throw escape path still drops `%h`.
//
// `inner()` throws { E1, E3 }; the catch arm catches only E1, so E3 forms
// ρ_residual ≠ ∅. On the E3 path control leaves `try` (and `wrapper`) after
// `inner()` throws — BEFORE `consume_h(%h)` on the success tail — without
// running the catch arm. `%h`, never consumed before that throw point, leaks.
//
// This is the spec-side gap the bd flagged (verify-r22/C/p11): the spec's
// reachable-path agreement (Δ_try = Δ_catch_E1 = {h}) does not surface the
// escape path. The impl closes it by adding the residual-escape leg
// independent of whether the try-body diverges.

exception E1
exception E3

type H = H(n: i64)

let make_h = fn () -> H do return H(n: 1) end

let consume_h = fn (h: %H) -> unit do
  match h do | H(n: _) -> return () end
end

let inner = fn () -> i64 throws { E1, E3 } do throw E3 end

let wrapper = fn () -> unit throws { E3 } do
  let %h = make_h()
  try
    let _x = inner()
    consume_h(h: %h)
  catch
  | E1 ->
      consume_h(h: %h)
  end
end

let main = fn () -> unit do
  try wrapper() catch | E3 -> () end
end
