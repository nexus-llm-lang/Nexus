// expect-fail: E2009
// expect-msg: match arms diverge on outer-linear consumption
//
// nexus-c3lk0 (T-TryCatch ρ_residual escape — survivor variant): the try-body
// has a normal-completion (success) path AND a non-empty residual. Both the
// success tail and the catch arm consume `%h` — yet the uncaught-throw escape
// path still drops `%h`.
//
// `inner()` throws { E1, E3 }; the catch arm catches only E1, so E3 forms
// ρ_residual ≠ ∅. On the E3 path control leaves `try` (and `wrapper`) after
// `inner()` throws — BEFORE `consume_h(%h)` on the success tail — without
// running the catch arm. `%h`, never consumed before that throw point, leaks.
//
// Since nexus-7hbia, the selective-`catch` desugar appends a synthetic residual
// re-throw arm `| __exn_v -> throw __exn_v` (so unmatched variants propagate at
// runtime instead of mis-dispatching). That arm is the literal E3 escape path
// and does NOT consume `%h`, while the `E1` arm does — so the linear-arm-
// agreement check rejects the leak directly (E2009: match arms diverge on
// outer-linear consumption). Same leak the c3lk0 residual-escape clause caught,
// now surfaced via the explicit synthetic escape arm.

exception E1
exception E3

type H = H(n: i64)

let make_h = fn () -> H do return H(n: 1) end

let consume_h = fn (h: %H) -> unit do
  match h do | H(n: _) -> return () end
end

let inner = fn () -> i64 throws { E1, E3 } do throw E3 end

let wrapper = fn () -> unit throws { E3 } do
  let %h = make_h()
  try
    let _x = inner()
    consume_h(h: %h)
  catch
  | E1 ->
      consume_h(h: %h)
  end
end

let main = fn () -> unit do
  try wrapper() catch | E3 -> () end
end
