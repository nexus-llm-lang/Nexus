// expect-fail: E2023
// expect-msg: linear
// expect-msg: ref
//
// wfRef on D-Cap method parameter types (spec §wfRef table, D-Cap):
// a cap method may not declare a parameter of type ref(%T) because each
// deref would produce a fresh copy of the linear payload, duplicating the
// resource (wfRef(~σ) ⟺ ¬linear(σ)).
//
// Before the fix, walk_port_methods discarded typ_params and never called
// enforce_wf_ref_params, so ref(%T) parameters were silently accepted.
//
// Spec: docs/spec/type-system-formal.md §wfRef table (line 446), D-Cap.
// nexus-sfwm

type Box<T> = Box(val: T)

cap BadCap do
  fn store_ref(h: ref(%Box<i64>)) -> unit
end

let main = fn () -> unit do
  return ()
end
