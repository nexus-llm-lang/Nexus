// Parser regression for nexus-lqza: call and constructor arg lists did not
// accept a trailing comma, unlike list/record literals which do.
// `f(x: 1, y: 2,)` and `Pair(a: 1, b: 2,)` were parse errors.
// This test exercises trailing commas in both fn-call and ctor-arg positions.
import * as test_assert from "std:test/assert"

let add = fn (x: i64, y: i64) -> i64 do
  return x + y
end

type Pair = Pair(a: i64, b: i64)

let pair_sum = fn (p: Pair) -> i64 do
  match p do
    | Pair(a: av, b: bv) -> return av + bv
  end
end

let body = fn () -> unit throws { Exn } do
  // Trailing comma in function call args
  let r1 = add(x: 10, y: 20,)
  test_assert.assert_eq_i64(actual: r1, expected: 30, label: "trailing comma in fn call")

  // Trailing comma in constructor args
  let p = Pair(a: 3, b: 4,)
  let r2 = pair_sum(p)
  test_assert.assert_eq_i64(actual: r2, expected: 7, label: "trailing comma in ctor args")

  // Single-arg trailing comma
  let r3 = add(x: 5, y: 6,)
  test_assert.assert_eq_i64(actual: r3, expected: 11, label: "single-arg trailing comma (y position)")

  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit throws { Exn } do
  let ok = safe_run()
  if ok == 0 then throw RuntimeError(val: "call_trailing_comma: body threw unexpectedly") end
  return ()
end
