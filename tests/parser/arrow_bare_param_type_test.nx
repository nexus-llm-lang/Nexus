// Parser regression: a function-type annotation may use a BARE (unlabelled)
// param type, e.g. `(i64) -> i64` or `(i64, string) -> bool`, per the grammar
// `arrow_param ::= IDENT ":" type | type` (syntax.md). Previously `is_arrow_start`
// assumed arrow params are always labelled (`name: Type`), so a bare param type
// failed to parse with `expected ), got '->' [E1001]`.
//
// The disambiguator between a parenthesised type `(T)` and an arrow param list
// `(T) -> R` is the `->` that follows the matching `)`. Bare params get a
// synthesised positional name (`_p0`, `_p1`, ...); arrow types unify
// positionally, so passing a differently-labelled function still works.
import * as test_assert from "std:test/assert"

// Bare single-param function type.
let apply = fn (f: (i64) -> i64, val: i64) -> i64 do
  return f(_p0: val)
end

// A normal labelled function passed into the bare-typed slot — unifies
// positionally despite the differing param label (`x` vs synthesised `_p0`).
let dbl = fn (x: i64) -> i64 do return x * 2 end

// Bare multi-param function type.
let pick = fn (g: (i64, string) -> bool, n: i64, s: string) -> bool do
  return g(_p0: n, _p1: s)
end

let positive = fn (a: i64, b: string) -> bool do return a > 0 end

// Mixed: one labelled, one bare param in the same arrow type.
let mixed = fn (h: (x: i64, bool) -> i64) -> i64 do
  return h(x: 40, _p1: true)
end

let combine = fn (x: i64, flag: bool) -> i64 do
  if flag then return x + 2 else return x end
end

// Controls that must keep working.
let labelled = fn (f: (x: i64) -> i64) -> i64 do return f(x: 21) end
let nullary = fn (f: () -> i64) -> i64 do return f() end
let seven = fn () -> i64 do return 7 end
let paren_ty = fn (n: (i64)) -> i64 do return n + 1 end

let body = fn () -> unit throws { Exn } do
  test_assert.assert_eq_i64(actual: apply(f: dbl, val: 21), expected: 42, label: "bare 1-arg arrow param")
  test_assert.assert(cond: pick(g: positive, n: 5, s: "hi"), label: "bare 2-arg arrow param")
  test_assert.assert_eq_i64(actual: mixed(h: combine), expected: 42, label: "mixed labelled+bare arrow param")
  test_assert.assert_eq_i64(actual: labelled(f: dbl), expected: 42, label: "labelled arrow param control")
  test_assert.assert_eq_i64(actual: nullary(f: seven), expected: 7, label: "nullary arrow param control")
  test_assert.assert_eq_i64(actual: (paren_ty(n: 5)), expected: 6, label: "parenthesised type + paren expr control")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
