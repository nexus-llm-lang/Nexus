// Parser regression for nexus-qjti: parse_inject_handlers built its
// accumulator in reverse (prepend-only, no final list.reverse), so
// `inject h1, h2, h3 do` would bind h3 → Cap1, h2 → Cap2, h1 → Cap3.
//
// This test defines three caps with distinct return values (1, 2, 3)
// and injects handlers in source order hA, hB, hC.  If the handler
// list is reversed, Cap1.val() returns 3 and the assert fails.
import * as test_assert from "std:test/assert"

cap Cap1 do fn val() -> i64 end
cap Cap2 do fn val() -> i64 end
cap Cap3 do fn val() -> i64 end

let hA = handler Cap1 do fn val() -> i64 do return 1 end end
let hB = handler Cap2 do fn val() -> i64 do return 2 end end
let hC = handler Cap3 do fn val() -> i64 do return 3 end end

let body = fn () -> unit throws { Exn } do
  inject hA, hB, hC do
    test_assert.assert_eq_i64(actual: Cap1.val(), expected: 1, label: "Cap1 handler is hA (first in source)")
    test_assert.assert_eq_i64(actual: Cap2.val(), expected: 2, label: "Cap2 handler is hB (second in source)")
    test_assert.assert_eq_i64(actual: Cap3.val(), expected: 3, label: "Cap3 handler is hC (third in source)")
  end
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit throws { Exn } do
  let ok = safe_run()
  if ok == 0 then throw RuntimeError(val: "inject_handler_order: body threw unexpectedly") end
  return ()
end
