/**
 * Parser regression: a bare chained call `f(...)()` is parsed as a further
 * application of the result, producing `ExprCallExpr(callee: f(...), args)`.
 *
 * Before this fix the atom parsers consumed exactly ONE argument list, and the
 * postfix loop handled only `.field` / `[idx]` — so `make(41)()` parsed as the
 * call `make(41)` followed by a SEPARATE bystander unit-literal statement `()`,
 * silently dropping the second application from the chain. (`(make(41))()` with
 * explicit parens was handled, but the bare form was not.)
 *
 * The lexer emits no statement-terminator token, so `f(x)()` and `f(x)\n()`
 * are the same token stream. The fix therefore chains a trailing `()` / `(args)`
 * suffix ONLY when it is span-adjacent — directly abutting the previous `)`
 * with no intervening whitespace or newline, and iterates so deeper chains
 * (`f()()`) nest. A bare `()` on a separate line (or
 * after a space) stays a distinct no-op unit statement, which is idiomatic at
 * the tail of a block. The negative half of this test guards that property so a
 * future change cannot regress the adjacency gate back into swallowing a bare
 * `()` no-op statement that follows a `let x = call(...)`.
 */
import * as test_assert from "std:test/assert"

// Outer call has a real argument so the returned closure type is preserved.
let make = fn (base: i64) -> (() -> i64) do
  return fn () -> i64 do return base + 1 end
end

let main = fn () -> unit throws { Exn } do
  // Positive: adjacent bare chained call applies the returned closure.
  let r = make(base: 41)()
  test_assert.assert_eq_i64(
    actual: r,
    expected: 42,
    label: "adjacent bare chained call make(41)() == 42"
  )

  // Negative guard: a bare `()` on a SEPARATE line after `let x = call(...)`
  // must remain a no-op unit statement, NOT be swallowed into a chained call.
  // `f` therefore stays the returned closure; the bare `()` is a no-op; and
  // `f()` below applies it. (If the adjacency gate regressed, the bare `()`
  // would chain onto `make(base: 40)` and either drop the binding or mis-apply.)
  let f = make(base: 40)
  ()
  let r2 = f()
  test_assert.assert_eq_i64(
    actual: r2,
    expected: 41,
    label: "bare () after call on separate line stays a no-op statement"
  )

  return ()
end
