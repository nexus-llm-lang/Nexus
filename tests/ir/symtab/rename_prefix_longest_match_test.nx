// Issue nexus-byiw subset: unit-test `src/ir/symtab.nx::rename`
// (dotted-prefix path via `find_best_dot`).
//
// When the full name is not in the rename table, the resolver tries to
// rewrite a dotted prefix and keep the suffix literal. This case covers
// module-qualified access like `M.f` where `M` is the only rename-table
// entry. The scanner takes the LONGEST matching prefix on `.` — a
// regression that took the FIRST matching prefix would silently
// mis-resolve nested module paths.
//
// Edge cases pinned:
//   1. Single-level prefix: `"M.x"` where only `M` is renamed → returns
//      `qual(M) ++ "." ++ "x"`.
//   2. Longest-prefix-wins: name `"A.B.C"` where BOTH `A` and `A.B` are
//      in the table → resolves through `A.B` (longer prefix wins), not
//      through `A`.
//   3. No prefix hits → name returned unchanged (suffix-only access on
//      a non-renamed module passes through).
import * as test_assert from "std:test/assert"
import { RenameEntry }, * as symtab from "src/ir/symtab.nx"

let body = fn () -> unit throws { Exn } do
  // ── case 1: simple prefix ──
  // entries: M -> std:foo
  let e1 = symtab.rename_add(entries: [], original: "M", qualified: "std:foo")
  let r1 = symtab.rename(name: "M.x", entries: e1)
  test_assert.assert_eq_string(actual: r1, expected: "std:foo.x",
    label: "rename: simple prefix M.x → qual(M).x")

  // ── case 2: longest prefix wins ──
  // entries: A -> QA, A.B -> QAB (added later, head-of-list)
  // `find_best_dot` scans left-to-right and KEEPS UPDATING best whenever
  // a longer prefix matches — so dot at i=3 (between B and C) wins over
  // dot at i=1.
  let e2a = symtab.rename_add(entries: [], original: "A", qualified: "QA")
  let e2 = symtab.rename_add(entries: e2a, original: "A.B", qualified: "QAB")
  let r2 = symtab.rename(name: "A.B.C", entries: e2)
  test_assert.assert_eq_string(actual: r2, expected: "QAB.C",
    label: "rename: longest prefix wins (A.B beats A in A.B.C)")

  // ── case 3: dotted name, no prefix match → passthrough ──
  // `Foo.bar` with only `Baz` in the table must come back unchanged.
  let e3 = symtab.rename_add(entries: [], original: "Baz", qualified: "std:baz")
  let r3 = symtab.rename(name: "Foo.bar", entries: e3)
  test_assert.assert_eq_string(actual: r3, expected: "Foo.bar",
    label: "rename: dotted name with no prefix hit → passthrough")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
