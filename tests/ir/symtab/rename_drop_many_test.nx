// Issue nexus-byiw subset: unit-test `src/ir/symtab.nx::rename_drop_many`
// — folds `rename_drop` over a list of names. Used by the resolver when
// a single binding form introduces multiple identifiers at once (e.g.
// fn with several parameters, destructuring `let`) and every one of
// them must lexically shadow any toplevel rename.
//
// Edge cases pinned:
//   1. Empty names list → entries pass through unchanged.
//   2. Multiple names, mixed presence: some in the table, some not —
//      every listed name MUST be absent post-drop, and the originally-
//      unmatched names must not cause failure.
//   3. Non-listed entries survive (the orthogonality property — drop
//      affects only what you ask it to drop).
import * as test_assert from "std:test/assert"
import { RenameEntry }, * as symtab from "src/ir/shared/symtab.nx"

let body = fn () -> unit throws { Exn } do
  // Build a table: a, b, c, d (d is the survivor).
  let e1 = symtab.rename_add(entries: [], original: "a", qualified: "QA")
  let e2 = symtab.rename_add(entries: e1, original: "b", qualified: "QB")
  let e3 = symtab.rename_add(entries: e2, original: "c", qualified: "QC")
  let e4 = symtab.rename_add(entries: e3, original: "d", qualified: "QD")

  // ── case 1: empty names list → no-op ──
  let r_noop = symtab.rename_drop_many(entries: e4, names: [])
  test_assert.assert_true(cond: symtab.rename_has(name: "a", entries: r_noop),
    label: "rename_drop_many: empty names list keeps `a`")
  test_assert.assert_true(cond: symtab.rename_has(name: "d", entries: r_noop),
    label: "rename_drop_many: empty names list keeps `d`")

  // ── case 2: drop {a, c, NOTFOUND} — mixed presence ──
  // NOTFOUND is not in the table; rename_drop_many must tolerate it
  // (no crash) and proceed.
  let dropped = symtab.rename_drop_many(entries: e4, names: [ "a", "c", "NOTFOUND" ])
  test_assert.assert_false(cond: symtab.rename_has(name: "a", entries: dropped),
    label: "rename_drop_many: `a` dropped")
  test_assert.assert_false(cond: symtab.rename_has(name: "c", entries: dropped),
    label: "rename_drop_many: `c` dropped")
  test_assert.assert_false(cond: symtab.rename_has(name: "NOTFOUND", entries: dropped),
    label: "rename_drop_many: unknown name does not (re)appear")

  // ── case 3: untouched entries survive ──
  test_assert.assert_true(cond: symtab.rename_has(name: "b", entries: dropped),
    label: "rename_drop_many: untouched `b` survives")
  test_assert.assert_true(cond: symtab.rename_has(name: "d", entries: dropped),
    label: "rename_drop_many: untouched `d` survives")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
