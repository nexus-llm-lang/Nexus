// Issue nexus-byiw subset: unit-test `src/ir/symtab.nx::rename_drop` —
// removes every entry whose `original` matches the dropped name. Used
// by the resolver to implement lexical shadowing: when a fn parameter
// or `let` introduces an identifier, every toplevel-scope rename for
// that name must be hidden inside the binding's scope so the
// identifier resolves to the local raw name.
//
// Edge cases pinned:
//   1. Drop on empty list → empty (no crash on degenerate input).
//   2. Drop removes ALL entries with matching `original`, not just the
//      first one. A regression that broke after the first match (e.g.
//      switched to early-return) would leave a stale duplicate in place
//      and resurrect the shadowed binding when an alpha-renamed scope
//      re-encountered the name.
//   3. Drop preserves non-matching entries — `rename_has` for an
//      untouched name must still hold after a drop on a different name.
//   4. Post-drop, `rename` of the dropped name passes through (no
//      qualified form leaks).
import * as test_assert from "std:test/assert"
import { RenameEntry }, * as symtab from "src/ir/symtab.nx"

let body = fn () -> unit throws { Exn } do
  // ── case 1: drop on empty ──
  let e_empty = symtab.rename_drop(entries: [], name: "x")
  test_assert.assert_false(cond: symtab.rename_has(name: "x", entries: e_empty),
    label: "rename_drop: empty in, empty out")

  // ── case 2: drop removes ALL duplicates for `x` ──
  // Add three entries for "x" plus a survivor "y".
  let e1 = symtab.rename_add(entries: [], original: "x", qualified: "Q1")
  let e2 = symtab.rename_add(entries: e1, original: "y", qualified: "QY")
  let e3 = symtab.rename_add(entries: e2, original: "x", qualified: "Q2")
  let e4 = symtab.rename_add(entries: e3, original: "x", qualified: "Q3")
  // Sanity: `x` is present pre-drop.
  test_assert.assert_true(cond: symtab.rename_has(name: "x", entries: e4),
    label: "rename_has: x present before drop")
  let dropped = symtab.rename_drop(entries: e4, name: "x")
  test_assert.assert_false(cond: symtab.rename_has(name: "x", entries: dropped),
    label: "rename_drop: removes ALL entries with matching original")

  // ── case 3: non-matching entries survive ──
  test_assert.assert_true(cond: symtab.rename_has(name: "y", entries: dropped),
    label: "rename_drop: untouched original `y` still present")

  // ── case 4: rename(x) passes through after drop ──
  let r = symtab.rename(name: "x", entries: dropped)
  test_assert.assert_eq_string(actual: r, expected: "x",
    label: "rename: dropped name → passthrough (no stale qual)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
