// Issue nexus-byiw subset: unit-test `src/ir/symtab.nx::rename` (direct
// path) — the core rewrite used by import resolution to turn raw
// identifiers into their qualified canonical form.
//
// Edge cases pinned:
//   1. Empty entry list → return name unchanged (resolver invariant: a
//      bare identifier with no rename table entries must pass through
//      so typecheck/codegen can interpret it as local/builtin/keyword).
//   2. Direct hit (no dot in name) → return qualified value.
//   3. Miss with no dotted prefix → return name unchanged (the
//      "passthrough is load-bearing" invariant called out in the
//      module comment: builtin types like `i64` must not raise here).
//   4. LIFO precedence: `rename_add` cons-prepends, so an entry added
//      LATER for the same `original` MUST win over an earlier one.
//      `rename_direct` walks head-first and returns on the first match.
//      A regression that recursed past the head would break shadowing.
import * as test_assert from "std:test/assert"
import { RenameEntry }, * as symtab from "src/ir/symtab.nx"

let body = fn () -> unit throws { Exn } do
  // ── case 1: empty table ──
  let r0 = symtab.rename(name: "foo", entries: [])
  test_assert.assert_eq_string(actual: r0, expected: "foo",
    label: "rename: empty table → passthrough")

  // ── case 2: direct hit ──
  let e1 = symtab.rename_add(entries: [], original: "List", qualified: "std:list.List")
  let r1 = symtab.rename(name: "List", entries: e1)
  test_assert.assert_eq_string(actual: r1, expected: "std:list.List",
    label: "rename: direct hit returns qualified form")

  // ── case 3: no-dot miss → passthrough ──
  let r2 = symtab.rename(name: "i64", entries: e1)
  test_assert.assert_eq_string(actual: r2, expected: "i64",
    label: "rename: builtin-like name not in table → passthrough")

  // ── case 4: LIFO precedence (later add wins) ──
  // Push two entries for the same original `foo`; the most-recently-added
  // qualified `B` must be returned.
  let e2 = symtab.rename_add(entries: [], original: "foo", qualified: "A")
  let e3 = symtab.rename_add(entries: e2, original: "foo", qualified: "B")
  let r3 = symtab.rename(name: "foo", entries: e3)
  test_assert.assert_eq_string(actual: r3, expected: "B",
    label: "rename: head-of-list entry wins (LIFO shadow)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
