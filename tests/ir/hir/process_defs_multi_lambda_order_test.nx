// Issue nexus-byiw subset: unit-test `process_defs` across MULTIPLE
// top-level lambdas — the recursive cons-prepend pattern in the
// non-empty branch.
//
// `process_defs` walks the input source-order list and threads the
// accumulator through every call. Each TLLet(lambda) cons-prepends a
// HirFunction onto `accum.functions`, so the final list is in
// REVERSE source order (head = last def). This is load-bearing: the
// downstream MIR/codegen lowers function tables in the order they
// appear in `functions`, and the LSP relies on the cons-prepend
// invariant to keep "most recently seen" defs at the head for
// duplicate-shadow detection (DuplicateTopLevelBinding).
//
// Edge cases pinned:
//   1. N input defs produce N functions in the accumulator.
//   2. Reverse-of-source order: head of the result = last input def.
//   3. Each function carries the right name (no cross-contamination).
//   4. value_binding_names is NOT extended for lambdas (each lambda
//      preserves the tt5a "lambda case" invariant).
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import { process_defs } from "src/ir/hir/build/defs.nx"
import { empty_accum } from "src/ir/hir/build/accum.nx"
import { HirAccum, HirFunction } from "src/ir/hir/types.nx"
import { SpannedTopLevel, SpannedExpr, SpannedStmt, TLLet, GlobalLet, ExprLambda, ExprLiteral, StmtReturn, LitInt, TyI64, TyRow } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"

// Build `let <name> = fn () -> i64 do return <ret> end`.
let make_let = fn (name: string, ret: i64, sp: Span) -> SpannedTopLevel do
  let empty_row = TyRow(types: [], rest: None)
  let ret_stmt = SpannedStmt(node: StmtReturn(value: SpannedExpr(node: ExprLiteral(lit: LitInt(val: ret)), span: sp)), span: sp)
  let lam = ExprLambda(type_params: [], params: [], ret_type: TyI64, requires: empty_row, throw_row: empty_row, body: [ ret_stmt ])
  return SpannedTopLevel(
    node: TLLet(def: GlobalLet(name, is_public: false, typ: None, value: SpannedExpr(node: lam, span: sp))),
    span: sp)
end

let body = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)
  let defs = [ make_let(name: "first", ret: 1, sp),
              make_let(name: "second", ret: 2, sp),
              make_let(name: "third", ret: 3, sp) ]

  let out = process_defs(defs, entries: [], accum: empty_accum(), source_file: "user_code.nx", is_defining: 1)
  let HirAccum(caps: _, functions: fs, externals: _, handler_bindings: _, enum_defs: _, wasm_module: _, exception_groups: _, value_binding_names: vbns, type_defs: _) = out

  test_assert.assert_eq_i64(actual: list.length(xs: fs), expected: 3, label: "process_defs multi: 3 lambdas → 3 functions")

  // Head = last input ("third"); tail-of-2 head = "second"; tail-of-3 = "first".
  match fs do
    | HirFunction(name: n0, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span: _, file: _)
        :: HirFunction(name: n1, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span: _, file: _)
        :: HirFunction(name: n2, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span: _, file: _)
        :: _ ->
      test_assert.assert_eq_string(actual: n0, expected: "third", label: "process_defs multi: head = last input (cons-prepend)")
      test_assert.assert_eq_string(actual: n1, expected: "second", label: "process_defs multi: mid = second input")
      test_assert.assert_eq_string(actual: n2, expected: "first", label: "process_defs multi: tail = first input")
    | _ ->
      test_assert.assert_true(cond: false, label: "process_defs multi: functions list shape unexpected")
  end

  // tt5a invariant: every let was a lambda → vbns stays empty.
  test_assert.assert_eq_i64(actual: list.length(xs: vbns), expected: 0, label: "process_defs multi: pure-lambda lets do not touch value_binding_names")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
