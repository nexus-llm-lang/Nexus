// Issue nexus-byiw subset: unit-test the TLException branch of
// `src/ir/hir/hir.nx::process_top_level`, which appends a variant to
// the pre-seeded `Exn` enum via `register_exn_variant`.
//
// A source `exception MyExn(field: i64)` parses as
// `TLException(def: ExceptionDef(name, fields))`. HIR lowering must:
//   1. Find the `Exn` enum in `accum.enum_defs` (seeded by
//      `empty_accum`) and prepend a new VariantDef to its variants
//      list — the count grows by exactly one.
//   2. Leave every other field of `Exn` untouched (is_public, name,
//      type_params).
//   3. Not touch any sibling collection (functions, caps, externals,
//      handler_bindings, exception_groups, type_defs,
//      value_binding_names).
//
// Edge cases pinned:
//   - The Exn variant list grows from 2 (seeded RuntimeError +
//     InvalidIndex) to 3, with the new variant at the HEAD.
//   - The new variant's name matches the source `exception` name.
//   - The enum_defs list itself does NOT grow — a regression that
//     prepended a NEW EnumDef instead of mutating the existing Exn
//     would break stdlib/exn.nx's `to_string` (which matches on Exn
//     variants directly).
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import { process_defs } from "src/ir/hir/build/defs.nx"
import { empty_accum } from "src/ir/hir/build/accum.nx"
import { HirAccum } from "src/ir/hir/types.nx"
import {
  SpannedTopLevel,
  TLException,
  ExceptionDef,
  EnumDef,
  VariantDef,
  VariantField,
  TyI64
} from "src/common/ast.nx"
import { Span } from "src/common/token.nx"

let body = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)
  // `exception MyExn(field: i64)` shape.
  let exn_def = ExceptionDef(
    name: "MyExn",
    is_public: true,
    fields: [ VariantField(name: Some(val: "field"), typ: TyI64) ])

  let out = process_defs(
    defs: [ SpannedTopLevel(node: TLException(def: exn_def), span: sp) ],
    entries: [], accum: empty_accum(), source_file: "<test>", is_defining: 1)
  let HirAccum(
    caps: ps,
    functions: fs,
    externals: exts,
    handler_bindings: hbs,
    enum_defs: eds,
    wasm_module: _,
    exception_groups: egs,
    value_binding_names: vbns,
    type_defs: tds
  ) = out

  // enum_defs LENGTH unchanged: still exactly one (Exn).
  test_assert.assert_eq_i64(
    actual: list.length(xs: eds),
    expected: 1,
    label: "TLException: enum_defs len unchanged (no new EnumDef)"
  )

  match eds do
    | EnumDef(name: en, is_public: pub_, is_opaque: _, type_params: _, variants: vs) :: _ ->
      test_assert.assert_eq_string(
        actual: en,
        expected: "Exn",
        label: "TLException: Exn enum identity preserved"
      )
      test_assert.assert_true(cond: pub_, label: "TLException: Exn is_public preserved")
      // Variants: seeded [RuntimeError, InvalidIndex] grows by ONE,
      // with the new variant CONS-prepended at the head.
      test_assert.assert_eq_i64(
        actual: list.length(xs: vs),
        expected: 3,
        label: "TLException: Exn variants 2 → 3"
      )
      match vs do
        | VariantDef(name: head_v, fields: _) :: _ ->
          test_assert.assert_eq_string(
            actual: head_v,
            expected: "MyExn",
            label: "TLException: new variant prepended at head"
          )
        | _ ->
          test_assert.assert_true(cond: false, label: "TLException: variants list shape unexpected")
      end
    | _ ->
      test_assert.assert_true(cond: false, label: "TLException: enum_defs missing Exn")
  end

  // Siblings untouched.
  test_assert.assert_eq_i64(
    actual: list.length(xs: ps),
    expected: 0,
    label: "TLException: caps untouched"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: fs),
    expected: 0,
    label: "TLException: functions untouched"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: exts),
    expected: 0,
    label: "TLException: externals untouched"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: hbs),
    expected: 0,
    label: "TLException: handler_bindings untouched"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: egs),
    expected: 0,
    label: "TLException: exception_groups untouched"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: vbns),
    expected: 0,
    label: "TLException: value_binding_names untouched"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: tds),
    expected: 0,
    label: "TLException: type_defs untouched"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
