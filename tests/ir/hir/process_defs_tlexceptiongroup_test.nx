// Issue nexus-byiw subset: unit-test the TLExceptionGroup branch of
// `src/ir/hir/hir.nx::process_top_level`.
//
// `exception group IOError = NotFound | PermDenied` parses as a
// `TLExceptionGroup(def: ExceptionGroupDef(name, members))`. HIR
// lowering must cons-prepend an `ExceptionGroupEntry { name, members }`
// onto `accum.exception_groups`. This list is later consumed by
// `expand_groups_in_functions` / `expand_groups_in_handler_bindings`
// inside `accum_to_program`, which replaces a group constructor
// pattern in any catch arm with one PCtor per member.
//
// Edge cases pinned:
//   1. exception_groups grows by exactly one (cons head = the new
//      group entry, name + members copied verbatim).
//   2. The members list preserves source order — a regression that
//      reversed it would silently scramble downstream pattern
//      expansion order.
//   3. enum_defs is NOT touched (groups are virtual: members must
//      still resolve via Exn variants registered via TLException).
//   4. Sibling collections (functions / ports / externals /
//      handler_bindings / type_defs / value_binding_names) are
//      unchanged.
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import * as hir from "src/ir/hir/hir.nx"
import { HirAccum, ExceptionGroupEntry } from "src/ir/hir/types.nx"
import { SpannedTopLevel, TLExceptionGroup, ExceptionGroupDef } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"

let body = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)
  let group_def = ExceptionGroupDef(
    name: "IOError",
    is_public: true,
    members: ["NotFound", "PermDenied"])

  let out = hir.process_defs(
    defs: [SpannedTopLevel(node: TLExceptionGroup(def: group_def), span: sp)],
    entries: [], accum: hir.empty_accum(), source_file: "<test>")
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: _, exception_groups: egs, value_binding_names: vbns, type_defs: tds) = out

  // ── case 1: exception_groups += 1 ──
  test_assert.assert_eq_i64(actual: list.length(xs: egs), expected: 1, label: "TLExceptionGroup: exception_groups grew by one")
  match egs do
    | ExceptionGroupEntry(name: gn, members: ms) :: _ ->
      test_assert.assert_eq_string(actual: gn, expected: "IOError", label: "TLExceptionGroup: group name = IOError")
      // ── case 2: member order preserved ──
      test_assert.assert_eq_i64(actual: list.length(xs: ms), expected: 2, label: "TLExceptionGroup: 2 members")
      match ms do
        | m0 :: m1 :: _ ->
          test_assert.assert_eq_string(actual: m0, expected: "NotFound", label: "TLExceptionGroup: member 0 = NotFound (source order)")
          test_assert.assert_eq_string(actual: m1, expected: "PermDenied", label: "TLExceptionGroup: member 1 = PermDenied (source order)")
        | _ ->
          test_assert.assert_true(cond: false, label: "TLExceptionGroup: members list shape unexpected")
      end
    | _ ->
      test_assert.assert_true(cond: false, label: "TLExceptionGroup: exception_groups missing head")
  end

  // ── case 3: enum_defs not perturbed (still just seeded Exn) ──
  test_assert.assert_eq_i64(actual: list.length(xs: eds), expected: 1, label: "TLExceptionGroup: enum_defs untouched (groups are virtual)")

  // ── case 4: every other sibling collection untouched ──
  test_assert.assert_eq_i64(actual: list.length(xs: ps), expected: 0, label: "TLExceptionGroup: ports untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: fs), expected: 0, label: "TLExceptionGroup: functions untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: exts), expected: 0, label: "TLExceptionGroup: externals untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: hbs), expected: 0, label: "TLExceptionGroup: handler_bindings untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: vbns), expected: 0, label: "TLExceptionGroup: value_binding_names untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: tds), expected: 0, label: "TLExceptionGroup: type_defs untouched")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
