// Issue nexus-byiw subset: unit-test the TLEnum branch of
// `src/ir/hir/hir.nx::process_top_level` (reached via `process_defs`).
//
// Walking the source file `type Color = Red | Green | Blue` produces a
// `SpannedTopLevel(TLEnum(def: EnumDef(...)))`. The HIR pass cons-
// prepends the user enum onto `accum.enum_defs`, so the resulting list
// is `[user_enum, ...previously_seeded]`. Since `empty_accum` seeds the
// list with `[Exn]`, after one `TLEnum` the list head must be the user
// enum and the second element must be `Exn`.
//
// Edge cases pinned:
//   1. enum_defs grows by exactly one entry per TLEnum (no accidental
//      dedup or replace path).
//   2. The new entry sits at the HEAD (cons-prepend order), not the tail.
//   3. The Exn seed is preserved (the user enum does not clobber it).
//   4. Sibling collections (functions/externals/handler_bindings/ports/
//      type_defs/value_binding_names) are NOT touched by a TLEnum decl.
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import { process_defs } from "src/ir/hir/build/defs.nx"
import { empty_accum } from "src/ir/hir/build/accum.nx"
import { HirAccum } from "src/ir/hir/types.nx"
import { SpannedTopLevel, TLEnum, EnumDef, VariantDef } from "src/syntax/ast.nx"
import { Span } from "src/types/span.nx"

let body = fn () -> unit throws { Exn } do
  let zero_span = Span(offset: 0, line: 1, col: 1)
  let color = EnumDef(
    name: "Color",
    is_public: true,
    is_opaque: false,
    type_params: [],
    variants: [
      VariantDef(name: "Red", fields: []),
      VariantDef(name: "Green", fields: []),
      VariantDef(name: "Blue", fields: []) ],
    layout_variants: [], module: "")

  let defs = [ SpannedTopLevel(node: TLEnum(def: color), span: zero_span) ]
  let out = process_defs(
    defs,
    entries: [],
    accum: empty_accum(),
    source_file: "<test>",
    is_defining: 1
  )
  let HirAccum(
    caps: ps,
    functions: fs,
    externals: exts,
    handler_bindings: hbs,
    enum_defs: eds,
    wasm_module: _,
    exception_groups: _,
    value_binding_names: vbns,
    type_defs: tds
  ) = out

  // ── case 1: exactly one growth ──
  test_assert.assert_eq_i64(
    actual: list.length(xs: eds),
    expected: 2,
    label: "TLEnum: enum_defs = [user, Exn]"
  )

  // ── case 2/3: head is user enum, tail is Exn ──
  match eds do
    | EnumDef(
      name: n0,
      is_public: _,
      is_opaque: _,
      type_params: _,
      variants: vs0
    ) :: EnumDef(name: n1, is_public: _, is_opaque: _, type_params: _, variants: _) :: _ ->
      test_assert.assert_eq_string(
        actual: n0,
        expected: "Color",
        label: "TLEnum: user enum prepended (head)"
      )
      test_assert.assert_eq_string(
        actual: n1,
        expected: "Exn",
        label: "TLEnum: seeded Exn enum preserved (tail)"
      )
      test_assert.assert_eq_i64(
        actual: list.length(xs: vs0),
        expected: 3,
        label: "TLEnum: Color has 3 variants"
      )
    | _ ->
      test_assert.assert_true(cond: false, label: "TLEnum: enum_defs unexpected shape")
  end

  // ── case 4: sibling collections untouched ──
  test_assert.assert_eq_i64(
    actual: list.length(xs: ps),
    expected: 0,
    label: "TLEnum: ports untouched"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: fs),
    expected: 0,
    label: "TLEnum: functions untouched"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: exts),
    expected: 0,
    label: "TLEnum: externals untouched"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: hbs),
    expected: 0,
    label: "TLEnum: handler_bindings untouched"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: vbns),
    expected: 0,
    label: "TLEnum: value_binding_names untouched"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: tds),
    expected: 0,
    label: "TLEnum: type_defs untouched (TLEnum does not feed RecordDef)"
  )
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
