// Issue nexus-byiw subset: unit-test `src/ir/hir/hir.nx::empty_accum`.
//
// `empty_accum` is the seed used by every HIR build (driver.build_hir and
// the LSP diagnostics pipeline both start there before `process_defs`).
// It must produce a "clean slate" with the Exn enum pre-seeded with the
// built-in `RuntimeError` and `InvalidIndex` variants — without these,
// `register_exn_variant` could not append later user-defined exceptions
// onto `Exn` and `to_string`'s match-on-Exn arms in stdlib/exn.nx would
// hit unknown-ctor errors.
//
// Edge cases pinned:
//   1. Every collection field is empty EXCEPT enum_defs.
//   2. enum_defs is a single-element list whose sole entry is the Exn
//      enum with exactly two seeded variants: RuntimeError, InvalidIndex.
//   3. wasm_module is None — a fresh accumulator MUST NOT carry an
//      external-import-module sentinel from a previous build.
//   4. The Exn enum is is_public: true (so user code in other files can
//      `throw` its variants without re-importing).
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import { empty_accum } from "src/ir/hir/build/accum.nx"
import { HirAccum } from "src/ir/hir/types.nx"
import { EnumDef, VariantDef } from "src/common/ast.nx"

let body = fn () -> unit throws { Exn } do
  let HirAccum(
    caps: ps,
    functions: fs,
    externals: exts,
    handler_bindings: hbs,
    enum_defs: eds,
    wasm_module: wmod,
    exception_groups: egs,
    value_binding_names: vbns,
    type_defs: tds
  ) = empty_accum()

  // ── case 1: every list-shaped field is empty ──
  test_assert.assert_eq_i64(
    actual: list.length(xs: ps),
    expected: 0,
    label: "empty_accum: caps empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: fs),
    expected: 0,
    label: "empty_accum: functions empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: exts),
    expected: 0,
    label: "empty_accum: externals empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: hbs),
    expected: 0,
    label: "empty_accum: handler_bindings empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: egs),
    expected: 0,
    label: "empty_accum: exception_groups empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: vbns),
    expected: 0,
    label: "empty_accum: value_binding_names empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: tds),
    expected: 0,
    label: "empty_accum: type_defs empty"
  )

  // ── case 2/4: enum_defs holds Exn with the two seeded variants ──
  test_assert.assert_eq_i64(
    actual: list.length(xs: eds),
    expected: 1,
    label: "empty_accum: enum_defs holds exactly Exn"
  )
  match eds do
    | [] ->
      test_assert.assert_true(cond: false, label: "empty_accum: enum_defs unexpectedly empty")
    | EnumDef(name: en, is_public: pub_, is_opaque: opq, type_params: _, variants: vs) :: _ ->
      test_assert.assert_eq_string(
        actual: en,
        expected: "Exn",
        label: "empty_accum: seeded enum is Exn"
      )
      test_assert.assert_true(cond: pub_, label: "empty_accum: Exn is_public")
      test_assert.assert_false(cond: opq, label: "empty_accum: Exn not opaque")
      test_assert.assert_eq_i64(
        actual: list.length(xs: vs),
        expected: 2,
        label: "empty_accum: Exn has 2 seeded variants"
      )
      match vs do
        | VariantDef(name: v0, fields: _) :: VariantDef(name: v1, fields: _) :: _ ->
          // empty_accum cons-builds [RuntimeError, InvalidIndex]; reading
          // head-first the order is the literal list order.
          test_assert.assert_eq_string(
            actual: v0,
            expected: "RuntimeError",
            label: "empty_accum: variant 0 = RuntimeError"
          )
          test_assert.assert_eq_string(
            actual: v1,
            expected: "InvalidIndex",
            label: "empty_accum: variant 1 = InvalidIndex"
          )
        | _ ->
          test_assert.assert_true(
            cond: false,
            label: "empty_accum: Exn variants list shape unexpected"
          )
      end
  end

  // ── case 3: wasm_module is None ──
  match wmod do
    | None -> test_assert.assert_true(cond: true, label: "empty_accum: wasm_module is None")
    | Some(val: _) -> test_assert.assert_true(
      cond: false,
      label: "empty_accum: wasm_module unexpectedly Some"
    )
  end
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
