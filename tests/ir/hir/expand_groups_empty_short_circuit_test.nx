// Issue nexus-byiw subset: unit-test the empty-groups short-circuit
// of `src/ir/hir/hir.nx::expand_groups_in_functions` (and the matching
// `expand_groups_in_handler_bindings`).
//
// Both expand passes are wrapped in a `match groups do [] -> funcs ...`
// guard so that programs WITHOUT any `exception group` declarations skip
// the entire recursive rewrite (an O(N*M) tree walk over every
// function/handler body). This is load-bearing: stdlib + most user code
// has zero exception groups, and a regression that removed the
// short-circuit would silently inflate HIR build time without changing
// the observable HIR.
//
// Edge cases pinned:
//   1. `expand_groups_in_functions(funcs, groups: [])` returns the
//      input list IDENTICALLY (same length, function names preserved).
//   2. `expand_groups_in_handler_bindings(bindings, groups: [])`
//      similarly returns the input unchanged.
//   3. Both passes work even when the input list itself is empty.
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import * as hir from "src/ir/hir/hir.nx"
import { HirFunction, EagerBody, HirHandlerBindingEntry, HirHandlerBinding } from "src/ir/hir/types.nx"
import { TyUnit, TyRow } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"

let body = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)
  let empty_row = TyRow(types: [], rest: None)

  // Build two trivial functions with empty EagerBody.
  let f1 = HirFunction(name: "alpha", type_params: [], params: [], ret_type: TyUnit, throw_row: empty_row, body: EagerBody(stmts: []), span: sp, file: "<test>", requires: empty_row)
  let f2 = HirFunction(name: "beta", type_params: [], params: [], ret_type: TyUnit, throw_row: empty_row, body: EagerBody(stmts: []), span: sp, file: "<test>", requires: empty_row)

  // ── case 1: groups: [] → input returned unchanged ──
  let out_fns = hir.expand_groups_in_functions(funcs: [f1, f2], groups: [])
  test_assert.assert_eq_i64(actual: list.length(xs: out_fns), expected: 2, label: "expand_groups_in_functions []: length preserved")
  match out_fns do
    | HirFunction(name: n0, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span: _, file: _, requires: _) :: HirFunction(name: n1, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span: _, file: _, requires: _) :: _ ->
      test_assert.assert_eq_string(actual: n0, expected: "alpha", label: "expand_groups_in_functions []: order preserved (head)")
      test_assert.assert_eq_string(actual: n1, expected: "beta", label: "expand_groups_in_functions []: order preserved (next)")
    | _ ->
      test_assert.assert_true(cond: false, label: "expand_groups_in_functions []: output shape unexpected")
  end

  // ── case 2: handler bindings, empty groups → unchanged ──
  let hb = HirHandlerBindingEntry(name: "console_h", binding: HirHandlerBinding(port_name: "Console", arms: []))
  let out_hbs = hir.expand_groups_in_handler_bindings(bindings: [hb], groups: [])
  test_assert.assert_eq_i64(actual: list.length(xs: out_hbs), expected: 1, label: "expand_groups_in_handler_bindings []: length preserved")
  match out_hbs do
    | HirHandlerBindingEntry(name: bn, binding: _) :: _ ->
      test_assert.assert_eq_string(actual: bn, expected: "console_h", label: "expand_groups_in_handler_bindings []: binding name preserved")
    | _ ->
      test_assert.assert_true(cond: false, label: "expand_groups_in_handler_bindings []: shape unexpected")
  end

  // ── case 3: empty input list also degenerate-safe ──
  let out_empty = hir.expand_groups_in_functions(funcs: [], groups: [])
  test_assert.assert_eq_i64(actual: list.length(xs: out_empty), expected: 0, label: "expand_groups_in_functions: empty funcs, empty groups → empty")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
