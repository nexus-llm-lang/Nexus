// Issue nexus-byiw subset: unit-test the TLCap branch of
// `src/ir/hir/hir.nx::process_top_level` (reached via `process_defs`).
//
// A source `cap Console { fn write_line(s: string) -> unit }` parses as
// `TLCap(def: Cap(name: "Console", functions: [FunctionSig{name:"write_line", …}]))`.
// HIR lowering must:
//   1. Resolve the cap name through `symtab.rename` (so a qualified
//      module alias maps to the canonical name when entries are
//      present).
//   2. Convert every `FunctionSig` into a `HirPortMethod` carrying just
//      the method `name` — the rest of the signature is consumed by
//      typecheck, not by HIR.
//   3. Cons-prepend the result onto `accum.ports`, leaving
//      `functions / externals / handler_bindings / enum_defs / type_defs`
//      untouched.
//
// Edge cases pinned:
//   - ports grows by exactly one (cons head = the new port).
//   - The port's `methods` list mirrors the source-order names.
//   - Sibling collections are not perturbed.
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import * as hir from "src/ir/hir/hir.nx"
import { HirAccum, HirPort, HirPortMethod } from "src/ir/hir/types.nx"
import { SpannedTopLevel, TLCap, Cap, FunctionSig, TyUnit, TyString, TyRow } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"

let body = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)
  let empty_row = TyRow(types: [], rest: None)
  let sig_write = FunctionSig(name: "write_line", params: [], ret_type: TyUnit, requires: empty_row, throw_row: empty_row)
  let sig_read = FunctionSig(name: "read_line", params: [], ret_type: TyString, requires: empty_row, throw_row: empty_row)
  let cap_def = Cap(name: "Console", is_public: true, functions: [sig_write, sig_read])
  let defs = [SpannedTopLevel(node: TLCap(def: cap_def), span: sp)]

  let out = hir.process_defs(defs, entries: [], accum: hir.empty_accum(), source_file: "<test>", is_defining: 1)
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: _, exception_groups: _, value_binding_names: vbns, type_defs: tds) = out

  // ── ports head = Console with two methods in source order ──
  test_assert.assert_eq_i64(actual: list.length(xs: ps), expected: 1, label: "TLCap: ports list grows by one")
  match ps do
    | HirPort(name: pn, methods: ms) :: _ ->
      test_assert.assert_eq_string(actual: pn, expected: "Console", label: "TLCap: port name resolved to Console")
      test_assert.assert_eq_i64(actual: list.length(xs: ms), expected: 2, label: "TLCap: 2 methods carried over")
      match ms do
        | HirPortMethod(name: m0, requires: _, throw_row: _, span: _) :: HirPortMethod(name: m1, requires: _, throw_row: _, span: _) :: _ ->
          test_assert.assert_eq_string(actual: m0, expected: "write_line", label: "TLCap: method 0 = write_line")
          test_assert.assert_eq_string(actual: m1, expected: "read_line", label: "TLCap: method 1 = read_line")
        | _ ->
          test_assert.assert_true(cond: false, label: "TLCap: methods list shape unexpected")
      end
    | _ ->
      test_assert.assert_true(cond: false, label: "TLCap: ports list missing the new port")
  end

  // ── siblings untouched ──
  test_assert.assert_eq_i64(actual: list.length(xs: fs), expected: 0, label: "TLCap: functions untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: exts), expected: 0, label: "TLCap: externals untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: hbs), expected: 0, label: "TLCap: handler_bindings untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: eds), expected: 1, label: "TLCap: only seeded Exn in enum_defs")
  test_assert.assert_eq_i64(actual: list.length(xs: vbns), expected: 0, label: "TLCap: value_binding_names untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: tds), expected: 0, label: "TLCap: type_defs untouched")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
