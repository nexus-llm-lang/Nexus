// pattern_binders for PatOr must compute the INTERSECTION of binders across
// all alternatives, not the union.
//
// If two alternatives bind the same name the name appears in the intersection.
// If only one alternative binds a name it must NOT appear (it is in the union
// but not the intersection), so HIR shadowing does not incorrectly drop that
// name from the rename entries.
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import { pattern_binders } from "src/ir/hir/pattern.nx"
import { SpannedPattern, PatOr, PatVariable, PatWildcard, SigilImmutable } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"

let mk_var = fn (name: string) -> SpannedPattern do
  return SpannedPattern(
    node: PatVariable(name, sigil: SigilImmutable),
    span: Span(offset: 0, line: 1, col: 1))
end

let mk_wild = fn () -> SpannedPattern do
  return SpannedPattern(node: PatWildcard, span: Span(offset: 0, line: 1, col: 1))
end

let str_in = fn (xs: [ string ], s: string) -> bool do
  match xs do
    | [] -> return false
    | h :: rest ->
      if h == s then return true end
      return str_in(xs: rest, s)
  end
end

let body = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)

  // case 1: both alternatives bind the same name "v"; intersection = {"v"}
  let both_v = SpannedPattern(
    node: PatOr(alts: [ mk_var(name: "v"), mk_var(name: "v") ]),
    span: sp)
  let binders1 = pattern_binders(pat: both_v)
  test_assert.assert_eq_i64(actual: list.length(xs: binders1), expected: 1, label: "both alts bind v: length 1")
  test_assert.assert_true(cond: str_in(xs: binders1, s: "v"), label: "both alts bind v: contains v")

  // case 2: alternatives bind different names; union = {"x","y"}, intersection = {}
  let sp2 = Span(offset: 0, line: 2, col: 1)
  let xy = SpannedPattern(
    node: PatOr(alts: [ mk_var(name: "x"), mk_var(name: "y") ]),
    span: sp2)
  let binders2 = pattern_binders(pat: xy)
  test_assert.assert_eq_i64(actual: list.length(xs: binders2), expected: 0, label: "diff names: intersection empty")

  // case 3: single alternative; intersection = {"z"}
  let sp3 = Span(offset: 0, line: 3, col: 1)
  let single = SpannedPattern(
    node: PatOr(alts: [ mk_var(name: "z") ]),
    span: sp3)
  let binders3 = pattern_binders(pat: single)
  test_assert.assert_eq_i64(actual: list.length(xs: binders3), expected: 1, label: "single alt: length 1")
  test_assert.assert_true(cond: str_in(xs: binders3, s: "z"), label: "single alt: z present")

  // case 4: empty POr; intersection = {}
  let sp4 = Span(offset: 0, line: 4, col: 1)
  let empty_or = SpannedPattern(node: PatOr(alts: []), span: sp4)
  let binders4 = pattern_binders(pat: empty_or)
  test_assert.assert_eq_i64(actual: list.length(xs: binders4), expected: 0, label: "empty or: no binders")

  // case 5: wildcard in one alt; wildcard binds nothing so intersection = {}
  let sp5 = Span(offset: 0, line: 5, col: 1)
  let var_wild = SpannedPattern(
    node: PatOr(alts: [ mk_var(name: "x"), mk_wild() ]),
    span: sp5)
  let binders5 = pattern_binders(pat: var_wild)
  test_assert.assert_eq_i64(actual: list.length(xs: binders5), expected: 0, label: "var|wild: wildcard blocks intersection")

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
