// Issue nexus-byiw subset: unit-test
// `src/ir/hir/hir.nx::accum_to_program` on an `empty_accum()` input
// (with the `process_defs []` identity base case piped in front).
//
// `accum_to_program` is the assembler called by `driver.build_hir`
// (after `process_defs` and lazy resolution) and by the LSP pipeline.
// On a clean accumulator with no defs, it must:
//   1. Move every collection through unchanged.
//   2. Pass `enum_defs`, `value_binding_names`, and `type_defs` straight
//      through (no reachability filter, no dedup at this layer — the
//      driver runs reachability separately on a downstream pass).
//   3. Drop `wasm_module` (it is intentionally NOT a HirProgram field —
//      every external has already absorbed its module name during
//      `process_tl_let`).
//
// Edge cases pinned:
//   - `process_defs` base case (empty defs) returns the SAME accum
//     verbatim — feeding an empty-defs walk into accum_to_program must
//     yield the same shape as feeding empty_accum() directly. A
//     regression where the base case replaced the accumulator (e.g.
//     `[] -> empty_accum()`) would silently drop pre-seeded state.
//   - The seeded Exn enum survives the trip (still exactly one
//     EnumDef in `enum_defs`, named "Exn").
//   - All other collections come out empty.
//   - exception_groups: [] makes the no-op short-circuit of
//     `expand_groups_in_functions` fire — that branch must not be
//     accidentally inverted.
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import { process_defs } from "src/ir/hir/build/defs.nx"
import { empty_accum, accum_to_program } from "src/ir/hir/build/accum.nx"
import { HirProgram } from "src/ir/hir/types.nx"
import { EnumDef } from "src/common/ast.nx"

let body = fn () -> unit throws { Exn } do
  // process_defs base case must be identity: feeding it the seeded
  // empty_accum with no defs yields the same accumulator that
  // accum_to_program then assembles into a clean HirProgram.
  let after_pd = process_defs(
    defs: [],
    entries: [],
    accum: empty_accum(),
    source_file: "<test>",
    is_defining: 1
  )
  let prog = accum_to_program(accum: after_pd)
  let HirProgram(
    caps: ps,
    functions: fs,
    externals: exts,
    handler_bindings: hbs,
    enum_defs: eds,
    exception_groups: egs,
    value_binding_names: vbns,
    type_defs: tds
  ) = prog

  test_assert.assert_eq_i64(
    actual: list.length(xs: ps),
    expected: 0,
    label: "accum_to_program empty: ports empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: fs),
    expected: 0,
    label: "accum_to_program empty: functions empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: exts),
    expected: 0,
    label: "accum_to_program empty: externals empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: hbs),
    expected: 0,
    label: "accum_to_program empty: handler_bindings empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: egs),
    expected: 0,
    label: "accum_to_program empty: exception_groups empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: vbns),
    expected: 0,
    label: "accum_to_program empty: value_binding_names empty"
  )
  test_assert.assert_eq_i64(
    actual: list.length(xs: tds),
    expected: 0,
    label: "accum_to_program empty: type_defs empty"
  )

  // The seeded Exn enum must survive intact.
  test_assert.assert_eq_i64(
    actual: list.length(xs: eds),
    expected: 1,
    label: "accum_to_program empty: seeded Exn enum survives"
  )
  match eds do
    | EnumDef(name: en, is_public: _, is_opaque: _, type_params: _, variants: _) :: _ ->
      test_assert.assert_eq_string(
        actual: en,
        expected: "Exn",
        label: "accum_to_program empty: surviving enum is Exn"
      )
    | _ ->
      test_assert.assert_true(
        cond: false,
        label: "accum_to_program empty: enum_defs shape unexpected"
      )
  end
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
