// Issue nexus-byiw subset: unit-test the TLImport branch of
// `src/ir/hir/hir.nx::process_top_level` (reached via `process_defs`).
//
// `import external "pkg:iface"` parses as a `TLImport` whose
// `ImportDef.is_external` flag is true. HIR lowering must set
// `accum.wasm_module` to the resolved import-module name (via
// `map_stdlib_to_wit` → `qualified_to_wit` for `pkg:iface` shapes).
// Plain `import * as foo from "src/path.nx"` (non-external) is handled
// upstream by the import resolver and MUST be a no-op here so the
// accumulator is unchanged.
//
// Edge cases pinned:
//   1. is_external=true with a `pkg:iface` path resolves to
//      `nexus:pkg/iface` and lands in `wasm_module: Some(...)`.
//   2. The special-case `nexus:intrinsic` is passed through verbatim
//      (no `nexus:nexus/intrinsic` expansion).
//   3. is_external=false leaves `wasm_module` as None — every other
//      field is untouched.
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import { process_defs } from "src/ir/hir/build/defs.nx"
import { empty_accum } from "src/ir/hir/build/accum.nx"
import { HirAccum } from "src/ir/hir/types.nx"
import { SpannedTopLevel, TLImport, ImportDef } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"

let body = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)

  // ── case 1: external `pkg:iface` → wasm_module Some("nexus:pkg/iface") ──
  let imp_pkg = ImportDef(path: "std:str", alias: None, items: [], is_external: true)
  let out1 = process_defs(
    defs: [SpannedTopLevel(node: TLImport(def: imp_pkg), span: sp)],
    entries: [], accum: empty_accum(), source_file: "<test>", is_defining: 1)
  let HirAccum(ports: _, functions: _, externals: _, handler_bindings: _, enum_defs: _, wasm_module: wm1, exception_groups: _, value_binding_names: _, type_defs: _) = out1
  match wm1 do
    | Some(val: name) ->
      test_assert.assert_eq_string(actual: name, expected: "nexus:std/str", label: "TLImport ext: std:str -> nexus:std/str")
    | None ->
      test_assert.assert_true(cond: false, label: "TLImport ext: wasm_module must be Some")
  end

  // ── case 2: `nexus:intrinsic` special-cased verbatim ──
  let imp_intr = ImportDef(path: "nexus:intrinsic", alias: None, items: [], is_external: true)
  let out2 = process_defs(
    defs: [SpannedTopLevel(node: TLImport(def: imp_intr), span: sp)],
    entries: [], accum: empty_accum(), source_file: "<test>", is_defining: 1)
  let HirAccum(ports: _, functions: _, externals: _, handler_bindings: _, enum_defs: _, wasm_module: wm2, exception_groups: _, value_binding_names: _, type_defs: _) = out2
  match wm2 do
    | Some(val: name) ->
      test_assert.assert_eq_string(actual: name, expected: "nexus:intrinsic", label: "TLImport ext: nexus:intrinsic passes through verbatim")
    | None ->
      test_assert.assert_true(cond: false, label: "TLImport ext: nexus:intrinsic must set wasm_module")
  end

  // ── case 3: non-external import is a no-op ──
  let imp_local = ImportDef(path: "src/common/ast.nx", alias: Some(val: "ast"), items: [], is_external: false)
  let out3 = process_defs(
    defs: [SpannedTopLevel(node: TLImport(def: imp_local), span: sp)],
    entries: [], accum: empty_accum(), source_file: "<test>", is_defining: 1)
  let HirAccum(ports: ps3, functions: fs3, externals: exts3, handler_bindings: hbs3, enum_defs: eds3, wasm_module: wm3, exception_groups: egs3, value_binding_names: vbns3, type_defs: tds3) = out3
  match wm3 do
    | None -> test_assert.assert_true(cond: true, label: "TLImport non-ext: wasm_module stays None")
    | Some(val: _) -> test_assert.assert_true(cond: false, label: "TLImport non-ext: wasm_module must NOT be set")
  end
  test_assert.assert_eq_i64(actual: list.length(xs: ps3), expected: 0, label: "TLImport non-ext: ports untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: fs3), expected: 0, label: "TLImport non-ext: functions untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: exts3), expected: 0, label: "TLImport non-ext: externals untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: hbs3), expected: 0, label: "TLImport non-ext: handler_bindings untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: eds3), expected: 1, label: "TLImport non-ext: only seeded Exn in enum_defs")
  test_assert.assert_eq_i64(actual: list.length(xs: egs3), expected: 0, label: "TLImport non-ext: exception_groups untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: vbns3), expected: 0, label: "TLImport non-ext: value_binding_names untouched")
  test_assert.assert_eq_i64(actual: list.length(xs: tds3), expected: 0, label: "TLImport non-ext: type_defs untouched")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
