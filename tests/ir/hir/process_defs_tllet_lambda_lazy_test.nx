// Issue nexus-byiw subset: unit-test the TLLet → Lambda branch of
// `src/ir/hir/hir.nx::process_tl_let` (reached via `process_defs`).
//
// For a non-stdlib source file `let f = fn () -> i64 do ... end`, the
// HIR pass:
//   1. Resolves the global name through `symtab.rename`.
//   2. Picks `convert_expr_toplevel` (because the source path is NOT
//      stdlib AND the rhs is an `ExprLambda`), which yields a Lambda
//      shape with EMPTY body — the real body is materialised lazily
//      via `LazyBody(ast_expr: val, entries)`.
//   3. Cons-prepends the resulting HirFunction onto `functions` with
//      LazyBody (the driver/LSP later resolves it).
//   4. value_binding_names is NOT extended for the lambda case (only
//      non-lambda toplevels wrapped-as-Lambda contribute to vbns —
//      tt5a tracking).
//
// Edge cases pinned:
//   - functions grows by exactly one and the head HirFunction.name
//     matches the source `let` name.
//   - The body is LazyBody, not EagerBody (a regression that converted
//     bodies eagerly would inflate non-stdlib HIR builds).
//   - ret_type is preserved from the ExprLambda.ret_type.
//   - value_binding_names is unchanged (lambda case).
import * as test_assert from "std:test/assert"
import * as list from "std:list"
import { process_defs } from "src/ir/hir/build/defs.nx"
import { empty_accum } from "src/ir/hir/build/accum.nx"
import { HirAccum, HirFunction, LazyBody, EagerBody } from "src/ir/hir/types.nx"
import { SpannedTopLevel, SpannedExpr, SpannedStmt, TLLet, GlobalLet, ExprLambda, ExprLiteral, StmtReturn, LitInt, TyI64, TyRow } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"

let body = fn () -> unit throws { Exn } do
  let sp = Span(offset: 0, line: 1, col: 1)
  let empty_row = TyRow(types: [], rest: None)

  // Build `let answer = fn () -> i64 do return 42 end` in AST form.
  let ret_stmt = SpannedStmt(node: StmtReturn(value: SpannedExpr(node: ExprLiteral(lit: LitInt(val: 42)), span: sp)), span: sp)
  let lam = ExprLambda(type_params: [], params: [], ret_type: TyI64, requires: empty_row, throw_row: empty_row, body: [ ret_stmt ])
  let glet = GlobalLet(name: "answer", is_public: false, typ: None, value: SpannedExpr(node: lam, span: sp))

  // Non-stdlib path → triggers convert_expr_toplevel + LazyBody.
  let out = process_defs(
    defs: [ SpannedTopLevel(node: TLLet(def: glet), span: sp) ],
    entries: [], accum: empty_accum(), source_file: "user_code.nx", is_defining: 1)
  let HirAccum(caps: _, functions: fs, externals: _, handler_bindings: _, enum_defs: _, wasm_module: _, exception_groups: _, value_binding_names: vbns, type_defs: _) = out

  test_assert.assert_eq_i64(actual: list.length(xs: fs), expected: 1, label: "TLLet Lambda: functions grew by one")
  match fs do
    | HirFunction(name: fn_name, type_params: _, params: _, ret_type: rty, throw_row: _, body: b, span: _, file: f) :: _ ->
      test_assert.assert_eq_string(actual: fn_name, expected: "answer", label: "TLLet Lambda: function name = answer")
      test_assert.assert_eq_string(actual: f, expected: "user_code.nx", label: "TLLet Lambda: function carries source file")
      match rty do
        | TyI64 -> test_assert.assert_true(cond: true, label: "TLLet Lambda: ret_type preserved as TyI64")
        | _ -> test_assert.assert_true(cond: false, label: "TLLet Lambda: ret_type NOT preserved")
      end
      // Non-stdlib lambda → LazyBody (deferred body conversion).
      match b do
        | LazyBody(ast_expr: _, entries: _) ->
          test_assert.assert_true(cond: true, label: "TLLet Lambda (non-stdlib): body is LazyBody")
        | EagerBody(stmts: _) ->
          test_assert.assert_true(cond: false, label: "TLLet Lambda (non-stdlib): regression — body eagerly converted")
      end
    | _ ->
      test_assert.assert_true(cond: false, label: "TLLet Lambda: functions list missing head")
  end

  // value_binding_names: lambdas are NOT added (only non-lambda
  // toplevels-wrapped-as-Lambda contribute).
  test_assert.assert_eq_i64(actual: list.length(xs: vbns), expected: 0, label: "TLLet Lambda: value_binding_names NOT extended for lambda case (tt5a)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
