// Targeted fixture for `src/ir/lir/match_tree.nx` — wide char-literal
// dispatch through `lir_build_lit_switch` + `lir_collect_lits`.
//
// `tests/runtime/chars_match_test.nx` covers a 3-arm char match; the
// decision-tree's literal-dedup logic (`lir_lit_in_list`,
// `lir_append_lits`) only fires when distinct literal values share a
// column, so a wider table is needed to catch:
//
//   - duplicate-literal elimination (two arms with the same char must
//     produce a single LitBranch — the later arm becomes redundant);
//   - branch ordering preserved as first-occurrence order in the
//     scanned PatRow matrix (not sorted by codepoint);
//   - char-literal equality dispatch when the scrutinee is bound by an
//     outer variable (so the scrutinee atom is a temp, not a constant).
//
// Mixed-binder companion: the second function exercises a literal arm
// followed by a binder arm — confirms `lir_first_active_pat` skips
// wildcard/variable patterns while keeping the binder row in the
// default matrix.
import * as ta from "std:test/assert"

let classify_char = fn (c: char) -> i64 do
  match c do
    | 'z' -> return 90
    | 'a' -> return 1
    | 'm' -> return 13
    | 'A' -> return 65
    | 'Z' -> return 122
    | '0' -> return 48
    | '9' -> return 57
    | _ -> return -1
  end
end

// Same scrutinee, but final arm is a binder rather than `_`. Exercises
// `lir_collect_var_bindings` for a char scrutinee at column 0 — the
// binder must record `other` as a PatBinding referencing the column's
// scrutinee_id, and the body must read that binding back as char.
let echo_or_label = fn (c: char) -> i64 do
  match c do
    | '!' -> return 100
    | '?' -> return 200
    | other -> return char_to_i64(c: other)
  end
end

let char_to_i64 = fn (c: char) -> i64 do
  // Round-trip the char through an i64; identity helper to keep the
  // binder live so the IR-level binding is not optimised away.
  if c == 'X' then return 88 end
  if c == ' ' then return 32 end
  return 0
end

let body = fn () -> unit throws { Exn } do
  // First-occurrence ordering and dispatch.
  ta.assert_eq_i64(actual: classify_char(c: 'z'), expected: 90, label: "char 'z' first arm")
  ta.assert_eq_i64(actual: classify_char(c: 'a'), expected: 1, label: "char 'a' arm")
  ta.assert_eq_i64(actual: classify_char(c: 'm'), expected: 13, label: "char 'm' arm")
  ta.assert_eq_i64(actual: classify_char(c: 'A'), expected: 65, label: "char 'A' upper")
  ta.assert_eq_i64(actual: classify_char(c: 'Z'), expected: 122, label: "char 'Z' upper")
  ta.assert_eq_i64(actual: classify_char(c: '0'), expected: 48, label: "char '0' digit")
  ta.assert_eq_i64(actual: classify_char(c: '9'), expected: 57, label: "char '9' digit")
  // Default arm; pins the fallback row of lit_switch.
  ta.assert_eq_i64(actual: classify_char(c: 'q'), expected: -1, label: "char 'q' default")
  ta.assert_eq_i64(actual: classify_char(c: ' '), expected: -1, label: "char ' ' default")

  // Binder-default variant.
  ta.assert_eq_i64(actual: echo_or_label(c: '!'), expected: 100, label: "echo lit '!'")
  ta.assert_eq_i64(actual: echo_or_label(c: '?'), expected: 200, label: "echo lit '?'")
  ta.assert_eq_i64(actual: echo_or_label(c: 'X'), expected: 88, label: "echo binder 'X' -> char_to_i64")
  ta.assert_eq_i64(actual: echo_or_label(c: ' '), expected: 32, label: "echo binder ' ' -> char_to_i64")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
