// Targeted fixture for `src/ir/lir/match_tree.nx` — decision-tree
// compilation. End-to-end runtime tests exercise this transitively, but
// nothing pins the LIR pattern-compiler's ctor-tag dispatch and nested
// field-extraction directly. A miscompile here (wrong column selection,
// reversed branch order, dropped subpattern binding for nested ctors)
// would slip past tests/runtime/* until a real program tripped it.
//
// Scope:
//   - 3-variant enum with mixed nullary / nested-payload variants — tests
//     `lir_build_ctor_switch` over multiple specialized rows.
//   - Match-arm order is deliberately non-canonical (Last variant first,
//     then nested ctors, then nullary) — pins arm ordering after
//     decision-tree compilation.
//   - Nested constructor pattern `Wrap(inner: Tag(...))` exercises the
//     specialize / push-cols path for sub-rows.
import * as ta from "std:test/assert"

type Tag = TagA(n: i64) | TagB(n: i64) | TagC
type Wrapped = Wrap(inner: Tag) | Bare(k: i64) | Empty

// Non-trivial arm order: catch Empty last; intermediate arms hit
// Wrap(...) with nested-ctor subpatterns interleaved between Bare arms.
let classify = fn (w: Wrapped) -> i64 do
  match w do
    | Wrap(inner: TagA(n: a)) -> return 100 + a
    | Bare(k: 0) -> return 0
    | Wrap(inner: TagB(n: b)) -> return 200 + b
    | Bare(k) -> return 50 + k
    | Wrap(inner: TagC) -> return 300
    | Empty -> return 999
  end
  return -1
end

// Reversed arm order to detect any accidental tag-ordering dependence in
// the decision tree's branch list. The variable-bind `Bare(k)` is
// listed before any nested-ctor `Wrap(...)` arm, so the decision tree
// must not collapse the Wrap arms into one bucket.
let classify_reversed = fn (w: Wrapped) -> i64 do
  match w do
    | Empty -> return 999
    | Wrap(inner: TagC) -> return 300
    | Bare(k) -> return 50 + k
    | Wrap(inner: TagB(n: b)) -> return 200 + b
    | Wrap(inner: TagA(n: a)) -> return 100 + a
  end
  return -1
end

let body = fn () -> unit throws { Exn } do
  // Nested ctor with binding
  ta.assert_eq_i64(actual: classify(w: Wrap(inner: TagA(n: 7))),
                   expected: 107, label: "classify Wrap(TagA(7))")
  ta.assert_eq_i64(actual: classify(w: Wrap(inner: TagB(n: 9))),
                   expected: 209, label: "classify Wrap(TagB(9))")
  // Nested ctor, nullary inner
  ta.assert_eq_i64(actual: classify(w: Wrap(inner: TagC)),
                   expected: 300, label: "classify Wrap(TagC)")
  // Literal subpattern matches first arm
  ta.assert_eq_i64(actual: classify(w: Bare(k: 0)),
                   expected: 0, label: "classify Bare(0) literal")
  // Variable subpattern catches the rest
  ta.assert_eq_i64(actual: classify(w: Bare(k: 5)),
                   expected: 55, label: "classify Bare(5) binds k")
  ta.assert_eq_i64(actual: classify(w: Empty),
                   expected: 999, label: "classify Empty")

  // Reversed-order variant — non-zero Bare must still take the variable arm.
  ta.assert_eq_i64(actual: classify_reversed(w: Wrap(inner: TagA(n: 7))),
                   expected: 107, label: "reversed Wrap(TagA(7))")
  ta.assert_eq_i64(actual: classify_reversed(w: Wrap(inner: TagB(n: 9))),
                   expected: 209, label: "reversed Wrap(TagB(9))")
  ta.assert_eq_i64(actual: classify_reversed(w: Wrap(inner: TagC)),
                   expected: 300, label: "reversed Wrap(TagC)")
  // Note: literal-0 arm is now after `Bare(k)` and therefore unreachable.
  // The variable arm should win; expected = 50 + 0 = 50.
  ta.assert_eq_i64(actual: classify_reversed(w: Bare(k: 0)),
                   expected: 50, label: "reversed Bare(0) caught by var arm")
  ta.assert_eq_i64(actual: classify_reversed(w: Bare(k: 5)),
                   expected: 55, label: "reversed Bare(5)")
  ta.assert_eq_i64(actual: classify_reversed(w: Empty),
                   expected: 999, label: "reversed Empty")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
