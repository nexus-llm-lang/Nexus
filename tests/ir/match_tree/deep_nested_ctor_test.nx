// Targeted fixture for `src/ir/lir/match_tree.nx` — deep nested ctor
// destructure with mixed binder/literal/wildcard subpatterns.
//
// `decision_tree_ctor_split_test.nx` already pins single-level nested
// ctors (Wrap(inner: TagA(n: a))). What it does not exercise:
//
//   - *Three* levels of nesting on the same scrutinee column —
//     `Outer(Mid(Inner(n: v)))` forces the specialise-then-push-cols
//     path to fire twice in a row, expanding column ids three times.
//   - The same outer column shared across an arm with a *lit*
//     subpattern at depth 2 and an arm with a *binder* subpattern at
//     depth 2 — pins the interaction between `lir_collect_lits` and
//     `lir_collect_var_bindings` for the inner column after two
//     specializations.
//   - A leading-wildcard arm before a deep-nested arm — pins
//     `lir_find_active_column` skipping wildcards in row 0 to land on
//     the column that row 1 constrains.
import * as ta from "std:test/assert"

type Inner = Leaf(n: i64) | Empty
type Mid = Mid(inner: Inner) | Skip
type Outer = Outer(mid: Mid) | Top(k: i64)

let probe = fn (o: Outer) -> i64 do
  match o do
    // Depth-3 with literal at the leaf.
    | Outer(mid: Mid(inner: Leaf(n: 0))) -> return 1
    // Depth-3 with binder at the leaf — exercise the same outer/mid
    // column shared with the previous row but a binder column at depth
    // 3 instead of a literal.
    | Outer(mid: Mid(inner: Leaf(n: v))) -> return 100 + v
    // Depth-2 with nullary inner — short-circuit at the mid level.
    | Outer(mid: Mid(inner: Empty)) -> return 50
    // Depth-1: nullary mid — short-circuit at the outer level.
    | Outer(mid: Skip) -> return 7
    // Sibling constructor at depth 0 with binder.
    | Top(k) -> return 1000 + k
  end
end

// Companion: leading wildcard arm forces `lir_find_active_column` to
// scan past column 0 (which is fully `_` in row 0) and pick the
// constructor column in row 1.
let mixed_wild = fn (a: i64, o: Outer) -> i64 do
  match { a: a, b: o } do
    | { a: 0, b: _ } -> return 9999
    | { a: _, b: Outer(mid: Mid(inner: Leaf(n: v))) } -> return v * 3
    | { a: _, b: Outer(mid: Mid(inner: Empty)) } -> return 11
    | { a: _, b: Outer(mid: Skip) } -> return 22
    | { a: _, b: Top(k) } -> return 33 + k
  end
end

let body = fn () -> unit throws { Exn } do
  // Literal at depth 3.
  ta.assert_eq_i64(actual: probe(o: Outer(mid: Mid(inner: Leaf(n: 0)))),
                   expected: 1, label: "Outer(Mid(Leaf(0))) literal arm")
  // Binder at depth 3 (n != 0).
  ta.assert_eq_i64(actual: probe(o: Outer(mid: Mid(inner: Leaf(n: 5)))),
                   expected: 105, label: "Outer(Mid(Leaf(5))) binder arm")
  ta.assert_eq_i64(actual: probe(o: Outer(mid: Mid(inner: Leaf(n: -3)))),
                   expected: 97, label: "Outer(Mid(Leaf(-3))) binder negative")
  // Nullary inner at depth 2.
  ta.assert_eq_i64(actual: probe(o: Outer(mid: Mid(inner: Empty))),
                   expected: 50, label: "Outer(Mid(Empty)) depth-2")
  // Nullary mid at depth 1.
  ta.assert_eq_i64(actual: probe(o: Outer(mid: Skip)),
                   expected: 7, label: "Outer(Skip) depth-1")
  // Sibling Top.
  ta.assert_eq_i64(actual: probe(o: Top(k: 13)),
                   expected: 1013, label: "Top(13) sibling depth-0")
  ta.assert_eq_i64(actual: probe(o: Top(k: 0)),
                   expected: 1000, label: "Top(0)")

  // Mixed-wildcard companion.
  // a=0 wins the first arm regardless of the Outer payload.
  ta.assert_eq_i64(actual: mixed_wild(a: 0, o: Top(k: 99)),
                   expected: 9999, label: "mixed a=0 wins")
  ta.assert_eq_i64(actual: mixed_wild(a: 0, o: Outer(mid: Skip)),
                   expected: 9999, label: "mixed a=0 wins even with deep Outer")
  // a != 0 falls through to the Outer/Top dispatch.
  ta.assert_eq_i64(actual: mixed_wild(a: 1, o: Outer(mid: Mid(inner: Leaf(n: 4)))),
                   expected: 12, label: "mixed a=1 Leaf(4) -> v*3")
  ta.assert_eq_i64(actual: mixed_wild(a: 2, o: Outer(mid: Mid(inner: Empty))),
                   expected: 11, label: "mixed a=2 Empty")
  ta.assert_eq_i64(actual: mixed_wild(a: 5, o: Outer(mid: Skip)),
                   expected: 22, label: "mixed a=5 Skip")
  ta.assert_eq_i64(actual: mixed_wild(a: 9, o: Top(k: 7)),
                   expected: 40, label: "mixed a=9 Top(7)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
