// Targeted fixture for `src/ir/lir/match_tree.nx` — wide int-literal
// cover with zero and a large value, plus binder-after-literal ordering.
//
// `lir_lit_in_list` compares via `LitInt(val)` equality, so a regression
// in i64 equality dispatch in the literal-collect helpers would surface
// when:
//
//   - the literal set includes 0 (a frequent special-case in lit-switch
//     lowering);
//   - the literal set spans several orders of magnitude (1, 100, 10000)
//     so no contiguous-range optimisation can mask a bug;
//   - source-order is preserved: the binder arm appears *after* literal
//     arms and must remain a catch-all rather than swallowing later
//     literals.
//
// Companion: `with_binder_first` shows that a binder arm placed after a
// few literals continues to bind every value the literals do not match
// — this pins that the decision tree's default-row plumbing keeps the
// binder row alive through `lir_default_matrix`.
//
// (Negative-int patterns are not in the surface grammar today, so the
// signed-cover variant is approximated by interleaving 0 / 1 / large
// values rather than negatives. Negatives are still exercised at the
// *body* level — `x * 1000` over a negative input — to keep i64 sign
// handling in the test's behavioural envelope.)
import * as ta from "std:test/assert"

let classify_unsigned = fn (x: i64) -> i64 do
  match x do
    | 0 -> return 100
    | 1 -> return 200
    | 7 -> return 300
    | 100 -> return 400
    | 10000 -> return 500
    | _ -> return 0
  end
  return -1
end

// Interleaved binder + literal: the binder arm `n` would shadow the
// later literal arm if rows were reordered; the test confirms the
// decision tree preserves source-order semantics so the binder catches
// only the values the literals miss.
let with_binder_first = fn (x: i64) -> i64 do
  match x do
    | 1 -> return 11
    | 2 -> return 22
    | n -> return n * 1000
  end
  return -1
end

let body = fn () -> unit throws { Exn } do
  // Zero — a frequent special-case in lit-switch lowering.
  ta.assert_eq_i64(actual: classify_unsigned(x: 0),
                   expected: 100, label: "lit 0 (zero special-case)")
  // Single-digit literals.
  ta.assert_eq_i64(actual: classify_unsigned(x: 1),
                   expected: 200, label: "lit 1")
  ta.assert_eq_i64(actual: classify_unsigned(x: 7),
                   expected: 300, label: "lit 7")
  // Wider magnitudes — pins that lit_switch does not assume a contiguous
  // range optimisation.
  ta.assert_eq_i64(actual: classify_unsigned(x: 100),
                   expected: 400, label: "lit 100")
  ta.assert_eq_i64(actual: classify_unsigned(x: 10000),
                   expected: 500, label: "lit 10000")
  // Default arm — must catch values in between and outside.
  ta.assert_eq_i64(actual: classify_unsigned(x: 42),
                   expected: 0, label: "default 42")
  ta.assert_eq_i64(actual: classify_unsigned(x: 99),
                   expected: 0, label: "default 99 (one off the upper lit)")
  ta.assert_eq_i64(actual: classify_unsigned(x: 9999),
                   expected: 0, label: "default 9999 (one off 10000)")
  ta.assert_eq_i64(actual: classify_unsigned(x: 10001),
                   expected: 0, label: "default 10001")

  // Binder-after-literals.
  ta.assert_eq_i64(actual: with_binder_first(x: 1),
                   expected: 11, label: "binder-fixture lit 1")
  ta.assert_eq_i64(actual: with_binder_first(x: 2),
                   expected: 22, label: "binder-fixture lit 2")
  ta.assert_eq_i64(actual: with_binder_first(x: 0),
                   expected: 0, label: "binder-fixture binds 0")
  ta.assert_eq_i64(actual: with_binder_first(x: 3),
                   expected: 3000, label: "binder-fixture binds 3")
  ta.assert_eq_i64(actual: with_binder_first(x: 50),
                   expected: 50000, label: "binder-fixture binds 50")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
