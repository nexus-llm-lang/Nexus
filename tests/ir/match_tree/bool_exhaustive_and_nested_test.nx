// Targeted fixture for `src/ir/lir/match_tree.nx` — bool-literal switch
// and nested record-with-bool destructure.
//
// Bool patterns flow through `lir_build_lit_switch` like ints, but they
// have only two inhabitants. An *exhaustive* bool match (`true`/`false`
// arms, no `_`) is interesting because:
//
//   - `lir_default_matrix` ends up empty, so the LitSwitch must lower
//     with a fallback that the compiler treats as unreachable rather
//     than wiring up a default row;
//   - the typechecker's exhaustiveness check (see exhaustive.nx) must
//     accept a `_`-less bool match — a regression that requires `_`
//     would break the test at compile time.
//
// The nested record fixture pins record-field destructure where one
// field is a bool literal — the row contributes both a record column
// (record_destructure → subtree) and a bool literal column inside.
import * as ta from "std:test/assert"

// Exhaustive bool match: no `_`, two arms exactly.
let neg = fn (b: bool) -> bool do
  match b do
    | true -> return false
    | false -> return true
  end
  return false
end

// Bool match that returns i64 — confirms the lit-switch result type is
// independent of scrutinee width.
let bool_to_i64 = fn (b: bool) -> i64 do
  match b do
    | true -> return 1
    | false -> return 0
  end
  return -1
end

// Record with one bool literal column and one i64 binder column.
// Exercise record_destructure → lit_switch composition.
let pick_flagged = fn (r: { flag: bool, n: i64 }) -> i64 do
  let result = match r do
    | { flag: true, n: k } -> k + 1000
    | { flag: false, n: k } -> k - 1000
  end
  return result
end

let body = fn () -> unit throws { Exn } do
  // Exhaustive bool — both arms reachable.
  ta.assert_eq_bool(actual: neg(b: true), expected: false, label: "neg(true) == false")
  ta.assert_eq_bool(actual: neg(b: false), expected: true, label: "neg(false) == true")
  ta.assert_eq_i64(actual: bool_to_i64(b: true), expected: 1, label: "bool_to_i64 true")
  ta.assert_eq_i64(actual: bool_to_i64(b: false), expected: 0, label: "bool_to_i64 false")

  // Record-destructure + bool lit_switch + binder.
  ta.assert_eq_i64(actual: pick_flagged(r: { flag: true, n: 5 }),
                   expected: 1005, label: "record flag:true binds n")
  ta.assert_eq_i64(actual: pick_flagged(r: { flag: false, n: 5 }),
                   expected: -995, label: "record flag:false binds n")
  ta.assert_eq_i64(actual: pick_flagged(r: { flag: true, n: 0 }),
                   expected: 1000, label: "record flag:true binds n=0")
  ta.assert_eq_i64(actual: pick_flagged(r: { flag: false, n: -7 }),
                   expected: -1007, label: "record flag:false binds n=-7")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
