// Targeted fixture for `src/ir/lir/match_tree.nx` — pattern-row
// precedence. Currently no direct fixture pins:
//   - row order between partially-wildcarded arms (column-selection
//     heuristic must not reorder them past a wildcard column);
//   - `_`/`x` binder semantics inside record patterns when an earlier
//     arm only constrains one field;
//   - the default-row plumbing for `_` columns under `lir_build_lit_switch`.
//
// A regression in the heuristic (e.g. greedily splitting on a column
// that contains a leading wildcard) would silently reorder these arms.
//
// Scope:
//   - Record { a, b } match with three arms: (x, _), (_, y), wildcard.
//     Each input must hit exactly one arm; the test asserts the binding
//     and arm-selection are correct.
//   - Tag-then-bind: `Tag(0) | Tag(n)` covers literal-arm followed by
//     variable-arm dispatch through `lir_build_lit_switch` + default.
import * as ta from "std:test/assert"

type Box = Box(v: i64)

// Record match: arm 1 fires only when a=0 (literal column-1), arm 2 is
// the catch-all binding b. Pins column-selection on a mixed literal/
// wildcard record pattern under the Maranget matrix.
let pick_record = fn (r: { a: i64, b: i64 }) -> i64 do
  let result = match r do
    | { a: 0, b: y } -> y + 2000
    | { a: x, b: _ } -> x + 1000
  end
  return result
end

// Literal-then-variable on a ctor field — exercises lit_switch + default
// branch. Box(0) hits the literal arm; Box(k) for k != 0 hits the
// variable arm. If decision-tree default-row plumbing is broken, k=0
// could fall through to the variable arm (or vice-versa).
let probe_box = fn (b: Box) -> i64 do
  match b do
    | Box(v: 0) -> return 0
    | Box(v: n) -> return n * 10
  end
  return -1
end

let body = fn () -> unit throws { Exn } do
  // a != 0 hits arm 2 (catch-all binding x).
  ta.assert_eq_i64(actual: pick_record(r: { a: 5, b: 7 }),
                   expected: 1005, label: "{a:x, b:_} catches a=5")
  ta.assert_eq_i64(actual: pick_record(r: { a: 3, b: 0 }),
                   expected: 1003, label: "{a:x, b:_} catches a=3 b=0")
  // a == 0 hits arm 1 (binds y).
  ta.assert_eq_i64(actual: pick_record(r: { a: 0, b: 99 }),
                   expected: 2099, label: "{a:0, b:y} fires on a=0")

  // Literal arm reachable.
  ta.assert_eq_i64(actual: probe_box(b: Box(v: 0)), expected: 0,
                   label: "Box(v: 0) hits literal arm")
  // Variable arm reachable.
  ta.assert_eq_i64(actual: probe_box(b: Box(v: 4)), expected: 40,
                   label: "Box(v: 4) hits variable arm via default")
  ta.assert_eq_i64(actual: probe_box(b: Box(v: -3)), expected: -30,
                   label: "Box(v: -3) variable arm with negative")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
