// Targeted fixture for `src/ir/lir/match_tree.nx` — nested or-patterns.
//
// Or-pattern handling lives in `lir_cases_to_rows` (each alt expands to its
// own PatRow) but the existing fixtures only exercise top-level or-patterns
// against bare-enum variants. Two paths remain unpinned:
//
//   - or-pattern of *literal* alternatives inside an `i64` scrutinee, where
//     each alt feeds `lir_build_lit_switch` as a separate row sharing one
//     case_idx (so a regression that double-counts case_idx, or collapses
//     literal alts into a single row, would surface here);
//   - or-pattern of *constructor* alternatives with shared payload binding —
//     `Left(v) | Right(v) -> v` — pins the binding-collection logic in
//     `lir_collect_var_bindings` against duplicate insertion across rows.
//
// Both patterns are *bare* (no nested ctor body), so the test stays close
// to the row-expansion machinery and away from the decision-tree column
// selection heuristic.
import * as ta from "std:test/assert"

type Either = Left(v: i64) | Right(v: i64) | Middle

// Literal or-pattern with several alts feeding lit_switch.
// Default arm is `_`; each alt must expand into a distinct PatRow but
// the resulting decision tree should still have a single LitBranch per
// distinct literal and one DecFail-or-leaf fallback.
let lit_or = fn (x: i64) -> i64 do
  match x do
    | 1 | 2 | 3 -> return 100
    | 10 | 20 -> return 200
    | _ -> return 0
  end
end

// Constructor or-pattern with shared binding: each alt rebinds `v` to the
// payload of its own variant. The decision tree must produce two separate
// CtorBranches (Left, Right) whose leaves both bind `v` from their own
// scrutinee, then a third arm `Middle` mapped via a distinct row.
let ctor_or = fn (e: Either) -> i64 do
  match e do
    | Left(v) | Right(v) -> return v * 2
    | Middle -> return 999
  end
end

let body = fn () -> unit throws { Exn } do
  // Lit-or path: each alt hits the 100-arm.
  ta.assert_eq_i64(actual: lit_or(x: 1), expected: 100, label: "lit_or 1 -> alt1")
  ta.assert_eq_i64(actual: lit_or(x: 2), expected: 100, label: "lit_or 2 -> alt2")
  ta.assert_eq_i64(actual: lit_or(x: 3), expected: 100, label: "lit_or 3 -> alt3")
  ta.assert_eq_i64(actual: lit_or(x: 10), expected: 200, label: "lit_or 10 -> second-or alt1")
  ta.assert_eq_i64(actual: lit_or(x: 20), expected: 200, label: "lit_or 20 -> second-or alt2")
  // Default fallthrough — must not be swallowed by the prior or-arms.
  ta.assert_eq_i64(actual: lit_or(x: 4), expected: 0, label: "lit_or 4 -> default")
  ta.assert_eq_i64(actual: lit_or(x: 0), expected: 0, label: "lit_or 0 -> default")
  ta.assert_eq_i64(actual: lit_or(x: 21), expected: 0, label: "lit_or 21 -> default")

  // Ctor-or with shared binding. Both alts must bind `v` from their own
  // scrutinee; a regression that captures the same scrutinee_id for both
  // rows would return Left's payload for a Right input (or vice-versa).
  ta.assert_eq_i64(actual: ctor_or(e: Left(v: 7)), expected: 14, label: "ctor_or Left binding")
  ta.assert_eq_i64(actual: ctor_or(e: Right(v: 11)), expected: 22, label: "ctor_or Right binding")
  ta.assert_eq_i64(actual: ctor_or(e: Middle), expected: 999, label: "ctor_or Middle separate arm")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
