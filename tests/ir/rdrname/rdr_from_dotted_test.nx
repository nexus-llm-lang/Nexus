// Issue nexus-byiw subset: targeted coverage for `src/ir/rdrname.nx::rdr_from_dotted`.
// This is the parser-side bridge that converts source-syntax identifiers
// like `mymod.foo` into the structured `RdrName` ADT (Unqual / Qual) used
// downstream by the resolver / typechecker.
//
// Rule: split on the FIRST dot. Everything before → alias; everything after
// → name. No dot → Unqual.
//
// Edge cases pinned:
//   1. Plain identifier: "foo" → Unqual("foo"). The resolver treats this
//      as either a local binding, a builtin, or a top-level def to look up.
//   2. Single dot: "mymod.foo" → Qual(alias: "mymod", name: "foo"). The
//      canonical module-qualified form.
//   3. Multiple dots: "a.b.c" → Qual(alias: "a", name: "b.c"). Confirms
//      "split on FIRST dot" — a regression that split on LAST dot would
//      return Qual("a.b", "c") and break nested-record field access syntax
//      that parses as `record.field.subfield`.
//   4. Trailing-dot edge: "foo." → Qual(alias: "foo", name: "") — the
//      parser may never produce this, but the function is total; we pin
//      what it returns so a refactor doesn't silently change behavior.
import * as test_assert from "std:test/assert"
import { RdrName, Unqual, Qual } from "src/common/ast.nx"
import * as rdrname from "src/ir/shared/rdrname.nx"

let body = fn () -> unit throws { Exn } do
  // We use `rdr_to_string` round-trip + `rdr_occ` to inspect the variant
  // without needing pattern-match assertions on the opaque-ish RdrName.

  // (1) Plain identifier → Unqual.
  let r1 = rdrname.rdr_from_dotted(s: "foo")
  test_assert.assert_eq_string(actual: rdrname.rdr_to_string(r: r1),
    expected: "foo", label: "rdr_from_dotted: plain → Unqual; to_string is bare name")

  // (2) Single-dot Qual.
  let r2 = rdrname.rdr_from_dotted(s: "mymod.foo")
  test_assert.assert_eq_string(actual: rdrname.rdr_to_string(r: r2),
    expected: "mymod.foo", label: "rdr_from_dotted: single-dot Qual round-trips")
  // Sanity: `rdr_occ` strips the alias and returns just the name part.
  test_assert.assert_eq_string(actual: rdrname.rdr_occ(r: r2),
    expected: "foo", label: "rdr_from_dotted: single-dot occ-name == 'foo'")

  // (3) Multiple dots: split on FIRST dot.
  // "a.b.c" must become Qual(alias="a", name="b.c").
  // rdr_to_string of Qual concats with one dot: "a" ++ "." ++ "b.c" = "a.b.c".
  let r3 = rdrname.rdr_from_dotted(s: "a.b.c")
  test_assert.assert_eq_string(actual: rdrname.rdr_to_string(r: r3),
    expected: "a.b.c", label: "rdr_from_dotted: 3-part round-trips via to_string")
  // The discriminating assertion: `rdr_occ` returns the NAME (right of first
  // dot). A "split on last dot" regression would return "c" here instead of "b.c".
  test_assert.assert_eq_string(actual: rdrname.rdr_occ(r: r3),
    expected: "b.c", label: "rdr_from_dotted: split-on-first-dot keeps inner dots in name")

  // (4) Trailing-dot total-function behavior.
  let r4 = rdrname.rdr_from_dotted(s: "foo.")
  test_assert.assert_eq_string(actual: rdrname.rdr_to_string(r: r4),
    expected: "foo.", label: "rdr_from_dotted: trailing dot → Qual(alias=foo, name=\"\")")
  test_assert.assert_eq_string(actual: rdrname.rdr_occ(r: r4),
    expected: "", label: "rdr_from_dotted: trailing-dot occ-name is empty")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
