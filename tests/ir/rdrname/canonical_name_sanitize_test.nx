// Issue nexus-byiw subset: targeted coverage for `src/ir/rdrname.nx::canonical_name`.
// The canonical-name string is the key the rename map / func table uses to
// distinguish same-named definitions across modules: `src/ir/symtab.nx#rename`
// and `tests/ir/symtab_test.nx#rename` must hash to different buckets.
//
// `canonical_name` composes `sanitize_path(source) ++ "#" ++ name`. The
// sanitizer must replace BOTH `/` (path separator) and `.` (extension dot),
// so that the output contains no characters the wasm validator rejects in
// identifier segments. (The module comment at rdrname.nx line 14 spells out
// "Both `/` (0x2F) and `.` (0x2E) are ASCII single-byte chars" — a two-pass
// byte-level replace.)
//
// Edge cases pinned:
//   1. Typical compiler path: "src/ir/symtab.nx" → "src_ir_symtab_nx".
//   2. Empty source path: sanitize_path("") → "" — canonical_name still
//      emits the "#name" separator (used for synthetic top-level names).
//   3. Path with no separators at all: "foo" → "foo".
//   4. Path with both kinds of chars interleaved: "a.b/c.d" → "a_b_c_d"
//      (confirms BOTH passes ran; a one-pass regression would leave one kind).
import * as test_assert from "std:test/assert"
import * as rdrname from "src/ir/rdrname.nx"

let body = fn () -> unit throws { Exn } do
  // (1) Typical compiler path.
  let c1 = rdrname.canonical_name(source_path: "src/ir/symtab.nx", name: "rename")
  test_assert.assert_eq_string(actual: c1, expected: "src_ir_symtab_nx#rename",
    label: "canonical_name: typical src path → underscored#name")

  // (2) Empty source path still emits the separator.
  let c2 = rdrname.canonical_name(source_path: "", name: "main")
  test_assert.assert_eq_string(actual: c2, expected: "#main",
    label: "canonical_name: empty source → bare #name")

  // (3) Identifier with no separators flows through unchanged before #.
  let c3 = rdrname.canonical_name(source_path: "foo", name: "bar")
  test_assert.assert_eq_string(actual: c3, expected: "foo#bar",
    label: "canonical_name: no-separator source passes through")

  // (4) Interleaved /  and .  — both passes must fire.
  let c4 = rdrname.canonical_name(source_path: "a.b/c.d", name: "x")
  test_assert.assert_eq_string(actual: c4, expected: "a_b_c_d#x",
    label: "canonical_name: both `/` and `.` get sanitized (two-pass)")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
