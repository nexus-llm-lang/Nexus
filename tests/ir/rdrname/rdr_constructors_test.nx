// Issue nexus-byiw subset: targeted coverage for `src/ir/rdrname.nx`
// — direct construction of `RdrName` values and the `rdr_to_string` /
// `rdr_occ` accessors. The `rdr_from_dotted` test (sibling fixture) hits
// the parser-bridge; this one hits the constructors directly so a regression
// that broke ONLY the dot-parser wouldn't mask a constructor regression.
//
// Edge cases pinned:
//   1. Unqual("name") — rdr_to_string returns the bare name.
//   2. Unqual("name") — rdr_occ returns the same bare name (the `_ -> n`
//      Unqual arm of the or-pattern in rdr_occ).
//   3. Qual(alias, name) — rdr_to_string concats with `.`.
//   4. Qual(alias, name) — rdr_occ returns ONLY the name, discarding alias.
//      This is the load-bearing distinction from rdr_to_string: name lookup
//      keys are the un-aliased occurrence; a regression that returned
//      `alias.name` here would break every qualified-name lookup.
//   5. Unqual("") — empty name is total (returned by rdr_from_dotted with
//      trailing-dot input); pin the empty-string round-trip behavior.
import * as test_assert from "std:test/assert"
import { RdrName, Unqual, Qual } from "src/common/ast.nx"
import * as rdrname from "src/ir/rdrname.nx"

let body = fn () -> unit throws { Exn } do
  // (1) Unqual to_string.
  let u = Unqual(name: "myfn")
  test_assert.assert_eq_string(actual: rdrname.rdr_to_string(r: u),
    expected: "myfn", label: "rdr_to_string: Unqual returns the bare name")

  // (2) Unqual occ.
  test_assert.assert_eq_string(actual: rdrname.rdr_occ(r: u),
    expected: "myfn", label: "rdr_occ: Unqual returns the bare name (or-pattern arm)")

  // (3) Qual to_string concatenates with a dot.
  let q = Qual(alias: "pkg", name: "ident")
  test_assert.assert_eq_string(actual: rdrname.rdr_to_string(r: q),
    expected: "pkg.ident", label: "rdr_to_string: Qual concatenates alias.name")

  // (4) Qual occ discards the alias — the load-bearing distinction.
  test_assert.assert_eq_string(actual: rdrname.rdr_occ(r: q),
    expected: "ident", label: "rdr_occ: Qual returns name only (alias dropped)")

  // (5) Empty-name total behavior.
  let empty = Unqual(name: "")
  test_assert.assert_eq_string(actual: rdrname.rdr_to_string(r: empty),
    expected: "", label: "rdr_to_string: Unqual empty name is empty string")
  test_assert.assert_eq_string(actual: rdrname.rdr_occ(r: empty),
    expected: "", label: "rdr_occ: Unqual empty name is empty string")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
