/**
 * Per-module constructor index: same-named constructors declared in distinct
 * modules must resolve to their OWN module's definition, never to an unrelated
 * module's same-named constructor.
 *
 * The flat `by_variant` map keys constructors by bare name, so two enums that
 * share a constructor name across modules collide there (first-defined wins).
 * `build_module_variant_index` keeps one scope per declaring module;
 * `lookup_variant_info_scoped(_, module: M, variant: c)` resolves `c` against
 * M's own enums first and only then the program-wide fallback. This pins that
 * behaviour using two `Diagnostic` constructors of different arity declared in
 * two different modules.
 */

import * as test_assert from "std:test/assert"
import { Option, Some, None } from "std:option"
import {
  build_module_variant_index, lookup_variant_info_scoped,
  lookup_variant_info_own_module, VariantInfo
} from "src/ir/support/variant_index.nx"
import { EnumDef, VariantDef, VariantField, TyString } from "src/types/type_expr.nx"

let enum_a = fn () -> EnumDef do
  return EnumDef(
    name: "MarkA",
    is_public: true,
    is_opaque: false,
    type_params: [],
    variants: [
      VariantDef(name: "Diagnostic", fields: [
        VariantField(name: Some(val: "a"), typ: TyString),
        VariantField(name: Some(val: "b"), typ: TyString)
      ])
    ],
    layout_variants: [],
    module: "mod_a.nx"
  )
end

let enum_b = fn () -> EnumDef do
  return EnumDef(
    name: "MarkB",
    is_public: true,
    is_opaque: false,
    type_params: [],
    variants: [
      VariantDef(name: "Diagnostic", fields: [
        VariantField(name: Some(val: "x"), typ: TyString)
      ])
    ],
    layout_variants: [],
    module: "mod_b.nx"
  )
end

let list_len = fn (xs: [ VariantField ]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + list_len(xs: rest)
  end
end

let arity_of = fn (vi: VariantInfo) -> i64 do
  let VariantInfo(enum_name: _, type_params: _, def: VariantDef(name: _, fields: fs)) = vi
  return list_len(xs: fs)
end

let owner_of = fn (vi: VariantInfo) -> string do
  let VariantInfo(enum_name: en, type_params: _, def: _) = vi
  return en
end

let main = fn () -> unit throws { Exn } do
  let mvi = build_module_variant_index(defs: [ enum_a(), enum_b() ])

  match lookup_variant_info_scoped(mvi, module: "mod_a.nx", variant: "Diagnostic") do
    | Some(val: vi) ->
      test_assert.assert_eq_string(actual: owner_of(vi), expected: "MarkA", label: "module A owner")
      test_assert.assert_eq_i64(actual: arity_of(vi), expected: 2, label: "module A arity")
    | None -> test_assert.assert(cond: false, label: "module A: Diagnostic should resolve")
  end

  match lookup_variant_info_scoped(mvi, module: "mod_b.nx", variant: "Diagnostic") do
    | Some(val: vi) ->
      test_assert.assert_eq_string(actual: owner_of(vi), expected: "MarkB", label: "module B owner")
      test_assert.assert_eq_i64(actual: arity_of(vi), expected: 1, label: "module B arity")
    | None -> test_assert.assert(cond: false, label: "module B: Diagnostic should resolve")
  end

  match lookup_variant_info_scoped(mvi, module: "unrelated.nx", variant: "Diagnostic") do
    | Some(_) -> ()
    | None -> test_assert.assert(cond: false, label: "fallback: Diagnostic should resolve via global")
  end

  match lookup_variant_info_own_module(mvi, module: "mod_a.nx", variant: "Diagnostic") do
    | Some(val: vi) ->
      test_assert.assert_eq_string(actual: owner_of(vi), expected: "MarkA", label: "own-module A owner")
      test_assert.assert_eq_i64(actual: arity_of(vi), expected: 2, label: "own-module A arity")
    | None -> test_assert.assert(cond: false, label: "own-module A: Diagnostic should resolve")
  end

  match lookup_variant_info_own_module(mvi, module: "mod_b.nx", variant: "Diagnostic") do
    | Some(val: vi) ->
      test_assert.assert_eq_i64(actual: arity_of(vi), expected: 1, label: "own-module B arity")
    | None -> test_assert.assert(cond: false, label: "own-module B: Diagnostic should resolve")
  end

  match lookup_variant_info_own_module(mvi, module: "unrelated.nx", variant: "Diagnostic") do
    | Some(_) ->
      test_assert.assert(cond: false, label: "own-module unrelated: must NOT leak another module's ctor")
    | None -> ()
  end

  match lookup_variant_info_own_module(mvi, module: "mod_a.nx", variant: "Absent") do
    | Some(_) ->
      test_assert.assert(cond: false, label: "own-module: unknown ctor must not resolve")
    | None -> ()
  end

  return ()
end
