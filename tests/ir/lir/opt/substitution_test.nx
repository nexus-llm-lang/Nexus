// Unit tests for src/ir/lir/opt/substitution.nx::opt_subst_atom /
// opt_subst_expr.
//
// Pinned correctness-critical edges:
//   1. opt_subst_atom: variable hit → replaced with recorded atom.
//   2. opt_subst_atom: variable miss → returned unchanged.
//   3. opt_subst_atom: non-variable atom (literal) → returned unchanged.
//   4. opt_subst_atom: shadowing — first matching entry wins (head of list),
//      a later entry for the same name is never consulted.
//   5. opt_subst_expr: LirExprAtom with variable → substituted.
//   6. opt_subst_expr: LirExprBinary — both operands substituted independently.
//   7. opt_subst_expr: no shadowing capture — a substitution for name "x"
//      does NOT replace an occurrence of a DIFFERENT variable "y" even when
//      both appear in the subst list.
import * as test_assert from "std:test/assert"
import { LirExpr, LirAtom } from "src/ir/lir/types.nx"
import { opt_subst_atom, opt_subst_expr } from "src/ir/lir/opt/substitution.nx"
import { OptSubstEntry } from "src/ir/lir/opt/helpers.nx"
import { TyI64, TyBool } from "src/types/type_expr.nx"
import { OpAdd } from "src/types/vocab.nx"

let body = fn () -> unit throws { Exn } do
  // ── case 1: variable hit ──
  let subst1 = [ OptSubstEntry(name: "x", atom: LirAtomInt(val: 42)) ]
  let atom_x = LirAtomVar(name: "x", typ: TyI64)
  let result1 = opt_subst_atom(atom: atom_x, subst: subst1)
  match result1 do
    | LirAtomInt(val: v) ->
      test_assert.assert_eq_i64(actual: v, expected: 42,
        label: "subst_atom: variable hit → replaced with recorded atom")
    | _ ->
      test_assert.assert_true(cond: false,
        label: "subst_atom: variable hit → wrong atom kind")
  end

  // ── case 2: variable miss → unchanged ──
  let atom_y = LirAtomVar(name: "y", typ: TyI64)
  let result2 = opt_subst_atom(atom: atom_y, subst: subst1)
  match result2 do
    | LirAtomVar(name: n, typ: _) ->
      test_assert.assert_eq_string(actual: n, expected: "y",
        label: "subst_atom: variable miss → returned unchanged")
    | _ ->
      test_assert.assert_true(cond: false,
        label: "subst_atom: variable miss → wrong result kind")
  end

  // ── case 3: literal atom → unchanged ──
  let lit = LirAtomInt(val: 99)
  let result3 = opt_subst_atom(atom: lit, subst: subst1)
  match result3 do
    | LirAtomInt(val: v) ->
      test_assert.assert_eq_i64(actual: v, expected: 99,
        label: "subst_atom: literal atom returned unchanged")
    | _ ->
      test_assert.assert_true(cond: false,
        label: "subst_atom: literal atom → wrong result kind")
  end

  // ── case 4: shadowing — first (head) entry wins ──
  // Two entries for name "z": head maps to 10, tail maps to 20.
  // Result must be 10 (head-of-list LIFO convention).
  let subst4 = [
    OptSubstEntry(name: "z", atom: LirAtomInt(val: 10)),
    OptSubstEntry(name: "z", atom: LirAtomInt(val: 20))
  ]
  let atom_z = LirAtomVar(name: "z", typ: TyI64)
  let result4 = opt_subst_atom(atom: atom_z, subst: subst4)
  match result4 do
    | LirAtomInt(val: v) ->
      test_assert.assert_eq_i64(actual: v, expected: 10,
        label: "subst_atom: shadowing — first entry wins, second skipped")
    | _ ->
      test_assert.assert_true(cond: false,
        label: "subst_atom: shadowing → wrong result kind")
  end

  // ── case 5: opt_subst_expr: LirExprAtom with variable ──
  let subst5 = [ OptSubstEntry(name: "a", atom: LirAtomBool(val: true)) ]
  let expr5 = LirExprAtom(atom: LirAtomVar(name: "a", typ: TyBool))
  let result5 = opt_subst_expr(expr: expr5, subst: subst5)
  match result5 do
    | LirExprAtom(atom: LirAtomBool(val: v)) ->
      test_assert.assert_eq_bool(actual: v, expected: true,
        label: "subst_expr: LirExprAtom variable → substituted")
    | _ ->
      test_assert.assert_true(cond: false,
        label: "subst_expr: LirExprAtom variable → wrong result")
  end

  // ── case 6: opt_subst_expr: LirExprBinary — both operands substituted ──
  let subst6 = [
    OptSubstEntry(name: "p", atom: LirAtomInt(val: 3)),
    OptSubstEntry(name: "q", atom: LirAtomInt(val: 7))
  ]
  let expr6 = LirExprBinary(
    op: OpAdd,
    lhs: LirAtomVar(name: "p", typ: TyI64),
    rhs: LirAtomVar(name: "q", typ: TyI64),
    typ: TyI64
  )
  let result6 = opt_subst_expr(expr: expr6, subst: subst6)
  match result6 do
    | LirExprBinary(op: _, lhs: l, rhs: r, typ: _) ->
      match l do
        | LirAtomInt(val: lv) ->
          test_assert.assert_eq_i64(actual: lv, expected: 3,
            label: "subst_expr: binary lhs substituted to 3")
        | _ ->
          test_assert.assert_true(cond: false, label: "subst_expr: binary lhs wrong kind")
      end
      match r do
        | LirAtomInt(val: rv) ->
          test_assert.assert_eq_i64(actual: rv, expected: 7,
            label: "subst_expr: binary rhs substituted to 7")
        | _ ->
          test_assert.assert_true(cond: false, label: "subst_expr: binary rhs wrong kind")
      end
    | _ ->
      test_assert.assert_true(cond: false, label: "subst_expr: binary → wrong result kind")
  end

  // ── case 7: no cross-variable capture ──
  // subst has entry for "x" only. Variable "y" in lhs must NOT be substituted.
  let subst7 = [ OptSubstEntry(name: "x", atom: LirAtomInt(val: 100)) ]
  let expr7 = LirExprBinary(
    op: OpAdd,
    lhs: LirAtomVar(name: "y", typ: TyI64),
    rhs: LirAtomVar(name: "x", typ: TyI64),
    typ: TyI64
  )
  let result7 = opt_subst_expr(expr: expr7, subst: subst7)
  match result7 do
    | LirExprBinary(op: _, lhs: l7, rhs: r7, typ: _) ->
      match l7 do
        | LirAtomVar(name: n7, typ: _) ->
          test_assert.assert_eq_string(actual: n7, expected: "y",
            label: "subst_expr: non-matching var y unchanged")
        | _ ->
          test_assert.assert_true(cond: false,
            label: "subst_expr: non-matching var y should remain LirAtomVar")
      end
      match r7 do
        | LirAtomInt(val: rv7) ->
          test_assert.assert_eq_i64(actual: rv7, expected: 100,
            label: "subst_expr: matching var x substituted to 100")
        | _ ->
          test_assert.assert_true(cond: false,
            label: "subst_expr: matching var x should be substituted")
      end
    | _ ->
      test_assert.assert_true(cond: false, label: "subst_expr: no-cross-capture → wrong result kind")
  end

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
