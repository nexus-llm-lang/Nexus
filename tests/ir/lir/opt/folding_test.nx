// Unit tests for src/ir/lir/opt/folding.nx::opt_fold_expr.
//
// Pinned correctness-critical edges:
//   1. div-by-zero: opt_fold_int_binary returns None → expression preserved, trap not elided.
//   2. mod-by-zero: same treatment.
//   3. identity rewrites: x+0→x, 0+x→x, x-0→x, x*1→x, 1*x→x, x/1→x.
//   4. absorbing element: x*0→0, 0*x→0.
//   5. const int folding: folded to a single LirAtomInt.
//   6. const bool folding via OpAnd/OpOr.
//   7. string concat folding.
//   8. non-binary expression: returned unchanged.
import * as test_assert from "std:test/assert"
import { LirExpr, LirAtom } from "src/ir/lir/types.nx"
import { opt_fold_expr } from "src/ir/lir/opt/folding.nx"
import { TyI64, TyBool, TyString } from "src/types/type_expr.nx"
import { OpAdd, OpSub, OpMul, OpDiv, OpMod, OpAnd, OpOr, OpConcat } from "src/types/vocab.nx"

// Assert that opt_fold_expr on a binary expression yields LirExprAtom with the expected atom.
let assert_folds_to_atom = fn (
  expr: LirExpr,
  expected_atom: LirAtom,
  label: string
) -> unit throws { Exn } do
  let result = opt_fold_expr(expr)
  match result do
    | LirExprAtom(atom: a) ->
      match a do
        | LirAtomInt(val: v) ->
          match expected_atom do
            | LirAtomInt(val: ev) ->
              test_assert.assert_eq_i64(actual: v, expected: ev, label)
            | _ ->
              test_assert.assert_true(cond: false, label: label ++ ": expected atom kind mismatch (expected non-int)")
          end
        | LirAtomBool(val: v) ->
          match expected_atom do
            | LirAtomBool(val: ev) ->
              test_assert.assert_eq_bool(actual: v, expected: ev, label)
            | _ ->
              test_assert.assert_true(cond: false, label: label ++ ": expected atom kind mismatch (expected non-bool)")
          end
        | LirAtomString(val: v) ->
          match expected_atom do
            | LirAtomString(val: ev) ->
              test_assert.assert_eq_string(actual: v, expected: ev, label)
            | _ ->
              test_assert.assert_true(cond: false, label: label ++ ": expected atom kind mismatch (expected non-string)")
          end
        | _ ->
          test_assert.assert_true(cond: false, label: label ++ ": unexpected atom variant")
      end
    | _ ->
      test_assert.assert_true(cond: false, label: label ++ ": expected LirExprAtom, got non-atom expr")
  end
  return ()
end

// Assert that opt_fold_expr returns the same binary expression (no folding).
let assert_not_folded = fn (expr: LirExpr, label: string) -> unit throws { Exn } do
  let result = opt_fold_expr(expr)
  match result do
    | LirExprBinary(op: _, lhs: _, rhs: _, typ: _) ->
      test_assert.assert_true(cond: true, label)
    | LirExprAtom(_) ->
      test_assert.assert_true(cond: false, label: label ++ ": expected no folding but got atom")
    | _ ->
      test_assert.assert_true(cond: false, label: label ++ ": expected binary or atom")
  end
  return ()
end

let body = fn () -> unit throws { Exn } do
  // ── case 1: div-by-zero is NOT folded (trap preserved) ──
  let div_zero = LirExprBinary(
    op: OpDiv,
    lhs: LirAtomInt(val: 42),
    rhs: LirAtomInt(val: 0),
    typ: TyI64
  )
  assert_not_folded(expr: div_zero, label: "div-by-zero: expression preserved (trap not elided)")

  // ── case 2: mod-by-zero is NOT folded ──
  let mod_zero = LirExprBinary(
    op: OpMod,
    lhs: LirAtomInt(val: 10),
    rhs: LirAtomInt(val: 0),
    typ: TyI64
  )
  assert_not_folded(expr: mod_zero, label: "mod-by-zero: expression preserved (trap not elided)")

  // ── case 3: identity rewrites ──

  // x + 0 → x
  let x_plus_zero = LirExprBinary(
    op: OpAdd,
    lhs: LirAtomInt(val: 7),
    rhs: LirAtomInt(val: 0),
    typ: TyI64
  )
  assert_folds_to_atom(expr: x_plus_zero, expected_atom: LirAtomInt(val: 7),
    label: "identity: x+0 → x")

  // 0 + x → x
  let zero_plus_x = LirExprBinary(
    op: OpAdd,
    lhs: LirAtomInt(val: 0),
    rhs: LirAtomInt(val: 5),
    typ: TyI64
  )
  assert_folds_to_atom(expr: zero_plus_x, expected_atom: LirAtomInt(val: 5),
    label: "identity: 0+x → x")

  // x - 0 → x
  let x_minus_zero = LirExprBinary(
    op: OpSub,
    lhs: LirAtomInt(val: 9),
    rhs: LirAtomInt(val: 0),
    typ: TyI64
  )
  assert_folds_to_atom(expr: x_minus_zero, expected_atom: LirAtomInt(val: 9),
    label: "identity: x-0 → x")

  // x * 1 → x
  let x_times_one = LirExprBinary(
    op: OpMul,
    lhs: LirAtomInt(val: 13),
    rhs: LirAtomInt(val: 1),
    typ: TyI64
  )
  assert_folds_to_atom(expr: x_times_one, expected_atom: LirAtomInt(val: 13),
    label: "identity: x*1 → x")

  // 1 * x → x
  let one_times_x = LirExprBinary(
    op: OpMul,
    lhs: LirAtomInt(val: 1),
    rhs: LirAtomInt(val: 11),
    typ: TyI64
  )
  assert_folds_to_atom(expr: one_times_x, expected_atom: LirAtomInt(val: 11),
    label: "identity: 1*x → x")

  // x / 1 → x
  let x_div_one = LirExprBinary(
    op: OpDiv,
    lhs: LirAtomInt(val: 15),
    rhs: LirAtomInt(val: 1),
    typ: TyI64
  )
  assert_folds_to_atom(expr: x_div_one, expected_atom: LirAtomInt(val: 15),
    label: "identity: x/1 → x")

  // ── case 4: absorbing element ──

  // x * 0 → 0
  let x_times_zero = LirExprBinary(
    op: OpMul,
    lhs: LirAtomInt(val: 99),
    rhs: LirAtomInt(val: 0),
    typ: TyI64
  )
  assert_folds_to_atom(expr: x_times_zero, expected_atom: LirAtomInt(val: 0),
    label: "absorbing: x*0 → 0")

  // 0 * x → 0
  let zero_times_x = LirExprBinary(
    op: OpMul,
    lhs: LirAtomInt(val: 0),
    rhs: LirAtomInt(val: 42),
    typ: TyI64
  )
  assert_folds_to_atom(expr: zero_times_x, expected_atom: LirAtomInt(val: 0),
    label: "absorbing: 0*x → 0")

  // ── case 5: const int folding ──
  let three_plus_four = LirExprBinary(
    op: OpAdd,
    lhs: LirAtomInt(val: 3),
    rhs: LirAtomInt(val: 4),
    typ: TyI64
  )
  assert_folds_to_atom(expr: three_plus_four, expected_atom: LirAtomInt(val: 7),
    label: "const folding: 3+4 → 7")

  let six_div_two = LirExprBinary(
    op: OpDiv,
    lhs: LirAtomInt(val: 6),
    rhs: LirAtomInt(val: 2),
    typ: TyI64
  )
  assert_folds_to_atom(expr: six_div_two, expected_atom: LirAtomInt(val: 3),
    label: "const folding: 6/2 → 3")

  let ten_mod_three = LirExprBinary(
    op: OpMod,
    lhs: LirAtomInt(val: 10),
    rhs: LirAtomInt(val: 3),
    typ: TyI64
  )
  assert_folds_to_atom(expr: ten_mod_three, expected_atom: LirAtomInt(val: 1),
    label: "const folding: 10 mod 3 → 1")

  // ── case 6: bool folding ──

  // true && false → false
  let true_and_false = LirExprBinary(
    op: OpAnd,
    lhs: LirAtomBool(val: true),
    rhs: LirAtomBool(val: false),
    typ: TyBool
  )
  assert_folds_to_atom(expr: true_and_false, expected_atom: LirAtomBool(val: false),
    label: "bool folding: true && false → false")

  // false || true → true
  let false_or_true = LirExprBinary(
    op: OpOr,
    lhs: LirAtomBool(val: false),
    rhs: LirAtomBool(val: true),
    typ: TyBool
  )
  assert_folds_to_atom(expr: false_or_true, expected_atom: LirAtomBool(val: true),
    label: "bool folding: false || true → true")

  // bool identity: true && x → x
  let true_and_x = LirExprBinary(
    op: OpAnd,
    lhs: LirAtomBool(val: true),
    rhs: LirAtomBool(val: false),
    typ: TyBool
  )
  assert_folds_to_atom(expr: true_and_x, expected_atom: LirAtomBool(val: false),
    label: "bool identity: true && false → false (rhs returned)")

  // bool absorbing: false && x → false
  let false_and_x = LirExprBinary(
    op: OpAnd,
    lhs: LirAtomBool(val: false),
    rhs: LirAtomBool(val: true),
    typ: TyBool
  )
  assert_folds_to_atom(expr: false_and_x, expected_atom: LirAtomBool(val: false),
    label: "bool absorbing: false && x → false")

  // ── case 7: string concat folding ──
  let hello_world = LirExprBinary(
    op: OpConcat,
    lhs: LirAtomString(val: "hello"),
    rhs: LirAtomString(val: " world"),
    typ: TyString
  )
  assert_folds_to_atom(expr: hello_world, expected_atom: LirAtomString(val: "hello world"),
    label: "string folding: \"hello\" ++ \" world\" → \"hello world\"")

  // ── case 8: non-binary expression returned unchanged ──
  let atom_expr = LirExprAtom(atom: LirAtomInt(val: 42))
  let result8 = opt_fold_expr(expr: atom_expr)
  match result8 do
    | LirExprAtom(atom: LirAtomInt(val: v)) ->
      test_assert.assert_eq_i64(actual: v, expected: 42,
        label: "non-binary: atom expr returned unchanged")
    | _ ->
      test_assert.assert_true(cond: false, label: "non-binary: atom expr shape changed")
  end

  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
