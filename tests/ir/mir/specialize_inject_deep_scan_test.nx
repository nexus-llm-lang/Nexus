// nexus-rj4n: iterative deep-scan for inject-handler specialization analysis.
//
// The old shallow scan only visited top-level statements and missed call sites
// nested inside MirIf then/else bodies, MirMatch arms, MirWhile bodies, and
// MirStmtTry bodies.  This test verifies that the new iterative worklist walk
// correctly counts __handler_* call sites at arbitrary nesting depths.
//
// Test structure:
//   fn1: flat __handler_a() at top level  → 1 specialized, 1 total
//   fn2: __handler_b() inside MirIf then-body  → 1 specialized, 1 total
//   fn3: __handler_c() inside MirMatch arm body  → 1 specialized, 1 total
//   fn4: __handler_d() inside MirWhile body  → 1 specialized, 1 total
//   fn5: __handler_e() inside MirStmtTry body  → 1 specialized, 1 total
//   fn6: non-handler regular_call() at top level → 0 specialized, 1 total
//   fn7: __handler_f() nested 2 levels deep (if inside match arm) → 1 spec, 1 total
//
// Expected totals: specialized = 6, total_calls = 7
import * as test_assert from "std:test/assert"
import * as str from "std:str"
import { analyze_specialization, SpecializeResult } from "src/ir/mir/specialize_inject.nx"
import {
  MirProgram,
  MirFunction,
  MirStmt,
  MirExpr,
  MirCallArg,
  MirMatchCase,
  MirPattern
} from "src/ir/mir/types.nx"
import { TypeExpr, Literal } from "src/syntax/ast.nx"
import { None, Some } from "std:option"
import { mk_mir_fn } from "tests/_fixtures/mir.nx"

let dummy_ty = fn () -> TypeExpr do
  return TyUnit
end

let make_handler_call = fn (suffix: string) -> MirExpr do
  return MirCall(func: str.concat(a: "__handler_", b: suffix), args: [], ret_type: dummy_ty())
end

let make_plain_call = fn (name: string) -> MirExpr do
  return MirCall(func: name, args: [], ret_type: dummy_ty())
end

let make_fn = fn (name: string, body: [ MirStmt ]) -> MirFunction do
  return mk_mir_fn(name, ret_type: dummy_ty(), body)
end

let body = fn () -> unit throws { Exn } do
  // fn1: top-level handler call
  let fn1 = make_fn(name: "fn1", body: [ MirStmtExpr(expr: make_handler_call(suffix: "a")) ])

  // fn2: handler call inside MirIf then-body
  let then_stmts_fn2 = [ MirStmtExpr(expr: make_handler_call(suffix: "b")) ]
  let if_expr_fn2 = MirIf(
    cond: MirLiteral(lit: LitBool(val: true)),
    then_body: then_stmts_fn2,
    else_body: None
  )
  let fn2 = make_fn(name: "fn2", body: [ MirStmtExpr(expr: if_expr_fn2) ])

  // fn3: handler call inside MirMatch arm body
  let arm_body_fn3 = [ MirStmtExpr(expr: make_handler_call(suffix: "c")) ]
  let match_case_fn3 = MirMatchCase(pattern: MirPatWildcard, body: arm_body_fn3)
  let match_expr_fn3 = MirMatch(
    target: MirLiteral(lit: LitBool(val: true)),
    cases: [ match_case_fn3 ]
  )
  let fn3 = make_fn(name: "fn3", body: [ MirStmtExpr(expr: match_expr_fn3) ])

  // fn4: handler call inside MirWhile body
  let while_body_fn4 = [ MirStmtExpr(expr: make_handler_call(suffix: "d")) ]
  let while_expr_fn4 = MirWhile(cond: MirLiteral(lit: LitBool(val: false)), body: while_body_fn4)
  let fn4 = make_fn(name: "fn4", body: [ MirStmtExpr(expr: while_expr_fn4) ])

  // fn5: handler call inside MirStmtTry body
  let try_body_fn5 = [ MirStmtExpr(expr: make_handler_call(suffix: "e")) ]
  let fn5 = make_fn(name: "fn5", body: [
    MirStmtTry(body: try_body_fn5, catch_param: "_ex", catch_body: [])
  ])

  // fn6: non-handler plain call at top level
  let fn6 = make_fn(name: "fn6", body: [ MirStmtExpr(expr: make_plain_call(name: "regular_call")) ])

  // fn7: handler call nested 2 deep (MirIf inside MirMatch arm)
  let inner_if_stmts = [ MirStmtExpr(expr: make_handler_call(suffix: "f")) ]
  let inner_if = MirIf(
    cond: MirLiteral(lit: LitBool(val: true)),
    then_body: inner_if_stmts,
    else_body: None
  )
  let arm_body_fn7 = [ MirStmtExpr(expr: inner_if) ]
  let match_case_fn7 = MirMatchCase(pattern: MirPatWildcard, body: arm_body_fn7)
  let match_expr_fn7 = MirMatch(
    target: MirLiteral(lit: LitBool(val: true)),
    cases: [ match_case_fn7 ]
  )
  let fn7 = make_fn(name: "fn7", body: [ MirStmtExpr(expr: match_expr_fn7) ])

  let mir = MirProgram(functions: [ fn1, fn2, fn3, fn4, fn5, fn6, fn7 ], externals: [])
  let SpecializeResult(specialized: spec, total_calls: total) = analyze_specialization(mir: mir)

  test_assert.assert_eq_i64(actual: spec, expected: 6, label: "deep scan: specialized count = 6")
  test_assert.assert_eq_i64(actual: total, expected: 7, label: "deep scan: total_calls = 7")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
