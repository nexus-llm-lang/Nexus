// Issue nexus-byiw subset: targeted coverage for `src/ir/package.nx`
// — happy-path qualified-import resolution. `resolve_import_path` is the
// only public entry into the package resolver; it dispatches through
// `split_qualified` → `package_root` → `strip_nx_ext` to map `pkg:path`
// strings to physical filesystem paths.
//
// Edge case pinned: a well-formed `std:foo` import resolves to
// `nxlib/stdlib/foo.nx`. This is the contract spelled out at line 8 of
// package.nx ("Example: `std:stdio` resolves to `nxlib/stdlib/stdio.nx`").
// Every stdlib import in the compiler depends on this path: a regression
// that returned the wrong root, the wrong separator, or stripped/added the
// extension wrong would break every `import * as foo from "std:foo"`.
//
// Multiple sub-cases:
//   1. Top-level: `std:str` → `nxlib/stdlib/str.nx`.
//   2. Subdirectory: `std:runtime/atomic` → `nxlib/stdlib/runtime/atomic.nx`
//      (confirms `/` in `rest` is preserved verbatim).
//   3. Deeper subdir: `std:test/assert` → `nxlib/stdlib/test/assert.nx`
//      (confirms no path-flattening / no double-slash insertion).
import * as test_assert from "std:test/assert"
import * as package_mod from "src/ir/shared/package.nx"

let body = fn () -> unit throws { Exn } do
  let r1 = package_mod.resolve_import_path(path: "std:str")
  test_assert.assert_eq_string(actual: r1, expected: "nxlib/stdlib/str.nx",
    label: "resolve_import_path: top-level std:str")

  let r2 = package_mod.resolve_import_path(path: "std:runtime/atomic")
  test_assert.assert_eq_string(actual: r2, expected: "nxlib/stdlib/runtime/atomic.nx",
    label: "resolve_import_path: std:runtime/atomic preserves subdir slash")

  let r3 = package_mod.resolve_import_path(path: "std:test/assert")
  test_assert.assert_eq_string(actual: r3, expected: "nxlib/stdlib/test/assert.nx",
    label: "resolve_import_path: std:test/assert deeper subdir")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
