// Issue nexus-byiw subset: targeted coverage for `src/ir/package.nx`
// — happy-path qualified-import resolution. `resolve_import_path` is the
// only public entry into the package resolver; it dispatches through
// `split_qualified` → `package_root` → manifest_lookup / `strip_nx_ext`
// to map `pkg:path` strings to physical filesystem paths.
//
// Flat stdlib names are looked up in the manifest and redirected to their
// subdirectory.  For example `std:str` → `nxlib/stdlib/text/str.nx` (via
// the manifest entry `str → text/str`), while path-based names like
// `std:runtime/atomic` still resolve verbatim (manifest only covers flat
// names with no `/`).
//
// Multiple sub-cases:
//   1. Manifest hit: `std:str` → `nxlib/stdlib/text/str.nx`.
//   2. Subdirectory passthrough: `std:runtime/atomic` → `nxlib/stdlib/runtime/atomic.nx`
//      (has a `/`, skips manifest, resolved verbatim).
//   3. Deeper subdir passthrough: `std:test/assert` → `nxlib/stdlib/test/assert.nx`
//      (confirms no path-flattening / no double-slash insertion).
import * as test_assert from "std:test/assert"
import * as package_mod from "src/ir/shared/package.nx"

let body = fn () -> unit throws { Exn } do
  // (1) Flat name in manifest: std:str maps to the text/ subdir.
  let r1 = package_mod.resolve_import_path(path: "std:str")
  test_assert.assert_eq_string(actual: r1, expected: "nxlib/stdlib/text/str.nx",
    label: "resolve_import_path: std:str via manifest → text/str.nx")

  // (2) Path-based name (has slash): skips manifest, verbatim resolve.
  let r2 = package_mod.resolve_import_path(path: "std:runtime/atomic")
  test_assert.assert_eq_string(actual: r2, expected: "nxlib/stdlib/runtime/atomic.nx",
    label: "resolve_import_path: std:runtime/atomic preserves subdir slash")

  // (3) Deeper subdir passthrough: test/assert is not in the manifest.
  let r3 = package_mod.resolve_import_path(path: "std:test/assert")
  test_assert.assert_eq_string(actual: r3, expected: "nxlib/stdlib/test/assert.nx",
    label: "resolve_import_path: std:test/assert deeper subdir")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
