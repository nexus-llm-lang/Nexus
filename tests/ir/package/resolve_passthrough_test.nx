// Issue nexus-byiw subset: targeted coverage for `src/ir/package.nx`
// — passthrough branches of `resolve_import_path`. The contract (line 13 of
// package.nx) is "Bare paths (no `:`) flow through unchanged so file-relative
// imports continue to work."
//
// `resolve_qualified_to_file` returns "" (the trigger to fall back to the
// raw `path` argument) in four distinct conditions; each is a separate
// regression risk that a refactor could collapse incorrectly:
//
//   1. No colon at all → "src/foo.nx" must passthrough untouched. Compiler
//      imports relative to the source file rely on this.
//   2. Unknown package → "unknown:bar" must passthrough; `package_root`
//      returns "" for any non-std package, which would otherwise produce
//      a bogus "/" ++ "bar.nx" path.
//   3. Colon with empty prefix → ":foo" — split returns empty pkg, passthrough.
//   4. Colon with empty suffix → "std:" — split returns empty rest, passthrough.
//
// A regression that mis-handled any of (2)-(4) (e.g. computed `package_root("")`
// then "/" ++ "" ++ ".nx") would emit a bogus filesystem path; passthrough
// is load-bearing for error-reporting (the user sees their literal string).
import * as test_assert from "std:test/assert"
import * as package_mod from "src/ir/package.nx"

let body = fn () -> unit throws { Exn } do
  // (1) No colon: bare relative path.
  let r1 = package_mod.resolve_import_path(path: "src/foo.nx")
  test_assert.assert_eq_string(actual: r1, expected: "src/foo.nx",
    label: "resolve_import_path: bare path passthrough (no colon)")

  // (2) Unknown package.
  let r2 = package_mod.resolve_import_path(path: "unknown:bar")
  test_assert.assert_eq_string(actual: r2, expected: "unknown:bar",
    label: "resolve_import_path: unknown package passthrough")

  // (3) Empty prefix before colon.
  let r3 = package_mod.resolve_import_path(path: ":foo")
  test_assert.assert_eq_string(actual: r3, expected: ":foo",
    label: "resolve_import_path: empty pkg prefix passthrough")

  // (4) Empty suffix after colon.
  let r4 = package_mod.resolve_import_path(path: "std:")
  test_assert.assert_eq_string(actual: r4, expected: "std:",
    label: "resolve_import_path: empty rest suffix passthrough")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
