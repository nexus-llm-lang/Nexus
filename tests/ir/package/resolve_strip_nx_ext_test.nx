// Issue nexus-byiw subset: targeted coverage for `src/ir/package.nx`
// — `.nx`-extension handling in the qualified-resolver path. The private
// helper `strip_nx_ext` is exercised through `resolve_import_path`: callers
// can write either `std:str` (no extension) or `std:str.nx` (with extension)
// and must get the *same* physical path back. This is the idempotency
// invariant of the resolver.
//
// Edge case pinned: `std:str.nx` resolves to `nxlib/stdlib/str.nx`, NOT
// `nxlib/stdlib/str.nx.nx`. A naive concatenation that skipped the strip
// step would produce the double-extension path and every stdlib `.nx`
// hot-path import would fail with FileNotFound.
//
// Sub-cases:
//   1. Idempotency: with-ext and without-ext both produce the same target.
//   2. Substring (not suffix) match must NOT strip: `std:my.nxlib` (where
//      ".nx" appears as a prefix-of-suffix, not the suffix itself) must
//      keep ".nxlib" intact and append ".nx" — final: "nxlib/stdlib/my.nxlib.nx".
//      `str.ends_with` is what `strip_nx_ext` calls; a buggy "contains"
//      replacement would flunk this.
import * as test_assert from "std:test/assert"
import * as package_mod from "src/ir/package.nx"

let body = fn () -> unit throws { Exn } do
  // (1a) Without extension (canonical).
  let r1 = package_mod.resolve_import_path(path: "std:str")
  test_assert.assert_eq_string(actual: r1, expected: "nxlib/stdlib/str.nx",
    label: "resolve_import_path: std:str canonical")

  // (1b) With explicit .nx — must produce the same physical path.
  let r2 = package_mod.resolve_import_path(path: "std:str.nx")
  test_assert.assert_eq_string(actual: r2, expected: "nxlib/stdlib/str.nx",
    label: "resolve_import_path: std:str.nx idempotent with std:str")

  // (2) Substring-not-suffix: the input ends with ".nxlib" not ".nx".
  // strip_nx_ext must leave this alone, then append ".nx".
  let r3 = package_mod.resolve_import_path(path: "std:my.nxlib")
  test_assert.assert_eq_string(actual: r3, expected: "nxlib/stdlib/my.nxlib.nx",
    label: "resolve_import_path: .nx is suffix-stripped, not contains-stripped")
  return ()
end

let main = fn () -> unit throws { Exn } do
  body()
  return ()
end
