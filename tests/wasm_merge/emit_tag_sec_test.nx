// Issue nexus-byiw.1: unit-test merge.section_emit.emit_tag_sec_with_off —
// the tag-section emitter that lifts every tag's type index by `off`
// when merging dep tags into the main module's type space.
//
// Tag section body layout (id=13):
//   ULEB count
//   For each tag: ULEB(attr), ULEB(type_idx)
//
// `emit_tag_sec_with_off(out, buf, sec_pk, off)`:
//   * Short-circuits if sec_pk==0 (no tag section in dep).
//   * Else wraps output as a full section: [13, ULEB(payload_size), payload].
//   * Within payload: ULEB(count), then each (attr, type_idx + off).
//
// We assert the entire wrapped section bytes — emit_tag_sec_with_off
// is the only entry point and the output format IS the contract.
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { ByteBuffer } from "std:bytebuffer"
import { emit_tag_sec_with_off } from "src/backend/wasm/merge/section_emit.nx"
import { pack } from "src/backend/wasm/read.nx"

let read_all = fn (buf: &ByteBuffer) -> [ i64 ] do
  return read_all_go(buf, idx: 0, len: bb.length(buf), acc: [])
end
let read_all_go = fn (buf: &ByteBuffer, idx: i64, len: i64, acc: [ i64 ]) -> [ i64 ] do
  if idx >= len then return reverse(xs: acc, out: []) end
  let b = bb.get_byte(buf, idx)
  return read_all_go(buf, idx: idx + 1, len, acc: b :: acc)
end
let reverse = fn (xs: [ i64 ], out: [ i64 ]) -> [ i64 ] do
  match xs do
    | [] -> return out
    | x :: rest -> return reverse(xs: rest, out: x :: out)
  end
end

let body = fn () -> unit throws { Exn } do
  // ── case 1: sec_pk == 0 short-circuits, output untouched ──
  let %z0 = bb.empty()
  let %z_src = bb.empty()
  let %z1 = emit_tag_sec_with_off(out: %z0, buf: &z_src, sec_pk: 0, off: 99)
  let z_len = bb.length(buf: &z1)
  bb.free(buf: %z1)
  bb.free(buf: %z_src)
  test_assert.assert_eq_i64(actual: z_len, expected: 0,
    label: "emit_tag_sec_with_off: sec_pk=0 (no tag section) emits nothing")

  // ── case 2: 2 tags, attr=0 each, type_idx 3 and 7; off = 4 ──
  // Source buffer at sec_off=1 (need non-zero to dodge the short-circuit):
  //   [pad, count=2, attr=0, tidx=3, attr=0, tidx=7]
  // sec_pk = pack(val=1, p=_size_unused_).
  //
  // Expected wrapped output:
  //   [13,        // sec_id (tag = 13)
  //    5,         // ULEB(payload_len = 5)
  //    2,         // count
  //    0, 7,      // tag 0: attr=0, type_idx 3 + 4 = 7
  //    0, 11]     // tag 1: attr=0, type_idx 7 + 4 = 11
  let %b0 = bb.empty()
  let %b1 = bb.push_byte(buf: %b0, byte: 99)   // pad
  let %b2 = bb.push_byte(buf: %b1, byte: 2)    // count (at sec_off=1)
  let %b3 = bb.push_byte(buf: %b2, byte: 0)    // attr 0
  let %b4 = bb.push_byte(buf: %b3, byte: 3)    // tidx 0
  let %b5 = bb.push_byte(buf: %b4, byte: 0)    // attr 1
  let %b6 = bb.push_byte(buf: %b5, byte: 7)    // tidx 1
  let sec_pk = pack(val: 1, p: 0)
  let %o0 = bb.empty()
  let %o1 = emit_tag_sec_with_off(out: %o0, buf: &b6, sec_pk, off: 4)
  let out_bytes = read_all(buf: &o1)
  let out_len = bb.length(buf: &o1)
  bb.free(buf: %o1)
  bb.free(buf: %b6)
  test_assert.assert_eq_i64(actual: out_len, expected: 7,
    label: "emit_tag_sec_with_off: header (id + ULEB len) + 5-byte body = 7 bytes")
  test_assert.assert_eq_i64_list(actual: out_bytes,
    expected: [ 13, 5, 2, 0, 7, 0, 11 ],
    label: "emit_tag_sec_with_off: sec_id=13, ULEB(5), count=2, (0, 7), (0, 11)")

  // ── case 3: 0 tags (empty tag sec) still emits header ──
  // Source: [pad, count=0]. Output: [13, 1, 0] — sec_id, ULEB(payload=1), count=0.
  // Verifies the section wrapper still fires even when there's nothing to remap.
  let %e0 = bb.empty()
  let %e1 = bb.push_byte(buf: %e0, byte: 99)
  let %e2 = bb.push_byte(buf: %e1, byte: 0)
  let sec_pk_e = pack(val: 1, p: 0)
  let %g0 = bb.empty()
  let %g1 = emit_tag_sec_with_off(out: %g0, buf: &e2, sec_pk: sec_pk_e, off: 100)
  let g_bytes = read_all(buf: &g1)
  bb.free(buf: %g1)
  bb.free(buf: %e2)
  test_assert.assert_eq_i64_list(actual: g_bytes, expected: [ 13, 1, 0 ],
    label: "emit_tag_sec_with_off: empty tag section still emits [sec_id, ULEB(1), count=0]")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
