// Issue nexus-byiw.1: unit-test merge.section_emit.copy_imports_with_type_off —
// the import-section copier that lifts function-import type indices
// when the dep module is appended into the main module's type space.
//
// `copy_imports_with_type_off(out, buf, pos, remaining, type_off)`:
//   * For each of `remaining` imports starting at `pos`:
//     - rd_str(mod_name), rd_str(field_name) — bulk-copied verbatim
//     - byte: kind
//     - kind == 0 (func) → ULEB type_idx → emit ULEB(type_idx + type_off)
//     - kind != 0        → skip_imp_desc + copy descriptor bytes verbatim
//
// Two-import fixture: one func (kind=0) followed by one memory (kind=2)
// exercises BOTH branches in one call, plus the recursion's bookkeeping
// (the second import only gets reached if the first was decoded to the
// right byte boundary).
import * as test_assert from "std:test/assert"
import * as bb from "std:bytebuffer"
import { ByteBuffer } from "std:bytebuffer"
import { copy_imports_with_type_off } from "src/backend/wasm/merge/section_emit.nx"

let read_all = fn (buf: &ByteBuffer) -> [ i64 ] do
  return read_all_go(buf, idx: 0, len: bb.length(buf), acc: [])
end
let read_all_go = fn (buf: &ByteBuffer, idx: i64, len: i64, acc: [ i64 ]) -> [ i64 ] do
  if idx >= len then return reverse(xs: acc, out: []) end
  let b = bb.get_byte(buf, idx)
  return read_all_go(buf, idx: idx + 1, len, acc: b :: acc)
end
let reverse = fn (xs: [ i64 ], out: [ i64 ]) -> [ i64 ] do
  match xs do
    | [] -> return out
    | x :: rest -> return reverse(xs: rest, out: x :: out)
  end
end

let body = fn () -> unit throws { Exn } do
  // ── Two-import fixture ──
  // Import 1: module="a", field="b", kind=0 (func), type_idx=4
  //   bytes: [1, 'a', 1, 'b', 0, 4]
  // Import 2: module="c", field="d", kind=2 (memory), limits=(flags=0, min=1)
  //   bytes: [1, 'c', 1, 'd', 2, 0, 1]
  // Combined input (13 bytes):
  //   [1, 97, 1, 98, 0, 4, 1, 99, 1, 100, 2, 0, 1]
  //
  // With type_off = 10, expected output:
  //   Import 1 → [1, 97, 1, 98, 0, 14]  (type_idx 4 → 14)
  //   Import 2 → [1, 99, 1, 100, 2, 0, 1]  (verbatim copy of full memory import)
  // Total: 13 bytes (same length here only because 14 still fits in 1 ULEB byte).
  let %s0 = bb.empty()
  let %s1 = bb.push_byte(buf: %s0, byte: 1)
  let %s2 = bb.push_byte(buf: %s1, byte: 97)   // 'a'
  let %s3 = bb.push_byte(buf: %s2, byte: 1)
  let %s4 = bb.push_byte(buf: %s3, byte: 98)   // 'b'
  let %s5 = bb.push_byte(buf: %s4, byte: 0)    // kind=func
  let %s6 = bb.push_byte(buf: %s5, byte: 4)    // type_idx
  let %s7 = bb.push_byte(buf: %s6, byte: 1)
  let %s8 = bb.push_byte(buf: %s7, byte: 99)   // 'c'
  let %s9 = bb.push_byte(buf: %s8, byte: 1)
  let %sa = bb.push_byte(buf: %s9, byte: 100)  // 'd'
  let %sb = bb.push_byte(buf: %sa, byte: 2)    // kind=memory
  let %sc = bb.push_byte(buf: %sb, byte: 0)    // limits flags
  let %sd = bb.push_byte(buf: %sc, byte: 1)    // min
  let %o0 = bb.empty()
  let %o1 = copy_imports_with_type_off(out: %o0, buf: &sd, pos: 0, remaining: 2, type_off: 10)
  let out_bytes = read_all(buf: &o1)
  let out_len = bb.length(buf: &o1)
  bb.free(buf: %o1)
  bb.free(buf: %sd)
  test_assert.assert_eq_i64(actual: out_len, expected: 13,
    label: "copy_imports_with_type_off: 2 imports → 13 bytes (no expansion since 14 still fits in 1 ULEB byte)")
  test_assert.assert_eq_i64_list(actual: out_bytes,
    expected: [ 1, 97, 1, 98, 0, 14, 1, 99, 1, 100, 2, 0, 1 ],
    label: "copy_imports_with_type_off: func type_idx 4 lifted to 14; memory import copied verbatim")

  // ── Edge: remaining=0 short-circuits, output stays empty ──
  let %e0 = bb.empty()
  let %f0 = bb.empty()
  let %f1 = copy_imports_with_type_off(out: %f0, buf: &e0, pos: 0, remaining: 0, type_off: 99)
  let f_len = bb.length(buf: &f1)
  bb.free(buf: %f1)
  bb.free(buf: %e0)
  test_assert.assert_eq_i64(actual: f_len, expected: 0,
    label: "copy_imports_with_type_off: remaining=0 base case emits nothing")
  return ()
end

let safe_run = fn () -> i64 do
  try
    body()
    return 1
  catch _ ->
    return 0
  end
end

let main = fn () -> unit do
  let ok = safe_run()
  let _ = 1 / ok
  return ()
end
