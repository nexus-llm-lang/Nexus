// expect-fail: E2012
// expect-msg: unknown throw variant
// expect-msg: BogusVariant
//
// wfThrow (docs/spec/type-system-formal.md §1 line 116) is enforced at
// every introduction site of a throws row: the fn-arrow `throws {…}`
// on `foo` here. `BogusVariant` is neither the universal `Exn` sentinel,
// a constructor of `Exn` (no `exception BogusVariant(...)` declared
// anywhere), nor a declared exception group. Without the
// introduction-site check the typo would only surface if a downstream
// raise/catch happened to look it up — and would silently persist if
// `foo` were dead code.
//
// The pre-DCE wfThrow pass (driver.nx invokes tcwf.check_program_wf_rows
// on `hir_raw`) rejects this even though `foo` is unused: per spec line
// 112, "may never if the cap is unused" is precisely the case the
// well-formedness check is supposed to prevent.
//
// nexus-t9cl.25

let foo = fn () -> unit throws { BogusVariant } do
  return ()
end

let main = fn () -> unit do
  return ()
end
