// expect-fail: E2001
// expect-msg: missing argument
//
// Every named parameter must be supplied at the call site. The compiler
// will not silently default a missing argument — drop the omission or
// add a default-providing wrapper.

let add = fn (a: i64, b: i64) -> i64 do
  return a + b
end

let main = fn () -> unit do
  let _ = add(a: 1)
  return ()
end
