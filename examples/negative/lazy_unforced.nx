// expect-fail: E2005
// expect-msg: lazy binding
// expect-msg: never forced
//
// `@`-prefixed bindings are *lazy*: their RHS is suspended until the
// matching `@name` force-read is reached. Like `%` bindings, they must
// be observed exactly once — leaving the thunk unobserved is a leak and
// the compiler refuses.

let main = fn () -> unit do
  let @t = 1 + 1
  return ()
end
