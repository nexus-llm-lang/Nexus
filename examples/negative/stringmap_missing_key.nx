// expect-runtime-throw: before lookup
//
// `std:stringmap.get` mirrors `std:hashmap.get`: it returns the safe
// `Lookup = Found(value: i64) | Missing` ADT and never raises. The
// fixture exercises the "raise on Missing" idiom for the string-keyed
// sister map. `main` hits the throw arm because the key "dave" was
// never inserted, and the constructor surfaces as a non-zero exit at
// run time. wasmtime swallows the constructor name on stderr, so the
// runner anchors on the captured stdout line "before lookup".
//
// Idiomatic alternative: use `get_or(map, key, default)` for a safe
// fallback, or keep the `Lookup` value and pattern-match in-place.

import { Console, system_handler } from "std:stdio"
import * as sm from "std:stringmap"
import { Found, Missing } from "std:stringmap"

exception MissingKey(key: string)

let lookup_or_raise = fn (map: &StringMap, key: string) -> i64 throws { MissingKey } do
  match sm.get(map: map, key: key) do
    | Found(value: v) -> return v
    | Missing -> raise MissingKey(key: key)
  end
end

let main = fn () -> unit require { PermConsole } throws { MissingKey } do
  inject system_handler do
    let %m = sm.empty()
    let %m = sm.put(map: m, key: "alice", value: 30)
    Console.println(val: "before lookup")
    let _ = lookup_or_raise(map: &m, key: "dave")
    Console.println(val: "should never print")
    sm.free(map: m)
  end
  return ()
end
