// expect-fail: E2007
// expect-msg: linear binding
// expect-msg: never consumed
//
// A `%`-prefixed binding introduces a linear value that must be consumed
// exactly once before its lexical scope ends. Letting it fall out of
// scope without a consumer is a compile-time error — the linearity
// check rejects this fixture deterministically.

type Box = Box(val: i64)

let main = fn () -> unit do
  let %b = Box(val: 1)
  return ()
end
