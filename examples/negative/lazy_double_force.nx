// expect-fail: E2006
// expect-msg: lazy binding
// expect-msg: forced more than once
//
// The `@t` form forces a lazy binding exactly once. A thunk is at-most
// once by construction (the parallel scheduler caches the result, so
// re-reading would either re-execute or rely on memoization neither side
// agrees on). The compiler rejects a second force.

let main = fn () -> unit do
  let @t = 1 + 1
  let a = @t
  let b = @t
  return ()
end
