// expect-runtime-throw: before unwrap
//
// `std:result` does not surface its own throw — `Ok/Err` are a pure
// algebraic alternative to `throws { ... }`. The error path of a
// Result-returning API is therefore caller-driven: pattern-match on
// `Err(err: ...)` and decide whether to raise (or recover). This
// fixture demonstrates the "raise on Err" idiom: the unwrap helper
// pattern-matches and surfaces the error as an exception when the
// caller has no fallback. Compile succeeds (the throws-row is closed
// by `main`'s `throws { ResultErr }`), but execution walks the `Err`
// arm and surfaces the constructor to wasmtime as a non-zero exit.
//
// Idiomatic alternative: handle the `Err` branch in-place
// (`unwrap_or(res, default)` or a custom recovery) rather than
// re-raising.

import { Console, system_handler } from "std:stdio"
import { Ok, Err } from "std:result"

type DivErr = DivByZero | Negative

exception ResultErr(reason: string)

let checked_div = fn (a: i64, b: i64) -> Result<i64, DivErr> do
  if b == 0 then return Err(err: DivByZero) end
  if a < 0 then return Err(err: Negative) end
  return Ok(val: a / b)
end

let unwrap_or_raise = fn (res: Result<i64, DivErr>) -> i64 throws { ResultErr } do
  match res do
    | Ok(val: v) -> return v
    | Err(err: DivByZero) -> raise ResultErr(reason: "divide by zero")
    | Err(err: Negative) -> raise ResultErr(reason: "negative numerator")
  end
end

let main = fn () -> unit require { PermConsole } throws { ResultErr } do
  inject system_handler do
    Console.println(val: "before unwrap")
    let _ = unwrap_or_raise(res: checked_div(a: 10, b: 0))
    Console.println(val: "should never print")
  end
  return ()
end
