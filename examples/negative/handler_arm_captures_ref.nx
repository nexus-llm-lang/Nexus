// expect-fail: E2001
// expect-msg: handler arm captures mutable ref binding
// expect-msg: counter
// expect-msg: stack-confined
//
// Spec T-Handler (docs/spec/type-system-formal.md, line ~1122) requires
// the same no-ref-capture premise as T-Lambda:
//   ∀y ∈ ⋃_j fv(e_j) ∩ dom(Γ). Γ(y) ≠ ~σ
//
// `~counter` is a stack-confined mutable ref bound inside `main`. The
// inline `handler Greeter do fn say() ... ~counter <- ... end end`
// arm captures it. If the handler value escaped `main` (e.g. stored in
// a top-level let and later injected) the ref would dangle. T-Lambda
// rejects the analogous case ("lambda captures mutable ref binding ...");
// T-Handler must reject it too — that's the t9cl.27 fix.
//
// Implementation: src/typecheck/infer.nx scans each inline handler
// arm's body against the construction-site env via
// capture.scan_lambda_captures and converts a RefCaptureHit into the
// "handler arm captures mutable ref binding ..." diagnostic — mirroring
// infer_lambda's rejection path so the two introduction rules report
// identically-shaped errors.
//
// nexus-t9cl.27

cap Greeter do fn say() -> unit end

let main = fn () -> unit do
  let ~counter = 0
  let bad = handler Greeter do
    fn say() -> unit do
      ~counter <- ~counter + 1
      return ()
    end
  end
  return ()
end
