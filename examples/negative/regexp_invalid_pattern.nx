// expect-runtime-throw: before compile
//
// `std:regexp.from_string` raises `InvalidRegexp(src, msg)` (a member
// of the `RegexpThrow` group) when the input pattern is not
// well-formed. An unterminated character class like `"["` is the
// canonical trigger — the parser reaches end-of-input still hunting
// for the closing `]`. The fixture compiles cleanly because `main`
// widens the throws-row with `RegexpThrow`, then surfaces the
// constructor as a non-zero exit at run time. wasmtime swallows the
// constructor name on stderr, so the runner anchors on the captured
// stdout line "before compile".
//
// Idiomatic alternative: wrap the call in
// `try ... catch | InvalidRegexp(src, msg) -> ... end` to report the
// offending pattern back to the user (or back-fall to a string
// `==` comparison).

import { Console, system_handler } from "std:stdio"
import * as re from "std:regexp"
import { RegexpThrow } from "std:regexp"

let main = fn () -> unit require { PermConsole } throws { RegexpThrow } do
  inject system_handler do
    Console.println(val: "before compile")
    let _ = re.from_string(src: "[")
    Console.println(val: "should never print")
  end
  return ()
end
