import external [=[nxlib/stdlib/net.wasm]=]
let http_request = external [=[http_request]=] : (method: string, url: string, headers: string, body: string) -> string effect { Net }
let print = external [=[print]=] : (val: string) -> unit effect { IO }

let main = fn () -> unit effect { IO, Net } do
  let url = [=[https://httpbin.org/get]=]
  perform print(val: [=[Fetching URL:\n]=])
  perform print(val: url)
  perform print(val: [=[\n]=])

  let response = perform http_request(method: [=[GET]=], url: url, headers: [=[]=], body: [=[]=])
  perform print(val: [=[Received response (status\nbody):\n]=])
  perform print(val: response)

  return ()
endfn
