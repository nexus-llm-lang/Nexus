import { Net, Request, request_method, request_path }, * as net_mod from stdlib/net.nx
import { Console }, * as stdio from stdlib/stdio.nx
import { Env }, * as env_mod from stdlib/env.nx

let handle_request = fn (req: Request) -> unit require { Net, Console } throws { Exn } do
  let method = request_method(req: &req)
  let path = request_path(req: &req)
  Console.println(val: method ++ " " ++ path)

  Net.respond(req: req, status: 200, body: "Hello from Nexus!")
  return ()
end

let get_port = fn () -> string require { Env } do
  let default_port = "8080"
  let e = Env.get(key: "PORT")
  match e do
  case Some(val: p) -> return p
  case None() -> return default_port
  end
end

// Handle one request then stop
let main = fn () -> unit require { PermNet, PermConsole, PermEnv } do
  inject net_mod.system_handler, stdio.system_handler, env_mod.system_handler do
  let prt = get_port()
  let addr = "127.0.0.1:" ++ prt

  Console.println(val: "Listening on " ++ addr)

  try
    let server = Net.listen(addr: addr)
    let req = Net.accept(server: &server)
    handle_request(req: req)

    Net.stop(server: server)
    Console.println(val: "Server stopped")
  catch e ->
    Console.println(val: "Server error")
  end
  end

  return ()
end
