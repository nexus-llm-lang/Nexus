import { Net, Request, request_method, request_path }, * as net_mod from nxlib/stdlib/net.nx
import { Console }, * as stdio from nxlib/stdlib/stdio.nx

let handle_request = fn (req: Request) -> bool require { Net, Console } do
  let method = request_method(req: &req)
  let path = request_path(req: &req)
  Console.println(val: method ++ " " ++ path)

  let ok = Net.respond(req: req, status: 200, body: "Hello from Nexus!")
  return ok
end

let main = fn () -> unit require { PermNet, PermConsole } do
  inject net_mod.system_handler, stdio.system_handler do
      try
        let addr = "127.0.0.1:8080"
        Console.println(val: "Listening on " ++ addr)
        let server = Net.listen(addr: addr)

        // Handle one request then stop
        let req = Net.accept(server: &server)
        let _ = handle_request(req: req)

        Net.stop(server: server)
        Console.println(val: "Server stopped")
      catch e ->
        Console.println(val: "Server error")
      end
  end

  return ()
end
