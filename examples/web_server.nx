import { default_net, Net, Request } from nxlib/stdlib/net.nx
import { request_method, request_path } from nxlib/stdlib/net.nx
import as stdio from nxlib/stdlib/stdio.nx

let handle_request = fn (req: Request) -> bool require { Net } effect { Console } do
  let method = request_method(req: &req)
  let path = request_path(req: &req)
  stdio.println(val: method ++ [=[ ]=] ++ path)

  let ok = Net.respond(req: req, status: 200, body: [=[Hello from Nexus!]=])
  return ok
endfn

let main = fn () -> unit effect { Console } do
  inject default_net do
    try
      let addr = [=[127.0.0.1:8080]=]
      stdio.println(val: [=[Listening on ]=] ++ addr)
      let server = Net.listen(addr: addr)

      // Handle one request then stop
      let req = Net.accept(server: &server)
      let _ = handle_request(req: req)

      Net.stop(server: server)
      stdio.println(val: [=[Server stopped]=])
    catch e ->
      stdio.println(val: [=[Server error]=])
    endtry
  endinject

  return ()
endfn
