import as fs from nxlib/stdlib/fs.nx
import as stdio from nxlib/stdlib/stdio.nx

// --- Port Definition (Interface) ---
port Logger do
    fn info(msg: string) -> unit effect { Console }
endport

// --- Business Logic ---
let greet = fn (name: string) -> unit require { Logger } effect { Console } do
    Logger.info(msg: [=[Greeting ]=] ++ name)
    stdio.println(val: [=[Hello, ]=] ++ name ++ [=[!]=])
    return ()
endfn

let console_logger = handler Logger do
    fn info(msg: string) -> unit effect { Console } do
        stdio.println(val: [=[[INFO] ]=] ++ msg)
        return ()
    endfn
endhandler

let main = fn () -> unit effect { Console } do
    stdio.println(val: [=[--- Using ConsoleLogger ---]=])
    inject console_logger do
        greet(name: [=[Nexus User]=])
    endinject
    return ()
endfn
