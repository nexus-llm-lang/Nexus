import as fs from [=[nxlib/stdlib/fs.nx]=]
import as stdio from [=[nxlib/stdlib/stdio.nx]=]

// --- Port Definition (Interface) ---
port Logger do
    fn info(msg: string) -> unit effect { IO }
endport

// --- Business Logic ---
let greet = fn (name: string) -> unit effect { IO } do
    let msg = [=[Greeting ]=] ++ name
    perform Logger.info(msg: msg)
    let msg = [=[Hello, ]=] ++ name ++ [=[!]=]
    perform stdio.print(val: msg)
    return ()
endfn

// --- Handler 1: Console Logger ---
handler ConsoleLogger for Logger do
    fn info(msg: string) -> unit effect { IO } do
        let val = [=[[INFO] ]=] ++ msg
        perform stdio.print(val: val)
        return ()
    endfn
endhandler

// --- Handler 2: File Logger ---
handler FileLogger for Logger do
    fn info(msg: string) -> unit effect { IO } do
        let content = [=[INFO: ]=] ++ msg ++ [=[\n]=]
        let _ = perform fs.write_string(path: [=[app.log]=], content: content)
        return ()
    endfn
endhandler

let main = fn () -> unit effect { IO } do
    perform stdio.print(val: [=[--- Using FileLogger (last defined) ---]=])
    perform greet(name: [=[Nexus User]=])
    return ()
endfn
