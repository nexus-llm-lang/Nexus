import as stdio from [=[nxlib/stdlib/stdio.nx]=]
import as result from [=[nxlib/stdlib/result.nx]=]

// --- Type Definitions ---
type User = {
  id: i64,
  name: string,
  email: string
}

// --- Port Definition ---
port UserRepository do
  fn exists(email: string) -> Result<bool, string> effect { IO }
  fn create(u: User) -> Result<unit, string> effect { IO }
endport

// --- Main Logic ---
pub let register_user = fn (name: string, email: string) -> Result<unit, string> effect { IO, Net } do
  conc do
    task audit_log effect { IO } do
       let msg = [=[Registration started: ]=] ++ email
       perform stdio.print(val: msg)
    endtask
  endconc

  let exists_res = perform UserRepository.exists(email: email)

  match exists_res do
    case Err(err: msg) ->
      return Err(err: msg)
    
    case Ok(val: is_exists) ->
      if is_exists then
        return Err(err: [=[User already exists]=])
      else
        ()
      endif
  endmatch

  let new_user = {
    id: 0,
    name: name,
    email: email
  }

  return perform UserRepository.create(u: new_user)
endfn
