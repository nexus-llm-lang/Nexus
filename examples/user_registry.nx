import { Console }, * as stdio from "stdlib/stdio.nx"
import * as result from "stdlib/result.nx"

// --- Type Definitions ---
type User = {
  id: i64,
  name: string,
  email: string
}

cap Logger do
  fn log(msg: string) -> unit
end

// --- Port Definition ---
cap UserRepository do
  fn exists(email: string) -> Result<bool, string>
  fn create(u: User) -> Result<unit, string>
end

// --- Main Logic ---
let register_user = fn (name: string, email: string) -> Result<unit, string> require { UserRepository, Logger } do
  Logger.log(msg: "Registration started: " ++ email)

  let exists_res = UserRepository.exists(email: email)

  match exists_res do
  | Err(err: msg) ->
    return Err(err: msg)

  | Ok(val: is_exists) ->
    if is_exists then
    return Err(err: "User already exists")
    else
    ()
    end
  end

  let new_user = {
  id: 0,
  name: name,
  email: email
  }

  return UserRepository.create(u: new_user)
end
