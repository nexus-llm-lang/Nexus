import as net from [=[nxlib/stdlib/net.nx]=]

let main = fn () -> unit effect { IO, Net } do
  let url = [=[https://httpbin.org/get]=]
  let body = perform net.get(url: url)
  perform net.print(val: [=[GET ]=])
  perform net.print(val: url)
  perform net.print(val: [=[\n]=])
  perform net.print(val: body)

  return ()
endfn
