/**
 * bench_parallel: demonstrates `std:lazy`'s parallel `force_all`.
 *
 * Eight independent CPU-bound thunks (a long pure-i64 mixing loop, no
 * allocation) are forced two ways:
 *   - in parallel via `lazy.force_all` — each thunk runs on its own OS thread
 *     (WASI threads), so the eight forces overlap;
 *   - sequentially — the same eight computations one after another.
 * Both branches print their wall-clock cost (Clock.now() is ms-since-epoch)
 * and we report the ratio. On a multi-core box the parallel branch should be
 * several times faster; the result-check value confirms both branches compute
 * the same thing.
 *
 * Run via the bundled `nexus` launcher (or `wasmtime -W threads=y,shared-memory=y -S threads`).
 */
import { Console, system_handler } from "std:stdio"
import { Clock, system_handler as clock_handler } from "std:clock"
import * as lazy from "std:lazy"
import * as str from "std:str"

/// `iters` rounds of a self-feeding LCG-style mixing step. Pure i64, no
/// allocation; the result depends on every iteration so it cannot be folded
/// away. Tail-recursive (lowers to a loop).
let hash_loop = fn (seed: i64, iters: i64) -> i64 do
  return hash_go(acc: seed, i: 0, n: iters)
end
let hash_go = fn (acc: i64, i: i64, n: i64) -> i64 do
  if i >= n then return acc end
  let nx = ((acc * 6364136223846793005) + 1442695040888963407) + i
  return hash_go(acc: nx, i: i + 1, n)
end

let iters = fn () -> i64 do return 80000000 end

let main = fn () -> unit require { PermConsole, PermClock } do
  inject clock_handler do
  inject system_handler do
    let seed = Clock.now()
    let n = iters()

    let @t0 = hash_loop(seed: seed, iters: n)
    let @t1 = hash_loop(seed: seed + 1, iters: n)
    let @t2 = hash_loop(seed: seed + 2, iters: n)
    let @t3 = hash_loop(seed: seed + 3, iters: n)
    let @t4 = hash_loop(seed: seed + 4, iters: n)
    let @t5 = hash_loop(seed: seed + 5, iters: n)
    let @t6 = hash_loop(seed: seed + 6, iters: n)
    let @t7 = hash_loop(seed: seed + 7, iters: n)
    let p_start = Clock.now()
    let rs = lazy.force_all(tasks: [t0, t1, t2, t3, t4, t5, t6, t7])
    let p_end = Clock.now()
    let p_check = xor_list(xs: rs, acc: 0)

    let s_start = Clock.now()
    let s0 = hash_loop(seed: seed, iters: n)
    let s1 = hash_loop(seed: seed + 1, iters: n)
    let s2 = hash_loop(seed: seed + 2, iters: n)
    let s3 = hash_loop(seed: seed + 3, iters: n)
    let s4 = hash_loop(seed: seed + 4, iters: n)
    let s5 = hash_loop(seed: seed + 5, iters: n)
    let s6 = hash_loop(seed: seed + 6, iters: n)
    let s7 = hash_loop(seed: seed + 7, iters: n)
    let s_end = Clock.now()
    let s_check = (((((((0 ^ s0) ^ s1) ^ s2) ^ s3) ^ s4) ^ s5) ^ s6) ^ s7

    let p_ms = p_end - p_start
    let s_ms = s_end - s_start
    Console.println(val: "8 thunks x " ++ str.from_i64(val: n) ++ " iters")
    Console.println(val: "  parallel   (force_all): " ++ str.from_i64(val: p_ms) ++ " ms")
    Console.println(val: "  sequential            : " ++ str.from_i64(val: s_ms) ++ " ms")
    let ratio = if p_ms <= 0 then 0 else (s_ms * 100) / p_ms end
    Console.println(val: "  speedup x100           : " ++ str.from_i64(val: ratio))
    let ok = if p_check == s_check then "ok" else "MISMATCH" end
    Console.println(val: "  result check           : " ++ ok)
  end
  end
  return ()
end

let xor_list = fn (xs: [ i64 ], acc: i64) -> i64 do
  match xs do | [] -> return acc | x :: rest -> return xor_list(xs: rest, acc: acc ^ x) end
end
