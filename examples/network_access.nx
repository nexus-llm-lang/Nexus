// Network capability demo (stub-only HTTP today).
//
// Status: the wasm targets nexus emits today are WASI preview1 core modules.
// preview1 has neither an HTTP client nor `sock_connect`/`sock_listen`, so
// every `Net.*` primitive in std:network is wired to a deliberate stub that
// returns the failure value (empty string / 0 / false). Callers therefore
// always observe `RequestError(url)` raised by `Net.get` and friends.
//
// What this example demonstrates today:
//   - the `Net` capability declaration end-to-end (require/inject/use)
//   - the launcher invocation succeeding (no `--wasi http` flag passed)
//   - graceful failure with a `RequestError(url)` plus a stub-only diagnostic
//
// What this example does NOT do today:
//   - issue a real HTTP request
//
// A real fetch needs a preview2 component target + `wasi:http` bridge; until
// that ships (tracked separately from nexus-yx5i), this file is the canonical
// place that documents the gap. See `nxlib/stdlib/network.nx` for the stub
// definitions, and the `cap_wasmtime_flags`/`cap_sflag_string` helpers in
// `src/driver.nx` and `src/backend/polyglot.nx` for the launcher contract.

import { Net, RequestError }, * as net_mod from "std:network"
import { Console }, * as stdio from "std:stdio"

let main = fn () -> unit require { PermNet, PermConsole } do
  inject net_mod.system_handler, stdio.system_handler do
  try
    let url = "https://httpbin.org/get"
    Console.print(val: "Fetching URL: ")
    Console.println(val: url)

    let response = Net.get(url: url)
    Console.print(val: "Received response:\n")
    Console.print(val: response)
  catch e ->
    match e do
      | RequestError(url) ->
        Console.print(val: "Request failed for ")
        Console.println(val: url)
        Console.println(val: "  reason: std:network HTTP primitives are stub-only on the preview1")
        Console.println(val: "          core-wasm target (no wasi:http bridge yet).")
        Console.println(val: "          See examples/network_access.nx header for details.")
      | _ ->
        Console.println(val: "Unexpected exception in network_access example")
    end
  end
  end

  return ()
end
