import { default_net, Net } from nxlib/stdlib/net.nx
import { print } from nxlib/stdlib/stdio.nx

let main = fn () -> unit effect { Console } do
  inject default_net do
    let url = [=[https://httpbin.org/get]=]
    print(val: [=[Fetching URL:\n]=])
    print(val: url)
    print(val: [=[\n]=])

    let response = Net.get(url: url)
    print(val: [=[Received response (status\nbody):\n]=])
    print(val: response)
  endinject

  return ()
endfn
