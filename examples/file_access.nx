import as fs from [=[nxlib/stdlib/fs.nx]=]
import as stdio from [=[nxlib/stdlib/stdio.nx]=]

let main = fn () -> unit effect { IO } do
    let path = [=[hello_nexus.txt]=]
    let content = [=[Hello from Nexus!\nThis is a multi-line string\nstored in a file.]=]

    let msg = [=[Writing to ]=] ++ path ++ [=[...]=]
    perform stdio.print(val: msg)
    let success = perform fs.write_string(path: path, content: content)

    if success then
        perform stdio.print(val: [=[Successfully wrote file. Reading it back:]=])
        let read_content = perform fs.read_to_string(path: path)
        let msg = [=[--- Content Start ---\n]=] ++ read_content ++ [=[\n--- Content End ---]=]
        perform stdio.print(val: msg)
    else
        let msg = [=[Failed to write to ]=] ++ path
        perform stdio.print(val: msg)
    endif

    return ()
endfn
