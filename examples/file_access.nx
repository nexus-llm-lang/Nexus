import { Fs }, * as fs from "stdlib/fs.nx"
import { Console }, * as stdio from "stdlib/stdio.nx"

let main = fn () -> unit require { PermFs, PermConsole } do
  inject fs.system_handler, stdio.system_handler do
  let path = "hello_nexus.txt"
  let content = "Hello from Nexus!\nThis is a multi-line string\nstored in a file."

  Console.println(val: "Writing to " ++ path ++ "...")
  try
    Fs.write_string(path: path, content: content)
    let %h = Fs.open_read(path: path)
    let %r = Fs.read(handle: %h)
    match %r do
    case { content: read_content, handle: %h2 } ->
      let %pr = Fs.handle_path(handle: %h2)
      match %pr do
      case { path: file_path, handle: %h3 } ->
        Fs.close(handle: %h3)
        Console.println(val: "Read from " ++ file_path ++ ":\n" ++ read_content)
      end
    end
  catch e ->
    Console.println(val: "File operation failed")
  end
  end

  return ()
end
