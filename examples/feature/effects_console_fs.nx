// effects_console_fs: A function that uses two caps simultaneously.
//
// `require { Console, Fs }` says: "I'll call methods on `Console` and on
// `Fs`. Whoever calls me must have both handlers in scope." `inject
// h1, h2 do ... end` installs them together. At the program boundary
// you also need the matching *permissions* (`PermConsole`, `PermFs`) on
// `main` — those are the cap-token edges of the security calculus.
//
// This file writes a small file to /tmp, reads it back, prints it,
// and removes it. Each Fs call may throw; we route group failures via
// `FsThrow` (the closed set fs ops can produce).
//
// require: { Console, Fs }
// difficulty: intermediate

import { Console, system_handler as console_handler } from "std:stdio"
import { Fs, system_handler as fs_handler, FsThrow } from "std:fs"

let write_then_read = fn (path: string, content: string) -> string
    require { Fs } throws { FsThrow } do
  Fs.write_string(path, content)
  let got = Fs.read_to_string(path)
  Fs.remove_file(path)
  return got
end

let main = fn () -> unit require { PermConsole, PermFs } do
  inject console_handler, fs_handler do
    try
      let path = "/tmp/nexus_example_effects_console_fs.txt"
      let got = write_then_read(path, content: "hello from nexus")
      Console.println(val: "round-trip: " ++ got)
    catch
      | _ -> Console.println(val: "fs operation failed")
    end
  end
  return ()
end
