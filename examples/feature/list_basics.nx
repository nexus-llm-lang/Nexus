// list_basics: List literals, head/tail patterns, and `std:list` combinators.
//
// Lists are written as `[a, b, c]` or built up with the cons operator
// `x :: xs`. The empty list is `[]`. Patterns mirror the constructors:
// `[]` matches the empty list and `head :: tail` matches a non-empty one,
// binding both pieces. The standard `map`, `length`, `reverse`, `filter_b`,
// etc. live in `std:list`.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"
import * as list from "std:list"

let sum = fn (xs: [ i64 ]) -> i64 do
  match xs do
    | [] -> return 0
    | x :: rest -> return x + sum(xs: rest)
  end
end

let stringify_each = fn (xs: [ i64 ]) -> [ string ] do
  return list.map(xs, f: fn (val: i64) -> string do return from_i64(val) end)
end

let join = fn (xs: [ string ], sep: string) -> string do
  match xs do
    | [] -> return ""
    | s :: [] -> return s
    | s :: rest -> return s ++ sep ++ join(xs: rest, sep)
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let xs: [ i64 ] = [ 1, 2, 3, 4, 5 ]
    Console.println(val: "len = " ++ from_i64(val: list.length(xs)))
    Console.println(val: "sum = " ++ from_i64(val: sum(xs)))
    let ys = list.reverse(xs)
    Console.println(val: "reversed = [" ++ join(xs: stringify_each(xs: ys), sep: ", ") ++ "]")
    // Cons a new head onto the existing tail.
    let zs: [ i64 ] = 0 :: xs
    Console.println(val: "consed   = [" ++ join(xs: stringify_each(xs: zs), sep: ", ") ++ "]")
  end
  return ()
end
