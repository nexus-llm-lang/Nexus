// bench_list_sum: List allocation + fold benchmark.
//
// Builds a list of N integers and sums them.  Exercises the allocator and
// GC-free traversal path.  Prints elapsed wall-clock time in milliseconds.
//
// bench-entry: list_sum
// require: { Console, Clock }
// difficulty: benchmark

import { Console, system_handler as console_handler } from "std:stdio"
import { Clock, system_handler as clock_handler } from "std:clock"
import * as str from "std:str"
import * as list from "std:list"

let make_list = fn (i: i64, n: i64, acc: [i64]) -> [i64] do
  if i >= n then return acc end
  return make_list(i: i + 1, n, acc: i :: acc)
end

let sum_list = fn (xs: [i64], acc: i64) -> i64 do
  match xs do
    | [] -> return acc
    | x :: rest -> return sum_list(xs: rest, acc: acc + x)
  end
end

let main = fn () -> unit require { PermConsole, PermClock } do
  inject console_handler, clock_handler do
    let t0 = Clock.now()
    let xs = make_list(i: 0, n: 50000, acc: [])
    let _ = sum_list(xs, acc: 0)
    let t1 = Clock.now()
    Console.println(val: str.from_i64(val: t1 - t0))
  end
  return ()
end
