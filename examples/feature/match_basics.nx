// match_basics: Pattern matching across literals, records, lists, and ctors.
//
// Demonstrates the four core match forms: integer literal, record
// destructure, list head-tail (with [] as the empty case), and named
// constructor with bound fields. Each match also shows the `_` wildcard.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

type Shape = Circle(r: i64) | Square(side: i64)

let describe = fn (xs: [i64], s: Shape, n: i64) -> string do
  let len_msg = match xs do
    | [] -> "empty"
    | _ :: _ -> "non-empty"
  end
  let shape_msg = match s do
    | Circle(r) -> "circle r=" ++ from_i64(val: r)
    | Square(side: s) -> "square s=" ++ from_i64(val: s)
  end
  let cmp_msg = match n do
    | 0 -> "zero"
    | _ -> "nonzero"
  end
  return len_msg ++ " | " ++ shape_msg ++ " | " ++ cmp_msg
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: describe(xs: [1, 2], s: Circle(r: 5), n: 0))
    Console.println(val: describe(xs: [], s: Square(side: 4), n: 9))
  end
  return ()
end
