// network_request: HTTP client via the `Net` cap.
//
// `std:network` exposes `Net` with `get(url)` (text-body shortcut),
// `request(method, url, headers, body)` (full-control), `listen` /
// `accept` / `respond` (server side). Requests throw `RequestError` on
// connection/protocol failures — wrap in `try` to recover.
//
// This example doesn't actually fire a network call (which would need
// a live endpoint); it just demonstrates the shape of a request and the
// `Header` builder. See examples/network_access.nx for a live fetch.
//
// require: { Console, Net }
// throws: { RequestError }
// difficulty: intermediate

import { Console, system_handler as console_handler } from "std:stdio"
import { Net, system_handler as net_handler, header, Header, RequestError } from "std:network"

// Constructs the request shape but never sends it — running this binary
// just prints the planned URL and one header (we cannot guarantee
// network availability in CI).
let planned = fn () -> unit require { Console } do
  let hs: [ Header ] = [
    header(name: "Accept", value: "application/json"),
    header(name: "User-Agent", value: "nexus-example"),
  ]
  match hs do
    | Header(name: n, value: v) :: _ -> Console.println(val: "first header: " ++ n ++ ": " ++ v)
    | [] -> Console.println(val: "no headers")
  end
  return ()
end

let main = fn () -> unit require { PermConsole, PermNet } do
  inject console_handler, net_handler do
    Console.println(val: "planned GET https://example.invalid/")
    planned()
  end
  return ()
end
