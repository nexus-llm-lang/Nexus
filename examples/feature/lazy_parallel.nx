// lazy_parallel: Force a list of thunks in parallel via `lazy.force_all`.
//
// `lazy.force_all([t0, t1, ...])` dispatches each `@T` thunk to its own OS
// thread (WASI threads), then joins the results in input order. The
// thunks must therefore be independent (no shared mutable state); they
// can read from immutable captured bindings freely.
//
// For a single thunk, plain `@t` (synchronous force) is enough. Use
// `force_all` when you have several CPU-bound computations whose total
// wall-time matters.
//
// See examples/bench_parallel.nx for a wall-clock comparison vs the
// sequential baseline.
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"
import * as lazy from "std:lazy"

// A pure, CPU-bound mixing loop — tail-recursive, no allocation.
let hash_loop = fn (seed: i64, n: i64) -> i64 do
  return hash_go(acc: seed, i: 0, n)
end
let hash_go = fn (acc: i64, i: i64, n: i64) -> i64 do
  if i >= n then return acc end
  let next = ((acc * 6364136223846793005) + 1442695040888963407) + i
  return hash_go(acc: next, i: i + 1, n)
end

let print_each = fn (xs: [ i64 ], i: i64) -> unit require { Console } do
  match xs do
    | [] -> return ()
    | v :: rest ->
        Console.println(val: "t" ++ from_i64(val: i) ++ " = " ++ from_i64(val: v))
        return print_each(xs: rest, i: i + 1)
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let iters = 200000
    let @t0 = hash_loop(seed: 1, n: iters)
    let @t1 = hash_loop(seed: 2, n: iters)
    let @t2 = hash_loop(seed: 3, n: iters)
    let @t3 = hash_loop(seed: 4, n: iters)
    let results = lazy.force_all(tasks: [ t0, t1, t2, t3 ])
    print_each(xs: results, i: 0)
  end
  return ()
end
