// handler_basic: Define a cap (effect), install a handler, perform from inside.
//
// A `cap Foo do fn op(...) -> ... end` declares an effect interface. A
// `handler Foo do fn op ... end` is one implementation. Inside an `inject
// h do ... end` block, calls to `Foo.op(...)` route to `h`'s arm. Capability
// requirements propagate via `require { Foo }` on each function that
// performs the effect.
//
// Note: Nexus handlers are direct calls — they do not capture continuations.
// Use them for dependency injection (logging, config, mocking I/O) rather
// than non-local control flow.
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"

cap Greeter do
  fn say(name: string) -> unit
end

let polite = handler Greeter require { Console } do
  fn say(name: string) -> unit do
    Console.println(val: "Hello, " ++ name ++ "!")
    return ()
  end
end

let shouty = handler Greeter require { Console } do
  fn say(name: string) -> unit do
    Console.println(val: "HEY, " ++ name ++ "!!!")
    return ()
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    // Each `inject` block routes Greeter.* to the named handler.
    Console.println(val: "-- polite --")
    inject polite do
      Greeter.say(name: "Alice")
      Greeter.say(name: "Bob")
    end
    Console.println(val: "-- shouty --")
    inject shouty do
      Greeter.say(name: "Alice")
      Greeter.say(name: "Bob")
    end
  end
  return ()
end
