// match_nested: Nested patterns inside ctors and records.
//
// A pattern can recurse: `Pair(fst: Some(val: x), snd: _)` binds `x` only if
// the outer `Pair` and inner `Option` both match. The compiler routes
// through every arm in order, so put the most specific pattern first.
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import { Option, Some, None } from "std:option"
import { from_i64 } from "std:str"

type Pair<A, B> = Pair(fst: A, snd: B)

let describe = fn (p: Pair< Option<i64>, Option<i64> >) -> string do
  match p do
    | Pair(fst: Some(val: a), snd: Some(val: b)) -> return "both: " ++ from_i64(val: a + b)
    | Pair(fst: Some(val: a), snd: None) -> return "left only: " ++ from_i64(val: a)
    | Pair(fst: None, snd: Some(val: b)) -> return "right only: " ++ from_i64(val: b)
    | Pair(fst: None, snd: None) -> return "none"
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: describe(p: Pair(fst: Some(val: 10), snd: Some(val: 5))))
    Console.println(val: describe(p: Pair(fst: Some(val: 1), snd: None)))
    Console.println(val: describe(p: Pair(fst: None, snd: None)))
  end
  return ()
end
