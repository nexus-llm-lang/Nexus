// clock_basics: Wall-clock time as a capability.
//
// `std:clock` exposes `Clock` with `now()` (millis since epoch) and
// `sleep(ms)` (cooperative blocking). Both operations require the
// `PermClock` permission so that pure code cannot accidentally observe
// or block on time.
//
// require: { Console, Clock }
// difficulty: beginner

import { Console, system_handler as console_handler } from "std:stdio"
import { from_i64 } from "std:str"
import { Clock, system_handler as clock_handler } from "std:clock"

let main = fn () -> unit require { PermConsole, PermClock } do
  inject console_handler, clock_handler do
    let t0 = Clock.now()
    Clock.sleep(ms: 10)
    let t1 = Clock.now()
    let dt = t1 - t0
    // 10ms sleep can drift on busy CI runners — just confirm monotonicity.
    Console.println(val: "elapsed >= 0: " ++ (if dt >= 0 then "yes" else "no" end))
    Console.println(val: "now (ms) = " ++ from_i64(val: t1))
  end
  return ()
end
