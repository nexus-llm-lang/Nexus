// exn_todo: `std:exn.todo()` as a typed placeholder.
//
// `exn.todo()` is the Nexus answer to Rust `todo!()` / Haskell `undefined`:
// a typed placeholder that compiles anywhere a value is needed and raises
// `NotImplemented` at runtime. Each call site contributes to its enclosing
// function's `throws { NotImplemented }` row, so callers must `try` or
// re-throw — the type system makes the unfinished-work cost visible.
//
// require: { Console }
// throws: { NotImplemented }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import * as exn from "std:exn"
import { NotImplemented } from "std:exn"

let pending_op = fn (x: i64) -> i64 throws { NotImplemented } do
  // The real implementation isn't ready yet; the type stays honest.
  return exn.todo()
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    try
      let _ = pending_op(x: 7)
      Console.println(val: "(unreached)")
    catch
      | NotImplemented(msg: m) -> Console.println(val: "todo fired: " ++ m)
    end
  end
  return ()
end
