// lazy_force: Suspend a computation with `@`, evaluate it with `@x`.
//
// `let @x = e` does not run `e` immediately. `e` is captured as a thunk
// and `x` is bound to a linear `@T` token. The first time you write `@x`
// (the force form), the thunk runs and yields the value. `@T` is linear:
// a thunk is consumed by exactly one force, so you cannot accidentally
// re-run the same expression twice.
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

// Note printlns to see *when* the thunk's body runs vs when the binding
// is made. The "computing..." line appears at the moment of `@n`.
let expensive = fn (label: string) -> i64 require { Console } do
  Console.println(val: "computing " ++ label ++ "...")
  return 7 * 6
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: "before let @")
    let @n = expensive(label: "n")
    Console.println(val: "between let @ and force")
    let v = @n
    Console.println(val: "after force, v = " ++ from_i64(val: v))
  end
  return ()
end
