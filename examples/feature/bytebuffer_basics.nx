// bytebuffer_basics: Linear `%ByteBuffer` for accumulating bytes.
//
// `std:bytebuffer` is the low-level byte sink used by codegen / json /
// serialization. Each `push_*` consumes the buffer and returns a new
// handle. `length` / `get_byte` / `to_string` borrow via `&ByteBuffer`.
// Wrap up with `free` (or pass ownership onward) to release the page.
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"
import * as bb from "std:bytebuffer"

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let %buf = bb.empty()
    let %buf = bb.push_string(buf, s: "hello")
    let %buf = bb.push_byte(buf, byte: 32) // ' '
    let %buf = bb.push_string(buf, s: "nexus")

    Console.println(val: "len = " ++ from_i64(val: bb.length(buf: &buf)))
    Console.println(val: "str = " ++ bb.to_string(buf: &buf))

    bb.free(buf)
  end
  return ()
end
