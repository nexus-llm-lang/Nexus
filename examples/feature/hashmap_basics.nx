// hashmap_basics: Linear `i64 -> i64` map with explicit ownership.
//
// `std:hashmap` is a *linear* resource: writes (`put`, `remove`) consume
// the map and return a new handle; reads (`get`, `size`, `contains_key`)
// borrow it via `&HashMap`. The `Lookup = Found(value: i64) | Missing`
// type avoids sentinel values. Linear handles must end their life with
// `free` (or be passed onward); leaking is a compile error.
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"
import * as hm from "std:hashmap"
import { Found, Missing } from "std:hashmap"

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let %m = hm.empty()
    let %m = hm.put(map: m, key: 1, value: 100)
    let %m = hm.put(map: m, key: 2, value: 200)
    let %m = hm.put(map: m, key: 3, value: 300)

    Console.println(val: "size = " ++ from_i64(val: hm.size(map: &m)))
    Console.println(val: "get_or(2) = " ++ from_i64(val: hm.get_or(map: &m, key: 2, default: -1)))

    match hm.get(map: &m, key: 7) do
      | Found(value: v) -> Console.println(val: "found 7 -> " ++ from_i64(val: v))
      | Missing -> Console.println(val: "7 missing")
    end

    hm.free(map: m)
  end
  return ()
end
