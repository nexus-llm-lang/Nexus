// import_forms: The three shapes of `import`.
//
//   1. Named:        `import { Foo, bar } from "mod"`         — bring in by name
//   2. Wildcard:     `import * as m from "mod"`               — namespace alias
//   3. Combined:     `import { Foo }, * as m from "mod"`      — both at once
//
// Convention: prefer named imports for short, well-known surfaces; reach
// for the wildcard alias when a module is referenced ≥3 times or when the
// short name is ambiguous (e.g. `list.map` vs a local `map`).
//
// require: { Console }
// difficulty: beginner

// (1) Named import — only the listed bindings enter scope.
import { Console, system_handler } from "std:stdio"
// (2) Wildcard alias — every export reachable as `str.foo`.
import * as str from "std:str"
// (3) Combined — `Some` / `None` direct, plus `opt.unwrap_or` as fallback.
import { Some, None }, * as opt from "std:option"

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let s: Option<i64> = Some(val: 42)
    let n: Option<i64> = None
    Console.println(val: "Some -> " ++ str.from_i64(val: opt.unwrap_or(opt: s, default: -1)))
    Console.println(val: "None -> " ++ str.from_i64(val: opt.unwrap_or(opt: n, default: -1)))
  end
  return ()
end
