// let_destructure: Pattern-match in a `let` to bind ctor / record fields.
//
// Instead of writing a one-arm `match`, you can destructure directly in a
// `let` binding: `let Ctor(field: x, ...) = expr`. For a linear ctor the
// `%` sigil indicates the bindings inherit the linear capability:
// `let %Ctor(field: x) = expr` binds linear `x`. The compiler still proves
// exhaustiveness — only irrefutable single-arm shapes are accepted here.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

type Point = Point(x: i64, y: i64)

let manhattan = fn (p: Point) -> i64 do
  // Record destructure inside a let — short for `match p do | Point(x, y) -> ... end`.
  let Point(x: a, y: b) = p
  let ax = if a < 0 then 0 - a else a end
  let ay = if b < 0 then 0 - b else b end
  return ax + ay
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let p = Point(x: -3, y: 4)
    Console.println(val: "|p| = " ++ from_i64(val: manhattan(p)))
  end
  return ()
end
