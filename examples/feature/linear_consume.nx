// linear_consume: A linear binding (%x) is consumed exactly once.
//
// `%Box` in a parameter type says "this function consumes the value" — the
// caller cannot reuse the binding afterwards. The destructuring pattern
// `let %x = ...` introduces a linear binding; passing `%x` to a function
// transfers ownership. To "modify" you destructure, build a new ctor, and
// return it (the SRA pass reuses the slot in-place when possible).
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

type Box = Box(val: i64)

let bump = fn (b: %Box) -> Box do
  match b do
    | Box(val: v) -> return Box(val: v + 1)
  end
end

let unwrap = fn (b: %Box) -> i64 do
  match b do
    | Box(val: v) -> return v
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let %b = Box(val: 41)
    let b2 = bump(%b)
    let b3 = bump(b: b2)
    Console.println(val: from_i64(val: unwrap(b: b3)))
  end
  return ()
end
