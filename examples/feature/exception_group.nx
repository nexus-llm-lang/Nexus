// exception_group: Name a closed set of exceptions for a `throws` row.
//
// `exception group G = A | B | C` introduces `G` as a *type-level* label
// for the disjoint union {A, B, C}. A function whose row is `throws { G }`
// is allowed to raise any of A/B/C; callers `try` against `G` (or any
// member) and route via concrete-variant arms.
//
// Groups are how stdlib presents many small exceptions as one route
// (see `std:list.ListError`, `std:fs.FsThrow`). Membership is checked at
// type time, not at the raise site.
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

exception EmptyKey(name: string)
exception BadIndex(at: i64)
exception OutOfRange(val: i64, max: i64)

exception group LookupError = EmptyKey | BadIndex | OutOfRange

let lookup = fn (key: string, idx: i64) -> i64 throws { LookupError } do
  if key == "" then raise EmptyKey(name: key) end
  if idx < 0 then raise BadIndex(at: idx) end
  if idx > 10 then raise OutOfRange(val: idx, max: 10) end
  return idx * 100
end

let try_lookup = fn (key: string, idx: i64) -> string do
  try
    let v = lookup(key, idx)
    return "ok: " ++ from_i64(val: v)
  catch
    | EmptyKey(name) -> return "empty key '" ++ name ++ "'"
    | BadIndex(at) -> return "bad index " ++ from_i64(val: at)
    | OutOfRange(val, max) ->
        return "out of range: " ++ from_i64(val: val) ++ " > " ++ from_i64(val: max)
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: try_lookup(key: "x", idx: 3))
    Console.println(val: try_lookup(key: "", idx: 0))
    Console.println(val: try_lookup(key: "k", idx: -1))
    Console.println(val: try_lookup(key: "k", idx: 99))
  end
  return ()
end
