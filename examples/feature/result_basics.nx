// result_basics: Explicit error returns via `Ok(val: T) | Err(err: E)`.
//
// `std:result` is the effect-free alternative to `throws { ... }`. Use it
// when callers should decide how to handle the failure (recover, ignore,
// propagate). `map` transforms the Ok side, `and_then` chains another
// fallible step, and `unwrap_or` provides a fallback. The Err type is
// fully generic — wrap a string, an enum, or any cause record.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"
import { Ok, Err, map, unwrap_or, is_err } from "std:result"

type DivErr = DivByZero | Negative

let checked_div = fn (a: i64, b: i64) -> Result<i64, DivErr> do
  if b == 0 then return Err(err: DivByZero) end
  if a < 0 then return Err(err: Negative) end
  return Ok(val: a / b)
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let r1 = checked_div(a: 84, b: 2)
    let r2 = checked_div(a: 5, b: 0)
    let doubled = map(res: r1, f: fn (val: i64) -> i64 do return val * 2 end)
    Console.println(val: "84/2 doubled = " ++ from_i64(val: unwrap_or(res: doubled, default: -1)))
    Console.println(val: "5/0 is err: " ++ (if is_err(res: r2) then "yes" else "no" end))
  end
  return ()
end
