// env_basics: Environment variables via the `Env` cap.
//
// `Env.get(key)` returns `Option<string>` — `None` when unset. `Env.set`
// writes to the process env table. Both are gated by `PermEnv`.
//
// require: { Console, Env }
// difficulty: beginner

import { Console, system_handler as console_handler } from "std:stdio"
import { Env, system_handler as env_handler } from "std:env"
import { Some, None } from "std:option"

let main = fn () -> unit require { PermConsole, PermEnv } do
  inject console_handler, env_handler do
    match Env.get(key: "HOME") do
      | Some(val: v) -> Console.println(val: "HOME = " ++ v)
      | None -> Console.println(val: "HOME unset")
    end
    Env.set(key: "NEXUS_EXAMPLE_VAR", value: "1")
    match Env.get(key: "NEXUS_EXAMPLE_VAR") do
      | Some(val: v) -> Console.println(val: "round-trip = " ++ v)
      | None -> Console.println(val: "lost")
    end
  end
  return ()
end
