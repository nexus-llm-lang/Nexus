// log_basics: Structured logging via the `Logger` cap.
//
// `std:log` defines a `Logger` cap with `trace`/`debug`/`info`/`warn`/`error`
// arms plus a generic `log(level, msg, fields)`. Two ready-made handlers
// are bundled: `console_logger` emits text lines, `json_logger` emits
// JSON-Lines. Use `field_str` / `field_i64` / ... to attach structured
// fields. The global level filter is set with `set_min_level` — anything
// below is dropped before the handler is even invoked.
//
// require: { Console, Logger }
// difficulty: beginner

import { Console, system_handler as console_handler } from "std:stdio"
import { Logger, console_logger, set_min_level, Info, field_str, field_i64 } from "std:log"

let main = fn () -> unit require { PermConsole } do
  inject console_handler do
    set_min_level(level: Info)
    inject console_logger do
      Logger.info(msg: "service starting", fields: [
        field_str(key: "version", value: "1.0.0"),
        field_i64(key: "pid", value: 42),
      ])
      // Trace is filtered out because we set min level = Info.
      Logger.trace(msg: "internal trace", fields: [])
      Logger.warn(msg: "low disk", fields: [ field_i64(key: "free_mb", value: 128) ])
    end
  end
  return ()
end
