// match_guards_or: Or-patterns and shared-name bindings.
//
// `|` between alternatives in one arm matches any of them. When all
// alternatives bind the same variable name with the same type, the bound
// name is usable in the arm body. Or-patterns also work for integer literals.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

type Sign = Pos | Neg | Zero
type Either = Left(v: i64) | Right(v: i64)

let classify = fn (s: Sign) -> string do
  match s do
    | Pos | Neg -> return "nonzero"
    | Zero -> return "zero"
  end
end

let extract = fn (e: Either) -> i64 do
  match e do
    | Left(v) | Right(v) -> return v
  end
end

let small = fn (n: i64) -> bool do
  match n do
    | 1 | 2 | 3 -> return true
    | _ -> return false
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: classify(s: Pos))
    Console.println(val: classify(s: Zero))
    Console.println(val: from_i64(val: extract(e: Left(v: 7))))
    Console.println(val: from_i64(val: extract(e: Right(v: 99))))
    Console.println(val: if small(n: 2) then "yes" else "no" end)
  end
  return ()
end
