// generics_poly_fn: Polymorphic functions and types via type parameters.
//
// `fn <T>(...)` declares a type parameter; the inferrer monomorphises at
// every call site. `type Box<T> = ...` is a polymorphic data type. Type
// parameters compose: `swap<A, B>` swaps a pair of distinct types.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

type Pair<A, B> = Pair(fst: A, snd: B)

let swap = fn <A, B>(p: Pair<A, B>) -> Pair<B, A> do
  match p do
    | Pair(fst: a, snd: b) -> return Pair(fst: b, snd: a)
  end
end

let identity = fn <T>(x: T) -> T do
  return x
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let p = Pair(fst: 1, snd: "one")
    let q = swap(p: p)
    match q do
      | Pair(fst: s, snd: n) -> Console.println(val: s ++ "/" ++ from_i64(val: n))
    end
    Console.println(val: identity(x: "echo"))
    Console.println(val: from_i64(val: identity(x: 42)))
  end
  return ()
end
