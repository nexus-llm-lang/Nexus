// linear_borrow: Inspect a linear value without consuming it via `&`.
//
// `&Box` borrows: the function may read the value but the caller keeps
// ownership and can pass `%b` to another consumer afterwards. Inside the
// borrow body the linear binding is alive but inaccessible.
//
// The hashmap stdlib is a canonical example: `get` takes `&HashMap` so
// lookups don't move the handle, while `put` takes `%HashMap` because it
// returns a (possibly resized) new handle.
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

type Counter = Counter(n: i64)

let peek = fn (c: &Counter) -> i64 do
  match c do
    | Counter(n) -> return n
  end
end

let consume_with_total = fn (c: %Counter) -> i64 do
  match c do
    | Counter(n) -> return n
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let %c = Counter(n: 7)
    let snapshot = peek(&c)
    let final = consume_with_total(%c)
    Console.println(val: "peek=" ++ from_i64(val: snapshot) ++ " final=" ++ from_i64(val: final))
  end
  return ()
end
