// char_basics: `std:char` classification and digit values.
//
// `char` is a 32-bit code-point scalar. `std:char` provides the usual
// `is_alpha`, `is_digit`, `is_whitespace`, plus identifier-aware
// `is_ident_start` / `is_ident_char` used by the compiler's own lexer.
// Digit conversion (`digit_value`, `hex_digit_value`) returns -1 for
// non-digits so callers can branch without throwing.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64, from_bool, char_at } from "std:str"
import * as ch from "std:char"

let report = fn (c: char) -> unit require { Console } do
  Console.println(val: "ord       = " ++ from_i64(val: ch.ord(c)))
  Console.println(val: "is_alpha  = " ++ from_bool(val: ch.is_alpha(c)))
  Console.println(val: "is_digit  = " ++ from_bool(val: ch.is_digit(c)))
  Console.println(val: "is_upper  = " ++ from_bool(val: ch.is_upper(c)))
  return ()
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let c = char_at(s: "A", idx: 0)
    report(c)
    Console.println(val: "digit('7')   = " ++ from_i64(val: ch.digit_value(c: char_at(s: "7", idx: 0))))
    Console.println(val: "hex('f')     = " ++ from_i64(val: ch.hex_digit_value(c: char_at(s: "f", idx: 0))))
    Console.println(val: "ws(' ')      = " ++ from_bool(val: ch.is_whitespace(c: char_at(s: " ", idx: 0))))
  end
  return ()
end
