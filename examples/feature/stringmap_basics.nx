// stringmap_basics: Linear `string -> V` map (sister of `hashmap`).
//
// Same ownership story as `std:hashmap`: linear handle, write consumes
// + returns, read borrows. Generic over the value type `V` — this example
// instantiates `%StringMap<i64>`. Use this when keys are strings (config
// tables, per-name counters, symbol tables) instead of synthesizing an i64
// hash yourself.
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"
import * as sm from "std:stringmap"
import { Found, Missing } from "std:stringmap"

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let %m = sm.empty()
    let %m = sm.put(map: m, key: "alice", value: 30)
    let %m = sm.put(map: m, key: "bob",   value: 25)
    let %m = sm.put(map: m, key: "carol", value: 42)

    Console.println(val: "size  = " ++ from_i64(val: sm.size(map: &m)))
    Console.println(val: "bob   = " ++ from_i64(val: sm.get_or(map: &m, key: "bob", default: -1)))

    match sm.get(map: &m, key: "dave") do
      | Found(value: v) -> Console.println(val: "dave -> " ++ from_i64(val: v))
      | Missing -> Console.println(val: "dave missing")
    end

    sm.free(map: m)
  end
  return ()
end
