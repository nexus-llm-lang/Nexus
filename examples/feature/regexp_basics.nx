// regexp_basics: Compile, test, and substitute via `std:regexp`.
//
// `std:regexp` is a Thompson-NFA matcher. `from_string` compiles (raising
// `InvalidRegexp` on syntax error), `test` returns a yes/no, `find`
// returns `Option<Match>` for the first hit, `gsub` does global
// replacement. `Match` carries `start`, `end_pos`, the matched `text`,
// and per-group captures as `[ Option<string> ]`.
//
// require: { Console }
// throws: { RegexpThrow }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import { from_i64, from_bool } from "std:str"
import * as re from "std:regexp"
import { Match, RegexpThrow } from "std:regexp"
import { Some, None } from "std:option"

let main = fn () -> unit require { PermConsole } throws { RegexpThrow } do
  inject system_handler do
    let pat = re.from_string(src: "[A-Za-z]+")
    Console.println(val: "test 'hello' = " ++ from_bool(val: re.test(re: pat, s: "hello")))
    Console.println(val: "test '123'   = " ++ from_bool(val: re.test(re: pat, s: "123")))

    match re.find(re: pat, s: "  Nexus is here  ") do
      | Some(val: Match(start: s, end_pos: e, text: t, _)) ->
          Console.println(val: "first = '" ++ t ++ "' [" ++ from_i64(val: s) ++ ".." ++ from_i64(val: e) ++ ")")
      | None -> Console.println(val: "no match")
    end

    Console.println(val: "gsub = " ++ re.gsub(re: pat, s: "1 cat 2 cats", repl: "<X>"))
  end
  return ()
end
