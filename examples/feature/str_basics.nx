// str_basics: `std:str` byte / char operations, conversions, and search.
//
// Nexus strings are UTF-8 packed `(ptr << 32) | len` words. `std:str`
// gives length (in chars), `contains` / `index_of` / `starts_with` for
// search, `to_lower` / `trim` for normalization, and the family
// `from_i64` / `from_float` / `from_bool` for converting primitives back
// to text. ASCII-only for case + trim; see the module docstring for
// caveats.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import * as str from "std:str"

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let s = "  Hello, Nexus!  "
    let trimmed = str.trim(s)
    Console.println(val: "trim:        [" ++ trimmed ++ "]")
    Console.println(val: "length:      " ++ str.from_i64(val: str.length(s: trimmed)))
    Console.println(val: "to_lower:    " ++ str.to_lower(s: trimmed))
    Console.println(val: "contains?:   " ++ str.from_bool(val: str.contains(s: trimmed, sub: "Nexus")))
    Console.println(val: "index_of:    " ++ str.from_i64(val: str.index_of(s: trimmed, sub: "Nexus")))
    Console.println(val: "starts_with: " ++ str.from_bool(val: str.starts_with(s: trimmed, prefix: "Hello")))
  end
  return ()
end
