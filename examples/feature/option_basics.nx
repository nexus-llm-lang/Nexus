// option_basics: Optional values via `Some(val: T) | None`.
//
// `std:option` is the LLM-friendly stand-in for nullable returns. Build
// with `Some(val: ...)` / `None`, inspect with `match`, default with
// `unwrap_or`, and chain via `map` / `and_then`. The type carries the
// "may be absent" contract on the function signature, so callers cannot
// forget to handle the empty case.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"
import { Some, None, unwrap_or, is_some } from "std:option"

let safe_div = fn (a: i64, b: i64) -> Option<i64> do
  if b == 0 then return None end
  return Some(val: a / b)
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let r1 = safe_div(a: 84, b: 2)
    let r2 = safe_div(a: 10, b: 0)
    Console.println(val: "84/2 = " ++ from_i64(val: unwrap_or(opt: r1, default: -1)))
    Console.println(val: "10/0 = " ++ from_i64(val: unwrap_or(opt: r2, default: -1)))
    Console.println(val: "r1 has value: " ++ (if is_some(opt: r1) then "yes" else "no" end))
  end
  return ()
end
