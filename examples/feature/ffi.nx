// ffi: Declare host-bound primitives via `import external` + `external`.
//
// FFI in Nexus is two declarations.
//
//   1. `import external "MODULE"` opens a host-module namespace for the rest of
//      the file. `"nexus:intrinsic"` is the in-compiler intrinsic namespace
//      (codegen rewrites these calls to inline WASM ops, no host import).
//      `"wasi_snapshot_preview1"` and other strings name real WASI / wasm
//      imports that wasmtime resolves at link time.
//
//   2. `external <NX_NAME> = "<WASM_NAME>" : <NEXUS_SIGNATURE>` binds a
//      callable. The Nexus-side name is used in source; the WASM name keys
//      the import (or intrinsic dispatch). The signature is checked exactly
//      like a normal `fn`.
//
// Below uses two `nexus:intrinsic` math externs — `f64_sqrt` and `f64_abs`.
// At codegen these expand to single WASM ops (`f64.sqrt`, `f64.abs`) with no
// import-section entry. The stdlib bundles these as `std:runtime/math`; this
// file re-derives them from scratch as a worked example of the FFI surface.
//
// require: { Console }
// difficulty: advanced

import { Console, system_handler } from "std:stdio"
import { from_float } from "std:str"
import { i64_to_float } from "std:math"
import external "nexus:intrinsic"

external sqrt = "f64_sqrt" : (val: float) -> float
external abs_f = "f64_abs"  : (val: float) -> float

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let two = i64_to_float(val: 2)
    let neg = 0.0 -. i64_to_float(val: 7)
    Console.println(val: "sqrt(2) = " ++ from_float(val: sqrt(val: two)))
    Console.println(val: "abs(-7) = " ++ from_float(val: abs_f(val: neg)))
  end
  return ()
end
