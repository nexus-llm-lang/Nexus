// rand_basics: Pseudo-random numbers as a capability.
//
// `std:rand` exposes `Random` (an effect) with `next_i64`, `range`, and
// `next_bool`. Use the supplied `system_handler` for production (it pulls
// entropy via the `PermRandom` permission) or define your own deterministic
// handler for tests / fixtures. `seed_with` makes the global PRNG
// reproducible.
//
// require: { Console, Random }
// difficulty: beginner

import { Console, system_handler as console_handler } from "std:stdio"
import { from_i64, from_bool } from "std:str"
import { Random, system_handler as rand_handler, seed_with } from "std:rand"

let main = fn () -> unit require { PermConsole, PermRandom } do
  seed_with(seed: 42)
  inject console_handler, rand_handler do
    Console.println(val: "next_i64 = " ++ from_i64(val: Random.next_i64()))
    Console.println(val: "range(0,100) = " ++ from_i64(val: Random.range(min: 0, max: 100)))
    Console.println(val: "next_bool = " ++ from_bool(val: Random.next_bool()))
  end
  return ()
end
