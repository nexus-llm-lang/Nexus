// proc_argv: Read program arguments via the `Proc` cap.
//
// `Proc.argv()` returns `[ string ]` — the program's argv excluding the
// binary itself. `Proc.exit(status)` halts the program with a code (the
// `unit` return is a syntactic convenience; control never returns).
// `Proc.exec` (not shown) shells out to a child process and bundles
// stdout/stderr/exit-code into `ExecResult`.
//
// require: { Console, Proc }
// difficulty: beginner

import { Console, system_handler as console_handler } from "std:stdio"
import { from_i64 } from "std:str"
import { Proc, system_handler as proc_handler } from "std:proc"
import * as list from "std:list"

let print_each = fn (xs: [ string ]) -> unit require { Console } do
  match xs do
    | [] -> return ()
    | s :: rest ->
        Console.println(val: "  " ++ s)
        return print_each(xs: rest)
  end
end

let main = fn () -> unit require { PermConsole, PermProc } do
  inject console_handler, proc_handler do
    let args = Proc.argv()
    Console.println(val: "argc = " ++ from_i64(val: list.length(xs: args)))
    print_each(xs: args)
  end
  return ()
end
