// if_expression: `if ... then ... else ... end` is an *expression*.
//
// Unlike C-style "if" statements, every `if` in Nexus produces a value.
// Both branches must agree on the result type. Use it inline for short
// conditionals; reach for `match` when there are more than two outcomes
// or pattern-shape distinctions.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"

let classify = fn (n: i64) -> string do
  // `if` is an expression — bind its value with a `let`.
  let pos_or_zero = if n == 0 then "zero" else "positive" end
  let label = if n < 0 then "negative" else pos_or_zero end
  return label
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: "-7 -> " ++ classify(n: -7))
    Console.println(val: " 0 -> " ++ classify(n: 0))
    Console.println(val: " 5 -> " ++ classify(n: 5))
  end
  return ()
end
