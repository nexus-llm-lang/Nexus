// mutable_ref: A mutable cell with `~` lets you re-assign in place.
//
// `let ~x = init` introduces a mutable binding. Inside scope, `~x` reads
// the cell's contents and `~x <- v` overwrites them. Refs are stack-bound:
// they cannot escape their declaring scope (you can return the *value*
// but not the cell itself). Refs cannot hold linear (`%`) values — that
// would let you smuggle a one-shot resource past its scope.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

let demo_ref = fn () -> i64 do
  let ~counter = 10
  ~counter <- ~counter + 5
  ~counter <- ~counter * 2
  return ~counter
end

let two_refs = fn () -> i64 do
  // Two independent cells: writing one doesn't touch the other.
  let ~a = 1
  let ~b = 100
  ~a <- ~a + 1
  ~b <- ~b + ~a
  return ~b
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: "(10+5)*2 = " ++ from_i64(val: demo_ref()))
    Console.println(val: "two refs = " ++ from_i64(val: two_refs()))
  end
  return ()
end
