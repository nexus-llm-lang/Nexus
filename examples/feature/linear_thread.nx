// linear_thread: Thread a linear value through a recursive accumulator.
//
// A linear binding (`%`) cannot be copied, so iterative updates must
// "thread" the value: each step takes ownership and returns a new handle.
// The pattern below — `step(%acc, ...) -> %Acc; let %acc2 = step(%acc, ...)` —
// is how linear data structures (HashMap, ByteBuffer, ...) compose with
// recursion. The SRA pass collapses these handle moves into in-place mutation
// when the producer and consumer agree on layout.
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

type Counter = Counter(n: i64)

let bump = fn (c: %Counter, by: i64) -> Counter do
  match c do
    | Counter(n) -> return Counter(n: n + by)
  end
end

// Tail-recursive: at each step the previous `%c` is consumed and a fresh
// `%Counter` is produced. The caller only ever holds one live handle.
let bump_many = fn (c: %Counter, steps: [ i64 ]) -> Counter do
  match steps do
    | [] -> match c do | Counter(n) -> return Counter(n) end
    | h :: t -> return bump_many(c: bump(c: %c, by: h), steps: t)
  end
end

let unwrap = fn (c: %Counter) -> i64 do
  match c do
    | Counter(n) -> return n
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let %c0 = Counter(n: 0)
    let c1 = bump_many(c: %c0, steps: [ 10, 20, 30, -5 ])
    Console.println(val: "final = " ++ from_i64(val: unwrap(c: c1)))
  end
  return ()
end
