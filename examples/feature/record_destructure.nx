// record_destructure: Records as `type T = { f: T1, g: T2 }`, with field
// patterns in `let` and `match`.
//
// `let { x: a, y: b } = r` binds `r.x` to `a` and `r.y` to `b`. The
// pattern can omit fields you don't want (`let { x } = r` still
// requires the record type to have `x`; trailing fields are simply not
// bound). Nested records destructure recursively: `let { inner: { a:
// x }, b: y } = o`. The same patterns work as `match` arms.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

type Point = { x: i64, y: i64 }
type Segment = { p0: Point, p1: Point }

let manhattan = fn (s: Segment) -> i64 do
  let { p0: { x: x1, y: y1 }, p1: { x: x2, y: y2 } } = s
  let dx = if x2 >= x1 then x2 - x1 else x1 - x2 end
  let dy = if y2 >= y1 then y2 - y1 else y1 - y2 end
  return dx + dy
end

let classify = fn (p: Point) -> string do
  match p do
    | { x: 0, y: 0 } -> return "origin"
    | { x: 0, y: _ } -> return "on y-axis"
    | { x: _, y: 0 } -> return "on x-axis"
    | _ -> return "general"
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let s: Segment = { p0: { x: 1, y: 2 }, p1: { x: 4, y: 6 } }
    Console.println(val: "manhattan = " ++ from_i64(val: manhattan(s)))
    Console.println(val: classify(p: { x: 0, y: 0 }))
    Console.println(val: classify(p: { x: 0, y: 5 }))
    Console.println(val: classify(p: { x: 3, y: 0 }))
    Console.println(val: classify(p: { x: 2, y: 7 }))
  end
  return ()
end
