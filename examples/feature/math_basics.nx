// math_basics: `std:math` integer + float helpers.
//
// Nexus separates `i64` (integers) from `float` (f64). Use `math.i64_to_float`
// and `math.float_to_i64` to convert. The classic helpers `abs`, `max`,
// `min`, `sqrt`, `floor`, `ceil` are all here. Division-by-zero on the
// dedicated checked helpers raises `DivisionByZero` — see the negative
// example for the throws rule.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64, from_float } from "std:str"
import * as math from "std:math"

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let a = -7
    let b = 3
    Console.println(val: "abs(-7)   = " ++ from_i64(val: math.abs(val: a)))
    Console.println(val: "max(-7,3) = " ++ from_i64(val: math.max(a, b)))
    Console.println(val: "min(-7,3) = " ++ from_i64(val: math.min(a, b)))
    let f = math.i64_to_float(val: 2)
    Console.println(val: "sqrt(2)   = " ++ from_float(val: math.sqrt(val: f)))
    Console.println(val: "ceil(2.3) = " ++ from_float(val: math.ceil(val: 2.3)))
    Console.println(val: "floor(2.7)= " ++ from_float(val: math.floor(val: 2.7)))
  end
  return ()
end
