// json_basics: Parse, inspect, and re-serialize JSON.
//
// `std:json` defines `JsonValue` as a sum of `JsonNull | JsonBool | JsonInt
// | JsonFloat | JsonString | JsonArray | JsonObject`. `parse` raises
// `JsonThrow` on malformed input; `serialize` only fails on non-finite
// floats (NaN/Infinity). `get_field` returns `Option<JsonValue>` so
// missing keys are surfaced explicitly.
//
// require: { Console }
// throws: { JsonThrow }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import * as json from "std:json"
import { JsonInt, JsonString } from "std:json"
import { Some, None } from "std:option"

let main = fn () -> unit require { PermConsole } throws { json.JsonThrow } do
  inject system_handler do
    let v = json.parse(s: "{\"name\": \"nexus\", \"version\": 1}")
    match json.get_field(obj: v, key: "name") do
      | Some(val: JsonString(val: s)) -> Console.println(val: "name = " ++ s)
      | _ -> Console.println(val: "name missing/wrong type")
    end
    match json.get_field(obj: v, key: "version") do
      | Some(val: JsonInt(val: n)) -> Console.println(val: "version int = " ++ json.serialize(v: JsonInt(val: n)))
      | _ -> Console.println(val: "version missing/wrong type")
    end
    Console.println(val: "roundtrip = " ++ json.serialize(v))
  end
  return ()
end
