// try_catch: Raise and catch exceptions; selective catch arms.
//
// `exception Foo(field: T)` declares a constructor that can be `raise`d.
// `try BLOCK catch | Pattern -> handler ... end` runs BLOCK, and if an
// exception escapes, dispatches it through the catch arms exactly like
// a `match` over the exception variants.
//
// A wildcard `_` catch is always exhaustive; named-variant arms must
// either be exhaustive over the function's declared `throws { ... }`
// effect row or rethrow the residual via `_`.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

exception Underflow(by: i64)
exception NotPositive(val: i64)

let safe_sub = fn (a: i64, b: i64) -> i64 throws { Underflow } do
  if b > a then raise Underflow(by: b - a) end
  return a - b
end

let must_be_positive = fn (n: i64) -> i64 throws { NotPositive } do
  if n <= 0 then raise NotPositive(val: n) end
  return n
end

let describe = fn (a: i64, b: i64) -> string do
  try
    let diff = safe_sub(a, b)
    let p = must_be_positive(n: diff)
    return "got " ++ from_i64(val: p)
  catch
    | Underflow(by) -> return "underflow by " ++ from_i64(val: by)
    | NotPositive(val) -> return "not positive: " ++ from_i64(val: val)
  end
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: describe(a: 10, b: 3))
    Console.println(val: describe(a: 2, b: 5))
    Console.println(val: describe(a: 5, b: 5))
  end
  return ()
end
