// tuple_pair: Heterogeneous two-value packing via `Pair<A, B>`.
//
// Nexus doesn't have anonymous tuples — `std:tuple` exports a generic
// `Pair(left: A, right: B)` ctor and the `fst` / `snd` accessors. Use it
// when you need to thread two related values through a single return
// position without naming a domain type.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"
import { Pair, fst, snd } from "std:tuple"

let divmod = fn (a: i64, b: i64) -> Pair<i64, i64> do
  return Pair(left: a / b, right: a - ((a / b) * b))
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let p = divmod(a: 17, b: 5)
    Console.println(val: "17 / 5 = " ++ from_i64(val: fst(p)))
    Console.println(val: "17 % 5 = " ++ from_i64(val: snd(p)))
  end
  return ()
end
