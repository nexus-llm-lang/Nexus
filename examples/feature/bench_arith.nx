// bench_arith: Pure arithmetic benchmark.
//
// Runs a tight LCG-style mixing loop (no allocation) and prints the
// elapsed wall-clock time in milliseconds.  The result depends on every
// iteration so it cannot be constant-folded.
//
// bench-entry: arith
// require: { Console, Clock }
// difficulty: benchmark

import { Console, system_handler as console_handler } from "std:stdio"
import { Clock, system_handler as clock_handler } from "std:clock"
import * as str from "std:str"

let hash_go = fn (acc: i64, i: i64, n: i64) -> i64 do
  if i >= n then return acc end
  let nx = ((acc * 6364136223846793005) + 1442695040888963407) + i
  return hash_go(acc: nx, i: i + 1, n)
end

let main = fn () -> unit require { PermConsole, PermClock } do
  inject console_handler, clock_handler do
    let t0 = Clock.now()
    hash_go(acc: 42, i: 0, n: 5000000)
    let t1 = Clock.now()
    Console.println(val: str.from_i64(val: t1 - t0))
  end
  return ()
end
