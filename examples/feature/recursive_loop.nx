// recursive_loop: Tail-recursive accumulators replace `for` / `while`.
//
// Nexus has no `for` / `while` keyword. The idiomatic loop is a recursive
// inner function with an explicit accumulator — the codegen lowers tail
// calls to wasm `return_call`, so deep iteration is constant-stack.
// Pair this pattern with `match` on the list (or an integer counter) as
// the recursion driver.
//
// require: { Console }
// difficulty: beginner

import { Console, system_handler } from "std:stdio"
import { from_i64 } from "std:str"

// Sum [0, n) via a tail-recursive helper. `acc` carries the running total.
let sum_to = fn (n: i64) -> i64 do
  return sum_go(i: 0, n, acc: 0)
end
let sum_go = fn (i: i64, n: i64, acc: i64) -> i64 do
  if i >= n then return acc end
  return sum_go(i: i + 1, n, acc: acc + i)
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    Console.println(val: "sum [0, 100) = " ++ from_i64(val: sum_to(n: 100)))
    Console.println(val: "sum [0, 1)   = " ++ from_i64(val: sum_to(n: 1)))
  end
  return ()
end
