// pbt_basics: Property-based test with `std:pbt`.
//
// `std:pbt` exposes `Gen<T>` (paired generator + shrinker + renderer) and
// the `forall(g, prop, n)` runner. Primitive generators include
// `small_int` (i64 in [-100, 100]), `bool_gen`, `string_gen`. The runner
// draws `n` samples and shrinks the first counterexample greedily.
// `Console` is required because `forall` reports witnesses on stdout.
//
// require: { Console }
// difficulty: intermediate

import { Console, system_handler } from "std:stdio"
import * as pbt from "std:pbt"

// A trivially true property: x + 0 == x. Should always Pass.
let id_plus_zero = fn (x: i64) -> bool do
  return (x + 0) == x
end

let main = fn () -> unit require { PermConsole } do
  inject system_handler do
    let r = pbt.forall(g: pbt.small_int, prop: id_plus_zero, n: 50)
    match r do
      | pbt.Pass -> Console.println(val: "x + 0 == x: PASS over 50 samples")
      | pbt.Fail(witness: w, shrunk_input: s) ->
          Console.println(val: "FAIL witness=" ++ w ++ " shrunk=" ++ s)
    end
  end
  return ()
end
