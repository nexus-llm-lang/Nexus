let fib = fn (n: i64) -> i64 do
  if n == 0 then
    return 0
  endif
  if n == 1 then
    return 1
  endif
  let n1 = n - 1
  let n2 = n - 2
  let a = fib(n: n1)
  let b = fib(n: n2)
  return a + b
endfn

let main = fn () ->  unit effect { IO } do
  let v = fib(n: 40)
  let val = i64_to_string(val: v)
  perform print(val: val)
  return ()
endfn
