{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "nexus",
      "scope": "source.nexus",
      "path": ".",
      "file-types": [
        "nx"
      ],
      "highlights": "queries/nexus/highlights.scm",
      "locals": "queries/nexus/locals.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Nexus programming language",
    "authors": []
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
