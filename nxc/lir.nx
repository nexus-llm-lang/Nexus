/**
 * lir: Low-level IR — A-Normal Form with semantic type tracking.
 *
 * Transforms MIR → LIR by:
 * 1. Converting all sub-expressions to atomic values (ANF)
 * 2. Tracking semantic types for field access resolution
 * 3. Lowering pattern matching to conditional checks
 * 4. Converting match/if expressions to assignment chains
 */
import { Span } from nxc/token.nx
import { Sigil, BinaryOp, Literal, TypeExpr, EnumDef, VariantDef, VariantField } from nxc/ast.nx
import { MirProgram, MirFunction, MirExpr, MirStmt, MirParam, MirExternal,
         MirCallArg, MirMatchCase, MirPattern, MirPatternField,
         MirRecordPatField, MirNamedExpr } from nxc/mir.nx
import { from_i64 } from stdlib/string.nx

// ─── LIR Types ───────────────────────────────────────────────────────────────

export type LirParam = LirParam(label: string, name: string, typ: TypeExpr)

export type LirExternal = LirExternal(
  name: string,
  wasm_module: string,
  wasm_name: string,
  params: [LirParam],
  ret_type: TypeExpr,
  throw_row: TypeExpr
)

export type LirAtom =
  LirAtomVar(name: string, typ: TypeExpr)
  | LirAtomInt(val: i64)
  | LirAtomFloat(val: string)
  | LirAtomBool(val: bool)
  | LirAtomString(val: string)
  | LirAtomUnit

export type LirExpr =
  LirExprAtom(atom: LirAtom)
  | LirExprBinary(op: BinaryOp, lhs: LirAtom, rhs: LirAtom, typ: TypeExpr)
  | LirExprCall(func: string, args: [LirCallArg], typ: TypeExpr)
  | LirExprTailCall(func: string, args: [LirCallArg], typ: TypeExpr)
  | LirExprConstructor(name: string, args: [LirAtom], typ: TypeExpr)
  | LirExprRecord(fields: [LirNamedAtom], typ: TypeExpr)
  | LirExprObjectTag(value: LirAtom, typ: TypeExpr)
  | LirExprObjectField(value: LirAtom, index: i64, typ: TypeExpr)
  | LirExprRaise(value: LirAtom, typ: TypeExpr)

export type LirCallArg = LirCallArg(label: string, value: LirAtom)
export type LirNamedAtom = LirNamedAtom(name: string, value: LirAtom)

export type LirStmt =
  LirStmtLet(name: string, typ: TypeExpr, expr: LirExpr)
  | LirStmtIf(cond: LirAtom, then_body: [LirStmt], else_body: [LirStmt])
  | LirStmtIfReturn(cond: LirAtom, then_body: [LirStmt], then_ret: LirAtom,
                     else_body: [LirStmt], else_ret: Option<LirAtom>, ret_type: TypeExpr)
  | LirStmtLoop(cond_stmts: [LirStmt], cond: LirAtom, body: [LirStmt])
  | LirStmtTryCatch(body: [LirStmt], body_ret: Option<LirAtom>,
                     catch_param: string, catch_param_typ: TypeExpr,
                     catch_body: [LirStmt], catch_ret: Option<LirAtom>)

export type LirFunction = LirFunction(
  name: string,
  params: [LirParam],
  ret_type: TypeExpr,
  body: [LirStmt],
  ret: LirAtom,
  span: Span
)

export type LirProgram = LirProgram(functions: [LirFunction], externals: [LirExternal])

// ─── Lowering Context ────────────────────────────────────────────────────────

type TypeEntry = TypeEntry(name: string, typ: TypeExpr)

type LowerCtx = LowerCtx(
  vars: [TypeEntry],
  semantic_vars: [TypeEntry],
  stmts: [LirStmt],
  temp_counter: i64,
  enum_defs: [EnumDef]
)

// ─── Type Lookup Helpers ─────────────────────────────────────────────────────

let lookup_type = fn (name: string, entries: [TypeEntry]) -> Option<TypeExpr> do
  match entries do
    case Nil -> return None
    case Cons(v: e, rest: rest) ->
      match e do case TypeEntry(name: n, typ: t) ->
        if n == name then return Some(val: t)
        else return lookup_type(name: name, entries: rest)
        end
      end
  end
end

let insert_type = fn (name: string, typ: TypeExpr, entries: [TypeEntry]) -> [TypeEntry] do
  return Cons(v: TypeEntry(name: name, typ: typ), rest: entries)
end

// ─── WASM Type Mapping ──────────────────────────────────────────────────────

let wasm_type = fn (typ: TypeExpr) -> TypeExpr do
  match typ do
    case TyI64 -> return TyI64
    case TyF64 -> return TyF64
    case TyBool -> return TyBool
    case TyString -> return TyString
    case TyUnit -> return TyUnit
    // Heap-allocated compound types → I64 (object pointer)
    case TyList(elem: _) -> return TyI64
    case TyUserDefined(name: _, args: _) -> return TyI64
    case TyHandler(name: _, requires: _) -> return TyI64
    case _ -> return TyI64
  end
end

// ─── Atom Type Accessor ──────────────────────────────────────────────────────

export let atom_type = fn (atom: LirAtom) -> TypeExpr do
  match atom do
    case LirAtomVar(name: _, typ: t) -> return t
    case LirAtomInt(val: _) -> return TyI64
    case LirAtomFloat(val: _) -> return TyF64
    case LirAtomBool(val: _) -> return TyBool
    case LirAtomString(val: _) -> return TyString
    case LirAtomUnit -> return TyUnit
  end
end

// ─── Default Atom for Type ───────────────────────────────────────────────────

let default_atom = fn (typ: TypeExpr) -> LirAtom do
  match typ do
    case TyI64 -> return LirAtomInt(val: 0)
    case TyF64 -> return LirAtomFloat(val: "0.0")
    case TyBool -> return LirAtomBool(val: false)
    case TyString -> return LirAtomString(val: "")
    case TyUnit -> return LirAtomUnit
    case _ -> return LirAtomInt(val: 0)
  end
end

// ─── Temp Variable Generation ────────────────────────────────────────────────

type TempResult = TempResult(ctx: LowerCtx, name: string)

let new_temp = fn (ctx: LowerCtx) -> TempResult do
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
    let name = "__t" ++ from_i64(val: c)
    return TempResult(
      ctx: LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c + 1, enum_defs: ed),
      name: name
    )
  end
end

// ─── Bind Expression to Temp ─────────────────────────────────────────────────

type BindResult = BindResult(ctx: LowerCtx, atom: LirAtom)

let bind_expr_to_temp = fn (ctx: LowerCtx, expr: LirExpr, typ: TypeExpr) -> BindResult do
  let tr = new_temp(ctx: ctx)
  match tr do case TempResult(ctx: ctx2, name: name) ->
    match ctx2 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
      let new_vars = insert_type(name: name, typ: typ, entries: v)
      let new_stmts = Cons(v: LirStmtLet(name: name, typ: typ, expr: expr), rest: s)
      return BindResult(
        ctx: LowerCtx(vars: new_vars, semantic_vars: sv, stmts: new_stmts, temp_counter: c, enum_defs: ed),
        atom: LirAtomVar(name: name, typ: typ)
      )
    end
  end
end

let bind_expr_to_temp_semantic = fn (ctx: LowerCtx, expr: LirExpr, typ: TypeExpr, semantic_type: TypeExpr) -> BindResult do
  let tr = new_temp(ctx: ctx)
  match tr do case TempResult(ctx: ctx2, name: name) ->
    match ctx2 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
      let new_vars = insert_type(name: name, typ: typ, entries: v)
      let new_sv = insert_type(name: name, typ: semantic_type, entries: sv)
      let new_stmts = Cons(v: LirStmtLet(name: name, typ: typ, expr: expr), rest: s)
      return BindResult(
        ctx: LowerCtx(vars: new_vars, semantic_vars: new_sv, stmts: new_stmts, temp_counter: c, enum_defs: ed),
        atom: LirAtomVar(name: name, typ: typ)
      )
    end
  end
end

// ─── Literal to Atom ─────────────────────────────────────────────────────────

let literal_to_atom = fn (lit: Literal) -> LirAtom do
  match lit do
    case LitInt(val: vi) -> return LirAtomInt(val: vi)
    case LitFloat(val: vf) -> return LirAtomFloat(val: vf)
    case LitBool(val: vb) -> return LirAtomBool(val: vb)
    case LitString(val: vs) -> return LirAtomString(val: vs)
    case LitUnit -> return LirAtomUnit
  end
end

// ─── Semantic Type Inference ─────────────────────────────────────────────────

let infer_semantic_type = fn (expr: MirExpr, ctx: LowerCtx) -> TypeExpr do
  match ctx do case LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
    match expr do
      case MirVariable(name: n) ->
        match lookup_type(name: n, entries: sv) do
          case Some(val: t) -> return t
          case None -> return TyI64
        end
      case MirCall(func: _, args: _, ret_type: rt) -> return rt
      case MirLiteral(lit: l) ->
        match l do
          case LitInt(val: _) -> return TyI64
          case LitFloat(val: _) -> return TyF64
          case LitBool(val: _) -> return TyBool
          case LitString(val: _) -> return TyString
          case LitUnit -> return TyUnit
        end
      case MirConstructor(name: _, args: _) -> return TyI64
      case MirBinaryOp(left: _, op: op, right: _) ->
        match op do
          case OpConcat -> return TyString
          case OpEq -> return TyBool
          case OpNe -> return TyBool
          case OpLt -> return TyBool
          case OpLe -> return TyBool
          case OpGt -> return TyBool
          case OpGe -> return TyBool
          case OpAnd -> return TyBool
          case OpOr -> return TyBool
          case _ -> return TyI64
        end
      case MirIf(cond: _, then_body: tb, else_body: _) ->
        return infer_stmts_type(stmts: tb, ctx: ctx)
      case MirMatch(target: _, cases: cs) ->
        match cs do
          case Cons(v: c, rest: _) ->
            match c do case MirMatchCase(pattern: _, body: b) ->
              return infer_stmts_type(stmts: b, ctx: ctx)
            end
          case Nil -> return TyUnit
        end
      case _ -> return TyI64
    end
  end
end

let infer_stmts_type = fn (stmts: [MirStmt], ctx: LowerCtx) -> TypeExpr do
  match stmts do
    case Nil -> return TyUnit
    case Cons(v: s, rest: Nil) ->
      // Last statement determines the type
      match s do
        case MirStmtExpr(expr: e) -> return infer_semantic_type(expr: e, ctx: ctx)
        case MirStmtReturn(expr: e) -> return infer_semantic_type(expr: e, ctx: ctx)
        case _ -> return TyUnit
      end
    case Cons(v: _, rest: rest) -> return infer_stmts_type(stmts: rest, ctx: ctx)
  end
end

// ─── Binary Type Inference ───────────────────────────────────────────────────

let infer_binary_type = fn (op: BinaryOp, lhs_type: TypeExpr, rhs_type: TypeExpr) -> TypeExpr do
  match op do
    case OpEq -> return TyBool
    case OpNe -> return TyBool
    case OpLt -> return TyBool
    case OpLe -> return TyBool
    case OpGt -> return TyBool
    case OpGe -> return TyBool
    case OpAnd -> return TyBool
    case OpOr -> return TyBool
    case OpConcat -> return TyString
    case OpAdd ->
      match lhs_type do
        case TyString -> return TyString
        case TyF64 -> return TyF64
        case _ -> return TyI64
      end
    case OpSub ->
      match lhs_type do
        case TyF64 -> return TyF64
        case _ -> return TyI64
      end
    case OpMul ->
      match lhs_type do
        case TyF64 -> return TyF64
        case _ -> return TyI64
      end
    case OpDiv ->
      match lhs_type do
        case TyF64 -> return TyF64
        case _ -> return TyI64
      end
    case OpMod -> return TyI64
    case _ -> return lhs_type
  end
end

// ─── Constructor Tag (FNV-1a) ────────────────────────────────────────────────

// Simplified tag: hash name and arity for constructor discrimination
let constructor_tag = fn (name: string, arity: i64) -> i64 do
  // Use a simplified hash: just combine chars. Real FNV-1a needs bit ops.
  // For self-hosting, we use the same hash as the Rust compiler.
  // Placeholder: simple sum-based hash. MUST match Rust codegen's constructor_tag.
  // TODO: implement exact FNV-1a matching Rust
  return arity * 1000 + 1
end

// ─── Expression Lowering ─────────────────────────────────────────────────────

let lower_expr_to_atom = fn (expr: MirExpr, ctx: LowerCtx) -> BindResult do
  match expr do
    case MirLiteral(lit: l) -> return BindResult(ctx: ctx, atom: literal_to_atom(lit: l))

    case MirVariable(name: n) ->
      match ctx do case LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
        let typ = match lookup_type(name: n, entries: sv) do
          case Some(val: t) -> wasm_type(typ: t)
          case None ->
            match ctx do case LowerCtx(vars: v, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: _) ->
              match lookup_type(name: n, entries: v) do
                case Some(val: t) -> t
                case None -> TyI64
              end
            end
        end
        return BindResult(ctx: ctx, atom: LirAtomVar(name: n, typ: typ))
      end

    case MirBinaryOp(left: lhs, op: op, right: rhs) ->
      let lr = lower_expr_to_atom(expr: lhs, ctx: ctx)
      match lr do case BindResult(ctx: ctx2, atom: la) ->
        let rr = lower_expr_to_atom(expr: rhs, ctx: ctx2)
        match rr do case BindResult(ctx: ctx3, atom: ra) ->
          let result_type = infer_binary_type(op: op, lhs_type: atom_type(atom: la), rhs_type: atom_type(atom: ra))
          return bind_expr_to_temp(ctx: ctx3,
            expr: LirExprBinary(op: op, lhs: la, rhs: ra, typ: result_type),
            typ: result_type)
        end
      end

    case MirCall(func: f, args: args, ret_type: rt) ->
      let ar = lir_lower_call_args(args: args, ctx: ctx)
      match ar do case LowerCallArgsResult(ctx: ctx2, lir_args: la) ->
        let wt = wasm_type(typ: rt)
        return bind_expr_to_temp_semantic(ctx: ctx2,
          expr: LirExprCall(func: f, args: la, typ: wt),
          typ: wt, semantic_type: rt)
      end

    case MirConstructor(name: n, args: args) ->
      let ar = lower_exprs_to_atoms(exprs: args, ctx: ctx)
      match ar do case LowerExprsResult(ctx: ctx2, atoms: atoms) ->
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprConstructor(name: n, args: atoms, typ: TyI64),
          typ: TyI64)
      end

    case MirRecord(fields: fields) ->
      let fr = lir_lower_named_exprs(fields: fields, ctx: ctx)
      match fr do case LowerNamedExprsResult(ctx: ctx2, atoms: named_atoms) ->
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprRecord(fields: named_atoms, typ: TyI64),
          typ: TyI64)
      end

    case MirFieldAccess(target: recv, field: field) ->
      let rr = lower_expr_to_atom(expr: recv, ctx: ctx)
      match rr do case BindResult(ctx: ctx2, atom: obj_atom) ->
        // For now, use index 0 and type I64 as a simplified fallback
        // TODO: resolve field index from semantic type
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprObjectField(value: obj_atom, index: 0, typ: TyI64),
          typ: TyI64)
      end

    case MirBorrow(name: n) ->
      match ctx do case LowerCtx(vars: v, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: _) ->
        let typ = match lookup_type(name: n, entries: v) do
          case Some(val: t) -> t
          case None -> TyI64
        end
        return BindResult(ctx: ctx, atom: LirAtomVar(name: n, typ: typ))
      end

    case MirRaise(expr: e) ->
      let er = lower_expr_to_atom(expr: e, ctx: ctx)
      match er do case BindResult(ctx: ctx2, atom: a) ->
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprRaise(value: a, typ: TyUnit),
          typ: TyUnit)
      end

    case MirIf(cond: cond, then_body: tb, else_body: eb) ->
      return lower_if_expr(cond: cond, then_body: tb, else_body: eb, ctx: ctx)

    case MirMatch(target: tgt, cases: cs) ->
      return lower_match_expr(target: tgt, cases: cs, ctx: ctx)

    case MirWhile(cond: _, body: _) ->
      // While loops not valid in expression position
      return BindResult(ctx: ctx, atom: LirAtomUnit)

    case MirArray(elems: elems) ->
      let er = lower_exprs_to_atoms(exprs: elems, ctx: ctx)
      match er do case LowerExprsResult(ctx: ctx2, atoms: atoms) ->
        // Encode array as record with numeric indices
        let named = number_atoms(atoms: atoms, idx: 0)
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprRecord(fields: named, typ: TyI64),
          typ: TyI64)
      end

    case MirIndex(target: arr, index: idx) ->
      let ar = lower_expr_to_atom(expr: arr, ctx: ctx)
      match ar do case BindResult(ctx: ctx2, atom: arr_atom) ->
        let ir = lower_expr_to_atom(expr: idx, ctx: ctx2)
        match ir do case BindResult(ctx: ctx3, atom: idx_atom) ->
          return bind_expr_to_temp(ctx: ctx3,
            expr: LirExprCall(func: "__array_get",
              args: Cons(v: LirCallArg(label: "arr", value: arr_atom),
                    rest: Cons(v: LirCallArg(label: "idx", value: idx_atom), rest: Nil)),
              typ: TyI64),
            typ: TyI64)
        end
      end
  end
end

// ─── Helper: Number atoms for array encoding ─────────────────────────────────

let number_atoms = fn (atoms: [LirAtom], idx: i64) -> [LirNamedAtom] do
  match atoms do
    case Nil -> return Nil
    case Cons(v: a, rest: rest) ->
      return Cons(
        v: LirNamedAtom(name: from_i64(val: idx), value: a),
        rest: number_atoms(atoms: rest, idx: idx + 1)
      )
  end
end

// ─── Helper: Lower Call Args ─────────────────────────────────────────────────

type LowerCallArgsResult = LowerCallArgsResult(ctx: LowerCtx, lir_args: [LirCallArg])

let lir_lower_call_args = fn (args: [MirCallArg], ctx: LowerCtx) -> LowerCallArgsResult do
  match args do
    case Nil -> return LowerCallArgsResult(ctx: ctx, lir_args: Nil)
    case Cons(v: arg, rest: rest) ->
      match arg do case MirCallArg(label: l, value: e) ->
        let br = lower_expr_to_atom(expr: e, ctx: ctx)
        match br do case BindResult(ctx: ctx2, atom: a) ->
          let rr = lir_lower_call_args(args: rest, ctx: ctx2)
          match rr do case LowerCallArgsResult(ctx: ctx3, lir_args: la) ->
            return LowerCallArgsResult(ctx: ctx3,
              lir_args: Cons(v: LirCallArg(label: l, value: a), rest: la))
          end
        end
      end
  end
end

// ─── Helper: Lower Multiple Exprs ────────────────────────────────────────────

type LowerExprsResult = LowerExprsResult(ctx: LowerCtx, atoms: [LirAtom])

let lower_exprs_to_atoms = fn (exprs: [MirExpr], ctx: LowerCtx) -> LowerExprsResult do
  match exprs do
    case Nil -> return LowerExprsResult(ctx: ctx, atoms: Nil)
    case Cons(v: e, rest: rest) ->
      let br = lower_expr_to_atom(expr: e, ctx: ctx)
      match br do case BindResult(ctx: ctx2, atom: a) ->
        let rr = lower_exprs_to_atoms(exprs: rest, ctx: ctx2)
        match rr do case LowerExprsResult(ctx: ctx3, atoms: rest_atoms) ->
          return LowerExprsResult(ctx: ctx3, atoms: Cons(v: a, rest: rest_atoms))
        end
      end
  end
end

// ─── Helper: Lower Named Exprs ───────────────────────────────────────────────

type LowerNamedExprsResult = LowerNamedExprsResult(ctx: LowerCtx, atoms: [LirNamedAtom])

let lir_lower_named_exprs = fn (fields: [MirNamedExpr], ctx: LowerCtx) -> LowerNamedExprsResult do
  match fields do
    case Nil -> return LowerNamedExprsResult(ctx: ctx, atoms: Nil)
    case Cons(v: f, rest: rest) ->
      match f do case MirNamedExpr(name: n, value: e) ->
        let br = lower_expr_to_atom(expr: e, ctx: ctx)
        match br do case BindResult(ctx: ctx2, atom: a) ->
          let rr = lir_lower_named_exprs(fields: rest, ctx: ctx2)
          match rr do case LowerNamedExprsResult(ctx: ctx3, atoms: na) ->
            return LowerNamedExprsResult(ctx: ctx3,
              atoms: Cons(v: LirNamedAtom(name: n, value: a), rest: na))
          end
        end
      end
  end
end

// ─── If Expression Lowering ──────────────────────────────────────────────────

let lower_if_expr = fn (cond: MirExpr, then_body: [MirStmt], else_body: Option<[MirStmt]>, ctx: LowerCtx) -> BindResult do
  let cr = lower_expr_to_atom(expr: cond, ctx: ctx)
  match cr do case BindResult(ctx: ctx2, atom: cond_atom) ->
    let sem_type = infer_stmts_type(stmts: then_body, ctx: ctx2)
    let result_type = wasm_type(typ: sem_type)
    let tr = new_temp(ctx: ctx2)
    match tr do case TempResult(ctx: ctx3, name: result_name) ->
      // Register result variable
      match ctx3 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
        let ctx4 = LowerCtx(
          vars: insert_type(name: result_name, typ: result_type, entries: v),
          semantic_vars: insert_type(name: result_name, typ: sem_type, entries: sv),
          stmts: Cons(v: LirStmtLet(name: result_name, typ: result_type,
                         expr: LirExprAtom(atom: default_atom(typ: result_type))),
                      rest: s),
          temp_counter: c,
          enum_defs: ed
        )
        // Lower then branch
        let then_r = lower_branch_for_value(body: then_body, result_name: result_name,
                                             result_type: result_type, ctx: ctx4)
        match then_r do case BranchResult(ctx: ctx5, stmts: then_stmts) ->
          // Lower else branch
          let else_r = match else_body do
            case Some(val: eb) -> lower_branch_for_value(body: eb, result_name: result_name,
                                                          result_type: result_type, ctx: ctx5)
            case None -> BranchResult(ctx: ctx5, stmts: Nil)
          end
          match else_r do case BranchResult(ctx: ctx6, stmts: else_stmts) ->
            // Add the if statement
            match ctx6 do case LowerCtx(vars: v2, semantic_vars: sv2, stmts: s2, temp_counter: c2, enum_defs: ed2) ->
              let ctx7 = LowerCtx(
                vars: v2, semantic_vars: sv2,
                stmts: Cons(v: LirStmtIf(cond: cond_atom, then_body: then_stmts, else_body: else_stmts), rest: s2),
                temp_counter: c2, enum_defs: ed2
              )
              return BindResult(ctx: ctx7, atom: LirAtomVar(name: result_name, typ: result_type))
            end
          end
        end
      end
    end
  end
end

// ─── Branch Value Extraction ─────────────────────────────────────────────────

type BranchResult = BranchResult(ctx: LowerCtx, stmts: [LirStmt])

let lower_branch_for_value = fn (body: [MirStmt], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> BranchResult do
  // Save current statements, lower branch in isolation
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: saved_stmts, temp_counter: c, enum_defs: ed) ->
    let branch_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: Nil, temp_counter: c, enum_defs: ed)
    let result = lower_branch_body(body: body, result_name: result_name, result_type: result_type, ctx: branch_ctx)
    match result do case BranchBodyResult(ctx: ctx2, value_opt: val_opt) ->
      match ctx2 do case LowerCtx(vars: v2, semantic_vars: sv2, stmts: branch_stmts, temp_counter: c2, enum_defs: _) ->
        // Assign value if present
        let final_stmts = match val_opt do
          case Some(val: atom) ->
            // If atom is unit but result_type is non-unit, use default to avoid empty stack
            let safe_atom = match atom do
              case LirAtomUnit -> default_atom(typ: result_type)
              case _ -> atom
            end
            Cons(v: LirStmtLet(name: result_name, typ: result_type,
                               expr: LirExprAtom(atom: safe_atom)), rest: branch_stmts)
          case None -> branch_stmts
        end
        // Restore outer context with updated temp counter
        let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved_stmts, temp_counter: c2, enum_defs: ed)
        return BranchResult(ctx: restored, stmts: reverse_stmts(stmts: final_stmts))
      end
    end
  end
end

type BranchBodyResult = BranchBodyResult(ctx: LowerCtx, value_opt: Option<LirAtom>)

let lower_branch_body = fn (body: [MirStmt], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> BranchBodyResult do
  match body do
    case Nil -> return BranchBodyResult(ctx: ctx, value_opt: None)
    case Cons(v: last, rest: Nil) ->
      // Last statement — extract value
      match last do
        case MirStmtExpr(expr: e) ->
          let br = lower_expr_to_atom(expr: e, ctx: ctx)
          match br do case BindResult(ctx: ctx2, atom: a) ->
            return BranchBodyResult(ctx: ctx2, value_opt: Some(val: a))
          end
        case MirStmtReturn(expr: e) ->
          let br = lower_expr_to_atom(expr: e, ctx: ctx)
          match br do case BindResult(ctx: ctx2, atom: a) ->
            return BranchBodyResult(ctx: ctx2, value_opt: Some(val: a))
          end
        case _ ->
          let sr = lower_stmt_inner(stmt: last, ret_type: TyUnit, ctx: ctx)
          match sr do case LowerStmtResult(ctx: ctx2, ret: _) ->
            return BranchBodyResult(ctx: ctx2, value_opt: None)
          end
      end
    case Cons(v: s, rest: rest) ->
      let sr = lower_stmt_inner(stmt: s, ret_type: TyUnit, ctx: ctx)
      match sr do case LowerStmtResult(ctx: ctx2, ret: _) ->
        return lower_branch_body(body: rest, result_name: result_name, result_type: result_type, ctx: ctx2)
      end
  end
end

// ─── Match Expression Lowering ───────────────────────────────────────────────

let lower_match_expr = fn (target: MirExpr, cases: [MirMatchCase], ctx: LowerCtx) -> BindResult do
  let tr = lower_expr_to_atom(expr: target, ctx: ctx)
  match tr do case BindResult(ctx: ctx2, atom: target_atom) ->
    match cases do
      case Nil -> return BindResult(ctx: ctx2, atom: LirAtomUnit)
      case _ ->
        // Lower all cases to get accurate types
        let cr = lower_match_cases_expr(cases: cases, target_atom: target_atom, ctx: ctx2)
        match cr do case LowerMatchCasesExprResult(ctx: ctx3, lowered: lowered) ->
          // Infer semantic type from first case value
          let sem_type = infer_case_value_type(cases: lowered, ctx: ctx3)
          let result_type = wasm_type(typ: sem_type)
          let nr = new_temp(ctx: ctx3)
          match nr do case TempResult(ctx: ctx4, name: result_name) ->
            match ctx4 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
              let ctx5 = LowerCtx(
                vars: insert_type(name: result_name, typ: result_type, entries: v),
                semantic_vars: insert_type(name: result_name, typ: sem_type, entries: sv),
                stmts: Cons(v: LirStmtLet(name: result_name, typ: result_type,
                               expr: LirExprAtom(atom: default_atom(typ: result_type))), rest: s),
                temp_counter: c, enum_defs: ed
              )
              // Build nested if chain
              let chain_stmts = build_match_if_chain(cases: lowered, result_name: result_name,
                                                      result_type: result_type)
              match ctx5 do case LowerCtx(vars: v2, semantic_vars: sv2, stmts: s2, temp_counter: c2, enum_defs: ed2) ->
                // chain_stmts is forward-order; context stmts are reversed (newest first)
                let ctx6 = LowerCtx(vars: v2, semantic_vars: sv2,
                  stmts: append_stmts(stmts: reverse_stmts(stmts: chain_stmts), tail: s2),
                  temp_counter: c2, enum_defs: ed2)
                return BindResult(ctx: ctx6, atom: LirAtomVar(name: result_name, typ: result_type))
              end
            end
          end
        end
    end
  end
end

type LoweredMatchCase = LoweredMatchCase(cond: Option<LirAtom>, cond_stmts: [LirStmt], stmts: [LirStmt], value: LirAtom, final_temp: i64)

type LoweredMatchCaseWithCtx = LoweredMatchCaseWithCtx(lmc: LoweredMatchCase, next_temp: i64)

type LowerMatchCasesExprResult = LowerMatchCasesExprResult(ctx: LowerCtx, lowered: [LoweredMatchCase])

let lower_match_cases_expr = fn (cases: [MirMatchCase], target_atom: LirAtom, ctx: LowerCtx) -> LowerMatchCasesExprResult do
  match cases do
    case Nil -> return LowerMatchCasesExprResult(ctx: ctx, lowered: Nil)
    case Cons(v: c, rest: rest) ->
      match c do case MirMatchCase(pattern: pat, body: body) ->
        let cr = lower_match_case_expr_tracked(target_atom: target_atom, pattern: pat, body: body, ctx: ctx)
        match cr do case LoweredMatchCaseWithCtx(lmc: lmc, next_temp: nt) ->
          match lmc do case LoweredMatchCase(cond: cond, cond_stmts: cs, stmts: stmts, value: val, final_temp: ft) ->
            // Advance temp_counter for next case to avoid name collisions
            match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: _, enum_defs: ed) ->
              let next_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: nt, enum_defs: ed)
              let rr = lower_match_cases_expr(cases: rest, target_atom: target_atom, ctx: next_ctx)
              match rr do case LowerMatchCasesExprResult(ctx: ctx2, lowered: rest_lowered) ->
                return LowerMatchCasesExprResult(ctx: ctx2,
                  lowered: Cons(v: LoweredMatchCase(cond: cond, cond_stmts: cs, stmts: stmts, value: val, final_temp: ft), rest: rest_lowered))
              end
            end
          end
        end
      end
  end
end

let lower_match_case_expr_tracked = fn (target_atom: LirAtom, pattern: MirPattern,
    body: [MirStmt], ctx: LowerCtx) -> LoweredMatchCaseWithCtx do
  let result = lower_match_case_expr(target_atom: target_atom, pattern: pattern, body: body, ctx: ctx)
  // Use the actual final temp counter from the lowering result
  match result do case LoweredMatchCase(cond: _, cond_stmts: _, stmts: _, value: _, final_temp: ft) ->
    return LoweredMatchCaseWithCtx(lmc: result, next_temp: ft)
  end
end

let count_let_stmts = fn (stmts: [LirStmt]) -> i64 do
  match stmts do
    case Nil -> return 0
    case Cons(v: s, rest: rest) ->
      let this_count = match s do
        case LirStmtLet(name: _, typ: _, expr: _) -> 1
        case LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
          count_let_stmts(stmts: tb) + count_let_stmts(stmts: eb)
        case LirStmtIfReturn(cond: _, then_body: tb, then_ret: _, else_body: eb, else_ret: _, ret_type: _) ->
          count_let_stmts(stmts: tb) + count_let_stmts(stmts: eb)
        case _ -> 0
      end
      return this_count + count_let_stmts(stmts: rest)
  end
end

let lower_match_case_expr = fn (target_atom: LirAtom, pattern: MirPattern, body: [MirStmt], ctx: LowerCtx) -> LoweredMatchCase do
  // Collect pattern conditions and bindings
  // For now, simplified: just support wildcard, variable, literal, and constructor patterns
  match pattern do
    case MirPatWildcard ->
      let vr = lower_case_body_value(body: body, ctx: ctx)
      match vr do case CaseBodyValueResult(stmts: stmts, value: val, final_temp: ft) ->
        return LoweredMatchCase(cond: None, cond_stmts: Nil, stmts: stmts, value: val, final_temp: ft)
      end

    case MirPatVariable(name: n, sigil: _) ->
      // Bind the variable to the target
      match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
        let bound_ctx = LowerCtx(
          vars: insert_type(name: n, typ: atom_type(atom: target_atom), entries: v),
          semantic_vars: insert_type(name: n, typ: atom_type(atom: target_atom), entries: sv),
          stmts: Nil, temp_counter: match ctx do case LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: c, enum_defs: _) -> c end,
          enum_defs: match ctx do case LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed) -> ed end
        )
        let vr = lower_case_body_value(body: body, ctx: bound_ctx)
        match vr do case CaseBodyValueResult(stmts: stmts, value: val, final_temp: ft) ->
          let binding_stmt = LirStmtLet(name: n, typ: atom_type(atom: target_atom),
                                         expr: LirExprAtom(atom: target_atom))
          return LoweredMatchCase(cond: None, cond_stmts: Nil, stmts: Cons(v: binding_stmt, rest: stmts), value: val, final_temp: ft)
        end
      end

    case MirPatLiteral(lit: l) ->
      let expected = literal_to_atom(lit: l)
      let cond_atom = LirAtomBool(val: true)
      // TODO: proper equality check
      let vr = lower_case_body_value(body: body, ctx: ctx)
      match vr do case CaseBodyValueResult(stmts: stmts, value: val, final_temp: ft) ->
        return LoweredMatchCase(cond: Some(val: cond_atom), cond_stmts: Nil, stmts: stmts, value: val, final_temp: ft)
      end

    case MirPatConstructor(name: n, fields: fields) ->
      let arity = list_length(lst: fields)
      let tag = constructor_tag(name: n, arity: arity)
      // Build field extraction in a fresh stmt context
      match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: _, temp_counter: tc, enum_defs: ed) ->
        let fresh_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: Nil, temp_counter: tc, enum_defs: ed)
        // Tag check: let __tN = ObjectTag(target); let __tN+1 = (__tN == expected_tag)
        let tag_br = bind_expr_to_temp(ctx: fresh_ctx,
          expr: LirExprObjectTag(value: target_atom, typ: TyI64), typ: TyI64)
        match tag_br do case BindResult(ctx: ctx2, atom: tag_atom) ->
          let cond_br = bind_expr_to_temp(ctx: ctx2,
            expr: LirExprBinary(op: OpEq, lhs: tag_atom, rhs: LirAtomInt(val: tag), typ: TyBool),
            typ: TyBool)
          match cond_br do case BindResult(ctx: ctx3, atom: cond_atom) ->
            // Separate cond_stmts (tag check + comparison) from field extraction
            match ctx3 do case LowerCtx(vars: v3, semantic_vars: sv3, stmts: cond_stmts_rev, temp_counter: tc3, enum_defs: ed3) ->
              let cond_stmts = reverse_stmts(stmts: cond_stmts_rev)
              // Extract fields in fresh context (without cond stmts)
              let field_start_ctx = LowerCtx(vars: v3, semantic_vars: sv3, stmts: Nil, temp_counter: tc3, enum_defs: ed3)
              let field_ctx = extract_ctor_fields(
                target_atom: target_atom, fields: fields, field_idx: 0, ctx: field_start_ctx)
              match field_ctx do case LowerCtx(vars: _, semantic_vars: _, stmts: field_stmts_rev, temp_counter: _, enum_defs: _) ->
                let field_stmts = reverse_stmts(stmts: field_stmts_rev)
                // Lower body with field vars available
                let vr = lower_case_body_value(body: body, ctx: field_ctx)
                match vr do case CaseBodyValueResult(stmts: body_stmts, value: val, final_temp: ft) ->
                  let body_and_fields = append_stmts(stmts: field_stmts, tail: body_stmts)
                  return LoweredMatchCase(cond: Some(val: cond_atom), cond_stmts: cond_stmts, stmts: body_and_fields, value: val, final_temp: ft)
                end
              end
            end
          end
        end
      end

    case MirPatRecord(fields: rec_fields, is_partial: _) ->
      // Extract record fields and bind pattern variables
      match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: _, temp_counter: tc, enum_defs: ed) ->
        let fresh_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: Nil, temp_counter: tc, enum_defs: ed)
        let field_ctx = extract_record_fields(
          target_atom: target_atom, fields: rec_fields, field_idx: 0, ctx: fresh_ctx)
        match field_ctx do case LowerCtx(vars: _, semantic_vars: _, stmts: extract_stmts, temp_counter: _, enum_defs: _) ->
          let prefix_stmts = reverse_stmts(stmts: extract_stmts)
          let vr = lower_case_body_value(body: body, ctx: field_ctx)
          match vr do case CaseBodyValueResult(stmts: body_stmts, value: val, final_temp: ft) ->
            let all_stmts = append_stmts(stmts: prefix_stmts, tail: body_stmts)
            return LoweredMatchCase(cond: None, cond_stmts: Nil, stmts: all_stmts, value: val, final_temp: ft)
          end
        end
      end
  end
end

// ─── Constructor/Record Field Extraction ──────────────────────────────────────

let extract_ctor_fields = fn (target_atom: LirAtom, fields: [MirPatternField],
                               field_idx: i64, ctx: LowerCtx) -> LowerCtx do
  match fields do
    case Nil -> return ctx
    case Cons(v: f, rest: rest) ->
      match f do case MirPatternField(name: _, pattern: pat) ->
        let ctx2 = extract_pattern_field(
          target_atom: target_atom, pat: pat, field_idx: field_idx, ctx: ctx)
        return extract_ctor_fields(
          target_atom: target_atom, fields: rest, field_idx: field_idx + 1, ctx: ctx2)
      end
  end
end

let extract_record_fields = fn (target_atom: LirAtom, fields: [MirRecordPatField],
                                 field_idx: i64, ctx: LowerCtx) -> LowerCtx do
  match fields do
    case Nil -> return ctx
    case Cons(v: f, rest: rest) ->
      match f do case MirRecordPatField(name: _, pattern: pat) ->
        let ctx2 = extract_pattern_field(
          target_atom: target_atom, pat: pat, field_idx: field_idx, ctx: ctx)
        return extract_record_fields(
          target_atom: target_atom, fields: rest, field_idx: field_idx + 1, ctx: ctx2)
      end
  end
end

let extract_pattern_field = fn (target_atom: LirAtom, pat: MirPattern,
                                 field_idx: i64, ctx: LowerCtx) -> LowerCtx do
  match pat do
    case MirPatVariable(name: var_name, sigil: _) ->
      // Bind: let var_name = ObjectField(target, field_idx)
      match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
        let binding_stmt = LirStmtLet(name: var_name, typ: TyI64,
          expr: LirExprObjectField(value: target_atom, index: field_idx, typ: TyI64))
        return LowerCtx(
          vars: insert_type(name: var_name, typ: TyI64, entries: v),
          semantic_vars: insert_type(name: var_name, typ: TyI64, entries: sv),
          stmts: Cons(v: binding_stmt, rest: s),
          temp_counter: c, enum_defs: ed)
      end
    case MirPatWildcard ->
      return ctx
    case _ ->
      // Nested patterns: extract to temp, skip binding for now
      return ctx
  end
end

type CaseBodyValueResult = CaseBodyValueResult(stmts: [LirStmt], value: LirAtom, final_temp: i64)

let lower_case_body_value = fn (body: [MirStmt], ctx: LowerCtx) -> CaseBodyValueResult do
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: _, temp_counter: c, enum_defs: ed) ->
    let work_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: Nil, temp_counter: c, enum_defs: ed)
    let result = lower_branch_body(body: body, result_name: "__case_val", result_type: TyI64, ctx: work_ctx)
    match result do case BranchBodyResult(ctx: ctx2, value_opt: val_opt) ->
      match ctx2 do case LowerCtx(vars: _, semantic_vars: _, stmts: branch_stmts, temp_counter: final_tc, enum_defs: _) ->
        let stmts = reverse_stmts(stmts: branch_stmts)
        let val = match val_opt do
          case Some(val: a) -> a
          case None -> LirAtomInt(val: 0)
        end
        return CaseBodyValueResult(stmts: stmts, value: val, final_temp: final_tc)
      end
    end
  end
end

let infer_case_value_type = fn (cases: [LoweredMatchCase], ctx: LowerCtx) -> TypeExpr do
  match cases do
    case Nil -> return TyUnit
    case Cons(v: c, rest: rest) ->
      match c do case LoweredMatchCase(cond: _, cond_stmts: _, stmts: _, value: val, final_temp: _) ->
        let t = atom_type(atom: val)
        match t do
          case TyUnit -> return infer_case_value_type(cases: rest, ctx: ctx)
          case _ ->
            // For Var atoms, look up their semantic type
            match val do
              case LirAtomVar(name: n, typ: _) ->
                match ctx do case LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
                  match lookup_type(name: n, entries: sv) do
                    case Some(val: st) -> return st
                    case None -> return t
                  end
                end
              case _ -> return t
            end
        end
      end
  end
end

let build_match_if_chain = fn (cases: [LoweredMatchCase], result_name: string, result_type: TypeExpr) -> [LirStmt] do
  // Build reversed (cases processed last-to-first to nest else bodies)
  return build_chain_reversed(cases: reverse_lowered_cases(cases: cases), chain: Nil,
                               result_name: result_name, result_type: result_type)
end

let build_chain_reversed = fn (cases: [LoweredMatchCase], chain: [LirStmt],
                                result_name: string, result_type: TypeExpr) -> [LirStmt] do
  match cases do
    case Nil -> return chain
    case Cons(v: c, rest: rest) ->
      match c do case LoweredMatchCase(cond: cond_opt, cond_stmts: cs, stmts: case_stmts, value: val, final_temp: _) ->
        let else_body = chain
        let cond = match else_body do
          case Nil -> LirAtomBool(val: true)
          case _ ->
            match cond_opt do
              case Some(val: c) -> c
              case None -> LirAtomBool(val: true)
            end
        end
        // If val is unit but result_type is non-unit, use default atom to avoid empty stack
        let safe_val = match val do
          case LirAtomUnit -> default_atom(typ: result_type)
          case _ -> val
        end
        let assign_stmt = LirStmtLet(name: result_name, typ: result_type,
                                      expr: LirExprAtom(atom: safe_val))
        let then_body = append_stmts(stmts: case_stmts, tail: Cons(v: assign_stmt, rest: Nil))
        let if_stmt = LirStmtIf(cond: cond, then_body: then_body, else_body: else_body)
        // cond_stmts go BEFORE the if so the condition variable is computed first
        let this_chain = append_stmts(stmts: cs, tail: Cons(v: if_stmt, rest: Nil))
        return build_chain_reversed(cases: rest, chain: this_chain,
                                     result_name: result_name, result_type: result_type)
      end
  end
end

// ─── Statement Lowering ──────────────────────────────────────────────────────

type LowerStmtResult = LowerStmtResult(ctx: LowerCtx, ret: Option<LirAtom>)

let lower_stmt_inner = fn (stmt: MirStmt, ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult do
  match stmt do
    case MirStmtLet(name: n, typ: t, expr: e) ->
      let sem_type = infer_semantic_type(expr: e, ctx: ctx)
      let br = lower_expr_to_atom(expr: e, ctx: ctx)
      match br do case BindResult(ctx: ctx2, atom: a) ->
        let inferred = atom_type(atom: a)
        // Prefer semantic type from lowered atom if available
        let actual_sem = match a do
          case LirAtomVar(name: vn, typ: _) ->
            match ctx2 do case LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
              match lookup_type(name: vn, entries: sv) do
                case Some(val: st) -> st
                case None -> sem_type
              end
            end
          case _ -> sem_type
        end
        match ctx2 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
          let ctx3 = LowerCtx(
            vars: insert_type(name: n, typ: inferred, entries: v),
            semantic_vars: insert_type(name: n, typ: actual_sem, entries: sv),
            stmts: Cons(v: LirStmtLet(name: n, typ: inferred, expr: LirExprAtom(atom: a)), rest: s),
            temp_counter: c, enum_defs: ed
          )
          return LowerStmtResult(ctx: ctx3, ret: None)
        end
      end

    case MirStmtExpr(expr: e) ->
      // Check for if/match/while at statement level
      match e do
        case MirIf(cond: cond, then_body: tb, else_body: eb) ->
          return lower_if_stmt(cond: cond, then_body: tb, else_body: eb, ret_type: ret_type, ctx: ctx)
        case MirMatch(target: tgt, cases: cs) ->
          return lower_match_stmt(target: tgt, cases: cs, ret_type: ret_type, ctx: ctx)
        case MirWhile(cond: cond, body: body) ->
          return lower_while_stmt(cond: cond, body: body, ctx: ctx)
        case _ ->
          let br = lower_expr_to_atom(expr: e, ctx: ctx)
          match br do case BindResult(ctx: ctx2, atom: _) ->
            return LowerStmtResult(ctx: ctx2, ret: None)
          end
      end

    case MirStmtReturn(expr: e) ->
      // Check for tail call optimization
      match e do
        case MirCall(func: f, args: args, ret_type: rt) ->
          let ar = lir_lower_call_args(args: args, ctx: ctx)
          match ar do case LowerCallArgsResult(ctx: ctx2, lir_args: la) ->
            let wt = wasm_type(typ: rt)
            let br = bind_expr_to_temp(ctx: ctx2,
              expr: LirExprTailCall(func: f, args: la, typ: wt), typ: wt)
            match br do case BindResult(ctx: ctx3, atom: a) ->
              return LowerStmtResult(ctx: ctx3, ret: Some(val: a))
            end
          end
        case _ ->
          let br = lower_expr_to_atom(expr: e, ctx: ctx)
          match br do case BindResult(ctx: ctx2, atom: a) ->
            return LowerStmtResult(ctx: ctx2, ret: Some(val: a))
          end
      end

    case MirStmtAssign(target: tgt, value: val) ->
      // ANF has no mutation — emit as Let re-binding
      match tgt do
        case MirVariable(name: n) ->
          let br = lower_expr_to_atom(expr: val, ctx: ctx)
          match br do case BindResult(ctx: ctx2, atom: a) ->
            match ctx2 do case LowerCtx(vars: vs, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
              let ctx3 = LowerCtx(
                vars: insert_type(name: n, typ: atom_type(atom: a), entries: vs),
                semantic_vars: sv,
                stmts: Cons(v: LirStmtLet(name: n, typ: atom_type(atom: a), expr: LirExprAtom(atom: a)), rest: s),
                temp_counter: c, enum_defs: ed
              )
              return LowerStmtResult(ctx: ctx3, ret: None)
            end
          end
        case _ ->
          // Non-variable assign — just lower both sides
          let br = lower_expr_to_atom(expr: val, ctx: ctx)
          match br do case BindResult(ctx: ctx2, atom: _) ->
            return LowerStmtResult(ctx: ctx2, ret: None)
          end
      end

    case MirStmtTry(body: body, catch_param: cp, catch_body: cb) ->
      return lower_try_stmt(body: body, catch_param: cp, catch_body: cb, ret_type: ret_type, ctx: ctx)

    case MirStmtConc(tasks: _) ->
      // Conc blocks not supported in self-hosting compiler yet
      return LowerStmtResult(ctx: ctx, ret: None)
  end
end

// ─── If Statement Lowering ───────────────────────────────────────────────────

let lower_if_stmt = fn (cond: MirExpr, then_body: [MirStmt], else_body: Option<[MirStmt]>, ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult do
  let cr = lower_expr_to_atom(expr: cond, ctx: ctx)
  match cr do case BindResult(ctx: ctx2, atom: cond_atom) ->
    let then_r = lower_block(stmts: then_body, ret_type: ret_type, ctx: ctx2)
    match then_r do case BlockResult(ctx: ctx3, stmts: then_stmts, ret: then_ret) ->
      match else_body do
        case Some(val: eb) ->
          let else_r = lower_block(stmts: eb, ret_type: ret_type, ctx: ctx3)
          match else_r do case BlockResult(ctx: ctx4, stmts: else_stmts, ret: else_ret) ->
            match then_ret do
              case Some(val: _) ->
                match ctx4 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
                  let then_ret_val = match then_ret do
                    case Some(val: a) -> a
                    case None -> LirAtomUnit
                  end
                  let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                    stmts: Cons(v: LirStmtIfReturn(cond: cond_atom,
                      then_body: then_stmts, then_ret: then_ret_val,
                      else_body: else_stmts, else_ret: else_ret,
                      ret_type: ret_type), rest: s),
                    temp_counter: c, enum_defs: ed)
                  return LowerStmtResult(ctx: ctx5, ret: None)
                end
              case None ->
                match else_ret do
                  case Some(val: _) ->
                    match ctx4 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
                      let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                        stmts: Cons(v: LirStmtIfReturn(cond: cond_atom,
                          then_body: then_stmts, then_ret: default_atom(typ: ret_type),
                          else_body: else_stmts, else_ret: else_ret,
                          ret_type: ret_type), rest: s),
                        temp_counter: c, enum_defs: ed)
                      return LowerStmtResult(ctx: ctx5, ret: None)
                    end
                  case None ->
                    match ctx4 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
                      let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                        stmts: Cons(v: LirStmtIf(cond: cond_atom, then_body: then_stmts, else_body: else_stmts), rest: s),
                        temp_counter: c, enum_defs: ed)
                      return LowerStmtResult(ctx: ctx5, ret: None)
                    end
                end
            end
          end
        case None ->
          match ctx3 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
            match then_ret do
              case Some(val: tr) ->
                let ctx4 = LowerCtx(vars: v, semantic_vars: sv,
                  stmts: Cons(v: LirStmtIfReturn(cond: cond_atom,
                    then_body: then_stmts, then_ret: tr,
                    else_body: Nil, else_ret: None,
                    ret_type: ret_type), rest: s),
                  temp_counter: c, enum_defs: ed)
                return LowerStmtResult(ctx: ctx4, ret: None)
              case None ->
                let ctx4 = LowerCtx(vars: v, semantic_vars: sv,
                  stmts: Cons(v: LirStmtIf(cond: cond_atom, then_body: then_stmts, else_body: Nil), rest: s),
                  temp_counter: c, enum_defs: ed)
                return LowerStmtResult(ctx: ctx4, ret: None)
            end
          end
      end
    end
  end
end

// ─── Match Statement Lowering ────────────────────────────────────────────────

let lower_match_stmt = fn (target: MirExpr, cases: [MirMatchCase], ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult do
  let tr = lower_expr_to_atom(expr: target, ctx: ctx)
  match tr do case BindResult(ctx: ctx2, atom: target_atom) ->
    // Lower each case and build IfReturn chain
    let cr = lower_match_cases_stmt(cases: cases, target_atom: target_atom, ret_type: ret_type, ctx: ctx2)
    match cr do case LowerMatchCasesStmtResult(ctx: ctx3, chain: chain) ->
      match chain do
        case Some(val: stmt) ->
          match ctx3 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
            let ctx4 = LowerCtx(vars: v, semantic_vars: sv, stmts: Cons(v: stmt, rest: s),
              temp_counter: c, enum_defs: ed)
            return LowerStmtResult(ctx: ctx4, ret: None)
          end
        case None -> return LowerStmtResult(ctx: ctx3, ret: None)
      end
    end
  end
end

type LowerMatchCasesStmtResult = LowerMatchCasesStmtResult(ctx: LowerCtx, chain: Option<LirStmt>)

let lower_match_cases_stmt = fn (cases: [MirMatchCase], target_atom: LirAtom, ret_type: TypeExpr, ctx: LowerCtx) -> LowerMatchCasesStmtResult do
  // Build chain in reverse
  let reversed = reverse_match_cases(cases: cases)
  return build_match_stmt_chain(cases: reversed, target_atom: target_atom, ret_type: ret_type,
                                 chain: None, ctx: ctx)
end

let build_match_stmt_chain = fn (cases: [MirMatchCase], target_atom: LirAtom, ret_type: TypeExpr,
                                  chain: Option<LirStmt>, ctx: LowerCtx) -> LowerMatchCasesStmtResult do
  match cases do
    case Nil -> return LowerMatchCasesStmtResult(ctx: ctx, chain: chain)
    case Cons(v: c, rest: rest) ->
      match c do case MirMatchCase(pattern: pat, body: body) ->
        // Lower case body
        let br = lower_block(stmts: body, ret_type: ret_type, ctx: ctx)
        match br do case BlockResult(ctx: ctx2, stmts: case_stmts, ret: case_ret) ->
          let else_body = match chain do
            case Some(val: stmt) -> Cons(v: stmt, rest: Nil)
            case None -> Nil
          end
          let cond = match else_body do
            case Nil -> LirAtomBool(val: true)
            case _ -> LirAtomBool(val: true)
            // TODO: generate proper conditions from pattern
          end
          let then_ret = match case_ret do
            case Some(val: a) -> a
            case None -> default_atom(typ: ret_type)
          end
          let new_chain = Some(val: LirStmtIfReturn(
            cond: cond, then_body: case_stmts, then_ret: then_ret,
            else_body: else_body, else_ret: None, ret_type: ret_type
          ))
          return build_match_stmt_chain(cases: rest, target_atom: target_atom, ret_type: ret_type,
                                         chain: new_chain, ctx: ctx2)
        end
      end
  end
end

// ─── While Statement Lowering ────────────────────────────────────────────────

let lower_while_stmt = fn (cond: MirExpr, body: [MirStmt], ctx: LowerCtx) -> LowerStmtResult do
  // Lower condition in isolation
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let cond_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: Nil, temp_counter: c, enum_defs: ed)
    let cr = lower_expr_to_atom(expr: cond, ctx: cond_ctx)
    match cr do case BindResult(ctx: ctx2, atom: cond_atom) ->
      // Negate the condition (loop breaks when true)
      let neg_r = bind_expr_to_temp(ctx: ctx2,
        expr: LirExprBinary(op: OpEq, lhs: cond_atom, rhs: LirAtomBool(val: false), typ: TyBool),
        typ: TyBool)
      match neg_r do case BindResult(ctx: ctx3, atom: neg_cond) ->
        match ctx3 do case LowerCtx(vars: v2, semantic_vars: sv2, stmts: cond_stmts, temp_counter: c2, enum_defs: _) ->
          // Lower body
          let body_ctx = LowerCtx(vars: v2, semantic_vars: sv2, stmts: Nil, temp_counter: c2, enum_defs: ed)
          let br = lir_lower_stmts(stmts: body, ret_type: TyUnit, ctx: body_ctx)
          match br do case LowerStmtsResult(ctx: ctx4, ret: _) ->
            match ctx4 do case LowerCtx(vars: _, semantic_vars: _, stmts: body_stmts, temp_counter: c3, enum_defs: _) ->
              let final_ctx = LowerCtx(vars: v, semantic_vars: sv,
                stmts: Cons(v: LirStmtLoop(
                  cond_stmts: reverse_stmts(stmts: cond_stmts),
                  cond: neg_cond,
                  body: reverse_stmts(stmts: body_stmts)
                ), rest: saved),
                temp_counter: c3, enum_defs: ed)
              return LowerStmtResult(ctx: final_ctx, ret: None)
            end
          end
        end
      end
    end
  end
end

// ─── Try-Catch Lowering ──────────────────────────────────────────────────────

let lower_try_stmt = fn (body: [MirStmt], catch_param: string, catch_body: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult do
  let br = lower_block(stmts: body, ret_type: ret_type, ctx: ctx)
  match br do case BlockResult(ctx: ctx2, stmts: body_stmts, ret: body_ret) ->
    // Add catch parameter to scope
    match ctx2 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
      let catch_ctx = LowerCtx(
        vars: insert_type(name: catch_param, typ: TyString, entries: v),
        semantic_vars: insert_type(name: catch_param, typ: TyString, entries: sv),
        stmts: s, temp_counter: c, enum_defs: ed
      )
      let cr = lower_block(stmts: catch_body, ret_type: ret_type, ctx: catch_ctx)
      match cr do case BlockResult(ctx: ctx3, stmts: catch_stmts, ret: catch_ret) ->
        match ctx3 do case LowerCtx(vars: v2, semantic_vars: sv2, stmts: s2, temp_counter: c2, enum_defs: ed2) ->
          let ctx4 = LowerCtx(vars: v2, semantic_vars: sv2,
            stmts: Cons(v: LirStmtTryCatch(
              body: body_stmts, body_ret: body_ret,
              catch_param: catch_param, catch_param_typ: TyString,
              catch_body: catch_stmts, catch_ret: catch_ret
            ), rest: s2),
            temp_counter: c2, enum_defs: ed2)
          return LowerStmtResult(ctx: ctx4, ret: None)
        end
      end
    end
  end
end

// ─── Block Lowering ──────────────────────────────────────────────────────────

type BlockResult = BlockResult(ctx: LowerCtx, stmts: [LirStmt], ret: Option<LirAtom>)

let lower_block = fn (stmts: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> BlockResult do
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let block_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: Nil, temp_counter: c, enum_defs: ed)
    let sr = lir_lower_stmts(stmts: stmts, ret_type: ret_type, ctx: block_ctx)
    match sr do case LowerStmtsResult(ctx: ctx2, ret: ret_val) ->
      match ctx2 do case LowerCtx(vars: v2, semantic_vars: sv2, stmts: block_stmts, temp_counter: c2, enum_defs: _) ->
        let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
        return BlockResult(ctx: restored, stmts: reverse_stmts(stmts: block_stmts), ret: ret_val)
      end
    end
  end
end

type LowerStmtsResult = LowerStmtsResult(ctx: LowerCtx, ret: Option<LirAtom>)

let lir_lower_stmts = fn (stmts: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtsResult do
  match stmts do
    case Nil -> return LowerStmtsResult(ctx: ctx, ret: None)
    case Cons(v: s, rest: rest) ->
      let sr = lower_stmt_inner(stmt: s, ret_type: ret_type, ctx: ctx)
      match sr do case LowerStmtResult(ctx: ctx2, ret: ret_val) ->
        match ret_val do
          case Some(val: _) -> return LowerStmtsResult(ctx: ctx2, ret: ret_val)
          case None -> return lir_lower_stmts(stmts: rest, ret_type: ret_type, ctx: ctx2)
        end
      end
  end
end

// ─── Function Lowering ───────────────────────────────────────────────────────

let lir_lower_function = fn (f: MirFunction, enum_defs: [EnumDef]) -> LirFunction do
  match f do case MirFunction(name: fname, params: params, ret_type: rt, body: body, span: sp) ->
    let wasm_ret = wasm_type(typ: rt)
    // Build initial context with params
    let param_vars = build_param_vars(params: params)
    let param_sem_vars = build_param_semantic_vars(params: params)
    let ctx = LowerCtx(
      vars: param_vars,
      semantic_vars: param_sem_vars,
      stmts: Nil,
      temp_counter: 0,
      enum_defs: enum_defs
    )
    // Lower body
    let sr = lir_lower_stmts(stmts: body, ret_type: wasm_ret, ctx: ctx)
    match sr do case LowerStmtsResult(ctx: ctx2, ret: ret_val) ->
      match ctx2 do case LowerCtx(vars: _, semantic_vars: _, stmts: stmts, temp_counter: _, enum_defs: _) ->
        let ret_atom = match ret_val do
          case Some(val: a) -> a
          case None -> default_atom(typ: wasm_ret)
        end
        let lir_params = convert_params(params: params)
        return LirFunction(
          name: fname,
          params: lir_params,
          ret_type: wasm_ret,
          body: reverse_stmts(stmts: stmts),
          ret: ret_atom,
          span: sp
        )
      end
    end
  end
end

let build_param_vars = fn (params: [MirParam]) -> [TypeEntry] do
  match params do
    case Nil -> return Nil
    case Cons(v: p, rest: rest) ->
      match p do case MirParam(label: _, name: n, typ: t) ->
        return Cons(v: TypeEntry(name: n, typ: wasm_type(typ: t)),
                    rest: build_param_vars(params: rest))
      end
  end
end

let build_param_semantic_vars = fn (params: [MirParam]) -> [TypeEntry] do
  match params do
    case Nil -> return Nil
    case Cons(v: p, rest: rest) ->
      match p do case MirParam(label: _, name: n, typ: t) ->
        return Cons(v: TypeEntry(name: n, typ: t),
                    rest: build_param_semantic_vars(params: rest))
      end
  end
end

let convert_params = fn (params: [MirParam]) -> [LirParam] do
  match params do
    case Nil -> return Nil
    case Cons(v: p, rest: rest) ->
      match p do case MirParam(label: l, name: n, typ: t) ->
        return Cons(v: LirParam(label: l, name: n, typ: wasm_type(typ: t)),
                    rest: convert_params(params: rest))
      end
  end
end

// ─── External Conversion ─────────────────────────────────────────────────────

let convert_external = fn (ext: MirExternal) -> LirExternal do
  match ext do case MirExternal(name: n, wasm_module: wm, wasm_name: wn, params: ps, ret_type: rt, throw_row: tr) ->
    return LirExternal(
      name: n, wasm_module: wm, wasm_name: wn,
      params: convert_ext_params(params: ps),
      ret_type: wasm_type(typ: rt),
      throw_row: tr
    )
  end
end

let convert_ext_params = fn (params: [MirParam]) -> [LirParam] do
  match params do
    case Nil -> return Nil
    case Cons(v: p, rest: rest) ->
      match p do case MirParam(label: l, name: n, typ: t) ->
        return Cons(v: LirParam(label: l, name: n, typ: wasm_type(typ: t)),
                    rest: convert_ext_params(params: rest))
      end
  end
end

// ─── Entry Point ─────────────────────────────────────────────────────────────

export let lower_mir_to_lir = fn (mir: MirProgram, enum_defs: [EnumDef]) -> LirProgram do
  match mir do case MirProgram(functions: fs, externals: exts) ->
    return LirProgram(
      functions: lir_lower_functions(functions: fs, enum_defs: enum_defs),
      externals: convert_externals(externals: exts)
    )
  end
end

let lir_lower_functions = fn (functions: [MirFunction], enum_defs: [EnumDef]) -> [LirFunction] do
  match functions do
    case Nil -> return Nil
    case Cons(v: f, rest: rest) ->
      return Cons(v: lir_lower_function(f: f, enum_defs: enum_defs),
                  rest: lir_lower_functions(functions: rest, enum_defs: enum_defs))
  end
end

let convert_externals = fn (externals: [MirExternal]) -> [LirExternal] do
  match externals do
    case Nil -> return Nil
    case Cons(v: e, rest: rest) ->
      return Cons(v: convert_external(ext: e), rest: convert_externals(externals: rest))
  end
end

// ─── List Utility Helpers ────────────────────────────────────────────────────

let list_length = fn (lst: [MirPatternField]) -> i64 do
  match lst do
    case Nil -> return 0
    case Cons(v: _, rest: rest) -> return 1 + list_length(lst: rest)
  end
end

let reverse_stmts = fn (stmts: [LirStmt]) -> [LirStmt] do
  return reverse_stmts_go(stmts: stmts, acc: Nil)
end

let reverse_stmts_go = fn (stmts: [LirStmt], acc: [LirStmt]) -> [LirStmt] do
  match stmts do
    case Nil -> return acc
    case Cons(v: s, rest: rest) -> return reverse_stmts_go(stmts: rest, acc: Cons(v: s, rest: acc))
  end
end

let append_stmts = fn (stmts: [LirStmt], tail: [LirStmt]) -> [LirStmt] do
  match stmts do
    case Nil -> return tail
    case Cons(v: s, rest: rest) -> return Cons(v: s, rest: append_stmts(stmts: rest, tail: tail))
  end
end

let reverse_lowered_cases = fn (cases: [LoweredMatchCase]) -> [LoweredMatchCase] do
  return reverse_lowered_go(cases: cases, acc: Nil)
end

let reverse_lowered_go = fn (cases: [LoweredMatchCase], acc: [LoweredMatchCase]) -> [LoweredMatchCase] do
  match cases do
    case Nil -> return acc
    case Cons(v: c, rest: rest) -> return reverse_lowered_go(cases: rest, acc: Cons(v: c, rest: acc))
  end
end

let reverse_match_cases = fn (cases: [MirMatchCase]) -> [MirMatchCase] do
  return reverse_mc_go(cases: cases, acc: Nil)
end

let reverse_mc_go = fn (cases: [MirMatchCase], acc: [MirMatchCase]) -> [MirMatchCase] do
  match cases do
    case Nil -> return acc
    case Cons(v: c, rest: rest) -> return reverse_mc_go(cases: rest, acc: Cons(v: c, rest: acc))
  end
end
