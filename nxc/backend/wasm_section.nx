/**
 * wasm_section: WASM binary section builders.
 *
 * Builds type, import, function, memory, global, export, and data sections.
 * Each builder returns a ByteBuffer containing the section content.
 */

import { ByteBuffer, empty, push_byte, push_uleb128, push_sleb128,
         push_string, push_buf, free } from "stdlib/bytebuffer.nx"
import * as bb from "stdlib/bytebuffer.nx"
import { starts_with, contains } from "stdlib/string.nx"
import { TypeExpr } from "nxc/common/ast.nx"
import { LirProgram, LirFunction, LirExternal, LirParam } from "nxc/ir/lir_types.nx"
import { vt_i32, vt_i64, vt_funcref, desc_func, desc_table, desc_memory,
         op_i32_const, op_i64_const, op_end, type_to_valtype, is_unit, peel_linear,
         emit_name, StringEntry, LocalEntry, FuncEntry } from "nxc/backend/wasm_defs.nx"
import { count_ext_param_slots } from "nxc/backend/wasm_collect.nx"
import * as list from "stdlib/list.nx"

// ─── Type section ───────────────────────────────────────────────────────────

let emit_ext_param_types = fn (buf: %ByteBuffer, params: [LirParam]) -> %ByteBuffer do
  match params do
    case [] -> %buf
    case LirParam(label: _, name: _, typ: t) :: rest ->
      let %buf = match peel_linear(typ: t) do
        case TyString ->
          let %b = push_byte(buf: %buf, byte: vt_i32)
          push_byte(buf: %b, byte: vt_i32)
        case TyArray(elem: _) ->
          let %b = push_byte(buf: %buf, byte: vt_i32)
          push_byte(buf: %b, byte: vt_i32)
        case TyChar -> push_byte(buf: %buf, byte: vt_i32)
        case _ -> push_byte(buf: %buf, byte: type_to_valtype(typ: t))
      end
      emit_ext_param_types(buf: %buf, params: rest)
  end
end

let ext_return_valtype = fn (typ: TypeExpr) -> i64 do
  return if let TyChar = peel_linear(typ: typ) then vt_i32 else type_to_valtype(typ: typ) end
end

let emit_ext_return_type = fn (buf: %ByteBuffer, typ: TypeExpr) -> %ByteBuffer do
  if is_unit(typ: typ) then return push_uleb128(buf: %buf, val: 0)
  else
    let %buf = push_uleb128(buf: %buf, val: 1)
    return push_byte(buf: %buf, byte: ext_return_valtype(typ: typ))
  end
end

let emit_internal_param_types = fn (buf: %ByteBuffer, params: [LirParam]) -> %ByteBuffer do
  match params do
    case [] -> %buf
    case LirParam(label: _, name: _, typ: t) :: rest ->
      emit_internal_param_types(buf: push_byte(buf: %buf, byte: type_to_valtype(typ: t)), params: rest)
  end
end

/// Check if an external uses canonical string return (retptr convention).
/// Component-model externals (wasm_module contains ':') that return string
/// use void return + retptr param instead of packed i64 return.
let ext_uses_canonical_string_return = fn (wasm_module: string, ret_type: TypeExpr) -> bool do
  if contains(s: wasm_module, sub: ":") then
    if starts_with(s: wasm_module, prefix: "nexus:runtime/") then return false end
    match peel_linear(typ: ret_type) do
      case TyString -> return true
      case _ -> return false
    end
  end
  return false
end

let emit_ext_type_entries = fn (buf: %ByteBuffer, exts: [LirExternal]) -> %ByteBuffer do
  match exts do
    case [] -> %buf
    case LirExternal(name: _, wasm_module: m, wasm_name: _, params: ps, ret_type: rt, throw_row: _) :: rest ->
      let canonical_str_ret = ext_uses_canonical_string_return(wasm_module: m, ret_type: rt)
      // For canonical string return: add 1 slot for retptr param
      let extra_params = match canonical_str_ret do case true -> 1 case false -> 0 end
      let %buf = push_byte(buf: %buf, byte: 96)
      let %buf = push_uleb128(buf: %buf, val: count_ext_param_slots(params: ps) + extra_params)
      let %buf = emit_ext_param_types(buf: %buf, params: ps)
      // Canonical string return: retptr (i32) as last param, void return
      let %buf = if canonical_str_ret then
        let %buf = push_byte(buf: %buf, byte: vt_i32)
        push_uleb128(buf: %buf, val: 0)
      else
        emit_ext_return_type(buf: %buf, typ: rt)
      end
      emit_ext_type_entries(buf: %buf, exts: rest)
  end
end

let emit_func_type_entries = fn (buf: %ByteBuffer, funcs: [LirFunction]) -> %ByteBuffer do
  match funcs do
    case [] -> %buf
    case LirFunction(name: _, params: ps, ret_type: rt, body: _, ret: _, span: _) :: rest ->
      let %buf = push_byte(buf: %buf, byte: 96)
      let %buf = push_uleb128(buf: %buf, val: list.length(xs: ps))
      let %buf = emit_internal_param_types(buf: %buf, params: ps)
      let %buf = emit_ext_return_type(buf: %buf, typ: rt)
      emit_func_type_entries(buf: %buf, funcs: rest)
  end
end

export let build_type_section = fn (program: LirProgram, has_eh: bool, has_alloc: bool,
                                    has_cabi_realloc: bool, n_closure_types: i64) -> %ByteBuffer do
  let LirProgram(functions: funcs, externals: exts) = program
  let n_eh_types = match has_eh do case true -> 1 case false -> 0 end
  let n_alloc_types = match has_alloc do case true -> 1 case false -> 0 end
  let n_cabi_types = match has_cabi_realloc do case true -> 1 case false -> 0 end
  let total = list.length(xs: exts) + list.length(xs: funcs) + 1 + n_eh_types + n_alloc_types + n_cabi_types + n_closure_types
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: total)
  let %sec = emit_ext_type_entries(buf: %sec, exts: exts)
  let %sec = emit_func_type_entries(buf: %sec, funcs: funcs)
  // wasi:cli/run type (_start): () -> ()
  let %sec = push_byte(buf: %sec, byte: 96)
  let %sec = push_uleb128(buf: %sec, val: 0)
  let %sec = push_uleb128(buf: %sec, val: 0)
  // exception tag type: (i64) -> ()
  let %sec = if has_eh then
    let %sec = push_byte(buf: %sec, byte: 96)
    let %sec = push_uleb128(buf: %sec, val: 1)
    let %sec = push_byte(buf: %sec, byte: vt_i64)
    push_uleb128(buf: %sec, val: 0)
  else %sec end
  let %sec = if has_alloc then
    // allocate: (i32) -> i32
    let %sec = push_byte(buf: %sec, byte: 96)
    let %sec = push_uleb128(buf: %sec, val: 1)
    let %sec = push_byte(buf: %sec, byte: vt_i32)
    let %sec = push_uleb128(buf: %sec, val: 1)
    push_byte(buf: %sec, byte: vt_i32)
  else %sec end
  let %sec = if has_cabi_realloc then
    // cabi_realloc: (i32, i32, i32, i32) -> i32
    let %sec = push_byte(buf: %sec, byte: 96)
    let %sec = push_uleb128(buf: %sec, val: 4)
    let %sec = push_byte(buf: %sec, byte: vt_i32)
    let %sec = push_byte(buf: %sec, byte: vt_i32)
    let %sec = push_byte(buf: %sec, byte: vt_i32)
    let %sec = push_byte(buf: %sec, byte: vt_i32)
    let %sec = push_uleb128(buf: %sec, val: 1)
    push_byte(buf: %sec, byte: vt_i32)
  else %sec end
  return %sec
end

// ─── Import section ─────────────────────────────────────────────────────────

/// Module names are emitted as-is — WIT names (nexus:stdlib/math) stay as WIT
/// names for component model composition. File paths stay as file paths.
let import_module_name = fn (module: string) -> string do
  return module
end

let emit_import_entries = fn (buf: %ByteBuffer, exts: [LirExternal], type_idx: i64) -> %ByteBuffer do
  match exts do
    case [] -> %buf
    case LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _) :: rest ->
      let %buf = emit_name(buf: %buf, name: import_module_name(module: m))
      let %buf = emit_name(buf: %buf, name: wn)
      let %buf = push_byte(buf: %buf, byte: desc_func)
      let %buf = push_uleb128(buf: %buf, val: type_idx)
      emit_import_entries(buf: %buf, exts: rest, type_idx: type_idx + 1)
  end
end

let maybe_emit_mem_import = fn (sec: %ByteBuffer, has_mem_import: bool, mem_mode: string) -> %ByteBuffer do
  match has_mem_import == false do
    case true -> %sec
    case false ->
      let %sec = emit_name(buf: %sec, name: import_module_name(module: mem_mode))
      let %sec = emit_name(buf: %sec, name: "memory")
      let %sec = push_byte(buf: %sec, byte: desc_memory)
      let %sec = push_byte(buf: %sec, byte: 0)
      push_uleb128(buf: %sec, val: 18)
  end
end

export let build_import_section = fn (exts: [LirExternal], mem_mode: string,
                                      has_alloc: bool, alloc_type_idx: i64, alloc_module: string) -> %ByteBuffer do
  let n_exts = list.length(xs: exts)
  let has_mem_import = mem_mode != "none" && mem_mode != "defined"
  let mem_count = match has_mem_import do case true -> 1 case false -> 0 end
  let alloc_count = match has_alloc do case true -> 1 case false -> 0 end
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: n_exts + mem_count + alloc_count)
  let %sec = maybe_emit_mem_import(sec: %sec, has_mem_import: has_mem_import, mem_mode: mem_mode)
  let %sec = emit_import_entries(buf: %sec, exts: exts, type_idx: 0)
  let %sec = if has_alloc then
    let %sec = emit_name(buf: %sec, name: import_module_name(module: alloc_module))
    let %sec = emit_name(buf: %sec, name: "allocate")
    let %sec = push_byte(buf: %sec, byte: desc_func)
    push_uleb128(buf: %sec, val: alloc_type_idx)
  else %sec end
  return %sec
end

// ─── Function section ───────────────────────────────────────────────────────

let emit_func_type_indices = fn (buf: %ByteBuffer, count: i64, start_idx: i64) -> %ByteBuffer do
  if count <= 0 then
    return %buf
  else
    return emit_func_type_indices(buf: push_uleb128(buf: %buf, val: start_idx), count: count - 1, start_idx: start_idx + 1)
  end
end

export let build_function_section = fn (n_funcs: i64, n_exts: i64) -> %ByteBuffer do
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: n_funcs + 1)
  let %sec = emit_func_type_indices(buf: %sec, count: n_funcs, start_idx: n_exts)
  let %sec = push_uleb128(buf: %sec, val: n_exts + n_funcs)
  return %sec
end

// ─── Memory section ─────────────────────────────────────────────────────────

export let build_memory_section = fn () -> %ByteBuffer do
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: 1)
  let %sec = push_byte(buf: %sec, byte: 0)
  let %sec = push_uleb128(buf: %sec, val: 17)
  return %sec
end

// ─── Global section ─────────────────────────────────────────────────────────

export let build_global_section = fn (heap_base: i64) -> %ByteBuffer do
  let %sec = empty()
  // 1 global: heap_ptr (i32 mut)
  let %sec = push_uleb128(buf: %sec, val: 1)
  // global 0: heap pointer (i32, mutable)
  let %sec = push_byte(buf: %sec, byte: vt_i32)
  let %sec = push_byte(buf: %sec, byte: 1)
  let %sec = push_byte(buf: %sec, byte: op_i32_const)
  let %sec = push_sleb128(buf: %sec, val: heap_base)
  let %sec = push_byte(buf: %sec, byte: op_end)
  return %sec
end

// ─── Export section ─────────────────────────────────────────────────────────

let append_mem_export = fn (sec: %ByteBuffer) -> %ByteBuffer do
  let %sec = emit_name(buf: %sec, name: "memory")
  let %sec = push_byte(buf: %sec, byte: desc_memory)
  let %sec = push_uleb128(buf: %sec, val: 0)
  return %sec
end

export let build_export_section = fn (main_idx: i64, wasi_run_idx: i64,
                                      cabi_realloc_idx: i64, has_cabi_realloc: bool,
                                      mem_mode: string) -> %ByteBuffer do
  let has_mem_export = mem_mode != "none"
  let mem_count = match has_mem_export do case true -> 1 case false -> 0 end
  let cabi_count = match has_cabi_realloc do case true -> 1 case false -> 0 end
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: 3 + mem_count + cabi_count)
  let %sec = emit_name(buf: %sec, name: "main")
  let %sec = push_byte(buf: %sec, byte: desc_func)
  let %sec = push_uleb128(buf: %sec, val: main_idx)
  let %sec = emit_name(buf: %sec, name: "_start")
  let %sec = push_byte(buf: %sec, byte: desc_func)
  let %sec = push_uleb128(buf: %sec, val: main_idx)
  let %sec = emit_name(buf: %sec, name: "wasi:cli/run@0.2.6#run")
  let %sec = push_byte(buf: %sec, byte: desc_func)
  let %sec = push_uleb128(buf: %sec, val: wasi_run_idx)
  let %sec = if has_cabi_realloc then
    let %sec = emit_name(buf: %sec, name: "cabi_realloc")
    let %sec = push_byte(buf: %sec, byte: desc_func)
    push_uleb128(buf: %sec, val: cabi_realloc_idx)
  else %sec end
  let %sec = if has_mem_export then
    append_mem_export(sec: %sec)
  else %sec end
  return %sec
end

// ─── Data section ───────────────────────────────────────────────────────────

let emit_data_segments = fn (buf: %ByteBuffer, entries: [StringEntry]) -> %ByteBuffer do
  match entries do
    case [] -> %buf
    case StringEntry(value: v, offset: off, slen: sl) :: rest ->
      let %buf = push_byte(buf: %buf, byte: 0)
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      let %buf = push_sleb128(buf: %buf, val: off)
      let %buf = push_byte(buf: %buf, byte: op_end)
      let %buf = push_uleb128(buf: %buf, val: sl)
      let %buf = push_string(buf: %buf, s: v)
      emit_data_segments(buf: %buf, entries: rest)
  end
end

export let build_data_section = fn (entries: [StringEntry]) -> %ByteBuffer do
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: list.length(xs: entries))
  let %sec = emit_data_segments(buf: %sec, entries: entries)
  return %sec
end

// ─── Local declaration emission ─────────────────────────────────────────────

let count_non_param_locals = fn (locals: [LocalEntry], param_count: i64) -> i64 do
  match locals do
    case [] -> 0
    case LocalEntry(name: _, index: idx, valtype: _) :: rest ->
      match idx >= param_count do
        case true -> 1 + count_non_param_locals(locals: rest, param_count: param_count)
        case false -> count_non_param_locals(locals: rest, param_count: param_count)
      end
  end
end

let emit_one_local = fn (buf: %ByteBuffer, idx: i64, vt: i64, param_count: i64) -> %ByteBuffer do
  match idx < param_count do
    case true -> return %buf
    case false ->
      let %buf = push_uleb128(buf: %buf, val: 1)
      return push_byte(buf: %buf, byte: vt)
  end
end

let emit_local_entries = fn (buf: %ByteBuffer, locals: [LocalEntry], param_count: i64) -> %ByteBuffer do
  match locals do
    case [] -> %buf
    case LocalEntry(name: _, index: idx, valtype: vt) :: rest ->
      let %buf = emit_one_local(buf: %buf, idx: idx, vt: vt, param_count: param_count)
      emit_local_entries(buf: %buf, locals: rest, param_count: param_count)
  end
end

export let emit_local_decls = fn (buf: %ByteBuffer, locals: [LocalEntry], param_count: i64) -> %ByteBuffer do
  let n = count_non_param_locals(locals: locals, param_count: param_count)
  let %buf = push_uleb128(buf: %buf, val: n + 6)
  let %buf = emit_local_entries(buf: %buf, locals: list.reverse(xs: locals), param_count: param_count)
  // Reserved temps: 2x i64, 2x i32, 2x i64, 7x i32, 1x i64 (tcmc_head), 1x i32 (tcmc_prev)
  let %buf = push_uleb128(buf: %buf, val: 2)
  let %buf = push_byte(buf: %buf, byte: vt_i64)
  let %buf = push_uleb128(buf: %buf, val: 2)
  let %buf = push_byte(buf: %buf, byte: vt_i32)
  let %buf = push_uleb128(buf: %buf, val: 2)
  let %buf = push_byte(buf: %buf, byte: vt_i64)
  let %buf = push_uleb128(buf: %buf, val: 7)
  let %buf = push_byte(buf: %buf, byte: vt_i32)
  let %buf = push_uleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: vt_i64)
  let %buf = push_uleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: vt_i32)
  return %buf
end

// ─── Table section ─────────────────────────────────────────────────────────

/// Build table section: 1 funcref table with min = n_closures.
export let build_table_section = fn (n_closures: i64) -> %ByteBuffer do
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: 1)
  // funcref type
  let %sec = push_byte(buf: %sec, byte: vt_funcref)
  // limits: has_max=0, min=n_closures
  let %sec = push_byte(buf: %sec, byte: 0)
  let %sec = push_uleb128(buf: %sec, val: n_closures)
  return %sec
end

// ─── Element section ───────────────────────────────────────────────────────

let emit_elem_func_indices = fn (buf: %ByteBuffer, entries: [FuncEntry]) -> %ByteBuffer do
  match entries do
    case [] -> %buf
    case FuncEntry(name: _, index: idx) :: rest ->
      emit_elem_func_indices(buf: push_uleb128(buf: %buf, val: idx), entries: rest)
  end
end

/// Build element section: active segment, table 0, offset 0, func indices.
export let build_element_section = fn (closure_entries: [FuncEntry]) -> %ByteBuffer do
  let n = list.length(xs: closure_entries)
  let %sec = empty()
  // 1 segment
  let %sec = push_uleb128(buf: %sec, val: 1)
  // Active segment: table index 0
  let %sec = push_byte(buf: %sec, byte: 0)
  // Offset expr: i32.const 0; end
  let %sec = push_byte(buf: %sec, byte: op_i32_const)
  let %sec = push_sleb128(buf: %sec, val: 0)
  let %sec = push_byte(buf: %sec, byte: op_end)
  // Function indices
  let %sec = push_uleb128(buf: %sec, val: n)
  let %sec = emit_elem_func_indices(buf: %sec, entries: closure_entries)
  return %sec
end

// ─── Closure type entries ──────────────────────────────────────────────────

/// Emit type entries for closure call types.
/// Each distinct arity N gets a type: (N+1 x i64) -> i64 (env + N args → result).
let emit_closure_type_entry = fn (buf: %ByteBuffer, arity: i64) -> %ByteBuffer do
  let %buf = push_byte(buf: %buf, byte: 96)
  // param count = arity + 1 (env + args)
  let %buf = push_uleb128(buf: %buf, val: arity + 1)
  let %buf = emit_n_i64_params(buf: %buf, count: arity + 1)
  // return: 1 x i64
  let %buf = push_uleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: vt_i64)
  return %buf
end

let emit_n_i64_params = fn (buf: %ByteBuffer, count: i64) -> %ByteBuffer do
  if count <= 0 then return %buf
  else emit_n_i64_params(buf: push_byte(buf: %buf, byte: vt_i64), count: count - 1)
  end
end

export let emit_closure_type_entries = fn (buf: %ByteBuffer, arities: [i64]) -> %ByteBuffer do
  match arities do
    case [] -> %buf
    case a :: rest ->
      emit_closure_type_entries(buf: emit_closure_type_entry(buf: %buf, arity: a), arities: rest)
  end
end

// ─── Tag section ────────────────────────────────────────────────────────────

export let build_tag_section = fn (exn_tag_type_idx: i64) -> %ByteBuffer do
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: 1)
  let %sec = push_byte(buf: %sec, byte: 0)  // tag_kind_exception = 0
  let %sec = push_uleb128(buf: %sec, val: exn_tag_type_idx)
  return %sec
end
