/**
 * codegen: WASM instruction emission and module assembly.
 *
 * Contains the mutually recursive emit_stmt/emit_stmts/emit_expr chain,
 * atom/coercion/pack helpers, string operations, call emission,
 * function body compilation, and the top-level compile_lir_to_wasm entry.
 *
 * ~700 lines due to mutual recursion preventing further splitting.
 */

import { ByteBuffer, empty, push_byte, push_uleb128, push_sleb128,
         push_string, push_buf, push_f64_str_le, free, length as buf_length } from "stdlib/bytebuffer.nx"
import { BinaryOp, TypeExpr } from "nxc/common/ast.nx"
import { LirProgram, LirFunction, LirStmt, LirExpr, LirAtom,
         LirExternal, LirParam, LirCallArg, LirNamedAtom, ConcTask } from "nxc/ir/lir_types.nx"
import { CodegenCtx, LocalEntry, FuncEntry, StringEntry, ArityTypeIdx,
         ctx_locals, ctx_internal_funcs, ctx_external_funcs, ctx_string_lits,
         ctx_alloc_mode, ctx_temps_base, ctx_func_ret_type, ctx_functions, ctx_externals, ctx_func_name,
         ctx_closure_table, ctx_closure_type_indices, is_closure_func,
         ctx_internal_func_map, ctx_external_func_map,
         peel_linear, type_to_valtype, is_unit, atom_type, expr_type,
         lookup_local, lookup_local_valtype, lookup_func_fast,
         lookup_string, find_function, find_external,
         build_func_map, build_local_map, free_func_map, hash_name,
         constructor_tag, record_tag,
         emit_name, emit_section, emit_memarg, emit_memarg_i64, emit_memarg_i8,
         sec_type, sec_import, sec_function, sec_table, sec_memory, sec_global, sec_export, sec_element, sec_code, sec_data, sec_custom, sec_tag,
         vt_i32, vt_i64, vt_f64, vt_funcref, bt_void, bt_i32, bt_i64, desc_func, desc_table, desc_memory,
         heap_global_idx, string_data_base,
         catch_kind_one,
         op_unreachable, op_block, op_loop, op_if, op_else, op_end, op_br, op_br_if, op_return,
         op_call, op_call_indirect, op_return_call, op_drop, op_throw, op_try_table,
         op_local_get, op_local_set, op_local_tee, op_global_get, op_global_set,
         op_i32_load, op_i64_load, op_i32_load8_u, op_i32_store, op_i64_store, op_i32_store8,
         op_i32_const, op_i64_const, op_f64_const,
         op_i32_eqz, op_i32_eq, op_i32_ne, op_i32_lt_s, op_i32_gt_s, op_i32_le_s, op_i32_ge_s, op_i32_ge_u,
         op_i32_add, op_i32_sub, op_i32_mul, op_i32_xor,
         op_i64_eq, op_i64_ne, op_i64_lt_s, op_i64_le_s, op_i64_gt_s, op_i64_ge_s,
         op_i64_add, op_i64_sub, op_i64_mul, op_i64_div_s, op_i64_rem_s,
         op_i64_and, op_i64_or, op_i64_xor, op_i64_shl, op_i64_shr_s, op_i64_shr_u,
         op_f64_eq, op_f64_ne, op_f64_lt, op_f64_le, op_f64_gt, op_f64_ge,
         op_f64_add, op_f64_sub, op_f64_mul, op_f64_div,
         op_i32_wrap_i64, op_i64_extend_i32_s, op_i64_extend_i32_u,
         op_f64_reinterpret_i64, op_i64_reinterpret_f64,
         op_i32_and, op_i32_or } from "nxc/backend/wasm_defs.nx"
import { collect_program_strings, build_string_entries, compute_last_string_end,
         program_uses_heap, choose_memory_mode, has_stdlib, align8,
         collect_local_stmts, LocalResult, program_needs_eh } from "nxc/backend/wasm_collect.nx"
import { build_type_section, build_import_section, build_function_section,
         build_memory_section, build_global_section, build_export_section,
         build_data_section, emit_local_decls,
         build_table_section, build_element_section, emit_closure_type_entries,
         build_tag_section } from "nxc/backend/wasm_section.nx"
import * as list from "stdlib/list.nx"
import { starts_with } from "stdlib/string.nx"
import { CompileError, error_no_span, PhaseCodegen } from "nxc/common/error.nx"

// ─── TCMC (Tail Call Modulo Constructor) ─────────────────────────────────────

/// TCMC context: tracks in-place list building state.
/// head_local/prev_local at temps_base + 13/14 (always allocated).
type TcmcCtx = NoTcmc | TcmcActive(
  head_local: i64, prev_local: i64, rest_field_idx: i64,
  call_var: string, cons_var: string,
  call_args: [LirCallArg],   // self-call args (for param reassignment)
  ctor_name: string,          // constructor name (for tag computation)
  ctor_args: [LirAtom],       // constructor field values (including placeholder rest)
  func_name: string,
  loop_depth: i64             // WASM block depth from current pos to TCO loop header
)

/// Return TcmcCtx with loop_depth incremented by n (for entering WASM blocks).
let tcmc_deeper = fn (tcmc: TcmcCtx, n: i64) -> TcmcCtx throws { Exn } do
  match tcmc do
    case NoTcmc -> NoTcmc
    case TcmcActive(head_local: hl, prev_local: pl, rest_field_idx: rfi,
                     call_var: cv, cons_var: consv, call_args: ca,
                     ctor_name: cn, ctor_args: cta, func_name: fn2, loop_depth: d) ->
      TcmcActive(head_local: hl, prev_local: pl, rest_field_idx: rfi,
                  call_var: cv, cons_var: consv, call_args: ca,
                  ctor_name: cn, ctor_args: cta, func_name: fn2, loop_depth: d + n)
  end
end

/// Detect TCMC pattern: consecutive Let Call(self) + Let Constructor using the call result.
// TODO: TCMC detection disabled — runtime bugs in nxc codegen need fixing
let detect_tcmc = fn (body: [LirStmt], func_name: string) -> TcmcCtx throws { Exn } do
  return NoTcmc
end

/// Check if two consecutive stmts form a TCMC pair: Let Call(self) + Let Constructor.
let check_tcmc_pair = fn (first: LirStmt, rest: [LirStmt], func_name: string) -> TcmcCtx throws { Exn } do
  match first do
    case LirStmtLet(name: call_name, typ: _, expr: LirExprCall(func: f, args: call_args, typ: _)) ->
      if f == func_name then
        match rest do
          case LirStmtLet(name: cons_name, typ: _, expr: LirExprConstructor(name: ctor_name, args: ctor_args, typ: _)) :: _ ->
            match find_var_in_atoms(atoms: ctor_args, target: call_name, idx: 0) do
              case Some(val: rest_idx) ->
                return TcmcActive(head_local: 0, prev_local: 0, rest_field_idx: rest_idx,
                  call_var: call_name, cons_var: cons_name, call_args: call_args,
                  ctor_name: ctor_name, ctor_args: ctor_args, func_name: func_name,
                  loop_depth: 0)
              case None -> return NoTcmc
            end
          case _ -> return NoTcmc
        end
      else return NoTcmc
      end
    case _ -> return NoTcmc
  end
end

/// Recurse into a statement's branches looking for TCMC patterns.
let find_tcmc_in_branches = fn (stmt: LirStmt, func_name: string) -> TcmcCtx throws { Exn } do
  match stmt do
    case LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
      match find_tcmc_in_stmts(stmts: tb, func_name: func_name) do
        case NoTcmc -> return find_tcmc_in_stmts(stmts: eb, func_name: func_name)
        case found -> return found
      end
    case LirStmtIfReturn(cond: _, then_body: tb, then_ret: _, else_body: eb, else_ret: _, ret_type: _) ->
      match find_tcmc_in_stmts(stmts: tb, func_name: func_name) do
        case NoTcmc -> return find_tcmc_in_stmts(stmts: eb, func_name: func_name)
        case found -> return found
      end
    case LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      match find_tcmc_in_stmts(stmts: cs, func_name: func_name) do
        case NoTcmc -> return find_tcmc_in_stmts(stmts: b, func_name: func_name)
        case found -> return found
      end
    case _ -> return NoTcmc
  end
end

let find_tcmc_in_stmts = fn (stmts: [LirStmt], func_name: string) -> TcmcCtx throws { Exn } do
  match stmts do
    case s :: rest ->
      // Check if s + rest[0] form a TCMC pair
      match check_tcmc_pair(first: s, rest: rest, func_name: func_name) do
        case NoTcmc ->
          // Not a pair — recurse into branches of s, then continue with rest
          match find_tcmc_in_branches(stmt: s, func_name: func_name) do
            case NoTcmc -> return find_tcmc_in_stmts(stmts: rest, func_name: func_name)
            case found -> return found
          end
        case found -> return found
      end
    case [] -> return NoTcmc
  end
end

let find_var_in_atoms = fn (atoms: [LirAtom], target: string, idx: i64) -> Option<i64> throws { Exn } do
  match atoms do
    case [] -> return None
    case LirAtomVar(name: n, typ: _) :: rest ->
      if n == target then return Some(val: idx)
      else return find_var_in_atoms(atoms: rest, target: target, idx: idx + 1)
      end
    case _ :: rest -> return find_var_in_atoms(atoms: rest, target: target, idx: idx + 1)
  end
end

/// Emit TCMC init: head = 0, prev = 0 (called before the loop, runs once).
let emit_tcmc_init = fn (buf: %ByteBuffer, tcmc: TcmcCtx) -> %ByteBuffer throws { Exn } do
  match tcmc do
    case NoTcmc -> return %buf
    case TcmcActive(head_local: hl, prev_local: pl, rest_field_idx: _, call_var: _,
                     cons_var: _, call_args: _, ctor_name: _, ctor_args: _, func_name: _, loop_depth: _) ->
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: 0)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: hl)
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      let %buf = push_sleb128(buf: %buf, val: 0)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      return push_uleb128(buf: %buf, val: pl)
  end
end

/// Emit TCMC alloc + link + param reassign + br to loop.
let emit_tcmc_cons_and_loop = fn (buf: %ByteBuffer, ctx: CodegenCtx, tcmc: TcmcCtx) -> %ByteBuffer throws { Exn } do
  match tcmc do
    case NoTcmc -> return %buf
    case TcmcActive(head_local: hl, prev_local: pl, rest_field_idx: rfi,
                     call_var: _, cons_var: _, call_args: cargs,
                     ctor_name: cname, ctor_args: cargs_ctor, func_name: fname,
                     loop_depth: ldepth) ->
      let obj_ptr = ctx_temps_base(ctx: ctx) + 3
      // Find the function to get its params
      match find_function(name: fname, funcs: ctx_functions(ctx: ctx)) do
        case None ->
          error_no_span(phase: PhaseCodegen, message: "TCMC: function not found: " ++ fname)
          return %buf
        case Some(val: LirFunction(name: _, params: params, ret_type: _, body: _, ret: _, span: _)) ->
          let arity = list.length(xs: cargs_ctor)
          // 1. Allocate constructor cell
          let %buf = emit_alloc_object(buf: %buf, ctx: ctx, words: 1 + arity)
          // Store tag
          let tag = constructor_tag(name: cname, arity: arity)
          let %buf = push_byte(buf: %buf, byte: op_local_get)
          let %buf = push_uleb128(buf: %buf, val: obj_ptr)
          let %buf = push_byte(buf: %buf, byte: op_i64_const)
          let %buf = push_sleb128(buf: %buf, val: tag)
          let %buf = push_byte(buf: %buf, byte: op_i64_store)
          let %buf = emit_memarg_i64(buf: %buf, offset: 0)
          // Store rest = 0 placeholder
          let %buf = push_byte(buf: %buf, byte: op_local_get)
          let %buf = push_uleb128(buf: %buf, val: obj_ptr)
          let %buf = push_byte(buf: %buf, byte: op_i64_const)
          let %buf = push_sleb128(buf: %buf, val: 0)
          let %buf = push_byte(buf: %buf, byte: op_i64_store)
          let %buf = emit_memarg_i64(buf: %buf, offset: (rfi + 1) * 8)
          // Store non-recursive fields (all fields except rest_field_idx)
          let %buf = emit_tcmc_non_rec_fields(buf: %buf, ctx: ctx, obj_ptr: obj_ptr,
            args: cargs_ctor, rest_idx: rfi, field_idx: 0)

          // 2. Link: if prev != 0 → prev.rest = current, else head = current
          let %buf = push_byte(buf: %buf, byte: op_local_get)
          let %buf = push_uleb128(buf: %buf, val: pl)
          let %buf = push_byte(buf: %buf, byte: op_i32_const)
          let %buf = push_sleb128(buf: %buf, val: 0)
          let %buf = push_byte(buf: %buf, byte: op_i32_ne)
          let %buf = push_byte(buf: %buf, byte: op_if)
          let %buf = push_byte(buf: %buf, byte: bt_void)
          // prev.rest = current cell ptr (i64)
          let %buf = push_byte(buf: %buf, byte: op_local_get)
          let %buf = push_uleb128(buf: %buf, val: pl)
          let %buf = push_byte(buf: %buf, byte: op_local_get)
          let %buf = push_uleb128(buf: %buf, val: obj_ptr)
          let %buf = push_byte(buf: %buf, byte: op_i64_extend_i32_u)
          let %buf = push_byte(buf: %buf, byte: op_i64_store)
          let %buf = emit_memarg_i64(buf: %buf, offset: (rfi + 1) * 8)
          let %buf = push_byte(buf: %buf, byte: op_else)
          // head = current cell ptr
          let %buf = push_byte(buf: %buf, byte: op_local_get)
          let %buf = push_uleb128(buf: %buf, val: obj_ptr)
          let %buf = push_byte(buf: %buf, byte: op_i64_extend_i32_u)
          let %buf = push_byte(buf: %buf, byte: op_local_set)
          let %buf = push_uleb128(buf: %buf, val: hl)
          let %buf = push_byte(buf: %buf, byte: op_end)

          // 3. Update prev = current
          let %buf = push_byte(buf: %buf, byte: op_local_get)
          let %buf = push_uleb128(buf: %buf, val: obj_ptr)
          let %buf = push_byte(buf: %buf, byte: op_local_set)
          let %buf = push_uleb128(buf: %buf, val: pl)

          // 4. Reassign params from call_args + br to loop
          let %buf = emit_tcmc_param_push(buf: %buf, args: cargs, params: params, ctx: ctx)
          let %buf = emit_tcmc_param_set(buf: %buf, params: list.reverse(xs: params), ctx: ctx)
          let %buf = push_byte(buf: %buf, byte: op_br)
          return push_uleb128(buf: %buf, val: ldepth)
      end
  end
end

/// Emit non-recursive constructor fields (skip the rest_field_idx).
let emit_tcmc_non_rec_fields = fn (buf: %ByteBuffer, ctx: CodegenCtx, obj_ptr: i64,
                                     args: [LirAtom], rest_idx: i64, field_idx: i64) -> %ByteBuffer throws { Exn } do
  match args do
    case [] -> return %buf
    case a :: rest ->
      if field_idx == rest_idx then
        // Skip rest field (already set to 0)
        return emit_tcmc_non_rec_fields(buf: %buf, ctx: ctx, obj_ptr: obj_ptr,
          args: rest, rest_idx: rest_idx, field_idx: field_idx + 1)
      else
        let %buf = push_byte(buf: %buf, byte: op_local_get)
        let %buf = push_uleb128(buf: %buf, val: obj_ptr)
        let %buf = emit_atom(atom: a, buf: %buf, ctx: ctx)
        let %buf = emit_pack_to_i64(typ: atom_type(atom: a), buf: %buf)
        let %buf = push_byte(buf: %buf, byte: op_i64_store)
        let %buf = emit_memarg_i64(buf: %buf, offset: (field_idx + 1) * 8)
        return emit_tcmc_non_rec_fields(buf: %buf, ctx: ctx, obj_ptr: obj_ptr,
          args: rest, rest_idx: rest_idx, field_idx: field_idx + 1)
      end
  end
end

/// Push all call arg values onto the WASM stack (for param reassignment).
let emit_tcmc_param_push = fn (buf: %ByteBuffer, args: [LirCallArg], params: [LirParam], ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  match args do
    case [] -> return %buf
    case LirCallArg(label: _, value: a) :: arest ->
      match params do
        case [] -> return %buf
        case LirParam(label: _, name: _, typ: pt) :: prest ->
          let %buf = emit_atom(atom: a, buf: %buf, ctx: ctx)
          let %buf = emit_coercion(from_type: atom_type(atom: a), to_type: pt, buf: %buf)
          return emit_tcmc_param_push(buf: %buf, args: arest, params: prest, ctx: ctx)
      end
  end
end

/// Pop params from stack in reverse order (WASM stack is LIFO).
let emit_tcmc_param_set = fn (buf: %ByteBuffer, params: [LirParam], ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  match params do
    case [] -> return %buf
    case LirParam(label: _, name: n, typ: _) :: rest ->
      let idx = lookup_local(name: n, entries: ctx_locals(ctx: ctx))
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: idx)
      return emit_tcmc_param_set(buf: %buf, params: rest, ctx: ctx)
  end
end

/// Emit a return value with conditional TCMC linking.
/// If TCMC prev != 0: link last cell's rest to ret_val, return head.
/// Otherwise: return ret_val normally.
let emit_return_with_tcmc = fn (buf: %ByteBuffer, ret_val: LirAtom, ret_type: TypeExpr,
                                 ctx: CodegenCtx, tcmc: TcmcCtx) -> %ByteBuffer throws { Exn } do
  match tcmc do
    case NoTcmc ->
      let %buf = emit_atom(atom: ret_val, buf: %buf, ctx: ctx)
      let %buf = emit_coercion(from_type: atom_type(atom: ret_val), to_type: ret_type, buf: %buf)
      return push_byte(buf: %buf, byte: op_return)
    case TcmcActive(head_local: hl, prev_local: pl, rest_field_idx: rfi,
                     call_var: _, cons_var: _, call_args: _, ctor_name: _, ctor_args: _, func_name: _, loop_depth: _) ->
      // if (prev != 0)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: pl)
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      let %buf = push_sleb128(buf: %buf, val: 0)
      let %buf = push_byte(buf: %buf, byte: op_i32_ne)
      let %buf = push_byte(buf: %buf, byte: op_if)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      // Link: prev.rest = ret_val
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: pl)
      let %buf = emit_atom(atom: ret_val, buf: %buf, ctx: ctx)
      let %buf = emit_pack_to_i64(typ: atom_type(atom: ret_val), buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_i64_store)
      let %buf = emit_memarg_i64(buf: %buf, offset: (rfi + 1) * 8)
      // Return head
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: hl)
      let %buf = push_byte(buf: %buf, byte: op_return)
      let %buf = push_byte(buf: %buf, byte: op_else)
      // Normal return
      let %buf = emit_atom(atom: ret_val, buf: %buf, ctx: ctx)
      let %buf = emit_coercion(from_type: atom_type(atom: ret_val), to_type: ret_type, buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_return)
      return push_byte(buf: %buf, byte: op_end)
  end
end

// ─── Atom emission ──────────────────────────────────────────────────────────

let emit_atom_var = fn (name: string, typ: TypeExpr, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  match peel_linear(typ: typ) do case TyUnit -> return %buf case _ -> () end
  let raw_idx = lookup_local(name: name, entries: ctx_locals(ctx: ctx))
  match raw_idx < 0 do
    case true ->
      // Not a local — try top-level function (zero-arg constant)
      let func_idx = lookup_func_fast(name: name, map_id: ctx_internal_func_map(ctx: ctx))
      match func_idx >= 0 do
        case true ->
          let %buf = push_byte(buf: %buf, byte: op_call)
          return push_uleb128(buf: %buf, val: func_idx)
        case false ->
          let ext_idx = lookup_func_fast(name: name, map_id: ctx_external_func_map(ctx: ctx))
          match ext_idx >= 0 do
            case true ->
              let %buf = push_byte(buf: %buf, byte: op_call)
              return push_uleb128(buf: %buf, val: ext_idx)
            case false ->
              error_no_span(phase: PhaseCodegen, message: "in " ++ ctx_func_name(ctx: ctx) ++ ": variable not found as local/func/external: " ++ name)
              return %buf
          end
      end
    case false ->
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: raw_idx)
      // Narrow i64→i32 if local was widened but atom type is i32
      let atom_vt = type_to_valtype(typ: peel_linear(typ: typ))
      let local_vt = lookup_local_valtype(name: name, entries: ctx_locals(ctx: ctx))
      return match atom_vt == vt_i32 && local_vt == vt_i64 do
        case true -> push_byte(buf: %buf, byte: op_i32_wrap_i64)
        case false -> %buf
      end
  end
end

let emit_atom = fn (atom: LirAtom, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  match atom do
    case LirAtomVar(name: n, typ: at) ->
      return emit_atom_var(name: n, typ: at, buf: %buf, ctx: ctx)
    case LirAtomInt(val: v) ->
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      return push_sleb128(buf: %buf, val: v)
    case LirAtomFloat(val: s) ->
      let %buf = push_byte(buf: %buf, byte: op_f64_const)
      return push_f64_str_le(buf: %buf, s: s)
    case LirAtomBool(val: bv) ->
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      return push_sleb128(buf: %buf, val: match bv do case true -> 1 case false -> 0 end)
    case LirAtomChar(val: cv) ->
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      return push_sleb128(buf: %buf, val: cv)
    case LirAtomString(val: s) ->
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      return push_sleb128(buf: %buf, val: lookup_string(value: s, entries: ctx_string_lits(ctx: ctx)))
    case LirAtomUnit -> %buf
  end
end

// ─── Coercion / pack / unpack ───────────────────────────────────────────────

let emit_coercion = fn (from_type: TypeExpr, to_type: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer throws { Exn } do
  let f = peel_linear(typ: from_type)
  let t = peel_linear(typ: to_type)
  match f do case TyUnit -> return %buf case _ ->
    match t do case TyUnit -> return %buf case _ ->
      let fv = type_to_valtype(typ: f)
      let tv = type_to_valtype(typ: t)
      if fv == tv then return %buf
      else if fv == vt_i64 && tv == vt_i32 then return push_byte(buf: %buf, byte: op_i32_wrap_i64)
      else if fv == vt_i32 && tv == vt_i64 then return push_byte(buf: %buf, byte: op_i64_extend_i32_s)
      else return %buf
      end end end
    end
  end
end

let emit_pack_to_i64 = fn (typ: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer throws { Exn } do
  match peel_linear(typ: typ) do
    case TyI32 -> push_byte(buf: %buf, byte: op_i64_extend_i32_s)
    case TyBool -> push_byte(buf: %buf, byte: op_i64_extend_i32_s)
    case TyChar -> push_byte(buf: %buf, byte: op_i64_extend_i32_s)
    case TyUnit ->
      let %buf = push_byte(buf: %buf, byte: op_drop)
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      push_sleb128(buf: %buf, val: 0)
    case TyF64 -> push_byte(buf: %buf, byte: op_i64_reinterpret_f64)
    case _ -> %buf
  end
end

let emit_unpack_from_i64 = fn (typ: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer throws { Exn } do
  match peel_linear(typ: typ) do
    case TyI32 -> push_byte(buf: %buf, byte: op_i32_wrap_i64)
    case TyBool -> push_byte(buf: %buf, byte: op_i32_wrap_i64)
    case TyChar -> push_byte(buf: %buf, byte: op_i32_wrap_i64)
    case TyF64 -> push_byte(buf: %buf, byte: op_f64_reinterpret_i64)
    case _ -> %buf
  end
end

// ─── Object allocation ──────────────────────────────────────────────────────

let emit_alloc_object = fn (buf: %ByteBuffer, ctx: CodegenCtx, words: i64) -> %ByteBuffer throws { Exn } do
  let obj_ptr = ctx_temps_base(ctx: ctx) + 3
  let alloc_idx = lookup_func_fast(name: "__nx_allocate", map_id: ctx_external_func_map(ctx: ctx))
  match alloc_idx >= 0 do
    case true ->
      // stdlib allocate: call allocate(bytes) -> ptr
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      let %buf = push_sleb128(buf: %buf, val: words * 8)
      let %buf = push_byte(buf: %buf, byte: op_call)
      let %buf = push_uleb128(buf: %buf, val: alloc_idx)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      return push_uleb128(buf: %buf, val: obj_ptr)
    case false ->
      // bump allocator: global_get 0, tee ptr, add bytes, global_set 0
      let %buf = push_byte(buf: %buf, byte: op_global_get)
      let %buf = push_uleb128(buf: %buf, val: heap_global_idx)
      let %buf = push_byte(buf: %buf, byte: op_local_tee)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      let %buf = push_sleb128(buf: %buf, val: words * 8)
      let %buf = push_byte(buf: %buf, byte: op_i32_add)
      let %buf = push_byte(buf: %buf, byte: op_global_set)
      return push_uleb128(buf: %buf, val: heap_global_idx)
  end
end

// ─── String unpack ──────────────────────────────────────────────────────────

let emit_unpack_string = fn (buf: %ByteBuffer, packed_local: i64, ptr_local: i64, len_local: i64) -> %ByteBuffer throws { Exn } do
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: packed_local)
  let %buf = push_byte(buf: %buf, byte: op_i64_const)
  let %buf = push_sleb128(buf: %buf, val: 32)
  let %buf = push_byte(buf: %buf, byte: op_i64_shr_u)
  let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: ptr_local)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: packed_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  return push_uleb128(buf: %buf, val: len_local)
end

// ─── Memcpy loops ───────────────────────────────────────────────────────────

let emit_memcpy_loop = fn (buf: %ByteBuffer, src_ptr: i64, dst_ptr: i64, dst_offset: i64,
                            len_local: i64, idx_local: i64) -> %ByteBuffer throws { Exn } do
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_block)
  let %buf = push_byte(buf: %buf, byte: bt_void)
  let %buf = push_byte(buf: %buf, byte: op_loop)
  let %buf = push_byte(buf: %buf, byte: bt_void)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: len_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_ge_u)
  let %buf = push_byte(buf: %buf, byte: op_br_if)
  let %buf = push_uleb128(buf: %buf, val: 1)
  // dst[idx] = src[idx]
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: dst_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: src_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_i32_load8_u)
  let %buf = emit_memarg_i8(buf: %buf)
  let %buf = push_byte(buf: %buf, byte: op_i32_store8)
  let %buf = emit_memarg_i8(buf: %buf)
  // idx++
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_br)
  let %buf = push_uleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_end)
  return push_byte(buf: %buf, byte: op_end)
end

let emit_memcpy_loop_offset = fn (buf: %ByteBuffer, src_ptr: i64, dst_ptr: i64,
                                   offset_local: i64, len_local: i64, idx_local: i64) -> %ByteBuffer throws { Exn } do
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_block)
  let %buf = push_byte(buf: %buf, byte: bt_void)
  let %buf = push_byte(buf: %buf, byte: op_loop)
  let %buf = push_byte(buf: %buf, byte: bt_void)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: len_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_ge_u)
  let %buf = push_byte(buf: %buf, byte: op_br_if)
  let %buf = push_uleb128(buf: %buf, val: 1)
  // dst[offset + idx]
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: dst_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: offset_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  // src[idx]
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: src_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_i32_load8_u)
  let %buf = emit_memarg_i8(buf: %buf)
  let %buf = push_byte(buf: %buf, byte: op_i32_store8)
  let %buf = emit_memarg_i8(buf: %buf)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_br)
  let %buf = push_uleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_end)
  return push_byte(buf: %buf, byte: op_end)
end

// ─── String concat ──────────────────────────────────────────────────────────

let emit_string_concat = fn (lhs: LirAtom, rhs: LirAtom, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  let t = ctx_temps_base(ctx: ctx)
  let lhs_packed = t + 4
  let rhs_packed = t + 5
  let lhs_ptr = t + 6
  let lhs_len = t + 7
  let rhs_ptr = t + 8
  let rhs_len = t + 9
  let out_ptr = t + 10
  let out_len = t + 11
  let idx_var = t + 12

  let %buf = emit_atom(atom: lhs, buf: %buf, ctx: ctx)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: lhs_packed)
  let %buf = emit_atom(atom: rhs, buf: %buf, ctx: ctx)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: rhs_packed)
  let %buf = emit_unpack_string(buf: %buf, packed_local: lhs_packed, ptr_local: lhs_ptr, len_local: lhs_len)
  let %buf = emit_unpack_string(buf: %buf, packed_local: rhs_packed, ptr_local: rhs_ptr, len_local: rhs_len)

  // out_len = lhs_len + rhs_len
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: lhs_len)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: rhs_len)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: out_len)

  // Allocate on heap
  let alloc_idx = lookup_func_fast(name: "__nx_allocate", map_id: ctx_external_func_map(ctx: ctx))
  match alloc_idx >= 0 do
    case true ->
      // stdlib allocate
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: out_len)
      let %buf = push_byte(buf: %buf, byte: op_call)
      let %buf = push_uleb128(buf: %buf, val: alloc_idx)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: out_ptr)
    case false ->
      // bump allocator
      let %buf = push_byte(buf: %buf, byte: op_global_get)
      let %buf = push_uleb128(buf: %buf, val: heap_global_idx)
      let %buf = push_byte(buf: %buf, byte: op_local_tee)
      let %buf = push_uleb128(buf: %buf, val: out_ptr)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: out_len)
      let %buf = push_byte(buf: %buf, byte: op_i32_add)
      let %buf = push_byte(buf: %buf, byte: op_global_set)
      let %buf = push_uleb128(buf: %buf, val: heap_global_idx)
  end

  let %buf = emit_memcpy_loop(buf: %buf, src_ptr: lhs_ptr, dst_ptr: out_ptr, dst_offset: -1,
                               len_local: lhs_len, idx_local: idx_var)
  let %buf = emit_memcpy_loop_offset(buf: %buf, src_ptr: rhs_ptr, dst_ptr: out_ptr,
                                      offset_local: lhs_len, len_local: rhs_len, idx_local: idx_var)

  // Pack result: (out_ptr as i64) << 32 | (out_len as i64)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: out_ptr)
  let %buf = push_byte(buf: %buf, byte: op_i64_extend_i32_u)
  let %buf = push_byte(buf: %buf, byte: op_i64_const)
  let %buf = push_sleb128(buf: %buf, val: 32)
  let %buf = push_byte(buf: %buf, byte: op_i64_shl)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: out_len)
  let %buf = push_byte(buf: %buf, byte: op_i64_extend_i32_u)
  return push_byte(buf: %buf, byte: op_i64_or)
end

// ─── String compare ─────────────────────────────────────────────────────────

let is_string_type = fn (t: TypeExpr) -> bool throws { Exn } do
  match peel_linear(typ: t) do case TyString -> true case _ -> false end
end

let is_string_op = fn (op: BinaryOp, lhs_type: TypeExpr, rhs_type: TypeExpr) -> bool throws { Exn } do
  // Either operand being TyString indicates string operation.
  // Pattern-extracted string vars have TyI64 (WASM type), but string literals
  // have TyString. If either side is TyString, use string comparison/concat.
  if is_string_type(t: lhs_type) || is_string_type(t: rhs_type) then
    match op do
      case OpEq -> return true case OpNe -> return true
      case OpConcat -> return true case OpAdd -> return true
      case _ -> return false
    end
  end
  return false
end

let is_string_concat_op = fn (op: BinaryOp, typ: TypeExpr) -> bool throws { Exn } do
  match peel_linear(typ: typ) do case TyString ->
    match op do case OpConcat -> true case OpAdd -> true case _ -> false end
  case _ -> false end
end

let emit_string_compare = fn (op: BinaryOp, lhs: LirAtom, rhs: LirAtom,
                               buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  let t = ctx_temps_base(ctx: ctx)
  let lhs_packed = t + 4
  let rhs_packed = t + 5
  let lhs_ptr = t + 6
  let lhs_len = t + 7
  let rhs_ptr = t + 8
  let rhs_len = t + 9
  let idx_var = t + 12

  let %buf = emit_atom(atom: lhs, buf: %buf, ctx: ctx)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: lhs_packed)
  let %buf = emit_atom(atom: rhs, buf: %buf, ctx: ctx)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: rhs_packed)
  let %buf = emit_unpack_string(buf: %buf, packed_local: lhs_packed, ptr_local: lhs_ptr, len_local: lhs_len)
  let %buf = emit_unpack_string(buf: %buf, packed_local: rhs_packed, ptr_local: rhs_ptr, len_local: rhs_len)

  // block $done (result i32) { block $not_equal {
  let %buf = push_byte(buf: %buf, byte: op_block)
  let %buf = push_byte(buf: %buf, byte: bt_i32)
  let %buf = push_byte(buf: %buf, byte: op_block)
  let %buf = push_byte(buf: %buf, byte: bt_void)

  // Compare lengths
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: lhs_len)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: rhs_len)
  let %buf = push_byte(buf: %buf, byte: op_i32_ne)
  let %buf = push_byte(buf: %buf, byte: op_br_if)
  let %buf = push_uleb128(buf: %buf, val: 0)

  // Byte comparison loop
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_block)
  let %buf = push_byte(buf: %buf, byte: bt_void)
  let %buf = push_byte(buf: %buf, byte: op_loop)
  let %buf = push_byte(buf: %buf, byte: bt_void)

  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: lhs_len)
  let %buf = push_byte(buf: %buf, byte: op_i32_ge_u)
  let %buf = push_byte(buf: %buf, byte: op_br_if)
  let %buf = push_uleb128(buf: %buf, val: 1)

  // Compare bytes
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: lhs_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_i32_load8_u)
  let %buf = emit_memarg_i8(buf: %buf)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: rhs_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_i32_load8_u)
  let %buf = emit_memarg_i8(buf: %buf)
  let %buf = push_byte(buf: %buf, byte: op_i32_ne)
  let %buf = push_byte(buf: %buf, byte: op_br_if)
  let %buf = push_uleb128(buf: %buf, val: 2)

  // idx++
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_br)
  let %buf = push_uleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_end)
  let %buf = push_byte(buf: %buf, byte: op_end)

  // Equal: push 1, br $done
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: op_br)
  let %buf = push_uleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: op_end)
  // Not equal: push 0
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_end)

  match op do
    case OpNe -> return push_byte(buf: %buf, byte: op_i32_eqz)
    case _ -> return %buf
  end
end

// ─── Binary operation ───────────────────────────────────────────────────────

let emit_binary = fn (op: BinaryOp, operand_type: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer throws { Exn } do
  let use_i32 = match peel_linear(typ: operand_type) do
    case TyBool -> true case TyI32 -> true case TyChar -> true case _ -> false
  end
  let opcode = match op do
    case OpAdd -> match use_i32 do case true -> op_i32_add case false -> op_i64_add end
    case OpSub -> match use_i32 do case true -> op_i32_sub case false -> op_i64_sub end
    case OpMul -> match use_i32 do case true -> op_i32_mul case false -> op_i64_mul end
    case OpDiv -> op_i64_div_s case OpMod -> op_i64_rem_s
    case OpFAdd -> op_f64_add case OpFSub -> op_f64_sub
    case OpFMul -> op_f64_mul case OpFDiv -> op_f64_div
    case OpEq -> match use_i32 do case true -> op_i32_eq case false -> op_i64_eq end
    case OpNe -> match use_i32 do case true -> op_i32_ne case false -> op_i64_ne end
    case OpLt -> match use_i32 do case true -> op_i32_lt_s case false -> op_i64_lt_s end
    case OpLe -> match use_i32 do case true -> op_i32_le_s case false -> op_i64_le_s end
    case OpGt -> match use_i32 do case true -> op_i32_gt_s case false -> op_i64_gt_s end
    case OpGe -> match use_i32 do case true -> op_i32_ge_s case false -> op_i64_ge_s end
    case OpFEq -> op_f64_eq case OpFNe -> op_f64_ne
    case OpFLt -> op_f64_lt case OpFLe -> op_f64_le
    case OpFGt -> op_f64_gt case OpFGe -> op_f64_ge
    case OpBitAnd -> match use_i32 do case true -> op_i32_and case false -> op_i64_and end
    case OpBitOr -> match use_i32 do case true -> op_i32_or case false -> op_i64_or end
    case OpBitXor -> match use_i32 do case true -> op_i32_xor case false -> op_i64_xor end
    case OpShl -> op_i64_shl case OpShr -> op_i64_shr_s
    case OpAnd -> op_i32_and case OpOr -> op_i32_or
    case _ -> op_i64_add
  end
  return push_byte(buf: %buf, byte: opcode)
end

// ─── External call arg ──────────────────────────────────────────────────────

let emit_external_arg = fn (atom: LirAtom, param_type: TypeExpr, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  match peel_linear(typ: param_type) do
    case TyString ->
      let packed_tmp = ctx_temps_base(ctx: ctx)
      let %buf = emit_atom(atom: atom, buf: %buf, ctx: ctx)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: 32)
      let %buf = push_byte(buf: %buf, byte: op_i64_shr_s)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      return push_byte(buf: %buf, byte: op_i32_wrap_i64)
    case TyArray(elem: _) ->
      let packed_tmp = ctx_temps_base(ctx: ctx)
      let %buf = emit_atom(atom: atom, buf: %buf, ctx: ctx)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: 32)
      let %buf = push_byte(buf: %buf, byte: op_i64_shr_s)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      return push_byte(buf: %buf, byte: op_i32_wrap_i64)
    case TyChar ->
      // Internal and external both use i32 for char — no conversion needed
      let %buf = emit_atom(atom: atom, buf: %buf, ctx: ctx)
      return emit_coercion(from_type: atom_type(atom: atom), to_type: param_type, buf: %buf)
    case _ ->
      let %buf = emit_atom(atom: atom, buf: %buf, ctx: ctx)
      return emit_coercion(from_type: atom_type(atom: atom), to_type: param_type, buf: %buf)
  end
end

// ─── Constructor/record field emission ──────────────────────────────────────

let emit_constructor_fields = fn (buf: %ByteBuffer, args: [LirAtom], ctx: CodegenCtx,
                                   obj_ptr: i64, field_idx: i64) -> %ByteBuffer throws { Exn } do
  match args do
    case [] -> %buf
    case a :: rest ->
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = emit_atom(atom: a, buf: %buf, ctx: ctx)
      let %buf = emit_pack_to_i64(typ: atom_type(atom: a), buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_i64_store)
      let %buf = emit_memarg_i64(buf: %buf, offset: field_idx * 8)
      emit_constructor_fields(buf: %buf, args: rest, ctx: ctx, obj_ptr: obj_ptr, field_idx: field_idx + 1)
  end
end

let emit_record_fields = fn (buf: %ByteBuffer, fields: [LirNamedAtom], ctx: CodegenCtx,
                              obj_ptr: i64, field_idx: i64) -> %ByteBuffer throws { Exn } do
  match fields do
    case [] -> %buf
    case LirNamedAtom(name: _, value: v) :: rest ->
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = emit_atom(atom: v, buf: %buf, ctx: ctx)
      let %buf = emit_pack_to_i64(typ: atom_type(atom: v), buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_i64_store)
      let %buf = emit_memarg_i64(buf: %buf, offset: field_idx * 8)
      emit_record_fields(buf: %buf, fields: rest, ctx: ctx, obj_ptr: obj_ptr, field_idx: field_idx + 1)
  end
end

let extract_field_names = fn (fields: [LirNamedAtom]) -> [string] throws { Exn } do
  match fields do
    case [] -> []
    case LirNamedAtom(name: n, value: _) :: rest ->
      n :: extract_field_names(fields: rest)
  end
end

// ─── Call emission ──────────────────────────────────────────────────────────

let emit_internal_call_args = fn (buf: %ByteBuffer, args: [LirCallArg], params: [LirParam], ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  match args do
    case [] -> %buf
    case LirCallArg(label: _, value: v) :: rest_args ->
      match params do
        case [] -> %buf
        case LirParam(label: _, name: _, typ: pt) :: rest_params ->
          let %buf = emit_atom(atom: v, buf: %buf, ctx: ctx)
          let %buf = emit_coercion(from_type: atom_type(atom: v), to_type: pt, buf: %buf)
          emit_internal_call_args(buf: %buf, args: rest_args, params: rest_params, ctx: ctx)
      end
  end
end

let find_call_arg_value = fn (label: string, args: [LirCallArg]) -> LirAtom throws { Exn } do
  match args do
    case [] -> return LirAtomInt(val: 0)
    case LirCallArg(label: l, value: v) :: rest ->
      if l == label then return v
      else return find_call_arg_value(label: label, args: rest)
      end
  end
end

let emit_external_call_args = fn (buf: %ByteBuffer, args: [LirCallArg], params: [LirParam], ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  // Iterate params in source order (matching stdlib ABI), look up args by label
  match params do
    case [] -> %buf
    case LirParam(label: pl, name: _, typ: pt) :: rest_params ->
      let v = find_call_arg_value(label: pl, args: args)
      let %buf = emit_external_arg(atom: v, param_type: pt, buf: %buf, ctx: ctx)
      emit_external_call_args(buf: %buf, args: args, params: rest_params, ctx: ctx)
  end
end

// ─── Call emission ──────────────────────────────────────────────────────────

let emit_internal_call = fn (func: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx,
                              is_tail: bool, in_try: bool, int_idx: i64) -> %ByteBuffer throws { Exn } do
  match find_function(name: func, funcs: ctx_functions(ctx: ctx)) do
    case Some(val: LirFunction(name: _, params: params, ret_type: _, body: _, ret: _, span: _)) ->
      let %buf = emit_internal_call_args(buf: %buf, args: args, params: params, ctx: ctx)
      let use_tail = is_tail && (in_try == false)
      let call_op = match use_tail do case true -> op_return_call case false -> op_call end
      let %buf = push_byte(buf: %buf, byte: call_op)
      push_uleb128(buf: %buf, val: int_idx)
    case None ->
      error_no_span(phase: PhaseCodegen, message: "internal call: function not found: " ++ func)
      return %buf
  end
end

let emit_external_call = fn (func: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx,
                               ext_idx: i64) -> %ByteBuffer throws { Exn } do
  match find_external(name: func, exts: ctx_externals(ctx: ctx)) do
    case Some(val: LirExternal(name: _, wasm_module: _, wasm_name: _, params: params, ret_type: _, throw_row: _)) ->
      let %buf = emit_external_call_args(buf: %buf, args: args, params: params, ctx: ctx)
      let %buf = push_byte(buf: %buf, byte: op_call)
      return push_uleb128(buf: %buf, val: ext_idx)
    case None ->
      error_no_span(phase: PhaseCodegen, message: "external call: function not found: " ++ func)
      return %buf
  end
end

let emit_call = fn (func: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx,
                     is_tail: bool, in_try: bool) -> %ByteBuffer throws { Exn } do
  let int_idx = lookup_func_fast(name: func, map_id: ctx_internal_func_map(ctx: ctx))
  if int_idx >= 0 then
    return emit_internal_call(func: func, args: args, buf: %buf, ctx: ctx, is_tail: is_tail, in_try: in_try, int_idx: int_idx)
  else
    let ext_idx = lookup_func_fast(name: func, map_id: ctx_external_func_map(ctx: ctx))
    if ext_idx >= 0 then
      return emit_external_call(func: func, args: args, buf: %buf, ctx: ctx, ext_idx: ext_idx)
    else
      error_no_span(phase: PhaseCodegen, message: "in " ++ ctx_func_name(ctx: ctx) ++ ": call: function not found: " ++ func)
      return %buf
    end
  end
end

// ─── Closure helpers ────────────────────────────────────────────────────────

/// Returns the table index (position) for a closure function name.
let lookup_closure_table_idx = fn (name: string, entries: [FuncEntry]) -> i64 throws { Exn } do
  return lookup_closure_table_idx_go(name: name, entries: entries, pos: 0)
end

let lookup_closure_table_idx_go = fn (name: string, entries: [FuncEntry], pos: i64) -> i64 throws { Exn } do
  match entries do
    case [] -> return -1
    case FuncEntry(name: n, index: _) :: rest ->
      if n == name then return pos
      else return lookup_closure_table_idx_go(name: name, entries: rest, pos: pos + 1)
      end
  end
end

/// Look up the type section index for a closure call with the given arity.
let lookup_closure_type_idx_pairs = fn (arity: i64, pairs: [ArityTypeIdx]) -> i64 throws { Exn } do
  match pairs do
    case [] -> return 0
    case ArityTypeIdx(arity: a, type_idx: ti) :: rest ->
      if a == arity then return ti
      else return lookup_closure_type_idx_pairs(arity: arity, pairs: rest)
      end
  end
end

let emit_closure_captures = fn (buf: %ByteBuffer, caps: [LirAtom], ctx: CodegenCtx, obj_ptr: i64, field_idx: i64) -> %ByteBuffer throws { Exn } do
  match caps do
    case [] -> %buf
    case a :: rest ->
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = emit_atom(atom: a, buf: %buf, ctx: ctx)
      let %buf = emit_pack_to_i64(typ: atom_type(atom: a), buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_i64_store)
      let %buf = emit_memarg_i64(buf: %buf, offset: field_idx * 8)
      emit_closure_captures(buf: %buf, caps: rest, ctx: ctx, obj_ptr: obj_ptr, field_idx: field_idx + 1)
  end
end

let emit_closure_call_args = fn (buf: %ByteBuffer, args: [LirCallArg], ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  match args do
    case [] -> %buf
    case LirCallArg(label: _, value: a) :: rest ->
      let %buf = emit_atom(atom: a, buf: %buf, ctx: ctx)
      let %buf = emit_pack_to_i64(typ: atom_type(atom: a), buf: %buf)
      emit_closure_call_args(buf: %buf, args: rest, ctx: ctx)
  end
end

// ─── Expression emission ────────────────────────────────────────────────────

let emit_expr = fn (expr: LirExpr, buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool) -> %ByteBuffer throws { Exn } do
  match expr do
    case LirExprAtom(atom: a) -> emit_atom(atom: a, buf: %buf, ctx: ctx)

    case LirExprBinary(op: op, lhs: l, rhs: r, typ: t) ->
      match is_string_concat_op(op: op, typ: t) do
        case true -> emit_string_concat(lhs: l, rhs: r, buf: %buf, ctx: ctx)
        case false ->
          match is_string_op(op: op, lhs_type: atom_type(atom: l), rhs_type: atom_type(atom: r)) do
            case true -> emit_string_compare(op: op, lhs: l, rhs: r, buf: %buf, ctx: ctx)
            case false ->
              let %buf = emit_atom(atom: l, buf: %buf, ctx: ctx)
              let %buf = emit_atom(atom: r, buf: %buf, ctx: ctx)
              emit_binary(op: op, operand_type: atom_type(atom: l), buf: %buf)
          end
      end

    case LirExprCall(func: fname, args: args, typ: _) ->
      emit_call(func: fname, args: args, buf: %buf, ctx: ctx, is_tail: false, in_try: in_try)

    case LirExprTailCall(func: fname, args: args, typ: _) ->
      emit_call(func: fname, args: args, buf: %buf, ctx: ctx, is_tail: true, in_try: in_try)

    case LirExprConstructor(name: cname, args: cargs, typ: _) ->
      let arity = list.length(xs: cargs)
      let tag = constructor_tag(name: cname, arity: arity)
      let %buf = emit_alloc_object(buf: %buf, ctx: ctx, words: 1 + arity)
      let obj_ptr = ctx_temps_base(ctx: ctx) + 3
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: tag)
      let %buf = push_byte(buf: %buf, byte: op_i64_store)
      let %buf = emit_memarg_i64(buf: %buf, offset: 0)
      let %buf = emit_constructor_fields(buf: %buf, args: cargs, ctx: ctx, obj_ptr: obj_ptr, field_idx: 1)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      return push_byte(buf: %buf, byte: op_i64_extend_i32_u)

    case LirExprRecord(fields: fields, typ: _) ->
      let names = extract_field_names(fields: fields)
      let tag = record_tag(sorted_names: names)
      let n_fields = list.length(xs: fields)
      let %buf = emit_alloc_object(buf: %buf, ctx: ctx, words: 1 + n_fields)
      let obj_ptr = ctx_temps_base(ctx: ctx) + 3
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: tag)
      let %buf = push_byte(buf: %buf, byte: op_i64_store)
      let %buf = emit_memarg_i64(buf: %buf, offset: 0)
      let %buf = emit_record_fields(buf: %buf, fields: fields, ctx: ctx, obj_ptr: obj_ptr, field_idx: 1)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      return push_byte(buf: %buf, byte: op_i64_extend_i32_u)

    case LirExprObjectTag(value: v, typ: _) ->
      let obj_ptr = ctx_temps_base(ctx: ctx) + 3
      let %buf = emit_atom(atom: v, buf: %buf, ctx: ctx)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_load)
      return emit_memarg_i64(buf: %buf, offset: 0)

    case LirExprObjectField(value: v, index: idx, typ: ftyp) ->
      let obj_ptr = ctx_temps_base(ctx: ctx) + 3
      let %buf = emit_atom(atom: v, buf: %buf, ctx: ctx)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_load)
      let %buf = emit_memarg_i64(buf: %buf, offset: (idx + 1) * 8)
      return emit_unpack_from_i64(typ: ftyp, buf: %buf)

    case LirExprRaise(value: v, typ: _) ->
      let %buf = emit_atom(atom: v, buf: %buf, ctx: ctx)
      // Unit-typed raise: push i64(0) as payload
      let %buf = match is_unit(typ: atom_type(atom: v)) do
        case true ->
          let %b = push_byte(buf: %buf, byte: op_i64_const)
          push_sleb128(buf: %b, val: 0)
        case false -> %buf
      end
      let %buf = push_byte(buf: %buf, byte: op_throw)
      let %buf = push_uleb128(buf: %buf, val: 0)
      return %buf

    case LirExprMakeClosure(func_name: fname, captures: caps, typ: _) ->
      // Allocate (1 + n_captures) words on heap
      let n_caps = list.length(xs: caps)
      let %buf = emit_alloc_object(buf: %buf, ctx: ctx, words: 1 + n_caps)
      let obj_ptr = ctx_temps_base(ctx: ctx) + 3
      // Store table_idx at offset 0
      let table_idx = lookup_closure_table_idx(name: fname, entries: ctx_closure_table(ctx: ctx))
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: table_idx)
      let %buf = push_byte(buf: %buf, byte: op_i64_store)
      let %buf = emit_memarg_i64(buf: %buf, offset: 0)
      // Store captures at offset 8, 16, ...
      let %buf = emit_closure_captures(buf: %buf, caps: caps, ctx: ctx, obj_ptr: obj_ptr, field_idx: 1)
      // Result: obj_ptr as i64
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      return push_byte(buf: %buf, byte: op_i64_extend_i32_u)

    case LirExprCallClosure(closure: clos, args: cargs, typ: _) ->
      // Push env (closure pointer) as first arg
      let %buf = emit_atom(atom: clos, buf: %buf, ctx: ctx)
      // Push actual args (packed to i64)
      let %buf = emit_closure_call_args(buf: %buf, args: cargs, ctx: ctx)
      // Load table_idx from "closure"
      let obj_ptr = ctx_temps_base(ctx: ctx) + 3
      let %buf = emit_atom(atom: clos, buf: %buf, ctx: ctx)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_load)
      let %buf = emit_memarg_i64(buf: %buf, offset: 0)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      // call_indirect: type_idx, table 0
      let n_args = list.length(xs: cargs)
      let type_idx = lookup_closure_type_idx_pairs(arity: n_args, pairs: ctx_closure_type_indices(ctx: ctx))
      let %buf = push_byte(buf: %buf, byte: op_call_indirect)
      let %buf = push_uleb128(buf: %buf, val: type_idx)
      let %buf = push_uleb128(buf: %buf, val: 0)
      return %buf
  end
end

let emit_if_return_unconditional = fn (buf: %ByteBuffer, then_body: [LirStmt], then_ret: LirAtom,
    ret_type: TypeExpr, ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { Exn } do
  let %buf = emit_stmts(stmts: then_body, buf: %buf, ctx: ctx, in_try: in_try, tcmc: tcmc)
  return emit_return_with_tcmc(buf: %buf, ret_val: then_ret, ret_type: ret_type, ctx: ctx, tcmc: tcmc)
end

let emit_if_return_conditional = fn (buf: %ByteBuffer, cond: LirAtom, then_body: [LirStmt], then_ret: LirAtom,
    else_body: [LirStmt], else_ret: Option<LirAtom>, ret_type: TypeExpr,
    ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { Exn } do
  let %buf = emit_atom(atom: cond, buf: %buf, ctx: ctx)
  let %buf = emit_coercion(from_type: atom_type(atom: cond), to_type: TyBool, buf: %buf)
  let %buf = push_byte(buf: %buf, byte: op_if)
  let %buf = push_byte(buf: %buf, byte: bt_void)
  let %buf = emit_stmts(stmts: then_body, buf: %buf, ctx: ctx, in_try: in_try, tcmc: tcmc)
  let %buf = emit_return_with_tcmc(buf: %buf, ret_val: then_ret, ret_type: ret_type, ctx: ctx, tcmc: tcmc)
  let has_else = list.length(xs: else_body) > 0
  let has_else_ret = match else_ret do case Some(val: _) -> true case None -> false end
  if has_else || has_else_ret then
    let %buf = push_byte(buf: %buf, byte: op_else)
    let %buf = emit_stmts(stmts: else_body, buf: %buf, ctx: ctx, in_try: in_try, tcmc: tcmc)
    match else_ret do
      case Some(val: a) ->
        let %buf = emit_return_with_tcmc(buf: %buf, ret_val: a, ret_type: ret_type, ctx: ctx, tcmc: tcmc)
      case None -> ()
    end
  end
  return push_byte(buf: %buf, byte: op_end)
end

let is_unconditional_return = fn (cond: LirAtom, else_body: [LirStmt], else_ret: Option<LirAtom>) -> bool throws { Exn } do
  match cond do
    case LirAtomBool(val: true) ->
      let has_else = list.length(xs: else_body) > 0
      let has_else_ret = match else_ret do case Some(val: _) -> true case None -> false end
      return (has_else || has_else_ret) == false
    case _ -> return false
  end
end

// ─── Statement emission (mutually recursive) ────────────────────────────────

let emit_stmt = fn (stmt: LirStmt, buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { Exn } do
  match stmt do
    case LirStmtLet(name: n, typ: t, expr: e) ->
      // TCMC interception: skip self-call, intercept constructor
      match tcmc do
        case TcmcActive(head_local: _, prev_local: _, rest_field_idx: _, call_var: cv,
                         cons_var: consv, call_args: _, ctor_name: _, ctor_args: _, func_name: _, loop_depth: _) ->
          if n == cv then
            match e do case LirExprCall(func: _, args: _, typ: _) -> return %buf case _ -> () end
          end
          if n == consv then
            match e do
              case LirExprConstructor(name: _, args: _, typ: _) ->
                return emit_tcmc_cons_and_loop(buf: %buf, ctx: ctx, tcmc: tcmc)
              case _ -> ()
            end
          end
        case NoTcmc -> ()
      end
      let %buf = emit_expr(expr: e, buf: %buf, ctx: ctx, in_try: in_try)
      let et = expr_type(expr: e)
      if is_unit(typ: t) then
        if is_unit(typ: et) == false then return push_byte(buf: %buf, byte: op_drop)
        else return %buf end
      else
        // If expr is Unit-typed but binding is not, emit a default value.
        // This happens for dead-code Let bindings where value comes from
        // explicit returns inside branches (if/match).
        let %buf = match is_unit(typ: et) do
          case true -> emit_default_for_type(buf: %buf, typ: t)
          case false -> emit_coercion(from_type: et, to_type: t, buf: %buf)
        end
        let raw_idx = lookup_local(name: n, entries: ctx_locals(ctx: ctx))
        let idx = match raw_idx < 0 do case true -> 0 case false -> raw_idx end
        // Widen i32→i64 if local was widened due to type conflict
        let expr_vt = type_to_valtype(typ: peel_linear(typ: et))
        let local_vt = lookup_local_valtype(name: n, entries: ctx_locals(ctx: ctx))
        let %buf = match expr_vt == vt_i32 && local_vt == vt_i64 do
          case true -> push_byte(buf: %buf, byte: op_i64_extend_i32_u)
          case false -> %buf
        end
        let %buf = push_byte(buf: %buf, byte: op_local_set)
        return push_uleb128(buf: %buf, val: idx)
      end

    case LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let %buf = emit_atom(atom: c, buf: %buf, ctx: ctx)
      let %buf = emit_coercion(from_type: atom_type(atom: c), to_type: TyBool, buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_if)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      let inner_tcmc = tcmc_deeper(tcmc: tcmc, n: 1)
      let %buf = emit_stmts(stmts: tb, buf: %buf, ctx: ctx, in_try: in_try, tcmc: inner_tcmc)
      if list.length(xs: eb) > 0 then
        let %buf = push_byte(buf: %buf, byte: op_else)
        let %buf = emit_stmts(stmts: eb, buf: %buf, ctx: ctx, in_try: in_try, tcmc: inner_tcmc)
      end
      return push_byte(buf: %buf, byte: op_end)

    case LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr, else_body: eb, else_ret: er, ret_type: rt) ->
      // Optimize: if cond is always true and no else, emit body directly (no if wrapper)
      match is_unconditional_return(cond: c, else_body: eb, else_ret: er) do
        case true ->
          return emit_if_return_unconditional(buf: %buf, then_body: tb, then_ret: tr,
            ret_type: rt, ctx: ctx, in_try: in_try, tcmc: tcmc)
        case false ->
          let inner_tcmc = tcmc_deeper(tcmc: tcmc, n: 1)
          return emit_if_return_conditional(buf: %buf, cond: c, then_body: tb, then_ret: tr,
            else_body: eb, else_ret: er, ret_type: rt, ctx: ctx, in_try: in_try, tcmc: inner_tcmc)
      end

    case LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      let inner_tcmc = tcmc_deeper(tcmc: tcmc, n: 2)
      let %buf = push_byte(buf: %buf, byte: op_block)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      let %buf = push_byte(buf: %buf, byte: op_loop)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      let %buf = emit_stmts(stmts: cs, buf: %buf, ctx: ctx, in_try: in_try, tcmc: inner_tcmc)
      let %buf = emit_atom(atom: c, buf: %buf, ctx: ctx)
      let %buf = emit_coercion(from_type: atom_type(atom: c), to_type: TyBool, buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_br_if)
      let %buf = push_uleb128(buf: %buf, val: 1)
      let %buf = emit_stmts(stmts: b, buf: %buf, ctx: ctx, in_try: in_try, tcmc: inner_tcmc)
      let %buf = push_byte(buf: %buf, byte: op_br)
      let %buf = push_uleb128(buf: %buf, val: 0)
      let %buf = push_byte(buf: %buf, byte: op_end)
      return push_byte(buf: %buf, byte: op_end)

    case LirStmtTryCatch(body: b, body_ret: br, catch_param: cp, catch_param_typ: _,
                          catch_body: cb, catch_ret: cr) ->
      let catch_local_idx = lookup_local(name: cp, entries: ctx_locals(ctx: ctx))

      // WASM EH: block $skip { block $catch (result i64) { try_table (catch tag0 $catch) { body } end; br 1 } end; catch body } end
      // Emit block $skip
      let %buf = push_byte(buf: %buf, byte: op_block)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      // Emit block $catch (result i64)
      let %buf = push_byte(buf: %buf, byte: op_block)
      let %buf = push_byte(buf: %buf, byte: bt_i64)
      // Emit try_table (catch tag0 label0)
      let %buf = push_byte(buf: %buf, byte: op_try_table)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      let %buf = push_uleb128(buf: %buf, val: 1)
      let %buf = push_byte(buf: %buf, byte: catch_kind_one)
      let %buf = push_uleb128(buf: %buf, val: 0)
      let %buf = push_uleb128(buf: %buf, val: 0)

      // Emit try body
      let %buf = emit_stmts(stmts: b, buf: %buf, ctx: ctx, in_try: true, tcmc: NoTcmc)
      let %buf = match br do
        case Some(val: a) ->
          let %b = emit_atom(atom: a, buf: %buf, ctx: ctx)
          let %b = emit_coercion(from_type: atom_type(atom: a), to_type: ctx_func_ret_type(ctx: ctx), buf: %b)
          push_byte(buf: %b, byte: op_return)
        case None -> %buf
      end
      let %buf = push_byte(buf: %buf, byte: op_end)

      // Try succeeded — skip catch
      let %buf = push_byte(buf: %buf, byte: op_br)
      let %buf = push_uleb128(buf: %buf, val: 1)
      let %buf = push_byte(buf: %buf, byte: op_end)

      // Catch body — i64 payload on stack from $catch block
      if catch_local_idx >= 0 then
        let %buf = push_byte(buf: %buf, byte: op_local_set)
        let %buf = push_uleb128(buf: %buf, val: catch_local_idx)
      end
      let %buf = emit_stmts(stmts: cb, buf: %buf, ctx: ctx, in_try: in_try, tcmc: NoTcmc)
      let %buf = match cr do
        case Some(val: a) ->
          let %b = emit_atom(atom: a, buf: %buf, ctx: ctx)
          let %b = emit_coercion(from_type: atom_type(atom: a), to_type: ctx_func_ret_type(ctx: ctx), buf: %b)
          push_byte(buf: %b, byte: op_return)
        case None -> %buf
      end
      return push_byte(buf: %buf, byte: op_end)

    case LirStmtConc(tasks: tasks) ->
      let spawn_idx = lookup_func_fast(name: "__nx_conc_spawn", map_id: ctx_external_func_map(ctx: ctx))
      let join_idx = lookup_func_fast(name: "__nx_conc_join", map_id: ctx_external_func_map(ctx: ctx))
      let args_ptr_local = ctx_temps_base(ctx: ctx) + 2
      let %buf = emit_conc_tasks(tasks: tasks, buf: %buf, ctx: ctx,
        spawn_idx: spawn_idx, args_ptr_local: args_ptr_local)
      // Call __nx_conc_join()
      let %buf = push_byte(buf: %buf, byte: op_call)
      return push_uleb128(buf: %buf, val: join_idx)
  end
end

let emit_conc_tasks = fn (tasks: [ConcTask], buf: %ByteBuffer, ctx: CodegenCtx,
                           spawn_idx: i64, args_ptr_local: i64) -> %ByteBuffer throws { Exn } do
  match tasks do
    case [] -> %buf
    case ConcTask(func_name: fname, args: args) :: rest ->
      let func_idx = lookup_func_fast(name: fname, map_id: ctx_internal_func_map(ctx: ctx))
      let n_args = list.length(xs: args)
      let conc_alloc_idx = lookup_func_fast(name: "__nx_allocate", map_id: ctx_external_func_map(ctx: ctx))
      // Allocate heap space for args (n_args * 8 bytes)
      match conc_alloc_idx >= 0 do
        case true ->
          let %buf = push_byte(buf: %buf, byte: op_i32_const)
          let %buf = push_sleb128(buf: %buf, val: n_args * 8)
          let %buf = push_byte(buf: %buf, byte: op_call)
          let %buf = push_uleb128(buf: %buf, val: conc_alloc_idx)
          let %buf = push_byte(buf: %buf, byte: op_local_set)
          let %buf = push_uleb128(buf: %buf, val: args_ptr_local)
        case false ->
          let %buf = push_byte(buf: %buf, byte: op_global_get)
          let %buf = push_uleb128(buf: %buf, val: heap_global_idx)
          let %buf = push_byte(buf: %buf, byte: op_local_set)
          let %buf = push_uleb128(buf: %buf, val: args_ptr_local)
      end
      // Write each captured arg as i64 to heap
      let %buf = emit_conc_args(args: args, buf: %buf, ctx: ctx,
        args_ptr_local: args_ptr_local, offset: 0)
      // Advance heap pointer (only for bump allocator)
      if conc_alloc_idx < 0 then
        let %buf = push_byte(buf: %buf, byte: op_local_get)
        let %buf = push_uleb128(buf: %buf, val: args_ptr_local)
        let %buf = push_byte(buf: %buf, byte: op_i32_const)
        let %buf = push_sleb128(buf: %buf, val: n_args * 8)
        let %buf = push_byte(buf: %buf, byte: op_i32_add)
        let %buf = push_byte(buf: %buf, byte: op_global_set)
        let %buf = push_uleb128(buf: %buf, val: heap_global_idx)
      end
      // Call __nx_conc_spawn(func_idx, args_ptr, n_args)
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      let %buf = push_sleb128(buf: %buf, val: func_idx)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: args_ptr_local)
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      let %buf = push_sleb128(buf: %buf, val: n_args)
      let %buf = push_byte(buf: %buf, byte: op_call)
      let %buf = push_uleb128(buf: %buf, val: spawn_idx)
      emit_conc_tasks(tasks: rest, buf: %buf, ctx: ctx,
        spawn_idx: spawn_idx, args_ptr_local: args_ptr_local)
  end
end

let emit_conc_args = fn (args: [LirNamedAtom], buf: %ByteBuffer, ctx: CodegenCtx,
                          args_ptr_local: i64, offset: i64) -> %ByteBuffer throws { Exn } do
  match args do
    case [] -> %buf
    case LirNamedAtom(name: _, value: atom) :: rest ->
      // base_ptr
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: args_ptr_local)
      // Load atom value
      let %buf = emit_atom(atom: atom, buf: %buf, ctx: ctx)
      // Widen to i64 if needed
      let %buf = emit_widen_to_i64(typ: atom_type(atom: atom), buf: %buf)
      // i64.store with offset
      let %buf = push_byte(buf: %buf, byte: op_i64_store)
      let %buf = push_uleb128(buf: %buf, val: 3)
      let %buf = push_uleb128(buf: %buf, val: offset)
      emit_conc_args(args: rest, buf: %buf, ctx: ctx,
        args_ptr_local: args_ptr_local, offset: offset + 8)
  end
end

let emit_widen_to_i64 = fn (typ: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer throws { Exn } do
  match peel_linear(typ: typ) do
    case TyI32 -> push_byte(buf: %buf, byte: op_i64_extend_i32_u)
    case TyBool -> push_byte(buf: %buf, byte: op_i64_extend_i32_u)
    case TyF64 -> push_byte(buf: %buf, byte: op_i64_reinterpret_f64)
    case _ -> %buf
  end
end

let emit_stmts = fn (stmts: [LirStmt], buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { Exn } do
  match stmts do
    case [] -> %buf
    case s :: rest ->
      emit_stmts(stmts: rest, buf: emit_stmt(stmt: s, buf: %buf, ctx: ctx, in_try: in_try, tcmc: tcmc), ctx: ctx, in_try: in_try, tcmc: tcmc)
  end
end

// ─── Function body compilation ──────────────────────────────────────────────

let emit_default_for_type = fn (buf: %ByteBuffer, typ: TypeExpr) -> %ByteBuffer throws { Exn } do
  let vt = type_to_valtype(typ: typ)
  match vt == vt_i32 do
    case true ->
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      return push_sleb128(buf: %buf, val: 0)
    case false ->
      match vt == vt_f64 do
        case true ->
          let %buf = push_byte(buf: %buf, byte: op_f64_const)
          return push_f64_str_le(buf: %buf, s: "0.0")
        case false ->
          let %buf = push_byte(buf: %buf, byte: op_i64_const)
          return push_sleb128(buf: %buf, val: 0)
      end
  end
end

let emit_return_value = fn (body: %ByteBuffer, rt: TypeExpr, r: LirAtom, ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  match is_unit(typ: rt) do
    case true -> %body
    case false ->
      let actual = match r do
        case LirAtomUnit -> emit_default_for_type(buf: %body, typ: rt)
        case _ ->
          let %body = emit_atom(atom: r, buf: %body, ctx: ctx)
          emit_coercion(from_type: atom_type(atom: r), to_type: rt, buf: %body)
      end
      return actual
  end
end

let compile_function_body = fn (func: LirFunction, ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  let LirFunction(name: fname, params: ps, ret_type: rt, body: b, ret: r, span: _) = func
  let %body = empty()
  let %body = emit_local_decls(buf: %body, locals: ctx_locals(ctx: ctx), param_count: list.length(xs: ps))

  // TCMC: detect pattern and set up locals
  let tcmc_raw = detect_tcmc(body: b, func_name: fname)
  let tcmc = match tcmc_raw do
    case NoTcmc -> NoTcmc
    case TcmcActive(head_local: _, prev_local: _, rest_field_idx: rfi, call_var: cv,
                     cons_var: consv, call_args: ca, ctor_name: cn, ctor_args: cta,
                     func_name: fn2, loop_depth: _) ->
      TcmcActive(head_local: ctx_temps_base(ctx: ctx) + 13,
                  prev_local: ctx_temps_base(ctx: ctx) + 14,
                  rest_field_idx: rfi, call_var: cv, cons_var: consv, call_args: ca,
                  ctor_name: cn, ctor_args: cta, func_name: fn2, loop_depth: 0)
  end

  // TCMC init (before loop, runs once)
  let %body = emit_tcmc_init(buf: %body, tcmc: tcmc)
  // Wrap body in loop if TCMC detected
  let is_tcmc = match tcmc do case TcmcActive(head_local: _, prev_local: _, rest_field_idx: _, call_var: _, cons_var: _, call_args: _, ctor_name: _, ctor_args: _, func_name: _, loop_depth: _) -> true case NoTcmc -> false end
  if is_tcmc then
    let %body = push_byte(buf: %body, byte: op_loop)
    let %body = push_byte(buf: %body, byte: bt_void)
  end

  let %body = emit_stmts(stmts: b, buf: %body, ctx: ctx, in_try: false, tcmc: tcmc)

  if is_tcmc then
    let %body = push_byte(buf: %body, byte: op_end)
  end

  let %body = emit_return_value(body: %body, rt: rt, r: r, ctx: ctx)
  push_byte(buf: %body, byte: op_end)
end

let compile_wasi_run_wrapper = fn (main_idx: i64, main_ret_type: TypeExpr) -> %ByteBuffer throws { Exn } do
  let %body = empty()
  let %body = push_uleb128(buf: %body, val: 0)
  let %body = push_byte(buf: %body, byte: op_call)
  let %body = push_uleb128(buf: %body, val: main_idx)
  let %body = match is_unit(typ: main_ret_type) do
    case true -> %body
    case false -> push_byte(buf: %body, byte: op_drop)
  end
  let %body = push_byte(buf: %body, byte: op_i32_const)
  let %body = push_sleb128(buf: %body, val: 0)
  return push_byte(buf: %body, byte: op_end)
end

// ─── Code section / context building ────────────────────────────────────────

let build_param_locals = fn (params: [LirParam], idx: i64) -> [LocalEntry] throws { Exn } do
  match params do
    case [] -> []
    case LirParam(label: _, name: n, typ: t) :: rest ->
      LocalEntry(name: n, index: idx, valtype: type_to_valtype(typ: t))
           :: build_param_locals(params: rest, idx: idx + 1)
  end
end

let build_func_ctx = fn (func: LirFunction, internal_funcs: [FuncEntry],
                          external_funcs: [FuncEntry], string_lits: [StringEntry],
                          alloc_mode: i64, functions: [LirFunction],
                          externals: [LirExternal],
                          closure_table: [FuncEntry],
                          closure_type_indices: [ArityTypeIdx],
                          internal_func_map: i64,
                          external_func_map: i64) -> CodegenCtx throws { Exn } do
  let LirFunction(name: fname, params: ps, ret_type: rt, body: b, ret: _, span: _) = func
  let param_locals = build_param_locals(params: ps, idx: 0)
  let param_count = list.length(xs: ps)
  let local_map = build_local_map(entries: param_locals)
  match collect_local_stmts(stmts: b, locals: param_locals, next_idx: param_count, local_map: local_map) do case LocalResult(locals: collected_locals, next_idx: collected_next_idx, local_map: lm) ->
  free_func_map(map_id: lm)
  return CodegenCtx(
    locals: collected_locals, internal_funcs: internal_funcs, external_funcs: external_funcs,
    string_lits: string_lits, alloc_mode: alloc_mode, temps_base: collected_next_idx,
    func_ret_type: rt, functions: functions, externals: externals,
    closure_table: closure_table, closure_type_indices: closure_type_indices,
    internal_func_map: internal_func_map, external_func_map: external_func_map,
    func_name: fname
  )
  end
end

let append_body_to_buf = fn (buf: %ByteBuffer, body: %ByteBuffer) -> %ByteBuffer throws { Exn } do
  let body_len = buf_length(buf: &body)
  let %buf = push_uleb128(buf: %buf, val: body_len)
  let %buf = push_buf(dst: %buf, src: &body)
  free(buf: %body)
  return %buf
end

let emit_one_body = fn (buf: %ByteBuffer, f: LirFunction,
                         internal_funcs: [FuncEntry], external_funcs: [FuncEntry],
                         string_lits: [StringEntry], alloc_mode: i64,
                         functions: [LirFunction], externals: [LirExternal],
                         closure_table: [FuncEntry],
                         closure_type_indices: [ArityTypeIdx],
                         internal_func_map: i64,
                         external_func_map: i64) -> %ByteBuffer throws { Exn } do
  let ctx = build_func_ctx(func: f, internal_funcs: internal_funcs,
                            external_funcs: external_funcs, string_lits: string_lits,
                            alloc_mode: alloc_mode, functions: functions, externals: externals,
                            closure_table: closure_table, closure_type_indices: closure_type_indices,
                            internal_func_map: internal_func_map, external_func_map: external_func_map)
  let %body = compile_function_body(func: f, ctx: ctx)
  return append_body_to_buf(buf: %buf, body: %body)
end

let emit_code_bodies = fn (buf: %ByteBuffer, funcs: [LirFunction],
                            internal_funcs: [FuncEntry], external_funcs: [FuncEntry],
                            string_lits: [StringEntry], alloc_mode: i64,
                            functions: [LirFunction], externals: [LirExternal],
                            closure_table: [FuncEntry],
                            closure_type_indices: [ArityTypeIdx],
                            internal_func_map: i64,
                            external_func_map: i64) -> %ByteBuffer throws { Exn } do
  match funcs do
    case [] -> return %buf
    case f :: rest ->
      let %buf = emit_one_body(buf: %buf, f: f, internal_funcs: internal_funcs,
                                external_funcs: external_funcs, string_lits: string_lits,
                                alloc_mode: alloc_mode, functions: functions, externals: externals,
                                closure_table: closure_table, closure_type_indices: closure_type_indices,
                                internal_func_map: internal_func_map, external_func_map: external_func_map)
      return emit_code_bodies(buf: %buf, funcs: rest, internal_funcs: internal_funcs,
                        external_funcs: external_funcs, string_lits: string_lits,
                        alloc_mode: alloc_mode, functions: functions, externals: externals,
                        closure_table: closure_table, closure_type_indices: closure_type_indices,
                        internal_func_map: internal_func_map, external_func_map: external_func_map)
  end
end

// ─── Module assembly ────────────────────────────────────────────────────────

let build_internal_func_entries = fn (funcs: [LirFunction], import_count: i64, idx: i64) -> [FuncEntry] throws { Exn } do
  match funcs do
    case [] -> []
    case LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      FuncEntry(name: n, index: import_count + idx)
           :: build_internal_func_entries(funcs: rest, import_count: import_count, idx: idx + 1)
  end
end

let build_external_func_entries = fn (exts: [LirExternal], idx: i64) -> [FuncEntry] throws { Exn } do
  match exts do
    case [] -> []
    case LirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) :: rest ->
      FuncEntry(name: n, index: idx)
           :: build_external_func_entries(exts: rest, idx: idx + 1)
  end
end

// ─── Conc detection helpers ──────────────────────────────────────────────────

let has_conc_tasks = fn (funcs: [LirFunction]) -> bool throws { Exn } do
  match funcs do
    case [] -> return false
    case LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      if starts_with(s: n, prefix: "__conc_") then return true
      else return has_conc_tasks(funcs: rest)
      end
  end
end

let collect_conc_exports = fn (funcs: [FuncEntry]) -> [FuncEntry] throws { Exn } do
  match funcs do
    case [] -> return []
    case FuncEntry(name: n, index: idx) :: rest ->
      if starts_with(s: n, prefix: "__conc_") then
        return FuncEntry(name: n, index: idx) :: collect_conc_exports(funcs: rest)
      else return collect_conc_exports(funcs: rest)
      end
  end
end

let make_conc_externals = fn () -> [LirExternal] throws { Exn } do
  return [
    LirExternal(
      name: "__nx_conc_spawn",
      wasm_module: "nexus:runtime/conc",
      wasm_name: "__nx_conc_spawn",
      params: [LirParam(label: "func_idx", name: "func_idx", typ: TyI32),
               LirParam(label: "args_ptr", name: "args_ptr", typ: TyI32),
               LirParam(label: "n_args", name: "n_args", typ: TyI32)],
      ret_type: TyUnit,
      throw_row: TyUnit
    ),
    LirExternal(
      name: "__nx_conc_join",
      wasm_module: "nexus:runtime/conc",
      wasm_name: "__nx_conc_join",
      params: [],
      ret_type: TyUnit,
      throw_row: TyUnit
    )
  ]
end

let append_externals = fn (a: [LirExternal], b: [LirExternal]) -> [LirExternal] throws { Exn } do
  match a do
    case [] -> b
    case e :: rest -> e :: append_externals(a: rest, b: b)
  end
end

// ─── Closure analysis helpers ───────────────────────────────────────────────

/// Build closure table entries: maps table index → function index for __closure_* functions.
let build_closure_table = fn (funcs: [LirFunction], internal_func_map: i64, table_idx: i64) -> [FuncEntry] throws { Exn } do
  match funcs do
    case [] -> []
    case LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      if is_closure_func(name: n) then
        let func_idx = lookup_func_fast(name: n, map_id: internal_func_map)
        return FuncEntry(name: n, index: func_idx)
             :: build_closure_table(funcs: rest, internal_func_map: internal_func_map, table_idx: table_idx + 1)
      end
      return build_closure_table(funcs: rest, internal_func_map: internal_func_map, table_idx: table_idx)
  end
end

/// Insert a value into a sorted list, skipping if already present. O(K) per insert.
let insert_sorted_i64 = fn (val: i64, xs: [i64]) -> [i64] throws { Exn } do
  match xs do
    case [] -> [val]
    case x :: rest ->
      match val == x do
        case true -> xs
        case false ->
          match val < x do
            case true -> val :: xs
            case false -> x :: insert_sorted_i64(val: val, xs: rest)
          end
      end
  end
end

/// Get distinct closure arities from __closure_* functions.
/// Arity = param count - 1 (subtract the __env param).
/// Builds a sorted+deduped list in a single pass.
let collect_closure_arities = fn (funcs: [LirFunction]) -> [i64] throws { Exn } do
  return collect_closure_arities_acc(funcs: funcs, acc: [])
end

let collect_closure_arities_acc = fn (funcs: [LirFunction], acc: [i64]) -> [i64] throws { Exn } do
  match funcs do
    case [] -> acc
    case LirFunction(name: n, params: ps, ret_type: _, body: _, ret: _, span: _) :: rest ->
      if is_closure_func(name: n) then
        let arity = list.length(xs: ps) - 1
        return collect_closure_arities_acc(funcs: rest, acc: insert_sorted_i64(val: arity, xs: acc))
      end
      return collect_closure_arities_acc(funcs: rest, acc: acc)
  end
end

// ─── Name section (custom) ─────────────────────────────────────────────────

/// Build name subsection entries for external (imported) functions
let emit_external_name_entries = fn (buf: %ByteBuffer, exts: [LirExternal], idx: i64) -> %ByteBuffer throws { Exn } do
  match exts do
    case [] -> return %buf
    case LirExternal(name: _, wasm_module: _, wasm_name: wn, params: _, ret_type: _, throw_row: _) :: rest ->
      let %buf = push_uleb128(buf: %buf, val: idx)
      let %buf = emit_name(buf: %buf, name: wn)
      return emit_external_name_entries(buf: %buf, exts: rest, idx: idx + 1)
  end
end

/// Build name subsection entries for internal functions
let emit_internal_name_entries = fn (buf: %ByteBuffer, funcs: [LirFunction], idx: i64) -> %ByteBuffer throws { Exn } do
  match funcs do
    case [] -> return %buf
    case LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      let %buf = push_uleb128(buf: %buf, val: idx)
      let %buf = emit_name(buf: %buf, name: n)
      return emit_internal_name_entries(buf: %buf, funcs: rest, idx: idx + 1)
  end
end

/// Build the WASM name custom section payload (section name + function subsection)
let build_name_section = fn (exts: [LirExternal], funcs: [LirFunction],
                              has_alloc: bool,
                              n_exts: i64, n_alloc_imports: i64,
                              total_funcs: i64) -> %ByteBuffer throws { Exn } do
  let %entries = empty()
  let %entries = push_uleb128(buf: %entries, val: total_funcs)
  let %entries = emit_external_name_entries(buf: %entries, exts: exts, idx: 0)
  if has_alloc then
    let %entries = push_uleb128(buf: %entries, val: n_exts)
    let %entries = emit_name(buf: %entries, name: "allocate")
  end
  let internal_start = n_exts + n_alloc_imports
  let %entries = emit_internal_name_entries(buf: %entries, funcs: funcs, idx: internal_start)
  let wasi_idx = total_funcs - 1
  let %entries = push_uleb128(buf: %entries, val: wasi_idx)
  let %entries = emit_name(buf: %entries, name: "wasi:cli/run@0.2.0#run")

  let entries_len = buf_length(buf: &entries)
  let %subsec = empty()
  let %subsec = push_byte(buf: %subsec, byte: 1)
  let %subsec = push_uleb128(buf: %subsec, val: entries_len)
  let %subsec = push_buf(dst: %subsec, src: &entries)
  free(buf: %entries)

  let %payload = empty()
  let %payload = emit_name(buf: %payload, name: "name")
  let %payload = push_buf(dst: %payload, src: &subsec)
  free(buf: %subsec)
  return %payload
end

// ─── Module entry point ────────────────────────────────────────────────────

export let compile_lir_to_wasm = fn (program: LirProgram) -> %ByteBuffer throws { Exn } do
  match program do
    case LirProgram(functions: funcs, externals: orig_exts) ->
      // Detect conc tasks and add conc imports if needed
      let has_conc = has_conc_tasks(funcs: funcs)
      let exts = match has_conc do
        case true -> append_externals(a: orig_exts, b: make_conc_externals())
        case false -> orig_exts
      end
      let augmented_program = LirProgram(functions: funcs, externals: exts)

      let n_exts = list.length(xs: exts)
      let n_funcs = list.length(xs: funcs)
      let has_eh = program_needs_eh(funcs: funcs)
      let heap_enabled = program_uses_heap(funcs: funcs)
      let uses_stdlib = has_stdlib(externals: exts)
      // alloc_mode: 0=none, 1=bump allocator, 2=stdlib allocate
      let alloc_mode = match heap_enabled do
        case false -> 0
        case true -> match uses_stdlib do case true -> 2 case false -> 1 end
      end
      let n_alloc_imports = match alloc_mode == 2 do case true -> 1 case false -> 0 end
      let import_count = n_exts + n_alloc_imports

      let internal_funcs = build_internal_func_entries(funcs: funcs, import_count: import_count, idx: 0)
      let base_external_funcs = build_external_func_entries(exts: exts, idx: 0)
      // Add allocate import to external_funcs for lookup
      let external_funcs = match alloc_mode == 2 do
        case true -> FuncEntry(name: "__nx_allocate", index: n_exts) :: base_external_funcs
        case false -> base_external_funcs
      end

      // Build hash maps for O(1) function lookup
      let internal_func_map = build_func_map(entries: internal_funcs)
      let external_func_map = build_func_map(entries: external_funcs)

      // Closure analysis
      let closure_table = build_closure_table(funcs: funcs, internal_func_map: internal_func_map, table_idx: 0)
      let n_closures = list.length(xs: closure_table)
      let closure_arities = collect_closure_arities(funcs: funcs)
      let n_closure_types = list.length(xs: closure_arities)
      // Closure type indices start after all ext + func + wasi_run + eh_tag + alloc types
      let n_eh_types = match has_eh do case true -> 1 case false -> 0 end
      let closure_type_base = n_exts + n_funcs + 1 + n_eh_types + n_alloc_imports

      let main_idx = lookup_func_fast(name: "main", map_id: internal_func_map)
      let main_ret = match find_function(name: "main", funcs: funcs) do
        case Some(val: LirFunction(name: _, params: _, ret_type: rt, body: _, ret: _, span: _)) -> rt
        case None -> TyUnit
      end

      let all_strings = collect_program_strings(funcs: funcs, acc: [])
      let string_entries = build_string_entries(strings: all_strings, next_offset: string_data_base, acc: [])
      let has_strings = list.length(xs: string_entries) > 0

      let mem_mode = choose_memory_mode(externals: exts, has_strings: has_strings, has_heap: heap_enabled)

      let last_end = compute_last_string_end(entries: string_entries)
      let heap_base_raw = match last_end > string_data_base do case true -> last_end case false -> string_data_base end
      let heap_base = align8(v: heap_base_raw)

      let wasi_run_idx = import_count + n_funcs

      // Conc exports
      let conc_exports = match has_conc do
        case true -> collect_conc_exports(funcs: internal_funcs)
        case false -> []
      end

      // WASM magic + version
      let %m = empty()
      let %m = push_byte(buf: %m, byte: 0)
      let %m = push_byte(buf: %m, byte: 97)
      let %m = push_byte(buf: %m, byte: 115)
      let %m = push_byte(buf: %m, byte: 109)
      let %m = push_byte(buf: %m, byte: 1)
      let %m = push_byte(buf: %m, byte: 0)
      let %m = push_byte(buf: %m, byte: 0)
      let %m = push_byte(buf: %m, byte: 0)

      // Type section (with EH tag + allocate + closure call types appended)
      let has_alloc = alloc_mode == 2
      let %type_sec = build_type_section(program: augmented_program, has_eh: has_eh, has_alloc: has_alloc, n_closure_types: n_closure_types)
      if n_closure_types > 0 then
        let %type_sec = emit_closure_type_entries(buf: %type_sec, arities: closure_arities)
      end
      let %m = emit_section(buf: %m, id: sec_type, content: %type_sec)

      // Import section
      if n_exts > 0 || (mem_mode != "none" && mem_mode != "defined") || has_alloc then
        let alloc_type_idx = n_exts + n_funcs + 1 + n_eh_types
        let %m = emit_section(buf: %m, id: sec_import,
                               content: build_import_section(exts: exts, mem_mode: mem_mode,
                                 has_alloc: has_alloc, alloc_type_idx: alloc_type_idx,
                                 alloc_module: mem_mode))
      end

      // Function section
      let %m = emit_section(buf: %m, id: sec_function, content: build_function_section(n_funcs: n_funcs, n_exts: n_exts))

      // Table section (if closures exist)
      if n_closures > 0 then
        let %m = emit_section(buf: %m, id: sec_table, content: build_table_section(n_closures: n_closures))
      end

      // Memory section
      if mem_mode == "defined" then
        let %m = emit_section(buf: %m, id: sec_memory, content: build_memory_section())
      end

      // Tag section (WASM EH) — must come after memory, before global
      if has_eh then
        let exn_tag_type_idx = n_exts + n_funcs + 1
        let %m = emit_section(buf: %m, id: sec_tag, content: build_tag_section(exn_tag_type_idx: exn_tag_type_idx))
      end

      // Global section — only needed for bump allocator (alloc_mode 1).
      // When using stdlib allocate (alloc_mode 2), stdlib owns the global heap pointer.
      // Emitting our own global[0] conflicts with stdlib's after wasm-merge.
      if heap_enabled && alloc_mode == 1 then
        let %m = emit_section(buf: %m, id: sec_global, content: build_global_section(heap_base: heap_base))
      end

      // Export section
      let %m = emit_section(buf: %m, id: sec_export,
                             content: build_export_section(main_idx: main_idx, wasi_run_idx: wasi_run_idx,
                                                           mem_mode: mem_mode, conc_exports: conc_exports))

      // Element section (populate funcref table)
      if n_closures > 0 then
        let %m = emit_section(buf: %m, id: sec_element, content: build_element_section(closure_entries: closure_table))
      end

      // Code section
      // Build closure_type_indices: map arity → type section index
      let closure_type_idx_list = build_closure_type_idx_list(arities: closure_arities, base: closure_type_base)
      let %code = empty()
      let %code = push_uleb128(buf: %code, val: n_funcs + 1)
      let %code = emit_code_bodies(buf: %code, funcs: funcs, internal_funcs: internal_funcs,
                                    external_funcs: external_funcs, string_lits: string_entries,
                                    alloc_mode: alloc_mode, functions: funcs, externals: exts,
                                    closure_table: closure_table, closure_type_indices: closure_type_idx_list,
                                    internal_func_map: internal_func_map, external_func_map: external_func_map)
      let %wasi_body = compile_wasi_run_wrapper(main_idx: main_idx, main_ret_type: main_ret)
      let %code = append_body_to_buf(buf: %code, body: %wasi_body)
      let %m = emit_section(buf: %m, id: sec_code, content: %code)

      // Data section
      if has_strings then
        let %m = emit_section(buf: %m, id: sec_data, content: build_data_section(entries: string_entries))
      end

      // Name section (custom)
      let total_named_funcs = import_count + n_funcs + 1
      let %name_payload = build_name_section(exts: exts, funcs: funcs,
                                              has_alloc: has_alloc,
                                              n_exts: n_exts,
                                              n_alloc_imports: n_alloc_imports,
                                              total_funcs: total_named_funcs)
      let name_payload_len = buf_length(buf: &name_payload)
      let %m = push_byte(buf: %m, byte: sec_custom)
      let %m = push_uleb128(buf: %m, val: name_payload_len)
      let %m = push_buf(dst: %m, src: &name_payload)
      free(buf: %name_payload)

      // Free function lookup maps
      free_func_map(map_id: internal_func_map)
      free_func_map(map_id: external_func_map)

      return %m
  end
end

let build_closure_type_idx_list = fn (arities: [i64], base: i64) -> [ArityTypeIdx] throws { Exn } do
  match arities do
    case [] -> []
    case a :: rest ->
      ArityTypeIdx(arity: a, type_idx: base)
           :: build_closure_type_idx_list(arities: rest, base: base + 1)
  end
end
