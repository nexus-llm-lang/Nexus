// ─── Helper types ───────────────────────────────────────────────────────────

export type LocalEntry = LocalEntry(name: string, index: i64, valtype: i64)
export type FuncEntry = FuncEntry(name: string, index: i64)
export type StringEntry = StringEntry(value: string, offset: i64, slen: i64)
export type DataSeg = DataSeg(offset: i64, value: string)
export type ArityTypeIdx = ArityTypeIdx(arity: i64, type_idx: i64)

// ─── CodegenCtx ─────────────────────────────────────────────────────────────

export type CodegenCtx = CodegenCtx(
  locals: [LocalEntry],
  internal_funcs: [FuncEntry],
  external_funcs: [FuncEntry],
  string_lits: [StringEntry],
  alloc_mode: i64,
  temps_base: i64,
  func_ret_type: TypeExpr,
  functions: [LirFunction],
  externals: [LirExternal],
  closure_table: [FuncEntry],
  closure_type_indices: [ArityTypeIdx],
  internal_func_map: i64,
  external_func_map: i64,
  func_name: string
)

export let ctx_locals = fn (ctx: CodegenCtx) -> [LocalEntry] do
  match ctx do case CodegenCtx(locals: l, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _) -> l end
end

export let ctx_internal_funcs = fn (ctx: CodegenCtx) -> [FuncEntry] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: f, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _) -> f end
end

export let ctx_external_funcs = fn (ctx: CodegenCtx) -> [FuncEntry] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: f, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _) -> f end
end

export let ctx_string_lits = fn (ctx: CodegenCtx) -> [StringEntry] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: s, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _) -> s end
end

export let ctx_alloc_mode = fn (ctx: CodegenCtx) -> i64 do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: m, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _) -> m end
end

export let ctx_temps_base = fn (ctx: CodegenCtx) -> i64 do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: t, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _) -> t end
end

export let ctx_func_ret_type = fn (ctx: CodegenCtx) -> TypeExpr do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: r, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _) -> r end
end

export let ctx_functions = fn (ctx: CodegenCtx) -> [LirFunction] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: f, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _) -> f end
end

export let ctx_externals = fn (ctx: CodegenCtx) -> [LirExternal] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: e, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _) -> e end
end

export let ctx_closure_table = fn (ctx: CodegenCtx) -> [FuncEntry] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: ct, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _) -> ct end
end

export let ctx_closure_type_indices = fn (ctx: CodegenCtx) -> [ArityTypeIdx] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: cti, internal_func_map: _, external_func_map: _, func_name: _) -> cti end
end

export let ctx_internal_func_map = fn (ctx: CodegenCtx) -> i64 do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: m, external_func_map: _, func_name: _) -> m end
end

export let ctx_external_func_map = fn (ctx: CodegenCtx) -> i64 do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: m, func_name: _) -> m end
end

export let ctx_func_name = fn (ctx: CodegenCtx) -> string do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: n) -> n end
end

// ─── Type utilities ─────────────────────────────────────────────────────────

export let peel_linear = fn (typ: TypeExpr) -> TypeExpr do
  match typ do
    case TyLinear(inner: t) -> return peel_linear(typ: t)
    case TyLazy(inner: t) -> return peel_linear(typ: t)
    case TyBorrow(inner: t) -> return peel_linear(typ: t)
    case _ -> return typ
  end
end

export let type_to_valtype = fn (typ: TypeExpr) -> i64 do
  match peel_linear(typ: typ) do
    case TyI32 -> vt_i32
    case TyBool -> vt_i32
    case TyChar -> vt_i32
    case TyI64 -> vt_i64
    case TyIntLit -> vt_i64
    case TyF32 -> vt_f32
    case TyF64 -> vt_f64
    case TyFloatLit -> vt_f64
    case _ -> vt_i64
  end
end

export let is_unit = fn (typ: TypeExpr) -> bool do
  match peel_linear(typ: typ) do
    case TyUnit -> return true
    case _ -> return false
  end
end

export let return_valtype = fn (typ: TypeExpr) -> i64 do
  if is_unit(typ: typ) then return -1
  else return type_to_valtype(typ: typ)
  end
end

// ─── FNV-1a hashing ─────────────────────────────────────────────────────────

let fnv_hash_byte = fn (hash: i64, byte: i64) -> i64 do
  return (hash ^ byte) * 1099511628211
end

let fnv_hash_string_go = fn (s: string, idx: i64, slen: i64, hash: i64) -> i64 do
  if idx >= slen then return hash
  else return fnv_hash_string_go(s: s, idx: idx + 1, slen: slen,
                                  hash: fnv_hash_byte(hash: hash, byte: char_code(s: s, idx: idx)))
  end
end

export let fnv_hash_string = fn (s: string, hash: i64) -> i64 do
  return fnv_hash_string_go(s: s, idx: 0, slen: str_length(s: s), hash: hash)
end

export let fnv_basis = -3750763034362895579

export let constructor_tag = fn (name: string, arity: i64) -> i64 do
  return fnv_hash_byte(hash: fnv_hash_string(s: name, hash: fnv_basis), byte: arity)
end

export let record_tag = fn (sorted_names: [string]) -> i64 do
  let shape = join(xs: sorted_names, sep: ",")
  let h = fnv_hash_string(s: shape, hash: fnv_hash_string(s: "rec", hash: fnv_basis))
  return fnv_hash_byte(hash: h, byte: list.length(xs: sorted_names))
end

// ─── Atom/expr type accessors ───────────────────────────────────────────────

export let atom_type = fn (atom: LirAtom) -> TypeExpr do
  match atom do
    case LirAtomVar(name: _, typ: t) -> t
    case LirAtomInt(val: _) -> TyI64
    case LirAtomFloat(val: _) -> TyF64
    case LirAtomBool(val: _) -> TyBool
    case LirAtomChar(val: _) -> TyChar
    case LirAtomString(val: _) -> TyString
    case LirAtomUnit -> TyUnit
  end
end

export let expr_type = fn (expr: LirExpr) -> TypeExpr do
  match expr do
    case LirExprAtom(atom: a) -> atom_type(atom: a)
    case LirExprBinary(op: _, lhs: _, rhs: _, typ: t) -> t
    case LirExprCall(func: _, args: _, typ: t) -> t
    case LirExprTailCall(func: _, args: _, typ: t) -> t
    case LirExprConstructor(name: _, args: _, typ: t) -> t
    case LirExprRecord(fields: _, typ: t) -> t
    case LirExprObjectTag(value: _, typ: t) -> t
    case LirExprObjectField(value: _, index: _, typ: t) -> t
    case LirExprRaise(value: _, typ: t) -> t
    case LirExprForce(value: _, typ: t) -> t
    case LirExprMakeClosure(func_name: _, captures: _, typ: t) -> t
    case LirExprCallClosure(closure: _, args: _, typ: t) -> t
  end
end

// ─── Lookup helpers ─────────────────────────────────────────────────────────

export let lookup_local = fn (name: string, entries: [LocalEntry]) -> i64 do
  match entries do
    case [] -> return -1
    case LocalEntry(name: n, index: idx, valtype: _) :: rest ->
      if n == name then return idx end
      return lookup_local(name: name, entries: rest)
  end
end

export let lookup_local_valtype = fn (name: string, entries: [LocalEntry]) -> i64 do
  match entries do
    case [] -> return -1
    case LocalEntry(name: n, index: _, valtype: vt) :: rest ->
      if n == name then return vt end
      return lookup_local_valtype(name: name, entries: rest)
  end
end

// Replace valtype for an existing local entry (widen i32 → i64 on conflict)
export let widen_local = fn (name: string, new_vt: i64, entries: [LocalEntry]) -> [LocalEntry] do
  return widen_local_go(name: name, new_vt: new_vt, entries: entries, acc: [])
end

let widen_local_go = fn (name: string, new_vt: i64, entries: [LocalEntry], acc: [LocalEntry]) -> [LocalEntry] do
  match entries do
    case [] -> return rev_local_entries(lst: acc, out: [])
    case LocalEntry(name: n, index: idx, valtype: vt) :: rest ->
      if n == name then
        return rev_local_entries(lst: acc, out: LocalEntry(name: n, index: idx, valtype: new_vt) :: rest)
      end
      return widen_local_go(name: name, new_vt: new_vt, entries: rest, acc: LocalEntry(name: n, index: idx, valtype: vt) :: acc)
  end
end

let rev_local_entries = fn (lst: [LocalEntry], out: [LocalEntry]) -> [LocalEntry] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_local_entries(lst: rest, out: x :: out)
  end
end

export let lookup_func = fn (name: string, entries: [FuncEntry]) -> i64 do
  match entries do
    case [] -> return -1
    case FuncEntry(name: n, index: idx) :: rest ->
      if n == name then return idx end
      return lookup_func(name: name, entries: rest)
  end
end

export let lookup_string = fn (value: string, entries: [StringEntry]) -> i64 do
  match entries do
    case [] -> return -1
    case StringEntry(value: v, offset: off, slen: sl) :: rest ->
      if v == value then return (off * 4294967296) + sl end
      return lookup_string(value: value, entries: rest)
  end
end

export let find_function = fn (name: string, funcs: [LirFunction]) -> Option<LirFunction> do
  match funcs do
    case [] -> return None
    case f :: rest ->
      let LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) = f
      if n == name then return Some(val: f) end
      return find_function(name: name, funcs: rest)
  end
end

export let find_external = fn (name: string, exts: [LirExternal]) -> Option<LirExternal> do
  match exts do
    case [] -> return None
    case e :: rest ->
      let LirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) = e
      if n == name then return Some(val: e) end
      return find_external(name: name, exts: rest)
  end
end

// ─── WASM encoding helpers ──────────────────────────────────────────────────

export let emit_name = fn (buf: %ByteBuffer, name: string) -> %ByteBuffer do
  let slen = str_length(s: name)
  let %buf = push_uleb128(buf: %buf, val: slen)
  let %buf = push_string(buf: %buf, s: name)
  return %buf
end

export let emit_section = fn (buf: %ByteBuffer, id: i64, content: %ByteBuffer) -> %ByteBuffer do
  let content_len = buf_length(buf: &content)
  let %buf = push_byte(buf: %buf, byte: id)
  let %buf = push_uleb128(buf: %buf, val: content_len)
  let %buf = push_buf(dst: %buf, src: &content)
  free(buf: %content)
  return %buf
end

export let emit_memarg = fn (buf: %ByteBuffer, align: i64, offset: i64) -> %ByteBuffer do
  let %buf = push_uleb128(buf: %buf, val: align)
  let %buf = push_uleb128(buf: %buf, val: offset)
  return %buf
end

export let emit_memarg_i32 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return emit_memarg(buf: %buf, align: 2, offset: offset)
end

export let emit_memarg_i64 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return emit_memarg(buf: %buf, align: 3, offset: offset)
end

export let emit_memarg_i8 = fn (buf: %ByteBuffer) -> %ByteBuffer do
  return emit_memarg(buf: %buf, align: 0, offset: 0)
end

/// Check if name starts with "__closure_" (10 chars: _ _ c l o s u r e _)
export let is_closure_func = fn (name: string) -> bool do
  if str_length(s: name) < 10 then return false end
  return char_code(s: name, idx: 0) == 95
      && char_code(s: name, idx: 1) == 95
      && char_code(s: name, idx: 2) == 99
      && char_code(s: name, idx: 3) == 108
      && char_code(s: name, idx: 4) == 111
      && char_code(s: name, idx: 5) == 115
      && char_code(s: name, idx: 6) == 117
      && char_code(s: name, idx: 7) == 114
      && char_code(s: name, idx: 8) == 101
      && char_code(s: name, idx: 9) == 95
end

// ─── HashMap-backed function index lookup ───────────────────────────────────

export let hash_name = fn (name: string) -> i64 do
  return fnv_hash_string(s: name, hash: fnv_basis)
end

export let build_func_map = fn (entries: [FuncEntry]) -> i64 do
  let map_id = __nx_hmap_new()
  return build_func_map_go(entries: entries, map_id: map_id)
end

let build_func_map_go = fn (entries: [FuncEntry], map_id: i64) -> i64 do
  match entries do
    case [] -> map_id
    case FuncEntry(name: n, index: idx) :: rest ->
      // Preserve first-wins semantics (matches linear lookup_func behavior)
      let key = hash_name(name: n)
      let existing = __nx_hmap_get(id: map_id, key: key, default_val: -1)
      if existing < 0 then
        let _ = __nx_hmap_put(id: map_id, key: key, value: idx)
      end
      return build_func_map_go(entries: rest, map_id: map_id)
  end
end

export let free_func_map = fn (map_id: i64) -> unit do
  let _ = __nx_hmap_free(id: map_id)
  return ()
end

export let lookup_func_fast = fn (name: string, map_id: i64) -> i64 do
  return __nx_hmap_get(id: map_id, key: hash_name(name: name), default_val: -1)
end

export let build_local_map = fn (entries: [LocalEntry]) -> i64 do
  let map_id = __nx_hmap_new()
  return build_local_map_go(entries: entries, map_id: map_id)
end

let build_local_map_go = fn (entries: [LocalEntry], map_id: i64) -> i64 do
  match entries do
    case [] -> map_id
    case LocalEntry(name: n, index: _, valtype: vt) :: rest ->
      let _ = __nx_hmap_put(id: map_id, key: hash_name(name: n), value: vt)
      return build_local_map_go(entries: rest, map_id: map_id)
  end
end
