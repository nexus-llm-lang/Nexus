/**
 * wasm_defs: WASM constants, helper types, and core utilities for codegen.
 *
 * Contains section IDs, value types, opcodes, CodegenCtx, type utilities,
 * FNV-1a hashing, lookup helpers, and WASM encoding primitives.
 */

import { ByteBuffer, empty, push_byte, push_uleb128, push_sleb128,
         push_string, push_buf, free, length as buf_length } from "stdlib/bytebuffer.nx"
import { BinaryOp, TypeExpr, NamedType } from "nxc/common/ast.nx"
import { LirProgram, LirFunction, LirStmt, LirExpr, LirAtom,
         LirExternal, LirParam, LirCallArg, LirNamedAtom } from "nxc/ir/lir_types.nx"
import { from_i64, join } from "stdlib/string.nx"
import { char_code } from "stdlib/string.nx"
import * as list from "stdlib/list.nx"

import { length as str_length, byte_length as str_byte_length } from "stdlib/string.nx"

// Raw hashmap FFI — we use stdlib/stdlib.wasm but the HIR maps these to the
// correct WIT interface based on the function name prefix.
import external "stdlib/stdlib.wasm"
external __nx_hmap_new = "__nx_hmap_new" : () -> i64
external __nx_hmap_put = "__nx_hmap_put" : (id: i64, key: i64, value: i64) -> i64
external __nx_hmap_get = "__nx_hmap_get" : (id: i64, key: i64, default_val: i64) -> i64
external __nx_hmap_free = "__nx_hmap_free" : (id: i64) -> bool

