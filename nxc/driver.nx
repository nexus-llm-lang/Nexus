/**
 * driver: Self-hosting compiler CLI entry point.
 *
 * Reads a Nexus source file, processes imports with cycle detection,
 * and compiles through the full pipeline:
 *   Lex → Parse → HIR → MIR → LIR → WASM
 */

import { tokenize } from "nxc/frontend/lexer.nx"
import { parse } from "nxc/frontend/parser.nx"
import { Program, SpannedTopLevel, TopLevel, ImportDef, ImportItem, EnumDef, GlobalLet } from "nxc/common/ast.nx"
import { CompileError, error_no_span, format_error, PhaseDriver } from "nxc/common/error.nx"
import { RenameEntry } from "nxc/ir/symtab.nx"
import { default_alias, build_rename_map, extract_imports } from "nxc/ir/resolve.nx"
import { HirAccum, HirProgram } from "nxc/ir/hir_types.nx"
import { empty_accum, process_defs, accum_to_program } from "nxc/ir/hir.nx"
import { lower_hir_to_mir } from "nxc/ir/mir.nx"
import { lower_mir_to_lir } from "nxc/ir/lir.nx"
import { optimize_lir } from "nxc/ir/lir_opt.nx"
import { compile_lir_to_wasm } from "nxc/backend/codegen.nx"
import { check_program } from "nxc/typecheck/check.nx"
import { write_file, free } from "stdlib/bytebuffer.nx"
import { Fs }, * as fs_mod from "stdlib/fs.nx"
import { Console }, * as stdio from "stdlib/stdio.nx"
import { Clock }, * as clock_mod from "stdlib/clock.nx"
import { from_i64 } from "stdlib/string.nx"
import * as list from "stdlib/list.nx"

// ─── Import processing ──────────────────────────────────────────────────────

type CacheEntry = CacheEntry(path: string, defs: [SpannedTopLevel])
type ImportResult = ImportResult(accum: HirAccum, visited: [string], cache: [CacheEntry])
type ImportEdge = ImportEdge(from_path: string, to_path: string, is_external: bool)
type GraphResult = GraphResult(edges: [ImportEdge], visited: [string])

let list_has_str = fn (xs: [string], s: string) -> bool do
  match xs do
    case Nil -> return false
    case x :: rest ->
      if x == s then return true end
      return list_has_str(xs: rest, s: s)
  end
end

let import_items_has = fn (items: [ImportItem], name: string) -> bool do
  match items do
    case Nil -> return false
    case ImportItem(name: item_name, item_alias: _) :: rest ->
      if item_name == name then return true end
      return import_items_has(items: rest, name: name)
  end
end

let cache_lookup = fn (cache: [CacheEntry], path: string) -> [SpannedTopLevel] do
  match cache do
    case Nil -> return Nil
    case CacheEntry(path: p, defs: d) :: rest ->
      if p == path then return d end
      return cache_lookup(cache: rest, path: path)
  end
end

/// Filter defs to only TLLet definitions whose names are in the items list.
/// Used for diamond import re-processing: only re-register the selectively
/// imported functions without duplicating enums, ports, or unrelated lets.
let filter_defs_by_items = fn (defs: [SpannedTopLevel], items: [ImportItem]) -> [SpannedTopLevel] do
  match defs do
    case Nil -> return Nil
    case d :: rest ->
      match d do
        case SpannedTopLevel(node: TLLet(def: GlobalLet(name: name, is_public: _, typ: _, value: _)), span: _) ->
          if import_items_has(items: items, name: name) then
            return Cons(v: d, rest: filter_defs_by_items(defs: rest, items: items))
          else
            return filter_defs_by_items(defs: rest, items: items)
          end
        case _ -> return filter_defs_by_items(defs: rest, items: items)
      end
  end
end

let process_imports = fn (imports: [ImportDef], accum: HirAccum,
    import_stack: [string], visited: [string], cache: [CacheEntry], depth: i64, verbose: bool) -> ImportResult require { Fs, Console } throws { Exn } do
  match imports do
    case Nil -> ImportResult(accum: accum, visited: visited, cache: cache)
    case imp :: rest ->
      match imp do case ImportDef(path: path, alias: _, items: _, is_external: is_ext) ->
        match is_ext do
          case true ->
            if verbose then Console.eprintln(val: "[nxc]   skip external: " ++ path) end
            process_imports(imports: rest, accum: accum, import_stack: import_stack, visited: visited, cache: cache, depth: depth, verbose: verbose)
          case false ->
            if list_has_str(xs: import_stack, s: path) then
              error_no_span(phase: PhaseDriver, message: "cyclic import: " ++ path)
            end
            if list_has_str(xs: visited, s: path) then
              // Diamond import: reuse cached parse result instead of re-reading file
              match imp do case ImportDef(path: _, alias: _, items: items, is_external: _) ->
                match items do
                  case Nil ->
                    return process_imports(imports: rest, accum: accum, import_stack: import_stack, visited: visited, cache: cache, depth: depth, verbose: verbose)
                  case _ :: _ ->
                    if verbose then Console.eprintln(val: "[nxc]   diamond (cached): " ++ path) end
                    let cached_defs = cache_lookup(cache: cache, path: path)
                    let selected = filter_defs_by_items(defs: cached_defs, items: items)
                    let re_entries = build_rename_map(imported_defs: cached_defs, import_def: imp, import_depth: depth)
                    let accum2 = process_defs(defs: selected, entries: re_entries, accum: accum)
                    return process_imports(imports: rest, accum: accum2, import_stack: import_stack, visited: visited, cache: cache, depth: depth, verbose: verbose)
                end
              end
            end
            if verbose then Console.eprintln(val: "[nxc]   import: " ++ path) end
            let src = Fs.read_to_string(path: path)
            let tokens = tokenize(src: src)
            let imported_prog = parse(tokens: tokens)
            let imported_defs = get_defs(prog: imported_prog)
            let entries = build_rename_map(imported_defs: imported_defs, import_def: imp, import_depth: depth)
            let sub_imports = extract_imports(defs: imported_defs)
            let new_stack = Cons(v: path, rest: import_stack)
            let new_cache = Cons(v: CacheEntry(path: path, defs: imported_defs), rest: cache)
            let sub_result = process_imports(imports: sub_imports, accum: accum, import_stack: new_stack, visited: Cons(v: path, rest: visited), cache: new_cache, depth: depth + 1, verbose: verbose)
            match sub_result do case ImportResult(accum: accum2, visited: visited2, cache: cache2) ->
              let accum3 = process_defs(defs: imported_defs, entries: entries, accum: accum2)
              process_imports(imports: rest, accum: accum3, import_stack: import_stack, visited: visited2, cache: cache2, depth: depth, verbose: verbose)
            end
        end
      end
  end
end

// ─── Import graph (DOT output) ──────────────────────────────────────────────

let append_edges = fn (xs: [ImportEdge], ys: [ImportEdge]) -> [ImportEdge] do
  match xs do
    case Nil -> ys
    case x :: rest -> Cons(v: x, rest: append_edges(xs: rest, ys: ys))
  end
end

let collect_import_graph = fn (imports: [ImportDef], from_path: string,
    visited: [string]) -> GraphResult require { Fs } throws { Exn } do
  match imports do
    case Nil -> GraphResult(edges: Nil, visited: visited)
    case imp :: rest ->
      match imp do case ImportDef(path: path, alias: _, items: _, is_external: is_ext) ->
        let edge = ImportEdge(from_path: from_path, to_path: path, is_external: is_ext)
        match is_ext do
          case true ->
            let rest_r = collect_import_graph(imports: rest, from_path: from_path, visited: visited)
            match rest_r do case GraphResult(edges: re, visited: rv) ->
              GraphResult(edges: Cons(v: edge, rest: re), visited: rv)
            end
          case false ->
            if list_has_str(xs: visited, s: path) then
              let rest_r = collect_import_graph(imports: rest, from_path: from_path, visited: visited)
              match rest_r do case GraphResult(edges: re, visited: rv) ->
                return GraphResult(edges: Cons(v: edge, rest: re), visited: rv)
              end
            end
            let src = Fs.read_to_string(path: path)
            let tokens = tokenize(src: src)
            let imported_prog = parse(tokens: tokens)
            let sub_imports = extract_imports(defs: get_defs(prog: imported_prog))
            let sub_r = collect_import_graph(imports: sub_imports, from_path: path, visited: Cons(v: path, rest: visited))
            match sub_r do case GraphResult(edges: se, visited: sv) ->
              let rest_r = collect_import_graph(imports: rest, from_path: from_path, visited: sv)
              match rest_r do case GraphResult(edges: re, visited: rv) ->
                GraphResult(edges: Cons(v: edge, rest: append_edges(xs: se, ys: re)), visited: rv)
              end
            end
        end
      end
  end
end

let print_dot_edge = fn (edge: ImportEdge) -> unit require { Console } do
  match edge do case ImportEdge(from_path: f, to_path: t, is_external: ext) ->
    match ext do
      case true -> Console.println(val: "  \"" ++ f ++ "\" -> \"" ++ t ++ "\" [style=dashed];")
      case false -> Console.println(val: "  \"" ++ f ++ "\" -> \"" ++ t ++ "\";")
    end
  end
end

let print_dot_edges = fn (edges: [ImportEdge]) -> unit require { Console } do
  match edges do
    case Nil -> ()
    case edge :: rest ->
      print_dot_edge(edge: edge)
      print_dot_edges(edges: rest)
  end
end

let dump_import_graph = fn (input_path: string) -> unit
    require { Fs, Console } throws { Exn } do
  let src = Fs.read_to_string(path: input_path)
  let tokens = tokenize(src: src)
  let prog = parse(tokens: tokens)
  let imports = extract_imports(defs: get_defs(prog: prog))
  let result = collect_import_graph(imports: imports, from_path: input_path, visited: Cons(v: input_path, rest: Nil))
  match result do case GraphResult(edges: edges, visited: _) ->
    Console.println(val: "digraph imports {")
    Console.println(val: "  rankdir=LR;")
    print_dot_edges(edges: edges)
    Console.println(val: "}")
  end
end

// ─── Pipeline ───────────────────────────────────────────────────────────────

let get_defs = fn (prog: Program) -> [SpannedTopLevel] do
  match prog do case Program(definitions: defs) -> defs end
end

let extract_function_names = fn (defs: [SpannedTopLevel]) -> [string] do
  match defs do
    case Nil -> return Nil
    case SpannedTopLevel(node: TLLet(def: GlobalLet(name: name, is_public: _, typ: _, value: _)), span: _) :: rest ->
      return Cons(v: name, rest: extract_function_names(defs: rest))
    case _ :: rest -> return extract_function_names(defs: rest)
  end
end

let get_enum_defs = fn (hir: HirProgram) -> [EnumDef] do
  match hir do case HirProgram(ports: _, functions: _, externals: _, handler_bindings: _, enum_defs: eds) -> eds end
end

let build_hir = fn (prog: Program, verbose: bool) -> HirProgram require { Fs, Console } throws { Exn } do
  let defs = get_defs(prog: prog)
  let imports = extract_imports(defs: defs)
  let result = process_imports(imports: imports, accum: empty_accum(), import_stack: Nil, visited: Nil, cache: Nil, depth: 1, verbose: verbose)
  match result do case ImportResult(accum: accum, visited: _, cache: _) ->
    let accum2 = process_defs(defs: defs, entries: Nil, accum: accum)
    return accum_to_program(accum: accum2)
  end
end

// ─── CLI ────────────────────────────────────────────────────────────────────

let str_nth = fn (xs: [string], n: i64) -> string do
  match xs do
    case Nil -> str_nth(xs: xs, n: n)
    case v :: rest ->
      if n == 0 then return v end
      return str_nth(xs: rest, n: n - 1)
  end
end

/// Check if --verbose flag is present in args list.
let has_verbose_flag = fn (xs: [string]) -> bool do
  match xs do
    case Nil -> return false
    case v :: rest ->
      if v == "--verbose" then return true end
      return has_verbose_flag(xs: rest)
  end
end

/// Remove --verbose flag from args list, preserving order.
let strip_verbose_flag = fn (xs: [string]) -> [string] do
  match xs do
    case Nil -> return Nil
    case v :: rest ->
      if v == "--verbose" then return strip_verbose_flag(xs: rest) end
      return Cons(v: v, rest: strip_verbose_flag(xs: rest))
  end
end

let get_output_path = fn (xs: [string], argc: i64) -> string do
  if argc >= 3 then return str_nth(xs: xs, n: 2) end
  return "output.wasm"
end

let write_and_free = fn (buf: %ByteBuffer, path: string) -> bool require { PermFs } do
  let ok = write_file(buf: &buf, path: path)
  free(buf: %buf)
  return ok
end

let main = fn (args: [string]) -> unit
    require { PermFs, PermConsole, PermClock } do
  inject stdio.system_handler, fs_mod.system_handler, clock_mod.system_handler do
  try
    let verbose = has_verbose_flag(xs: args)
    let clean_args = strip_verbose_flag(xs: args)
    let argc = list.length(xs: clean_args)
    if argc < 2 then
      Console.eprintln(val: "Usage: nxc <input.nx> [output.wasm]")
      Console.eprintln(val: "       nxc --dump-imports <input.nx>")
      Console.eprintln(val: "       nxc --verbose <input.nx> [output.wasm]")
      error_no_span(phase: PhaseDriver, message: "missing input file argument")
    end

    let first_arg = str_nth(xs: clean_args, n: 1)
    if first_arg == "--dump-imports" then
      if argc < 3 then
        error_no_span(phase: PhaseDriver, message: "usage: nxc --dump-imports <input.nx>")
      end
      dump_import_graph(input_path: str_nth(xs: clean_args, n: 2))
      return ()
    end

    let input_path = first_arg
    let output_path = get_output_path(xs: clean_args, argc: argc)

    if verbose then Console.eprintln(val: "nxc: compiling " ++ input_path ++ " -> " ++ output_path) end

    let t0 = Clock.now()
    let src = Fs.read_to_string(path: input_path)
    let t1 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] read source (" ++ from_i64(val: t1 - t0) ++ "ms)") end

    let tokens = tokenize(src: src)
    let t2 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] lex (" ++ from_i64(val: t2 - t1) ++ "ms)") end

    let prog = parse(tokens: tokens)
    let t3 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] parse (" ++ from_i64(val: t3 - t2) ++ "ms)") end

    let hir = build_hir(prog: prog, verbose: verbose)
    let t4 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] HIR (" ++ from_i64(val: t4 - t3) ++ "ms)") end

    let local_names = extract_function_names(defs: get_defs(prog: prog))
    let hir_checked = check_program(hir: hir, local_names: local_names)
    let t5 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] typecheck (" ++ from_i64(val: t5 - t4) ++ "ms)") end

    let mir = lower_hir_to_mir(hir: hir_checked)
    let t6 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] MIR (" ++ from_i64(val: t6 - t5) ++ "ms)") end

    let lir = lower_mir_to_lir(mir: mir, enum_defs: get_enum_defs(hir: hir))
    let t7 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] LIR (" ++ from_i64(val: t7 - t6) ++ "ms)") end

    let lir_opt = optimize_lir(program: lir)
    let t8 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] optimize (" ++ from_i64(val: t8 - t7) ++ "ms)") end

    let %wasm_buf = compile_lir_to_wasm(program: lir_opt)
    let t9 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] codegen (" ++ from_i64(val: t9 - t8) ++ "ms)") end

    let ok = write_and_free(buf: %wasm_buf, path: output_path)
    let t10 = Clock.now()

    if ok then
      if verbose then
        Console.eprintln(val: "[nxc] write (" ++ from_i64(val: t10 - t9) ++ "ms)")
        Console.eprintln(val: "nxc: wrote " ++ output_path ++ " (total " ++ from_i64(val: t10 - t0) ++ "ms)")
      end
    else
      error_no_span(phase: PhaseDriver, message: "failed to write " ++ output_path)
    end
  catch e ->
    Console.eprintln(val: "error: " ++ format_error(err: e))
  end
  end
end
