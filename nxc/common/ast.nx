/**
 * ast: AST type definitions for the Nexus self-hosting compiler.
 *
 * Mirrors src/lang/ast.rs. Uses concrete Spanned* wrapper types
 * instead of generics (Nexus lacks user-defined generic ADTs).
 */

import { Span } from nxc/common/token.nx

// ─── Binding qualifiers ─────────────────────────────────────────────────────

pub type Sigil =
  SigilImmutable
  | SigilMutable
  | SigilLinear
  | SigilBorrow

// ─── Binary operators ───────────────────────────────────────────────────────

pub type BinaryOp =
  // Integer arithmetic
  OpAdd | OpSub | OpMul | OpDiv | OpMod
  // Float arithmetic
  | OpFAdd | OpFSub | OpFMul | OpFDiv
  // Integer comparisons
  | OpEq | OpNe | OpLt | OpLe | OpGt | OpGe
  // Float comparisons
  | OpFEq | OpFNe | OpFLt | OpFLe | OpFGt | OpFGe
  // Bitwise
  | OpBitAnd | OpBitOr | OpBitXor | OpShl | OpShr
  // Logical & string
  | OpAnd | OpOr | OpConcat

// ─── Literals ───────────────────────────────────────────────────────────────

pub type Literal =
  LitInt(val: i64)
  | LitFloat(val: string)
  | LitBool(val: bool)
  | LitChar(val: i64)
  | LitString(val: string)
  | LitUnit

// ─── Helper pair types (no tuples in Nexus) ─────────────────────────────────

pub type NamedType = NamedType(name: string, typ: TypeExpr)

pub type VariantField = VariantField(name: Option<string>, typ: TypeExpr)

pub type CallArg = CallArg(name: string, value: SpannedExpr)

pub type CtorArg = CtorArg(name: Option<string>, value: SpannedExpr)

pub type NamedExpr = NamedExpr(name: string, value: SpannedExpr)

pub type CtorPatternField = CtorPatternField(name: Option<string>, pattern: SpannedPattern)

pub type RecordPatField = RecordPatField(name: string, pattern: SpannedPattern)

// ─── Type expressions ───────────────────────────────────────────────────────

pub type TypeExpr =
  TyI32 | TyI64 | TyF32 | TyF64 | TyBool | TyChar | TyString | TyUnit
  | TyIntLit | TyFloatLit
  | TyUserDefined(name: string, args: [TypeExpr])
  | TyVar(name: string)
  | TyArrow(params: [NamedType], ret: TypeExpr, requires: TypeExpr, throw_row: TypeExpr)
  | TyRef(inner: TypeExpr)
  | TyLinear(inner: TypeExpr)
  | TyBorrow(inner: TypeExpr)
  | TyArray(elem: TypeExpr)
  | TyList(elem: TypeExpr)
  | TyRecord(fields: [NamedType])
  | TyRow(types: [TypeExpr], rest: Option<TypeExpr>)
  | TyHandler(name: string, requires: TypeExpr)

// ─── Patterns ───────────────────────────────────────────────────────────────

pub type Pattern =
  PatLiteral(lit: Literal)
  | PatVariable(name: string, sigil: Sigil)
  | PatConstructor(name: string, fields: [CtorPatternField])
  | PatRecord(fields: [RecordPatField], has_wildcard: bool)
  | PatWildcard

pub type SpannedPattern = SpannedPattern(node: Pattern, span: Span)

// ─── Match cases ────────────────────────────────────────────────────────────

pub type MatchCase = MatchCase(pattern: SpannedPattern, body: [SpannedStmt])

// ─── Expressions ────────────────────────────────────────────────────────────

pub type Expr =
  // Atoms
  ExprLiteral(lit: Literal)
  | ExprVariable(name: string, sigil: Sigil)
  | ExprBorrow(name: string, sigil: Sigil)
  // Operators
  | ExprBinaryOp(left: SpannedExpr, op: BinaryOp, right: SpannedExpr)
  // Calls
  | ExprCall(func: string, args: [CallArg])
  | ExprConstructor(name: string, args: [CtorArg])
  | ExprExternal(symbol: string, arg_names: [string], typ: TypeExpr)
  // Collections
  | ExprArray(elements: [SpannedExpr])
  | ExprList(elements: [SpannedExpr])
  | ExprRecord(fields: [NamedExpr])
  // Access
  | ExprIndex(target: SpannedExpr, index: SpannedExpr)
  | ExprFieldAccess(target: SpannedExpr, field: string)
  // Control flow
  | ExprIf(cond: SpannedExpr, then_branch: [SpannedStmt], else_branch: [SpannedStmt])
  | ExprMatch(target: SpannedExpr, cases: [MatchCase])
  | ExprWhile(cond: SpannedExpr, body: [SpannedStmt])
  | ExprFor(var: string, start: SpannedExpr, end_expr: SpannedExpr, body: [SpannedStmt])
  // Functions & effects
  | ExprLambda(type_params: [string], params: [Param], ret_type: TypeExpr, requires: TypeExpr, throw_row: TypeExpr, body: [SpannedStmt])
  | ExprRaise(value: SpannedExpr)
  | ExprHandler(coeffect_name: string, requires: TypeExpr, functions: [Function])

pub type SpannedExpr = SpannedExpr(node: Expr, span: Span)

// ─── Statements ─────────────────────────────────────────────────────────────

pub type Stmt =
  StmtLet(name: string, sigil: Sigil, typ: Option<TypeExpr>, value: SpannedExpr)
  | StmtExpr(expr: SpannedExpr)
  | StmtReturn(value: SpannedExpr)
  | StmtAssign(target: string, value: SpannedExpr)
  | StmtConc(tasks: [Function])
  | StmtTry(body: [SpannedStmt], catch_param: string, catch_body: [SpannedStmt])
  | StmtInject(handlers: [SpannedExpr], body: [SpannedStmt])

pub type SpannedStmt = SpannedStmt(node: Stmt, span: Span)

// ─── Parameters ─────────────────────────────────────────────────────────────

pub type Param = Param(name: string, sigil: Sigil, typ: TypeExpr)

// ─── Function definitions ───────────────────────────────────────────────────

pub type Function = Function(
  name: string,
  is_public: bool,
  type_params: [string],
  params: [Param],
  ret_type: TypeExpr,
  requires: TypeExpr,
  throw_row: TypeExpr,
  body: [SpannedStmt]
)

// ─── Top-level declarations ─────────────────────────────────────────────────

pub type VariantDef = VariantDef(name: string, fields: [VariantField])

pub type EnumDef = EnumDef(
  name: string,
  is_public: bool,
  is_opaque: bool,
  type_params: [string],
  variants: [VariantDef]
)

pub type RecordDef = RecordDef(
  name: string,
  is_public: bool,
  type_params: [string],
  fields: [NamedType]
)

pub type ExceptionDef = ExceptionDef(
  name: string,
  is_public: bool,
  fields: [VariantField]
)

pub type ImportDef = ImportDef(
  path: string,
  alias: Option<string>,
  items: [string],
  is_external: bool
)

pub type FunctionSig = FunctionSig(
  name: string,
  params: [Param],
  ret_type: TypeExpr,
  requires: TypeExpr,
  throw_row: TypeExpr
)

pub type Port = Port(
  name: string,
  is_public: bool,
  functions: [FunctionSig]
)

pub type GlobalLet = GlobalLet(
  name: string,
  is_public: bool,
  typ: Option<TypeExpr>,
  value: SpannedExpr
)

pub type TopLevel =
  TLTypeDef(def: RecordDef)
  | TLEnum(def: EnumDef)
  | TLException(def: ExceptionDef)
  | TLImport(def: ImportDef)
  | TLPort(def: Port)
  | TLLet(def: GlobalLet)

pub type SpannedTopLevel = SpannedTopLevel(node: TopLevel, span: Span)

// ─── Program root ───────────────────────────────────────────────────────────

pub type Program = Program(definitions: [SpannedTopLevel])
