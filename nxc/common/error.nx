/**
 * error: Qualified exception types for the Nexus self-hosting compiler.
 *
 * Per-phase exceptions grouped under CompileError for structured error handling.
 * `catch case CompileError ->` catches any compiler error.
 * `catch case ParseError(...) ->` catches only parse-phase errors.
 */

import { Span } from "nxc/common/token.nx"
import { from_i64 } from "stdlib/string.nx"

// ─── Per-phase exceptions ──────────────────────────────────────────────────

export exception LexError(message: string, span: Option<Span>)
export exception ParseError(message: string, span: Option<Span>)
export exception TypeError(message: string, span: Option<Span>)
export exception HirError(message: string, span: Option<Span>)
export exception MirError(message: string, span: Option<Span>)
export exception LirError(message: string, span: Option<Span>)
export exception CodegenError(message: string, span: Option<Span>)
export exception DriverError(message: string, span: Option<Span>)

export exception group CompileError = LexError | ParseError | TypeError
  | HirError | MirError | LirError | CodegenError | DriverError

// ─── Error construction helpers ─────────────────────────────────────────────

export type Phase =
  PhaseLex
  | PhaseParse
  | PhaseTypecheck
  | PhaseHir
  | PhaseMir
  | PhaseLir
  | PhaseCodegen
  | PhaseDriver

export let phase_name = fn (phase: Phase) -> string do
  match phase do
    case PhaseLex -> return "lex"
    case PhaseParse -> return "parse"
    case PhaseTypecheck -> return "typecheck"
    case PhaseHir -> return "hir"
    case PhaseMir -> return "mir"
    case PhaseLir -> return "lir"
    case PhaseCodegen -> return "codegen"
    case PhaseDriver -> return "driver"
  end
end

export let error = fn (phase: Phase, message: string, span: Span) -> unit throws { CompileError } do
  let sp = Some(val: span)
  match phase do
    case PhaseLex -> raise LexError(message: message, span: sp)
    case PhaseParse -> raise ParseError(message: message, span: sp)
    case PhaseTypecheck -> raise TypeError(message: message, span: sp)
    case PhaseHir -> raise HirError(message: message, span: sp)
    case PhaseMir -> raise MirError(message: message, span: sp)
    case PhaseLir -> raise LirError(message: message, span: sp)
    case PhaseCodegen -> raise CodegenError(message: message, span: sp)
    case PhaseDriver -> raise DriverError(message: message, span: sp)
  end
end

export let error_no_span = fn (phase: Phase, message: string) -> unit throws { CompileError } do
  match phase do
    case PhaseLex -> raise LexError(message: message, span: None)
    case PhaseParse -> raise ParseError(message: message, span: None)
    case PhaseTypecheck -> raise TypeError(message: message, span: None)
    case PhaseHir -> raise HirError(message: message, span: None)
    case PhaseMir -> raise MirError(message: message, span: None)
    case PhaseLir -> raise LirError(message: message, span: None)
    case PhaseCodegen -> raise CodegenError(message: message, span: None)
    case PhaseDriver -> raise DriverError(message: message, span: None)
  end
end

// ─── Error formatting ───────────────────────────────────────────────────────

let format_span = fn (sp: Option<Span>) -> string do
  match sp do
    case Some(val: s) ->
      match s do case Span(offset: _, line: l, col: c) ->
        return " at line " ++ from_i64(val: l) ++ " col " ++ from_i64(val: c)
      end
    case None -> return ""
  end
end

export let format_error = fn (err: Exn) -> string do
  match err do
    case LexError(message: msg, span: sp) -> "lex: " ++ msg ++ format_span(sp: sp)
    case ParseError(message: msg, span: sp) -> "parse: " ++ msg ++ format_span(sp: sp)
    case TypeError(message: msg, span: sp) -> "typecheck: " ++ msg ++ format_span(sp: sp)
    case HirError(message: msg, span: sp) -> "hir: " ++ msg ++ format_span(sp: sp)
    case MirError(message: msg, span: sp) -> "mir: " ++ msg ++ format_span(sp: sp)
    case LirError(message: msg, span: sp) -> "lir: " ++ msg ++ format_span(sp: sp)
    case CodegenError(message: msg, span: sp) -> "codegen: " ++ msg ++ format_span(sp: sp)
    case DriverError(message: msg, span: sp) -> "driver: " ++ msg ++ format_span(sp: sp)
    case RuntimeError(val: msg) -> msg
    case _ -> "unknown error"
  end
end
