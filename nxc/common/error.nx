/**
 * error: Unified error types for the Nexus self-hosting compiler.
 *
 * All compiler passes raise CompileError with phase, span, and message.
 * Replaces ad-hoc RuntimeError raises scattered across the codebase.
 */

import { Span } from nxc/common/token.nx

// ─── Compiler phase ─────────────────────────────────────────────────────────

export type Phase =
  PhaseLex
  | PhaseParse
  | PhaseTypecheck
  | PhaseHir
  | PhaseMir
  | PhaseLir
  | PhaseCodegen
  | PhaseDriver

export let phase_name = fn (phase: Phase) -> string do
  match phase do
    case PhaseLex -> return "lex"
    case PhaseParse -> return "parse"
    case PhaseTypecheck -> return "typecheck"
    case PhaseHir -> return "hir"
    case PhaseMir -> return "mir"
    case PhaseLir -> return "lir"
    case PhaseCodegen -> return "codegen"
    case PhaseDriver -> return "driver"
  end
end

// ─── Compile error ──────────────────────────────────────────────────────────

export exception CompileError(phase: Phase, message: string, span: Option<Span>)

// ─── Error construction helpers ─────────────────────────────────────────────

export let error = fn (phase: Phase, message: string, span: Span) -> unit throws { Exn } do
  raise CompileError(phase: phase, message: message, span: Some(val: span))
end

export let error_no_span = fn (phase: Phase, message: string) -> unit throws { Exn } do
  raise CompileError(phase: phase, message: message, span: None)
end

// ─── Error formatting ───────────────────────────────────────────────────────

let format_compile_error = fn (p: Phase, msg: string) -> string do
  return phase_name(phase: p) ++ ": " ++ msg
end

export let format_error = fn (err: Exn) -> string do
  match err do
    case CompileError(phase: p, message: msg, span: _) ->
      format_compile_error(p: p, msg: msg)
    case _ -> "unknown error"
  end
end
