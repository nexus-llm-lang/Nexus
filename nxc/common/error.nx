/**
 * error: Unified error types for the Nexus self-hosting compiler.
 *
 * All compiler passes raise CompileError with phase, span, and message.
 * Replaces ad-hoc RuntimeError raises scattered across the codebase.
 */

import { Span } from nxc/common/token.nx
import { from_i64 } from stdlib/string.nx

// ─── Compiler phase ─────────────────────────────────────────────────────────

pub type Phase =
  PhaseLex
  | PhaseParse
  | PhaseTypecheck
  | PhaseHir
  | PhaseMir
  | PhaseLir
  | PhaseCodegen
  | PhaseDriver

pub let phase_name = fn (phase: Phase) -> string do
  match phase
    case PhaseLex() -> return "lex"
    case PhaseParse() -> return "parse"
    case PhaseTypecheck() -> return "typecheck"
    case PhaseHir() -> return "hir"
    case PhaseMir() -> return "mir"
    case PhaseLir() -> return "lir"
    case PhaseCodegen() -> return "codegen"
    case PhaseDriver() -> return "driver"
  end
end

// ─── Compile error ──────────────────────────────────────────────────────────

pub exception CompileError(phase: Phase, message: string, span: Option<Span>)

// ─── Error construction helpers ─────────────────────────────────────────────

pub let error = fn (phase: Phase, message: string, span: Span) -> unit do
  raise CompileError(phase: phase, message: message, span: Some(val: span))
end

pub let error_no_span = fn (phase: Phase, message: string) -> unit do
  raise CompileError(phase: phase, message: message, span: None())
end

// ─── Error formatting ───────────────────────────────────────────────────────

pub let format_error = fn (err: CompileError) -> string do
  match err
    case CompileError(phase: p, message: msg, span: Some(val: Span(offset: _, line: l, col: c))) ->
      return phase_name(phase: p) ++ ":" ++ from_i64(val: l) ++ ":" ++ from_i64(val: c) ++ ": " ++ msg
    case CompileError(phase: p, message: msg, span: None()) ->
      return phase_name(phase: p) ++ ": " ++ msg
  end
end
