/**
 * token: Token types for the Nexus lexer.
 *
 * Token is the sum type of all lexical tokens.
 * Span records source position (byte offset + line + column).
 */

// ─── Source position ──────────────────────────────────────────────────────────

pub type Span = Span(offset: i64, line: i64, col: i64)

// ─── Token kinds ──────────────────────────────────────────────────────────────

pub type Token =
  // Keywords
    TkLet
  | TkFn
  | TkDo
  | TkEnd
  | TkIf
  | TkThen
  | TkElse
  | TkMatch
  | TkCase
  | TkWhile
  | TkFor
  | TkTo
  | TkReturn
  | TkImport
  | TkFrom
  | TkAs
  | TkExternal
  | TkPub
  | TkOpaque
  | TkType
  | TkPort
  | TkHandler
  | TkInject
  | TkConc
  | TkTask
  | TkTry
  | TkCatch
  | TkRaise
  | TkDrop
  | TkRequire
  | TkThrows
  | TkException
  | TkRef
  // Operators
  | TkPlus
  | TkMinus
  | TkStar
  | TkSlash
  | TkPlusPlus
  | TkPlusDot
  | TkMinusDot
  | TkStarDot
  | TkSlashDot
  | TkEqEq
  | TkBangEq
  | TkLt
  | TkGt
  | TkLe
  | TkGe
  | TkEqEqDot
  | TkBangEqDot
  | TkLtDot
  | TkGtDot
  | TkLeDot
  | TkGeDot
  | TkAndAnd
  | TkPipePipe
  | TkArrow
  | TkLArrow
  | TkEq
  | TkPipe
  // Punctuation
  | TkLParen
  | TkRParen
  | TkLBrace
  | TkRBrace
  | TkLBracket
  | TkRBracket
  | TkLArray
  | TkRArray
  | TkComma
  | TkDot
  | TkColon
  | TkTilde
  | TkPercent
  | TkAmpersand
  // Literals
  | TkTrue
  | TkFalse
  | TkUnit
  | TkInt(val: i64)
  | TkFloat(val: string)
  | TkChar(val: i64)
  | TkString(val: string)
  // Identifiers
  | TkIdent(name: string)
  | TkUident(name: string)
  // Import path (e.g. stdlib/string.nx)
  | TkImportPath(path: string)
  // Error recovery
  | TkError(msg: string)
  // Special
  | TkEof

// ─── Spanned token ────────────────────────────────────────────────────────────

pub type SpannedToken = SpannedToken(token: Token, span: Span)

// ─── Keyword lookup ───────────────────────────────────────────────────────────

/// Maps a lowercase identifier string to its keyword token, or None.
pub let keyword_lookup = fn (name: string) -> Option<Token> do
  if name == "let" then return Some(val: TkLet) end
  if name == "fn" then return Some(val: TkFn) end
  if name == "do" then return Some(val: TkDo) end
  if name == "end" then return Some(val: TkEnd) end
  if name == "if" then return Some(val: TkIf) end
  if name == "then" then return Some(val: TkThen) end
  if name == "else" then return Some(val: TkElse) end
  if name == "match" then return Some(val: TkMatch) end
  if name == "case" then return Some(val: TkCase) end
  if name == "while" then return Some(val: TkWhile) end
  if name == "for" then return Some(val: TkFor) end
  if name == "to" then return Some(val: TkTo) end
  if name == "return" then return Some(val: TkReturn) end
  if name == "import" then return Some(val: TkImport) end
  if name == "from" then return Some(val: TkFrom) end
  if name == "as" then return Some(val: TkAs) end
  if name == "external" then return Some(val: TkExternal) end
  if name == "pub" then return Some(val: TkPub) end
  if name == "opaque" then return Some(val: TkOpaque) end
  if name == "type" then return Some(val: TkType) end
  if name == "port" then return Some(val: TkPort) end
  if name == "handler" then return Some(val: TkHandler) end
  if name == "inject" then return Some(val: TkInject) end
  if name == "conc" then return Some(val: TkConc) end
  if name == "task" then return Some(val: TkTask) end
  if name == "try" then return Some(val: TkTry) end
  if name == "catch" then return Some(val: TkCatch) end
  if name == "raise" then return Some(val: TkRaise) end
  if name == "drop" then return Some(val: TkDrop) end
  if name == "require" then return Some(val: TkRequire) end
  if name == "throws" then return Some(val: TkThrows) end
  if name == "exception" then return Some(val: TkException) end
  if name == "ref" then return Some(val: TkRef) end
  if name == "true" then return Some(val: TkTrue) end
  if name == "false" then return Some(val: TkFalse) end
  return None
end
