import { buf_concat } from "stdlib/bytebuffer.nx"
import { length as str_length } from "stdlib/string.nx"

export let handler_func_name = fn (handler_name: string, method_name: string) -> string do
  return buf_concat(parts: ["__handler_", handler_name, "_", method_name])
end

export let handler_prefix_len = fn (handler_name: string) -> i64 do
  return str_length(s: buf_concat(parts: ["__handler_", handler_name, "_"]))
end
