import { concat } from nxc/common/strcat.nx

export let handler_func_name = fn (handler_name: string, method_name: string) -> string do
  return concat(parts: ["__handler_", handler_name, "_", method_name])
end

export let handler_prefix_len = fn (handler_name: string) -> i64 do
  return length(s: concat(parts: ["__handler_", handler_name, "_"]))
end
