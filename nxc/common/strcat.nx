/**
 * strcat: Multi-part string concatenation via ByteBuffer.
 *
 * Replaces chains of `++` operators (which consume codegen temp variables)
 * with ByteBuffer-based assembly. Takes a linear list %[string] so that
 * cons cells are consumed and freed after iteration.
 */

import { ByteBuffer, empty, push_string, to_string, free } from stdlib/bytebuffer.nx

let concat_go = fn (buf: %ByteBuffer, parts: %[string]) -> %ByteBuffer do
  match parts do
    case Nil -> return buf
    case s :: rest ->
      let buf = push_string(buf: %buf, s: s)
      let %linear_rest = rest
      return concat_go(buf: %buf, parts: %linear_rest)
  end
end

export let concat = fn (parts: %[string]) -> string do
  let buf = empty()
  let buf = concat_go(buf: %buf, parts: %parts)
  let result = to_string(buf: &buf)
  free(buf: %buf)
  return result
end
