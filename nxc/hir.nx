/**
 * hir: High-level Intermediate Representation for the Nexus self-hosting compiler.
 *
 * The HIR is a name-resolved AST with:
 * - All modules flattened into a single namespace
 * - All identifiers fully qualified via import renaming
 * - Handlers synthesized as regular functions
 * - Reachability-filtered (dead code removed)
 */
import { Span } from nxc/token.nx
import { Sigil, BinaryOp, Literal, TypeExpr, Pattern, Expr, Stmt,
         SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel,
         Param, Function, MatchCase, CallArg, CtorArg, NamedExpr,
         NamedType, VariantField, CtorPatternField, RecordPatField,
         VariantDef, EnumDef, RecordDef, ExceptionDef, ImportDef,
         FunctionSig, Port, GlobalLet, TopLevel, Program } from nxc/ast.nx
import { RenameEntry, rename, rename_add } from nxc/symtab.nx
import { default_alias, build_rename_map, apply_rename,
         collect_enum_defs, extract_imports,
         merge_rename_entries } from nxc/resolve.nx
import { reverse } from stdlib/list.nx
import { from_i64 } from stdlib/string.nx

// ─── HIR Types ───────────────────────────────────────────────────────────────

pub type HirParam = HirParam(name: string, label: string, typ: TypeExpr)

pub type HirPortMethod = HirPortMethod(name: string)

pub type HirPort = HirPort(name: string, methods: [HirPortMethod])

pub type HirExternal = HirExternal(
  name: string,
  wasm_module: string,
  wasm_name: string,
  params: [HirParam],
  ret_type: TypeExpr,
  throw_row: TypeExpr
)

pub type HirExpr =
  HirLiteral(lit: Literal)
  | HirVariable(name: string, sigil: Sigil)
  | HirBinaryOp(left: HirExpr, op: BinaryOp, right: HirExpr)
  | HirBorrow(name: string, sigil: Sigil)
  | HirCall(func: string, args: [HirCallArg])
  | HirConstructor(variant: string, args: [HirExpr])
  | HirRecord(fields: [HirNamedExpr])
  | HirArray(elems: [HirExpr])
  | HirIndex(target: HirExpr, index: HirExpr)
  | HirFieldAccess(target: HirExpr, field: string)
  | HirIf(cond: HirExpr, then_branch: [HirStmt], else_branch: Option<[HirStmt]>)
  | HirMatch(target: HirExpr, cases: [HirMatchCase])
  | HirWhile(cond: HirExpr, body: [HirStmt])
  | HirFor(var: string, start: HirExpr, end_expr: HirExpr, body: [HirStmt])
  | HirLambda(params: [HirParam], ret_type: TypeExpr, body: [HirStmt])
  | HirRaise(expr: HirExpr)
  | HirExternal_(symbol: string, arg_names: [string], typ: TypeExpr)
  | HirHandler(functions: [HirFunction])

pub type HirCallArg = HirCallArg(label: string, value: HirExpr)

pub type HirNamedExpr = HirNamedExpr(name: string, value: HirExpr)

pub type HirStmt =
  HirStmtLet(name: string, typ: Option<TypeExpr>, value: HirExpr)
  | HirStmtExpr(expr: HirExpr)
  | HirStmtReturn(expr: HirExpr)
  | HirStmtAssign(target: HirExpr, value: HirExpr)
  | HirStmtConc(tasks: [HirFunction])
  | HirStmtTry(body: [HirStmt], catch_param: string, catch_body: [HirStmt])
  | HirStmtInject(handlers: [string], body: [HirStmt])

pub type HirMatchCase = HirMatchCase(pattern: HirPattern, body: [HirStmt])

pub type HirPattern =
  HirPatLiteral(lit: Literal)
  | HirPatVariable(name: string, sigil: Sigil)
  | HirPatConstructor(variant: string, fields: [HirPatternField])
  | HirPatRecord(fields: [HirRecordPatField], is_partial: bool)
  | HirPatWildcard

pub type HirPatternField = HirPatternField(name: Option<string>, pattern: HirPattern)

pub type HirRecordPatField = HirRecordPatField(name: string, pattern: HirPattern)

pub type HirFunction = HirFunction(
  name: string,
  params: [HirParam],
  ret_type: TypeExpr,
  body: [HirStmt],
  span: Span
)

pub type HirHandlerBinding = HirHandlerBinding(
  port_name: string,
  functions: [HirFunction]
)

pub type HirProgram = HirProgram(
  ports: [HirPort],
  functions: [HirFunction],
  externals: [HirExternal],
  handler_bindings: [HirHandlerBindingEntry],
  enum_defs: [EnumDef]
)

/// Named entry for handler bindings (since we don't have HashMap in Nexus).
pub type HirHandlerBindingEntry = HirHandlerBindingEntry(
  name: string,
  binding: HirHandlerBinding
)

// ─── AST → HIR Conversion ───────────────────────────────────────────────────

/// Convert an AST expression to HIR, applying rename entries.
pub let convert_expr = fn (expr: SpannedExpr, entries: [RenameEntry]) -> HirExpr do
  match expr do case SpannedExpr(node: node, span: _) ->
    return convert_expr_node(node: node, entries: entries)
  end
end

let convert_expr_node = fn (node: Expr, entries: [RenameEntry]) -> HirExpr do
  match node do
    case ExprLiteral(lit: lit) -> return HirLiteral(lit: lit)
    case ExprVariable(name: name, sigil: sig) ->
      return HirVariable(name: rename(name: name, entries: entries), sigil: sig)
    case ExprBinaryOp(left: l, op: op, right: r) ->
      return HirBinaryOp(
        left: convert_expr(expr: l, entries: entries),
        op: op,
        right: convert_expr(expr: r, entries: entries)
      )
    case ExprBorrow(name: name, sigil: sig) ->
      return HirBorrow(name: rename(name: name, entries: entries), sigil: sig)
    case ExprCall(func: f, args: args) ->
      return HirCall(
        func: rename(name: f, entries: entries),
        args: convert_call_args(args: args, entries: entries)
      )
    case ExprConstructor(name: v, args: args) ->
      return HirConstructor(
        variant: rename(name: v, entries: entries),
        args: convert_ctor_args(args: args, entries: entries)
      )
    case ExprRecord(fields: fs) ->
      return HirRecord(fields: convert_named_exprs(exprs: fs, entries: entries))
    case ExprArray(elements: es) ->
      return HirArray(elems: convert_expr_list(exprs: es, entries: entries))
    case ExprIndex(target: t, index: i) ->
      return HirIndex(
        target: convert_expr(expr: t, entries: entries),
        index: convert_expr(expr: i, entries: entries)
      )
    case ExprFieldAccess(target: t, field: f) ->
      return HirFieldAccess(target: convert_expr(expr: t, entries: entries), field: f)
    case ExprIf(cond: c, then_branch: tb, else_branch: eb) ->
      let hir_else = match eb do
        case Nil -> None
        case Cons(v: _, rest: _) -> Some(val: convert_stmts(stmts: eb, entries: entries))
      end
      return HirIf(
        cond: convert_expr(expr: c, entries: entries),
        then_branch: convert_stmts(stmts: tb, entries: entries),
        else_branch: hir_else
      )
    case ExprMatch(target: t, cases: cs) ->
      return HirMatch(
        target: convert_expr(expr: t, entries: entries),
        cases: convert_match_cases(cases: cs, entries: entries)
      )
    case ExprWhile(cond: c, body: b) ->
      return HirWhile(
        cond: convert_expr(expr: c, entries: entries),
        body: convert_stmts(stmts: b, entries: entries)
      )
    case ExprFor(var: v, start: s, end_expr: e, body: b) ->
      return HirFor(
        var: v,
        start: convert_expr(expr: s, entries: entries),
        end_expr: convert_expr(expr: e, entries: entries),
        body: convert_stmts(stmts: b, entries: entries)
      )
    case ExprLambda(type_params: _, params: ps, ret_type: rt, requires: _, throw_row: _, body: b) ->
      return HirLambda(
        params: convert_params(params: ps),
        ret_type: rt,
        body: convert_stmts(stmts: b, entries: entries)
      )
    case ExprRaise(value: e) ->
      return HirRaise(expr: convert_expr(expr: e, entries: entries))
    case ExprExternal(symbol: sym, arg_names: names, typ: t) ->
      return HirExternal_(symbol: sym, arg_names: names, typ: t)
    case ExprHandler(coeffect_name: _, requires: _, functions: fs) ->
      return HirHandler(functions: convert_functions(funcs: fs, entries: entries))
    case ExprList(elements: es) ->
      // Desugar list literal to Cons/Nil chain
      return desugar_list(elems: es, entries: entries)
  end
end

/// Desugar [a, b, c] → Cons(a, Cons(b, Cons(c, Nil)))
let desugar_list = fn (elems: [SpannedExpr], entries: [RenameEntry]) -> HirExpr do
  match elems do
    case Nil ->
      return HirConstructor(variant: "Nil", args: Nil)
    case Cons(v: e, rest: rest) ->
      let head = convert_expr(expr: e, entries: entries)
      let tail = desugar_list(elems: rest, entries: entries)
      return HirConstructor(variant: "Cons",
        args: Cons(v: head, rest: Cons(v: tail, rest: Nil)))
  end
end

let convert_call_args = fn (args: [CallArg], entries: [RenameEntry]) -> [HirCallArg] do
  match args do
    case Nil -> return Nil
    case Cons(v: arg, rest: rest) ->
      match arg do case CallArg(name: l, value: v) ->
        return Cons(
          v: HirCallArg(label: l, value: convert_expr(expr: v, entries: entries)),
          rest: convert_call_args(args: rest, entries: entries)
        )
      end
  end
end

let convert_ctor_args = fn (args: [CtorArg], entries: [RenameEntry]) -> [HirExpr] do
  match args do
    case Nil -> return Nil
    case Cons(v: arg, rest: rest) ->
      match arg do case CtorArg(name: _, value: v) ->
        return Cons(
          v: convert_expr(expr: v, entries: entries),
          rest: convert_ctor_args(args: rest, entries: entries)
        )
      end
  end
end

let convert_named_exprs = fn (exprs: [NamedExpr], entries: [RenameEntry]) -> [HirNamedExpr] do
  match exprs do
    case Nil -> return Nil
    case Cons(v: ne, rest: rest) ->
      match ne do case NamedExpr(name: n, value: v) ->
        return Cons(
          v: HirNamedExpr(name: n, value: convert_expr(expr: v, entries: entries)),
          rest: convert_named_exprs(exprs: rest, entries: entries)
        )
      end
  end
end

let convert_expr_list = fn (exprs: [SpannedExpr], entries: [RenameEntry]) -> [HirExpr] do
  match exprs do
    case Nil -> return Nil
    case Cons(v: e, rest: rest) ->
      return Cons(
        v: convert_expr(expr: e, entries: entries),
        rest: convert_expr_list(exprs: rest, entries: entries)
      )
  end
end

/// Convert AST statements to HIR statements.
pub let convert_stmts = fn (stmts: [SpannedStmt], entries: [RenameEntry]) -> [HirStmt] do
  match stmts do
    case Nil -> return Nil
    case Cons(v: s, rest: rest) ->
      match s do case SpannedStmt(node: node, span: _) ->
        let hir_stmt = convert_stmt_node(node: node, entries: entries)
        return Cons(v: hir_stmt, rest: convert_stmts(stmts: rest, entries: entries))
      end
  end
end

let convert_stmt_node = fn (node: Stmt, entries: [RenameEntry]) -> HirStmt do
  match node do
    case StmtLet(name: n, sigil: _, typ: t, value: v) ->
      return HirStmtLet(name: n, typ: t, value: convert_expr(expr: v, entries: entries))
    case StmtExpr(expr: e) ->
      return HirStmtExpr(expr: convert_expr(expr: e, entries: entries))
    case StmtReturn(value: e) ->
      return HirStmtReturn(expr: convert_expr(expr: e, entries: entries))
    case StmtAssign(target: t, value: v) ->
      return HirStmtAssign(
        target: HirVariable(name: rename(name: t, entries: entries), sigil: SigilMutable),
        value: convert_expr(expr: v, entries: entries)
      )
    case StmtConc(tasks: tasks) ->
      return HirStmtConc(tasks: convert_functions(funcs: tasks, entries: entries))
    case StmtTry(body: b, catch_param: p, catch_body: cb) ->
      return HirStmtTry(
        body: convert_stmts(stmts: b, entries: entries),
        catch_param: p,
        catch_body: convert_stmts(stmts: cb, entries: entries)
      )
    case StmtInject(handlers: hs, body: b) ->
      let handler_names = extract_handler_names(exprs: hs)
      let qualified_handlers = rename_strings(names: handler_names, entries: entries)
      return HirStmtInject(
        handlers: qualified_handlers,
        body: convert_stmts(stmts: b, entries: entries)
      )
  end
end

let rename_strings = fn (names: [string], entries: [RenameEntry]) -> [string] do
  match names do
    case Nil -> return Nil
    case Cons(v: n, rest: rest) ->
      return Cons(v: rename(name: n, entries: entries),
                  rest: rename_strings(names: rest, entries: entries))
  end
end

/// Extract handler variable names from inject handler expressions.
let extract_handler_names = fn (exprs: [SpannedExpr]) -> [string] do
  match exprs do
    case Nil -> return Nil
    case Cons(v: se, rest: rest) ->
      match se do case SpannedExpr(node: node, span: _) ->
        match node do
          case ExprVariable(name: name, sigil: _) ->
            return Cons(v: name, rest: extract_handler_names(exprs: rest))
          case _ ->
            return extract_handler_names(exprs: rest)
        end
      end
  end
end

/// Convert match cases to HIR.
let convert_match_cases = fn (cases: [MatchCase], entries: [RenameEntry]) -> [HirMatchCase] do
  match cases do
    case Nil -> return Nil
    case Cons(v: c, rest: rest) ->
      match c do case MatchCase(pattern: p, body: b) ->
        return Cons(
          v: HirMatchCase(
            pattern: convert_pattern(pat: p, entries: entries),
            body: convert_stmts(stmts: b, entries: entries)
          ),
          rest: convert_match_cases(cases: rest, entries: entries)
        )
      end
  end
end

/// Convert a pattern to HIR pattern.
pub let convert_pattern = fn (pat: SpannedPattern, entries: [RenameEntry]) -> HirPattern do
  match pat do case SpannedPattern(node: node, span: _) ->
    return convert_pattern_node(node: node, entries: entries)
  end
end

let convert_pattern_node = fn (node: Pattern, entries: [RenameEntry]) -> HirPattern do
  match node do
    case PatLiteral(lit: lit) -> return HirPatLiteral(lit: lit)
    case PatVariable(name: name, sigil: sig) ->
      return HirPatVariable(name: name, sigil: sig)
    case PatConstructor(name: v, fields: fs) ->
      return HirPatConstructor(
        variant: rename(name: v, entries: entries),
        fields: convert_pattern_fields(fs: fs, entries: entries)
      )
    case PatRecord(fields: fs, has_wildcard: p) ->
      return HirPatRecord(
        fields: convert_record_pat_fields(fs: fs, entries: entries),
        is_partial: p
      )
    case PatWildcard -> return HirPatWildcard
  end
end

let convert_pattern_fields = fn (fs: [CtorPatternField], entries: [RenameEntry]) -> [HirPatternField] do
  match fs do
    case Nil -> return Nil
    case Cons(v: f, rest: rest) ->
      match f do case CtorPatternField(name: n, pattern: p) ->
        return Cons(
          v: HirPatternField(name: n, pattern: convert_pattern(pat: p, entries: entries)),
          rest: convert_pattern_fields(fs: rest, entries: entries)
        )
      end
  end
end

let convert_record_pat_fields = fn (fs: [RecordPatField], entries: [RenameEntry]) -> [HirRecordPatField] do
  match fs do
    case Nil -> return Nil
    case Cons(v: f, rest: rest) ->
      match f do case RecordPatField(name: n, pattern: p) ->
        return Cons(
          v: HirRecordPatField(name: n, pattern: convert_pattern(pat: p, entries: entries)),
          rest: convert_record_pat_fields(fs: rest, entries: entries)
        )
      end
  end
end

/// Convert AST params to HIR params.
let convert_params = fn (params: [Param]) -> [HirParam] do
  match params do
    case Nil -> return Nil
    case Cons(v: p, rest: rest) ->
      match p do case Param(name: n, sigil: _, typ: t) ->
        return Cons(
          v: HirParam(name: n, label: n, typ: t),
          rest: convert_params(params: rest)
        )
      end
  end
end

/// Convert AST functions to HIR functions.
let convert_functions = fn (funcs: [Function], entries: [RenameEntry]) -> [HirFunction] do
  match funcs do
    case Nil -> return Nil
    case Cons(v: f, rest: rest) ->
      match f do case Function(name: n, is_public: _, type_params: _, params: ps, ret_type: rt, requires: _, throw_row: _, body: b) ->
        return Cons(
          v: HirFunction(
            name: n,
            params: convert_params(params: ps),
            ret_type: rt,
            body: convert_stmts(stmts: b, entries: entries),
            span: Span(offset: 0, line: 0, col: 0)
          ),
          rest: convert_functions(funcs: rest, entries: entries)
        )
      end
  end
end

// ─── Top-level definition processing ─────────────────────────────────────────

/// Process result for accumulating HIR definitions.
pub type ConstantEntry = ConstantEntry(name: string, lit: Literal)

pub type HirAccum = HirAccum(
  ports: [HirPort],
  functions: [HirFunction],
  externals: [HirExternal],
  handler_bindings: [HirHandlerBindingEntry],
  enum_defs: [EnumDef],
  wasm_module: Option<string>,
  constants: [ConstantEntry]
)

/// Create an empty HirAccum.
pub let empty_accum = fn () -> HirAccum do
  return HirAccum(
    ports: Nil, functions: Nil, externals: Nil,
    handler_bindings: Nil, enum_defs: Nil, wasm_module: None,
    constants: Nil
  )
end

/// Process a list of top-level definitions into HIR components.
pub let process_defs = fn (defs: [SpannedTopLevel], entries: [RenameEntry], accum: HirAccum) -> HirAccum do
  match defs do
    case Nil -> return accum
    case Cons(v: stl, rest: rest) ->
      match stl do case SpannedTopLevel(node: node, span: sp) ->
        let new_accum = process_top_level(node: node, span: sp, entries: entries, accum: accum)
        return process_defs(defs: rest, entries: entries, accum: new_accum)
      end
  end
end

let process_top_level = fn (node: TopLevel, span: Span, entries: [RenameEntry], accum: HirAccum) -> HirAccum do
  match accum do case HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, constants: csts) ->
    match node do
      case TLImport(def: imp) ->
        match imp do case ImportDef(path: path, alias: _, items: _, is_external: is_ext) ->
          if is_ext then
            return HirAccum(ports: ps, functions: fs, externals: exts,
              handler_bindings: hbs, enum_defs: eds, wasm_module: Some(val: path),
              constants: csts)
          else
            return accum
          end
        end
      case TLLet(def: gl) ->
        match gl do case GlobalLet(name: name, is_public: _, typ: _, value: val) ->
          let qname = rename(name: name, entries: entries)
          let hir_val = convert_expr(expr: val, entries: entries)
          match hir_val do
            case HirHandler(functions: handler_funcs) ->
              let binding = synthesize_handler(
                binding_name: qname, functions: handler_funcs)
              return HirAccum(ports: ps, functions: fs, externals: exts,
                handler_bindings: Cons(v: binding, rest: hbs),
                enum_defs: eds, wasm_module: wmod, constants: csts)
            case HirLambda(params: lps, ret_type: rt, body: body) ->
              let func = HirFunction(name: qname, params: lps, ret_type: rt, body: body, span: span)
              return HirAccum(ports: ps, functions: Cons(v: func, rest: fs),
                externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod,
                constants: csts)
            case HirExternal_(symbol: sym, arg_names: anames, typ: t) ->
              match wmod do
                case Some(val: wm) ->
                  let ext = make_hir_external(name: qname, wasm_module: wm,
                    wasm_name: sym, arg_names: anames, typ: t)
                  return HirAccum(ports: ps, functions: fs,
                    externals: Cons(v: ext, rest: exts),
                    handler_bindings: hbs, enum_defs: eds, wasm_module: wmod,
                    constants: csts)
                case None ->
                  return accum
              end
            case HirLiteral(lit: lit) ->
              // Literal constant — store for inlining, don't create a function
              return HirAccum(ports: ps, functions: fs, externals: exts,
                handler_bindings: hbs, enum_defs: eds, wasm_module: wmod,
                constants: Cons(v: ConstantEntry(name: qname, lit: lit), rest: csts))
            case _ ->
              // Non-literal non-function binding — wrap as zero-arg function
              let func = HirFunction(
                name: qname, params: Nil, ret_type: TyUnit,
                body: Cons(v: HirStmtReturn(expr: hir_val), rest: Nil),
                span: span)
              return HirAccum(ports: ps, functions: Cons(v: func, rest: fs),
                externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod,
                constants: csts)
          end
        end
      case TLPort(def: p) ->
        match p do case Port(name: pname, is_public: _, functions: sigs) ->
          let qname = rename(name: pname, entries: entries)
          let hir_port = HirPort(name: qname, methods: convert_port_sigs(sigs: sigs))
          return HirAccum(ports: Cons(v: hir_port, rest: ps), functions: fs,
            externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod,
            constants: csts)
        end
      case TLEnum(def: ed) ->
        return HirAccum(ports: ps, functions: fs, externals: exts,
          handler_bindings: hbs,
          enum_defs: Cons(v: ed, rest: eds), wasm_module: wmod, constants: csts)
      case TLTypeDef(def: _) -> return accum
      case TLException(def: _) -> return accum
    end
  end
end

/// Build HirExternal from an external declaration's type arrow.
let make_hir_external = fn (name: string, wasm_module: string, wasm_name: string, arg_names: [string], typ: TypeExpr) -> HirExternal do
  match typ do
    case TyArrow(params: params, ret: ret, requires: _, throw_row: tw) ->
      return HirExternal(name: name, wasm_module: wasm_module, wasm_name: wasm_name,
        params: named_types_to_hir_params(nts: params),
        ret_type: ret, throw_row: tw)
    case _ ->
      // Non-arrow external, shouldn't happen, fallback
      return HirExternal(name: name, wasm_module: wasm_module, wasm_name: wasm_name,
        params: Nil, ret_type: typ, throw_row: TyUnit)
  end
end

let named_types_to_hir_params = fn (nts: [NamedType]) -> [HirParam] do
  match nts do
    case Nil -> return Nil
    case Cons(v: nt, rest: rest) ->
      match nt do case NamedType(name: n, typ: t) ->
        return Cons(
          v: HirParam(name: n, label: n, typ: t),
          rest: named_types_to_hir_params(nts: rest))
      end
  end
end

let convert_port_sigs = fn (sigs: [FunctionSig]) -> [HirPortMethod] do
  match sigs do
    case Nil -> return Nil
    case Cons(v: sig, rest: rest) ->
      match sig do case FunctionSig(name: n, params: _, ret_type: _, requires: _, throw_row: _) ->
        return Cons(v: HirPortMethod(name: n), rest: convert_port_sigs(sigs: rest))
      end
  end
end

/// Synthesize handler binding: create named function entries for each method.
let synthesize_handler = fn (binding_name: string, functions: [HirFunction]) -> HirHandlerBindingEntry do
  let synth_funcs = synthesize_handler_funcs(binding_name: binding_name, functions: functions)
  // Extract port name from first function's original name (or use binding_name)
  return HirHandlerBindingEntry(
    name: binding_name,
    binding: HirHandlerBinding(port_name: binding_name, functions: synth_funcs)
  )
end

let synthesize_handler_funcs = fn (binding_name: string, functions: [HirFunction]) -> [HirFunction] do
  match functions do
    case Nil -> return Nil
    case Cons(v: f, rest: rest) ->
      match f do case HirFunction(name: n, params: ps, ret_type: rt, body: b, span: sp) ->
        let synth_name = "__handler_" ++ binding_name ++ "_" ++ n
        return Cons(
          v: HirFunction(name: synth_name, params: ps, ret_type: rt, body: b, span: sp),
          rest: synthesize_handler_funcs(binding_name: binding_name, functions: rest)
        )
      end
  end
end

// ─── Reachability Analysis ───────────────────────────────────────────────────

/// Collect all function names called from a list of HIR statements.
pub let collect_calls_stmts = fn (stmts: [HirStmt]) -> [string] do
  match stmts do
    case Nil -> return Nil
    case Cons(v: s, rest: rest) ->
      let calls = collect_calls_stmt(stmt: s)
      return concat_str_lists(a: calls, b: collect_calls_stmts(stmts: rest))
  end
end

let collect_calls_stmt = fn (stmt: HirStmt) -> [string] do
  match stmt do
    case HirStmtLet(name: _, typ: _, value: v) -> return collect_calls_expr(expr: v)
    case HirStmtExpr(expr: e) -> return collect_calls_expr(expr: e)
    case HirStmtReturn(expr: e) -> return collect_calls_expr(expr: e)
    case HirStmtAssign(target: t, value: v) ->
      return concat_str_lists(a: collect_calls_expr(expr: t), b: collect_calls_expr(expr: v))
    case HirStmtConc(tasks: ts) -> return collect_calls_functions(funcs: ts)
    case HirStmtTry(body: b, catch_param: _, catch_body: cb) ->
      return concat_str_lists(a: collect_calls_stmts(stmts: b), b: collect_calls_stmts(stmts: cb))
    case HirStmtInject(handlers: hs, body: b) ->
      return concat_str_lists(a: hs, b: collect_calls_stmts(stmts: b))
  end
end

let collect_calls_expr = fn (expr: HirExpr) -> [string] do
  match expr do
    case HirLiteral(lit: _) -> return Nil
    case HirVariable(name: _, sigil: _) -> return Nil
    case HirBinaryOp(left: l, op: _, right: r) ->
      return concat_str_lists(a: collect_calls_expr(expr: l), b: collect_calls_expr(expr: r))
    case HirBorrow(name: _, sigil: _) -> return Nil
    case HirCall(func: f, args: args) ->
      return Cons(v: f, rest: collect_calls_args(args: args))
    case HirConstructor(variant: _, args: args) -> return collect_calls_expr_list(exprs: args)
    case HirRecord(fields: fs) -> return collect_calls_named_exprs(exprs: fs)
    case HirArray(elems: es) -> return collect_calls_expr_list(exprs: es)
    case HirIndex(target: t, index: i) ->
      return concat_str_lists(a: collect_calls_expr(expr: t), b: collect_calls_expr(expr: i))
    case HirFieldAccess(target: t, field: _) -> return collect_calls_expr(expr: t)
    case HirIf(cond: c, then_branch: tb, else_branch: eb) ->
      let base = concat_str_lists(a: collect_calls_expr(expr: c), b: collect_calls_stmts(stmts: tb))
      match eb do
        case Some(val: stmts) -> return concat_str_lists(a: base, b: collect_calls_stmts(stmts: stmts))
        case None -> return base
      end
    case HirMatch(target: t, cases: cs) ->
      return concat_str_lists(a: collect_calls_expr(expr: t), b: collect_calls_cases(cases: cs))
    case HirWhile(cond: c, body: b) ->
      return concat_str_lists(a: collect_calls_expr(expr: c), b: collect_calls_stmts(stmts: b))
    case HirFor(var: _, start: s, end_expr: e, body: b) ->
      return concat_str_lists(
        a: collect_calls_expr(expr: s),
        b: concat_str_lists(a: collect_calls_expr(expr: e), b: collect_calls_stmts(stmts: b))
      )
    case HirLambda(params: _, ret_type: _, body: b) -> return collect_calls_stmts(stmts: b)
    case HirRaise(expr: e) -> return collect_calls_expr(expr: e)
    case HirExternal_(symbol: _, arg_names: _, typ: _) -> return Nil
    case HirHandler(functions: fs) -> return collect_calls_functions(funcs: fs)
  end
end

let collect_calls_args = fn (args: [HirCallArg]) -> [string] do
  match args do
    case Nil -> return Nil
    case Cons(v: arg, rest: rest) ->
      match arg do case HirCallArg(label: _, value: v) ->
        return concat_str_lists(a: collect_calls_expr(expr: v), b: collect_calls_args(args: rest))
      end
  end
end

let collect_calls_named_exprs = fn (exprs: [HirNamedExpr]) -> [string] do
  match exprs do
    case Nil -> return Nil
    case Cons(v: ne, rest: rest) ->
      match ne do case HirNamedExpr(name: _, value: v) ->
        return concat_str_lists(a: collect_calls_expr(expr: v), b: collect_calls_named_exprs(exprs: rest))
      end
  end
end

let collect_calls_expr_list = fn (exprs: [HirExpr]) -> [string] do
  match exprs do
    case Nil -> return Nil
    case Cons(v: e, rest: rest) ->
      return concat_str_lists(a: collect_calls_expr(expr: e), b: collect_calls_expr_list(exprs: rest))
  end
end

let collect_calls_cases = fn (cases: [HirMatchCase]) -> [string] do
  match cases do
    case Nil -> return Nil
    case Cons(v: c, rest: rest) ->
      match c do case HirMatchCase(pattern: _, body: b) ->
        return concat_str_lists(a: collect_calls_stmts(stmts: b), b: collect_calls_cases(cases: rest))
      end
  end
end

let collect_calls_functions = fn (funcs: [HirFunction]) -> [string] do
  match funcs do
    case Nil -> return Nil
    case Cons(v: f, rest: rest) ->
      match f do case HirFunction(name: _, params: _, ret_type: _, body: b, span: _) ->
        return concat_str_lists(a: collect_calls_stmts(stmts: b), b: collect_calls_functions(funcs: rest))
      end
  end
end

/// Worklist reachability: starting from "main", collect all transitively called functions.
pub let collect_reachable = fn (functions: [HirFunction], handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  let worklist = Cons(v: "main", rest: Nil)
  return reachable_go(worklist: worklist, visited: Nil, functions: functions, handler_bindings: handler_bindings)
end

let reachable_go = fn (worklist: [string], visited: [string], functions: [HirFunction], handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  match worklist do
    case Nil -> return visited
    case Cons(v: name, rest: rest) ->
      if str_in_list(s: name, xs: visited) then
        return reachable_go(worklist: rest, visited: visited, functions: functions, handler_bindings: handler_bindings)
      else
        let new_visited = Cons(v: name, rest: visited)
        // Find calls in this function's body
        let calls = find_calls_for_name(name: name, functions: functions, handler_bindings: handler_bindings)
        let new_worklist = concat_str_lists(a: calls, b: rest)
        return reachable_go(worklist: new_worklist, visited: new_visited, functions: functions, handler_bindings: handler_bindings)
      end
  end
end

let find_calls_for_name = fn (name: string, functions: [HirFunction], handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  // Check regular functions
  let func = find_function(name: name, functions: functions)
  match func do
    case Some(val: f) ->
      match f do case HirFunction(name: _, params: _, ret_type: _, body: b, span: _) ->
        return collect_calls_stmts(stmts: b)
      end
    case None ->
      // Check handler bindings
      return find_calls_in_handlers(name: name, bindings: handler_bindings)
  end
end

let find_function = fn (name: string, functions: [HirFunction]) -> Option<HirFunction> do
  match functions do
    case Nil -> return None
    case Cons(v: f, rest: rest) ->
      match f do case HirFunction(name: n, params: _, ret_type: _, body: _, span: _) ->
        if n == name then return Some(val: f)
        else return find_function(name: name, functions: rest)
        end
      end
  end
end

let find_calls_in_handlers = fn (name: string, bindings: [HirHandlerBindingEntry]) -> [string] do
  match bindings do
    case Nil -> return Nil
    case Cons(v: entry, rest: rest) ->
      match entry do case HirHandlerBindingEntry(name: _, binding: b) ->
        match b do case HirHandlerBinding(port_name: _, functions: fs) ->
          let found = find_function(name: name, functions: fs)
          match found do
            case Some(val: f) ->
              match f do case HirFunction(name: _, params: _, ret_type: _, body: body, span: _) ->
                return collect_calls_stmts(stmts: body)
              end
            case None -> return find_calls_in_handlers(name: name, bindings: rest)
          end
        end
      end
  end
end

/// Filter functions to only reachable ones.
pub let filter_reachable_functions = fn (functions: [HirFunction], reachable: [string]) -> [HirFunction] do
  match functions do
    case Nil -> return Nil
    case Cons(v: f, rest: rest) ->
      match f do case HirFunction(name: n, params: _, ret_type: _, body: _, span: _) ->
        if str_in_list(s: n, xs: reachable) then
          return Cons(v: f, rest: filter_reachable_functions(functions: rest, reachable: reachable))
        else
          return filter_reachable_functions(functions: rest, reachable: reachable)
        end
      end
  end
end

/// Filter externals to only reachable ones.
pub let filter_reachable_externals = fn (externals: [HirExternal], reachable: [string]) -> [HirExternal] do
  match externals do
    case Nil -> return Nil
    case Cons(v: ext, rest: rest) ->
      match ext do case HirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) ->
        if str_in_list(s: n, xs: reachable) then
          return Cons(v: ext, rest: filter_reachable_externals(externals: rest, reachable: reachable))
        else
          return filter_reachable_externals(externals: rest, reachable: reachable)
        end
      end
  end
end

/// Assemble a HirProgram from an accumulator with reachability filtering.
pub let accum_to_program = fn (accum: HirAccum) -> HirProgram do
  match accum do case HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: _, constants: csts) ->
    // Inline top-level constants into function bodies
    let inlined_funcs = inline_constants_in_functions(functions: fs, constants: csts)
    let reachable = collect_reachable(functions: inlined_funcs, handler_bindings: hbs)
    let filtered_funcs = filter_reachable_functions(functions: inlined_funcs, reachable: reachable)
    let filtered_exts = filter_reachable_externals(externals: exts, reachable: reachable)
    return HirProgram(
      ports: ps,
      functions: filtered_funcs,
      externals: filtered_exts,
      handler_bindings: hbs,
      enum_defs: eds
    )
  end
end

// ─── String list helpers ─────────────────────────────────────────────────────

let concat_str_lists = fn (a: [string], b: [string]) -> [string] do
  match a do
    case Nil -> return b
    case Cons(v: x, rest: rest) ->
      return Cons(v: x, rest: concat_str_lists(a: rest, b: b))
  end
end

let str_in_list = fn (s: string, xs: [string]) -> bool do
  match xs do
    case Nil -> return false
    case Cons(v: x, rest: rest) ->
      if x == s then return true
      else return str_in_list(s: s, xs: rest)
      end
  end
end

// ─── Constant Inlining ────────────────────────────────────────────────────

let lookup_constant = fn (name: string, constants: [ConstantEntry]) -> Option<Literal> do
  match constants do
    case Nil -> return None
    case Cons(v: c, rest: rest) ->
      match c do case ConstantEntry(name: n, lit: l) ->
        if n == name then return Some(val: l)
        else return lookup_constant(name: name, constants: rest)
        end
      end
  end
end

let inline_constants_in_functions = fn (functions: [HirFunction], constants: [ConstantEntry]) -> [HirFunction] do
  match functions do
    case Nil -> return Nil
    case Cons(v: f, rest: rest) ->
      match f do case HirFunction(name: n, params: ps, ret_type: rt, body: b, span: sp) ->
        let new_body = inline_constants_stmts(stmts: b, constants: constants)
        return Cons(
          v: HirFunction(name: n, params: ps, ret_type: rt, body: new_body, span: sp),
          rest: inline_constants_in_functions(functions: rest, constants: constants))
      end
  end
end

let inline_constants_stmts = fn (stmts: [HirStmt], constants: [ConstantEntry]) -> [HirStmt] do
  match stmts do
    case Nil -> return Nil
    case Cons(v: s, rest: rest) ->
      return Cons(v: inline_constants_stmt(stmt: s, constants: constants),
        rest: inline_constants_stmts(stmts: rest, constants: constants))
  end
end

let inline_constants_stmt = fn (stmt: HirStmt, constants: [ConstantEntry]) -> HirStmt do
  match stmt do
    case HirStmtLet(name: n, typ: t, value: v) ->
      return HirStmtLet(name: n, typ: t, value: inline_constants_expr(expr: v, constants: constants))
    case HirStmtExpr(expr: e) ->
      return HirStmtExpr(expr: inline_constants_expr(expr: e, constants: constants))
    case HirStmtReturn(expr: e) ->
      return HirStmtReturn(expr: inline_constants_expr(expr: e, constants: constants))
    case HirStmtAssign(target: t, value: v) ->
      return HirStmtAssign(
        target: inline_constants_expr(expr: t, constants: constants),
        value: inline_constants_expr(expr: v, constants: constants))
    case HirStmtConc(tasks: _) -> return stmt
    case HirStmtTry(body: b, catch_param: cp, catch_body: cb) ->
      return HirStmtTry(
        body: inline_constants_stmts(stmts: b, constants: constants),
        catch_param: cp,
        catch_body: inline_constants_stmts(stmts: cb, constants: constants))
    case HirStmtInject(handlers: _, body: b) ->
      return stmt
  end
end

let inline_constants_expr = fn (expr: HirExpr, constants: [ConstantEntry]) -> HirExpr do
  match expr do
    case HirVariable(name: n, sigil: _) ->
      match lookup_constant(name: n, constants: constants) do
        case Some(val: lit) -> return HirLiteral(lit: lit)
        case None -> return expr
      end
    case HirLiteral(lit: _) -> return expr
    case HirBinaryOp(left: l, op: op, right: r) ->
      return HirBinaryOp(
        left: inline_constants_expr(expr: l, constants: constants),
        op: op,
        right: inline_constants_expr(expr: r, constants: constants))
    case HirCall(func: f, args: args) ->
      return HirCall(func: f,
        args: inline_constants_call_args(args: args, constants: constants))
    case HirConstructor(variant: v, args: args) ->
      match args do
        case Nil ->
          // Zero-arg constructor may actually be a top-level constant reference
          match lookup_constant(name: v, constants: constants) do
            case Some(val: lit) -> return HirLiteral(lit: lit)
            case None -> return HirConstructor(variant: v, args: Nil)
          end
        case Cons(v: _, rest: _) ->
          return HirConstructor(variant: v,
            args: inline_constants_expr_list(exprs: args, constants: constants))
      end
    case HirRecord(fields: fs) ->
      return HirRecord(fields: inline_constants_named_exprs(exprs: fs, constants: constants))
    case HirArray(elems: es) ->
      return HirArray(elems: inline_constants_expr_list(exprs: es, constants: constants))
    case HirIndex(target: t, index: i) ->
      return HirIndex(
        target: inline_constants_expr(expr: t, constants: constants),
        index: inline_constants_expr(expr: i, constants: constants))
    case HirFieldAccess(target: t, field: f) ->
      return HirFieldAccess(target: inline_constants_expr(expr: t, constants: constants), field: f)
    case HirIf(cond: c, then_branch: tb, else_branch: eb) ->
      let new_eb = match eb do
        case Some(val: stmts) -> Some(val: inline_constants_stmts(stmts: stmts, constants: constants))
        case None -> None
      end
      return HirIf(
        cond: inline_constants_expr(expr: c, constants: constants),
        then_branch: inline_constants_stmts(stmts: tb, constants: constants),
        else_branch: new_eb)
    case HirMatch(target: t, cases: cs) ->
      return HirMatch(
        target: inline_constants_expr(expr: t, constants: constants),
        cases: inline_constants_match_cases(cases: cs, constants: constants))
    case HirWhile(cond: c, body: b) ->
      return HirWhile(
        cond: inline_constants_expr(expr: c, constants: constants),
        body: inline_constants_stmts(stmts: b, constants: constants))
    case HirFor(var: v, start: s, end_expr: e, body: b) ->
      return HirFor(var: v,
        start: inline_constants_expr(expr: s, constants: constants),
        end_expr: inline_constants_expr(expr: e, constants: constants),
        body: inline_constants_stmts(stmts: b, constants: constants))
    case HirLambda(params: ps, ret_type: rt, body: b) ->
      return HirLambda(params: ps, ret_type: rt,
        body: inline_constants_stmts(stmts: b, constants: constants))
    case HirRaise(expr: e) ->
      return HirRaise(expr: inline_constants_expr(expr: e, constants: constants))
    case HirBorrow(name: _, sigil: _) -> return expr
    case HirExternal_(symbol: _, arg_names: _, typ: _) -> return expr
    case HirHandler(functions: _) -> return expr
  end
end

let inline_constants_call_args = fn (args: [HirCallArg], constants: [ConstantEntry]) -> [HirCallArg] do
  match args do
    case Nil -> return Nil
    case Cons(v: a, rest: rest) ->
      match a do case HirCallArg(label: l, value: v) ->
        return Cons(
          v: HirCallArg(label: l, value: inline_constants_expr(expr: v, constants: constants)),
          rest: inline_constants_call_args(args: rest, constants: constants))
      end
  end
end

let inline_constants_expr_list = fn (exprs: [HirExpr], constants: [ConstantEntry]) -> [HirExpr] do
  match exprs do
    case Nil -> return Nil
    case Cons(v: e, rest: rest) ->
      return Cons(v: inline_constants_expr(expr: e, constants: constants),
        rest: inline_constants_expr_list(exprs: rest, constants: constants))
  end
end

let inline_constants_named_exprs = fn (exprs: [HirNamedExpr], constants: [ConstantEntry]) -> [HirNamedExpr] do
  match exprs do
    case Nil -> return Nil
    case Cons(v: ne, rest: rest) ->
      match ne do case HirNamedExpr(name: n, value: v) ->
        return Cons(
          v: HirNamedExpr(name: n, value: inline_constants_expr(expr: v, constants: constants)),
          rest: inline_constants_named_exprs(exprs: rest, constants: constants))
      end
  end
end

let inline_constants_match_cases = fn (cases: [HirMatchCase], constants: [ConstantEntry]) -> [HirMatchCase] do
  match cases do
    case Nil -> return Nil
    case Cons(v: c, rest: rest) ->
      match c do case HirMatchCase(pattern: p, body: b) ->
        return Cons(
          v: HirMatchCase(pattern: p,
            body: inline_constants_stmts(stmts: b, constants: constants)),
          rest: inline_constants_match_cases(cases: rest, constants: constants))
      end
  end
end
