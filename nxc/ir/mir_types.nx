/**
 * mir_types: MIR type definitions for the Nexus self-hosting compiler.
 *
 * Pure data types extracted from mir.nx. No logic, no helpers.
 */

import { Span } from "nxc/common/token.nx"
import { Sigil, BinaryOp, Literal, TypeExpr } from "nxc/common/ast.nx"

// ─── MIR Types ───────────────────────────────────────────────────────────────

export type MirParam = MirParam(label: string, name: string, typ: TypeExpr)

export type MirExternal = MirExternal(
  name: string,
  wasm_module: string,
  wasm_name: string,
  params: [MirParam],
  ret_type: TypeExpr,
  throw_row: TypeExpr
)

export type MirFunction = MirFunction(
  name: string,
  params: [MirParam],
  ret_type: TypeExpr,
  body: [MirStmt],
  span: Span
)

export type MirCallArg = MirCallArg(label: string, value: MirExpr)

export type MirExpr =
  MirLiteral(lit: Literal)
  | MirVariable(name: string)
  | MirBinaryOp(left: MirExpr, op: BinaryOp, right: MirExpr)
  | MirCall(func: string, args: [MirCallArg], ret_type: TypeExpr)
  | MirConstructor(name: string, args: [MirExpr])
  | MirRecord(fields: [MirNamedExpr])
  | MirArray(elems: [MirExpr])
  | MirIndex(target: MirExpr, index: MirExpr)
  | MirFieldAccess(target: MirExpr, field: string)
  | MirIf(cond: MirExpr, then_body: [MirStmt], else_body: Option<[MirStmt]>)
  | MirMatch(target: MirExpr, cases: [MirMatchCase])
  | MirWhile(cond: MirExpr, body: [MirStmt])
  | MirBorrow(name: string)
  | MirRaise(expr: MirExpr)
  | MirForce(expr: MirExpr)
  | MirMakeClosure(func_name: string, captures: [MirExpr])
  | MirCallClosure(closure: MirExpr, args: [MirCallArg], ret_type: TypeExpr)
  | MirEnvLoad(env_var: string, index: i64)

export type MirNamedExpr = MirNamedExpr(name: string, value: MirExpr)

export type MirStmt =
  MirStmtLet(name: string, typ: TypeExpr, expr: MirExpr)
  | MirStmtExpr(expr: MirExpr)
  | MirStmtReturn(expr: MirExpr)
  | MirStmtAssign(target: MirExpr, value: MirExpr)
  | MirStmtTry(body: [MirStmt], catch_param: string, catch_body: [MirStmt])

export type MirMatchCase = MirMatchCase(pattern: MirPattern, body: [MirStmt])

export type MirPattern =
  MirPatLiteral(lit: Literal)
  | MirPatVariable(name: string, sigil: Sigil)
  | MirPatConstructor(name: string, fields: [MirPatternField])
  | MirPatRecord(fields: [MirRecordPatField], is_partial: bool)
  | MirPatWildcard

export type MirPatternField = MirPatternField(name: Option<string>, pattern: MirPattern)

export type MirRecordPatField = MirRecordPatField(name: string, pattern: MirPattern)

export type MirProgram = MirProgram(functions: [MirFunction], externals: [MirExternal])
