/**
 * resolve: Name resolution for the Nexus self-hosting compiler.
 *
 * Provides:
 * - build_rename_map: construct rename entries from an import definition
 * - default_alias: extract module stem from import path
 * - register_top_level: populate symbol table from top-level definitions
 * - collect_enum_defs: gather all enum definitions
 * - extract_imports: gather all import definitions
 * - would_cycle: import cycle detection
 * - merge_rename_entries / apply_rename / make_rename_entry: rename utilities
 */
import { concat } from nxc/common/strcat.nx
import { SpannedExpr, SpannedTopLevel, TopLevel,
         GlobalLet, Port, VariantDef, EnumDef, RecordDef,
         ExceptionDef, ImportDef } from nxc/common/ast.nx
import { RenameEntry, rename, rename_add,
         ScopeState,
         define_value, define_type, define_port,
         define_constructor, define_exception } from nxc/ir/symtab.nx
import { from_i64, length, substring, index_of } from stdlib/string.nx
import * as list from stdlib/list.nx
import { StringMap } from stdlib/stringmap.nx

// ─── Path utilities ───────────────────────────────────────────────────────────

let find_last_slash_go = fn (s: string, pos: i64, last: i64) -> i64 do
  if pos >= length(s: s) then return last
  else
    let ch = substring(s: s, start: pos, len: 1)
    if ch == "/" then return find_last_slash_go(s: s, pos: pos + 1, last: pos)
    else return find_last_slash_go(s: s, pos: pos + 1, last: last)
    end
  end
end

/// Extract the module stem from an import path.
/// e.g., "stdlib/string.nx" -> "string", "foo.nx" -> "foo"
export let default_alias = fn (path: string) -> string do
  let slash_pos = find_last_slash_go(s: path, pos: 0, last: -1)
  let start = slash_pos + 1
  let rest = substring(s: path, start: start, len: length(s: path) - start)
  let dot_pos = index_of(s: rest, sub: ".")
  if dot_pos < 0 then return rest
  else return substring(s: rest, start: 0, len: dot_pos)
  end
end

// ─── Rename map construction ──────────────────────────────────────────────────

let is_selected = fn (name: string, items: [string]) -> bool do
  match items do
    case Nil -> return false
    case item :: rest ->
      if item == name then return true
      else return is_selected(name: name, items: rest)
      end
  end
end

let build_wildcard_rename_go = fn (defs: [SpannedTopLevel], alias: string, acc: [RenameEntry]) -> [RenameEntry] do
  match defs do
    case Nil -> return acc
    case SpannedTopLevel(node: TLLet(def: GlobalLet(name: name, is_public: _, typ: _, value: _)), span: _) :: rest ->
      let acc2 = rename_add(entries: acc, original: name, qualified: concat(parts: [alias, ".", name]))
      return build_wildcard_rename_go(defs: rest, alias: alias, acc: acc2)
    case SpannedTopLevel(node: TLPort(def: Port(name: name, is_public: _, functions: _)), span: _) :: rest ->
      let acc2 = rename_add(entries: acc, original: name, qualified: concat(parts: [alias, ".", name]))
      return build_wildcard_rename_go(defs: rest, alias: alias, acc: acc2)
    case _ :: rest ->
      return build_wildcard_rename_go(defs: rest, alias: alias, acc: acc)
  end
end

let get_prefix = fn (alias_opt: Option<string>, import_depth: i64) -> string do
  match alias_opt do
    case Some(val: a) -> return a
    case None -> return "__import_" ++ from_i64(val: import_depth)
  end
end

let build_selective_rename_go = fn (defs: [SpannedTopLevel], items: [string], prefix: string, acc: [RenameEntry]) -> [RenameEntry] do
  match defs do
    case Nil -> return acc
    case SpannedTopLevel(node: TLLet(def: GlobalLet(name: name, is_public: _, typ: _, value: _)), span: _) :: rest ->
      if is_selected(name: name, items: items) then
        let acc2 = rename_add(entries: acc, original: name, qualified: name)
        return build_selective_rename_go(defs: rest, items: items, prefix: prefix, acc: acc2)
      else
        let acc2 = rename_add(entries: acc, original: name, qualified: concat(parts: [prefix, ".", name]))
        return build_selective_rename_go(defs: rest, items: items, prefix: prefix, acc: acc2)
      end
    case SpannedTopLevel(node: TLPort(def: Port(name: name, is_public: _, functions: _)), span: _) :: rest ->
      if is_selected(name: name, items: items) then
        let acc2 = rename_add(entries: acc, original: name, qualified: name)
        return build_selective_rename_go(defs: rest, items: items, prefix: prefix, acc: acc2)
      else
        let acc2 = rename_add(entries: acc, original: name, qualified: concat(parts: [prefix, ".", name]))
        return build_selective_rename_go(defs: rest, items: items, prefix: prefix, acc: acc2)
      end
    case _ :: rest ->
      return build_selective_rename_go(defs: rest, items: items, prefix: prefix, acc: acc)
  end
end

/// Build a rename map for a single import.
/// imported_defs: top-level definitions from the imported module's AST.
/// import_def: the import statement being processed.
/// import_depth: nesting depth (for auto-generated prefixes).
export let build_rename_map = fn (imported_defs: [SpannedTopLevel], import_def: ImportDef, import_depth: i64) -> [RenameEntry] do
  match import_def do
    case ImportDef(path: path, alias: alias_opt, items: items, is_external: is_ext) ->
      if is_ext then return Nil
      else
        match items do
          case Nil ->
            let alias = match alias_opt do
              case Some(val: a) -> a
              case None -> default_alias(path: path)
            end
            return build_wildcard_rename_go(defs: imported_defs, alias: alias, acc: Nil)
          case _ :: _ ->
            let prefix = get_prefix(alias_opt: alias_opt, import_depth: import_depth)
            return build_selective_rename_go(defs: imported_defs, items: items, prefix: prefix, acc: Nil)
        end
      end
  end
end

// ─── Symbol registration ──────────────────────────────────────────────────────

let register_variants_go = fn (tab: %StringMap, state: ScopeState, variants: [VariantDef]) -> %StringMap throws { Exn } do
  match variants do
    case Nil -> return tab
    case VariantDef(name: vname, fields: _) :: rest ->
      let %tab2 = define_constructor(tab: tab, state: state, name: vname)
      return register_variants_go(tab: %tab2, state: state, variants: rest)
  end
end

/// Register all top-level definitions from a program into the symbol table.
/// Uses rename entries to qualify names.
export let register_top_level = fn (tab: %StringMap, state: ScopeState, defs: [SpannedTopLevel], entries: [RenameEntry]) -> %StringMap throws { Exn } do
  match defs do
    case Nil -> return tab
    case SpannedTopLevel(node: TLLet(def: GlobalLet(name: name, is_public: _, typ: _, value: val)), span: _) :: rest ->
      let qname = rename(name: name, entries: entries)
      let %tab2 = match val do
        case SpannedExpr(node: ExprLambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: _), span: _) ->
          define_value(tab: tab, state: state, name: qname, kind: SkFunction)
        case SpannedExpr(node: ExprExternal(symbol: _, arg_names: _, typ: _), span: _) ->
          define_value(tab: tab, state: state, name: qname, kind: SkExternal)
        case SpannedExpr(node: ExprHandler(coeffect_name: _, requires: _, functions: _), span: _) ->
          define_value(tab: tab, state: state, name: qname, kind: SkFunction)
        case _ ->
          define_value(tab: tab, state: state, name: qname, kind: SkVariable)
      end
      return register_top_level(tab: %tab2, state: state, defs: rest, entries: entries)
    case SpannedTopLevel(node: TLEnum(def: EnumDef(name: ename, is_public: _, is_opaque: _, type_params: _, variants: variants)), span: _) :: rest ->
      let %t = define_type(tab: tab, state: state, name: ename)
      let %tab2 = register_variants_go(tab: %t, state: state, variants: variants)
      return register_top_level(tab: %tab2, state: state, defs: rest, entries: entries)
    case SpannedTopLevel(node: TLTypeDef(def: RecordDef(name: rname, is_public: _, type_params: _, fields: _)), span: _) :: rest ->
      let %tab2 = define_type(tab: tab, state: state, name: rname)
      return register_top_level(tab: %tab2, state: state, defs: rest, entries: entries)
    case SpannedTopLevel(node: TLPort(def: Port(name: pname, is_public: _, functions: _)), span: _) :: rest ->
      let qname = rename(name: pname, entries: entries)
      let %tab2 = define_port(tab: tab, state: state, name: qname)
      return register_top_level(tab: %tab2, state: state, defs: rest, entries: entries)
    case SpannedTopLevel(node: TLException(def: ExceptionDef(name: exname, is_public: _, fields: _)), span: _) :: rest ->
      let %tab2 = define_exception(tab: tab, state: state, name: exname)
      return register_top_level(tab: %tab2, state: state, defs: rest, entries: entries)
    case SpannedTopLevel(node: TLImport(def: _), span: _) :: rest ->
      return register_top_level(tab: tab, state: state, defs: rest, entries: entries)
  end
end

// ─── Enum definition collection ───────────────────────────────────────────────

let collect_enum_defs_go = fn (defs: [SpannedTopLevel], acc: [EnumDef]) -> [EnumDef] do
  match defs do
    case Nil -> return acc
    case SpannedTopLevel(node: TLEnum(def: ed), span: _) :: rest ->
      return collect_enum_defs_go(defs: rest, acc: Cons(v: ed, rest: acc))
    case _ :: rest ->
      return collect_enum_defs_go(defs: rest, acc: acc)
  end
end

/// Collect all enum definitions from top-level definitions.
export let collect_enum_defs = fn (defs: [SpannedTopLevel]) -> [EnumDef] do
  return list.reverse(xs: collect_enum_defs_go(defs: defs, acc: Nil))
end

// ─── Import extraction ────────────────────────────────────────────────────────

let extract_imports_go = fn (defs: [SpannedTopLevel], acc: [ImportDef]) -> [ImportDef] do
  match defs do
    case Nil -> return acc
    case SpannedTopLevel(node: TLImport(def: imp), span: _) :: rest ->
      return extract_imports_go(defs: rest, acc: Cons(v: imp, rest: acc))
    case _ :: rest ->
      return extract_imports_go(defs: rest, acc: acc)
  end
end

/// Extract all import definitions from a program's top-level.
export let extract_imports = fn (defs: [SpannedTopLevel]) -> [ImportDef] do
  return list.reverse(xs: extract_imports_go(defs: defs, acc: Nil))
end

// ─── Cycle detection ──────────────────────────────────────────────────────────

let has_path = fn (stack: [string], path: string) -> bool do
  match stack do
    case Nil -> return false
    case p :: rest ->
      if p == path then return true
      else return has_path(stack: rest, path: path)
      end
  end
end

/// Check if importing a path would create a cycle.
export let would_cycle = fn (import_stack: [string], path: string) -> bool do
  return has_path(stack: import_stack, path: path)
end

// ─── Merge rename entries ─────────────────────────────────────────────────────

let merge_entries_go = fn (src: [RenameEntry], dst: [RenameEntry]) -> [RenameEntry] do
  match src do
    case Nil -> return dst
    case entry :: rest ->
      return merge_entries_go(src: rest, dst: Cons(v: entry, rest: dst))
  end
end

/// Merge two rename entry lists (prepend src onto dst).
export let merge_rename_entries = fn (src: [RenameEntry], dst: [RenameEntry]) -> [RenameEntry] do
  return merge_entries_go(src: src, dst: dst)
end

// ─── Convenience re-exports for downstream use ────────────────────────────────

/// Apply a rename map to a name. Returns qualified name if found, original otherwise.
export let apply_rename = fn (name: string, entries: [RenameEntry]) -> string do
  return rename(name: name, entries: entries)
end

/// Build a single rename entry list from original -> qualified.
export let make_rename_entry = fn (original: string, qualified: string) -> [RenameEntry] do
  return rename_add(entries: Nil, original: original, qualified: qualified)
end
