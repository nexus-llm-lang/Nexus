let rev_mir_named_exprs = fn (lst: [MirNamedExpr], out: [MirNamedExpr]) -> [MirNamedExpr] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_mir_named_exprs(lst: rest, out: x :: out)
