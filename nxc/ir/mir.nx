let rev_mir_match_cases = fn (lst: [MirMatchCase], out: [MirMatchCase]) -> [MirMatchCase] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_mir_match_cases(lst: rest, out: x :: out)
