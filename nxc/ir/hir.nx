let rev_spanned_expr = fn (lst: [SpannedExpr], out: [SpannedExpr]) -> [SpannedExpr] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_spanned_expr(lst: rest, out: x :: out)
  end
end
