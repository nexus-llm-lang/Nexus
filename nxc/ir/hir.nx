/**
 * hir: AST -> HIR conversion + reachability analysis.
 *
 * Type definitions live in nxc/ir/hir_types.nx.
 * This file handles:
 * - AST expression/statement/pattern conversion to HIR
 * - Top-level definition processing (functions, externals, handlers, ports)
 * - Reachability analysis (worklist from "main")
 * - Dead code filtering
 */
import { Span } from "nxc/common/token.nx"
import { concat } from "stdlib/bytebuffer.nx"
import { handler_func_name } from "nxc/common/naming.nx"
import { Sigil, SigilImmutable, SigilLazy, SigilMutable, TypeExpr, TyI64, TyVar, TyUnit, TyArrow,
         Expr, ExprLiteral, ExprVariable, ExprBinaryOp, ExprBorrow,
         ExprCall, ExprConstructor, ExprRecord, ExprArray, ExprIndex,
         ExprFieldAccess, ExprIf, ExprMatch, ExprWhile, ExprFor,
         ExprLambda, ExprRaise, ExprForce, ExprExternal, ExprHandler, ExprList,
         Stmt, StmtLet, StmtLetPattern, StmtExpr, StmtReturn, StmtAssign,
         StmtTry, StmtInject,
         Pattern, PatLiteral, PatVariable, PatConstructor, PatRecord, PatWildcard,
         SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel,
         Param, Function, MatchCase, CallArg, CtorArg, NamedExpr,
         NamedType, CtorPatternField, RecordPatField,
         EnumDef, ImportDef, FunctionSig, Port, GlobalLet,
         CatchArm,
         TopLevel, TLImport, TLLet, TLPort, TLEnum, TLTypeDef, TLException, TLExceptionGroup,
         ExceptionGroupDef } from "nxc/common/ast.nx"
import { RenameEntry, rename } from "nxc/ir/symtab.nx"
import { char_code, length, substring, ends_with, starts_with, index_of,
         byte_at, byte_length, byte_substring, contains, replace } from "stdlib/string.nx"
import * as hir from "nxc/ir/hir_types.nx"
import { HirParam, HirPortMethod, HirPort, HirExternal,
         HirExpr, HirStmt, HirExprKind, HirStmtKind,
         HirCallArg, HirNamedExpr,
         HirMatchCase, HirPatternKind,
         HirPatternField, HirRecordPatField,
         HirBody, EagerBody, LazyBody,
         HirFunction, HirHandlerBinding, HirHandlerBindingEntry,
         HirProgram, HirAccum, ExceptionGroupEntry } from "nxc/ir/hir_types.nx"

/// Strip module qualifier from a constructor name (e.g., "hir.PLit" → "PLit").
let strip_qual = fn (name: string) -> string do
  let len = length(s: name)
  return strip_qual_go(name: name, i: len - 1)
end

let strip_qual_go = fn (name: string, i: i64) -> string do
  if i < 0 then return name end
  if char_code(s: name, idx: i) == 46 then
    return substring(s: name, start: i + 1, len: length(s: name) - i - 1)
  else
    return strip_qual_go(name: name, i: i - 1)
  end
end

// ─── AST -> HIR Conversion ──────────────────────────────────────────────────

/// Convert an AST expression (SpannedExpr) to HIR.
export let convert_expr = fn (expr: SpannedExpr, entries: [RenameEntry]) -> HirExpr do
  let SpannedExpr(node: node, span: sp) = expr
  let hir = match node do
    case ExprLiteral(lit: lit) ->
      Literal(lit: lit)
    case ExprVariable(name: name, sigil: sig) ->
      let renamed = rename(name: name, entries: entries)
      match sig do
        case SigilLazy ->
          // @ thunks are eagerly evaluated in nxc — force is identity
          Variable(name: renamed, sigil: SigilImmutable)
        case _ ->
          Variable(name: renamed, sigil: sig)
      end
    case ExprBinaryOp(left: l, op: op, right: r) ->
      BinOp(
        left: convert_expr(expr: l, entries: entries),
        op: op,
        right: convert_expr(expr: r, entries: entries)
      )
    case ExprBorrow(name: name, sigil: sig) ->
      Borrow(name: rename(name: name, entries: entries), sigil: sig)
    case ExprCall(func: f, args: args) ->
      Call(
        func: rename(name: f, entries: entries),
        args: convert_call_args(args: args, entries: entries)
      )
    case ExprConstructor(name: v, args: args) ->
      Ctor(
        variant: strip_qual(name: rename(name: v, entries: entries)),
        args: convert_ctor_args(args: args, entries: entries)
      )
    case ExprRecord(fields: fs) ->
      Record(fields: convert_named_exprs(exprs: fs, entries: entries))
    case ExprArray(elements: es) ->
      Array(elems: convert_expr_list(exprs: es, entries: entries))
    case ExprIndex(target: t, index: i) ->
      Index(
        target: convert_expr(expr: t, entries: entries),
        index: convert_expr(expr: i, entries: entries)
      )
    case ExprFieldAccess(target: t, field: f) ->
      FieldAccess(target: convert_expr(expr: t, entries: entries), field: f)
    case ExprIf(cond: c, then_branch: tb, else_branch: eb) ->
      let hir_else = match eb do
        case [] -> None
        case _ :: _ -> Some(val: convert_stmts(stmts: eb, entries: entries))
      end
      If(
        cond: convert_expr(expr: c, entries: entries),
        then_branch: convert_stmts(stmts: tb, entries: entries),
        else_branch: hir_else
      )
    case ExprMatch(target: t, cases: cs) ->
      Match(
        target: convert_expr(expr: t, entries: entries),
        cases: convert_match_cases(cases: cs, entries: entries)
      )
    case ExprWhile(cond: c, body: b) ->
      While(
        cond: convert_expr(expr: c, entries: entries),
        body: convert_stmts(stmts: b, entries: entries)
      )
    case ExprFor(var: v, start: s, end_expr: e, body: b) ->
      For(
        var: v,
        start: convert_expr(expr: s, entries: entries),
        end_expr: convert_expr(expr: e, entries: entries),
        body: convert_stmts(stmts: b, entries: entries)
      )
    case ExprLambda(type_params: tps, params: ps, ret_type: rt, requires: _, throw_row: _, body: b) ->
      Lambda(
        type_params: tps,
        params: convert_params(params: ps),
        ret_type: rt,
        body: convert_stmts(stmts: b, entries: entries)
      )
    case ExprRaise(value: e) ->
      Raise(expr: convert_expr(expr: e, entries: entries))
    case ExprForce(value: e) ->
      Force(expr: convert_expr(expr: e, entries: entries))
    case ExprExternal(symbol: sym, arg_names: names, typ: t) ->
      ExternalRef(symbol: sym, arg_names: names, typ: t)
    case ExprHandler(coeffect_name: pname, requires: _, functions: fs) ->
      Handler(port_name: pname, functions: convert_functions(funcs: fs, entries: entries))
    case ExprList(elements: es) ->
      // Extract inner node from desugar_list result — span comes from outer wrapping
      let HirExpr(node: desugared, span: _) = desugar_list(elems: es, entries: entries, span: sp)
      desugared
  end
  return HirExpr(node: hir, span: sp)
end

/// Convert a top-level AST expression, ALWAYS skipping body conversion.
/// Returns Lambda with empty body for everything — the caller (process_tl_let)
/// matches on the HirExprKind to distinguish Lambda from External/Handler.
/// Non-Lambda TLLets get LazyBody too, but resolve_lazy_bodies handles the
/// empty-body case gracefully (returns empty stmts).
let convert_expr_toplevel = fn (expr: SpannedExpr, entries: [RenameEntry]) -> HirExpr do
  let SpannedExpr(node: node, span: sp) = expr
  let tps = infer_tparams_from_expr(expr: node)
  let ps = infer_params_from_expr(expr: node)
  let rt = infer_ret_from_expr(expr: node)
  return HirExpr(node: Lambda(type_params: tps, params: ps, ret_type: rt, body: []), span: sp)
end

/// Desugar [a, b, c] -> Cons(a, Cons(b, Cons(c, Nil)))
/// Args are unlabeled, so they must be in alphabetical field order: (rest, v)
let desugar_list = fn (elems: [SpannedExpr], entries: [RenameEntry], span: Span) -> HirExpr do
  let reversed = rev_spanned_expr(lst: elems, out: [])
  let zero = Span(offset: 0, line: 0, col: 0)
  let inner = desugar_list_go(elems: reversed, entries: entries,
    acc: HirExpr(node: Ctor(variant: "Nil", args: []), span: zero))
  let HirExpr(node: result_node, span: _) = inner
  return HirExpr(node: result_node, span: span)
end

let desugar_list_go = fn (elems: [SpannedExpr], entries: [RenameEntry], acc: HirExpr) -> HirExpr do
  match elems do
    case [] -> return acc
    case e :: rest ->
      let head = convert_expr(expr: e, entries: entries)
      let zero = Span(offset: 0, line: 0, col: 0)
      return desugar_list_go(elems: rest, entries: entries,
        acc: HirExpr(node: Ctor(variant: "Cons", args: [acc, head]), span: zero))
  end
end

let convert_call_args = fn (args: [CallArg], entries: [RenameEntry]) -> [HirCallArg] do
  return convert_call_args_go(args: args, entries: entries, acc: [])
end

let convert_call_args_go = fn (args: [CallArg], entries: [RenameEntry], acc: [HirCallArg]) -> [HirCallArg] do
  match args do
    case [] -> return rev_hir_call_arg(lst: acc, out: [])
    case CallArg(name: l, value: v) :: rest ->
      return convert_call_args_go(args: rest, entries: entries, acc: HirCallArg(label: l, value: convert_expr(expr: v, entries: entries)) :: acc)
  end
end

// ─── Constructor field sorting (alphabetical, matching memory layout) ────────

let str_less_than_loop = fn (a: string, b: string, idx: i64, la: i64, lb: i64) -> bool do
  if idx >= la then
    return idx < lb
  else
    if idx >= lb then
      return false
    else
      let ca = char_code(s: a, idx: idx)
      let cb = char_code(s: b, idx: idx)
      if ca < cb then
        return true
      else
        if ca > cb then
          return false
        else
          return str_less_than_loop(a: a, b: b, idx: idx + 1, la: la, lb: lb)
        end
      end
    end
  end
end

let str_less_than = fn (a: string, b: string) -> bool do
  return str_less_than_loop(a: a, b: b, idx: 0, la: length(s: a), lb: length(s: b))
end

let all_labeled = fn (args: [CtorArg]) -> bool do
  match args do
    case [] -> return true
    case CtorArg(name: Some(val: _), value: _) :: rest -> return all_labeled(args: rest)
    case CtorArg(name: None, value: _) :: _ -> return false
  end
end

let ctor_arg_name = fn (arg: CtorArg) -> string do
  match arg do
    case CtorArg(name: Some(val: n), value: _) -> return n
    case CtorArg(name: None, value: _) -> return ""
  end
end

let insert_ctor_arg = fn (arg: CtorArg, sorted: [CtorArg]) -> [CtorArg] do
  return insert_ctor_arg_go(arg: arg, sorted: sorted, acc: [])
end

let insert_ctor_arg_go = fn (arg: CtorArg, sorted: [CtorArg], acc: [CtorArg]) -> [CtorArg] do
  match sorted do
    case [] -> return rev_ctor_arg(lst: acc, out: [arg])
    case head :: rest ->
      if str_less_than(a: ctor_arg_name(arg: arg), b: ctor_arg_name(arg: head)) then
        return rev_ctor_arg(lst: acc, out: arg :: sorted)
      else
        return insert_ctor_arg_go(arg: arg, sorted: rest, acc: head :: acc)
      end
  end
end

let sort_ctor_args = fn (args: [CtorArg]) -> [CtorArg] do
  return sort_ctor_args_go(args: args, sorted: [])
end

let sort_ctor_args_go = fn (args: [CtorArg], sorted: [CtorArg]) -> [CtorArg] do
  match args do
    case [] -> return sorted
    case a :: rest -> return sort_ctor_args_go(args: rest, sorted: insert_ctor_arg(arg: a, sorted: sorted))
  end
end

let convert_ctor_args = fn (args: [CtorArg], entries: [RenameEntry]) -> [HirExpr] do
  if all_labeled(args: args) then
    return convert_ctor_args_inner(args: sort_ctor_args(args: args), entries: entries)
  end
  return convert_ctor_args_inner(args: args, entries: entries)
end

let convert_ctor_args_inner = fn (args: [CtorArg], entries: [RenameEntry]) -> [HirExpr] do
  return convert_ctor_args_inner_go(args: args, entries: entries, acc: [])
end

let convert_ctor_args_inner_go = fn (args: [CtorArg], entries: [RenameEntry], acc: [HirExpr]) -> [HirExpr] do
  match args do
    case [] -> return rev_hir_expr(lst: acc, out: [])
    case CtorArg(name: _, value: v) :: rest ->
      return convert_ctor_args_inner_go(args: rest, entries: entries, acc: convert_expr(expr: v, entries: entries) :: acc)
  end
end

let convert_named_exprs = fn (exprs: [NamedExpr], entries: [RenameEntry]) -> [HirNamedExpr] do
  return convert_named_exprs_go(exprs: exprs, entries: entries, acc: [])
end

let convert_named_exprs_go = fn (exprs: [NamedExpr], entries: [RenameEntry], acc: [HirNamedExpr]) -> [HirNamedExpr] do
  match exprs do
    case [] -> return rev_hir_named_expr(lst: acc, out: [])
    case NamedExpr(name: n, value: v) :: rest ->
      return convert_named_exprs_go(exprs: rest, entries: entries, acc: HirNamedExpr(name: n, value: convert_expr(expr: v, entries: entries)) :: acc)
  end
end

let convert_expr_list = fn (exprs: [SpannedExpr], entries: [RenameEntry]) -> [HirExpr] do
  return convert_expr_list_go(exprs: exprs, entries: entries, acc: [])
end

let convert_expr_list_go = fn (exprs: [SpannedExpr], entries: [RenameEntry], acc: [HirExpr]) -> [HirExpr] do
  match exprs do
    case [] -> return rev_hir_expr(lst: acc, out: [])
    case e :: rest ->
      return convert_expr_list_go(exprs: rest, entries: entries, acc: convert_expr(expr: e, entries: entries) :: acc)
  end
end

// ─── Statement Conversion ───────────────────────────────────────────────────

/// Convert AST statements to HIR statements.
export let convert_stmts = fn (stmts: [SpannedStmt], entries: [RenameEntry]) -> [HirStmt] do
  return convert_stmts_go(stmts: stmts, entries: entries, acc: [])
end

let convert_stmts_go = fn (stmts: [SpannedStmt], entries: [RenameEntry], acc: [HirStmt]) -> [HirStmt] do
  match stmts do
    case [] -> return rev_hir_stmt(lst: acc, out: [])
    case SpannedStmt(node: StmtLet(name: n, sigil: sig, typ: t, value: v), span: sp) :: rest ->
      let hir_val = match sig do
        case SigilLazy ->
          // @ thunks compile eagerly in nxc: evaluate the expression immediately.
          // nxc doesn't have inline lambda lifting, so closures from @ desugaring
          // would produce malformed WASM. The typechecker still enforces @T linearity;
          // actual lazy/parallel execution is provided by the Rust compiler.
          convert_expr(expr: v, entries: entries)
        case _ ->
          convert_expr(expr: v, entries: entries)
      end
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Let(name: n, typ: t, value: hir_val), span: sp) :: acc)
    case SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp) :: rest ->
      // Desugar: let Pattern = expr; rest → match expr do case Pattern -> rest end
      let case_body = convert_stmts(stmts: rest, entries: entries)
      let match_case = HirMatchCase(
        pattern: convert_pattern(pat: pat, entries: entries),
        body: case_body
      )
      return rev_hir_stmt(lst: acc, out: [HirStmt(node: Expr(expr: HirExpr(node: Match(
          target: convert_expr(expr: v, entries: entries),
          cases: [match_case]
        ), span: sp)), span: sp)])
    case SpannedStmt(node: StmtExpr(expr: e), span: sp) :: rest ->
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Expr(expr: convert_expr(expr: e, entries: entries)), span: sp) :: acc)
    case SpannedStmt(node: StmtReturn(value: e), span: sp) :: rest ->
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Return(expr: convert_expr(expr: e, entries: entries)), span: sp) :: acc)
    case SpannedStmt(node: StmtAssign(target: t, value: v), span: sp) :: rest ->
      let zero = Span(offset: 0, line: 0, col: 0)
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Assign(
          target: HirExpr(node: Variable(name: rename(name: t, entries: entries), sigil: SigilMutable), span: zero),
          value: convert_expr(expr: v, entries: entries)
        ), span: sp) :: acc)
    case SpannedStmt(node: StmtTry(body: b, catch_arms: CatchArm(pattern: SpannedPattern(node: PatVariable(name: n, sigil: _), span: _), body: cb) :: Nil), span: sp) :: rest ->
      // Legacy single-arm variable catch: catch param -> body
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Try(
          body: convert_stmts(stmts: b, entries: entries),
          catch_param: n,
          catch_body: convert_stmts(stmts: cb, entries: entries)
        ), span: sp) :: acc)
    case SpannedStmt(node: StmtTry(body: b, catch_arms: arms), span: sp) :: rest ->
      // Multi-arm or non-variable: desugar to catch __exn -> match __exn do ... end
      let mir_cases = convert_catch_arms_to_match_cases(arms: arms, entries: entries)
      let match_expr = hir.Match(target: HirExpr(node: hir.Variable(name: "__exn", sigil: SigilImmutable), span: sp), cases: mir_cases)
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Try(
          body: convert_stmts(stmts: b, entries: entries),
          catch_param: "__exn",
          catch_body: [HirStmt(node: hir.Expr(expr: HirExpr(node: match_expr, span: sp)), span: sp)]
        ), span: sp) :: acc)
    case SpannedStmt(node: StmtInject(handlers: hs, body: b), span: sp) :: rest ->
      let handler_names = extract_handler_names(exprs: hs)
      let qualified_handlers = rename_strings(names: handler_names, entries: entries)
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Inject(
          handlers: qualified_handlers,
          body: convert_stmts(stmts: b, entries: entries)
        ), span: sp) :: acc)
  end
end

let rename_strings = fn (names: [string], entries: [RenameEntry]) -> [string] do
  return rename_strings_go(names: names, entries: entries, acc: [])
end

let rename_strings_go = fn (names: [string], entries: [RenameEntry], acc: [string]) -> [string] do
  match names do
    case [] -> return rev_string(lst: acc, out: [])
    case n :: rest ->
      return rename_strings_go(names: rest, entries: entries, acc: rename(name: n, entries: entries) :: acc)
  end
end

/// Extract handler variable names from inject handler expressions.
let extract_handler_names = fn (exprs: [SpannedExpr]) -> [string] do
  return extract_handler_names_go(exprs: exprs, acc: [])
end

let extract_handler_names_go = fn (exprs: [SpannedExpr], acc: [string]) -> [string] do
  match exprs do
    case [] -> return rev_string(lst: acc, out: [])
    case e :: rest ->
      let name = extract_handler_name_from_expr(expr: e)
      return extract_handler_names_go(exprs: rest, acc: name :: acc)
  end
end

/// Extract handler name from an expression. Handles both simple variables and dotted access.
let extract_handler_name_from_expr = fn (expr: SpannedExpr) -> string do
  let SpannedExpr(node: node, span: _) = expr
  return extract_name_from_node(node: node)
end

let extract_name_from_node = fn (node: Expr) -> string do
  match node do
    case ExprVariable(name: name, sigil: _) -> return name
    case ExprFieldAccess(target: t, field: fld) ->
      let base = extract_handler_name_from_expr(expr: t)
      return base ++ "." ++ fld
    case _ -> return ""
  end
end

// ─── Pattern Conversion ─────────────────────────────────────────────────────

/// Convert match cases to HIR.
let convert_match_cases = fn (cases: [MatchCase], entries: [RenameEntry]) -> [HirMatchCase] do
  return convert_match_cases_go(cases: cases, entries: entries, acc: [])
end

let convert_match_cases_go = fn (cases: [MatchCase], entries: [RenameEntry], acc: [HirMatchCase]) -> [HirMatchCase] do
  match cases do
    case [] -> return rev_hir_match_case(lst: acc, out: [])
    case MatchCase(pattern: p, body: b) :: rest ->
      return convert_match_cases_go(cases: rest, entries: entries, acc: HirMatchCase(
          pattern: convert_pattern(pat: p, entries: entries),
          body: convert_stmts(stmts: b, entries: entries)
        ) :: acc)
  end
end

/// Convert a pattern to HIR pattern.
export let convert_pattern = fn (pat: SpannedPattern, entries: [RenameEntry]) -> HirPatternKind do
  match pat do
    case SpannedPattern(node: PatLiteral(lit: lit), span: _) ->
      return hir.PLit(lit: lit)
    case SpannedPattern(node: PatVariable(name: name, sigil: sig), span: _) ->
      return hir.PVar(name: name, sigil: sig)
    case SpannedPattern(node: PatConstructor(name: v, fields: fs), span: _) ->
      return hir.PCtor(
        variant: strip_qual(name: rename(name: v, entries: entries)),
        fields: convert_pattern_fields(fs: fs, entries: entries)
      )
    case SpannedPattern(node: PatRecord(fields: fs, has_wildcard: p), span: _) ->
      return hir.PRec(
        fields: convert_record_pat_fields(fs: fs, entries: entries),
        is_partial: p
      )
    case SpannedPattern(node: PatWildcard, span: _) ->
      return hir.PWild
  end
end

let convert_catch_arms_to_match_cases = fn (arms: [CatchArm], entries: [RenameEntry]) -> [HirMatchCase] do
  return convert_catch_arms_go(arms: arms, entries: entries, acc: [])
end

let convert_catch_arms_go = fn (arms: [CatchArm], entries: [RenameEntry], acc: [HirMatchCase]) -> [HirMatchCase] do
  match arms do
    case [] -> return rev_hir_match_case(lst: acc, out: [])
    case CatchArm(pattern: p, body: b) :: rest ->
      let mc = HirMatchCase(pattern: convert_pattern(pat: p, entries: entries), body: convert_stmts(stmts: b, entries: entries))
      return convert_catch_arms_go(arms: rest, entries: entries, acc: mc :: acc)
  end
end

let convert_pattern_fields = fn (fs: [CtorPatternField], entries: [RenameEntry]) -> [HirPatternField] do
  return convert_pattern_fields_go(fs: fs, entries: entries, acc: [])
end

let convert_pattern_fields_go = fn (fs: [CtorPatternField], entries: [RenameEntry], acc: [HirPatternField]) -> [HirPatternField] do
  match fs do
    case [] -> return rev_hir_pattern_field(lst: acc, out: [])
    case CtorPatternField(name: n, pattern: p) :: rest ->
      return convert_pattern_fields_go(fs: rest, entries: entries, acc: HirPatternField(name: n, pattern: convert_pattern(pat: p, entries: entries)) :: acc)
  end
end

let convert_record_pat_fields = fn (fs: [RecordPatField], entries: [RenameEntry]) -> [HirRecordPatField] do
  return convert_record_pat_fields_go(fs: fs, entries: entries, acc: [])
end

let convert_record_pat_fields_go = fn (fs: [RecordPatField], entries: [RenameEntry], acc: [HirRecordPatField]) -> [HirRecordPatField] do
  match fs do
    case [] -> return rev_hir_record_pat_field(lst: acc, out: [])
    case RecordPatField(name: n, pattern: p) :: rest ->
      return convert_record_pat_fields_go(fs: rest, entries: entries, acc: HirRecordPatField(name: n, pattern: convert_pattern(pat: p, entries: entries)) :: acc)
  end
end

// ─── Param / Function Conversion ────────────────────────────────────────────

/// Convert AST params to HIR params.
let convert_params = fn (params: [Param]) -> [HirParam] do
  return convert_params_go(params: params, acc: [])
end

let convert_params_go = fn (params: [Param], acc: [HirParam]) -> [HirParam] do
  match params do
    case [] -> return rev_hir_param(lst: acc, out: [])
    case Param(name: n, sigil: _, typ: t) :: rest ->
      return convert_params_go(params: rest, acc: HirParam(name: n, label: n, typ: t) :: acc)
  end
end

/// Convert AST functions to HIR functions.
let convert_functions = fn (funcs: [Function], entries: [RenameEntry]) -> [HirFunction] do
  return convert_functions_go(funcs: funcs, entries: entries, acc: [])
end

let convert_functions_go = fn (funcs: [Function], entries: [RenameEntry], acc: [HirFunction]) -> [HirFunction] do
  match funcs do
    case [] -> return rev_hir_function(lst: acc, out: [])
    case Function(name: n, is_public: _, type_params: tps, params: ps, ret_type: rt, requires: _, throw_row: _, body: b) :: rest ->
      return convert_functions_go(funcs: rest, entries: entries, acc: HirFunction(
          name: n,
          type_params: tps,
          params: convert_params(params: ps),
          ret_type: rt,
          body: EagerBody(stmts: convert_stmts(stmts: b, entries: entries)),
          span: Span(offset: 0, line: 0, col: 0)
        ) :: acc)
  end
end

// ─── Top-level definition processing ────────────────────────────────────────

/// Create an empty HirAccum.
export let empty_accum = fn () -> HirAccum do
  return HirAccum(
    ports: [], functions: [], externals: [],
    handler_bindings: [],
    // Seed Exn enum with built-in exception variants (matching Rust compiler's exn_enum_def()).
    // User-defined exceptions are added as variants via register_exn_variant.
    enum_defs: [EnumDef(name: "Exn", is_public: true, is_opaque: false,
      type_params: [],
      variants: [
        VariantDef(name: "RuntimeError", fields: [VariantField(name: Some(val: "val"), typ: TyString)]),
        VariantDef(name: "InvalidIndex", fields: [VariantField(name: Some(val: "val"), typ: TyI64)])])],
    wasm_module: None,
    exception_groups: []
  )
end

/// Register an exception as a variant of the Exn enum in enum_defs.
let register_exn_variant = fn (enum_defs: [EnumDef], vname: string, vfields: [VariantField]) -> [EnumDef] do
  return register_exn_variant_go(enum_defs: enum_defs, vname: vname, vfields: vfields, acc: [])
end

let register_exn_variant_go = fn (enum_defs: [EnumDef], vname: string, vfields: [VariantField], acc: [EnumDef]) -> [EnumDef] do
  match enum_defs do
    case [] -> return rev_enum_def(lst: acc, out: [])
    case ed :: rest ->
      match ed do case EnumDef(name: n, is_public: pub_, is_opaque: opq, type_params: tp, variants: vs) ->
        if n == "Exn" then
          let new_variant = VariantDef(name: vname, fields: vfields)
          return rev_enum_def(lst: acc, out: EnumDef(name: n, is_public: pub_, is_opaque: opq, type_params: tp,
            variants: new_variant :: vs) :: rest)
        else
          return register_exn_variant_go(enum_defs: rest, vname: vname, vfields: vfields, acc: ed :: acc)
        end
      end
  end
end

/// Check if defs contain main(args: [string]) which needs argv import.
/// Uses the same is_main_with_argv check from the HIR processing
/// but operates on AST-level types.
export let needs_argv_import = fn (defs: [SpannedTopLevel]) -> bool do
  match defs do
    case [] -> return false
    case d :: rest ->
      match d do
        case SpannedTopLevel(node: TLLet(def: GlobalLet(name: "main", is_public: _, typ: _, value: _)), span: _) ->
          // main found — check if is_main_with_argv would trigger during HIR processing
          // (Heuristic: any main with exactly 1 param is assumed to be main(args))
          return true
        case _ -> return needs_argv_import(defs: rest)
      end
  end
end

/// Map a stdlib .nx source file path to its WIT interface name.
/// Map a file stem to its WIT interface name. Returns "" if not a known stdlib stem.
let stem_to_wit = fn (stem: string) -> string do
  if stem == "math" then return "nexus:stdlib/math" end
  if stem == "string" then return "nexus:stdlib/string-ops" end
  if stem == "stdio" then return "nexus:stdlib/stdio" end
  if stem == "fs" then return "nexus:stdlib/filesystem" end
  if stem == "net" then return "nexus:stdlib/network" end
  if stem == "proc" then return "nexus:stdlib/process" end
  if stem == "env" then return "nexus:stdlib/environment" end
  if stem == "clock" then return "nexus:stdlib/clock" end
  if stem == "random" then return "nexus:stdlib/random" end
  if stem == "char" then return "nexus:stdlib/string-ops" end
  if stem == "bytebuffer" then return "nexus:stdlib/bytebuffer" end
  if stem == "hashmap" then return "nexus:stdlib/collections" end
  if stem == "stringmap" then return "nexus:stdlib/collections" end
  if stem == "set" then return "nexus:stdlib/collections" end
  if stem == "array" then return "nexus:stdlib/collections" end
  if stem == "core" then return "nexus:stdlib/core" end
  return ""
end

/// Extract file stem from a path: "stdlib/string.nx" → "string", "nxc/backend/foo.nx" → "foo"
let extract_nx_stem = fn (path: string) -> string do
  let dot_pos = index_of(s: path, sub: ".nx")
  if dot_pos < 0 then return "" end
  let stem_start = find_last_slash(s: path, pos: dot_pos - 1) + 1
  return substring(s: path, start: stem_start, len: dot_pos - stem_start)
end

/// Returns the original path unchanged if it's not a known stdlib file.
/// Set wasm_module on an accum for a stdlib source file.
/// Used by diamond imports where TLImport is filtered out.
export let set_accum_wmod_for_stdlib = fn (accum: HirAccum, source_file: string) -> HirAccum do
  let stem = extract_nx_stem(path: source_file)
  let wit = stem_to_wit(stem: stem)
  if length(s: wit) > 0 then
    let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: _, exception_groups: egs) = accum
    return HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: Some(val: wit), exception_groups: egs)
  end
  return accum
end

let map_stdlib_to_wit = fn (ext_path: string, source_file: string) -> string do
  // Only map "stdlib/stdlib.wasm" or "nxlib/stdlib/stdlib.wasm" style paths.
  if ends_with(s: ext_path, suffix: "stdlib.wasm") then
    // Try source_file stem first (normal case: stdlib .nx file importing stdlib.wasm)
    let stem = extract_nx_stem(path: source_file)
    let wit = stem_to_wit(stem: stem)
    if length(s: wit) > 0 then return wit end
    // Not a known stdlib file — keep as file path
    return ext_path
  end
  // If ext_path is a .nx file (e.g. "stdlib/hashmap.nx"), use its stem
  if ends_with(s: ext_path, suffix: ".nx") then
    let stem = extract_nx_stem(path: ext_path)
    let wit = stem_to_wit(stem: stem)
    if length(s: wit) > 0 then return wit end
  end
  return ext_path
end

/// Convert __nx_* FFI name to WIT-canonical kebab-case.
/// "__nx_abs_i64" → "abs-i64", "allocate" → "allocate"
let wit_canonical_name = fn (ffi_name: string) -> string do
  if starts_with(s: ffi_name, prefix: "__nx_") then
    let stripped = byte_substring(s: ffi_name, start: 5, len: byte_length(s: ffi_name) - 5)
    return replace(s: stripped, from_str: "_", to_str: "-")
  end
  return ffi_name
end

let find_last_slash = fn (s: string, pos: i64) -> i64 do
  if pos < 0 then return -1 end
  let c = byte_at(s: s, idx: pos)
  if c == '/' then return pos end
  return find_last_slash(s: s, pos: pos - 1)
end

/// Process a list of top-level definitions into HIR components.
export let process_defs = fn (defs: [SpannedTopLevel], entries: [RenameEntry], accum: HirAccum, source_file: string) -> HirAccum do
  match defs do
    case [] -> return accum
    case SpannedTopLevel(node: node, span: sp) :: rest ->
      let new_accum = process_top_level(node: node, span: sp, entries: entries, accum: accum, source_file: source_file)
      return process_defs(defs: rest, entries: entries, accum: new_accum, source_file: source_file)
  end
end

/// Lightweight variant for diamond imports: registers types, externals, and
/// exceptions but skips function-body conversion (already done on first import).
let ext_list_has = fn (exts: [HirExternal], name: string) -> bool do
  match exts do
    case [] -> return false
    case HirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) :: rest ->
      if n == name then return true end
      return ext_list_has(exts: rest, name: name)
  end
end

let func_list_has = fn (funcs: [HirFunction], name: string) -> bool do
  match funcs do
    case [] -> return false
    case HirFunction(name: n, type_params: _, params: _, ret_type: _, body: _, span: _) :: rest ->
      if n == name then return true end
      return func_list_has(funcs: rest, name: name)
  end
end

/// Process a TLLet definition. convert_expr returns Lambda with empty body
/// (body conversion skipped). We detect Lambda and store LazyBody from original AST.
let process_tl_let = fn (qname: string, orig_name: string, val: SpannedExpr, type_ann: Option<TypeExpr>,
    entries: [RenameEntry], span: Span, accum: HirAccum, source_file: string) -> HirAccum do
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs) = accum
  // Stdlib files (path starts with "stdlib/") may have external declarations.
  // Use full convert_expr for stdlib files (externals are cheap to convert).
  // Non-stdlib .nx files only have Lambda defs — use convert_expr_toplevel to skip bodies.
  let is_stdlib = starts_with(s: source_file, prefix: "stdlib/")
     || starts_with(s: source_file, prefix: "nxlib/stdlib/")
  let hir_val = if is_stdlib then convert_expr(expr: val, entries: entries)
    else convert_expr_toplevel(expr: val, entries: entries)
  end
  let HirExpr(node: hir_val_node, span: _) = hir_val
  match hir_val_node do
    case Lambda(type_params: tps, params: lps, ret_type: rt, body: _) ->
      // All Lambdas (including main) get LazyBody. Resolved during resolve phase.
      let func = HirFunction(name: qname, type_params: tps, params: lps,
        ret_type: rt, body: LazyBody(ast_expr: val, entries: entries), span: span)
      return HirAccum(ports: ps, functions: func :: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
    case Handler(port_name: pname, functions: handler_funcs) ->
      let binding = synthesize_handler(
        binding_name: qname, port_name: pname, functions: handler_funcs)
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: binding :: hbs,
        enum_defs: eds, wasm_module: wmod, exception_groups: egs)
    case ExternalRef(symbol: sym, arg_names: anames, typ: t) ->
      match wmod do
        case Some(val: wm) ->
          let effective_sym = if contains(s: wm, sub: ":") then
            wit_canonical_name(ffi_name: sym)
          else sym end
          let ext = make_hir_external(name: qname, wasm_module: wm,
            wasm_name: effective_sym, arg_names: anames, typ: t)
          return HirAccum(ports: ps, functions: fs,
            externals: ext :: exts,
            handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
        case None -> return accum
      end
    case _ ->
      let rt = match type_ann do
        case Some(val: t) -> t
        case None -> infer_constant_type(expr: hir_val)
      end
      let func = HirFunction(
        name: qname, type_params: [], params: [], ret_type: rt,
        body: EagerBody(stmts: [HirStmt(node: Return(expr: hir_val), span: span)]),
        span: span)
      return HirAccum(ports: ps, functions: func :: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
  end
end

/// Extract type params from a raw AST expression.
let infer_tparams_from_expr = fn (expr: Expr) -> [string] do
  match expr do
    case ExprLambda(type_params: tps, params: _, ret_type: _, requires: _, throw_row: _, body: _) ->
      return tps
    case _ -> return []
  end
end

/// Extract HirParam list from a raw AST expression (ExprLambda → params, else []).
let infer_params_from_expr = fn (expr: Expr) -> [HirParam] do
  match expr do
    case ExprLambda(type_params: _, params: ps, ret_type: _, requires: _, throw_row: _, body: _) ->
      return convert_params(params: ps)
    case _ -> return []
  end
end

/// Extract return type from a raw AST expression (ExprLambda → ret_type, else TyUnit).
let infer_ret_from_expr = fn (expr: Expr) -> TypeExpr do
  match expr do
    case ExprLambda(type_params: _, params: _, ret_type: rt, requires: _, throw_row: _, body: _) ->
      return rt
    case _ -> return TyUnit
  end
end

/// Extract Lambda body stmts from a raw AST expression (ExprLambda → body, else []).
export let infer_lambda_body = fn (expr: Expr) -> [SpannedStmt] do
  match expr do
    case ExprLambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: b) -> b
    case _ -> []
  end
end

let is_expr_lambda = fn (expr: Expr) -> bool do
  match expr do
    case ExprLambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: _) -> return true
    case _ -> return false
  end
end

let is_expr_external = fn (expr: Expr) -> bool do
  match expr do
    case ExprExternal(symbol: _, arg_names: _, typ: _) -> return true
    case _ -> return false
  end
end

let is_expr_handler = fn (expr: Expr) -> bool do
  match expr do
    case ExprHandler(coeffect_name: _, requires: _, functions: _) -> return true
    case _ -> return false
  end
end

let shallow_dispatch_let = fn (qname: string, val: SpannedExpr, entries: [RenameEntry], accum: HirAccum, wmod: Option<string>, span: Span) -> HirAccum do
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: _, exception_groups: egs) = accum
  let SpannedExpr(node: val_node, span: _) = val
  // Only call convert_expr for externals and handlers (cheap).
  // Lambda bodies are skipped to avoid OOM.
  // Always call convert_expr — ExprExternal/ExprHandler are cheap.
  // ExprLambda with body causes OOM, so detect and skip:
  // Dispatch on expression type inline
  match val_node do
    case ExprExternal(symbol: sym, arg_names: anames, typ: t) ->
      match wmod do
        case Some(val: wm) ->
          let effective_sym = if contains(s: wm, sub: ":") then
            wit_canonical_name(ffi_name: sym)
          else sym end
          let ext = make_hir_external(name: qname, wasm_module: wm,
            wasm_name: effective_sym, arg_names: anames, typ: t)
          return HirAccum(ports: ps, functions: fs,
            externals: ext :: exts,
            handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
        case None ->
          let ext = make_hir_external(name: qname, wasm_module: sym, wasm_name: sym, arg_names: anames, typ: t)
          return HirAccum(ports: ps, functions: fs,
            externals: ext :: exts,
            handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
      end
    case ExprHandler(coeffect_name: pname, requires: _, functions: hfs) ->
      let binding = synthesize_handler(binding_name: qname, port_name: pname, functions: convert_functions(funcs: hfs, entries: entries))
      return HirAccum(ports: ps, functions: fs,
        externals: exts, handler_bindings: binding :: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
    case _ -> return accum
  end
end

export let process_defs_shallow = fn (defs: [SpannedTopLevel], entries: [RenameEntry], accum: HirAccum, source_file: string) -> HirAccum do
  match defs do
    case [] -> return accum
    case SpannedTopLevel(node: node, span: sp) :: rest ->
      let new_accum = process_top_level_shallow(node: node, span: sp, entries: entries, accum: accum, source_file: source_file)
      return process_defs_shallow(defs: rest, entries: entries, accum: new_accum, source_file: source_file)
  end
end

/// Infer return type for a top-level constant expression.
let infer_constant_type = fn (expr: HirExpr) -> TypeExpr do
  let HirExpr(node: inner, span: _) = expr
  match inner do
    case Literal(lit: l) ->
      match l do
        case LitInt(val: _) -> return TyI64
        case LitFloat(val: _) -> return TyF64
        case LitString(val: _) -> return TyString
        case LitChar(val: _) -> return TyChar
        case LitBool(val: _) -> return TyBool
        case LitUnit -> return TyUnit
      end
    case _ -> return TyI64
  end
end

/// Detect main(args: [string]) pattern and return the arg name for desugaring.
let is_main_with_argv = fn (name: string, params: [HirParam]) -> Option<string> do
  if name == "main" then
    return if let [HirParam(name: arg_name, label: _, typ: TyList(elem: TyString))] = params then
      Some(val: arg_name)
    else None end
  end
  return None
end

let process_top_level = fn (node: TopLevel, span: Span, entries: [RenameEntry], accum: HirAccum, source_file: string) -> HirAccum do
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs) = accum
  match node do
    case TLImport(def: ImportDef(path: path, alias: _, items: _, is_external: is_ext)) ->
      if is_ext then
        let mapped = map_stdlib_to_wit(ext_path: path, source_file: source_file)
        return HirAccum(ports: ps, functions: fs, externals: exts,
          handler_bindings: hbs, enum_defs: eds, wasm_module: Some(val: mapped), exception_groups: egs)
      else
        return accum
      end
    case TLLet(def: GlobalLet(name: name, is_public: _, typ: type_ann, value: val)) ->
      let qname = rename(name: name, entries: entries)
      return process_tl_let(qname: qname, orig_name: name, val: val, type_ann: type_ann, entries: entries,
        span: span, accum: accum, source_file: source_file)
    case TLPort(def: Port(name: pname, is_public: _, functions: sigs)) ->
      let qname = rename(name: pname, entries: entries)
      let hir_port = HirPort(name: qname, methods: convert_port_sigs(sigs: sigs))
      return HirAccum(ports: hir_port :: ps, functions: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
    case TLEnum(def: ed) ->
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs,
        enum_defs: ed :: eds, wasm_module: wmod, exception_groups: egs)
    case TLTypeDef(def: _) -> return accum
    case TLException(def: ExceptionDef(name: ename, is_public: _, fields: efields)) ->
      // Register exception as a variant of the Exn enum (matching Rust compiler's approach).
      // This ensures LIR lowering can resolve field names for sorted heap layout.
      let updated_eds = register_exn_variant(enum_defs: eds, vname: ename, vfields: efields)
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: updated_eds, wasm_module: wmod, exception_groups: egs)
    case TLExceptionGroup(def: ExceptionGroupDef(name: gname, is_public: _, members: gmembers)) ->
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: eds, wasm_module: wmod,
        exception_groups: ExceptionGroupEntry(name: gname, members: gmembers) :: egs)
  end
end

/// Find an existing HirFunction in the accumulator whose unqualified name matches.
/// Qualified names have format "__import_N_name" or "name" (unqualified).
/// Used to find the first import's version of a function for forwarding.
let find_existing_function = fn (name: string, funcs: [HirFunction]) -> Option<string> do
  let dot_suffix = "." ++ name
  match funcs do
    case [] -> return None
    case HirFunction(name: fname, type_params: _, params: _, ret_type: _, body: _, span: _) :: rest ->
      if fname == name || ends_with(s: fname, suffix: dot_suffix) then
        return Some(val: fname)
      else
        return find_existing_function(name: name, funcs: rest)
      end
  end
end

/// Build HirCallArgs from HirParams — for forwarding calls: foo(x: x, y: y)
let params_to_call_args = fn (params: [HirParam]) -> [HirCallArg] do
  match params do
    case [] -> []
    case HirParam(name: n, label: l, typ: _) :: rest ->
      let zero = Span(offset: 0, line: 0, col: 0)
      Cons(v: HirCallArg(label: l, value: HirExpr(node: Variable(name: n, sigil: SigilImmutable), span: zero)),
           rest: params_to_call_args(params: rest))
  end
end

/// Create a forwarding function: fn new_name(params) = return old_name(params)
/// Used for diamond re-imports to avoid re-converting the entire function body.
let make_forwarding_function = fn (new_name: string, orig_name: string, params: [HirParam],
    type_params: [string], ret_type: TypeExpr, span: Span) -> HirFunction do
  let zero = Span(offset: 0, line: 0, col: 0)
  let call_args = params_to_call_args(params: params)
  let call_expr = HirExpr(node: Call(func: orig_name, args: call_args), span: zero)
  let body = [HirStmt(node: Return(expr: call_expr), span: zero)]
  return HirFunction(name: new_name, type_params: type_params, params: params,
    ret_type: ret_type, body: EagerBody(stmts: body), span: span)
end

/// Shallow variant of process_top_level for diamond imports.
/// For Lambda defs: creates forwarding functions instead of re-converting bodies.
/// For Externals: registers directly. For others: delegates to full processing.
let process_top_level_shallow = fn (node: TopLevel, span: Span, entries: [RenameEntry], accum: HirAccum, source_file: string) -> HirAccum do
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs) = accum
  match node do
    case TLImport(def: ImportDef(path: path, alias: _, items: _, is_external: is_ext)) ->
      if is_ext then
        let mapped = map_stdlib_to_wit(ext_path: path, source_file: source_file)
        return HirAccum(ports: ps, functions: fs, externals: exts,
          handler_bindings: hbs, enum_defs: eds, wasm_module: Some(val: mapped), exception_groups: egs)
      else
        return accum
      end
    case TLLet(def: GlobalLet(name: name, is_public: _, typ: type_ann, value: val)) ->
      let qname = rename(name: name, entries: entries)
      // For diamond re-imports: if a function with this name already exists,
      // create a cheap forwarding stub instead of re-converting the entire body.
      // This avoids the 4GB OOM from convert_expr on large Lambda bodies.
      match find_existing_function(name: name, funcs: fs) do
        case Some(val: orig_qname) ->
          // Extract params and return type from AST without converting body
          let SpannedExpr(node: val_node, span: _) = val
          let fwd = match val_node do
            case ExprLambda(type_params: tps, params: ast_params, ret_type: rt, requires: _, throw_row: _, body: _) ->
              let hir_params = convert_params(params: ast_params)
              make_forwarding_function(new_name: qname, orig_name: orig_qname,
                params: hir_params, type_params: tps, ret_type: rt, span: span)
            case ExprExternal(symbol: sym, arg_names: anames, typ: t) ->
              // External: register with original name, no body needed
              // (handled below via process_top_level fallback)
              make_forwarding_function(new_name: qname, orig_name: orig_qname,
                params: [], type_params: [], ret_type: TyUnit, span: span)
            case _ ->
              // Non-function value: create zero-arg forwarding function
              make_forwarding_function(new_name: qname, orig_name: orig_qname,
                params: [], type_params: [], ret_type: TyUnit, span: span)
          end
          return HirAccum(ports: ps, functions: fwd :: fs, externals: exts,
            handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
        case None ->
          // First time seeing this function — fall back to full processing
          return process_top_level(node: node, span: span, entries: entries, accum: accum, source_file: source_file)
      end
    case TLPort(def: _) ->
      return process_top_level(node: node, span: span, entries: entries, accum: accum, source_file: source_file)
    case TLEnum(def: ed) ->
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: ed :: eds, wasm_module: wmod, exception_groups: egs)
    case TLTypeDef(def: _) -> return accum
    case TLException(def: ExceptionDef(name: ename, is_public: _, fields: efields)) ->
      let updated_eds = register_exn_variant(enum_defs: eds, vname: ename, vfields: efields)
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: updated_eds, wasm_module: wmod, exception_groups: egs)
    case TLExceptionGroup(def: ExceptionGroupDef(name: gname, is_public: _, members: gmembers)) ->
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: eds, wasm_module: wmod,
        exception_groups: ExceptionGroupEntry(name: gname, members: gmembers) :: egs)
  end
end

/// Build HirExternal from an external declaration's type arrow.
let make_hir_external = fn (name: string, wasm_module: string, wasm_name: string, arg_names: [string], typ: TypeExpr) -> HirExternal do
  match typ do
    case TyArrow(params: params, ret: ret, requires: _, throw_row: tw) ->
      return HirExternal(name: name, wasm_module: wasm_module, wasm_name: wasm_name,
        params: named_types_to_hir_params(nts: params),
        ret_type: ret, throw_row: tw)
    case _ ->
      return HirExternal(name: name, wasm_module: wasm_module, wasm_name: wasm_name,
        params: [], ret_type: typ, throw_row: TyUnit)
  end
end

let named_types_to_hir_params = fn (nts: [NamedType]) -> [HirParam] do
  return named_types_to_hir_params_go(nts: nts, acc: [])
end

let named_types_to_hir_params_go = fn (nts: [NamedType], acc: [HirParam]) -> [HirParam] do
  match nts do
    case [] -> return rev_hir_param(lst: acc, out: [])
    case NamedType(name: n, typ: t) :: rest ->
      return named_types_to_hir_params_go(nts: rest, acc: HirParam(name: n, label: n, typ: t) :: acc)
  end
end

let convert_port_sigs = fn (sigs: [FunctionSig]) -> [HirPortMethod] do
  return convert_port_sigs_go(sigs: sigs, acc: [])
end

let convert_port_sigs_go = fn (sigs: [FunctionSig], acc: [HirPortMethod]) -> [HirPortMethod] do
  match sigs do
    case [] -> return rev_hir_port_method(lst: acc, out: [])
    case FunctionSig(name: n, params: _, ret_type: _, requires: _, throw_row: _) :: rest ->
      return convert_port_sigs_go(sigs: rest, acc: HirPortMethod(name: n) :: acc)
  end
end

/// Synthesize handler binding: create named function entries for each method.
let synthesize_handler = fn (binding_name: string, port_name: string, functions: [HirFunction]) -> HirHandlerBindingEntry do
  let synth_funcs = synthesize_handler_funcs(binding_name: binding_name, functions: functions)
  return HirHandlerBindingEntry(
    name: binding_name,
    binding: HirHandlerBinding(port_name: port_name, functions: synth_funcs)
  )
end

let synthesize_handler_funcs = fn (binding_name: string, functions: [HirFunction]) -> [HirFunction] do
  return synthesize_handler_funcs_go(binding_name: binding_name, functions: functions, acc: [])
end

let synthesize_handler_funcs_go = fn (binding_name: string, functions: [HirFunction], acc: [HirFunction]) -> [HirFunction] do
  match functions do
    case [] -> return rev_hir_function(lst: acc, out: [])
    case HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, body: b, span: sp) :: rest ->
      let synth_name = handler_func_name(handler_name: binding_name, method_name: n)
      return synthesize_handler_funcs_go(binding_name: binding_name, functions: rest, acc: HirFunction(name: synth_name, type_params: tps, params: ps, ret_type: rt, body: b, span: sp) :: acc)
  end
end

// ─── Exception Group Expansion ──────────────────────────────────────────────
// Post-processing pass: expand group constructor patterns in catch arms.
// When a catch arm matches a group name (e.g., CompileError), expand it to
// one match case per member exception (e.g., LexError, ParseError).

/// Look up a group name and return its members, or None if not a group.
let lookup_group = fn (name: string, groups: [ExceptionGroupEntry]) -> Option<[string]> do
  match groups do
    case [] -> return None
    case ExceptionGroupEntry(name: gn, members: ms) :: rest ->
      if gn == name then return Some(val: ms)
      else return lookup_group(name: name, groups: rest) end
  end
end

/// Expand group patterns in a list of match cases.
/// For each case with a PCtor whose variant is a group name, emit one case per member.
let expand_groups_in_cases = fn (cases: [HirMatchCase], groups: [ExceptionGroupEntry]) -> [HirMatchCase] do
  return expand_groups_in_cases_go(cases: cases, groups: groups, acc: [])
end

let expand_groups_in_cases_go = fn (cases: [HirMatchCase], groups: [ExceptionGroupEntry], acc: [HirMatchCase]) -> [HirMatchCase] do
  match cases do
    case [] -> return rev_hir_match_case(lst: acc, out: [])
    case HirMatchCase(pattern: pat, body: body) :: rest ->
      let expanded_body = expand_groups_in_stmts(stmts: body, groups: groups)
      match pat do
        case PCtor(variant: vname, fields: fs) ->
          match lookup_group(name: vname, groups: groups) do
            case Some(val: members) ->
              // Expand: emit one case per member with the same fields and body
              let member_cases = expand_group_members(members: members, fields: fs, body: expanded_body)
              return expand_groups_in_cases_go(cases: rest, groups: groups,
                acc: prepend_cases(cases: member_cases, acc: acc))
            case None ->
              return expand_groups_in_cases_go(cases: rest, groups: groups,
                acc: HirMatchCase(pattern: PCtor(variant: vname, fields: fs), body: expanded_body) :: acc)
          end
        case _ ->
          return expand_groups_in_cases_go(cases: rest, groups: groups,
            acc: HirMatchCase(pattern: pat, body: expanded_body) :: acc)
      end
  end
end

/// Create one HirMatchCase per member, preserving the same fields and body.
let expand_group_members = fn (members: [string], fields: [HirPatternField], body: [HirStmt]) -> [HirMatchCase] do
  return expand_group_members_go(members: members, fields: fields, body: body, acc: [])
end

let expand_group_members_go = fn (members: [string], fields: [HirPatternField], body: [HirStmt], acc: [HirMatchCase]) -> [HirMatchCase] do
  match members do
    case [] -> return acc
    case m :: rest ->
      return expand_group_members_go(members: rest, fields: fields, body: body,
        acc: HirMatchCase(pattern: PCtor(variant: m, fields: fields), body: body) :: acc)
  end
end

/// Prepend a list of cases onto an accumulator (in order).
let prepend_cases = fn (cases: [HirMatchCase], acc: [HirMatchCase]) -> [HirMatchCase] do
  match cases do
    case [] -> return acc
    case c :: rest -> return prepend_cases(cases: rest, acc: c :: acc)
  end
end

/// Expand group patterns in a list of statements.
let expand_groups_in_stmts = fn (stmts: [HirStmt], groups: [ExceptionGroupEntry]) -> [HirStmt] do
  return expand_groups_in_stmts_go(stmts: stmts, groups: groups, acc: [])
end

let expand_groups_in_stmts_go = fn (stmts: [HirStmt], groups: [ExceptionGroupEntry], acc: [HirStmt]) -> [HirStmt] do
  match stmts do
    case [] -> return rev_hir_stmt(lst: acc, out: [])
    case HirStmt(node: sk, span: sp) :: rest ->
      let expanded = expand_groups_in_stmt_kind(stmt: sk, groups: groups)
      return expand_groups_in_stmts_go(stmts: rest, groups: groups,
        acc: HirStmt(node: expanded, span: sp) :: acc)
  end
end

let expand_groups_in_stmt_kind = fn (stmt: HirStmtKind, groups: [ExceptionGroupEntry]) -> HirStmtKind do
  match stmt do
    case Let(name: n, typ: t, value: v) ->
      return Let(name: n, typ: t, value: expand_groups_in_expr(expr: v, groups: groups))
    case Expr(expr: e) ->
      return Expr(expr: expand_groups_in_expr(expr: e, groups: groups))
    case Return(expr: e) ->
      return Return(expr: expand_groups_in_expr(expr: e, groups: groups))
    case Assign(target: t, value: v) ->
      return Assign(
        target: expand_groups_in_expr(expr: t, groups: groups),
        value: expand_groups_in_expr(expr: v, groups: groups))
    case Try(body: b, catch_param: cp, catch_body: cb) ->
      return Try(
        body: expand_groups_in_stmts(stmts: b, groups: groups),
        catch_param: cp,
        catch_body: expand_groups_in_stmts(stmts: cb, groups: groups))
    case Inject(handlers: hs, body: b) ->
      return Inject(handlers: hs, body: expand_groups_in_stmts(stmts: b, groups: groups))
  end
end

let expand_groups_in_expr = fn (expr: HirExpr, groups: [ExceptionGroupEntry]) -> HirExpr do
  let HirExpr(node: inner, span: sp) = expr
  return HirExpr(node: expand_groups_in_expr_kind(expr: inner, groups: groups), span: sp)
end

let expand_groups_in_expr_kind = fn (expr: HirExprKind, groups: [ExceptionGroupEntry]) -> HirExprKind do
  match expr do
    case Literal(lit: l) -> return Literal(lit: l)
    case Variable(name: n, sigil: s) -> return Variable(name: n, sigil: s)
    case BinOp(left: l, op: o, right: r) ->
      return BinOp(
        left: expand_groups_in_expr(expr: l, groups: groups),
        op: o,
        right: expand_groups_in_expr(expr: r, groups: groups))
    case Borrow(name: n, sigil: s) -> return Borrow(name: n, sigil: s)
    case Call(func: f, args: args) ->
      return Call(func: f, args: expand_groups_in_call_args(args: args, groups: groups))
    case Ctor(variant: v, args: args) ->
      return Ctor(variant: v, args: expand_groups_in_expr_list(exprs: args, groups: groups))
    case Record(fields: fs) ->
      return Record(fields: expand_groups_in_named_exprs(exprs: fs, groups: groups))
    case Array(elems: es) ->
      return Array(elems: expand_groups_in_expr_list(exprs: es, groups: groups))
    case Index(target: t, index: i) ->
      return Index(
        target: expand_groups_in_expr(expr: t, groups: groups),
        index: expand_groups_in_expr(expr: i, groups: groups))
    case FieldAccess(target: t, field: f) ->
      return FieldAccess(target: expand_groups_in_expr(expr: t, groups: groups), field: f)
    case If(cond: c, then_branch: tb, else_branch: eb) ->
      let new_eb = match eb do
        case None -> None
        case Some(val: stmts) -> Some(val: expand_groups_in_stmts(stmts: stmts, groups: groups))
      end
      return If(
        cond: expand_groups_in_expr(expr: c, groups: groups),
        then_branch: expand_groups_in_stmts(stmts: tb, groups: groups),
        else_branch: new_eb)
    case Match(target: t, cases: cs) ->
      return Match(
        target: expand_groups_in_expr(expr: t, groups: groups),
        cases: expand_groups_in_cases(cases: cs, groups: groups))
    case While(cond: c, body: b) ->
      return While(
        cond: expand_groups_in_expr(expr: c, groups: groups),
        body: expand_groups_in_stmts(stmts: b, groups: groups))
    case For(var: v, start: s, end_expr: e, body: b) ->
      return For(var: v,
        start: expand_groups_in_expr(expr: s, groups: groups),
        end_expr: expand_groups_in_expr(expr: e, groups: groups),
        body: expand_groups_in_stmts(stmts: b, groups: groups))
    case Lambda(type_params: tps, params: ps, ret_type: rt, body: b) ->
      return Lambda(type_params: tps, params: ps, ret_type: rt,
        body: expand_groups_in_stmts(stmts: b, groups: groups))
    case Raise(expr: e) ->
      return Raise(expr: expand_groups_in_expr(expr: e, groups: groups))
    case Force(expr: e) ->
      return Force(expr: expand_groups_in_expr(expr: e, groups: groups))
    case ExternalRef(symbol: s, arg_names: an, typ: t) ->
      return ExternalRef(symbol: s, arg_names: an, typ: t)
    case Handler(port_name: pn, functions: fs) ->
      return Handler(port_name: pn, functions: expand_groups_in_hir_functions(funcs: fs, groups: groups))
  end
end

let expand_groups_in_call_args = fn (args: [HirCallArg], groups: [ExceptionGroupEntry]) -> [HirCallArg] do
  return expand_groups_in_call_args_go(args: args, groups: groups, acc: [])
end

let expand_groups_in_call_args_go = fn (args: [HirCallArg], groups: [ExceptionGroupEntry], acc: [HirCallArg]) -> [HirCallArg] do
  match args do
    case [] -> return rev_hir_call_arg(lst: acc, out: [])
    case HirCallArg(label: l, value: v) :: rest ->
      return expand_groups_in_call_args_go(args: rest, groups: groups,
        acc: HirCallArg(label: l, value: expand_groups_in_expr(expr: v, groups: groups)) :: acc)
  end
end

let expand_groups_in_expr_list = fn (exprs: [HirExpr], groups: [ExceptionGroupEntry]) -> [HirExpr] do
  return expand_groups_in_expr_list_go(exprs: exprs, groups: groups, acc: [])
end

let expand_groups_in_expr_list_go = fn (exprs: [HirExpr], groups: [ExceptionGroupEntry], acc: [HirExpr]) -> [HirExpr] do
  match exprs do
    case [] -> return rev_hir_expr(lst: acc, out: [])
    case e :: rest ->
      return expand_groups_in_expr_list_go(exprs: rest, groups: groups,
        acc: expand_groups_in_expr(expr: e, groups: groups) :: acc)
  end
end

let expand_groups_in_named_exprs = fn (exprs: [HirNamedExpr], groups: [ExceptionGroupEntry]) -> [HirNamedExpr] do
  return expand_groups_in_named_exprs_go(exprs: exprs, groups: groups, acc: [])
end

let expand_groups_in_named_exprs_go = fn (exprs: [HirNamedExpr], groups: [ExceptionGroupEntry], acc: [HirNamedExpr]) -> [HirNamedExpr] do
  match exprs do
    case [] -> return rev_hir_named_expr(lst: acc, out: [])
    case HirNamedExpr(name: n, value: v) :: rest ->
      return expand_groups_in_named_exprs_go(exprs: rest, groups: groups,
        acc: HirNamedExpr(name: n, value: expand_groups_in_expr(expr: v, groups: groups)) :: acc)
  end
end

/// Expand groups in a list of HirFunctions.
let expand_groups_in_hir_functions = fn (funcs: [HirFunction], groups: [ExceptionGroupEntry]) -> [HirFunction] do
  return expand_groups_in_hir_functions_go(funcs: funcs, groups: groups, acc: [])
end

let expand_groups_in_hir_functions_go = fn (funcs: [HirFunction], groups: [ExceptionGroupEntry], acc: [HirFunction]) -> [HirFunction] do
  match funcs do
    case [] -> return rev_hir_function(lst: acc, out: [])
    case HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, body: EagerBody(stmts: b), span: sp) :: rest ->
      return expand_groups_in_hir_functions_go(funcs: rest, groups: groups,
        acc: HirFunction(name: n, type_params: tps, params: ps, ret_type: rt,
          body: EagerBody(stmts: expand_groups_in_stmts(stmts: b, groups: groups)), span: sp) :: acc)
    case HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, body: b, span: sp) :: rest ->
      // LazyBody: no stmts to expand, preserve as-is
      return expand_groups_in_hir_functions_go(funcs: rest, groups: groups,
        acc: HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, body: b, span: sp) :: acc)
  end
end

/// Top-level: expand groups in all program functions.
let expand_groups_in_functions = fn (funcs: [HirFunction], groups: [ExceptionGroupEntry]) -> [HirFunction] do
  match groups do
    case [] -> return funcs
    case _ :: _ -> return expand_groups_in_hir_functions(funcs: funcs, groups: groups)
  end
end

/// Top-level: expand groups in handler bindings.
let expand_groups_in_handler_bindings = fn (bindings: [HirHandlerBindingEntry], groups: [ExceptionGroupEntry]) -> [HirHandlerBindingEntry] do
  match groups do
    case [] -> return bindings
    case _ :: _ -> return expand_groups_in_handler_bindings_go(bindings: bindings, groups: groups, acc: [])
  end
end

let expand_groups_in_handler_bindings_go = fn (bindings: [HirHandlerBindingEntry], groups: [ExceptionGroupEntry], acc: [HirHandlerBindingEntry]) -> [HirHandlerBindingEntry] do
  match bindings do
    case [] -> return rev_hir_handler_binding_entry(lst: acc, out: [])
    case HirHandlerBindingEntry(name: n, binding: HirHandlerBinding(port_name: pn, functions: fs)) :: rest ->
      let expanded_fs = expand_groups_in_hir_functions(funcs: fs, groups: groups)
      return expand_groups_in_handler_bindings_go(bindings: rest, groups: groups,
        acc: HirHandlerBindingEntry(name: n, binding: HirHandlerBinding(port_name: pn, functions: expanded_fs)) :: acc)
  end
end

// ─── Reachability Analysis ──────────────────────────────────────────────────

/// Collect all function names called from a list of HIR statements.
export let collect_calls_stmts = fn (stmts: [HirStmt]) -> [string] do
  return collect_calls_stmts_go(stmts: stmts, acc: [])
end

let collect_calls_stmts_go = fn (stmts: [HirStmt], acc: [string]) -> [string] do
  match stmts do
    case [] -> return acc
    case HirStmt(node: s, span: _) :: rest ->
      let calls = collect_calls_stmt_kind(stmt: s)
      return collect_calls_stmts_go(stmts: rest, acc: concat_str_lists(a: calls, b: acc))
  end
end

let collect_calls_stmt_kind = fn (stmt: HirStmtKind) -> [string] do
  match stmt do
    case Let(name: _, typ: _, value: v) -> return collect_calls_expr(expr: v)
    case Expr(expr: e) -> return collect_calls_expr(expr: e)
    case Return(expr: e) -> return collect_calls_expr(expr: e)
    case Assign(target: t, value: v) ->
      return concat_str_lists(a: collect_calls_expr(expr: t), b: collect_calls_expr(expr: v))
    case Try(body: b, catch_param: _, catch_body: cb) ->
      return concat_str_lists(a: collect_calls_stmts(stmts: b), b: collect_calls_stmts(stmts: cb))
    case Inject(handlers: hs, body: b) ->
      return concat_str_lists(a: hs, b: collect_calls_stmts(stmts: b))
  end
end

let collect_calls_expr = fn (expr: HirExpr) -> [string] do
  let HirExpr(node: inner, span: _) = expr
  return collect_calls_expr_kind(expr: inner)
end

let collect_calls_expr_kind = fn (expr: HirExprKind) -> [string] do
  match expr do
    case Literal(lit: _) -> return []
    case Variable(name: n, sigil: _) -> return [n]
    case BinOp(left: l, op: _, right: r) ->
      return concat_str_lists(a: collect_calls_expr(expr: l), b: collect_calls_expr(expr: r))
    case Borrow(name: _, sigil: _) -> return []
    case Call(func: f, args: args) ->
      return f :: collect_calls_args(args: args)
    case Ctor(variant: _, args: args) -> return collect_calls_expr_list(exprs: args)
    case Record(fields: fs) -> return collect_calls_named_exprs(exprs: fs)
    case Array(elems: es) -> return collect_calls_expr_list(exprs: es)
    case Index(target: t, index: i) ->
      return concat_str_lists(a: collect_calls_expr(expr: t), b: collect_calls_expr(expr: i))
    case FieldAccess(target: t, field: _) -> return collect_calls_expr(expr: t)
    case If(cond: c, then_branch: tb, else_branch: eb) ->
      let base = concat_str_lists(a: collect_calls_expr(expr: c), b: collect_calls_stmts(stmts: tb))
      match eb do
        case Some(val: stmts) -> return concat_str_lists(a: base, b: collect_calls_stmts(stmts: stmts))
        case None -> return base
      end
    case Match(target: t, cases: cs) ->
      return concat_str_lists(a: collect_calls_expr(expr: t), b: collect_calls_cases(cases: cs))
    case While(cond: c, body: b) ->
      return concat_str_lists(a: collect_calls_expr(expr: c), b: collect_calls_stmts(stmts: b))
    case For(var: _, start: s, end_expr: e, body: b) ->
      return concat_str_lists(
        a: collect_calls_expr(expr: s),
        b: concat_str_lists(a: collect_calls_expr(expr: e), b: collect_calls_stmts(stmts: b))
      )
    case Lambda(type_params: _, params: _, ret_type: _, body: b) -> return collect_calls_stmts(stmts: b)
    case Raise(expr: e) -> return collect_calls_expr(expr: e)
    case Force(expr: e) -> return collect_calls_expr(expr: e)
    case ExternalRef(symbol: _, arg_names: _, typ: _) -> return []
    case Handler(port_name: _, functions: fs) -> return collect_calls_functions(funcs: fs)
  end
end

let collect_calls_args = fn (args: [HirCallArg]) -> [string] do
  return collect_calls_args_go(args: args, acc: [])
end

let collect_calls_args_go = fn (args: [HirCallArg], acc: [string]) -> [string] do
  match args do
    case [] -> return acc
    case HirCallArg(label: _, value: v) :: rest ->
      return collect_calls_args_go(args: rest, acc: concat_str_lists(a: collect_calls_expr(expr: v), b: acc))
  end
end

let collect_calls_named_exprs = fn (exprs: [HirNamedExpr]) -> [string] do
  return collect_calls_named_exprs_go(exprs: exprs, acc: [])
end

let collect_calls_named_exprs_go = fn (exprs: [HirNamedExpr], acc: [string]) -> [string] do
  match exprs do
    case [] -> return acc
    case HirNamedExpr(name: _, value: v) :: rest ->
      return collect_calls_named_exprs_go(exprs: rest, acc: concat_str_lists(a: collect_calls_expr(expr: v), b: acc))
  end
end

let collect_calls_expr_list = fn (exprs: [HirExpr]) -> [string] do
  return collect_calls_expr_list_go(exprs: exprs, acc: [])
end

let collect_calls_expr_list_go = fn (exprs: [HirExpr], acc: [string]) -> [string] do
  match exprs do
    case [] -> return acc
    case e :: rest ->
      return collect_calls_expr_list_go(exprs: rest, acc: concat_str_lists(a: collect_calls_expr(expr: e), b: acc))
  end
end

let collect_calls_cases = fn (cases: [HirMatchCase]) -> [string] do
  return collect_calls_cases_go(cases: cases, acc: [])
end

let collect_calls_cases_go = fn (cases: [HirMatchCase], acc: [string]) -> [string] do
  match cases do
    case [] -> return acc
    case HirMatchCase(pattern: _, body: b) :: rest ->
      return collect_calls_cases_go(cases: rest, acc: concat_str_lists(a: collect_calls_stmts(stmts: b), b: acc))
  end
end

let collect_calls_functions = fn (funcs: [HirFunction]) -> [string] do
  return collect_calls_functions_go(funcs: funcs, acc: [])
end

let collect_calls_functions_go = fn (funcs: [HirFunction], acc: [string]) -> [string] do
  match funcs do
    case [] -> return acc
    case HirFunction(name: _, type_params: _, params: _, ret_type: _, body: EagerBody(stmts: b), span: _) :: rest ->
      return collect_calls_functions_go(funcs: rest, acc: concat_str_lists(a: collect_calls_stmts(stmts: b), b: acc))
    case HirFunction(name: _, type_params: _, params: _, ret_type: _, body: LazyBody(ast_expr: _, entries: _), span: _) :: rest ->
      // LazyBody: no converted stmts to analyze, treat as empty
      return collect_calls_functions_go(funcs: rest, acc: acc)
  end
end

/// Worklist reachability: starting from "main", collect all transitively called functions.
export let collect_reachable = fn (functions: [HirFunction], handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  // Seed worklist with main + all handler binding names + all calls from handler functions.
  // Handler functions are not in the regular functions list, so their transitive
  // dependencies must be seeded explicitly.
  let handler_seeds = collect_handler_seeds(bindings: handler_bindings, acc: [])
  let worklist = concat_str_lists(a: ["main"], b: handler_seeds)
  return reachable_go(worklist: worklist, visited: [], functions: functions, handler_bindings: handler_bindings)
end

let collect_handler_seeds = fn (bindings: [HirHandlerBindingEntry], acc: [string]) -> [string] do
  match bindings do
    case [] -> return acc
    case HirHandlerBindingEntry(name: bname, binding: HirHandlerBinding(port_name: _, functions: fs)) :: rest ->
      let calls = collect_calls_functions(funcs: fs)
      return collect_handler_seeds(bindings: rest, acc: concat_str_lists(a: bname :: calls, b: acc))
  end
end

let reachable_go = fn (worklist: [string], visited: [string], functions: [HirFunction], handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  match worklist do
    case [] -> return visited
    case name :: rest ->
      if str_in_list(s: name, xs: visited) then
        return reachable_go(worklist: rest, visited: visited, functions: functions, handler_bindings: handler_bindings)
      else
        let new_visited = name :: visited
        let calls = find_calls_for_name(name: name, functions: functions, handler_bindings: handler_bindings)
        let new_worklist = concat_str_lists(a: calls, b: rest)
        return reachable_go(worklist: new_worklist, visited: new_visited, functions: functions, handler_bindings: handler_bindings)
      end
  end
end

let find_calls_for_name = fn (name: string, functions: [HirFunction], handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  let func = find_function(name: name, functions: functions)
  match func do
    case Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, body: EagerBody(stmts: b), span: _)) ->
      return collect_calls_stmts(stmts: b)
    case Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, body: LazyBody(ast_expr: _, entries: _), span: _)) ->
      // LazyBody: no converted stmts to analyze
      return []
    case None ->
      return find_calls_in_handlers(name: name, bindings: handler_bindings)
  end
end

let find_function = fn (name: string, functions: [HirFunction]) -> Option<HirFunction> do
  match functions do
    case [] -> return None
    case f :: rest ->
      let HirFunction(name: n, type_params: _, params: _, ret_type: _, body: _, span: _) = f
      if n == name then return Some(val: f)
      else return find_function(name: name, functions: rest)
      end
  end
end

let find_calls_in_handlers = fn (name: string, bindings: [HirHandlerBindingEntry]) -> [string] do
  match bindings do
    case [] -> return []
    case HirHandlerBindingEntry(name: bname, binding: HirHandlerBinding(port_name: _, functions: fs)) :: rest ->
      if bname == name then
        return collect_calls_functions(funcs: fs)
      else
        let found = find_function(name: name, functions: fs)
        match found do
          case Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, body: EagerBody(stmts: body), span: _)) ->
            return collect_calls_stmts(stmts: body)
          case Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, body: LazyBody(ast_expr: _, entries: _), span: _)) ->
            // LazyBody: no converted stmts to analyze
            return []
          case None -> return find_calls_in_handlers(name: name, bindings: rest)
        end
      end
  end
end

/// Filter functions to only reachable ones.
export let filter_reachable_functions = fn (functions: [HirFunction], reachable: [string]) -> [HirFunction] do
  return filter_reachable_functions_go(functions: functions, reachable: reachable, acc: [])
end

let filter_reachable_functions_go = fn (functions: [HirFunction], reachable: [string], acc: [HirFunction]) -> [HirFunction] do
  match functions do
    case [] -> return rev_hir_function(lst: acc, out: [])
    case f :: rest ->
      let HirFunction(name: n, type_params: _, params: _, ret_type: _, body: _, span: _) = f
      if str_in_list(s: n, xs: reachable) then
        return filter_reachable_functions_go(functions: rest, reachable: reachable, acc: f :: acc)
      else
        return filter_reachable_functions_go(functions: rest, reachable: reachable, acc: acc)
      end
  end
end

/// Filter externals to only reachable ones.
export let filter_reachable_externals = fn (externals: [HirExternal], reachable: [string]) -> [HirExternal] do
  return filter_reachable_externals_go(externals: externals, reachable: reachable, acc: [])
end

let filter_reachable_externals_go = fn (externals: [HirExternal], reachable: [string], acc: [HirExternal]) -> [HirExternal] do
  match externals do
    case [] -> return rev_hir_external(lst: acc, out: [])
    case ext :: rest ->
      let HirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) = ext
      if str_in_list(s: n, xs: reachable) then
        return filter_reachable_externals_go(externals: rest, reachable: reachable, acc: ext :: acc)
      else
        return filter_reachable_externals_go(externals: rest, reachable: reachable, acc: acc)
      end
  end
end

let filter_reachable_handlers = fn (bindings: [HirHandlerBindingEntry], reachable: [string]) -> [HirHandlerBindingEntry] do
  return filter_reachable_handlers_go(bindings: bindings, reachable: reachable, acc: [])
end

let filter_reachable_handlers_go = fn (bindings: [HirHandlerBindingEntry], reachable: [string], acc: [HirHandlerBindingEntry]) -> [HirHandlerBindingEntry] do
  match bindings do
    case [] -> return rev_hir_handler_binding_entry(lst: acc, out: [])
    case hbe :: rest ->
      let HirHandlerBindingEntry(name: n, binding: _) = hbe
      if str_in_list(s: n, xs: reachable) then
        return filter_reachable_handlers_go(bindings: rest, reachable: reachable, acc: hbe :: acc)
      else
        return filter_reachable_handlers_go(bindings: rest, reachable: reachable, acc: acc)
      end
  end
end

/// Assemble a HirProgram from an accumulator with reachability filtering.
export let accum_to_program = fn (accum: HirAccum) -> HirProgram do
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: _, exception_groups: egs) = accum
  // Expand exception group patterns in catch arms before reachability filtering.
  let expanded_fs = expand_groups_in_functions(funcs: fs, groups: egs)
  let expanded_hbs = expand_groups_in_handler_bindings(bindings: hbs, groups: egs)
  let filtered_funcs = expanded_fs
  let filtered_exts = exts
  // Note: LazyBody functions are NOT resolved here. The caller (driver.nx)
  // resolves them after accum_to_program returns, because resolution requires
  // Fs capability to re-read source files.
  let resolved_funcs = filtered_funcs
  // Handler bindings are not filtered (matching Rust compiler behavior).
  return HirProgram(
    ports: ps,
    functions: resolved_funcs,
    externals: filtered_exts,
    handler_bindings: expanded_hbs,
    enum_defs: eds
  )
end

/// Resolve a single lazy body given AST stmts already extracted.
export let resolve_one_lazy = fn (ast_stmts: [SpannedStmt], entries: [RenameEntry]) -> [HirStmt] do
  return convert_stmts(stmts: ast_stmts, entries: entries)
end

// ─── String list helpers ────────────────────────────────────────────────────

let concat_str_lists = fn (a: [string], b: [string]) -> [string] do
  return concat_str_lists_go(a: a, b: b, acc: [])
end

let concat_str_lists_go = fn (a: [string], b: [string], acc: [string]) -> [string] do
  match a do
    case [] -> return rev_string(lst: acc, out: b)
    case x :: rest ->
      return concat_str_lists_go(a: rest, b: b, acc: x :: acc)
  end
end

let str_in_list = fn (s: string, xs: [string]) -> bool do
  match xs do
    case [] -> return false
    case x :: rest ->
      if x == s then return true
      else return str_in_list(s: s, xs: rest)
      end
  end
end

// ─── Monomorphic reverse helpers (list.reverse has codegen issues in nxc) ────

let rev_string = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_string(lst: rest, out: x :: out)
  end
end

let rev_hir_call_arg = fn (lst: [HirCallArg], out: [HirCallArg]) -> [HirCallArg] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_hir_call_arg(lst: rest, out: x :: out)
  end
end

