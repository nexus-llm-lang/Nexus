/**
 * subst: Type substitution, free variables, and occurs check.
 *
 * Core type manipulation primitives used by unification and scheme operations.
 */

import { TypeExpr, NamedType } from nxc/common/ast.nx

// ─── Substitution ───────────────────────────────────────────────────────────

pub type SubstEntry = SubstEntry(var: string, typ: TypeExpr)

let subst_lookup = fn (subst: [SubstEntry], var: string) -> Option<TypeExpr> do
  match subst
    case Nil() -> None()
    case Cons(v: SubstEntry(var: v, typ: t), rest: rest) ->
      if v == var then Some(val: t)
      else subst_lookup(subst: rest, var: var)
      end
  end
end

pub let apply_subst = fn (subst: [SubstEntry], typ: TypeExpr) -> TypeExpr do
  match typ
    case TyVar(name: n) ->
      match subst_lookup(subst: subst, var: n)
        case Some(val: t) -> t
        case None() -> typ
      end
    case TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      TyArrow(params: apply_subst_named_types(subst: subst, nts: ps),
              ret: apply_subst(subst: subst, typ: r),
              requires: apply_subst(subst: subst, typ: req),
              throw_row: apply_subst(subst: subst, typ: thr))
    case TyUserDefined(name: n, args: args) ->
      TyUserDefined(name: n, args: apply_subst_list(subst: subst, types: args))
    case TyRef(inner: i) -> TyRef(inner: apply_subst(subst: subst, typ: i))
    case TyLinear(inner: i) -> TyLinear(inner: apply_subst(subst: subst, typ: i))
    case TyBorrow(inner: i) -> TyBorrow(inner: apply_subst(subst: subst, typ: i))
    case TyArray(elem: e) -> TyArray(elem: apply_subst(subst: subst, typ: e))
    case TyList(elem: e) -> TyList(elem: apply_subst(subst: subst, typ: e))
    case TyRecord(fields: fs) -> TyRecord(fields: apply_subst_named_types(subst: subst, nts: fs))
    case TyRow(types: es, rest: tail) ->
      let new_tail = match tail
        case Some(val: t) -> Some(val: apply_subst(subst: subst, typ: t))
        case None() -> None()
      end
      TyRow(types: apply_subst_list(subst: subst, types: es), rest: new_tail)
    case TyHandler(name: n, requires: req) ->
      TyHandler(name: n, requires: apply_subst(subst: subst, typ: req))
    case _ -> typ
  end
end

pub let apply_subst_list = fn (subst: [SubstEntry], types: [TypeExpr]) -> [TypeExpr] do
  match types
    case Nil() -> Nil()
    case Cons(v: t, rest: rest) ->
      Cons(v: apply_subst(subst: subst, typ: t), rest: apply_subst_list(subst: subst, types: rest))
  end
end

pub let apply_subst_named_types = fn (subst: [SubstEntry], nts: [NamedType]) -> [NamedType] do
  match nts
    case Nil() -> Nil()
    case Cons(v: NamedType(name: n, typ: t), rest: rest) ->
      Cons(v: NamedType(name: n, typ: apply_subst(subst: subst, typ: t)),
           rest: apply_subst_named_types(subst: subst, nts: rest))
  end
end

// ─── Substitution composition ───────────────────────────────────────────────

let subst_has_key = fn (subst: [SubstEntry], var: string) -> bool do
  match subst
    case Nil() -> false
    case Cons(v: SubstEntry(var: v, typ: _), rest: rest) ->
      if v == var then true
      else subst_has_key(subst: rest, var: var)
      end
  end
end

let apply_subst_to_entries = fn (s2: [SubstEntry], entries: [SubstEntry]) -> [SubstEntry] do
  match entries
    case Nil() -> Nil()
    case Cons(v: SubstEntry(var: v, typ: t), rest: rest) ->
      Cons(v: SubstEntry(var: v, typ: apply_subst(subst: s2, typ: t)),
           rest: apply_subst_to_entries(s2: s2, entries: rest))
  end
end

let merge_subst_entries = fn (base: [SubstEntry], extra: [SubstEntry]) -> [SubstEntry] do
  match extra
    case Nil() -> base
    case Cons(v: entry, rest: rest) ->
      match entry case SubstEntry(var: v, typ: _) ->
        if subst_has_key(subst: base, var: v) then merge_subst_entries(base: base, extra: rest)
        else merge_subst_entries(base: Cons(v: entry, rest: base), extra: rest)
        end
      end
  end
end

pub let compose_subst = fn (s1: [SubstEntry], s2: [SubstEntry]) -> [SubstEntry] do
  return merge_subst_entries(base: apply_subst_to_entries(s2: s2, entries: s1), extra: s2)
end

pub let empty_subst = fn () -> [SubstEntry] do
  return Nil()
end

pub let singleton_subst = fn (var: string, typ: TypeExpr) -> [SubstEntry] do
  return Cons(v: SubstEntry(var: var, typ: typ), rest: Nil())
end

// ─── String list helpers ────────────────────────────────────────────────────

pub let concat_strings = fn (a: [string], b: [string]) -> [string] do
  match a
    case Nil() -> b
    case Cons(v: x, rest: rest) -> Cons(v: x, rest: concat_strings(a: rest, b: b))
  end
end

pub let string_in_list = fn (s: string, xs: [string]) -> bool do
  match xs
    case Nil() -> false
    case Cons(v: x, rest: rest) ->
      if x == s then true
      else string_in_list(s: s, xs: rest)
      end
  end
end

let dedup_strings_go = fn (xs: [string], seen: [string]) -> [string] do
  match xs
    case Nil() -> Nil()
    case Cons(v: x, rest: rest) ->
      if string_in_list(s: x, xs: seen) then dedup_strings_go(xs: rest, seen: seen)
      else Cons(v: x, rest: dedup_strings_go(xs: rest, seen: Cons(v: x, rest: seen)))
      end
  end
end

pub let dedup_strings = fn (xs: [string]) -> [string] do
  return dedup_strings_go(xs: xs, seen: Nil())
end

pub let subtract_strings = fn (as_: [string], bs: [string]) -> [string] do
  match as_
    case Nil() -> Nil()
    case Cons(v: x, rest: rest) ->
      if string_in_list(s: x, xs: bs) then subtract_strings(as_: rest, bs: bs)
      else Cons(v: x, rest: subtract_strings(as_: rest, bs: bs))
      end
  end
end

// ─── Free variables ─────────────────────────────────────────────────────────

let free_vars_go = fn (typ: TypeExpr) -> [string] do
  match typ
    case TyVar(name: n) -> Cons(v: n, rest: Nil())
    case TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      concat_strings(a: free_vars_named_types(nts: ps),
        b: concat_strings(a: free_vars_go(typ: r),
          b: concat_strings(a: free_vars_go(typ: req), b: free_vars_go(typ: thr))))
    case TyUserDefined(name: _, args: args) -> free_vars_list(types: args)
    case TyRef(inner: i) -> free_vars_go(typ: i)
    case TyLinear(inner: i) -> free_vars_go(typ: i)
    case TyBorrow(inner: i) -> free_vars_go(typ: i)
    case TyArray(elem: e) -> free_vars_go(typ: e)
    case TyList(elem: e) -> free_vars_go(typ: e)
    case TyRecord(fields: fs) -> free_vars_named_types(nts: fs)
    case TyRow(types: es, rest: tail) ->
      match tail
        case Some(val: t) -> concat_strings(a: free_vars_list(types: es), b: free_vars_go(typ: t))
        case None() -> free_vars_list(types: es)
      end
    case TyHandler(name: _, requires: req) -> free_vars_go(typ: req)
    case _ -> Nil()
  end
end

let free_vars_list = fn (types: [TypeExpr]) -> [string] do
  match types
    case Nil() -> Nil()
    case Cons(v: t, rest: rest) ->
      concat_strings(a: free_vars_go(typ: t), b: free_vars_list(types: rest))
  end
end

let free_vars_named_types = fn (nts: [NamedType]) -> [string] do
  match nts
    case Nil() -> Nil()
    case Cons(v: NamedType(name: _, typ: t), rest: rest) ->
      concat_strings(a: free_vars_go(typ: t), b: free_vars_named_types(nts: rest))
  end
end

pub let free_vars = fn (typ: TypeExpr) -> [string] do
  return dedup_strings(xs: free_vars_go(typ: typ))
end

// ─── Occurs check ───────────────────────────────────────────────────────────

pub let occurs_check = fn (var: string, typ: TypeExpr) -> bool do
  match typ
    case TyVar(name: n) -> n == var
    case TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      occurs_check(var: var, typ: r)
      || occurs_check_named_types(var: var, nts: ps)
      || occurs_check(var: var, typ: req)
      || occurs_check(var: var, typ: thr)
    case TyUserDefined(name: _, args: args) -> occurs_check_list(var: var, types: args)
    case TyRef(inner: i) -> occurs_check(var: var, typ: i)
    case TyLinear(inner: i) -> occurs_check(var: var, typ: i)
    case TyBorrow(inner: i) -> occurs_check(var: var, typ: i)
    case TyArray(elem: e) -> occurs_check(var: var, typ: e)
    case TyList(elem: e) -> occurs_check(var: var, typ: e)
    case TyRecord(fields: fs) -> occurs_check_named_types(var: var, nts: fs)
    case TyRow(types: es, rest: tail) ->
      if occurs_check_list(var: var, types: es) then true
      else match tail
        case Some(val: t) -> occurs_check(var: var, typ: t)
        case None() -> false
      end end
    case TyHandler(name: _, requires: req) -> occurs_check(var: var, typ: req)
    case _ -> false
  end
end

let occurs_check_list = fn (var: string, types: [TypeExpr]) -> bool do
  match types
    case Nil() -> false
    case Cons(v: t, rest: rest) ->
      if occurs_check(var: var, typ: t) then true
      else occurs_check_list(var: var, types: rest)
      end
  end
end

let occurs_check_named_types = fn (var: string, nts: [NamedType]) -> bool do
  match nts
    case Nil() -> false
    case Cons(v: NamedType(name: _, typ: t), rest: rest) ->
      if occurs_check(var: var, typ: t) then true
      else occurs_check_named_types(var: var, nts: rest)
      end
  end
end
