/**
 * typecheck/subst: Type substitution operations.
 *
 * Association-list based substitution: apply, compose, lookup.
 * Also provides structural type equality (type_eq) since Nexus == only
 * works on primitives.
 */

import {
  TypeExpr, TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyBorrow,
  TyArray, TyList, TyRecord, TyRow, TyHandler, NamedType
} from "nxc/common/ast.nx"
import { SubstEntry, Scheme, EnvEntry } from "nxc/typecheck/types.nx"

// ─── Substitution primitives ────────────────────────────────────────────────

export let subst_empty = fn () -> [SubstEntry] do
  return Nil
end

export let subst_single = fn (var: string, typ: TypeExpr) -> [SubstEntry] do
  return Cons(v: SubstEntry(var: var, typ: typ), rest: Nil)
end

export let subst_lookup = fn (subst: [SubstEntry], var: string) -> Option<TypeExpr> do
  match subst do
    case Nil -> return None
    case SubstEntry(var: v, typ: t) :: rest ->
      if v == var then
        return Some(val: t)
      end
      return subst_lookup(subst: rest, var: var)
  end
end

// ─── Apply substitution to a type ───────────────────────────────────────────

export let subst_apply = fn (subst: [SubstEntry], typ: TypeExpr) -> TypeExpr do
  match typ do
    case TyVar(name: n) ->
      match subst_lookup(subst: subst, var: n) do
        case Some(val: t) -> return t
        case None -> return typ
      end
    case TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return TyArrow(
        params: apply_named_types(subst: subst, nts: ps),
        ret: subst_apply(subst: subst, typ: r),
        requires: subst_apply(subst: subst, typ: req),
        throw_row: subst_apply(subst: subst, typ: thr)
      )
    case TyUserDefined(name: n, args: args) ->
      return TyUserDefined(name: n, args: apply_type_list(subst: subst, types: args))
    case TyRef(inner: i) -> return TyRef(inner: subst_apply(subst: subst, typ: i))
    case TyLinear(inner: i) -> return TyLinear(inner: subst_apply(subst: subst, typ: i))
    case TyBorrow(inner: i) -> return TyBorrow(inner: subst_apply(subst: subst, typ: i))
    case TyArray(elem: e) -> return TyArray(elem: subst_apply(subst: subst, typ: e))
    case TyList(elem: e) -> return TyList(elem: subst_apply(subst: subst, typ: e))
    case TyRecord(fields: fs) ->
      return TyRecord(fields: apply_named_types(subst: subst, nts: fs))
    case TyRow(types: ts, rest: r) ->
      let new_rest = match r do
        case Some(val: t) -> Some(val: subst_apply(subst: subst, typ: t))
        case None -> None
      end
      return TyRow(types: apply_type_list(subst: subst, types: ts), rest: new_rest)
    case TyHandler(name: n, requires: req) ->
      return TyHandler(name: n, requires: subst_apply(subst: subst, typ: req))
    case _ -> return typ
  end
end

let apply_named_types = fn (subst: [SubstEntry], nts: [NamedType]) -> [NamedType] do
  match nts do
    case Nil -> return Nil
    case NamedType(name: n, typ: t) :: rest ->
      return Cons(
        v: NamedType(name: n, typ: subst_apply(subst: subst, typ: t)),
        rest: apply_named_types(subst: subst, nts: rest)
      )
  end
end

let apply_type_list = fn (subst: [SubstEntry], types: [TypeExpr]) -> [TypeExpr] do
  match types do
    case Nil -> return Nil
    case t :: rest ->
      return Cons(
        v: subst_apply(subst: subst, typ: t),
        rest: apply_type_list(subst: subst, types: rest)
      )
  end
end

// ─── Compose substitutions: s2 after s1 ─────────────────────────────────────

export let subst_compose = fn (s1: [SubstEntry], s2: [SubstEntry]) -> [SubstEntry] do
  let applied = apply_subst_to_entries(entries: s1, subst: s2)
  return merge_entries(base: applied, extra: s2)
end

let apply_subst_to_entries = fn (entries: [SubstEntry], subst: [SubstEntry]) -> [SubstEntry] do
  match entries do
    case Nil -> return Nil
    case SubstEntry(var: v, typ: t) :: rest ->
      return Cons(
        v: SubstEntry(var: v, typ: subst_apply(subst: subst, typ: t)),
        rest: apply_subst_to_entries(entries: rest, subst: subst)
      )
  end
end

/// Add entries from extra that are not already in base.
let merge_entries = fn (base: [SubstEntry], extra: [SubstEntry]) -> [SubstEntry] do
  match extra do
    case Nil -> return base
    case SubstEntry(var: v, typ: t) :: rest ->
      if entry_exists(entries: base, var: v) then
        return merge_entries(base: base, extra: rest)
      end
      return merge_entries(
        base: Cons(v: SubstEntry(var: v, typ: t), rest: base),
        extra: rest
      )
  end
end

let entry_exists = fn (entries: [SubstEntry], var: string) -> bool do
  match entries do
    case Nil -> return false
    case SubstEntry(var: v, typ: _) :: rest ->
      if v == var then
        return true
      end
      return entry_exists(entries: rest, var: var)
  end
end

// ─── Apply substitution to environment ──────────────────────────────────────

export let subst_apply_env = fn (subst: [SubstEntry], env: [EnvEntry]) -> [EnvEntry] do
  match env do
    case Nil -> return Nil
    case EnvEntry(name: n, scheme: Scheme(vars: vs, typ: t)) :: rest ->
      return Cons(
        v: EnvEntry(name: n, scheme: Scheme(vars: vs, typ: subst_apply(subst: subst, typ: t))),
        rest: subst_apply_env(subst: subst, env: rest)
      )
  end
end

// ─── Structural type equality ───────────────────────────────────────────────

export let type_eq = fn (a: TypeExpr, b: TypeExpr) -> bool do
  match a do
    case TyI32 -> match b do case TyI32 -> return true case _ -> return false end
    case TyI64 -> match b do case TyI64 -> return true case _ -> return false end
    case TyF32 -> match b do case TyF32 -> return true case _ -> return false end
    case TyF64 -> match b do case TyF64 -> return true case _ -> return false end
    case TyBool -> match b do case TyBool -> return true case _ -> return false end
    case TyChar -> match b do case TyChar -> return true case _ -> return false end
    case TyString -> match b do case TyString -> return true case _ -> return false end
    case TyUnit -> match b do case TyUnit -> return true case _ -> return false end
    case TyIntLit -> match b do case TyIntLit -> return true case _ -> return false end
    case TyFloatLit -> match b do case TyFloatLit -> return true case _ -> return false end
    case TyVar(name: n1) ->
      match b do case TyVar(name: n2) -> return n1 == n2 case _ -> return false end
    case TyUserDefined(name: n1, args: a1) ->
      match b do
        case TyUserDefined(name: n2, args: a2) ->
          if n1 == n2 then
            return type_list_eq(a: a1, b: a2)
          end
          return false
        case _ -> return false
      end
    case TyArrow(params: p1, ret: r1, requires: req1, throw_row: t1) ->
      match b do
        case TyArrow(params: p2, ret: r2, requires: req2, throw_row: t2) ->
          return named_types_eq(a: p1, b: p2)
            && type_eq(a: r1, b: r2)
            && type_eq(a: req1, b: req2)
            && type_eq(a: t1, b: t2)
        case _ -> return false
      end
    case TyRef(inner: i1) ->
      match b do case TyRef(inner: i2) -> return type_eq(a: i1, b: i2) case _ -> return false end
    case TyLinear(inner: i1) ->
      match b do case TyLinear(inner: i2) -> return type_eq(a: i1, b: i2) case _ -> return false end
    case TyBorrow(inner: i1) ->
      match b do case TyBorrow(inner: i2) -> return type_eq(a: i1, b: i2) case _ -> return false end
    case TyArray(elem: e1) ->
      match b do case TyArray(elem: e2) -> return type_eq(a: e1, b: e2) case _ -> return false end
    case TyList(elem: e1) ->
      match b do case TyList(elem: e2) -> return type_eq(a: e1, b: e2) case _ -> return false end
    case TyRecord(fields: f1) ->
      match b do case TyRecord(fields: f2) -> return named_types_eq(a: f1, b: f2) case _ -> return false end
    case TyRow(types: ts1, rest: r1) ->
      match b do
        case TyRow(types: ts2, rest: r2) ->
          if type_list_eq(a: ts1, b: ts2) then
            match r1 do
              case Some(val: t1) ->
                match r2 do
                  case Some(val: t2) -> return type_eq(a: t1, b: t2)
                  case None -> return false
                end
              case None ->
                match r2 do
                  case Some(val: _) -> return false
                  case None -> return true
                end
            end
          end
          return false
        case _ -> return false
      end
    case TyHandler(name: n1, requires: req1) ->
      match b do
        case TyHandler(name: n2, requires: req2) ->
          return n1 == n2 && type_eq(a: req1, b: req2)
        case _ -> return false
      end
  end
end

export let type_list_eq = fn (a: [TypeExpr], b: [TypeExpr]) -> bool do
  match a do
    case Nil ->
      match b do case Nil -> return true case _ -> return false end
    case ha :: ra ->
      match b do
        case Nil -> return false
        case hb :: rb ->
          if type_eq(a: ha, b: hb) then
            return type_list_eq(a: ra, b: rb)
          end
          return false
      end
  end
end

export let named_types_eq = fn (a: [NamedType], b: [NamedType]) -> bool do
  match a do
    case Nil ->
      match b do case Nil -> return true case _ -> return false end
    case NamedType(name: n1, typ: t1) :: ra ->
      match b do
        case Nil -> return false
        case NamedType(name: n2, typ: t2) :: rb ->
          if n1 == n2 && type_eq(a: t1, b: t2) then
            return named_types_eq(a: ra, b: rb)
          end
          return false
      end
  end
end

// ─── Occurs check ───────────────────────────────────────────────────────────

export let occurs_check = fn (var: string, typ: TypeExpr) -> bool do
  match typ do
    case TyVar(name: n) -> return n == var
    case TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return occurs_in_named_types(var: var, nts: ps)
        || occurs_check(var: var, typ: r)
        || occurs_check(var: var, typ: req)
        || occurs_check(var: var, typ: thr)
    case TyUserDefined(name: _, args: args) ->
      return occurs_in_type_list(var: var, types: args)
    case TyRef(inner: i) -> return occurs_check(var: var, typ: i)
    case TyLinear(inner: i) -> return occurs_check(var: var, typ: i)
    case TyBorrow(inner: i) -> return occurs_check(var: var, typ: i)
    case TyArray(elem: e) -> return occurs_check(var: var, typ: e)
    case TyList(elem: e) -> return occurs_check(var: var, typ: e)
    case TyRecord(fields: fs) -> return occurs_in_named_types(var: var, nts: fs)
    case TyRow(types: ts, rest: r) ->
      if occurs_in_type_list(var: var, types: ts) then
        return true
      end
      match r do
        case Some(val: t) -> return occurs_check(var: var, typ: t)
        case None -> return false
      end
    case TyHandler(name: _, requires: req) -> return occurs_check(var: var, typ: req)
    case _ -> return false
  end
end

let occurs_in_type_list = fn (var: string, types: [TypeExpr]) -> bool do
  match types do
    case Nil -> return false
    case t :: rest ->
      if occurs_check(var: var, typ: t) then
        return true
      end
      return occurs_in_type_list(var: var, types: rest)
  end
end

let occurs_in_named_types = fn (var: string, nts: [NamedType]) -> bool do
  match nts do
    case Nil -> return false
    case NamedType(name: _, typ: t) :: rest ->
      if occurs_check(var: var, typ: t) then
        return true
      end
      return occurs_in_named_types(var: var, nts: rest)
  end
end
