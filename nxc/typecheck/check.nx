/**
 * typecheck/check: Top-level program type checking entry point.
 *
 * Takes HirProgram, validates types of all functions, and returns
 * the HirProgram unchanged on success or raises CompileError.
 */

import { Span } from "nxc/common/token.nx"
import { buf_concat } from "stdlib/bytebuffer.nx"
import { handler_prefix_len } from "nxc/common/naming.nx"
import {
  TypeExpr, TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyLazy, TyBorrow,
  TyArray, TyList, TyRecord, TyRow, TyHandler, NamedType,
  EnumDef, VariantDef, VariantField
} from "nxc/common/ast.nx"
import {
  HirProgram, HirFunction, HirParam, HirExternal, HirPort, HirPortMethod,
  HirHandlerBindingEntry, HirHandlerBinding, HirStmt,
  HirBody, EagerBody, LazyBody
} from "nxc/ir/hir_types.nx"
import { TypeMismatch, MissingMain, MainNotFunction, MainNotUnit } from "nxc/common/error.nx"
import {
  CheckState, Scheme, EnvEntry, EnumEntry, TypeDefEntry, FreshResult,
  InferExprResult, InferExprOk, InferExprErr,
  tc_new_state, tc_fresh_var, env_insert, env_lookup, mono,
  state_with_env, state_env, state_enums, state_typedefs
} from "nxc/typecheck/types.nx"
import * as subst from "nxc/typecheck/subst.nx"
import * as infer from "nxc/typecheck/infer.nx"

// ─── Public entry point ─────────────────────────────────────────────────────

export let check_program = fn (hir: HirProgram, local_names: [string]) -> HirProgram throws { Exn } do
  let HirProgram(ports: ports, functions: funcs, externals: exts, handler_bindings: hbs, enum_defs: edefs) = hir
  // Build enum entries
  let enum_entries = build_enum_entries(defs: edefs)
  // Add built-in Exn and List
  let enum_entries2 = add_builtins(entries: enum_entries)
  // Build initial state
  let state = tc_new_state(enum_defs: enum_entries2, type_defs: [])

  // Pass 1: Register all signatures
  let st1 = register_externals(state: state, exts: exts)
  let st2 = register_functions(state: st1, funcs: funcs)
  let st3 = register_ports(state: st2, ports: ports)
  let st4 = register_handler_bindings(state: st3, hbs: hbs)
  let st5 = register_enum_constructors(state: st4, defs: edefs)

  // Pass 2: Check only local (main module) function bodies
  check_all_functions(state: st5, funcs: funcs, local_names: local_names)

  // Validate main exists and has correct signature
  validate_main(state: st5)

  return hir
end

// ─── Built-in types ─────────────────────────────────────────────────────────

let add_builtins = fn (entries: [EnumEntry]) -> [EnumEntry] do
  // Add Exn (empty enum for exception base type)
  let exn = EnumEntry(
    name: "Exn",
    def: EnumDef(name: "Exn", is_public: true, is_opaque: false, type_params: [], variants: [])
  )
  // Add List with Nil/Cons
  let list_variants = [
    VariantDef(name: "Nil", fields: []),
    VariantDef(name: "Cons", fields: [
      VariantField(name: Some(val: "v"), typ: TyVar(name: "T")),
      VariantField(name: Some(val: "rest"), typ: TyList(elem: TyVar(name: "T")))
    ])
  ]
  let list_def = EnumEntry(
    name: "List",
    def: EnumDef(name: "List", is_public: true, is_opaque: false,
      type_params: ["T"], variants: list_variants)
  )
  // Add Option with None/Some
  let option_variants = [
    VariantDef(name: "None", fields: []),
    VariantDef(name: "Some", fields: [
      VariantField(name: Some(val: "val"), typ: TyVar(name: "T"))
    ])
  ]
  let option_def = EnumEntry(
    name: "Option",
    def: EnumDef(name: "Option", is_public: true, is_opaque: false,
      type_params: ["T"], variants: option_variants)
  )
  return exn :: list_def :: option_def :: entries
end

// ─── Build enum entries ─────────────────────────────────────────────────────

let build_enum_entries = fn (defs: [EnumDef]) -> [EnumEntry] do
  return build_enum_entries_go(defs: defs, acc: [])
end

let build_enum_entries_go = fn (defs: [EnumDef], acc: [EnumEntry]) -> [EnumEntry] do
  match defs do
    case [] -> return rev_enum_entries(lst: acc, out: [])
    case EnumDef(name: n, is_public: p, is_opaque: o, type_params: tps, variants: vs) :: rest ->
      return build_enum_entries_go(defs: rest, acc: EnumEntry(name: n, def: EnumDef(name: n, is_public: p, is_opaque: o, type_params: tps, variants: vs)) :: acc)
  end
end

// ─── Register externals ────────────────────────────────────────────────────

let register_externals = fn (state: CheckState, exts: [HirExternal]) -> CheckState do
  match exts do
    case [] -> return state
    case HirExternal(name: n, wasm_module: _, wasm_name: _, params: params, ret_type: ret, throw_row: thr) :: rest ->
      let param_types = hir_params_to_named_types(params: params)
      let arrow = TyArrow(
        params: param_types, ret: ret,
        requires: TyRow(types: [], rest: None),
        throw_row: thr
      )
      let env = env_insert(env: state_env(state: state), name: n, scheme: mono(typ: arrow))
      return register_externals(state: state_with_env(state: state, env: env), exts: rest)
  end
end

// ─── Generic type parameter resolution ──────────────────────────────────────
// Convert TyUserDefined("T", []) → TyVar("T") when "T" is a type parameter.
// Mirrors Rust compiler's convert_generic_user_defined_to_var.

let str_list_contains = fn (xs: [string], s: string) -> bool do
  match xs do
    case [] -> return false
    case x :: rest ->
      if x == s then return true end
      return str_list_contains(xs: rest, s: s)
  end
end

let convert_ud_to_var = fn (typ: TypeExpr, vars: [string]) -> TypeExpr do
  match typ do
    case TyUserDefined(name: n, args: []) ->
      if str_list_contains(xs: vars, s: n) then return TyVar(name: n) end
      return typ
    case TyUserDefined(name: n, args: targs) ->
      return TyUserDefined(name: n, args: convert_type_list(types: targs, vars: vars))
    case TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return TyArrow(
        params: convert_named_types(nts: ps, vars: vars),
        ret: convert_ud_to_var(typ: r, vars: vars),
        requires: convert_ud_to_var(typ: req, vars: vars),
        throw_row: convert_ud_to_var(typ: thr, vars: vars)
      )
    case TyList(elem: e) -> return TyList(elem: convert_ud_to_var(typ: e, vars: vars))
    case TyArray(elem: e) -> return TyArray(elem: convert_ud_to_var(typ: e, vars: vars))
    case TyRef(inner: i) -> return TyRef(inner: convert_ud_to_var(typ: i, vars: vars))
    case TyLinear(inner: i) -> return TyLinear(inner: convert_ud_to_var(typ: i, vars: vars))
    case TyLazy(inner: i) -> return TyLazy(inner: convert_ud_to_var(typ: i, vars: vars))
    case TyBorrow(inner: i) -> return TyBorrow(inner: convert_ud_to_var(typ: i, vars: vars))
    case TyRecord(fields: fs) -> return TyRecord(fields: convert_named_types(nts: fs, vars: vars))
    case TyRow(types: ts, rest: r) ->
      let new_rest = match r do
        case Some(val: t) -> Some(val: convert_ud_to_var(typ: t, vars: vars))
        case None -> None
      end
      return TyRow(types: convert_type_list(types: ts, vars: vars), rest: new_rest)
    case TyHandler(name: n, requires: req) ->
      return TyHandler(name: n, requires: convert_ud_to_var(typ: req, vars: vars))
    case _ -> return typ
  end
end

let convert_named_types = fn (nts: [NamedType], vars: [string]) -> [NamedType] do
  return convert_named_types_go(nts: nts, vars: vars, acc: [])
end

let convert_named_types_go = fn (nts: [NamedType], vars: [string], acc: [NamedType]) -> [NamedType] do
  match nts do
    case [] -> return rev_named_types(lst: acc, out: [])
    case NamedType(name: n, typ: t) :: rest ->
      return convert_named_types_go(nts: rest, vars: vars, acc: NamedType(name: n, typ: convert_ud_to_var(typ: t, vars: vars)) :: acc)
  end
end

let convert_type_list = fn (types: [TypeExpr], vars: [string]) -> [TypeExpr] do
  return convert_type_list_go(types: types, vars: vars, acc: [])
end

let convert_type_list_go = fn (types: [TypeExpr], vars: [string], acc: [TypeExpr]) -> [TypeExpr] do
  match types do
    case [] -> return rev_type_exprs(lst: acc, out: [])
    case t :: rest ->
      return convert_type_list_go(types: rest, vars: vars, acc: convert_ud_to_var(typ: t, vars: vars) :: acc)
  end
end

let convert_hir_params = fn (params: [HirParam], vars: [string]) -> [HirParam] do
  return convert_hir_params_go(params: params, vars: vars, acc: [])
end

let convert_hir_params_go = fn (params: [HirParam], vars: [string], acc: [HirParam]) -> [HirParam] do
  match params do
    case [] -> return rev_hir_params(lst: acc, out: [])
    case HirParam(name: n, label: l, typ: t) :: rest ->
      return convert_hir_params_go(params: rest, vars: vars, acc: HirParam(name: n, label: l, typ: convert_ud_to_var(typ: t, vars: vars)) :: acc)
  end
end

// ─── Register functions ─────────────────────────────────────────────────────

let register_functions = fn (state: CheckState, funcs: [HirFunction]) -> CheckState do
  match funcs do
    case [] -> return state
    case HirFunction(name: n, type_params: tps, params: params, ret_type: ret, body: _, span: _) :: rest ->
      let param_types = hir_params_to_named_types(params: params)
      let arrow = TyArrow(
        params: convert_named_types(nts: param_types, vars: tps),
        ret: convert_ud_to_var(typ: ret, vars: tps),
        requires: TyRow(types: [], rest: None),
        throw_row: TyRow(types: [], rest: None)
      )
      let env = env_insert(env: state_env(state: state), name: n, scheme: Scheme(vars: tps, typ: arrow))
      return register_functions(state: state_with_env(state: state, env: env), funcs: rest)
  end
end

// ─── Register ports ─────────────────────────────────────────────────────────

let register_ports = fn (state: CheckState, ports: [HirPort]) -> CheckState do
  match ports do
    case [] -> return state
    case HirPort(name: _, methods: _) :: rest ->
      // Ports are structural — methods are registered via handler bindings
      return register_ports(state: state, ports: rest)
  end
end

// ─── Register handler bindings ──────────────────────────────────────────────

let register_handler_bindings = fn (state: CheckState, hbs: [HirHandlerBindingEntry]) -> CheckState do
  match hbs do
    case [] -> return state
    case HirHandlerBindingEntry(name: n, binding: HirHandlerBinding(port_name: pname, functions: funcs)) :: rest ->
      let handler_type = TyHandler(name: pname, requires: TyRow(types: [], rest: None))
      let env1 = env_insert(env: state_env(state: state), name: n, scheme: mono(typ: handler_type))
      // Also register individual methods as port_name.method_name
      let prefix_len = handler_prefix_len(handler_name: n)
      let env2 = register_handler_methods(env: env1, port_name: pname, prefix_len: prefix_len, funcs: funcs)
      let st1 = state_with_env(state: state, env: env2)
      return register_handler_bindings(state: st1, hbs: rest)
  end
end

let register_handler_methods = fn (env: [EnvEntry], port_name: string, prefix_len: i64, funcs: [HirFunction]) -> [EnvEntry] do
  match funcs do
    case [] -> return env
    case HirFunction(name: n, type_params: _, params: params, ret_type: ret, body: _, span: _) :: rest ->
      let original_name = substring(s: n, start: prefix_len, len: str_length(s: n) - prefix_len)
      let method_name = buf_concat(parts: [port_name, ".", original_name])
      let param_types = hir_params_to_named_types(params: params)
      let arrow = TyArrow(
        params: param_types, ret: ret,
        requires: TyRow(types: [], rest: None),
        throw_row: TyRow(types: [], rest: None)
      )
      let env1 = env_insert(env: env, name: method_name, scheme: mono(typ: arrow))
      return register_handler_methods(env: env1, port_name: port_name, prefix_len: prefix_len, funcs: rest)
  end
end

// ─── Register enum constructors ─────────────────────────────────────────────

let register_enum_constructors = fn (state: CheckState, defs: [EnumDef]) -> CheckState do
  match defs do
    case [] -> return state
    case EnumDef(name: ename, is_public: _, is_opaque: _, type_params: tps, variants: vs) :: rest ->
      let st1 = register_variants(state: state, enum_name: ename, type_params: tps, variants: vs)
      return register_enum_constructors(state: st1, defs: rest)
  end
end

let register_variants = fn (state: CheckState, enum_name: string, type_params: [string], variants: [VariantDef]) -> CheckState do
  match variants do
    case [] -> return state
    case VariantDef(name: vname, fields: fields) :: rest ->
      let enum_type = build_enum_type_from_params(name: enum_name, params: type_params)
      let ctor_type = match fields do
        case [] -> enum_type
        case _ ->
          let param_types = variant_fields_to_named_types(fields: fields, idx: 0)
          TyArrow(
            params: param_types, ret: enum_type,
            requires: TyRow(types: [], rest: None),
            throw_row: TyRow(types: [], rest: None)
          )
      end
      let env = env_insert(env: state_env(state: state), name: vname, scheme: mono(typ: ctor_type))
      return register_variants(state: state_with_env(state: state, env: env), enum_name: enum_name, type_params: type_params, variants: rest)
  end
end

let build_enum_type_from_params = fn (name: string, params: [string]) -> TypeExpr do
  match params do
    case [] -> return TyUserDefined(name: name, args: [])
    case _ -> return TyUserDefined(name: name, args: params_to_vars(params: params))
  end
end

let params_to_vars = fn (params: [string]) -> [TypeExpr] do
  return params_to_vars_go(params: params, acc: [])
end

let params_to_vars_go = fn (params: [string], acc: [TypeExpr]) -> [TypeExpr] do
  match params do
    case [] -> return rev_type_exprs(lst: acc, out: [])
    case p :: rest ->
      return params_to_vars_go(params: rest, acc: TyVar(name: p) :: acc)
  end
end

let variant_fields_to_named_types = fn (fields: [VariantField], idx: i64) -> [NamedType] do
  return variant_fields_to_named_types_go(fields: fields, idx: idx, acc: [])
end

let variant_fields_to_named_types_go = fn (fields: [VariantField], idx: i64, acc: [NamedType]) -> [NamedType] do
  match fields do
    case [] -> return rev_named_types(lst: acc, out: [])
    case VariantField(name: mname, typ: t) :: rest ->
      let fname = match mname do
        case Some(val: n) -> n
        case None -> "_" ++ from_i64(val: idx)
      end
      return variant_fields_to_named_types_go(fields: rest, idx: idx + 1, acc: NamedType(name: fname, typ: t) :: acc)
  end
end

// ─── Check all function bodies ──────────────────────────────────────────────

let is_local = fn (name: string, local_names: [string]) -> bool do
  match local_names do
    case [] -> return false
    case n :: rest ->
      if n == name then return true end
      return is_local(name: name, local_names: rest)
  end
end

let check_all_functions = fn (state: CheckState, funcs: [HirFunction], local_names: [string]) -> unit throws { Exn } do
  match funcs do
    case [] -> return ()
    case func :: rest ->
      let HirFunction(name: name, type_params: _, params: _, ret_type: _, body: _, span: _) = func
      if is_local(name: name, local_names: local_names) then
        check_function(state: state, func: func)
      end
      return check_all_functions(state: state, funcs: rest, local_names: local_names)
  end
end

let check_function = fn (state: CheckState, func: HirFunction) -> unit throws { Exn } do
  let HirFunction(name: name, type_params: tps, params: params, ret_type: ret, body: hir_body, span: span) = func
  let body = match hir_body do case EagerBody(stmts: s) -> s case LazyBody(ast_expr: _, entries: _) -> [] end
  // Convert UserDefined type params to TyVar in param types and return type
  let conv_params = convert_hir_params(params: params, vars: tps)
  let conv_ret = convert_ud_to_var(typ: ret, vars: tps)
  // Build local env with function params
  let body_env = add_func_params(env: state_env(state: state), params: conv_params)
  let body_state = state_with_env(state: state, env: body_env)
  match infer.infer_stmts(state: body_state, stmts: body, ret_type: conv_ret) do
    case InferExprErr(message: m, span: err_span) ->
      raise TypeMismatch(func_name: name, detail: m, span: err_span)
    case InferExprOk(state: _, subst: _, typ: _) ->
      return ()
  end
end

let add_func_params = fn (env: [EnvEntry], params: [HirParam]) -> [EnvEntry] do
  match params do
    case [] -> return env
    case HirParam(name: n, label: _, typ: t) :: rest ->
      return add_func_params(env: env_insert(env: env, name: n, scheme: mono(typ: t)), params: rest)
  end
end

// ─── Validate main function ────────────────────────────────────────────────

let validate_main = fn (state: CheckState) -> unit throws { Exn } do
  match env_lookup(env: state_env(state: state), name: "main") do
    case None ->
      raise MissingMain
    case Some(val: Scheme(vars: _, typ: main_type)) ->
      match main_type do
        case TyArrow(params: params, ret: ret, requires: _, throw_row: _) ->
          // Check return type is Unit
          if subst.type_eq(a: ret, b: TyUnit) then
            return ()
          end
          raise MainNotUnit
        case _ ->
          raise MainNotFunction
      end
  end
end

// ─── Helpers ────────────────────────────────────────────────────────────────

let hir_params_to_named_types = fn (params: [HirParam]) -> [NamedType] do
  return hir_params_to_named_types_go(params: params, acc: [])
end

let hir_params_to_named_types_go = fn (params: [HirParam], acc: [NamedType]) -> [NamedType] do
  match params do
    case [] -> return rev_named_types(lst: acc, out: [])
    case HirParam(name: n, label: l, typ: t) :: rest ->
      return hir_params_to_named_types_go(params: rest, acc: NamedType(name: l, typ: t) :: acc)
  end
end

// ─── Monomorphic reverse helpers (list.reverse has codegen issues in nxc) ────

let rev_enum_entries = fn (lst: [EnumEntry], out: [EnumEntry]) -> [EnumEntry] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_enum_entries(lst: rest, out: x :: out)
  end
end

let rev_named_types = fn (lst: [NamedType], out: [NamedType]) -> [NamedType] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_named_types(lst: rest, out: x :: out)
  end
end

let rev_type_exprs = fn (lst: [TypeExpr], out: [TypeExpr]) -> [TypeExpr] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_type_exprs(lst: rest, out: x :: out)
  end
end

let rev_hir_params = fn (lst: [HirParam], out: [HirParam]) -> [HirParam] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_hir_params(lst: rest, out: x :: out)
  end
end

import { from_i64, length as str_length, substring } from "stdlib/string.nx"
