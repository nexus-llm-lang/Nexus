/**
 * typecheck/check: Top-level program type checking entry point.
 *
 * Takes HirProgram, validates types of all functions, and returns
 * the HirProgram unchanged on success or raises CompileError.
 */

import { Span } from nxc/common/token.nx
import {
  TypeExpr, TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyBorrow,
  TyArray, TyList, TyRecord, TyRow, TyHandler, NamedType,
  EnumDef, VariantDef, VariantField
} from nxc/common/ast.nx
import {
  HirProgram, HirFunction, HirParam, HirExternal, HirPort, HirPortMethod,
  HirHandlerBindingEntry, HirHandlerBinding
} from nxc/ir/hir_types.nx
import {
  CompileError, PhaseTypecheck, error, error_no_span
} from nxc/common/error.nx
import {
  CheckState, Scheme, EnvEntry, EnumEntry, TypeDefEntry, FreshResult,
  InferExprResult, InferExprOk, InferExprErr,
  tc_new_state, tc_fresh_var, env_insert, env_lookup, mono,
  state_with_env, state_env, state_enums, state_typedefs
} from nxc/typecheck/types.nx
import { subst_empty, subst_apply, type_eq } from nxc/typecheck/subst.nx
import { infer_stmts } from nxc/typecheck/infer.nx

// ─── Public entry point ─────────────────────────────────────────────────────

export let check_program = fn (hir: HirProgram) -> HirProgram do
  match hir
    case HirProgram(ports: ports, functions: funcs, externals: exts, handler_bindings: hbs, enum_defs: edefs) ->
      // Build enum entries
      let enum_entries = build_enum_entries(defs: edefs)
      // Add built-in Exn and List
      let enum_entries2 = add_builtins(entries: enum_entries)
      // Build initial state
      let state = tc_new_state(enum_defs: enum_entries2, type_defs: Nil)

      // Pass 1: Register all signatures
      let st1 = register_externals(state: state, exts: exts)
      let st2 = register_functions(state: st1, funcs: funcs)
      let st3 = register_ports(state: st2, ports: ports)
      let st4 = register_handler_bindings(state: st3, hbs: hbs)
      let st5 = register_enum_constructors(state: st4, defs: edefs)

      // Pass 2: Check all function bodies
      check_all_functions(state: st5, funcs: funcs)

      // Validate main exists and has correct signature
      validate_main(state: st5)

      return hir
  end
end

// ─── Built-in types ─────────────────────────────────────────────────────────

let add_builtins = fn (entries: [EnumEntry]) -> [EnumEntry] do
  // Add Exn (empty enum for exception base type)
  let exn = EnumEntry(
    name: "Exn",
    def: EnumDef(name: "Exn", is_public: true, is_opaque: false, type_params: Nil, variants: Nil)
  )
  // Add List with Nil/Cons
  let list_variants = Cons(
    v: VariantDef(name: "Nil", fields: Nil),
    rest: Cons(
      v: VariantDef(name: "Cons", fields: Cons(
        v: VariantField(name: Some(val: "v"), typ: TyVar(name: "T")),
        rest: Cons(
          v: VariantField(name: Some(val: "rest"), typ: TyList(elem: TyVar(name: "T"))),
          rest: Nil
        )
      )),
      rest: Nil
    )
  )
  let list_def = EnumEntry(
    name: "List",
    def: EnumDef(name: "List", is_public: true, is_opaque: false,
      type_params: Cons(v: "T", rest: Nil), variants: list_variants)
  )
  // Add Option with None/Some
  let option_variants = Cons(
    v: VariantDef(name: "None", fields: Nil),
    rest: Cons(
      v: VariantDef(name: "Some", fields: Cons(
        v: VariantField(name: Some(val: "val"), typ: TyVar(name: "T")),
        rest: Nil
      )),
      rest: Nil
    )
  )
  let option_def = EnumEntry(
    name: "Option",
    def: EnumDef(name: "Option", is_public: true, is_opaque: false,
      type_params: Cons(v: "T", rest: Nil), variants: option_variants)
  )
  return Cons(v: exn, rest: Cons(v: list_def, rest: Cons(v: option_def, rest: entries)))
end

// ─── Build enum entries ─────────────────────────────────────────────────────

let build_enum_entries = fn (defs: [EnumDef]) -> [EnumEntry] do
  match defs
    case Nil -> return Nil
    case EnumDef(name: n, is_public: p, is_opaque: o, type_params: tps, variants: vs) :: rest ->
      return Cons(
        v: EnumEntry(name: n, def: EnumDef(name: n, is_public: p, is_opaque: o, type_params: tps, variants: vs)),
        rest: build_enum_entries(defs: rest)
      )
  end
end

// ─── Register externals ────────────────────────────────────────────────────

let register_externals = fn (state: CheckState, exts: [HirExternal]) -> CheckState do
  match exts
    case Nil -> return state
    case HirExternal(name: n, wasm_module: _, wasm_name: _, params: params, ret_type: ret, throw_row: thr) :: rest ->
      let param_types = hir_params_to_named_types(params: params)
      let arrow = TyArrow(
        params: param_types, ret: ret,
        requires: TyRow(types: Nil, rest: None),
        throw_row: thr
      )
      let env = env_insert(env: state_env(state: state), name: n, scheme: mono(typ: arrow))
      return register_externals(state: state_with_env(state: state, env: env), exts: rest)
  end
end

// ─── Register functions ─────────────────────────────────────────────────────

let register_functions = fn (state: CheckState, funcs: [HirFunction]) -> CheckState do
  match funcs
    case Nil -> return state
    case HirFunction(name: n, params: params, ret_type: ret, body: _, span: _) :: rest ->
      let param_types = hir_params_to_named_types(params: params)
      let arrow = TyArrow(
        params: param_types, ret: ret,
        requires: TyRow(types: Nil, rest: None),
        throw_row: TyRow(types: Nil, rest: None)
      )
      let env = env_insert(env: state_env(state: state), name: n, scheme: mono(typ: arrow))
      return register_functions(state: state_with_env(state: state, env: env), funcs: rest)
  end
end

// ─── Register ports ─────────────────────────────────────────────────────────

let register_ports = fn (state: CheckState, ports: [HirPort]) -> CheckState do
  match ports
    case Nil -> return state
    case HirPort(name: _, methods: _) :: rest ->
      // Ports are structural — methods are registered via handler bindings
      return register_ports(state: state, ports: rest)
  end
end

// ─── Register handler bindings ──────────────────────────────────────────────

let register_handler_bindings = fn (state: CheckState, hbs: [HirHandlerBindingEntry]) -> CheckState do
  match hbs
    case Nil -> return state
    case HirHandlerBindingEntry(name: n, binding: HirHandlerBinding(port_name: pname, functions: funcs)) :: rest ->
      let handler_type = TyHandler(name: pname, requires: TyRow(types: Nil, rest: None))
      let env1 = env_insert(env: state_env(state: state), name: n, scheme: mono(typ: handler_type))
      // Also register individual methods as port_name.method_name
      let env2 = register_handler_methods(env: env1, port_name: pname, funcs: funcs)
      let st1 = state_with_env(state: state, env: env2)
      return register_handler_bindings(state: st1, hbs: rest)
  end
end

let register_handler_methods = fn (env: [EnvEntry], port_name: string, funcs: [HirFunction]) -> [EnvEntry] do
  match funcs
    case Nil -> return env
    case HirFunction(name: n, params: params, ret_type: ret, body: _, span: _) :: rest ->
      let method_name = port_name ++ "." ++ n
      let param_types = hir_params_to_named_types(params: params)
      let arrow = TyArrow(
        params: param_types, ret: ret,
        requires: TyRow(types: Nil, rest: None),
        throw_row: TyRow(types: Nil, rest: None)
      )
      let env1 = env_insert(env: env, name: method_name, scheme: mono(typ: arrow))
      return register_handler_methods(env: env1, port_name: port_name, funcs: rest)
  end
end

// ─── Register enum constructors ─────────────────────────────────────────────

let register_enum_constructors = fn (state: CheckState, defs: [EnumDef]) -> CheckState do
  match defs
    case Nil -> return state
    case EnumDef(name: ename, is_public: _, is_opaque: _, type_params: tps, variants: vs) :: rest ->
      let st1 = register_variants(state: state, enum_name: ename, type_params: tps, variants: vs)
      return register_enum_constructors(state: st1, defs: rest)
  end
end

let register_variants = fn (state: CheckState, enum_name: string, type_params: [string], variants: [VariantDef]) -> CheckState do
  match variants
    case Nil -> return state
    case VariantDef(name: vname, fields: fields) :: rest ->
      let enum_type = build_enum_type_from_params(name: enum_name, params: type_params)
      let ctor_type = match fields
        case Nil -> enum_type
        case _ ->
          let param_types = variant_fields_to_named_types(fields: fields, idx: 0)
          TyArrow(
            params: param_types, ret: enum_type,
            requires: TyRow(types: Nil, rest: None),
            throw_row: TyRow(types: Nil, rest: None)
          )
      end
      let env = env_insert(env: state_env(state: state), name: vname, scheme: mono(typ: ctor_type))
      return register_variants(state: state_with_env(state: state, env: env), enum_name: enum_name, type_params: type_params, variants: rest)
  end
end

let build_enum_type_from_params = fn (name: string, params: [string]) -> TypeExpr do
  match params
    case Nil -> return TyUserDefined(name: name, args: Nil)
    case _ -> return TyUserDefined(name: name, args: params_to_vars(params: params))
  end
end

let params_to_vars = fn (params: [string]) -> [TypeExpr] do
  match params
    case Nil -> return Nil
    case p :: rest ->
      return Cons(v: TyVar(name: p), rest: params_to_vars(params: rest))
  end
end

let variant_fields_to_named_types = fn (fields: [VariantField], idx: i64) -> [NamedType] do
  match fields
    case Nil -> return Nil
    case VariantField(name: mname, typ: t) :: rest ->
      let fname = match mname
        case Some(val: n) -> n
        case None -> "_" ++ from_i64(val: idx)
      end
      return Cons(
        v: NamedType(name: fname, typ: t),
        rest: variant_fields_to_named_types(fields: rest, idx: idx + 1)
      )
  end
end

// ─── Check all function bodies ──────────────────────────────────────────────

let check_all_functions = fn (state: CheckState, funcs: [HirFunction]) -> unit do
  match funcs
    case Nil -> return ()
    case func :: rest ->
      check_function(state: state, func: func)
      return check_all_functions(state: state, funcs: rest)
  end
end

let check_function = fn (state: CheckState, func: HirFunction) -> unit do
  match func
    case HirFunction(name: name, params: params, ret_type: ret, body: body, span: span) ->
      // Build local env with function params
      let body_env = add_func_params(env: state_env(state: state), params: params)
      let body_state = state_with_env(state: state, env: body_env)
      match infer_stmts(state: body_state, stmts: body, ret_type: ret)
        case InferExprErr(message: m) ->
          error(phase: PhaseTypecheck, message: "in " ++ name ++ ": " ++ m, span: span)
        case InferExprOk(state: _, subst: _, typ: _) ->
          return ()
      end
  end
end

let add_func_params = fn (env: [EnvEntry], params: [HirParam]) -> [EnvEntry] do
  match params
    case Nil -> return env
    case HirParam(name: n, label: _, typ: t) :: rest ->
      return add_func_params(env: env_insert(env: env, name: n, scheme: mono(typ: t)), params: rest)
  end
end

// ─── Validate main function ────────────────────────────────────────────────

let validate_main = fn (state: CheckState) -> unit do
  match env_lookup(env: state_env(state: state), name: "main")
    case None ->
      error_no_span(phase: PhaseTypecheck, message: "no main function defined")
    case Some(val: Scheme(vars: _, typ: main_type)) ->
      match main_type
        case TyArrow(params: params, ret: ret, requires: _, throw_row: _) ->
          // Check return type is Unit
          if type_eq(a: ret, b: TyUnit) then
            return ()
          end
          error_no_span(phase: PhaseTypecheck, message: "main must return unit")
        case _ ->
          error_no_span(phase: PhaseTypecheck, message: "main is not a function")
      end
  end
end

// ─── Helpers ────────────────────────────────────────────────────────────────

let hir_params_to_named_types = fn (params: [HirParam]) -> [NamedType] do
  match params
    case Nil -> return Nil
    case HirParam(name: n, label: l, typ: t) :: rest ->
      return Cons(v: NamedType(name: l, typ: t), rest: hir_params_to_named_types(params: rest))
  end
end

import { from_i64 } from stdlib/string.nx
