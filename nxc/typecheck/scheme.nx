/**
 * scheme: Polytypes with quantified variables.
 *
 * Provides type scheme creation, generalization over an environment,
 * and instantiation with fresh type variables.
 */

import { TypeExpr } from nxc/common/ast.nx
import { SubstEntry, apply_subst, free_vars, subtract_strings } from nxc/typecheck/subst.nx
import { from_i64 } from stdlib/string.nx

// ─── Types ──────────────────────────────────────────────────────────────────

pub type Scheme = Scheme(vars: [string], typ: TypeExpr)

pub type InstResult = InstResult(supply: i64, typ: TypeExpr)

pub type FreshResult = FreshResult(supply: i64, typ: TypeExpr)

// ─── Operations ─────────────────────────────────────────────────────────────

pub let mono_scheme = fn (typ: TypeExpr) -> Scheme do
  return Scheme(vars: Nil(), typ: typ)
end

pub let generalize = fn (env_free: [string], typ: TypeExpr) -> Scheme do
  let quantified = subtract_strings(as_: free_vars(typ: typ), bs: env_free)
  return Scheme(vars: quantified, typ: typ)
end

pub let instantiate = fn (scheme: Scheme, supply: i64) -> InstResult do
  match scheme
    case Scheme(vars: vars, typ: typ) ->
      let r = build_inst_subst(vars: vars, supply: supply)
      match r case InstSubst(subst: s, supply: new_supply) ->
        InstResult(supply: new_supply, typ: apply_subst(subst: s, typ: typ))
      end
  end
end

pub let fresh_var = fn (supply: i64) -> FreshResult do
  return FreshResult(supply: supply + 1, typ: TyVar(name: "?" ++ from_i64(val: supply)))
end

// ─── Internal ───────────────────────────────────────────────────────────────

type InstSubst = InstSubst(subst: [SubstEntry], supply: i64)

let build_inst_subst = fn (vars: [string], supply: i64) -> InstSubst do
  match vars
    case Nil() -> InstSubst(subst: Nil(), supply: supply)
    case Cons(v: v, rest: rest) ->
      let fresh = "?" ++ from_i64(val: supply)
      match build_inst_subst(vars: rest, supply: supply + 1)
        case InstSubst(subst: s, supply: ns) ->
          InstSubst(subst: Cons(v: SubstEntry(var: v, typ: TyVar(name: fresh)), rest: s), supply: ns)
      end
  end
end
