/**
 * typecheck/infer: Expression and statement type inference.
 *
 * Hindley-Milner style inference over HirExpr/HirStmt, producing
 * substitutions and inferred types. Threads CheckState for fresh
 * variable generation and environment management.
 */

import { Span } from nxc/common/token.nx
import {
  TypeExpr, TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyBorrow,
  TyArray, TyList, TyRecord, TyRow, TyHandler, NamedType,
  BinaryOp, OpAdd, OpSub, OpMul, OpDiv, OpMod,
  OpFAdd, OpFSub, OpFMul, OpFDiv,
  OpEq, OpNe, OpLt, OpLe, OpGt, OpGe,
  OpFEq, OpFNe, OpFLt, OpFLe, OpFGt, OpFGe,
  OpBitAnd, OpBitOr, OpBitXor, OpShl, OpShr,
  OpAnd, OpOr, OpConcat,
  Literal, LitInt, LitFloat, LitBool, LitChar, LitString, LitUnit,
  Sigil, SigilImmutable, SigilMutable, SigilLinear, SigilBorrow,
  VariantField, EnumDef, VariantDef
} from nxc/common/ast.nx
import {
  HirExpr, HirLiteral, HirVariable, HirBinaryOp, HirBorrow, HirCall, HirConstructor,
  HirRecord, HirArray, HirIndex, HirFieldAccess, HirIf, HirMatch, HirWhile, HirFor,
  HirLambda, HirRaise, HirExternal_, HirHandler,
  HirStmt, HirStmtLet, HirStmtExpr, HirStmtReturn, HirStmtAssign, HirStmtConc,
  HirStmtTry, HirStmtInject,
  HirCallArg, HirNamedExpr, HirMatchCase, HirFunction, HirParam,
  HirPattern, HirPatLiteral, HirPatVariable, HirPatConstructor, HirPatRecord, HirPatWildcard,
  HirPatternField, HirRecordPatField
} from nxc/ir/hir_types.nx
import {
  SubstEntry, Scheme, EnvEntry, CheckState, FreshResult,
  InferExprResult, InferExprOk, InferExprErr,
  UnifyResult, UnifyOk, UnifyErr,
  BindResult, BindOk, BindErr,
  EnumVariantInfo,
  tc_fresh_var, env_lookup, env_insert, mono,
  find_variant, state_with_env, state_env, state_enums, state_typedefs
} from nxc/typecheck/types.nx
import {
  subst_empty, subst_single, subst_apply, subst_compose, subst_apply_env,
  type_eq, occurs_check
} from nxc/typecheck/subst.nx
import { unify } from nxc/typecheck/unify.nx
import { from_i64 } from stdlib/string.nx

// ─── Expression inference ───────────────────────────────────────────────────

export let infer_expr = fn (state: CheckState, expr: HirExpr) -> InferExprResult do
  match expr
    case HirLiteral(lit: lit) -> return infer_literal(state: state, lit: lit)
    case HirVariable(name: name, sigil: _) -> return infer_variable(state: state, name: name)
    case HirBorrow(name: name, sigil: _) -> return infer_variable(state: state, name: name)
    case HirBinaryOp(left: left, op: op, right: right) ->
      return infer_binop(state: state, left: left, op: op, right: right)
    case HirCall(func: func, args: args) ->
      return infer_call(state: state, func: func, args: args)
    case HirConstructor(variant: variant, args: args) ->
      return infer_constructor(state: state, variant: variant, args: args)
    case HirRecord(fields: fields) ->
      return infer_record(state: state, fields: fields)
    case HirArray(elems: elems) ->
      return infer_array(state: state, elems: elems)
    case HirIndex(target: target, index: index) ->
      return infer_index(state: state, target: target, index: index)
    case HirFieldAccess(target: target, field: field) ->
      return infer_field_access(state: state, target: target, field: field)
    case HirIf(cond: cond, then_branch: then_b, else_branch: else_b) ->
      return infer_if(state: state, cond: cond, then_b: then_b, else_b: else_b)
    case HirMatch(target: target, cases: cases) ->
      return infer_match(state: state, target: target, cases: cases)
    case HirWhile(cond: cond, body: body) ->
      return infer_while(state: state, cond: cond, body: body)
    case HirFor(var: var, start: start, end_expr: end_e, body: body) ->
      return infer_for(state: state, var: var, start: start, end_e: end_e, body: body)
    case HirLambda(params: params, ret_type: ret, body: body) ->
      return infer_lambda(state: state, params: params, ret_type: ret, body: body)
    case HirRaise(expr: inner) ->
      return infer_raise(state: state, inner: inner)
    case HirExternal_(symbol: _, arg_names: _, typ: typ) ->
      return InferExprOk(state: state, subst: subst_empty(), typ: typ)
    case HirHandler(functions: _) ->
      // Handler expressions type as Unit for now
      return InferExprOk(state: state, subst: subst_empty(), typ: TyUnit)
  end
end

// ─── Literal inference ──────────────────────────────────────────────────────

let infer_literal = fn (state: CheckState, lit: Literal) -> InferExprResult do
  let typ = match lit
    case LitInt(val: _) -> TyIntLit
    case LitFloat(val: _) -> TyFloatLit
    case LitBool(val: _) -> TyBool
    case LitChar(val: _) -> TyChar
    case LitString(val: _) -> TyString
    case LitUnit -> TyUnit
  end
  return InferExprOk(state: state, subst: subst_empty(), typ: typ)
end

// ─── Variable inference ─────────────────────────────────────────────────────

let infer_variable = fn (state: CheckState, name: string) -> InferExprResult do
  match env_lookup(env: state_env(state: state), name: name)
    case Some(val: Scheme(vars: _, typ: t)) ->
      return InferExprOk(state: state, subst: subst_empty(), typ: t)
    case None ->
      return InferExprErr(message: "unbound variable: " ++ name)
  end
end

// ─── Binary operator inference ──────────────────────────────────────────────

let infer_binop = fn (state: CheckState, left: HirExpr, op: BinaryOp, right: HirExpr) -> InferExprResult do
  match infer_expr(state: state, expr: left)
    case InferExprErr(message: m) -> return InferExprErr(message: m)
    case InferExprOk(state: st1, subst: s1, typ: t1) ->
      match infer_expr(state: st1, expr: right)
        case InferExprErr(message: m) -> return InferExprErr(message: m)
        case InferExprOk(state: st2, subst: s2, typ: t2) ->
          let s12 = subst_compose(s1: s1, s2: s2)
          let lt = subst_apply(subst: s12, typ: t1)
          let rt = subst_apply(subst: s12, typ: t2)
          return resolve_binop_types(state: st2, subst: s12, op: op, lt: lt, rt: rt)
      end
  end
end

let resolve_binop_types = fn (state: CheckState, subst: [SubstEntry], op: BinaryOp, lt: TypeExpr, rt: TypeExpr) -> InferExprResult do
  match op
    // Integer arithmetic -> result is integer type
    case OpAdd -> return unify_int_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpSub -> return unify_int_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpMul -> return unify_int_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpDiv -> return unify_int_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpMod -> return unify_int_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpBitAnd -> return unify_int_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpBitOr -> return unify_int_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpBitXor -> return unify_int_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpShl -> return unify_int_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpShr -> return unify_int_binop(state: state, subst: subst, lt: lt, rt: rt)
    // Float arithmetic
    case OpFAdd -> return unify_float_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpFSub -> return unify_float_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpFMul -> return unify_float_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpFDiv -> return unify_float_binop(state: state, subst: subst, lt: lt, rt: rt)
    // Integer comparisons -> bool
    case OpEq -> return unify_cmp_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpNe -> return unify_cmp_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpLt -> return unify_cmp_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpLe -> return unify_cmp_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpGt -> return unify_cmp_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpGe -> return unify_cmp_binop(state: state, subst: subst, lt: lt, rt: rt)
    // Float comparisons -> bool
    case OpFEq -> return unify_float_cmp(state: state, subst: subst, lt: lt, rt: rt)
    case OpFNe -> return unify_float_cmp(state: state, subst: subst, lt: lt, rt: rt)
    case OpFLt -> return unify_float_cmp(state: state, subst: subst, lt: lt, rt: rt)
    case OpFLe -> return unify_float_cmp(state: state, subst: subst, lt: lt, rt: rt)
    case OpFGt -> return unify_float_cmp(state: state, subst: subst, lt: lt, rt: rt)
    case OpFGe -> return unify_float_cmp(state: state, subst: subst, lt: lt, rt: rt)
    // Logical -> bool
    case OpAnd ->
      return unify_bool_binop(state: state, subst: subst, lt: lt, rt: rt)
    case OpOr ->
      return unify_bool_binop(state: state, subst: subst, lt: lt, rt: rt)
    // String concat
    case OpConcat ->
      let tdefs = state_typedefs(state: state)
      match unify(t1: lt, t2: TyString, tdefs: tdefs)
        case UnifyErr(message: m) -> return InferExprErr(message: "concat lhs: " ++ m)
        case UnifyOk(subst: s1) ->
          let s_merged = subst_compose(s1: subst, s2: s1)
          match unify(t1: subst_apply(subst: s_merged, typ: rt), t2: TyString, tdefs: tdefs)
            case UnifyErr(message: m) -> return InferExprErr(message: "concat rhs: " ++ m)
            case UnifyOk(subst: s2) ->
              return InferExprOk(state: state, subst: subst_compose(s1: s_merged, s2: s2), typ: TyString)
          end
      end
  end
end

let unify_int_binop = fn (state: CheckState, subst: [SubstEntry], lt: TypeExpr, rt: TypeExpr) -> InferExprResult do
  let target = select_int_type(a: lt, b: rt)
  let tdefs = state_typedefs(state: state)
  match unify(t1: lt, t2: target, tdefs: tdefs)
    case UnifyErr(message: m) -> return InferExprErr(message: "int op lhs: " ++ m)
    case UnifyOk(subst: s1) ->
      let sm = subst_compose(s1: subst, s2: s1)
      match unify(t1: subst_apply(subst: sm, typ: rt), t2: target, tdefs: tdefs)
        case UnifyErr(message: m) -> return InferExprErr(message: "int op rhs: " ++ m)
        case UnifyOk(subst: s2) ->
          return InferExprOk(state: state, subst: subst_compose(s1: sm, s2: s2), typ: target)
      end
  end
end

let unify_float_binop = fn (state: CheckState, subst: [SubstEntry], lt: TypeExpr, rt: TypeExpr) -> InferExprResult do
  let target = select_float_type(a: lt, b: rt)
  let tdefs = state_typedefs(state: state)
  match unify(t1: lt, t2: target, tdefs: tdefs)
    case UnifyErr(message: m) -> return InferExprErr(message: "float op lhs: " ++ m)
    case UnifyOk(subst: s1) ->
      let sm = subst_compose(s1: subst, s2: s1)
      match unify(t1: subst_apply(subst: sm, typ: rt), t2: target, tdefs: tdefs)
        case UnifyErr(message: m) -> return InferExprErr(message: "float op rhs: " ++ m)
        case UnifyOk(subst: s2) ->
          return InferExprOk(state: state, subst: subst_compose(s1: sm, s2: s2), typ: target)
      end
  end
end

let unify_cmp_binop = fn (state: CheckState, subst: [SubstEntry], lt: TypeExpr, rt: TypeExpr) -> InferExprResult do
  let tdefs = state_typedefs(state: state)
  match unify(t1: lt, t2: rt, tdefs: tdefs)
    case UnifyErr(message: m) -> return InferExprErr(message: "comparison: " ++ m)
    case UnifyOk(subst: s1) ->
      return InferExprOk(state: state, subst: subst_compose(s1: subst, s2: s1), typ: TyBool)
  end
end

let unify_float_cmp = fn (state: CheckState, subst: [SubstEntry], lt: TypeExpr, rt: TypeExpr) -> InferExprResult do
  let tdefs = state_typedefs(state: state)
  let target = select_float_type(a: lt, b: rt)
  match unify(t1: lt, t2: target, tdefs: tdefs)
    case UnifyErr(message: m) -> return InferExprErr(message: "float cmp lhs: " ++ m)
    case UnifyOk(subst: s1) ->
      let sm = subst_compose(s1: subst, s2: s1)
      match unify(t1: subst_apply(subst: sm, typ: rt), t2: target, tdefs: tdefs)
        case UnifyErr(message: m) -> return InferExprErr(message: "float cmp rhs: " ++ m)
        case UnifyOk(subst: s2) ->
          return InferExprOk(state: state, subst: subst_compose(s1: sm, s2: s2), typ: TyBool)
      end
  end
end

let unify_bool_binop = fn (state: CheckState, subst: [SubstEntry], lt: TypeExpr, rt: TypeExpr) -> InferExprResult do
  let tdefs = state_typedefs(state: state)
  match unify(t1: lt, t2: TyBool, tdefs: tdefs)
    case UnifyErr(message: m) -> return InferExprErr(message: "logical lhs: " ++ m)
    case UnifyOk(subst: s1) ->
      let sm = subst_compose(s1: subst, s2: s1)
      match unify(t1: subst_apply(subst: sm, typ: rt), t2: TyBool, tdefs: tdefs)
        case UnifyErr(message: m) -> return InferExprErr(message: "logical rhs: " ++ m)
        case UnifyOk(subst: s2) ->
          return InferExprOk(state: state, subst: subst_compose(s1: sm, s2: s2), typ: TyBool)
      end
  end
end

// ─── Numeric type selection ─────────────────────────────────────────────────

let select_int_type = fn (a: TypeExpr, b: TypeExpr) -> TypeExpr do
  // If either is concrete, use it. Default to i64.
  match a
    case TyI32 -> return TyI32
    case TyI64 -> return TyI64
    case _ -> return ()
  end
  match b
    case TyI32 -> return TyI32
    case TyI64 -> return TyI64
    case _ -> return ()
  end
  return TyI64
end

let select_float_type = fn (a: TypeExpr, b: TypeExpr) -> TypeExpr do
  match a
    case TyF32 -> return TyF32
    case TyF64 -> return TyF64
    case _ -> return ()
  end
  match b
    case TyF32 -> return TyF32
    case TyF64 -> return TyF64
    case _ -> return ()
  end
  return TyF64
end

// ─── Call inference ─────────────────────────────────────────────────────────

let infer_call = fn (state: CheckState, func: string, args: [HirCallArg]) -> InferExprResult do
  match env_lookup(env: state_env(state: state), name: func)
    case None -> return InferExprErr(message: "unbound function: " ++ func)
    case Some(val: Scheme(vars: _, typ: func_type)) ->
      match func_type
        case TyArrow(params: params, ret: ret, requires: _, throw_row: _) ->
          return check_call_args(state: state, params: params, args: args, ret: ret, subst: subst_empty())
        case _ ->
          // Non-arrow type — could be calling a variable bound to a function
          return InferExprErr(message: func ++ " is not a function")
      end
  end
end

let check_call_args = fn (
  state: CheckState, params: [NamedType], args: [HirCallArg],
  ret: TypeExpr, subst: [SubstEntry]
) -> InferExprResult do
  match params
    case Nil ->
      match args
        case Nil -> return InferExprOk(state: state, subst: subst, typ: subst_apply(subst: subst, typ: ret))
        case _ -> return InferExprErr(message: "too many arguments")
      end
    case NamedType(name: pname, typ: ptyp) :: rp ->
      match args
        case Nil -> return InferExprErr(message: "missing argument: " ++ pname)
        case HirCallArg(label: _, value: val) :: ra ->
          match infer_expr(state: state, expr: val)
            case InferExprErr(message: m) -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m)
            case InferExprOk(state: st1, subst: s1, typ: arg_t) ->
              let s_merged = subst_compose(s1: subst, s2: s1)
              let expected = subst_apply(subst: s_merged, typ: ptyp)
              let tdefs = state_typedefs(state: st1)
              match unify(t1: arg_t, t2: expected, tdefs: tdefs)
                case UnifyErr(message: m) -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m)
                case UnifyOk(subst: s2) ->
                  let s_all = subst_compose(s1: s_merged, s2: s2)
                  return check_call_args(state: st1, params: rp, args: ra, ret: ret, subst: s_all)
              end
          end
      end
  end
end

// ─── Constructor inference ──────────────────────────────────────────────────

let infer_constructor = fn (state: CheckState, variant: string, args: [HirExpr]) -> InferExprResult do
  match find_variant(defs: state_enums(state: state), variant: variant)
    case None -> return InferExprErr(message: "unknown constructor: " ++ variant)
    case Some(val: EnumVariantInfo(enum_name: ename, type_params: tps, fields: fields)) ->
      // Generate fresh type vars for type parameters
      let fr = freshen_type_params(state: state, params: tps)
      match fr
        case FreshenResult(state: st1, param_subst: psubst) ->
          // Check constructor args against field types
          let enum_type = build_enum_type(name: ename, params: tps, param_subst: psubst)
          return check_ctor_args(state: st1, fields: fields, args: args, param_subst: psubst, enum_type: enum_type, subst: subst_empty())
      end
  end
end

type FreshenResult = FreshenResult(state: CheckState, param_subst: [SubstEntry])

let freshen_type_params = fn (state: CheckState, params: [string]) -> FreshenResult do
  match params
    case Nil -> return FreshenResult(state: state, param_subst: subst_empty())
    case p :: rest ->
      match tc_fresh_var(state: state)
        case FreshResult(state: st1, typ: tv) ->
          match freshen_type_params(state: st1, params: rest)
            case FreshenResult(state: st2, param_subst: ps) ->
              return FreshenResult(
                state: st2,
                param_subst: Cons(v: SubstEntry(var: p, typ: tv), rest: ps)
              )
          end
      end
  end
end

let build_enum_type = fn (name: string, params: [string], param_subst: [SubstEntry]) -> TypeExpr do
  let args = build_type_args(params: params, param_subst: param_subst)
  return TyUserDefined(name: name, args: args)
end

let build_type_args = fn (params: [string], param_subst: [SubstEntry]) -> [TypeExpr] do
  match params
    case Nil -> return Nil
    case p :: rest ->
      match subst_apply(subst: param_subst, typ: TyVar(name: p))
        case resolved ->
          return Cons(v: resolved, rest: build_type_args(params: rest, param_subst: param_subst))
      end
  end
end

let check_ctor_args = fn (
  state: CheckState, fields: [VariantField], args: [HirExpr],
  param_subst: [SubstEntry], enum_type: TypeExpr, subst: [SubstEntry]
) -> InferExprResult do
  match fields
    case Nil ->
      match args
        case Nil -> return InferExprOk(state: state, subst: subst, typ: subst_apply(subst: subst, typ: enum_type))
        case _ -> return InferExprErr(message: "too many constructor arguments")
      end
    case VariantField(name: _, typ: ftyp) :: rf ->
      match args
        case Nil -> return InferExprErr(message: "missing constructor argument")
        case arg :: ra ->
          match infer_expr(state: state, expr: arg)
            case InferExprErr(message: m) -> return InferExprErr(message: m)
            case InferExprOk(state: st1, subst: s1, typ: at) ->
              let sm = subst_compose(s1: subst, s2: s1)
              let expected = subst_apply(subst: subst_compose(s1: param_subst, s2: sm), typ: ftyp)
              let tdefs = state_typedefs(state: st1)
              match unify(t1: at, t2: expected, tdefs: tdefs)
                case UnifyErr(message: m) -> return InferExprErr(message: "ctor field: " ++ m)
                case UnifyOk(subst: s2) ->
                  return check_ctor_args(
                    state: st1, fields: rf, args: ra,
                    param_subst: param_subst, enum_type: enum_type,
                    subst: subst_compose(s1: sm, s2: s2)
                  )
              end
          end
      end
  end
end

// ─── Record inference ───────────────────────────────────────────────────────

let infer_record = fn (state: CheckState, fields: [HirNamedExpr]) -> InferExprResult do
  return infer_record_fields(state: state, fields: fields, subst: subst_empty(), acc: Nil)
end

let infer_record_fields = fn (state: CheckState, fields: [HirNamedExpr], subst: [SubstEntry], acc: [NamedType]) -> InferExprResult do
  match fields
    case Nil ->
      return InferExprOk(state: state, subst: subst, typ: TyRecord(fields: reverse_named_types(nts: acc, out: Nil)))
    case HirNamedExpr(name: n, value: v) :: rest ->
      match infer_expr(state: state, expr: v)
        case InferExprErr(message: m) -> return InferExprErr(message: "record field " ++ n ++ ": " ++ m)
        case InferExprOk(state: st1, subst: s1, typ: ft) ->
          let sm = subst_compose(s1: subst, s2: s1)
          return infer_record_fields(
            state: st1, fields: rest, subst: sm,
            acc: Cons(v: NamedType(name: n, typ: ft), rest: acc)
          )
      end
  end
end

let reverse_named_types = fn (nts: [NamedType], out: [NamedType]) -> [NamedType] do
  match nts
    case Nil -> return out
    case h :: rest ->
      return reverse_named_types(nts: rest, out: Cons(v: h, rest: out))
  end
end

// Fix infer_record to use the correct helper
// (Override the earlier definition by redefining)

// ─── Array inference ────────────────────────────────────────────────────────

let infer_array = fn (state: CheckState, elems: [HirExpr]) -> InferExprResult do
  match elems
    case Nil ->
      match tc_fresh_var(state: state)
        case FreshResult(state: st, typ: tv) ->
          return InferExprOk(state: st, subst: subst_empty(), typ: TyArray(elem: tv))
      end
    case first :: rest ->
      match infer_expr(state: state, expr: first)
        case InferExprErr(message: m) -> return InferExprErr(message: m)
        case InferExprOk(state: st1, subst: s1, typ: t1) ->
          return unify_array_elems(state: st1, elems: rest, subst: s1, elem_type: t1)
      end
  end
end

let unify_array_elems = fn (state: CheckState, elems: [HirExpr], subst: [SubstEntry], elem_type: TypeExpr) -> InferExprResult do
  match elems
    case Nil -> return InferExprOk(state: state, subst: subst, typ: TyArray(elem: subst_apply(subst: subst, typ: elem_type)))
    case e :: rest ->
      match infer_expr(state: state, expr: e)
        case InferExprErr(message: m) -> return InferExprErr(message: m)
        case InferExprOk(state: st1, subst: s1, typ: et) ->
          let sm = subst_compose(s1: subst, s2: s1)
          let tdefs = state_typedefs(state: st1)
          match unify(t1: et, t2: subst_apply(subst: sm, typ: elem_type), tdefs: tdefs)
            case UnifyErr(message: m) -> return InferExprErr(message: "array element: " ++ m)
            case UnifyOk(subst: s2) ->
              return unify_array_elems(state: st1, elems: rest, subst: subst_compose(s1: sm, s2: s2), elem_type: elem_type)
          end
      end
  end
end

// ─── Index inference ────────────────────────────────────────────────────────

let infer_index = fn (state: CheckState, target: HirExpr, index: HirExpr) -> InferExprResult do
  match infer_expr(state: state, expr: target)
    case InferExprErr(message: m) -> return InferExprErr(message: m)
    case InferExprOk(state: st1, subst: s1, typ: tt) ->
      match infer_expr(state: st1, expr: index)
        case InferExprErr(message: m) -> return InferExprErr(message: m)
        case InferExprOk(state: st2, subst: s2, typ: it) ->
          let sm = subst_compose(s1: s1, s2: s2)
          let tdefs = state_typedefs(state: st2)
          match unify(t1: it, t2: TyI64, tdefs: tdefs)
            case UnifyErr(message: m) -> return InferExprErr(message: "index must be i64: " ++ m)
            case UnifyOk(subst: s3) ->
              let sf = subst_compose(s1: sm, s2: s3)
              let arr_t = subst_apply(subst: sf, typ: tt)
              match arr_t
                case TyArray(elem: e) -> return InferExprOk(state: st2, subst: sf, typ: e)
                case _ -> return InferExprErr(message: "cannot index non-array type")
              end
          end
      end
  end
end

// ─── Field access inference ─────────────────────────────────────────────────

let infer_field_access = fn (state: CheckState, target: HirExpr, field: string) -> InferExprResult do
  match infer_expr(state: state, expr: target)
    case InferExprErr(message: m) -> return InferExprErr(message: m)
    case InferExprOk(state: st1, subst: s1, typ: tt) ->
      let resolved = subst_apply(subst: s1, typ: tt)
      match resolved
        case TyRecord(fields: fs) ->
          match lookup_named_type(nts: fs, name: field)
            case Some(val: ft) -> return InferExprOk(state: st1, subst: s1, typ: ft)
            case None -> return InferExprErr(message: "no field " ++ field ++ " in record")
          end
        case _ -> return InferExprErr(message: "field access on non-record type")
      end
  end
end

let lookup_named_type = fn (nts: [NamedType], name: string) -> Option<TypeExpr> do
  match nts
    case Nil -> return None
    case NamedType(name: n, typ: t) :: rest ->
      if n == name then
        return Some(val: t)
      end
      return lookup_named_type(nts: rest, name: name)
  end
end

// ─── If inference (always Unit) ─────────────────────────────────────────────

let infer_if = fn (state: CheckState, cond: HirExpr, then_b: [HirStmt], else_b: Option<[HirStmt]>) -> InferExprResult do
  match infer_expr(state: state, expr: cond)
    case InferExprErr(message: m) -> return InferExprErr(message: m)
    case InferExprOk(state: st1, subst: s1, typ: ct) ->
      let tdefs = state_typedefs(state: st1)
      match unify(t1: ct, t2: TyBool, tdefs: tdefs)
        case UnifyErr(message: m) -> return InferExprErr(message: "if condition must be bool: " ++ m)
        case UnifyOk(subst: s2) ->
          let sm = subst_compose(s1: s1, s2: s2)
          let env1 = subst_apply_env(subst: sm, env: state_env(state: st1))
          let st2 = state_with_env(state: st1, env: env1)
          match infer_stmts(state: st2, stmts: then_b, ret_type: TyUnit)
            case InferExprErr(message: m) -> return InferExprErr(message: "if then: " ++ m)
            case InferExprOk(state: st3, subst: s3, typ: _) ->
              let sm2 = subst_compose(s1: sm, s2: s3)
              match else_b
                case None -> return InferExprOk(state: st3, subst: sm2, typ: TyUnit)
                case Some(val: else_stmts) ->
                  match infer_stmts(state: st3, stmts: else_stmts, ret_type: TyUnit)
                    case InferExprErr(message: m) -> return InferExprErr(message: "if else: " ++ m)
                    case InferExprOk(state: st4, subst: s4, typ: _) ->
                      return InferExprOk(state: st4, subst: subst_compose(s1: sm2, s2: s4), typ: TyUnit)
                  end
              end
          end
      end
  end
end

// ─── Match inference ────────────────────────────────────────────────────────

let infer_match = fn (state: CheckState, target: HirExpr, cases: [HirMatchCase]) -> InferExprResult do
  match infer_expr(state: state, expr: target)
    case InferExprErr(message: m) -> return InferExprErr(message: m)
    case InferExprOk(state: st1, subst: s1, typ: tt) ->
      return infer_match_cases(state: st1, cases: cases, target_type: tt, subst: s1, ret_type: TyUnit)
  end
end

let infer_match_cases = fn (
  state: CheckState, cases: [HirMatchCase],
  target_type: TypeExpr, subst: [SubstEntry], ret_type: TypeExpr
) -> InferExprResult do
  match cases
    case Nil -> return InferExprOk(state: state, subst: subst, typ: TyUnit)
    case HirMatchCase(pattern: pat, body: body) :: rest ->
      let tt = subst_apply(subst: subst, typ: target_type)
      match bind_pattern(state: state, pattern: pat, target_type: tt)
        case BindErr(message: m) -> return InferExprErr(message: "match pattern: " ++ m)
        case BindOk(state: st1, subst: ps, env: bindings) ->
          let sm = subst_compose(s1: subst, s2: ps)
          let case_env = append_env(base: state_env(state: st1), extra: bindings)
          let st2 = state_with_env(state: st1, env: subst_apply_env(subst: sm, env: case_env))
          match infer_stmts(state: st2, stmts: body, ret_type: ret_type)
            case InferExprErr(message: m) -> return InferExprErr(message: "match case: " ++ m)
            case InferExprOk(state: st3, subst: bs, typ: _) ->
              // Restore env to pre-case state
              let st4 = state_with_env(state: st3, env: state_env(state: state))
              return infer_match_cases(
                state: st4, cases: rest,
                target_type: target_type, subst: subst_compose(s1: sm, s2: bs),
                ret_type: ret_type
              )
          end
      end
  end
end

let append_env = fn (base: [EnvEntry], extra: [EnvEntry]) -> [EnvEntry] do
  match extra
    case Nil -> return base
    case entry :: rest ->
      return append_env(base: Cons(v: entry, rest: base), extra: rest)
  end
end

// ─── While inference ────────────────────────────────────────────────────────

let infer_while = fn (state: CheckState, cond: HirExpr, body: [HirStmt]) -> InferExprResult do
  match infer_expr(state: state, expr: cond)
    case InferExprErr(message: m) -> return InferExprErr(message: m)
    case InferExprOk(state: st1, subst: s1, typ: ct) ->
      let tdefs = state_typedefs(state: st1)
      match unify(t1: ct, t2: TyBool, tdefs: tdefs)
        case UnifyErr(message: m) -> return InferExprErr(message: "while cond must be bool: " ++ m)
        case UnifyOk(subst: s2) ->
          let sm = subst_compose(s1: s1, s2: s2)
          let st2 = state_with_env(state: st1, env: subst_apply_env(subst: sm, env: state_env(state: st1)))
          match infer_stmts(state: st2, stmts: body, ret_type: TyUnit)
            case InferExprErr(message: m) -> return InferExprErr(message: "while body: " ++ m)
            case InferExprOk(state: st3, subst: s3, typ: _) ->
              return InferExprOk(state: st3, subst: subst_compose(s1: sm, s2: s3), typ: TyUnit)
          end
      end
  end
end

// ─── For inference ──────────────────────────────────────────────────────────

let infer_for = fn (state: CheckState, var: string, start: HirExpr, end_e: HirExpr, body: [HirStmt]) -> InferExprResult do
  match infer_expr(state: state, expr: start)
    case InferExprErr(message: m) -> return InferExprErr(message: m)
    case InferExprOk(state: st1, subst: s1, typ: st_t) ->
      let tdefs = state_typedefs(state: st1)
      match unify(t1: st_t, t2: TyI64, tdefs: tdefs)
        case UnifyErr(message: m) -> return InferExprErr(message: "for start must be i64: " ++ m)
        case UnifyOk(subst: s2) ->
          let sm = subst_compose(s1: s1, s2: s2)
          match infer_expr(state: st1, expr: end_e)
            case InferExprErr(message: m) -> return InferExprErr(message: m)
            case InferExprOk(state: st2, subst: s3, typ: et_t) ->
              let sm2 = subst_compose(s1: sm, s2: s3)
              match unify(t1: et_t, t2: TyI64, tdefs: tdefs)
                case UnifyErr(message: m) -> return InferExprErr(message: "for end must be i64: " ++ m)
                case UnifyOk(subst: s4) ->
                  let sm3 = subst_compose(s1: sm2, s2: s4)
                  let body_env = env_insert(env: subst_apply_env(subst: sm3, env: state_env(state: st2)), name: var, scheme: mono(typ: TyI64))
                  let st3 = state_with_env(state: st2, env: body_env)
                  match infer_stmts(state: st3, stmts: body, ret_type: TyUnit)
                    case InferExprErr(message: m) -> return InferExprErr(message: "for body: " ++ m)
                    case InferExprOk(state: st4, subst: s5, typ: _) ->
                      return InferExprOk(state: st4, subst: subst_compose(s1: sm3, s2: s5), typ: TyUnit)
                  end
              end
          end
      end
  end
end

// ─── Lambda inference ───────────────────────────────────────────────────────

let infer_lambda = fn (state: CheckState, params: [HirParam], ret_type: TypeExpr, body: [HirStmt]) -> InferExprResult do
  let param_types = build_param_named_types(params: params)
  let body_env = add_params_to_env(env: state_env(state: state), params: params)
  let st1 = state_with_env(state: state, env: body_env)
  match infer_stmts(state: st1, stmts: body, ret_type: ret_type)
    case InferExprErr(message: m) -> return InferExprErr(message: "lambda body: " ++ m)
    case InferExprOk(state: st2, subst: s1, typ: _) ->
      let arrow = TyArrow(
        params: param_types,
        ret: ret_type,
        requires: TyRow(types: Nil, rest: None),
        throw_row: TyRow(types: Nil, rest: None)
      )
      return InferExprOk(state: st2, subst: s1, typ: subst_apply(subst: s1, typ: arrow))
  end
end

let build_param_named_types = fn (params: [HirParam]) -> [NamedType] do
  match params
    case Nil -> return Nil
    case HirParam(name: n, label: _, typ: t) :: rest ->
      return Cons(v: NamedType(name: n, typ: t), rest: build_param_named_types(params: rest))
  end
end

let add_params_to_env = fn (env: [EnvEntry], params: [HirParam]) -> [EnvEntry] do
  match params
    case Nil -> return env
    case HirParam(name: n, label: _, typ: t) :: rest ->
      return add_params_to_env(env: env_insert(env: env, name: n, scheme: mono(typ: t)), params: rest)
  end
end

// ─── Raise inference ────────────────────────────────────────────────────────

let infer_raise = fn (state: CheckState, inner: HirExpr) -> InferExprResult do
  match infer_expr(state: state, expr: inner)
    case InferExprErr(message: m) -> return InferExprErr(message: m)
    case InferExprOk(state: st1, subst: s1, typ: _) ->
      // Raise diverges, return a fresh type variable
      match tc_fresh_var(state: st1)
        case FreshResult(state: st2, typ: tv) ->
          return InferExprOk(state: st2, subst: s1, typ: tv)
      end
  end
end

// ─── Statement inference ────────────────────────────────────────────────────

export let infer_stmts = fn (state: CheckState, stmts: [HirStmt], ret_type: TypeExpr) -> InferExprResult do
  match stmts
    case Nil -> return InferExprOk(state: state, subst: subst_empty(), typ: TyUnit)
    case stmt :: rest ->
      match infer_stmt(state: state, stmt: stmt, ret_type: ret_type)
        case InferExprErr(message: m) -> return InferExprErr(message: m)
        case InferExprOk(state: st1, subst: s1, typ: _) ->
          let env1 = subst_apply_env(subst: s1, env: state_env(state: st1))
          let st2 = state_with_env(state: st1, env: env1)
          match infer_stmts(state: st2, stmts: rest, ret_type: subst_apply(subst: s1, typ: ret_type))
            case InferExprErr(message: m) -> return InferExprErr(message: m)
            case InferExprOk(state: st3, subst: s2, typ: t) ->
              return InferExprOk(state: st3, subst: subst_compose(s1: s1, s2: s2), typ: t)
          end
      end
  end
end

let infer_stmt = fn (state: CheckState, stmt: HirStmt, ret_type: TypeExpr) -> InferExprResult do
  match stmt
    case HirStmtLet(name: name, typ: ann, value: value) ->
      return infer_let(state: state, name: name, ann: ann, value: value)
    case HirStmtExpr(expr: expr) ->
      return infer_expr(state: state, expr: expr)
    case HirStmtReturn(expr: expr) ->
      return infer_return(state: state, expr: expr, ret_type: ret_type)
    case HirStmtAssign(target: _, value: value) ->
      // Simplified: just check the value expression
      return infer_expr(state: state, expr: value)
    case HirStmtConc(tasks: tasks) ->
      return infer_conc_tasks(state: state, tasks: tasks)
    case HirStmtTry(body: body, catch_param: cp, catch_body: cb) ->
      return infer_try(state: state, body: body, catch_param: cp, catch_body: cb, ret_type: ret_type)
    case HirStmtInject(handlers: _, body: body) ->
      // Simplified: just check the body
      return infer_stmts(state: state, stmts: body, ret_type: ret_type)
  end
end

// ─── Let statement inference ────────────────────────────────────────────────

let infer_let = fn (state: CheckState, name: string, ann: Option<TypeExpr>, value: HirExpr) -> InferExprResult do
  // Pre-register for recursive lambdas
  let st0 = match value
    case HirLambda(params: params, ret_type: ret, body: _) ->
      let arrow = TyArrow(
        params: build_param_named_types(params: params),
        ret: ret,
        requires: TyRow(types: Nil, rest: None),
        throw_row: TyRow(types: Nil, rest: None)
      )
      let env1 = env_insert(env: state_env(state: state), name: name, scheme: mono(typ: arrow))
      state_with_env(state: state, env: env1)
    case _ -> state
  end
  match infer_expr(state: st0, expr: value)
    case InferExprErr(message: m) -> return InferExprErr(message: "let " ++ name ++ ": " ++ m)
    case InferExprOk(state: st1, subst: s1, typ: t1) ->
      let final_type = match ann
        case Some(val: expected) ->
          let tdefs = state_typedefs(state: st1)
          match unify(t1: t1, t2: expected, tdefs: tdefs)
            case UnifyErr(message: m) ->
              // We can't return InferExprErr from inside match-as-expression
              // so we use the annotation type and hope for the best
              expected
            case UnifyOk(subst: _) ->
              expected
          end
        case None -> default_numeric_literals(typ: t1)
      end
      let env2 = env_insert(
        env: subst_apply_env(subst: s1, env: state_env(state: st1)),
        name: name, scheme: mono(typ: final_type)
      )
      return InferExprOk(state: state_with_env(state: st1, env: env2), subst: s1, typ: TyUnit)
  end
end

// ─── Return statement inference ─────────────────────────────────────────────

let infer_return = fn (state: CheckState, expr: HirExpr, ret_type: TypeExpr) -> InferExprResult do
  match infer_expr(state: state, expr: expr)
    case InferExprErr(message: m) -> return InferExprErr(message: "return: " ++ m)
    case InferExprOk(state: st1, subst: s1, typ: t1) ->
      let expected = subst_apply(subst: s1, typ: ret_type)
      let tdefs = state_typedefs(state: st1)
      match unify(t1: t1, t2: expected, tdefs: tdefs)
        case UnifyErr(message: m) -> return InferExprErr(message: "return type mismatch: " ++ m)
        case UnifyOk(subst: s2) ->
          return InferExprOk(state: st1, subst: subst_compose(s1: s1, s2: s2), typ: TyUnit)
      end
  end
end

// ─── Conc inference ─────────────────────────────────────────────────────────

let infer_conc_tasks = fn (state: CheckState, tasks: [HirFunction]) -> InferExprResult do
  match tasks
    case Nil -> return InferExprOk(state: state, subst: subst_empty(), typ: TyUnit)
    case HirFunction(name: _, params: _, ret_type: _, body: body, span: _) :: rest ->
      match infer_stmts(state: state, stmts: body, ret_type: TyUnit)
        case InferExprErr(message: m) -> return InferExprErr(message: "conc task: " ++ m)
        case InferExprOk(state: st1, subst: s1, typ: _) ->
          match infer_conc_tasks(state: st1, tasks: rest)
            case InferExprErr(message: m) -> return InferExprErr(message: m)
            case InferExprOk(state: st2, subst: s2, typ: _) ->
              return InferExprOk(state: st2, subst: subst_compose(s1: s1, s2: s2), typ: TyUnit)
          end
      end
  end
end

// ─── Try inference ──────────────────────────────────────────────────────────

let infer_try = fn (state: CheckState, body: [HirStmt], catch_param: string, catch_body: [HirStmt], ret_type: TypeExpr) -> InferExprResult do
  match infer_stmts(state: state, stmts: body, ret_type: ret_type)
    case InferExprErr(message: m) -> return InferExprErr(message: "try body: " ++ m)
    case InferExprOk(state: st1, subst: s1, typ: _) ->
      let catch_env = env_insert(
        env: state_env(state: st1),
        name: catch_param,
        scheme: mono(typ: TyUserDefined(name: "Exn", args: Nil))
      )
      let st2 = state_with_env(state: st1, env: catch_env)
      match infer_stmts(state: st2, stmts: catch_body, ret_type: ret_type)
        case InferExprErr(message: m) -> return InferExprErr(message: "catch: " ++ m)
        case InferExprOk(state: st3, subst: s2, typ: _) ->
          // Restore env to pre-try state
          let st4 = state_with_env(state: st3, env: state_env(state: state))
          return InferExprOk(state: st4, subst: subst_compose(s1: s1, s2: s2), typ: TyUnit)
      end
  end
end

// ─── Pattern binding ────────────────────────────────────────────────────────

export let bind_pattern = fn (state: CheckState, pattern: HirPattern, target_type: TypeExpr) -> BindResult do
  match pattern
    case HirPatWildcard ->
      return BindOk(state: state, subst: subst_empty(), env: Nil)
    case HirPatVariable(name: name, sigil: _) ->
      return BindOk(
        state: state, subst: subst_empty(),
        env: Cons(v: EnvEntry(name: name, scheme: mono(typ: target_type)), rest: Nil)
      )
    case HirPatLiteral(lit: lit) ->
      let lit_type = match lit
        case LitInt(val: _) -> TyIntLit
        case LitFloat(val: _) -> TyFloatLit
        case LitBool(val: _) -> TyBool
        case LitChar(val: _) -> TyChar
        case LitString(val: _) -> TyString
        case LitUnit -> TyUnit
      end
      let tdefs = state_typedefs(state: state)
      match unify(t1: lit_type, t2: target_type, tdefs: tdefs)
        case UnifyErr(message: m) -> return BindErr(message: "literal pattern: " ++ m)
        case UnifyOk(subst: s) -> return BindOk(state: state, subst: s, env: Nil)
      end
    case HirPatConstructor(variant: variant, fields: fields) ->
      return bind_constructor_pattern(state: state, variant: variant, fields: fields, target_type: target_type)
    case HirPatRecord(fields: fields, is_partial: _) ->
      return bind_record_pattern(state: state, fields: fields, target_type: target_type)
  end
end

let bind_constructor_pattern = fn (
  state: CheckState, variant: string,
  fields: [HirPatternField], target_type: TypeExpr
) -> BindResult do
  match find_variant(defs: state_enums(state: state), variant: variant)
    case None -> return BindErr(message: "unknown constructor in pattern: " ++ variant)
    case Some(val: EnumVariantInfo(enum_name: ename, type_params: tps, fields: field_types)) ->
      let fr = freshen_type_params(state: state, params: tps)
      match fr
        case FreshenResult(state: st1, param_subst: psubst) ->
          let enum_type = build_enum_type(name: ename, params: tps, param_subst: psubst)
          let tdefs = state_typedefs(state: st1)
          match unify(t1: enum_type, t2: target_type, tdefs: tdefs)
            case UnifyErr(message: m) -> return BindErr(message: "constructor pattern type: " ++ m)
            case UnifyOk(subst: s1) ->
              let full_subst = subst_compose(s1: psubst, s2: s1)
              return bind_ctor_fields(state: st1, fields: fields, field_types: field_types, param_subst: full_subst, subst: s1, env: Nil)
          end
      end
  end
end

let bind_ctor_fields = fn (
  state: CheckState, fields: [HirPatternField], field_types: [VariantField],
  param_subst: [SubstEntry], subst: [SubstEntry], env: [EnvEntry]
) -> BindResult do
  match fields
    case Nil -> return BindOk(state: state, subst: subst, env: env)
    case HirPatternField(name: _, pattern: pat) :: rf ->
      match field_types
        case Nil -> return BindErr(message: "too many constructor pattern fields")
        case VariantField(name: _, typ: ft) :: rft ->
          let expected = subst_apply(subst: param_subst, typ: ft)
          match bind_pattern(state: state, pattern: pat, target_type: expected)
            case BindErr(message: m) -> return BindErr(message: m)
            case BindOk(state: st1, subst: ps, env: new_binds) ->
              let sm = subst_compose(s1: subst, s2: ps)
              return bind_ctor_fields(
                state: st1, fields: rf, field_types: rft,
                param_subst: param_subst, subst: sm,
                env: append_env(base: env, extra: new_binds)
              )
          end
      end
  end
end

let bind_record_pattern = fn (
  state: CheckState, fields: [HirRecordPatField], target_type: TypeExpr
) -> BindResult do
  match target_type
    case TyRecord(fields: rec_fields) ->
      return bind_rec_pat_fields(state: state, fields: fields, rec_fields: rec_fields, subst: subst_empty(), env: Nil)
    case _ -> return BindErr(message: "record pattern on non-record type")
  end
end

let bind_rec_pat_fields = fn (
  state: CheckState, fields: [HirRecordPatField],
  rec_fields: [NamedType], subst: [SubstEntry], env: [EnvEntry]
) -> BindResult do
  match fields
    case Nil -> return BindOk(state: state, subst: subst, env: env)
    case HirRecordPatField(name: fname, pattern: pat) :: rest ->
      match lookup_named_type(nts: rec_fields, name: fname)
        case None -> return BindErr(message: "no field " ++ fname ++ " in record pattern")
        case Some(val: ft) ->
          match bind_pattern(state: state, pattern: pat, target_type: ft)
            case BindErr(message: m) -> return BindErr(message: m)
            case BindOk(state: st1, subst: ps, env: new_binds) ->
              let sm = subst_compose(s1: subst, s2: ps)
              return bind_rec_pat_fields(
                state: st1, fields: rest, rec_fields: rec_fields,
                subst: sm, env: append_env(base: env, extra: new_binds)
              )
          end
      end
  end
end

// ─── Numeric literal defaulting ─────────────────────────────────────────────

export let default_numeric_literals = fn (typ: TypeExpr) -> TypeExpr do
  match typ
    case TyIntLit -> return TyI64
    case TyFloatLit -> return TyF64
    case TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return TyArrow(
        params: default_named_types(nts: ps),
        ret: default_numeric_literals(typ: r),
        requires: req,
        throw_row: thr
      )
    case TyArray(elem: e) -> return TyArray(elem: default_numeric_literals(typ: e))
    case TyList(elem: e) -> return TyList(elem: default_numeric_literals(typ: e))
    case TyRecord(fields: fs) -> return TyRecord(fields: default_named_types(nts: fs))
    case _ -> return typ
  end
end

let default_named_types = fn (nts: [NamedType]) -> [NamedType] do
  match nts
    case Nil -> return Nil
    case NamedType(name: n, typ: t) :: rest ->
      return Cons(
        v: NamedType(name: n, typ: default_numeric_literals(typ: t)),
        rest: default_named_types(nts: rest)
      )
  end
end
