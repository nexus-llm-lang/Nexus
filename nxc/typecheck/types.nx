/**
 * typecheck/types: Core types for the Nexus self-hosting typechecker.
 *
 * Defines Scheme, TypeEnv (as association lists), CheckState,
 * and result types for the typechecker passes.
 */

import { Span } from nxc/common/token.nx
import {
  TypeExpr, TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyBorrow,
  TyArray, TyList, TyRecord, TyRow, TyHandler, NamedType,
  EnumDef, VariantDef, VariantField, RecordDef
} from nxc/common/ast.nx
import { from_i64 } from stdlib/string.nx

// ─── Substitution ───────────────────────────────────────────────────────────

export type SubstEntry = SubstEntry(var: string, typ: TypeExpr)

// ─── Scheme ─────────────────────────────────────────────────────────────────

export type Scheme = Scheme(vars: [string], typ: TypeExpr)

// ─── Environment entries ────────────────────────────────────────────────────

export type EnvEntry = EnvEntry(name: string, scheme: Scheme)

export type EnumEntry = EnumEntry(name: string, def: EnumDef)

export type TypeDefEntry = TypeDefEntry(name: string, def: RecordDef)

// ─── Checker state ──────────────────────────────────────────────────────────

export type CheckState = CheckState(
  supply: i64,
  env: [EnvEntry],
  enum_defs: [EnumEntry],
  type_defs: [TypeDefEntry]
)

// ─── Result types ───────────────────────────────────────────────────────────

export type FreshResult = FreshResult(state: CheckState, typ: TypeExpr)

export type InferResult =
  InferOk(subst: [SubstEntry], typ: TypeExpr)
  | InferErr(message: string)

export type UnifyResult =
  UnifyOk(subst: [SubstEntry])
  | UnifyErr(message: string)

export type InferExprResult =
  InferExprOk(state: CheckState, subst: [SubstEntry], typ: TypeExpr)
  | InferExprErr(message: string)

export type BindResult =
  BindOk(state: CheckState, subst: [SubstEntry], env: [EnvEntry])
  | BindErr(message: string)

export type EnumVariantInfo = EnumVariantInfo(
  enum_name: string,
  type_params: [string],
  fields: [VariantField]
)

// ─── State operations ───────────────────────────────────────────────────────

export let tc_new_state = fn (enum_defs: [EnumEntry], type_defs: [TypeDefEntry]) -> CheckState do
  return CheckState(supply: 0, env: Nil, enum_defs: enum_defs, type_defs: type_defs)
end

export let tc_fresh_var = fn (state: CheckState) -> FreshResult do
  match state
    case CheckState(supply: n, env: e, enum_defs: ed, type_defs: td) ->
      let name = "?" ++ from_i64(val: n)
      return FreshResult(
        state: CheckState(supply: n + 1, env: e, enum_defs: ed, type_defs: td),
        typ: TyVar(name: name)
      )
  end
end

// ─── Environment operations ─────────────────────────────────────────────────

export let env_lookup = fn (env: [EnvEntry], name: string) -> Option<Scheme> do
  match env
    case Nil -> return None
    case EnvEntry(name: n, scheme: s) :: rest ->
      if n == name then
        return Some(val: s)
      end
      return env_lookup(env: rest, name: name)
  end
end

export let env_insert = fn (env: [EnvEntry], name: string, scheme: Scheme) -> [EnvEntry] do
  return Cons(v: EnvEntry(name: name, scheme: scheme), rest: env)
end

export let mono = fn (typ: TypeExpr) -> Scheme do
  return Scheme(vars: Nil, typ: typ)
end

// ─── Enum lookup ────────────────────────────────────────────────────────────

export let enum_lookup = fn (defs: [EnumEntry], name: string) -> Option<EnumDef> do
  match defs
    case Nil -> return None
    case EnumEntry(name: n, def: d) :: rest ->
      if n == name then
        return Some(val: d)
      end
      return enum_lookup(defs: rest, name: name)
  end
end

export let typedef_lookup = fn (defs: [TypeDefEntry], name: string) -> Option<RecordDef> do
  match defs
    case Nil -> return None
    case TypeDefEntry(name: n, def: d) :: rest ->
      if n == name then
        return Some(val: d)
      end
      return typedef_lookup(defs: rest, name: name)
  end
end

/// Find which enum a variant belongs to and return its info.
export let find_variant = fn (defs: [EnumEntry], variant: string) -> Option<EnumVariantInfo> do
  match defs
    case Nil -> return None
    case EnumEntry(name: _, def: EnumDef(name: ename, is_public: _, is_opaque: _, type_params: tps, variants: vs)) :: rest ->
      match find_variant_in_list(variants: vs, variant: variant)
        case Some(val: VariantDef(name: _, fields: fs)) ->
          return Some(val: EnumVariantInfo(enum_name: ename, type_params: tps, fields: fs))
        case None -> return find_variant(defs: rest, variant: variant)
      end
  end
end

let find_variant_in_list = fn (variants: [VariantDef], variant: string) -> Option<VariantDef> do
  match variants
    case Nil -> return None
    case VariantDef(name: n, fields: fs) :: rest ->
      if n == variant then
        return Some(val: VariantDef(name: n, fields: fs))
      end
      return find_variant_in_list(variants: rest, variant: variant)
  end
end

// ─── State with env helpers ─────────────────────────────────────────────────

export let state_with_env = fn (state: CheckState, env: [EnvEntry]) -> CheckState do
  match state
    case CheckState(supply: s, env: _, enum_defs: ed, type_defs: td) ->
      return CheckState(supply: s, env: env, enum_defs: ed, type_defs: td)
  end
end

export let state_env = fn (state: CheckState) -> [EnvEntry] do
  match state
    case CheckState(supply: _, env: e, enum_defs: _, type_defs: _) -> return e
  end
end

export let state_enums = fn (state: CheckState) -> [EnumEntry] do
  match state
    case CheckState(supply: _, env: _, enum_defs: ed, type_defs: _) -> return ed
  end
end

export let state_typedefs = fn (state: CheckState) -> [TypeDefEntry] do
  match state
    case CheckState(supply: _, env: _, enum_defs: _, type_defs: td) -> return td
  end
end
