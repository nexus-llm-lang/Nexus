/**
 * parse_type: Type expression parsing for the Nexus self-hosting compiler.
 *
 * Parses all TypeExpr forms: primitives, user-defined (with type args),
 * arrow types, rows, records, refs, linear, borrow, list, array, handler.
 */

import { Token, Span, SpannedToken } from nxc/common/token.nx
import { TypeExpr, NamedType } from nxc/common/ast.nx
import { error, PhaseParse } from nxc/common/error.nx
import {
  ParsedType, ParsedNamedTypes, ParsedTypes, ParsedIdent, ParsedStrings,
  peek_token, peek_span, skip, is_tok, expect, expect_ident, expect_uident,
  is_arrow_start, token_tag
} from nxc/frontend/parse_core.nx
import as list from stdlib/list.nx

// ─── Helpers ────────────────────────────────────────────────────────────────

pub let empty_row = fn () -> TypeExpr do
  return TyRow(types: [], rest: None)
end

// ─── Top-level type dispatch ────────────────────────────────────────────────

pub let parse_type = fn (toks: [SpannedToken]) -> ParsedType throws { Exn } do
  match peek_token(toks: toks)
    case TkLParen -> parse_type_maybe_arrow(toks: toks)
    case _ -> parse_type_atom(toks: toks)
  end
end

pub let parse_type_maybe_arrow = fn (toks: [SpannedToken]) -> ParsedType throws { Exn } do
  if is_arrow_start(toks: toks) then return parse_arrow_type(toks: toks)
  else return parse_type_atom(toks: toks)
  end
end

// ─── Arrow types ────────────────────────────────────────────────────────────

pub let parse_arrow_type = fn (toks: [SpannedToken]) -> ParsedType throws { Exn } do
  let r = expect(toks: toks, expected: "(")
  match parse_arrow_params(toks: r, acc: [])
    case ParsedNamedTypes(fields: ps, rest: r2) ->
      let r3 = expect(toks: r2, expected: ")")
      let r4 = expect(toks: r3, expected: "->")
      match parse_type(toks: r4)
        case ParsedType(typ: ret, rest: r5) ->
          match parse_optional_require(toks: r5)
            case ParsedType(typ: req_ty, rest: r6) ->
              match parse_optional_throws(toks: r6)
                case ParsedType(typ: thr_ty, rest: r7) ->
                  ParsedType(typ: TyArrow(params: ps, ret: ret, requires: req_ty, throw_row: thr_ty), rest: r7)
              end
          end
      end
  end
end

pub let parse_arrow_params = fn (toks: [SpannedToken], acc: [NamedType]) -> ParsedNamedTypes throws { Exn } do
  match peek_token(toks: toks)
    case TkRParen -> return ParsedNamedTypes(fields: list.reverse(xs: acc), rest: toks)
    case _ ->
      match expect_ident(toks: toks)
        case ParsedIdent(name: n, rest: r) ->
          let r2 = expect(toks: r, expected: ":")
          match parse_type(toks: r2)
            case ParsedType(typ: t, rest: r3) ->
              let new_acc = Cons(v: NamedType(name: n, typ: t), rest: acc)
              parse_arrow_params_continue(toks: r3, acc: new_acc)
          end
      end
  end
end

pub let parse_arrow_params_continue = fn (toks: [SpannedToken], acc: [NamedType]) -> ParsedNamedTypes throws { Exn } do
  if is_tok(toks: toks, expected: ",") then return parse_arrow_params(toks: skip(toks: toks), acc: acc)
  else return ParsedNamedTypes(fields: list.reverse(xs: acc), rest: toks)
  end
end

// ─── Require / throws clauses ───────────────────────────────────────────────

pub let parse_optional_require = fn (toks: [SpannedToken]) -> ParsedType throws { Exn } do
  match peek_token(toks: toks)
    case TkRequire ->
      match parse_row_or_type(toks: skip(toks: toks))
        case ParsedType(typ: t, rest: r2) -> return ParsedType(typ: t, rest: r2)
      end
    case _ -> return ParsedType(typ: empty_row(), rest: toks)
  end
end

pub let parse_optional_throws = fn (toks: [SpannedToken]) -> ParsedType throws { Exn } do
  match peek_token(toks: toks)
    case TkThrows ->
      match parse_row_or_type(toks: skip(toks: toks))
        case ParsedType(typ: t, rest: r2) -> return ParsedType(typ: t, rest: r2)
      end
    case _ -> return ParsedType(typ: empty_row(), rest: toks)
  end
end

// ─── Row types ──────────────────────────────────────────────────────────────

pub let parse_row_or_type = fn (toks: [SpannedToken]) -> ParsedType throws { Exn } do
  match peek_token(toks: toks)
    case TkLBrace ->
      let r = skip(toks: toks)
      match parse_row_types(toks: r, acc: [])
        case ParsedTypes(types: ts, rest: r2) ->
          match peek_token(toks: r2)
            case TkPipe ->
              match parse_type(toks: skip(toks: r2))
                case ParsedType(typ: tail, rest: r4) ->
                  let r5 = expect(toks: r4, expected: "}")
                  ParsedType(typ: TyRow(types: ts, rest: Some(val: tail)), rest: r5)
              end
            case _ ->
              let r3 = expect(toks: r2, expected: "}")
              ParsedType(typ: TyRow(types: ts, rest: None), rest: r3)
          end
      end
    case _ -> parse_type(toks: toks)
  end
end

pub let parse_row_types = fn (toks: [SpannedToken], acc: [TypeExpr]) -> ParsedTypes throws { Exn } do
  match peek_token(toks: toks)
    case TkRBrace -> return ParsedTypes(types: list.reverse(xs: acc), rest: toks)
    case TkPipe -> return ParsedTypes(types: list.reverse(xs: acc), rest: toks)
    case _ ->
      match parse_type(toks: toks)
        case ParsedType(typ: t, rest: r) ->
          let new_acc = Cons(v: t, rest: acc)
          if is_tok(toks: r, expected: ",") then
            return parse_row_types(toks: skip(toks: r), acc: new_acc)
          else
            return ParsedTypes(types: list.reverse(xs: new_acc), rest: r)
          end
      end
  end
end

// ─── Atomic types ───────────────────────────────────────────────────────────

pub let parse_type_atom = fn (toks: [SpannedToken]) -> ParsedType throws { Exn } do
  match peek_token(toks: toks)
    case TkIdent(name: n) ->
      if n == "i32" then return ParsedType(typ: TyI32, rest: skip(toks: toks))
      else if n == "i64" then return ParsedType(typ: TyI64, rest: skip(toks: toks))
      else if n == "f32" then return ParsedType(typ: TyF32, rest: skip(toks: toks))
      else if n == "f64" then return ParsedType(typ: TyF64, rest: skip(toks: toks))
      else if n == "bool" then return ParsedType(typ: TyBool, rest: skip(toks: toks))
      else if n == "string" then return ParsedType(typ: TyString, rest: skip(toks: toks))
      else if n == "unit" then return ParsedType(typ: TyUnit, rest: skip(toks: toks))
      else
        let r = skip(toks: toks)
        if is_tok(toks: r, expected: "<") then
          let r2 = skip(toks: r)
          match parse_type_args(toks: r2, acc: [])
            case ParsedTypes(types: args, rest: r3) ->
              let r4 = expect(toks: r3, expected: ">")
              return ParsedType(typ: TyUserDefined(name: n, args: args), rest: r4)
          end
        else
          return ParsedType(typ: TyUserDefined(name: n, args: []), rest: r)
        end
      end end end end end end end
    case TkUident(name: n) ->
      let r = skip(toks: toks)
      if is_tok(toks: r, expected: "<") then
        let r2 = skip(toks: r)
        match parse_type_args(toks: r2, acc: [])
          case ParsedTypes(types: args, rest: r3) ->
            let r4 = expect(toks: r3, expected: ">")
            return ParsedType(typ: TyUserDefined(name: n, args: args), rest: r4)
        end
      else
        return ParsedType(typ: TyUserDefined(name: n, args: []), rest: r)
      end
    case TkUnit ->
      return ParsedType(typ: TyUnit, rest: skip(toks: toks))
    case TkLParen ->
      let r = skip(toks: toks)
      if is_tok(toks: r, expected: ")") then
        return ParsedType(typ: TyUnit, rest: skip(toks: r))
      else
        match parse_type(toks: r)
          case ParsedType(typ: t, rest: r2) ->
            let r3 = expect(toks: r2, expected: ")")
            return ParsedType(typ: t, rest: r3)
        end
      end
    case TkLBracket ->
      match parse_type(toks: skip(toks: toks))
        case ParsedType(typ: elem, rest: r2) ->
          let r3 = expect(toks: r2, expected: "]")
          return ParsedType(typ: TyList(elem: elem), rest: r3)
      end
    case TkLArray ->
      match parse_type(toks: skip(toks: toks))
        case ParsedType(typ: elem, rest: r2) ->
          let r3 = expect(toks: r2, expected: "|]")
          return ParsedType(typ: TyArray(elem: elem), rest: r3)
      end
    case TkLBrace ->
      match parse_record_type_fields(toks: skip(toks: toks), acc: [])
        case ParsedNamedTypes(fields: fs, rest: r2) ->
          let r3 = expect(toks: r2, expected: "}")
          return ParsedType(typ: TyRecord(fields: fs), rest: r3)
      end
    case TkRef ->
      let r = skip(toks: toks)
      let r2 = expect(toks: r, expected: "(")
      match parse_type(toks: r2)
        case ParsedType(typ: inner, rest: r3) ->
          let r4 = expect(toks: r3, expected: ")")
          return ParsedType(typ: TyRef(inner: inner), rest: r4)
      end
    case TkAmpersand ->
      match parse_type(toks: skip(toks: toks))
        case ParsedType(typ: inner, rest: r2) ->
          return ParsedType(typ: TyBorrow(inner: inner), rest: r2)
      end
    case TkPercent ->
      match parse_type(toks: skip(toks: toks))
        case ParsedType(typ: inner, rest: r2) ->
          return ParsedType(typ: TyLinear(inner: inner), rest: r2)
      end
    case TkHandler ->
      match expect_uident(toks: skip(toks: toks))
        case ParsedIdent(name: n, rest: r2) ->
          return ParsedType(typ: TyHandler(name: n, requires: empty_row()), rest: r2)
      end
    case _ ->
      error(phase: PhaseParse, message: "expected type, got '" ++ token_tag(tok: peek_token(toks: toks)) ++ "'", span: peek_span(toks: toks))
      // unreachable — error raises CompileError
      return ParsedType(typ: TyUnit, rest: toks)
  end
end

// ─── Type arguments ─────────────────────────────────────────────────────────

pub let parse_type_args = fn (toks: [SpannedToken], acc: [TypeExpr]) -> ParsedTypes throws { Exn } do
  match peek_token(toks: toks)
    case TkGt -> return ParsedTypes(types: list.reverse(xs: acc), rest: toks)
    case _ ->
      match parse_type(toks: toks)
        case ParsedType(typ: t, rest: r) ->
          let new_acc = Cons(v: t, rest: acc)
          if is_tok(toks: r, expected: ",") then
            return parse_type_args(toks: skip(toks: r), acc: new_acc)
          else
            return ParsedTypes(types: list.reverse(xs: new_acc), rest: r)
          end
      end
  end
end

// ─── Record type fields ────────────────────────────────────────────────────

pub let parse_record_type_fields = fn (toks: [SpannedToken], acc: [NamedType]) -> ParsedNamedTypes throws { Exn } do
  match peek_token(toks: toks)
    case TkRBrace -> return ParsedNamedTypes(fields: list.reverse(xs: acc), rest: toks)
    case _ ->
      match expect_ident(toks: toks)
        case ParsedIdent(name: n, rest: r) ->
          let r2 = expect(toks: r, expected: ":")
          match parse_type(toks: r2)
            case ParsedType(typ: t, rest: r3) ->
              let new_acc = Cons(v: NamedType(name: n, typ: t), rest: acc)
              if is_tok(toks: r3, expected: ",") then
                return parse_record_type_fields(toks: skip(toks: r3), acc: new_acc)
              else
                return ParsedNamedTypes(fields: list.reverse(xs: new_acc), rest: r3)
              end
          end
      end
  end
end
