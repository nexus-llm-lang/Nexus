/**
 * parse_type: Type expression parsing for the Nexus self-hosting compiler.
 *
 * Parses all TypeExpr forms: primitives, user-defined (with type args),
 * arrow types, rows, records, refs, linear, borrow, list, array, handler.
 */

import { Token, Span, SpannedToken } from "nxc/common/token.nx"
import { TypeExpr, NamedType } from "nxc/common/ast.nx"
import { CompileError, error, PhaseParse } from "nxc/common/error.nx"
import {
  ParsedType, ParsedNamedTypes, ParsedTypes, ParsedIdent, ParsedStrings,
  peek_token, peek_span, skip, is_tok, expect, expect_ident, expect_uident,
  is_arrow_start, token_tag
} from "nxc/frontend/parse_core.nx"
import * as list from "stdlib/list.nx"

// ─── Helpers ────────────────────────────────────────────────────────────────

export let empty_row = fn () -> TypeExpr do
  return TyRow(types: [], rest: None)
end

// ─── Top-level type dispatch ────────────────────────────────────────────────

export let parse_type = fn (toks: [SpannedToken]) -> ParsedType throws { CompileError } do
  match peek_token(toks: toks) do
    case TkLParen -> parse_type_maybe_arrow(toks: toks)
    case _ -> parse_type_atom(toks: toks)
  end
end

export let parse_type_maybe_arrow = fn (toks: [SpannedToken]) -> ParsedType throws { CompileError } do
  if is_arrow_start(toks: toks) then return parse_arrow_type(toks: toks)
  else return parse_type_atom(toks: toks)
  end
end

// ─── Arrow types ────────────────────────────────────────────────────────────

export let parse_arrow_type = fn (toks: [SpannedToken]) -> ParsedType throws { CompileError } do
  let r = expect(toks: toks, expected: "(")
  let ParsedNamedTypes(fields: ps, rest: r2) = parse_arrow_params(toks: r, acc: [])
  let r3 = expect(toks: r2, expected: ")")
  let r4 = expect(toks: r3, expected: "->")
  let ParsedType(typ: ret, rest: r5) = parse_type(toks: r4)
  let ParsedType(typ: req_ty, rest: r6) = parse_optional_require(toks: r5)
  let ParsedType(typ: thr_ty, rest: r7) = parse_optional_throws(toks: r6)
  ParsedType(typ: TyArrow(params: ps, ret: ret, requires: req_ty, throw_row: thr_ty), rest: r7)
end

export let parse_arrow_params = fn (toks: [SpannedToken], acc: [NamedType]) -> ParsedNamedTypes throws { CompileError } do
  match peek_token(toks: toks) do
    case TkRParen -> return ParsedNamedTypes(fields: list.reverse(xs: acc), rest: toks)
    case _ ->
      let ParsedIdent(name: n, rest: r) = expect_ident(toks: toks)
      let r2 = expect(toks: r, expected: ":")
      let ParsedType(typ: t, rest: r3) = parse_type(toks: r2)
      let new_acc = Cons(v: NamedType(name: n, typ: t), rest: acc)
      parse_arrow_params_continue(toks: r3, acc: new_acc)
  end
end

export let parse_arrow_params_continue = fn (toks: [SpannedToken], acc: [NamedType]) -> ParsedNamedTypes throws { CompileError } do
  if is_tok(toks: toks, expected: ",") then return parse_arrow_params(toks: skip(toks: toks), acc: acc)
  else return ParsedNamedTypes(fields: list.reverse(xs: acc), rest: toks)
  end
end

// ─── Require / throws clauses ───────────────────────────────────────────────

export let parse_optional_require = fn (toks: [SpannedToken]) -> ParsedType throws { CompileError } do
  match peek_token(toks: toks) do
    case TkRequire ->
      let ParsedType(typ: t, rest: r2) = parse_row_or_type(toks: skip(toks: toks))
      return ParsedType(typ: t, rest: r2)
    case _ -> return ParsedType(typ: empty_row(), rest: toks)
  end
end

export let parse_optional_throws = fn (toks: [SpannedToken]) -> ParsedType throws { CompileError } do
  match peek_token(toks: toks) do
    case TkThrows ->
      let ParsedType(typ: t, rest: r2) = parse_row_or_type(toks: skip(toks: toks))
      return ParsedType(typ: t, rest: r2)
    case _ -> return ParsedType(typ: empty_row(), rest: toks)
  end
end

// ─── Row types ──────────────────────────────────────────────────────────────

export let parse_row_or_type = fn (toks: [SpannedToken]) -> ParsedType throws { CompileError } do
  match peek_token(toks: toks) do
    case TkLBrace ->
      let r = skip(toks: toks)
      let ParsedTypes(types: ts, rest: r2) = parse_row_types(toks: r, acc: [])
      match peek_token(toks: r2) do
        case TkPipe ->
          let ParsedType(typ: tail, rest: r4) = parse_type(toks: skip(toks: r2))
          let r5 = expect(toks: r4, expected: "}")
          ParsedType(typ: TyRow(types: ts, rest: Some(val: tail)), rest: r5)
        case _ ->
          let r3 = expect(toks: r2, expected: "}")
          ParsedType(typ: TyRow(types: ts, rest: None), rest: r3)
      end
    case _ -> parse_type(toks: toks)
  end
end

export let parse_row_types = fn (toks: [SpannedToken], acc: [TypeExpr]) -> ParsedTypes throws { CompileError } do
  match peek_token(toks: toks) do
    case TkRBrace -> return ParsedTypes(types: list.reverse(xs: acc), rest: toks)
    case TkPipe -> return ParsedTypes(types: list.reverse(xs: acc), rest: toks)
    case _ ->
      let ParsedType(typ: t, rest: r) = parse_type(toks: toks)
      let new_acc = Cons(v: t, rest: acc)
      if is_tok(toks: r, expected: ",") then
        return parse_row_types(toks: skip(toks: r), acc: new_acc)
      else
        return ParsedTypes(types: list.reverse(xs: new_acc), rest: r)
      end
  end
end

let resolve_primitive_type = fn (name: string) -> Option<TypeExpr> do
  if name == "i32" then return Some(val: TyI32) end
  if name == "i64" then return Some(val: TyI64) end
  if name == "f32" then return Some(val: TyF32) end
  if name == "f64" then return Some(val: TyF64) end
  if name == "float" then return Some(val: TyF64) end
  if name == "bool" then return Some(val: TyBool) end
  if name == "char" then return Some(val: TyChar) end
  if name == "string" then return Some(val: TyString) end
  if name == "unit" then return Some(val: TyUnit) end
  return None
end

// ─── Atomic types ───────────────────────────────────────────────────────────

export let parse_type_atom = fn (toks: [SpannedToken]) -> ParsedType throws { CompileError } do
  match peek_token(toks: toks) do
    case TkIdent(name: n) ->
      let prim = resolve_primitive_type(name: n)
      match prim do
        case Some(val: t) -> return ParsedType(typ: t, rest: skip(toks: toks))
        case None ->
          let r = skip(toks: toks)
          if is_tok(toks: r, expected: "<") then
            let r2 = skip(toks: r)
            let ParsedTypes(types: args, rest: r3) = parse_type_args(toks: r2, acc: [])
            let r4 = expect(toks: r3, expected: ">")
            return ParsedType(typ: TyUserDefined(name: n, args: args), rest: r4)
          else
            return ParsedType(typ: TyUserDefined(name: n, args: []), rest: r)
          end
      end
    case TkUident(name: n) ->
      let r = skip(toks: toks)
      if is_tok(toks: r, expected: "<") then
        let r2 = skip(toks: r)
        let ParsedTypes(types: args, rest: r3) = parse_type_args(toks: r2, acc: [])
        let r4 = expect(toks: r3, expected: ">")
        return ParsedType(typ: TyUserDefined(name: n, args: args), rest: r4)
      else
        return ParsedType(typ: TyUserDefined(name: n, args: []), rest: r)
      end
    case TkUnit ->
      return ParsedType(typ: TyUnit, rest: skip(toks: toks))
    case TkLParen ->
      let r = skip(toks: toks)
      if is_tok(toks: r, expected: ")") then
        return ParsedType(typ: TyUnit, rest: skip(toks: r))
      else
        let ParsedType(typ: t, rest: r2) = parse_type(toks: r)
        let r3 = expect(toks: r2, expected: ")")
        return ParsedType(typ: t, rest: r3)
      end
    case TkLBracket ->
      let ParsedType(typ: elem, rest: r2) = parse_type(toks: skip(toks: toks))
      let r3 = expect(toks: r2, expected: "]")
      return ParsedType(typ: TyList(elem: elem), rest: r3)
    case TkLArray ->
      let ParsedType(typ: elem, rest: r2) = parse_type(toks: skip(toks: toks))
      let r3 = expect(toks: r2, expected: "|]")
      return ParsedType(typ: TyArray(elem: elem), rest: r3)
    case TkLBrace ->
      let ParsedNamedTypes(fields: fs, rest: r2) = parse_record_type_fields(toks: skip(toks: toks), acc: [])
      let r3 = expect(toks: r2, expected: "}")
      return ParsedType(typ: TyRecord(fields: fs), rest: r3)
    case TkRef ->
      let r = skip(toks: toks)
      let r2 = expect(toks: r, expected: "(")
      let ParsedType(typ: inner, rest: r3) = parse_type(toks: r2)
      let r4 = expect(toks: r3, expected: ")")
      return ParsedType(typ: TyRef(inner: inner), rest: r4)
    case TkAmpersand ->
      let ParsedType(typ: inner, rest: r2) = parse_type(toks: skip(toks: toks))
      return ParsedType(typ: TyBorrow(inner: inner), rest: r2)
    case TkPercent ->
      let ParsedType(typ: inner, rest: r2) = parse_type(toks: skip(toks: toks))
      return ParsedType(typ: TyLinear(inner: inner), rest: r2)
    case TkAt ->
      let ParsedType(typ: inner, rest: r2) = parse_type(toks: skip(toks: toks))
      return ParsedType(typ: TyLazy(inner: inner), rest: r2)
    case TkHandler ->
      let ParsedIdent(name: n, rest: r2) = expect_uident(toks: skip(toks: toks))
      return ParsedType(typ: TyHandler(name: n, requires: empty_row()), rest: r2)
    case _ ->
      error(phase: PhaseParse, message: "expected type, got '" ++ token_tag(tok: peek_token(toks: toks)) ++ "'", span: peek_span(toks: toks))
      // unreachable — error raises CompileError
      return ParsedType(typ: TyUnit, rest: toks)
  end
end

// ─── Type arguments ─────────────────────────────────────────────────────────

export let parse_type_args = fn (toks: [SpannedToken], acc: [TypeExpr]) -> ParsedTypes throws { CompileError } do
  match peek_token(toks: toks) do
    case TkGt -> return ParsedTypes(types: list.reverse(xs: acc), rest: toks)
    case _ ->
      let ParsedType(typ: t, rest: r) = parse_type(toks: toks)
      let new_acc = Cons(v: t, rest: acc)
      if is_tok(toks: r, expected: ",") then
        return parse_type_args(toks: skip(toks: r), acc: new_acc)
      else
        return ParsedTypes(types: list.reverse(xs: new_acc), rest: r)
      end
  end
end

// ─── Record type fields ────────────────────────────────────────────────────

export let parse_record_type_fields = fn (toks: [SpannedToken], acc: [NamedType]) -> ParsedNamedTypes throws { CompileError } do
  match peek_token(toks: toks) do
    case TkRBrace -> return ParsedNamedTypes(fields: list.reverse(xs: acc), rest: toks)
    case _ ->
      let ParsedIdent(name: n, rest: r) = expect_ident(toks: toks)
      let r2 = expect(toks: r, expected: ":")
      let ParsedType(typ: t, rest: r3) = parse_type(toks: r2)
      let new_acc = Cons(v: NamedType(name: n, typ: t), rest: acc)
      if is_tok(toks: r3, expected: ",") then
        return parse_record_type_fields(toks: skip(toks: r3), acc: new_acc)
      else
        return ParsedNamedTypes(fields: list.reverse(xs: new_acc), rest: r3)
      end
  end
end
