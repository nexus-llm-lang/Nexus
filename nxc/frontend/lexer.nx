/**
 * lexer: Tokenizer for Nexus source code.
 *
 * Uses byte-level scanning primitives (byte_at, scan_ident, scan_digits, etc.)
 * for O(1) character access instead of O(n) char_at. Bulk scan functions reduce
 * FFI crossings from O(chars) to O(tokens).
 */

import * as str from "stdlib/string.nx"
import * as char from "stdlib/char.nx"
import { Token, Span, SpannedToken }, * as token from "nxc/common/token.nx"

// ─── Character constants ────────────────────────────────────────────────────

let ch_tab       = '\t'
let ch_newline   = '\n'
let ch_space     = ' '
let ch_bang      = '!'
let ch_dquote    = '"'
let ch_percent   = '%'
let ch_ampersand = '&'
let ch_at        = '@'
let ch_lparen    = '('
let ch_rparen    = ')'
let ch_star      = '*'
let ch_plus      = '+'
let ch_comma     = ','
let ch_minus     = '-'
let ch_dot       = '.'
let ch_slash     = '/'
let ch_colon     = ':'
let ch_lt        = '<'
let ch_eq        = '='
let ch_gt        = '>'
let ch_lbracket  = '['
let ch_backslash = '\\'
let ch_rbracket  = ']'
let ch_lbrace    = '{'
let ch_pipe      = '|'
let ch_rbrace    = '}'
let ch_caret     = '^'
let ch_tilde     = '~'
let ch_underscore = '_'
let ch_squote    = '\''
let ch_eof       = '\0'

// ─── Lexer state ─────────────────────────────────────────────────────────────

type LexerState = LexerState(src: string, pos: i64, line: i64, col: i64, len: i64)

let make_lexer = fn (src: string) -> LexerState do
  return LexerState(src: src, pos: 0, line: 1, col: 1, len: str.byte_length(s: src))
end

// ─── Character access (byte-level, O(1) per call) ───────────────────────────

let peek = fn (st: LexerState) -> char do
  let LexerState(src: s, pos: p, line: _, col: _, len: l) = st
  if p >= l then return ch_eof end
  return str.byte_at(s: s, idx: p)
end

let peek_at = fn (st: LexerState, offset: i64) -> char do
  let LexerState(src: s, pos: p, line: _, col: _, len: l) = st
  let idx = p + offset
  if idx >= l then return ch_eof end
  return str.byte_at(s: s, idx: idx)
end

let advance = fn (st: LexerState) -> LexerState do
  let LexerState(src: s, pos: p, line: ln, col: c, len: l) = st
  if str.byte_at(s: s, idx: p) == ch_newline then
    return LexerState(src: s, pos: p + 1, line: ln + 1, col: 1, len: l)
  else
    return LexerState(src: s, pos: p + 1, line: ln, col: c + 1, len: l)
  end
end

let advance_n = fn (st: LexerState, n: i64) -> LexerState do
  if n <= 0 then return st end
  return advance_n(st: advance(st: st), n: n - 1)
end

let at_end = fn (st: LexerState) -> bool do
  let LexerState(src: _, pos: p, line: _, col: _, len: l) = st
  return p >= l
end

let current_span = fn (st: LexerState) -> Span do
  let LexerState(src: _, pos: p, line: ln, col: c, len: _) = st
  return Span(offset: p, line: ln, col: c)
end

let slice = fn (st: LexerState, start: i64, length: i64) -> string do
  let LexerState(src: s, pos: _, line: _, col: _, len: _) = st
  return str.byte_substring(s: s, start: start, len: length)
end

// ─── Bulk state update helper ────────────────────────────────────────────────

// Update LexerState after jumping from current pos to new_pos,
// correctly tracking line/col by counting newlines in the skipped range.
let update_state_bulk = fn (st: LexerState, new_pos: i64) -> LexerState do
  let LexerState(src: s, pos: old_pos, line: ln, col: c, len: l) = st
  if new_pos == old_pos then return st end
  let nl_count = str.count_newlines_in(s: s, start: old_pos, end_pos: new_pos)
  if nl_count > 0 then
    let last_nl = str.last_newline_in(s: s, start: old_pos, end_pos: new_pos)
    return LexerState(src: s, pos: new_pos, line: ln + nl_count, col: new_pos - last_nl, len: l)
  else
    return LexerState(src: s, pos: new_pos, line: ln, col: c + (new_pos - old_pos), len: l)
  end
end

// ─── Lexer result ────────────────────────────────────────────────────────────

type LexResult = LexResult(st: LexerState, tok: SpannedToken)

let spanned = fn (st: LexerState, token: Token, span: Span) -> LexResult do
  return LexResult(st: st, tok: SpannedToken(token: token, span: span))
end

// ─── Skip whitespace and comments ────────────────────────────────────────────

let skip_line_comment = fn (st: LexerState) -> LexerState do
  let LexerState(src: s, pos: p, line: ln, col: _, len: l) = st
  let nl_pos = str.find_byte(s: s, start: p, ch: ch_newline)
  if nl_pos < 0 then
    return LexerState(src: s, pos: l, line: ln, col: 1 + l - p, len: l)
  else
    return LexerState(src: s, pos: nl_pos + 1, line: ln + 1, col: 1, len: l)
  end
end

let skip_block_comment = fn (st: LexerState, depth: i64) -> LexerState do
  if at_end(st: st) then return st end
  if depth <= 0 then return st end
  let c = peek(st: st)
  let c2 = peek_at(st: st, offset: 1)
  if c == ch_star && c2 == ch_slash then
    return skip_block_comment(st: advance_n(st: st, n: 2), depth: depth - 1)
  end
  if c == ch_slash && c2 == ch_star then
    return skip_block_comment(st: advance_n(st: st, n: 2), depth: depth + 1)
  end
  return skip_block_comment(st: advance(st: st), depth: depth)
end

let skip_whitespace_and_comments = fn (st: LexerState) -> LexerState do
  let LexerState(src: s, pos: p, line: _, col: _, len: l) = st
  if p >= l then return st end
  // Bulk skip whitespace
  let ws_end = str.skip_ws(s: s, start: p)
  if ws_end > p then
    let st1 = update_state_bulk(st: st, new_pos: ws_end)
    return skip_whitespace_and_comments(st: st1)
  end
  // Check for comments — use flat if-then chains (nxc codegen miscompiles nested ifs)
  let c = str.byte_at(s: s, idx: p)
  let c2 = str.byte_at(s: s, idx: p + 1)
  if c == ch_slash && c2 == ch_slash then
    return skip_whitespace_and_comments(st: skip_line_comment(st: st))
  end
  if c == ch_slash && c2 == ch_star then
    return skip_whitespace_and_comments(st: skip_block_comment(st: advance_n(st: st, n: 2), depth: 1))
  end
  return st
end

// ─── Identifiers and keywords (bulk scan) ────────────────────────────────────

let lex_ident_rest = fn (st: LexerState) -> LexerState do
  let LexerState(src: s, pos: p, line: ln, col: c, len: l) = st
  let end_pos = str.scan_ident(s: s, start: p)
  return LexerState(src: s, pos: end_pos, line: ln, col: c + (end_pos - p), len: l)
end

let lex_identifier = fn (st: LexerState, span: Span) -> LexResult do
  let Span(offset: start, line: _, col: _) = span
  let st2 = lex_ident_rest(st: st)
  let LexerState(src: _, pos: end_pos, line: _, col: _, len: elen) = st2
  let name = slice(st: st2, start: start, length: end_pos - start)
  match token.keyword_lookup(name: name) do
    case Some(val: tk) -> return spanned(st: st2, token: tk, span: span)
    case None -> return spanned(st: st2, token: TkIdent(name: name), span: span)
  end
end

let lex_uident = fn (st: LexerState, span: Span) -> LexResult do
  let Span(offset: start, line: _, col: _) = span
  let st2 = lex_ident_rest(st: st)
  let LexerState(src: _, pos: end_pos, line: _, col: _, len: _) = st2
  let name = slice(st: st2, start: start, length: end_pos - start)
  return spanned(st: st2, token: TkUident(name: name), span: span)
end

// ─── Numbers (bulk scan) ─────────────────────────────────────────────────────

let lex_digits = fn (st: LexerState) -> LexerState do
  let LexerState(src: s, pos: p, line: ln, col: c, len: l) = st
  let end_pos = str.scan_digits(s: s, start: p)
  return LexerState(src: s, pos: end_pos, line: ln, col: c + (end_pos - p), len: l)
end

let lex_number = fn (st: LexerState, span: Span) -> LexResult do
  let Span(offset: start, line: _, col: _) = span
  let st2 = lex_digits(st: st)
  let c = peek(st: st2)
  // Float: digits '.' digit+
  if c == ch_dot then
    if char.is_digit(c: peek_at(st: st2, offset: 1)) then
      let st3 = lex_digits(st: advance(st: st2))
      let LexerState(src: _, pos: end_pos, line: _, col: _, len: _) = st3
      let text = slice(st: st3, start: start, length: end_pos - start)
      return spanned(st: st3, token: TkFloat(val: text), span: span)
    end
  end
  // Integer
  let LexerState(src: _, pos: end_pos, line: _, col: _, len: _) = st2
  let text = slice(st: st2, start: start, length: end_pos - start)
  match str.parse_i64(s: text) do
    case Some(val: v) -> return spanned(st: st2, token: TkInt(val: v), span: span)
    case None -> return spanned(st: st2, token: TkInt(val: 0), span: span)
  end
end

// ─── Escape helpers ─────────────────────────────────────────────────────────

type HexAccum = HexOk(st: LexerState, code: i64) | HexErr(st: LexerState, msg: string)

let collect_hex_digits = fn (st: LexerState, code: i64) -> HexAccum do
  if at_end(st: st) then
    return HexErr(st: st, msg: "unterminated \\u{} escape")
  end
  let c = peek(st: st)
  if c == ch_rbrace then
    return HexOk(st: advance(st: st), code: code)
  end
  let v = char.hex_digit_value(c: c)
  if v >= 0 then
    return collect_hex_digits(st: advance(st: st), code: code * 16 + v)
  else
    return HexErr(st: st, msg: "invalid hex digit in \\u{} escape")
  end
end

// ─── String literals ─────────────────────────────────────────────────────────

let lex_string_body = fn (st: LexerState, acc: string) -> LexResult do
  if at_end(st: st) then
    return spanned(st: st, token: TkError(msg: "unterminated string"), span: current_span(st: st))
  end
  let c = peek(st: st)
  // End of string
  if c == ch_dquote then
    return spanned(st: advance(st: st), token: TkString(val: acc), span: current_span(st: st))
  end
  // Escape sequence
  if c == ch_backslash then
    let c2 = peek_at(st: st, offset: 1)
    // Named escapes
    if c2 == 'n' then return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ "\n") end
    if c2 == 'r' then return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ "\r") end
    if c2 == 't' then return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ "\t") end
    if c2 == 'a' then return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ str.from_char_code(code: 7)) end
    if c2 == 'b' then return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ str.from_char_code(code: 8)) end
    if c2 == 'v' then return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ str.from_char_code(code: 11)) end
    if c2 == 'f' then return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ str.from_char_code(code: 12)) end
    if c2 == 'e' then return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ str.from_char_code(code: 27)) end
    if c2 == ch_backslash then return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ "\\") end
    if c2 == ch_dquote then return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ "\"") end
    // Unicode escape: \u{NNNN}
    if c2 == 'u' then
      if peek_at(st: st, offset: 2) == ch_lbrace then
        match collect_hex_digits(st: advance_n(st: st, n: 3), code: 0) do
          case HexOk(st: st3, code: code) ->
            return lex_string_body(st: st3, acc: acc ++ str.from_char_code(code: code))
          case HexErr(st: st3, msg: msg) ->
            return spanned(st: st3, token: TkError(msg: msg), span: current_span(st: st3))
        end
      else
        return spanned(st: advance_n(st: st, n: 2), token: TkError(msg: "expected '{' after \\u"), span: current_span(st: st))
      end
    end
    // Hex escape: \xNN (exactly 2 hex digits)
    if c2 == 'x' then
      let h1 = peek_at(st: st, offset: 2)
      let h2 = peek_at(st: st, offset: 3)
      let v1 = char.hex_digit_value(c: h1)
      let v2 = char.hex_digit_value(c: h2)
      if v1 >= 0 && v2 >= 0 then
        return lex_string_body(st: advance_n(st: st, n: 4), acc: acc ++ str.from_char_code(code: v1 * 16 + v2))
      else
        return spanned(st: advance_n(st: st, n: 2), token: TkError(msg: "\\x requires exactly 2 hex digits"), span: current_span(st: st))
      end
    end
    // Octal escape: \NNN (1-3 octal digits)
    if c2 >= '0' && c2 <= '7' then
      let d1 = char.digit_value(c: c2)
      let c3 = peek_at(st: st, offset: 2)
      if c3 >= '0' && c3 <= '7' then
        let d2 = char.digit_value(c: c3)
        let c4 = peek_at(st: st, offset: 3)
        if c4 >= '0' && c4 <= '7' then
          let d3 = char.digit_value(c: c4)
          return lex_string_body(st: advance_n(st: st, n: 4), acc: acc ++ str.from_char_code(code: d1 * 64 + d2 * 8 + d3))
        else
          return lex_string_body(st: advance_n(st: st, n: 3), acc: acc ++ str.from_char_code(code: d1 * 8 + d2))
        end
      else
        return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ str.from_char_code(code: d1))
      end
    end
    // Unknown escape: pass through as-is
    return lex_string_body(st: advance_n(st: st, n: 2), acc: acc ++ "\\" ++ str.from_char(c: c2))
  end
  // Regular character
  let LexerState(src: s, pos: p, line: _, col: _, len: _) = st
  return lex_string_body(st: advance(st: st), acc: acc ++ str.from_char(c: str.byte_at(s: s, idx: p)))
end

let lex_string = fn (st: LexerState, span: Span) -> LexResult do
  let result = lex_string_body(st: st, acc: "")
  match result do
    case LexResult(st: st2, tok: SpannedToken(token: TkString(val: v), span: _)) ->
      return spanned(st: st2, token: TkString(val: v), span: span)
    case LexResult(st: st2, tok: t) ->
      return LexResult(st: st2, tok: t)
  end
end

// ─── Char literals ──────────────────────────────────────────────────────────

let lex_char_escape = fn (st: LexerState, span: Span, c2: char) -> LexResult do
  if c2 == 'n' then return lex_char_close(st: advance_n(st: st, n: 2), span: span, code: 10) end
  if c2 == 'r' then return lex_char_close(st: advance_n(st: st, n: 2), span: span, code: 13) end
  if c2 == 't' then return lex_char_close(st: advance_n(st: st, n: 2), span: span, code: 9) end
  if c2 == '0' then return lex_char_close(st: advance_n(st: st, n: 2), span: span, code: 0) end
  if c2 == ch_backslash then return lex_char_close(st: advance_n(st: st, n: 2), span: span, code: 92) end
  if c2 == ch_squote then return lex_char_close(st: advance_n(st: st, n: 2), span: span, code: 39) end
  if c2 == 'u' then
    if peek_at(st: st, offset: 2) == ch_lbrace then
      match collect_hex_digits(st: advance_n(st: st, n: 3), code: 0) do
        case HexOk(st: st3, code: hex_code) ->
          return lex_char_close(st: st3, span: span, code: hex_code)
        case HexErr(st: st3, msg: msg) ->
          return spanned(st: st3, token: TkError(msg: msg), span: span)
      end
    end
  end
  return spanned(st: advance_n(st: st, n: 2), token: TkError(msg: "unknown char escape"), span: span)
end

let lex_char_close = fn (st: LexerState, span: Span, code: i64) -> LexResult do
  if peek(st: st) == ch_squote then
    return spanned(st: advance(st: st), token: TkChar(val: code), span: span)
  end
  return spanned(st: st, token: TkError(msg: "expected closing ' for char literal"), span: span)
end

let lex_char_literal = fn (st: LexerState, span: Span) -> LexResult do
  if at_end(st: st) then
    return spanned(st: st, token: TkError(msg: "unterminated char literal"), span: span)
  end
  let c = peek(st: st)
  if c == ch_backslash then
    return lex_char_escape(st: st, span: span, c2: peek_at(st: st, offset: 1))
  end
  let LexerState(src: s, pos: p, line: _, col: _, len: _) = st
  let code = char.ord(c: str.byte_at(s: s, idx: p))
  return lex_char_close(st: advance(st: st), span: span, code: code)
end

// ─── Bracket string [=[ ... ]=] ──────────────────────────────────────────────

let lex_bracket_body = fn (st: LexerState, acc: string) -> LexResult do
  if at_end(st: st) then
    return spanned(st: st, token: TkError(msg: "unterminated bracket string"), span: current_span(st: st))
  end
  let c = peek(st: st)
  // Check for ]=]
  if c == ch_rbracket then
    if peek_at(st: st, offset: 1) == ch_eq && peek_at(st: st, offset: 2) == ch_rbracket then
      return spanned(st: advance_n(st: st, n: 3), token: TkString(val: acc), span: current_span(st: st))
    end
  end
  // Escape: \]=] → literal ]=]
  if c == ch_backslash then
    if peek_at(st: st, offset: 1) == ch_rbracket && peek_at(st: st, offset: 2) == ch_eq && peek_at(st: st, offset: 3) == ch_rbracket then
      return lex_bracket_body(st: advance_n(st: st, n: 4), acc: acc ++ "]=]")
    end
  end
  let LexerState(src: s, pos: p, line: _, col: _, len: _) = st
  return lex_bracket_body(st: advance(st: st), acc: acc ++ str.from_char(c: str.byte_at(s: s, idx: p)))
end

let lex_bracket_string = fn (st: LexerState, span: Span) -> LexResult do
  let result = lex_bracket_body(st: st, acc: "")
  match result do
    case LexResult(st: st2, tok: SpannedToken(token: TkString(val: v), span: _)) ->
      return spanned(st: st2, token: TkString(val: v), span: span)
    case LexResult(st: st2, tok: t) ->
      return LexResult(st: st2, tok: t)
  end
end

// ─── Operators ───────────────────────────────────────────────────────────────

let lex_three_char_op = fn (st: LexerState, span: Span, c: char, c2: char, c3: char) -> Option<LexResult> do
  // ==.  !=.  <=.  >=.
  if c == ch_eq && c2 == ch_eq && c3 == ch_dot then
    return Some(val: spanned(st: advance_n(st: st, n: 3), token: TkEqEqDot, span: span))
  end
  if c == ch_bang && c2 == ch_eq && c3 == ch_dot then
    return Some(val: spanned(st: advance_n(st: st, n: 3), token: TkBangEqDot, span: span))
  end
  if c == ch_lt && c2 == ch_eq && c3 == ch_dot then
    return Some(val: spanned(st: advance_n(st: st, n: 3), token: TkLeDot, span: span))
  end
  if c == ch_gt && c2 == ch_eq && c3 == ch_dot then
    return Some(val: spanned(st: advance_n(st: st, n: 3), token: TkGeDot, span: span))
  end
  return None
end

let lex_two_char_op = fn (st: LexerState, span: Span, c: char, c2: char) -> Option<LexResult> do
  // ++  +.  -.  ->  *.  /.  <-  &&  ||  ==  !=  <=  >=  <.  >.
  if c == ch_plus && c2 == ch_plus then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkPlusPlus, span: span))
  end
  if c == ch_plus && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkPlusDot, span: span))
  end
  if c == ch_minus && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkMinusDot, span: span))
  end
  if c == ch_minus && c2 == ch_gt then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkArrow, span: span))
  end
  if c == ch_star && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkStarDot, span: span))
  end
  if c == ch_slash && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkSlashDot, span: span))
  end
  if c == ch_lt && c2 == ch_lt then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkShl, span: span))
  end
  if c == ch_gt && c2 == ch_gt then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkShr, span: span))
  end
  if c == ch_lt && c2 == ch_minus then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkLArrow, span: span))
  end
  if c == ch_ampersand && c2 == ch_ampersand then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkAndAnd, span: span))
  end
  if c == ch_pipe && c2 == ch_pipe then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkPipePipe, span: span))
  end
  if c == ch_eq && c2 == ch_eq then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkEqEq, span: span))
  end
  if c == ch_bang && c2 == ch_eq then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkBangEq, span: span))
  end
  if c == ch_lt && c2 == ch_eq then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkLe, span: span))
  end
  if c == ch_gt && c2 == ch_eq then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkGe, span: span))
  end
  if c == ch_lt && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkLtDot, span: span))
  end
  if c == ch_gt && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkGtDot, span: span))
  end
  // [| |]
  if c == ch_lbracket && c2 == ch_pipe then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkLArray, span: span))
  end
  if c == ch_pipe && c2 == ch_rbracket then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkRArray, span: span))
  end
  // ()
  if c == ch_lparen && c2 == ch_rparen then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkUnit, span: span))
  end
  // ::
  if c == ch_colon && c2 == ch_colon then
    return Some(val: spanned(st: advance_n(st: st, n: 2), token: TkColonColon, span: span))
  end
  return None
end

let lex_single_char = fn (st: LexerState, span: Span, c: char) -> Option<LexResult> do
  if c == ch_lparen then return Some(val: spanned(st: advance(st: st), token: TkLParen, span: span)) end
  if c == ch_rparen then return Some(val: spanned(st: advance(st: st), token: TkRParen, span: span)) end
  if c == ch_lbrace then return Some(val: spanned(st: advance(st: st), token: TkLBrace, span: span)) end
  if c == ch_rbrace then return Some(val: spanned(st: advance(st: st), token: TkRBrace, span: span)) end
  if c == ch_lbracket then return Some(val: spanned(st: advance(st: st), token: TkLBracket, span: span)) end
  if c == ch_rbracket then return Some(val: spanned(st: advance(st: st), token: TkRBracket, span: span)) end
  if c == ch_comma then return Some(val: spanned(st: advance(st: st), token: TkComma, span: span)) end
  if c == ch_dot then return Some(val: spanned(st: advance(st: st), token: TkDot, span: span)) end
  if c == ch_colon then return Some(val: spanned(st: advance(st: st), token: TkColon, span: span)) end
  if c == ch_eq then return Some(val: spanned(st: advance(st: st), token: TkEq, span: span)) end
  if c == ch_plus then return Some(val: spanned(st: advance(st: st), token: TkPlus, span: span)) end
  if c == ch_minus then return Some(val: spanned(st: advance(st: st), token: TkMinus, span: span)) end
  if c == ch_star then return Some(val: spanned(st: advance(st: st), token: TkStar, span: span)) end
  if c == ch_slash then return Some(val: spanned(st: advance(st: st), token: TkSlash, span: span)) end
  if c == ch_lt then return Some(val: spanned(st: advance(st: st), token: TkLt, span: span)) end
  if c == ch_gt then return Some(val: spanned(st: advance(st: st), token: TkGt, span: span)) end
  if c == ch_pipe then return Some(val: spanned(st: advance(st: st), token: TkPipe, span: span)) end
  if c == ch_tilde then return Some(val: spanned(st: advance(st: st), token: TkTilde, span: span)) end
  if c == ch_percent then return Some(val: spanned(st: advance(st: st), token: TkPercent, span: span)) end
  if c == ch_ampersand then return Some(val: spanned(st: advance(st: st), token: TkAmpersand, span: span)) end
  if c == ch_at then return Some(val: spanned(st: advance(st: st), token: TkAt, span: span)) end
  if c == ch_caret then return Some(val: spanned(st: advance(st: st), token: TkCaret, span: span)) end
  return None
end

// ─── Main token dispatch ─────────────────────────────────────────────────────

let lex_token = fn (st: LexerState) -> LexResult do
  let st0 = skip_whitespace_and_comments(st: st)
  if at_end(st: st0) then
    return spanned(st: st0, token: TkEof, span: current_span(st: st0))
  end

  let span = current_span(st: st0)
  let c = peek(st: st0)
  let c2 = peek_at(st: st0, offset: 1)

  // Identifier or keyword
  if char.is_lower(c: c) || c == ch_underscore then
    return lex_identifier(st: advance(st: st0), span: span)
  end

  // Uppercase identifier
  if char.is_upper(c: c) then
    return lex_uident(st: advance(st: st0), span: span)
  end

  // Number (digit, or minus followed by digit)
  if char.is_digit(c: c) then
    return lex_number(st: advance(st: st0), span: span)
  end
  if c == ch_minus && char.is_digit(c: c2) then
    return lex_number(st: advance_n(st: st0, n: 2), span: span)
  end

  // String literal
  if c == ch_dquote then
    return lex_string(st: advance(st: st0), span: span)
  end

  // Char literal
  if c == ch_squote then
    return lex_char_literal(st: advance(st: st0), span: span)
  end

  // Bracket string [=[
  if c == ch_lbracket && c2 == ch_eq && peek_at(st: st0, offset: 2) == ch_lbracket then
    return lex_bracket_string(st: advance_n(st: st0, n: 3), span: span)
  end

  // Three-char operators (must check before two-char)
  let c3 = peek_at(st: st0, offset: 2)
  match lex_three_char_op(st: st0, span: span, c: c, c2: c2, c3: c3) do
    case Some(val: result) -> return result
    case None -> ()
  end

  // Two-char operators
  match lex_two_char_op(st: st0, span: span, c: c, c2: c2) do
    case Some(val: result) -> return result
    case None -> ()
  end

  // Single-char tokens
  match lex_single_char(st: st0, span: span, c: c) do
    case Some(val: result) -> return result
    case None -> ()
  end

  // Unknown character → error token, skip and continue
  return spanned(st: advance(st: st0), token: TkError(msg: "unexpected character: " ++ str.from_char(c: c)), span: span)
end

// ─── Public API ──────────────────────────────────────────────────────────────

// Monomorphic reverse for SpannedToken lists (generic list.reverse has codegen issues in nxc)
let reverse_tokens = fn (xs: [SpannedToken], acc: [SpannedToken]) -> [SpannedToken] do
  match xs do
    case Nil -> return acc
    case Cons(v: v, rest: rest) -> return reverse_tokens(xs: rest, acc: Cons(v: v, rest: acc))
  end
end

// Accumulator-based tokenizer (tail-recursive to avoid stack overflow on large files)
let tokenize_loop = fn (st: LexerState, acc: [SpannedToken]) -> [SpannedToken] do
  let st1 = skip_whitespace_and_comments(st: st)
  if at_end(st: st1) then
    return reverse_tokens(xs: Cons(v: SpannedToken(token: TkEof, span: current_span(st: st1)), rest: acc), acc: Nil)
  end
  let result = lex_token(st: st1)
  let LexResult(st: next, tok: tok) = result
  return tokenize_loop(st: next, acc: Cons(v: tok, rest: acc))
end

/// Tokenize a source string into a list of SpannedTokens (ending with TkEof).
export let tokenize = fn (src: string) -> [SpannedToken] do
  return tokenize_loop(st: make_lexer(src: src), acc: Nil)
end
