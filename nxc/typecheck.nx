/**
 * typecheck: Type inference and checking for the Nexus self-hosting compiler.
 *
 * Core infrastructure:
 * - Substitution: list-based type variable → type mappings
 * - Unification: Robinson-style with numeric flex, row types, borrow transparency
 * - Free variables: computation for generalization
 * - Scheme: polytypes with quantified variables
 * - TypeEnv: typing environment with bindings, type defs, enum defs, linearity
 */
import { Span } from nxc/token.nx
import { Sigil, BinaryOp, Literal, TypeExpr, Pattern, Expr, Stmt,
         SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel,
         Param, Function, MatchCase, CallArg, CtorArg, NamedExpr,
         NamedType, VariantField, CtorPatternField, RecordPatField,
         VariantDef, EnumDef, RecordDef, ExceptionDef, ImportDef,
         FunctionSig, Port, GlobalLet, TopLevel, Program } from nxc/ast.nx
import { length, substring, index_of, from_i64 } from stdlib/string.nx
import { reverse } from stdlib/list.nx

// ─── Substitution ────────────────────────────────────────────────────────────

/// A single type variable → type mapping.
pub type SubstEntry = SubstEntry(var: string, typ: TypeExpr)

/// Look up a type variable in a substitution.
let subst_lookup = fn (subst: [SubstEntry], var: string) -> Option<TypeExpr> do
  match subst do
    case Nil() -> return None()
    case Cons(v: entry, rest: rest) ->
      match entry do case SubstEntry(var: v, typ: t) ->
        if v == var then return Some(val: t)
        else return subst_lookup(subst: rest, var: var)
        end
      end
  end
end

/// Apply a substitution to a type, recursively replacing type variables.
pub let apply_subst = fn (subst: [SubstEntry], typ: TypeExpr) -> TypeExpr do
  match typ do
    case TyVar(name: n) ->
      match subst_lookup(subst: subst, var: n) do
        case Some(val: t) -> return t
        case None() -> return typ
      end
    case TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return TyArrow(
        params: apply_subst_named_types(subst: subst, nts: ps),
        ret: apply_subst(subst: subst, typ: r),
        requires: apply_subst(subst: subst, typ: req),
        throw_row: apply_subst(subst: subst, typ: thr)
      )
    case TyUserDefined(name: n, args: args) ->
      return TyUserDefined(name: n, args: apply_subst_list(subst: subst, types: args))
    case TyRef(inner: i) -> return TyRef(inner: apply_subst(subst: subst, typ: i))
    case TyLinear(inner: i) -> return TyLinear(inner: apply_subst(subst: subst, typ: i))
    case TyBorrow(inner: i) -> return TyBorrow(inner: apply_subst(subst: subst, typ: i))
    case TyArray(elem: e) -> return TyArray(elem: apply_subst(subst: subst, typ: e))
    case TyList(elem: e) -> return TyList(elem: apply_subst(subst: subst, typ: e))
    case TyRecord(fields: fs) ->
      return TyRecord(fields: apply_subst_named_types(subst: subst, nts: fs))
    case TyRow(types: es, rest: tail) ->
      let new_tail = match tail do
        case Some(val: t) -> Some(val: apply_subst(subst: subst, typ: t))
        case None() -> None()
      end
      return TyRow(types: apply_subst_list(subst: subst, types: es), rest: new_tail)
    case TyHandler(name: n, requires: req) ->
      return TyHandler(name: n, requires: apply_subst(subst: subst, typ: req))
    case _ -> return typ
  end
end

let apply_subst_list = fn (subst: [SubstEntry], types: [TypeExpr]) -> [TypeExpr] do
  match types do
    case Nil() -> return Nil()
    case Cons(v: t, rest: rest) ->
      return Cons(v: apply_subst(subst: subst, typ: t),
                  rest: apply_subst_list(subst: subst, types: rest))
  end
end

let apply_subst_named_types = fn (subst: [SubstEntry], nts: [NamedType]) -> [NamedType] do
  return match nts do
    case Nil() -> return Nil()
    case Cons(v: NamedType(name: n, typ: t), rest: rest) ->
      Cons(v: NamedType(name: n, typ: apply_subst(subst: subst, typ: t)),
                rest: apply_subst_named_types(subst: subst, nts: rest))
  end
end

/// Compose two substitutions: apply s2 to all values of s1, then merge.
pub let compose_subst = fn (s1: [SubstEntry], s2: [SubstEntry]) -> [SubstEntry] do
  let applied = apply_subst_to_entries(s2: s2, entries: s1)
  return merge_subst_entries(base: applied, extra: s2)
end

let apply_subst_to_entries = fn (s2: [SubstEntry], entries: [SubstEntry]) -> [SubstEntry] do
  match entries do
    case Nil() -> return Nil()
    case Cons(v: entry, rest: rest) ->
      match entry do case SubstEntry(var: v, typ: t) ->
        return Cons(v: SubstEntry(var: v, typ: apply_subst(subst: s2, typ: t)),
                    rest: apply_subst_to_entries(s2: s2, entries: rest))
      end
  end
end

/// Merge entries from extra into base, skipping keys already in base.
let merge_subst_entries = fn (base: [SubstEntry], extra: [SubstEntry]) -> [SubstEntry] do
  match extra do
    case Nil() -> return base
    case Cons(v: entry, rest: rest) ->
      match entry do case SubstEntry(var: v, typ: _) ->
        if subst_has_key(subst: base, var: v) then
          return merge_subst_entries(base: base, extra: rest)
        else
          return merge_subst_entries(base: Cons(v: entry, rest: base), extra: rest)
        end
      end
  end
end

let subst_has_key = fn (subst: [SubstEntry], var: string) -> bool do
  return match subst do
    case Nil() -> return false
    case Cons(v: SubstEntry(var: v, typ: _), rest: rest) ->
      if v == var then true
      else subst_has_key(subst: rest, var: var)
      end
  end
end

/// Empty substitution.
pub let empty_subst = fn () -> [SubstEntry] do
  return Nil()
end

/// Singleton substitution.
pub let singleton_subst = fn (var: string, typ: TypeExpr) -> [SubstEntry] do
  return Cons(v: SubstEntry(var: var, typ: typ), rest: Nil())
end

// ─── Free Variables ──────────────────────────────────────────────────────────

/// Collect free type variables from a type.
pub let free_vars = fn (typ: TypeExpr) -> [string] do
  return dedup_strings(xs: free_vars_go(typ: typ))
end

let free_vars_go = fn (typ: TypeExpr) -> [string] do
  match typ do
    case TyVar(name: n) -> return Cons(v: n, rest: Nil())
    case TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      let a = free_vars_named_types(nts: ps)
      let b = free_vars_go(typ: r)
      let c = free_vars_go(typ: req)
      let d = free_vars_go(typ: thr)
      return concat_strings(a: a, b: concat_strings(a: b, b: concat_strings(a: c, b: d)))
    case TyUserDefined(name: _, args: args) ->
      return free_vars_list(types: args)
    case TyRef(inner: i) -> return free_vars_go(typ: i)
    case TyLinear(inner: i) -> return free_vars_go(typ: i)
    case TyBorrow(inner: i) -> return free_vars_go(typ: i)
    case TyArray(elem: e) -> return free_vars_go(typ: e)
    case TyList(elem: e) -> return free_vars_go(typ: e)
    case TyRecord(fields: fs) -> return free_vars_named_types(nts: fs)
    case TyRow(types: es, rest: tail) ->
      let a = free_vars_list(types: es)
      match tail do
        case Some(val: t) -> return concat_strings(a: a, b: free_vars_go(typ: t))
        case None() -> return a
      end
    case TyHandler(name: _, requires: req) -> return free_vars_go(typ: req)
    case _ -> return Nil()
  end
end

let free_vars_list = fn (types: [TypeExpr]) -> [string] do
  match types do
    case Nil() -> return Nil()
    case Cons(v: t, rest: rest) ->
      return concat_strings(a: free_vars_go(typ: t), b: free_vars_list(types: rest))
  end
end

let free_vars_named_types = fn (nts: [NamedType]) -> [string] do
  return match nts do
    case Nil() -> return Nil()
    case Cons(v: NamedType(name: _, typ: t), rest: rest) ->
      concat_strings(a: free_vars_go(typ: t), b: free_vars_named_types(nts: rest))
  end
end

// ─── String list helpers ─────────────────────────────────────────────────────

let concat_strings = fn (a: [string], b: [string]) -> [string] do
  match a do
    case Nil() -> return b
    case Cons(v: x, rest: rest) ->
      return Cons(v: x, rest: concat_strings(a: rest, b: b))
  end
end

let string_in_list = fn (s: string, xs: [string]) -> bool do
  match xs do
    case Nil() -> return false
    case Cons(v: x, rest: rest) ->
      if x == s then return true
      else return string_in_list(s: s, xs: rest)
      end
  end
end

let dedup_strings = fn (xs: [string]) -> [string] do
  return dedup_strings_go(xs: xs, seen: Nil())
end

let dedup_strings_go = fn (xs: [string], seen: [string]) -> [string] do
  match xs do
    case Nil() -> return Nil()
    case Cons(v: x, rest: rest) ->
      if string_in_list(s: x, xs: seen) then
        return dedup_strings_go(xs: rest, seen: seen)
      else
        return Cons(v: x, rest: dedup_strings_go(xs: rest, seen: Cons(v: x, rest: seen)))
      end
  end
end

/// Remove elements of bs from as.
let subtract_strings = fn (as_: [string], bs: [string]) -> [string] do
  match as_ do
    case Nil() -> return Nil()
    case Cons(v: x, rest: rest) ->
      if string_in_list(s: x, xs: bs) then
        return subtract_strings(as_: rest, bs: bs)
      else
        return Cons(v: x, rest: subtract_strings(as_: rest, bs: bs))
      end
  end
end

// ─── Occurs Check ────────────────────────────────────────────────────────────

/// Check whether type variable `var` occurs in `typ` (prevents infinite types).
pub let occurs_check = fn (var: string, typ: TypeExpr) -> bool do
  match typ do
    case TyVar(name: n) -> return n == var
    case TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      if occurs_check(var: var, typ: r) then return true end
      if occurs_check_named_types(var: var, nts: ps) then return true end
      if occurs_check(var: var, typ: req) then return true end
      return occurs_check(var: var, typ: thr)
    case TyUserDefined(name: _, args: args) ->
      return occurs_check_list(var: var, types: args)
    case TyRef(inner: i) -> return occurs_check(var: var, typ: i)
    case TyLinear(inner: i) -> return occurs_check(var: var, typ: i)
    case TyBorrow(inner: i) -> return occurs_check(var: var, typ: i)
    case TyArray(elem: e) -> return occurs_check(var: var, typ: e)
    case TyList(elem: e) -> return occurs_check(var: var, typ: e)
    case TyRecord(fields: fs) -> return occurs_check_named_types(var: var, nts: fs)
    case TyRow(types: es, rest: tail) ->
      if occurs_check_list(var: var, types: es) then return true end
      match tail do
        case Some(val: t) -> return occurs_check(var: var, typ: t)
        case None() -> return false
      end
    case TyHandler(name: _, requires: req) -> return occurs_check(var: var, typ: req)
    case _ -> return false
  end
end

let occurs_check_list = fn (var: string, types: [TypeExpr]) -> bool do
  match types do
    case Nil() -> return false
    case Cons(v: t, rest: rest) ->
      if occurs_check(var: var, typ: t) then return true
      else return occurs_check_list(var: var, types: rest)
      end
  end
end

let occurs_check_named_types = fn (var: string, nts: [NamedType]) -> bool do
  return match nts do
    case Nil() -> return false
    case Cons(v: NamedType(name: _, typ: t), rest: rest) ->
      if occurs_check(var: var, typ: t) then true
      else occurs_check_named_types(var: var, nts: rest)
      end
  end
end

// ─── Type Equality ───────────────────────────────────────────────────────────

/// Structural type equality check.
pub let type_eq = fn (a: TypeExpr, b: TypeExpr) -> bool do
  match a do
    case TyI32 -> match b do case TyI32 -> return true case _ -> return false end
    case TyI64 -> match b do case TyI64 -> return true case _ -> return false end
    case TyF32 -> match b do case TyF32 -> return true case _ -> return false end
    case TyF64 -> match b do case TyF64 -> return true case _ -> return false end
    case TyBool -> match b do case TyBool -> return true case _ -> return false end
    case TyString -> match b do case TyString -> return true case _ -> return false end
    case TyUnit -> match b do case TyUnit -> return true case _ -> return false end
    case TyIntLit -> match b do case TyIntLit -> return true case _ -> return false end
    case TyFloatLit -> match b do case TyFloatLit -> return true case _ -> return false end
    case TyVar(name: n1) ->
      match b do case TyVar(name: n2) -> return n1 == n2 case _ -> return false end
    case TyUserDefined(name: n1, args: a1) ->
      match b do
        case TyUserDefined(name: n2, args: a2) ->
          if n1 == n2 then return type_list_eq(a: a1, b: a2)
          else return false
          end
        case _ -> return false
      end
    case TyArrow(params: p1, ret: r1, requires: req1, throw_row: thr1) ->
      match b do
        case TyArrow(params: p2, ret: r2, requires: req2, throw_row: thr2) ->
          if type_eq(a: r1, b: r2) == false then return false end
          if type_eq(a: req1, b: req2) == false then return false end
          if type_eq(a: thr1, b: thr2) == false then return false end
          return named_type_list_eq(a: p1, b: p2)
        case _ -> return false
      end
    case TyRef(inner: i1) ->
      match b do case TyRef(inner: i2) -> return type_eq(a: i1, b: i2) case _ -> return false end
    case TyLinear(inner: i1) ->
      match b do case TyLinear(inner: i2) -> return type_eq(a: i1, b: i2) case _ -> return false end
    case TyBorrow(inner: i1) ->
      match b do case TyBorrow(inner: i2) -> return type_eq(a: i1, b: i2) case _ -> return false end
    case TyArray(elem: e1) ->
      match b do case TyArray(elem: e2) -> return type_eq(a: e1, b: e2) case _ -> return false end
    case TyList(elem: e1) ->
      match b do case TyList(elem: e2) -> return type_eq(a: e1, b: e2) case _ -> return false end
    case TyRecord(fields: f1) ->
      match b do case TyRecord(fields: f2) -> return named_type_list_eq(a: f1, b: f2) case _ -> return false end
    case TyRow(types: e1, rest: t1) ->
      match b do
        case TyRow(types: e2, rest: t2) ->
          if type_list_eq(a: e1, b: e2) == false then return false end
          match t1 do
            case Some(val: tt1) ->
              match t2 do
                case Some(val: tt2) -> return type_eq(a: tt1, b: tt2)
                case None() -> return false
              end
            case None() ->
              match t2 do
                case Some(val: _) -> return false
                case None() -> return true
              end
          end
        case _ -> return false
      end
    case TyHandler(name: n1, requires: r1) ->
      match b do
        case TyHandler(name: n2, requires: r2) ->
          if n1 == n2 then return type_eq(a: r1, b: r2)
          else return false
          end
        case _ -> return false
      end
  end
end

let type_list_eq = fn (a: [TypeExpr], b: [TypeExpr]) -> bool do
  let t = { l: a, r: b }
  return match t do
           case { l: Nil(), r: Nil() } -> true
           case { l: Cons(v: x, rest: xs), r: Cons(v: y, rest: ys) } ->
               if type_eq(a: x, b: y) then type_list_eq(a: xs, b: ys)
               else false
               end
           case _ -> false
         end
end

let named_type_list_eq = fn (a: [NamedType], b: [NamedType]) -> bool do
  let t = { l: a, r: b }
  return match t do
           case { l: Nil(), r: Nil() } -> false
           case { l: Nil(), r: _ } -> true
           case { l: Cons(v: x, rest: xs), r: Nil() } -> false
           case { l: Cons(v: NamedType(name: n1, typ: t1), rest: xs)
                , r: Cons(v: NamedType(name: n2, typ: t2), rest: ys) } ->
                     if n1 == n2 && type_eq(a: t1, b: t2) then
                       named_type_list_eq(a: xs, b: ys)
                     else false
                     end
         end
end

// ─── Unification ─────────────────────────────────────────────────────────────

/// Result of unification: either a substitution or an error message.
pub type UnifyResult =
  UnifyOk(subst: [SubstEntry])
  | UnifyErr(msg: string)

/// Unify two types, returning a substitution if successful.
pub let unify = fn (t1: TypeExpr, t2: TypeExpr) -> UnifyResult do
  // Same type → empty subst
  if type_eq(a: t1, b: t2) then return UnifyOk(subst: Nil()) end

  // Numeric flex: IntLit ↔ I32/I64, FloatLit ↔ F32/F64
  match t1 do
    case TyIntLit ->
      match t2 do
        case TyI32 -> return UnifyOk(subst: Nil())
        case TyI64 -> return UnifyOk(subst: Nil())
        case _ -> return unify_continue(t1: t1, t2: t2)
      end
    case TyFloatLit ->
      match t2 do
        case TyF32 -> return UnifyOk(subst: Nil())
        case TyF64 -> return UnifyOk(subst: Nil())
        case _ -> return unify_continue(t1: t1, t2: t2)
      end
    case TyI32 ->
      match t2 do
        case TyIntLit -> return UnifyOk(subst: Nil())
        case _ -> return unify_continue(t1: t1, t2: t2)
      end
    case TyI64 ->
      match t2 do
        case TyIntLit -> return UnifyOk(subst: Nil())
        case _ -> return unify_continue(t1: t1, t2: t2)
      end
    case TyF32 ->
      match t2 do
        case TyFloatLit -> return UnifyOk(subst: Nil())
        case _ -> return unify_continue(t1: t1, t2: t2)
      end
    case TyF64 ->
      match t2 do
        case TyFloatLit -> return UnifyOk(subst: Nil())
        case _ -> return unify_continue(t1: t1, t2: t2)
      end
    case _ -> return unify_continue(t1: t1, t2: t2)
  end
end

let unify_continue = fn (t1: TypeExpr, t2: TypeExpr) -> UnifyResult do
  // Type variable binding
  match t1 do
    case TyVar(name: n) ->
      if occurs_check(var: n, typ: t2) then return UnifyErr(msg: "Recursive type")
      else return UnifyOk(subst: singleton_subst(var: n, typ: t2))
      end
    case _ ->
      match t2 do
        case TyVar(name: n) ->
          if occurs_check(var: n, typ: t1) then return UnifyErr(msg: "Recursive type")
          else return UnifyOk(subst: singleton_subst(var: n, typ: t1))
          end
        case _ -> return unify_structural(t1: t1, t2: t2)
      end
  end
end

let unify_structural = fn (t1: TypeExpr, t2: TypeExpr) -> UnifyResult do
  match t1 do
    case TyArrow(params: p1, ret: r1, requires: req1, throw_row: thr1) ->
      match t2 do
        case TyArrow(params: p2, ret: r2, requires: req2, throw_row: thr2) ->
          return unify_arrows(p1: p1, r1: r1, req1: req1, thr1: thr1,
                              p2: p2, r2: r2, req2: req2, thr2: thr2)
        case _ -> return UnifyErr(msg: "Type mismatch: arrow vs non-arrow")
      end
    case TyUserDefined(name: n1, args: a1) ->
      match t2 do
        case TyUserDefined(name: n2, args: a2) ->
          if n1 == n2 then return unify_type_lists(t1s: a1, t2s: a2, s: Nil())
          else return UnifyErr(msg: "Type mismatch: " ++ n1 ++ " vs " ++ n2)
          end
        case TyList(elem: inner) ->
          if n1 == "List" then
            return unify_ud_list(args: a1, inner: inner)
          else return UnifyErr(msg: "Type mismatch")
          end
        case _ -> return UnifyErr(msg: "Type mismatch")
      end
    case TyList(elem: inner) ->
      match t2 do
        case TyList(elem: inner2) -> return unify(t1: inner, t2: inner2)
        case TyUserDefined(name: n, args: args) ->
          if n == "List" then return unify_ud_list(args: args, inner: inner)
          else return UnifyErr(msg: "Type mismatch")
          end
        case _ -> return UnifyErr(msg: "Type mismatch")
      end
    case TyArray(elem: e1) ->
      match t2 do
        case TyArray(elem: e2) -> return unify(t1: e1, t2: e2)
        case _ -> return UnifyErr(msg: "Type mismatch: array")
      end
    case TyRef(inner: i1) ->
      match t2 do
        case TyRef(inner: i2) -> return unify(t1: i1, t2: i2)
        case _ -> return UnifyErr(msg: "Type mismatch: ref")
      end
    case TyLinear(inner: i1) ->
      match t2 do
        case TyLinear(inner: i2) -> return unify(t1: i1, t2: i2)
        case _ -> return UnifyErr(msg: "Type mismatch: linear")
      end
    case TyBorrow(inner: i1) ->
      match t2 do
        case TyBorrow(inner: i2) -> return unify(t1: i1, t2: i2)
        case _ ->
          // Borrow transparency: &T can unify with T
          return unify(t1: i1, t2: t2)
      end
    case TyRecord(fields: f1) ->
      match t2 do
        case TyRecord(fields: f2) -> return unify_records(f1: f1, f2: f2)
        case _ -> return UnifyErr(msg: "Type mismatch: record")
      end
    case TyRow(types: e1, rest: tail1) ->
      match t2 do
        case TyRow(types: e2, rest: tail2) ->
          return unify_rows(e1: e1, tail1: tail1, e2: e2, tail2: tail2)
        case _ -> return UnifyErr(msg: "Type mismatch: row")
      end
    case TyHandler(name: n1, requires: req1) ->
      match t2 do
        case TyHandler(name: n2, requires: req2) ->
          if n1 == n2 then return unify(t1: req1, t2: req2)
          else return UnifyErr(msg: "Handler mismatch: " ++ n1 ++ " vs " ++ n2)
          end
        case _ -> return UnifyErr(msg: "Type mismatch: handler")
      end
    case _ ->
      // Handle borrow on the right side too
      match t2 do
        case TyBorrow(inner: i2) -> return unify(t1: t1, t2: i2)
        case _ -> return UnifyErr(msg: "Type mismatch")
      end
  end
end

let unify_ud_list = fn (args: [TypeExpr], inner: TypeExpr) -> UnifyResult do
  match args do
    case Cons(v: arg, rest: Nil()) -> return unify(t1: arg, t2: inner)
    case _ -> return UnifyErr(msg: "List arity mismatch")
  end
end

let unify_type_lists = fn (t1s: [TypeExpr], t2s: [TypeExpr], s: [SubstEntry]) -> UnifyResult do
  match t1s do
    case Nil() ->
      match t2s do
        case Nil() -> return UnifyOk(subst: s)
        case _ -> return UnifyErr(msg: "Type argument arity mismatch")
      end
    case Cons(v: a, rest: ar) ->
      match t2s do
        case Nil() -> return UnifyErr(msg: "Type argument arity mismatch")
        case Cons(v: b, rest: br) ->
          let r = unify(t1: apply_subst(subst: s, typ: a),
                        t2: apply_subst(subst: s, typ: b))
          match r do
            case UnifyOk(subst: sn) ->
              return unify_type_lists(t1s: ar, t2s: br, s: compose_subst(s1: s, s2: sn))
            case UnifyErr(msg: m) -> return UnifyErr(msg: m)
          end
      end
  end
end

/// Unify arrow types by matching params by label then return, requires, throws.
let unify_arrows = fn (p1: [NamedType], r1: TypeExpr, req1: TypeExpr, thr1: TypeExpr,
                        p2: [NamedType], r2: TypeExpr, req2: TypeExpr, thr2: TypeExpr) -> UnifyResult do
  let r = unify_named_type_lists(nt1s: p1, nt2s: p2, s: Nil())
  match r do
    case UnifyErr(msg: m) -> return UnifyErr(msg: m)
    case UnifyOk(subst: s) ->
      let rr = unify(t1: apply_subst(subst: s, typ: r1),
                      t2: apply_subst(subst: s, typ: r2))
      match rr do
        case UnifyErr(msg: m) -> return UnifyErr(msg: m)
        case UnifyOk(subst: sr) ->
          let s2 = compose_subst(s1: s, s2: sr)
          let reqr = unify(t1: apply_subst(subst: s2, typ: req1),
                            t2: apply_subst(subst: s2, typ: req2))
          match reqr do
            case UnifyErr(msg: m) -> return UnifyErr(msg: m)
            case UnifyOk(subst: sreq) ->
              let s3 = compose_subst(s1: s2, s2: sreq)
              let thrr = unify(t1: apply_subst(subst: s3, typ: thr1),
                                t2: apply_subst(subst: s3, typ: thr2))
              match thrr do
                case UnifyErr(msg: m) -> return UnifyErr(msg: m)
                case UnifyOk(subst: sthr) -> return UnifyOk(subst: compose_subst(s1: s3, s2: sthr))
              end
          end
      end
  end
end

let unify_named_type_lists = fn (nt1s: [NamedType], nt2s: [NamedType], s: [SubstEntry]) -> UnifyResult do
  match nt1s do
    case Nil() ->
      match nt2s do
        case Nil() -> return UnifyOk(subst: s)
        case _ -> return UnifyErr(msg: "Param arity mismatch")
      end
    case Cons(v: nt1, rest: rest1) ->
      match nt1 do case NamedType(name: n1, typ: t1) ->
        let found = find_and_remove_by_name(name: n1, nts: nt2s)
        match found do
          case None() -> return UnifyErr(msg: "Label mismatch: missing " ++ n1)
          case Some(val: pair) ->
            match pair do case NamedType(name: _, typ: t2) ->
              let r = unify(t1: apply_subst(subst: s, typ: t1),
                            t2: apply_subst(subst: s, typ: t2))
              match r do
                case UnifyErr(msg: m) -> return UnifyErr(msg: m)
                case UnifyOk(subst: sn) ->
                  let s2 = compose_subst(s1: s, s2: sn)
                  let remaining = remove_by_name(name: n1, nts: nt2s)
                  return unify_named_type_lists(nt1s: rest1, nt2s: remaining, s: s2)
              end
            end
        end
      end
  end
end

let find_and_remove_by_name = fn (name: string, nts: [NamedType]) -> Option<NamedType> do
  match nts do
    case Nil() -> return None()
    case Cons(v: nt, rest: rest) ->
      match nt do case NamedType(name: n, typ: _) ->
        if n == name then return Some(val: nt)
        else return find_and_remove_by_name(name: name, nts: rest)
        end
      end
  end
end

let remove_by_name = fn (name: string, nts: [NamedType]) -> [NamedType] do
  match nts do
    case Nil() -> return Nil()
    case Cons(v: nt, rest: rest) ->
      match nt do case NamedType(name: n, typ: _) ->
        if n == name then return rest
        else return Cons(v: nt, rest: remove_by_name(name: name, nts: rest))
        end
      end
  end
end

/// Unify record types by sorting fields and comparing structurally.
let unify_records = fn (f1: [NamedType], f2: [NamedType]) -> UnifyResult do
  return unify_named_type_lists(nt1s: f1, nt2s: f2, s: Nil())
end

/// Unify row types (for effect polymorphism).
let unify_rows = fn (e1: [TypeExpr], tail1: Option<TypeExpr>,
                      e2: [TypeExpr], tail2: Option<TypeExpr>) -> UnifyResult do
  // Remove common elements
  let split = split_common_rows(e1: e1, e2: e2)
  match split do case RowSplit(only1: only1, only2: only2) ->
    // If both empty after removing common → unify tails
    match only1 do
      case Nil() ->
        match only2 do
          case Nil() ->
            // Both sides have same elements, just unify tails
            match tail1 do
              case Some(val: t1) ->
                match tail2 do
                  case Some(val: t2) -> return unify(t1: t1, t2: t2)
                  case None() -> return UnifyOk(subst: singleton_subst(var: extract_var_name(t: t1), typ: TyRow(types: Nil(), rest: None())))
                end
              case None() ->
                match tail2 do
                  case Some(val: t2) -> return UnifyOk(subst: singleton_subst(var: extract_var_name(t: t2), typ: TyRow(types: Nil(), rest: None())))
                  case None() -> return UnifyOk(subst: Nil())
                end
            end
          case _ ->
            // only2 has extras; unify tail1 with Row(only2, tail2)
            match tail1 do
              case Some(val: t1) ->
                return unify(t1: t1, t2: TyRow(types: only2, rest: tail2))
              case None() -> return UnifyErr(msg: "Row mismatch: extra elements")
            end
        end
      case _ ->
        // only1 has extras; unify tail2 with Row(only1, tail1)
        match tail2 do
          case Some(val: t2) ->
            return unify(t1: t2, t2: TyRow(types: only1, rest: tail1))
          case None() ->
            match only2 do
              case Nil() ->
                match tail1 do
                  case Some(val: t1) -> return unify(t1: t1, t2: TyRow(types: Nil(), rest: None()))
                  case None() -> return UnifyErr(msg: "Row mismatch: extra elements")
                end
              case _ -> return UnifyErr(msg: "Row mismatch: extra elements on both sides")
            end
        end
    end
  end
end

type RowSplit = RowSplit(only1: [TypeExpr], only2: [TypeExpr])

let split_common_rows = fn (e1: [TypeExpr], e2: [TypeExpr]) -> RowSplit do
  let only1 = remove_common(src: e1, targets: e2)
  let only2 = remove_common(src: e2, targets: e1)
  return RowSplit(only1: only1, only2: only2)
end

let remove_common = fn (src: [TypeExpr], targets: [TypeExpr]) -> [TypeExpr] do
  match src do
    case Nil() -> return Nil()
    case Cons(v: x, rest: rest) ->
      if type_in_list(t: x, ts: targets) then
        return remove_common(src: rest, targets: targets)
      else
        return Cons(v: x, rest: remove_common(src: rest, targets: targets))
      end
  end
end

let type_in_list = fn (t: TypeExpr, ts: [TypeExpr]) -> bool do
  match ts do
    case Nil() -> return false
    case Cons(v: x, rest: rest) ->
      if type_eq(a: t, b: x) then return true
      else return type_in_list(t: t, ts: rest)
      end
  end
end

let extract_var_name = fn (t: TypeExpr) -> string do
  match t do
    case TyVar(name: n) -> return n
    case _ -> return "__unknown"
  end
end

// ─── Scheme (Polytypes) ──────────────────────────────────────────────────────

/// A type scheme: universally quantified type variables + monotype.
pub type Scheme = Scheme(vars: [string], typ: TypeExpr)

/// Create a monomorphic scheme (no quantified variables).
pub let mono_scheme = fn (typ: TypeExpr) -> Scheme do
  return Scheme(vars: Nil(), typ: typ)
end

/// Generalize a type over variables not free in the environment.
/// env_free_vars: free variables from the typing environment.
pub let generalize = fn (env_free: [string], typ: TypeExpr) -> Scheme do
  let tvs = free_vars(typ: typ)
  let quantified = subtract_strings(as_: tvs, bs: env_free)
  return Scheme(vars: quantified, typ: typ)
end

/// Instantiate a scheme by replacing quantified variables with fresh ones.
/// supply: current fresh variable counter (returns new counter + type).
pub type InstResult = InstResult(supply: i64, typ: TypeExpr)

pub let instantiate = fn (scheme: Scheme, supply: i64) -> InstResult do
  match scheme do case Scheme(vars: vars, typ: typ) ->
    let result = build_inst_subst(vars: vars, supply: supply)
    match result do case InstSubst(subst: s, supply: new_supply) ->
      return InstResult(supply: new_supply, typ: apply_subst(subst: s, typ: typ))
    end
  end
end

type InstSubst = InstSubst(subst: [SubstEntry], supply: i64)

let build_inst_subst = fn (vars: [string], supply: i64) -> InstSubst do
  match vars do
    case Nil() -> return InstSubst(subst: Nil(), supply: supply)
    case Cons(v: v, rest: rest) ->
      let fresh = "?" ++ from_i64(val: supply)
      let r = build_inst_subst(vars: rest, supply: supply + 1)
      match r do case InstSubst(subst: s, supply: ns) ->
        return InstSubst(
          subst: Cons(v: SubstEntry(var: v, typ: TyVar(name: fresh)), rest: s),
          supply: ns
        )
      end
  end
end

/// Generate a fresh type variable.
pub type FreshResult = FreshResult(supply: i64, typ: TypeExpr)

pub let fresh_var = fn (supply: i64) -> FreshResult do
  return FreshResult(supply: supply + 1, typ: TyVar(name: "?" ++ from_i64(val: supply)))
end
