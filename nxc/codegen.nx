let op_i64_or = 132
let op_i64_xor = 133
let op_i64_shl = 134
let op_i64_shr_s = 135
let op_i64_shr_u = 136
let op_f64_add = 160
let op_f64_sub = 161
let op_f64_mul = 162
let op_f64_div = 163
let op_i32_wrap_i64 = 167
let op_i64_extend_i32_s = 172
let op_i64_extend_i32_u = 173
let op_f64_reinterpret_i64 = 191
let op_i64_reinterpret_f64 = 189

let string_data_base = 16
let heap_global_idx = 0

// ─── Helper Types ───────────────────────────────────────────────────────────

type LocalEntry = LocalEntry(name: string, index: i64, valtype: i64)
type FuncEntry = FuncEntry(name: string, index: i64)
type StringEntry = StringEntry(value: string, offset: i64, slen: i64)
type DataSeg = DataSeg(offset: i64, value: string)

type CodegenCtx = CodegenCtx(
  locals: [LocalEntry],
  internal_funcs: [FuncEntry],
  external_funcs: [FuncEntry],
  string_lits: [StringEntry],
  heap_enabled: bool,
  temps_base: i64,
  func_ret_type: TypeExpr,
  functions: [LirFunction],
  externals: [LirExternal]
)

let ctx_locals = fn (ctx: CodegenCtx) -> [LocalEntry] do
  match ctx do case CodegenCtx(locals: l, internal_funcs: _, external_funcs: _, string_lits: _, heap_enabled: _, temps_base: _, func_ret_type: _, functions: _, externals: _) -> return l end
end
let ctx_internal_funcs = fn (ctx: CodegenCtx) -> [FuncEntry] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: f, external_funcs: _, string_lits: _, heap_enabled: _, temps_base: _, func_ret_type: _, functions: _, externals: _) -> return f end
end
let ctx_external_funcs = fn (ctx: CodegenCtx) -> [FuncEntry] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: f, string_lits: _, heap_enabled: _, temps_base: _, func_ret_type: _, functions: _, externals: _) -> return f end
end
let ctx_string_lits = fn (ctx: CodegenCtx) -> [StringEntry] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: s, heap_enabled: _, temps_base: _, func_ret_type: _, functions: _, externals: _) -> return s end
end
let ctx_heap_enabled = fn (ctx: CodegenCtx) -> bool do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, heap_enabled: h, temps_base: _, func_ret_type: _, functions: _, externals: _) -> return h end
end
let ctx_temps_base = fn (ctx: CodegenCtx) -> i64 do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, heap_enabled: _, temps_base: t, func_ret_type: _, functions: _, externals: _) -> return t end
end
let ctx_func_ret_type = fn (ctx: CodegenCtx) -> TypeExpr do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, heap_enabled: _, temps_base: _, func_ret_type: r, functions: _, externals: _) -> return r end
end
let ctx_functions = fn (ctx: CodegenCtx) -> [LirFunction] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, heap_enabled: _, temps_base: _, func_ret_type: _, functions: f, externals: _) -> return f end
end
let ctx_externals = fn (ctx: CodegenCtx) -> [LirExternal] do
  match ctx do case CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, heap_enabled: _, temps_base: _, func_ret_type: _, functions: _, externals: e) -> return e end
end

// ─── Type Utilities ─────────────────────────────────────────────────────────

let peel_linear = fn (typ: TypeExpr) -> TypeExpr do
  match typ do
    case TyLinear(inner: t) -> return peel_linear(typ: t)
    case TyBorrow(inner: t) -> return peel_linear(typ: t)
    case _ -> return typ
  end
end

let type_to_valtype = fn (typ: TypeExpr) -> i64 do
  let t = peel_linear(typ: typ)
  match t do
    case TyI32 -> return vt_i32
    case TyBool -> return vt_i32
    case TyI64 -> return vt_i64
    case TyIntLit -> return vt_i64
    case TyF32 -> return vt_f32
    case TyF64 -> return vt_f64
    case TyFloatLit -> return vt_f64
    case TyString -> return vt_i64
    case TyArray(elem: _) -> return vt_i64
    case TyList(elem: _) -> return vt_i64
    case TyRecord(fields: _) -> return vt_i64
    case TyUserDefined(name: _, args: _) -> return vt_i64
    case TyVar(name: _) -> return vt_i64
    case TyHandler(name: _, requires: _) -> return vt_i64
    case _ -> return vt_i64
  end
end

let is_unit = fn (typ: TypeExpr) -> bool do
  let t = peel_linear(typ: typ)
  match t do
    case TyUnit -> return true
    case _ -> return false
  end
end

let return_valtype = fn (typ: TypeExpr) -> i64 do
  if is_unit(typ: typ) then return -1
  else return type_to_valtype(typ: typ)
  end
end

// ─── FNV-1a Hashing ─────────────────────────────────────────────────────────

let fnv_hash_byte = fn (hash: i64, byte: i64) -> i64 do
  let h = hash bxor byte
  // wrapping_mul with FNV prime 0x0000_0100_0000_01b3
  return h * 1099511628211
end

let fnv_hash_string_go = fn (s: string, idx: i64, slen: i64, hash: i64) -> i64 do
  if idx >= slen then return hash
  else
    let b = char_code(s: s, idx: idx)
    let h = fnv_hash_byte(hash: hash, byte: b)
    return fnv_hash_string_go(s: s, idx: idx + 1, slen: slen, hash: h)
  end
end

let fnv_hash_string = fn (s: string, hash: i64) -> i64 do
  let slen = str_length(s: s)
  return fnv_hash_string_go(s: s, idx: 0, slen: slen, hash: hash)
end

// FNV offset basis: 0xcbf29ce484222325
let fnv_basis = -3750763034362895579

let constructor_tag = fn (name: string, arity: i64) -> i64 do
  let h = fnv_hash_string(s: name, hash: fnv_basis)
  let h2 = fnv_hash_byte(hash: h, byte: arity)
  return h2
end

let record_tag = fn (sorted_names: [string]) -> i64 do
  let shape = join(xs: sorted_names, sep: ",")
  let h = fnv_hash_string(s: "rec", hash: fnv_basis)
  let h2 = fnv_hash_string(s: shape, hash: h)
  let n = list.length(xs: sorted_names)
  return fnv_hash_byte(hash: h2, byte: n)
end

// ─── Atom Type Accessor ─────────────────────────────────────────────────────

let atom_type = fn (atom: LirAtom) -> TypeExpr do
  match atom do
    case LirAtomVar(name: _, typ: t) -> return t
    case LirAtomInt(val: _) -> return TyI64
    case LirAtomFloat(val: _) -> return TyF64
    case LirAtomBool(val: _) -> return TyBool
    case LirAtomString(val: _) -> return TyString
    case LirAtomUnit -> return TyUnit
  end
end

let expr_type = fn (expr: LirExpr) -> TypeExpr do
  match expr do
    case LirExprAtom(atom: a) -> return atom_type(atom: a)
    case LirExprBinary(op: _, lhs: _, rhs: _, typ: t) -> return t
    case LirExprCall(func: _, args: _, typ: t) -> return t
    case LirExprTailCall(func: _, args: _, typ: t) -> return t
    case LirExprConstructor(name: _, args: _, typ: t) -> return t
    case LirExprRecord(fields: _, typ: t) -> return t
    case LirExprObjectTag(value: _, typ: t) -> return t
    case LirExprObjectField(value: _, index: _, typ: t) -> return t
    case LirExprRaise(value: _, typ: t) -> return t
  end
end

// ─── Lookup Helpers ─────────────────────────────────────────────────────────

let lookup_local = fn (name: string, entries: [LocalEntry]) -> i64 do
  match entries do
    case Nil() -> return -1
    case Cons(v: e, rest: rest) ->
      match e do case LocalEntry(name: n, index: idx, valtype: _) ->
        if n == name then return idx
        else return lookup_local(name: name, entries: rest)
        end
      end
  end
end

let lookup_func = fn (name: string, entries: [FuncEntry]) -> i64 do
  match entries do
    case Nil() -> return -1
    case Cons(v: e, rest: rest) ->
      match e do case FuncEntry(name: n, index: idx) ->
        if n == name then return idx
        else return lookup_func(name: name, entries: rest)
        end
      end
  end
end

/// Extract the base name from an import-prefixed function name.
/// "__import_N.foo" -> "foo", "foo" -> "foo"
let extract_base_name = fn (name: string) -> string do
  if str_starts_with(s: name, prefix: "__import_") then
    let dot_pos = str_index_of(s: name, sub: ".")
    if dot_pos >= 0 then
      return str_substring(s: name, start: dot_pos + 1, len: str_length(s: name) - dot_pos - 1)
    else return name
    end
  else return name
  end
end

/// Check if a function entry's name has the same base name.
let has_base_name = fn (entry_name: string, base: string) -> bool do
  let entry_base = extract_base_name(name: entry_name)
  return entry_base == base
end

/// Lookup a function by base name (ignoring __import_N. prefix differences).
let lookup_func_by_base = fn (base: string, entries: [FuncEntry]) -> i64 do
  match entries do
    case Nil() -> return -1
    case Cons(v: e, rest: rest) ->
      match e do case FuncEntry(name: n, index: idx) ->
        if has_base_name(entry_name: n, base: base) then return idx
        else return lookup_func_by_base(base: base, entries: rest)
        end
      end
  end
end

/// Find a function definition by base name (ignoring __import_N. prefix differences).
let find_function_by_base = fn (base: string, funcs: [LirFunction]) -> Option<LirFunction> do
  match funcs do
    case Nil() -> return None()
    case Cons(v: f, rest: rest) ->
      match f do case LirFunction(name: fname, params: _, ret_type: _, body: _, ret: _, span: _) ->
        if has_base_name(entry_name: fname, base: base) then return Some(val: f)
        else return find_function_by_base(base: base, funcs: rest)
        end
      end
  end
end

let lookup_string = fn (value: string, entries: [StringEntry]) -> i64 do
  match entries do
    case Nil() -> return -1
    case Cons(v: e, rest: rest) ->
      match e do case StringEntry(value: v, offset: off, slen: sl) ->
        if v == value then
          // pack: (offset << 32) | length
          return (off * 4294967296) + sl
        else return lookup_string(value: value, entries: rest)
        end
      end
  end
end

let find_function = fn (name: string, funcs: [LirFunction]) -> Option<LirFunction> do
  match funcs do
    case Nil() -> return None()
    case Cons(v: f, rest: rest) ->
      match f do case LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) ->
        if n == name then return Some(val: f)
        else return find_function(name: name, funcs: rest)
        end
      end
  end
end

let find_external = fn (name: string, exts: [LirExternal]) -> Option<LirExternal> do
  match exts do
    case Nil() -> return None()
    case Cons(v: e, rest: rest) ->
      match e do case LirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) ->
        if n == name then return Some(val: e)
        else return find_external(name: name, exts: rest)
        end
      end
  end
end

// ─── WASM Encoding Helpers ──────────────────────────────────────────────────

let emit_name = fn (buf: %ByteBuffer, name: string) -> %ByteBuffer do
  let slen = str_length(s: name)
  let %buf = push_uleb128(buf: %buf, val: slen)
  let %buf = push_string(buf: %buf, s: name)
  return %buf
end

let emit_section = fn (buf: %ByteBuffer, id: i64, content: %ByteBuffer) -> %ByteBuffer do
  let content_len = bb.length(buf: &content)
  let %buf = push_byte(buf: %buf, byte: id)
  let %buf = push_uleb128(buf: %buf, val: content_len)
  let %buf = push_buf(dst: %buf, src: &content)
  free(buf: %content)
  return %buf
end

let emit_memarg = fn (buf: %ByteBuffer, align: i64, offset: i64) -> %ByteBuffer do
  let %buf = push_uleb128(buf: %buf, val: align)
  let %buf = push_uleb128(buf: %buf, val: offset)
  return %buf
end

let emit_memarg_i64 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return emit_memarg(buf: %buf, align: 3, offset: offset)
end

let emit_memarg_i8 = fn (buf: %ByteBuffer) -> %ByteBuffer do
  return emit_memarg(buf: %buf, align: 0, offset: 0)
end

// ─── String Literal Collection ──────────────────────────────────────────────

let collect_atom_strings = fn (atom: LirAtom, acc: [string]) -> [string] do
  match atom do
    case LirAtomString(val: s) -> return Cons(v: s, rest: acc)
    case _ -> return acc
  end
end

let collect_expr_strings = fn (expr: LirExpr, acc: [string]) -> [string] do
  match expr do
    case LirExprAtom(atom: a) -> return collect_atom_strings(atom: a, acc: acc)
    case LirExprBinary(op: _, lhs: l, rhs: r, typ: _) ->
      let acc2 = collect_atom_strings(atom: l, acc: acc)
      return collect_atom_strings(atom: r, acc: acc2)
    case LirExprCall(func: _, args: args, typ: _) ->
      return collect_call_arg_strings(args: args, acc: acc)
    case LirExprTailCall(func: _, args: args, typ: _) ->
      return collect_call_arg_strings(args: args, acc: acc)
    case LirExprConstructor(name: _, args: atoms, typ: _) ->
      return collect_atom_list_strings(atoms: atoms, acc: acc)
    case LirExprRecord(fields: fields, typ: _) ->
      return collect_named_atom_strings(fields: fields, acc: acc)
    case LirExprObjectTag(value: v, typ: _) ->
      return collect_atom_strings(atom: v, acc: acc)
    case LirExprObjectField(value: v, index: _, typ: _) ->
      return collect_atom_strings(atom: v, acc: acc)
    case LirExprRaise(value: v, typ: _) ->
      return collect_atom_strings(atom: v, acc: acc)
  end
end

let collect_call_arg_strings = fn (args: [LirCallArg], acc: [string]) -> [string] do
  match args do
    case Nil() -> return acc
    case Cons(v: arg, rest: rest) ->
      match arg do case LirCallArg(label: _, value: v) ->
        let acc2 = collect_atom_strings(atom: v, acc: acc)
        return collect_call_arg_strings(args: rest, acc: acc2)
      end
  end
end

let collect_atom_list_strings = fn (atoms: [LirAtom], acc: [string]) -> [string] do
  match atoms do
    case Nil() -> return acc
    case Cons(v: a, rest: rest) ->
      let acc2 = collect_atom_strings(atom: a, acc: acc)
      return collect_atom_list_strings(atoms: rest, acc: acc2)
  end
end

let collect_named_atom_strings = fn (fields: [LirNamedAtom], acc: [string]) -> [string] do
  match fields do
    case Nil() -> return acc
    case Cons(v: f, rest: rest) ->
      match f do case LirNamedAtom(name: _, value: v) ->
        let acc2 = collect_atom_strings(atom: v, acc: acc)
        return collect_named_atom_strings(fields: rest, acc: acc2)
      end
  end
end

let collect_stmt_strings = fn (stmt: LirStmt, acc: [string]) -> [string] do
  match stmt do
    case LirStmtLet(name: _, typ: _, expr: e) ->
      return collect_expr_strings(expr: e, acc: acc)
    case LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let acc2 = collect_atom_strings(atom: c, acc: acc)
      let acc3 = collect_stmts_strings(stmts: tb, acc: acc2)
      return collect_stmts_strings(stmts: eb, acc: acc3)
    case LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr, else_body: eb, else_ret: er, ret_type: _) ->
      let acc2 = collect_atom_strings(atom: c, acc: acc)
      let acc3 = collect_stmts_strings(stmts: tb, acc: acc2)
      let acc4 = collect_atom_strings(atom: tr, acc: acc3)
      let acc5 = collect_stmts_strings(stmts: eb, acc: acc4)
      match er do
        case Some(val: a) -> return collect_atom_strings(atom: a, acc: acc5)
        case None() -> return acc5
      end
    case LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      let acc2 = collect_stmts_strings(stmts: cs, acc: acc)
      let acc3 = collect_atom_strings(atom: c, acc: acc2)
      return collect_stmts_strings(stmts: b, acc: acc3)
    case LirStmtTryCatch(body: b, body_ret: br, catch_param: _, catch_param_typ: _,
                          catch_body: cb, catch_ret: cr) ->
      let acc2 = collect_stmts_strings(stmts: b, acc: acc)
      let acc3 = match br do
        case Some(val: a) -> collect_atom_strings(atom: a, acc: acc2)
        case None() -> acc2
      end
      let acc4 = collect_stmts_strings(stmts: cb, acc: acc3)
      match cr do
        case Some(val: a) -> return collect_atom_strings(atom: a, acc: acc4)
        case None() -> return acc4
      end
  end
end

let collect_stmts_strings = fn (stmts: [LirStmt], acc: [string]) -> [string] do
  match stmts do
    case Nil() -> return acc
    case Cons(v: s, rest: rest) ->
      let acc2 = collect_stmt_strings(stmt: s, acc: acc)
      return collect_stmts_strings(stmts: rest, acc: acc2)
  end
end

let collect_func_strings = fn (func: LirFunction, acc: [string]) -> [string] do
  match func do case LirFunction(name: _, params: _, ret_type: _, body: b, ret: r, span: _) ->
    let acc2 = collect_stmts_strings(stmts: b, acc: acc)
    return collect_atom_strings(atom: r, acc: acc2)
  end
end

let collect_program_strings = fn (funcs: [LirFunction], acc: [string]) -> [string] do
  match funcs do
    case Nil() -> return acc
    case Cons(v: f, rest: rest) ->
      let acc2 = collect_func_strings(func: f, acc: acc)
      return collect_program_strings(funcs: rest, acc: acc2)
  end
end

// Deduplicate strings and build entries with offsets
let string_already_seen = fn (s: string, entries: [StringEntry]) -> bool do
  match entries do
    case Nil() -> return false
    case Cons(v: e, rest: rest) ->
      match e do case StringEntry(value: v, offset: _, slen: _) ->
        if v == s then return true
        else return string_already_seen(s: s, entries: rest)
        end
      end
  end
end

let build_string_entries = fn (strings: [string], next_offset: i64, acc: [StringEntry]) -> [StringEntry] do
  match strings do
    case Nil() -> return list.reverse(xs: acc)
    case Cons(v: s, rest: rest) ->
      if string_already_seen(s: s, entries: acc) then
        return build_string_entries(strings: rest, next_offset: next_offset, acc: acc)
      else
        let slen = str_length(s: s)
        let entry = StringEntry(value: s, offset: next_offset, slen: slen)
        return build_string_entries(strings: rest, next_offset: next_offset + slen, acc: Cons(v: entry, rest: acc))
      end
  end
end

// ─── Object Heap Detection ──────────────────────────────────────────────────

let expr_uses_heap = fn (expr: LirExpr) -> bool do
  match expr do
    case LirExprConstructor(name: _, args: _, typ: _) -> return true
    case LirExprRecord(fields: _, typ: _) -> return true
    case LirExprObjectTag(value: _, typ: _) -> return true
    case LirExprObjectField(value: _, index: _, typ: _) -> return true
    case LirExprBinary(op: op, lhs: _, rhs: _, typ: t) ->
      match op do
        case OpConcat -> return true
        case OpAdd ->
          let pt = peel_linear(typ: t)
          match pt do
            case TyString -> return true
            case _ -> return false
          end
        case _ -> return false
      end
    case _ -> return false
  end
end

let stmt_uses_heap = fn (stmt: LirStmt) -> bool do
  match stmt do
    case LirStmtLet(name: _, typ: _, expr: e) -> return expr_uses_heap(expr: e)
    case LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
      return stmts_use_heap(stmts: tb) || stmts_use_heap(stmts: eb)
    case LirStmtIfReturn(cond: _, then_body: tb, then_ret: _, else_body: eb, else_ret: _, ret_type: _) ->
      return stmts_use_heap(stmts: tb) || stmts_use_heap(stmts: eb)
    case LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      return stmts_use_heap(stmts: cs) || stmts_use_heap(stmts: b)
    case LirStmtTryCatch(body: b, body_ret: _, catch_param: _, catch_param_typ: _,
                          catch_body: cb, catch_ret: _) ->
      return stmts_use_heap(stmts: b) || stmts_use_heap(stmts: cb)
  end
end

let stmts_use_heap = fn (stmts: [LirStmt]) -> bool do
  match stmts do
    case Nil() -> return false
    case Cons(v: s, rest: rest) ->
      if stmt_uses_heap(stmt: s) then return true
      else return stmts_use_heap(stmts: rest)
      end
  end
end

let program_uses_heap = fn (funcs: [LirFunction]) -> bool do
  match funcs do
    case Nil() -> return false
    case Cons(v: f, rest: rest) ->
      match f do case LirFunction(name: _, params: _, ret_type: _, body: b, ret: _, span: _) ->
        if stmts_use_heap(stmts: b) then return true
        else return program_uses_heap(funcs: rest)
        end
      end
  end
end

// ─── External ABI helpers ───────────────────────────────────────────────────

let ext_param_is_string = fn (typ: TypeExpr) -> bool do
  let t = peel_linear(typ: typ)
  match t do
    case TyString -> return true
    case _ -> return false
  end
end

let ext_param_is_array = fn (typ: TypeExpr) -> bool do
  let t = peel_linear(typ: typ)
  match t do
    case TyArray(elem: _) -> return true
    case _ -> return false
  end
end

let external_uses_string_abi = fn (ext: LirExternal) -> bool do
  match ext do case LirExternal(name: _, wasm_module: _, wasm_name: _, params: ps, ret_type: rt, throw_row: _) ->
    if ext_param_is_string(typ: rt) then return true
    else return ext_params_use_string(params: ps)
    end
  end
end

let ext_params_use_string = fn (params: [LirParam]) -> bool do
  match params do
    case Nil() -> return false
    case Cons(v: p, rest: rest) ->
      match p do case LirParam(label: _, name: _, typ: t) ->
        if ext_param_is_string(typ: t) then return true
        else return ext_params_use_string(params: rest)
        end
      end
  end
end

// Count external param wasm slots (string/array expand to 2)
let count_ext_param_slots = fn (params: [LirParam]) -> i64 do
  match params do
    case Nil() -> return 0
    case Cons(v: p, rest: rest) ->
      match p do case LirParam(label: _, name: _, typ: t) ->
        let pt = peel_linear(typ: t)
        let slots = match pt do
          case TyString -> 2
          case TyArray(elem: _) -> 2
          case _ -> 1
        end
        return slots + count_ext_param_slots(params: rest)
      end
  end
end

// ─── Memory Mode ────────────────────────────────────────────────────────────

// Returns: 0 = None, 1 = Defined, or the module name string if Imported
// We encode as: "none", "defined", or the module name
let choose_memory_mode = fn (externals: [LirExternal], has_strings: bool, has_heap: bool) -> string do
  let mod_name = find_string_abi_module(exts: externals)
  match mod_name do
    case None() ->
      if has_strings || has_heap then return "defined"
      else return "none"
      end
    case Some(val: m) ->
      return m
  end
end

let find_string_abi_module = fn (exts: [LirExternal]) -> Option<string> do
  match exts do
    case Nil() -> return None()
    case Cons(v: e, rest: rest) ->
      if external_uses_string_abi(ext: e) then
        match e do case LirExternal(name: _, wasm_module: m, wasm_name: _, params: _, ret_type: _, throw_row: _) ->
          return Some(val: m)
        end
      else return find_string_abi_module(exts: rest)
      end
  end
end

let align8 = fn (v: i64) -> i64 do
  return (v + 7) / 8 * 8
end

// ─── Type Section Emission ──────────────────────────────────────────────────

let emit_ext_param_types = fn (buf: %ByteBuffer, params: [LirParam]) -> %ByteBuffer do
  match params do
    case Nil() -> return %buf
    case Cons(v: p, rest: rest) ->
      match p do case LirParam(label: _, name: _, typ: t) ->
        let pt = peel_linear(typ: t)
        let %buf = match pt do
          case TyString ->
            let %b = push_byte(buf: %buf, byte: vt_i32)
            push_byte(buf: %b, byte: vt_i32)
          case TyArray(elem: _) ->
            let %b = push_byte(buf: %buf, byte: vt_i32)
            push_byte(buf: %b, byte: vt_i32)
          case _ ->
            push_byte(buf: %buf, byte: type_to_valtype(typ: t))
        end
        return emit_ext_param_types(buf: %buf, params: rest)
      end
  end
end

let emit_ext_return_type = fn (buf: %ByteBuffer, typ: TypeExpr) -> %ByteBuffer do
  if is_unit(typ: typ) then
    let %buf = push_uleb128(buf: %buf, val: 0)
    return %buf
  else
    let %buf = push_uleb128(buf: %buf, val: 1)
    let %buf = push_byte(buf: %buf, byte: type_to_valtype(typ: typ))
    return %buf
  end
end

let emit_internal_param_types = fn (buf: %ByteBuffer, params: [LirParam]) -> %ByteBuffer do
  match params do
    case Nil() -> return %buf
    case Cons(v: p, rest: rest) ->
      match p do case LirParam(label: _, name: _, typ: t) ->
        let %buf = push_byte(buf: %buf, byte: type_to_valtype(typ: t))
        return emit_internal_param_types(buf: %buf, params: rest)
      end
  end
end

let emit_ext_type_entries = fn (buf: %ByteBuffer, exts: [LirExternal]) -> %ByteBuffer do
  match exts do
    case Nil() -> return %buf
    case Cons(v: e, rest: rest) ->
      match e do case LirExternal(name: _, wasm_module: _, wasm_name: _, params: ps, ret_type: rt, throw_row: _) ->
        let %buf = push_byte(buf: %buf, byte: 96)
        let slot_count = count_ext_param_slots(params: ps)
        let %buf = push_uleb128(buf: %buf, val: slot_count)
        let %buf = emit_ext_param_types(buf: %buf, params: ps)
        let %buf = emit_ext_return_type(buf: %buf, typ: rt)
        return emit_ext_type_entries(buf: %buf, exts: rest)
      end
  end
end

let emit_func_type_entries = fn (buf: %ByteBuffer, funcs: [LirFunction]) -> %ByteBuffer do
  match funcs do
    case Nil() -> return %buf
    case Cons(v: f, rest: rest) ->
      match f do case LirFunction(name: _, params: ps, ret_type: rt, body: _, ret: _, span: _) ->
        let %buf = push_byte(buf: %buf, byte: 96)
        let param_count = list.length(xs: ps)
        let %buf = push_uleb128(buf: %buf, val: param_count)
        let %buf = emit_internal_param_types(buf: %buf, params: ps)
        let %buf = emit_ext_return_type(buf: %buf, typ: rt)
        return emit_func_type_entries(buf: %buf, funcs: rest)
      end
  end
end

// Builds the full type section
let build_type_section = fn (program: LirProgram) -> %ByteBuffer do
  match program do case LirProgram(functions: funcs, externals: exts) ->
    let n_exts = list.length(xs: exts)
    let n_funcs = list.length(xs: funcs)
    // +1 for wasi:cli/run type
    let total = n_exts + n_funcs + 1
    let %sec = empty()
    let %sec = push_uleb128(buf: %sec, val: total)
    let %sec = emit_ext_type_entries(buf: %sec, exts: exts)
    let %sec = emit_func_type_entries(buf: %sec, funcs: funcs)
    // wasi:cli/run type: () -> i32
    let %sec = push_byte(buf: %sec, byte: 96)
    let %sec = push_uleb128(buf: %sec, val: 0)
    let %sec = push_uleb128(buf: %sec, val: 1)
    let %sec = push_byte(buf: %sec, byte: vt_i32)
    return %sec
  end
end

// ─── Import Section Emission ────────────────────────────────────────────────

let emit_import_entries = fn (buf: %ByteBuffer, exts: [LirExternal], type_idx: i64) -> %ByteBuffer do
  match exts do
    case Nil() -> return %buf
    case Cons(v: e, rest: rest) ->
      match e do case LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _) ->
        let %buf = emit_name(buf: %buf, name: m)
        let %buf = emit_name(buf: %buf, name: wn)
        let %buf = push_byte(buf: %buf, byte: desc_func)
        let %buf = push_uleb128(buf: %buf, val: type_idx)
        return emit_import_entries(buf: %buf, exts: rest, type_idx: type_idx + 1)
      end
  end
end

let build_import_section = fn (exts: [LirExternal], mem_mode: string) -> %ByteBuffer do
  let n_exts = list.length(xs: exts)
  let has_mem_import = mem_mode != "none" && mem_mode != "defined"
  let mem_import_count = match has_mem_import do case true -> 1 case false -> 0 end
  let n_imports = n_exts + mem_import_count
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: n_imports)
  // Memory import first (if needed)
  if has_mem_import then
    let %sec = emit_name(buf: %sec, name: mem_mode)
    let %sec = emit_name(buf: %sec, name: "memory")
    let %sec = push_byte(buf: %sec, byte: desc_memory)
    let %sec = push_byte(buf: %sec, byte: 0) // limits: no max
    let %sec = push_uleb128(buf: %sec, val: 1)            // min pages = 1
  end
  // Function imports
  let %sec = emit_import_entries(buf: %sec, exts: exts, type_idx: 0)
  return %sec
end

// ─── Function Section ───────────────────────────────────────────────────────

let emit_func_type_indices = fn (buf: %ByteBuffer, count: i64, start_idx: i64) -> %ByteBuffer do
  if count <= 0 then return %buf
  else
    let %buf = push_uleb128(buf: %buf, val: start_idx)
    return emit_func_type_indices(buf: %buf, count: count - 1, start_idx: start_idx + 1)
  end
end

let build_function_section = fn (n_funcs: i64, n_exts: i64) -> %ByteBuffer do
  let %sec = empty()
  // +1 for wasi:cli/run wrapper
  let %sec = push_uleb128(buf: %sec, val: n_funcs + 1)
  let %sec = emit_func_type_indices(buf: %sec, count: n_funcs, start_idx: n_exts)
  // wasi:cli/run type index is last
  let %sec = push_uleb128(buf: %sec, val: n_exts + n_funcs)
  return %sec
end

// ─── Memory Section ─────────────────────────────────────────────────────────

let build_memory_section = fn () -> %ByteBuffer do
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: 1)  // 1 memory
  let %sec = push_byte(buf: %sec, byte: 0) // no max
  let %sec = push_uleb128(buf: %sec, val: 17)  // 17 pages
  return %sec
end

// ─── Global Section ─────────────────────────────────────────────────────────

let build_global_section = fn (heap_base: i64) -> %ByteBuffer do
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: 1)    // 1 global
  let %sec = push_byte(buf: %sec, byte: vt_i32)  // type: i32
  let %sec = push_byte(buf: %sec, byte: 1)    // mutable
  let %sec = push_byte(buf: %sec, byte: op_i32_const)
  let %sec = push_sleb128(buf: %sec, val: heap_base)
  let %sec = push_byte(buf: %sec, byte: op_end)
  return %sec
end

// ─── Export Section ─────────────────────────────────────────────────────────

let build_export_section = fn (main_idx: i64, wasi_run_idx: i64, mem_mode: string) -> %ByteBuffer do
  let has_mem_export = mem_mode != "none"
  let mem_export_count = match has_mem_export do case true -> 1 case false -> 0 end
  let n_exports = 2 + mem_export_count
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: n_exports)
  // Export "main"
  let %sec = emit_name(buf: %sec, name: "main")
  let %sec = push_byte(buf: %sec, byte: desc_func)
  let %sec = push_uleb128(buf: %sec, val: main_idx)
  // Export "wasi:cli/run@0.2.6#run"
  let %sec = emit_name(buf: %sec, name: "wasi:cli/run@0.2.6#run")
  let %sec = push_byte(buf: %sec, byte: desc_func)
  let %sec = push_uleb128(buf: %sec, val: wasi_run_idx)
  // Export "memory"
  if has_mem_export then
    let %sec = emit_name(buf: %sec, name: "memory")
    let %sec = push_byte(buf: %sec, byte: desc_memory)
    let %sec = push_uleb128(buf: %sec, val: 0)
  end
  return %sec
end

// ─── Data Section ───────────────────────────────────────────────────────────

let emit_data_segments = fn (buf: %ByteBuffer, entries: [StringEntry]) -> %ByteBuffer do
  match entries do
    case Nil() -> return %buf
    case Cons(v: e, rest: rest) ->
      match e do case StringEntry(value: v, offset: off, slen: sl) ->
        let %buf = push_byte(buf: %buf, byte: 0) // active segment, memory 0
        let %buf = push_byte(buf: %buf, byte: op_i32_const)
        let %buf = push_sleb128(buf: %buf, val: off)
        let %buf = push_byte(buf: %buf, byte: op_end)
        let %buf = push_uleb128(buf: %buf, val: sl)
        let %buf = push_string(buf: %buf, s: v)
        return emit_data_segments(buf: %buf, entries: rest)
      end
  end
end

let build_data_section = fn (entries: [StringEntry]) -> %ByteBuffer do
  let n = list.length(xs: entries)
  let %sec = empty()
  let %sec = push_uleb128(buf: %sec, val: n)
  let %sec = emit_data_segments(buf: %sec, entries: entries)
  return %sec
end

// ─── Local Variable Collection ──────────────────────────────────────────────

let register_local = fn (name: string, typ: TypeExpr, locals: [LocalEntry], next_idx: i64)
    -> { locals: [LocalEntry], next_idx: i64 } do
  if is_unit(typ: typ) then
    return { locals: locals, next_idx: next_idx }
  end
  let existing = lookup_local(name: name, entries: locals)
  if existing >= 0 then
    return { locals: locals, next_idx: next_idx }
  else
    let vt = type_to_valtype(typ: typ)
    let entry = LocalEntry(name: name, index: next_idx, valtype: vt)
    return { locals: Cons(v: entry, rest: locals), next_idx: next_idx + 1 }
  end
end

let collect_local_stmts = fn (stmts: [LirStmt], locals: [LocalEntry], next_idx: i64)
    -> { locals: [LocalEntry], next_idx: i64 } do
  match stmts do
    case Nil() -> return { locals: locals, next_idx: next_idx }
    case Cons(v: s, rest: rest) ->
      let r = collect_local_stmt(stmt: s, locals: locals, next_idx: next_idx)
      return collect_local_stmts(stmts: rest, locals: r.locals, next_idx: r.next_idx)
  end
end

let collect_local_stmt = fn (stmt: LirStmt, locals: [LocalEntry], next_idx: i64)
    -> { locals: [LocalEntry], next_idx: i64 } do
  match stmt do
    case LirStmtLet(name: n, typ: t, expr: _) ->
      return register_local(name: n, typ: t, locals: locals, next_idx: next_idx)
    case LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
      let r = collect_local_stmts(stmts: tb, locals: locals, next_idx: next_idx)
      return collect_local_stmts(stmts: eb, locals: r.locals, next_idx: r.next_idx)
    case LirStmtIfReturn(cond: _, then_body: tb, then_ret: _, else_body: eb, else_ret: _, ret_type: _) ->
      let r = collect_local_stmts(stmts: tb, locals: locals, next_idx: next_idx)
      return collect_local_stmts(stmts: eb, locals: r.locals, next_idx: r.next_idx)
    case LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      let r = collect_local_stmts(stmts: cs, locals: locals, next_idx: next_idx)
      return collect_local_stmts(stmts: b, locals: r.locals, next_idx: r.next_idx)
    case LirStmtTryCatch(body: b, body_ret: _, catch_param: cp, catch_param_typ: cpt,
                          catch_body: cb, catch_ret: _) ->
      let r = register_local(name: cp, typ: cpt, locals: locals, next_idx: next_idx)
      let r2 = collect_local_stmts(stmts: b, locals: r.locals, next_idx: r.next_idx)
      return collect_local_stmts(stmts: cb, locals: r2.locals, next_idx: r2.next_idx)
  end
end

// ─── Atom Emission ──────────────────────────────────────────────────────────

let emit_atom = fn (atom: LirAtom, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer do
  match atom do
    case LirAtomVar(name: n, typ: _) ->
      let idx = lookup_local(name: n, entries: ctx_locals(ctx: ctx))
      // Guard: prevent invalid WASM from unresolved variables (9-byte LEB128)
      let safe_idx = match idx < 0 do case true -> 0 case false -> idx end
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: safe_idx)
      return %buf
    case LirAtomInt(val: v) ->
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: v)
      return %buf
    case LirAtomFloat(val: _) ->
      // TODO: f64 emission requires __nx_buf_push_f64_le FFI
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: 0)
      return %buf
    case LirAtomBool(val: bv) ->
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      let bool_val = match bv do case true -> 1 case false -> 0 end
      let %buf = push_sleb128(buf: %buf, val: bool_val)
      return %buf
    case LirAtomString(val: s) ->
      let packed = lookup_string(value: s, entries: ctx_string_lits(ctx: ctx))
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: packed)
      return %buf
    case LirAtomUnit -> return %buf
  end
end

// ─── Numeric Coercion ───────────────────────────────────────────────────────

// Coerce between WASM valtypes (raw i32/i64/f32/f64 values)
let emit_valtype_coercion = fn (from_vt: i64, to_vt: i64, buf: %ByteBuffer) -> %ByteBuffer do
  if from_vt == to_vt then return %buf
  else if from_vt == vt_i32 && to_vt == vt_i64 then
    return push_byte(buf: %buf, byte: op_i64_extend_i32_s)
  else if from_vt == vt_i64 && to_vt == vt_i32 then
    return push_byte(buf: %buf, byte: op_i32_wrap_i64)
  else return %buf
  end end end
end

let emit_coercion = fn (from_type: TypeExpr, to_type: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer do
  let f = peel_linear(typ: from_type)
  let t = peel_linear(typ: to_type)
  // Unit coercion is no-op
  match f do case TyUnit -> return %buf case _ ->
    match t do case TyUnit -> return %buf case _ ->
      // Same valtype => no-op
      let fv = type_to_valtype(typ: f)
      let tv = type_to_valtype(typ: t)
      if fv == tv then return %buf
      else
        // I64 -> I32 (wrap)
        if fv == vt_i64 && tv == vt_i32 then
          return push_byte(buf: %buf, byte: op_i32_wrap_i64)
        // I32 -> I64 (extend)
        else if fv == vt_i32 && tv == vt_i64 then
          return push_byte(buf: %buf, byte: op_i64_extend_i32_s)
        else return %buf
        end end
      end
    end
  end
end

// ─── Pack/Unpack for Object Fields ──────────────────────────────────────────

let emit_pack_to_i64 = fn (typ: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer do
  let t = peel_linear(typ: typ)
  match t do
    case TyI32 -> return push_byte(buf: %buf, byte: op_i64_extend_i32_s)
    case TyBool -> return push_byte(buf: %buf, byte: op_i64_extend_i32_s)
    case TyUnit ->
      let %buf = push_byte(buf: %buf, byte: op_drop)
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      return push_sleb128(buf: %buf, val: 0)
    case TyF64 -> return push_byte(buf: %buf, byte: op_i64_reinterpret_f64)
    case _ -> return %buf  // i64, string, objects already i64
  end
end

let emit_unpack_from_i64 = fn (typ: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer do
  let t = peel_linear(typ: typ)
  match t do
    case TyI32 -> return push_byte(buf: %buf, byte: op_i32_wrap_i64)
    case TyBool -> return push_byte(buf: %buf, byte: op_i32_wrap_i64)
    case TyF64 -> return push_byte(buf: %buf, byte: op_f64_reinterpret_i64)
    case _ -> return %buf
  end
end

// ─── Object Allocation ──────────────────────────────────────────────────────

let emit_alloc_object = fn (buf: %ByteBuffer, ctx: CodegenCtx, words: i64) -> %ByteBuffer do
  let obj_ptr_local = ctx_temps_base(ctx: ctx) + 3  // object_ptr_i32
  // global.get heap_ptr; local.tee obj_ptr; i32.const size; i32.add; global.set heap_ptr
  let %buf = push_byte(buf: %buf, byte: op_global_get)
  let %buf = push_uleb128(buf: %buf, val: heap_global_idx)
  let %buf = push_byte(buf: %buf, byte: op_local_tee)
  let %buf = push_uleb128(buf: %buf, val: obj_ptr_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: words * 8)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_global_set)
  let %buf = push_uleb128(buf: %buf, val: heap_global_idx)
  return %buf
end

// ─── String Concat Emission ─────────────────────────────────────────────────

let emit_string_concat = fn (lhs: LirAtom, rhs: LirAtom, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer do
  let t = ctx_temps_base(ctx: ctx)
  let lhs_packed = t + 4   // concat_lhs_packed_i64
  let rhs_packed = t + 5   // concat_rhs_packed_i64
  let lhs_ptr = t + 6      // concat_lhs_ptr_i32
  let lhs_len = t + 7      // concat_lhs_len_i32
  let rhs_ptr = t + 8      // concat_rhs_ptr_i32
  let rhs_len = t + 9      // concat_rhs_len_i32
  let out_ptr = t + 10     // concat_out_ptr_i32
  let out_len = t + 11     // concat_out_len_i32
  let idx_var = t + 12     // concat_idx_i32

  // Load lhs packed
  let %buf = emit_atom(atom: lhs, buf: %buf, ctx: ctx)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: lhs_packed)
  // Load rhs packed
  let %buf = emit_atom(atom: rhs, buf: %buf, ctx: ctx)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: rhs_packed)

  // Unpack lhs: ptr = packed >> 32, len = packed & 0xFFFFFFFF
  let %buf = emit_unpack_string(buf: %buf, packed_local: lhs_packed, ptr_local: lhs_ptr, len_local: lhs_len)
  let %buf = emit_unpack_string(buf: %buf, packed_local: rhs_packed, ptr_local: rhs_ptr, len_local: rhs_len)

  // out_len = lhs_len + rhs_len
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: lhs_len)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: rhs_len)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: out_len)

  // Allocate output on heap
  let %buf = push_byte(buf: %buf, byte: op_global_get)
  let %buf = push_uleb128(buf: %buf, val: heap_global_idx)
  let %buf = push_byte(buf: %buf, byte: op_local_tee)
  let %buf = push_uleb128(buf: %buf, val: out_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: out_len)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_global_set)
  let %buf = push_uleb128(buf: %buf, val: heap_global_idx)

  // Copy lhs bytes: loop { if idx >= lhs_len break; out[idx] = lhs[idx]; idx++ }
  let %buf = emit_memcpy_loop(buf: %buf, src_ptr: lhs_ptr, dst_ptr: out_ptr, dst_offset: -1,
                               len_local: lhs_len, idx_local: idx_var)

  // Copy rhs bytes: loop { if idx >= rhs_len break; out[lhs_len+idx] = rhs[idx]; idx++ }
  let %buf = emit_memcpy_loop_offset(buf: %buf, src_ptr: rhs_ptr, dst_ptr: out_ptr,
                                      offset_local: lhs_len, len_local: rhs_len, idx_local: idx_var)

  // Pack result: (out_ptr as i64) << 32 | (out_len as i64)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: out_ptr)
  let %buf = push_byte(buf: %buf, byte: op_i64_extend_i32_u)
  let %buf = push_byte(buf: %buf, byte: op_i64_const)
  let %buf = push_sleb128(buf: %buf, val: 32)
  let %buf = push_byte(buf: %buf, byte: op_i64_shl)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: out_len)
  let %buf = push_byte(buf: %buf, byte: op_i64_extend_i32_u)
  let %buf = push_byte(buf: %buf, byte: op_i64_or)
  return %buf
end

let emit_unpack_string = fn (buf: %ByteBuffer, packed_local: i64, ptr_local: i64, len_local: i64) -> %ByteBuffer do
  // ptr = (packed >>> 32) as i32  (unsigned shift)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: packed_local)
  let %buf = push_byte(buf: %buf, byte: op_i64_const)
  let %buf = push_sleb128(buf: %buf, val: 32)
  let %buf = push_byte(buf: %buf, byte: op_i64_shr_u)
  let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: ptr_local)
  // len = packed as i32 (low 32 bits)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: packed_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: len_local)
  return %buf
end

// Simple memcpy loop: copy src[0..len] to dst[0..len]
let emit_memcpy_loop = fn (buf: %ByteBuffer, src_ptr: i64, dst_ptr: i64, dst_offset: i64,
                            len_local: i64, idx_local: i64) -> %ByteBuffer do
  // idx = 0
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  // block { loop {
  let %buf = push_byte(buf: %buf, byte: op_block)
  let %buf = push_byte(buf: %buf, byte: bt_void)
  let %buf = push_byte(buf: %buf, byte: op_loop)
  let %buf = push_byte(buf: %buf, byte: bt_void)
  // if idx >= len, br 1 (break)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: len_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_ge_u)
  let %buf = push_byte(buf: %buf, byte: op_br_IF)
  let %buf = push_uleb128(buf: %buf, val: 1)
  // dst[idx] = src[idx]  (i32.store8)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: dst_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: src_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_i32_load8_U)
  let %buf = emit_memarg_i8(buf: %buf)
  let %buf = push_byte(buf: %buf, byte: op_i32_store8)
  let %buf = emit_memarg_i8(buf: %buf)
  // idx++
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  // br 0 (continue)
  let %buf = push_byte(buf: %buf, byte: op_br)
  let %buf = push_uleb128(buf: %buf, val: 0)
  // } end loop; } end block
  let %buf = push_byte(buf: %buf, byte: op_end)
  let %buf = push_byte(buf: %buf, byte: op_end)
  return %buf
end

// Memcpy with offset: copy src[0..len] to dst[offset..offset+len]
let emit_memcpy_loop_offset = fn (buf: %ByteBuffer, src_ptr: i64, dst_ptr: i64,
                                   offset_local: i64, len_local: i64, idx_local: i64) -> %ByteBuffer do
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_block)
  let %buf = push_byte(buf: %buf, byte: bt_void)
  let %buf = push_byte(buf: %buf, byte: op_loop)
  let %buf = push_byte(buf: %buf, byte: bt_void)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: len_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_ge_u)
  let %buf = push_byte(buf: %buf, byte: op_br_IF)
  let %buf = push_uleb128(buf: %buf, val: 1)
  // dst[offset + idx]
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: dst_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: offset_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  // src[idx]
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: src_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_i32_load8_U)
  let %buf = emit_memarg_i8(buf: %buf)
  let %buf = push_byte(buf: %buf, byte: op_i32_store8)
  let %buf = emit_memarg_i8(buf: %buf)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_local)
  let %buf = push_byte(buf: %buf, byte: op_br)
  let %buf = push_uleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_end)
  let %buf = push_byte(buf: %buf, byte: op_end)
  return %buf
end

// ─── String Compare Emission ────────────────────────────────────────────────

let is_string_op = fn (op: BinaryOp, lhs_type: TypeExpr, rhs_type: TypeExpr) -> bool do
  let lt = peel_linear(typ: lhs_type)
  let rt = peel_linear(typ: rhs_type)
  match lt do case TyString ->
    match rt do case TyString ->
      match op do
        case OpEq -> return true
        case OpNe -> return true
        case OpConcat -> return true
        case OpAdd -> return true
        case _ -> return false
      end
    case _ -> return false end
  case _ -> return false end
end

let is_string_concat_op = fn (op: BinaryOp, typ: TypeExpr) -> bool do
  let t = peel_linear(typ: typ)
  match t do case TyString ->
    match op do
      case OpConcat -> return true
      case OpAdd -> return true
      case _ -> return false
    end
  case _ -> return false end
end

let emit_string_compare = fn (op: BinaryOp, lhs: LirAtom, rhs: LirAtom,
                               buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer do
  let t = ctx_temps_base(ctx: ctx)
  let lhs_packed = t + 4
  let rhs_packed = t + 5
  let lhs_ptr = t + 6
  let lhs_len = t + 7
  let rhs_ptr = t + 8
  let rhs_len = t + 9
  let idx_var = t + 12

  let %buf = emit_atom(atom: lhs, buf: %buf, ctx: ctx)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: lhs_packed)
  let %buf = emit_atom(atom: rhs, buf: %buf, ctx: ctx)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: rhs_packed)

  let %buf = emit_unpack_string(buf: %buf, packed_local: lhs_packed, ptr_local: lhs_ptr, len_local: lhs_len)
  let %buf = emit_unpack_string(buf: %buf, packed_local: rhs_packed, ptr_local: rhs_ptr, len_local: rhs_len)

  // block $done (result i32) { block $not_equal {
  let %buf = push_byte(buf: %buf, byte: op_block)
  let %buf = push_byte(buf: %buf, byte: bt_i32)  // result i32
  let %buf = push_byte(buf: %buf, byte: op_block)
  let %buf = push_byte(buf: %buf, byte: bt_void)

  // Compare lengths
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: lhs_len)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: rhs_len)
  let %buf = push_byte(buf: %buf, byte: op_i32_ne)
  let %buf = push_byte(buf: %buf, byte: op_br_IF)
  let %buf = push_uleb128(buf: %buf, val: 0)  // br $not_equal

  // Byte comparison loop
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_block)
  let %buf = push_byte(buf: %buf, byte: bt_void)
  let %buf = push_byte(buf: %buf, byte: op_loop)
  let %buf = push_byte(buf: %buf, byte: bt_void)

  // if idx >= len break
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: lhs_len)
  let %buf = push_byte(buf: %buf, byte: op_i32_ge_u)
  let %buf = push_byte(buf: %buf, byte: op_br_IF)
  let %buf = push_uleb128(buf: %buf, val: 1)  // break inner block

  // Compare bytes
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: lhs_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_i32_load8_U)
  let %buf = emit_memarg_i8(buf: %buf)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: rhs_ptr)
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_i32_load8_U)
  let %buf = emit_memarg_i8(buf: %buf)
  let %buf = push_byte(buf: %buf, byte: op_i32_ne)
  let %buf = push_byte(buf: %buf, byte: op_br_IF)
  let %buf = push_uleb128(buf: %buf, val: 2)  // br $not_equal

  // idx++
  let %buf = push_byte(buf: %buf, byte: op_local_get)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: op_i32_add)
  let %buf = push_byte(buf: %buf, byte: op_local_set)
  let %buf = push_uleb128(buf: %buf, val: idx_var)
  let %buf = push_byte(buf: %buf, byte: op_br)
  let %buf = push_uleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_end)  // end loop
  let %buf = push_byte(buf: %buf, byte: op_end)  // end inner block

  // Equal: push 1, br $done
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 1)
  let %buf = push_byte(buf: %buf, byte: op_br)
  let %buf = push_uleb128(buf: %buf, val: 1)

  let %buf = push_byte(buf: %buf, byte: op_end)  // end $not_equal
  // Not equal: push 0
  let %buf = push_byte(buf: %buf, byte: op_i32_const)
  let %buf = push_sleb128(buf: %buf, val: 0)
  let %buf = push_byte(buf: %buf, byte: op_end)  // end $done

  // For Ne, invert
  let %buf = match op do
    case OpNe -> push_byte(buf: %buf, byte: op_i32_eqZ)
    case _ -> %buf
  end
  return %buf
end

// ─── Binary Operation Emission ──────────────────────────────────────────────

// Returns the expected WASM valtype for operands of a binary operator.
let binary_operand_valtype = fn (op: BinaryOp) -> i64 do
  match op do
    case OpAnd -> return vt_i32
    case OpOr -> return vt_i32
    case OpFAdd -> return vt_f64
    case OpFSub -> return vt_f64
    case OpFMul -> return vt_f64
    case OpFDiv -> return vt_f64
    case OpFEq -> return vt_f64
    case OpFNe -> return vt_f64
    case OpFLt -> return vt_f64
    case OpFLe -> return vt_f64
    case OpFGt -> return vt_f64
    case OpFGe -> return vt_f64
    case _ -> return vt_i64
  end
end

/// Returns the ACTUAL WASM valtype that a binary op pushes onto the stack.
/// Comparison and logical ops always produce i32, regardless of operand type.
let binary_result_valtype = fn (op: BinaryOp) -> i64 do
  match op do
    // Integer comparisons -> i32
    case OpEq -> return vt_i32
    case OpNe -> return vt_i32
    case OpLt -> return vt_i32
    case OpLe -> return vt_i32
    case OpGt -> return vt_i32
    case OpGe -> return vt_i32
    // Float comparisons -> i32
    case OpFEq -> return vt_i32
    case OpFNe -> return vt_i32
    case OpFLt -> return vt_i32
    case OpFLe -> return vt_i32
    case OpFGt -> return vt_i32
    case OpFGe -> return vt_i32
    // Logical -> i32
    case OpAnd -> return vt_i32
    case OpOr -> return vt_i32
    // Float arithmetic -> f64
    case OpFAdd -> return vt_f64
    case OpFSub -> return vt_f64
    case OpFMul -> return vt_f64
    case OpFDiv -> return vt_f64
    // Integer arithmetic -> i64
    case _ -> return vt_i64
  end
end

let emit_binary = fn (op: BinaryOp, buf: %ByteBuffer) -> %ByteBuffer do
  let opcode = match op do
    case OpAdd -> op_i64_add
    case OpSub -> op_i64_sub
    case OpMul -> op_i64_mul
    case OpDiv -> op_i64_div_s
    case OpMod -> op_i64_rem_s
    case OpFAdd -> op_f64_add
    case OpFSub -> op_f64_sub
    case OpFMul -> op_f64_mul
    case OpFDiv -> op_f64_div
    case OpEq -> op_i64_eq
    case OpNe -> op_i64_ne
    case OpLt -> op_i64_lt_s
    case OpLe -> op_i64_le_s
    case OpGt -> op_i64_gt_s
    case OpGe -> op_i64_ge_s
    case OpFEq -> op_f64_eq
    case OpFNe -> op_f64_ne
    case OpFLt -> op_f64_lt
    case OpFLe -> op_f64_le
    case OpFGt -> op_f64_gt
    case OpFGe -> op_f64_ge
    case OpBitAnd -> op_i64_and
    case OpBitOr -> op_i64_or
    case OpBitXor -> op_i64_xor
    case OpShl -> op_i64_shl
    case OpShr -> op_i64_shr_s
    case OpAnd -> op_i32_and
    case OpOr -> op_i32_or
    case _ -> op_i64_add  // fallback
  end
  return push_byte(buf: %buf, byte: opcode)
end

// ─── External Call Arg Emission ─────────────────────────────────────────────

let emit_external_arg = fn (atom: LirAtom, param_type: TypeExpr, buf: %ByteBuffer,
                             ctx: CodegenCtx) -> %ByteBuffer do
  let pt = peel_linear(typ: param_type)
  match pt do
    case TyString ->
      let packed_tmp = ctx_temps_base(ctx: ctx)  // packed_tmp_i64
      let %buf = emit_atom(atom: atom, buf: %buf, ctx: ctx)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      // ptr = packed >> 32
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: 32)
      let %buf = push_byte(buf: %buf, byte: op_i64_shr_s)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      // len = packed & 0xFFFFFFFF
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      return %buf
    case TyArray(elem: _) ->
      let packed_tmp = ctx_temps_base(ctx: ctx)
      let %buf = emit_atom(atom: atom, buf: %buf, ctx: ctx)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: 32)
      let %buf = push_byte(buf: %buf, byte: op_i64_shr_s)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: packed_tmp)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      return %buf
    case _ ->
      let %buf = emit_atom(atom: atom, buf: %buf, ctx: ctx)
      return emit_coercion(from_type: atom_type(atom: atom), to_type: param_type, buf: %buf)
  end
end

// ─── Expression Emission ────────────────────────────────────────────────────

let emit_expr = fn (expr: LirExpr, buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool) -> %ByteBuffer do
  match expr do
    case LirExprAtom(atom: a) ->
      return emit_atom(atom: a, buf: %buf, ctx: ctx)

    case LirExprBinary(op: op, lhs: l, rhs: r, typ: t) ->
      if is_string_concat_op(op: op, typ: t) then
        return emit_string_concat(lhs: l, rhs: r, buf: %buf, ctx: ctx)
      else if is_string_op(op: op, lhs_type: atom_type(atom: l), rhs_type: atom_type(atom: r)) then
        let %buf = emit_string_compare(op: op, lhs: l, rhs: r, buf: %buf, ctx: ctx)
        // String compare produces i32; coerce to target type if needed
        let target_vt = type_to_valtype(typ: t)
        return emit_valtype_coercion(from_vt: vt_i32, to_vt: target_vt, buf: %buf)
      else
        let expected_vt = binary_operand_valtype(op: op)
        let %buf = emit_atom(atom: l, buf: %buf, ctx: ctx)
        let lhs_vt = type_to_valtype(typ: atom_type(atom: l))
        let %buf = emit_valtype_coercion(from_vt: lhs_vt, to_vt: expected_vt, buf: %buf)
        let %buf = emit_atom(atom: r, buf: %buf, ctx: ctx)
        let rhs_vt = type_to_valtype(typ: atom_type(atom: r))
        let %buf = emit_valtype_coercion(from_vt: rhs_vt, to_vt: expected_vt, buf: %buf)
        let %buf = emit_binary(op: op, buf: %buf)
        // Coerce binary result to match the LIR expression's declared type.
        // Comparisons produce i32 but typ may expect i64.
        let result_vt = binary_result_valtype(op: op)
        let target_vt = type_to_valtype(typ: t)
        return emit_valtype_coercion(from_vt: result_vt, to_vt: target_vt, buf: %buf)
      end end

    case LirExprCall(func: fname, args: args, typ: _) ->
      return emit_call(func: fname, args: args, buf: %buf, ctx: ctx, is_tail: false, in_try: in_try)

    case LirExprTailCall(func: fname, args: args, typ: _) ->
      return emit_call(func: fname, args: args, buf: %buf, ctx: ctx, is_tail: true, in_try: in_try)

    case LirExprConstructor(name: cname, args: cargs, typ: _) ->
      let arity = list.length(xs: cargs)
      let tag = constructor_tag(name: cname, arity: arity)
      let %buf = emit_alloc_object(buf: %buf, ctx: ctx, words: 1 + arity)
      let obj_ptr = ctx_temps_base(ctx: ctx) + 3
      // Store tag at word 0
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: tag)
      let %buf = push_byte(buf: %buf, byte: op_i64_store)
      let %buf = emit_memarg_i64(buf: %buf, offset: 0)
      // Store fields
      let %buf = emit_constructor_fields(buf: %buf, args: cargs, ctx: ctx, obj_ptr: obj_ptr, field_idx: 1)
      // Push object pointer as i64
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_extend_i32_u)
      return %buf

    case LirExprRecord(fields: fields, typ: _) ->
      let names = extract_field_names(fields: fields)
      let sorted = names  // TODO: sort field names for record tag
      let tag = record_tag(sorted_names: sorted)
      let n_fields = list.length(xs: fields)
      let %buf = emit_alloc_object(buf: %buf, ctx: ctx, words: 1 + n_fields)
      let obj_ptr = ctx_temps_base(ctx: ctx) + 3
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_const)
      let %buf = push_sleb128(buf: %buf, val: tag)
      let %buf = push_byte(buf: %buf, byte: op_i64_store)
      let %buf = emit_memarg_i64(buf: %buf, offset: 0)
      let %buf = emit_record_fields(buf: %buf, fields: fields, ctx: ctx, obj_ptr: obj_ptr, field_idx: 1)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_extend_i32_u)
      return %buf

    case LirExprObjectTag(value: v, typ: _) ->
      let obj_ptr = ctx_temps_base(ctx: ctx) + 3
      let %buf = emit_atom(atom: v, buf: %buf, ctx: ctx)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_load)
      let %buf = emit_memarg_i64(buf: %buf, offset: 0)
      return %buf

    case LirExprObjectField(value: v, index: idx, typ: ftyp) ->
      let obj_ptr = ctx_temps_base(ctx: ctx) + 3
      let %buf = emit_atom(atom: v, buf: %buf, ctx: ctx)
      let %buf = push_byte(buf: %buf, byte: op_i32_wrap_i64)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = push_byte(buf: %buf, byte: op_i64_load)
      let %buf = emit_memarg_i64(buf: %buf, offset: (idx + 1) * 8)
      let %buf = emit_unpack_from_i64(typ: ftyp, buf: %buf)
      return %buf

    case LirExprRaise(value: v, typ: _) ->
      let exn_value = ctx_temps_base(ctx: ctx) + 1  // exn_value_i64
      let exn_flag = ctx_temps_base(ctx: ctx) + 2   // exn_flag_i32
      let %buf = emit_atom(atom: v, buf: %buf, ctx: ctx)
      let at = atom_type(atom: v)
      if is_unit(typ: at) then
        let %buf = push_byte(buf: %buf, byte: op_i64_const)
        let %buf = push_sleb128(buf: %buf, val: 0)
      end
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: exn_value)
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      let %buf = push_sleb128(buf: %buf, val: 1)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: exn_flag)
      if in_try == false then
        let %buf = push_byte(buf: %buf, byte: op_unreachable)
      end
      return %buf
  end
end

let emit_call = fn (func: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx,
                     is_tail: bool, in_try: bool) -> %ByteBuffer do
  let int_idx = lookup_func(name: func, entries: ctx_internal_funcs(ctx: ctx))
  if int_idx >= 0 then
    // Internal call — exact match
    let callee = find_function(name: func, funcs: ctx_functions(ctx: ctx))
    match callee do
      case Some(val: f) ->
        match f do case LirFunction(name: _, params: params, ret_type: _, body: _, ret: _, span: _) ->
          let %buf = emit_internal_call_args(buf: %buf, args: args, params: params, ctx: ctx)
          let use_tail = is_tail && (in_try == false)
          let call_op = match use_tail do case true -> op_return_CALL case false -> op_call end
          let %buf = push_byte(buf: %buf, byte: call_op)
          let %buf = push_uleb128(buf: %buf, val: int_idx)
          return %buf
        end
      case None() ->
        // Should not happen
        let %buf = push_byte(buf: %buf, byte: op_unreachable)
        return %buf
    end
  else
    let ext_idx = lookup_func(name: func, entries: ctx_external_funcs(ctx: ctx))
    if ext_idx >= 0 then
      let ext = find_external(name: func, exts: ctx_externals(ctx: ctx))
      match ext do
        case Some(val: e) ->
          match e do case LirExternal(name: _, wasm_module: _, wasm_name: _, params: params, ret_type: _, throw_row: _) ->
            let %buf = emit_external_call_args(buf: %buf, args: args, params: params, ctx: ctx)
            let %buf = push_byte(buf: %buf, byte: op_call)
            let %buf = push_uleb128(buf: %buf, val: ext_idx)
            return %buf
          end
        case None() ->
          let %buf = push_byte(buf: %buf, byte: op_unreachable)
          return %buf
      end
    else
      // Exact match failed — try fuzzy lookup by base name (handles __import_N. prefix mismatch)
      let base = extract_base_name(name: func)
      let fuzzy_int_idx = lookup_func_by_base(base: base, entries: ctx_internal_funcs(ctx: ctx))
      if fuzzy_int_idx >= 0 then
        let fuzzy_callee = find_function_by_base(base: base, funcs: ctx_functions(ctx: ctx))
        match fuzzy_callee do
          case Some(val: f) ->
            match f do case LirFunction(name: _, params: params, ret_type: _, body: _, ret: _, span: _) ->
              let %buf = emit_internal_call_args(buf: %buf, args: args, params: params, ctx: ctx)
              let use_tail = is_tail && (in_try == false)
              let call_op = match use_tail do case true -> op_return_CALL case false -> op_call end
              let %buf = push_byte(buf: %buf, byte: call_op)
              let %buf = push_uleb128(buf: %buf, val: fuzzy_int_idx)
              return %buf
            end
          case None() ->
            let %buf = push_byte(buf: %buf, byte: op_unreachable)
            return %buf
        end
      else
        // Unknown function — emit unreachable to prevent invalid dead code
        let %buf = push_byte(buf: %buf, byte: op_unreachable)
        return %buf
      end
    end
  end
  return %buf
end

let emit_internal_call_args = fn (buf: %ByteBuffer, args: [LirCallArg], params: [LirParam],
                                   ctx: CodegenCtx) -> %ByteBuffer do
  match args do
    case Nil() -> return %buf
    case Cons(v: arg, rest: rest_args) ->
      match arg do case LirCallArg(label: _, value: v) ->
        match params do
          case Nil() -> return %buf
          case Cons(v: p, rest: rest_params) ->
            match p do case LirParam(label: _, name: _, typ: pt) ->
              let %buf = emit_atom(atom: v, buf: %buf, ctx: ctx)
              let %buf = emit_coercion(from_type: atom_type(atom: v), to_type: pt, buf: %buf)
              return emit_internal_call_args(buf: %buf, args: rest_args, params: rest_params, ctx: ctx)
            end
        end
      end
  end
end

let emit_external_call_args = fn (buf: %ByteBuffer, args: [LirCallArg], params: [LirParam],
                                   ctx: CodegenCtx) -> %ByteBuffer do
  match args do
    case Nil() -> return %buf
    case Cons(v: arg, rest: rest_args) ->
      match arg do case LirCallArg(label: _, value: v) ->
        match params do
          case Nil() -> return %buf
          case Cons(v: p, rest: rest_params) ->
            match p do case LirParam(label: _, name: _, typ: pt) ->
              let %buf = emit_external_arg(atom: v, param_type: pt, buf: %buf, ctx: ctx)
              return emit_external_call_args(buf: %buf, args: rest_args, params: rest_params, ctx: ctx)
            end
        end
      end
  end
end

let emit_constructor_fields = fn (buf: %ByteBuffer, args: [LirAtom], ctx: CodegenCtx,
                                   obj_ptr: i64, field_idx: i64) -> %ByteBuffer do
  match args do
    case Nil() -> return %buf
    case Cons(v: a, rest: rest) ->
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = emit_atom(atom: a, buf: %buf, ctx: ctx)
      let %buf = emit_pack_to_i64(typ: atom_type(atom: a), buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_i64_store)
      let %buf = emit_memarg_i64(buf: %buf, offset: field_idx * 8)
      return emit_constructor_fields(buf: %buf, args: rest, ctx: ctx, obj_ptr: obj_ptr, field_idx: field_idx + 1)
  end
end

let emit_record_fields = fn (buf: %ByteBuffer, fields: [LirNamedAtom], ctx: CodegenCtx,
                              obj_ptr: i64, field_idx: i64) -> %ByteBuffer do
  match fields do
    case Nil() -> return %buf
    case Cons(v: f, rest: rest) ->
      match f do case LirNamedAtom(name: _, value: v) ->
        let %buf = push_byte(buf: %buf, byte: op_local_get)
        let %buf = push_uleb128(buf: %buf, val: obj_ptr)
        let %buf = emit_atom(atom: v, buf: %buf, ctx: ctx)
        let %buf = emit_pack_to_i64(typ: atom_type(atom: v), buf: %buf)
        let %buf = push_byte(buf: %buf, byte: op_i64_store)
        let %buf = emit_memarg_i64(buf: %buf, offset: field_idx * 8)
        return emit_record_fields(buf: %buf, fields: rest, ctx: ctx, obj_ptr: obj_ptr, field_idx: field_idx + 1)
      end
  end
end

let extract_field_names = fn (fields: [LirNamedAtom]) -> [string] do
  match fields do
    case Nil() -> return Nil()
    case Cons(v: f, rest: rest) ->
      match f do case LirNamedAtom(name: n, value: _) ->
        return Cons(v: n, rest: extract_field_names(fields: rest))
      end
  end
end

// ─── Statement Emission ─────────────────────────────────────────────────────

let emit_optional_else_ret = fn (buf: %ByteBuffer, er: Option<LirAtom>, rt: TypeExpr, ctx: CodegenCtx) -> %ByteBuffer do
  match er do
    case Some(val: a) ->
      let %buf = emit_atom(atom: a, buf: %buf, ctx: ctx)
      let %buf = emit_coercion(from_type: atom_type(atom: a), to_type: rt, buf: %buf)
      return push_byte(buf: %buf, byte: op_return)
    case None() -> return %buf
  end
end

let emit_stmt = fn (stmt: LirStmt, buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool) -> %ByteBuffer do
  match stmt do
    case LirStmtLet(name: n, typ: t, expr: e) ->
      let %buf = emit_expr(expr: e, buf: %buf, ctx: ctx, in_try: in_try)
      let et = expr_type(expr: e)
      if is_unit(typ: t) then
        if is_unit(typ: et) == false then
          return push_byte(buf: %buf, byte: op_drop)
        else return %buf end
      else
        if is_unit(typ: et) then
          // Expression pushed nothing but we need a value for local.set.
          // Push a zero constant matching the target WASM type.
          let vt = type_to_valtype(typ: t)
          if vt == vt_i32 then
            let %buf = push_byte(buf: %buf, byte: op_i32_const)
            let %buf = push_sleb128(buf: %buf, val: 0)
            let idx = lookup_local(name: n, entries: ctx_locals(ctx: ctx))
            let safe_idx = match idx < 0 do case true -> 0 case false -> idx end
            let %buf = push_byte(buf: %buf, byte: op_local_set)
            let %buf = push_uleb128(buf: %buf, val: safe_idx)
            return %buf
          else
            let %buf = push_byte(buf: %buf, byte: op_i64_const)
            let %buf = push_sleb128(buf: %buf, val: 0)
            let idx = lookup_local(name: n, entries: ctx_locals(ctx: ctx))
            let safe_idx = match idx < 0 do case true -> 0 case false -> idx end
            let %buf = push_byte(buf: %buf, byte: op_local_set)
            let %buf = push_uleb128(buf: %buf, val: safe_idx)
            return %buf
          end
        else
          let %buf = emit_coercion(from_type: et, to_type: t, buf: %buf)
          let idx = lookup_local(name: n, entries: ctx_locals(ctx: ctx))
          let safe_idx = match idx < 0 do case true -> 0 case false -> idx end
          let %buf = push_byte(buf: %buf, byte: op_local_set)
          let %buf = push_uleb128(buf: %buf, val: safe_idx)
          return %buf
        end
      end
      return %buf

    case LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let %buf = emit_atom(atom: c, buf: %buf, ctx: ctx)
      let %buf = emit_coercion(from_type: atom_type(atom: c), to_type: TyBool, buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_if)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      let %buf = emit_stmts(stmts: tb, buf: %buf, ctx: ctx, in_try: in_try)
      let %buf = push_byte(buf: %buf, byte: op_else)
      let %buf = emit_stmts(stmts: eb, buf: %buf, ctx: ctx, in_try: in_try)
      let %buf = push_byte(buf: %buf, byte: op_end)
      return %buf

    case LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr, else_body: eb, else_ret: er, ret_type: rt) ->
      let %buf = emit_atom(atom: c, buf: %buf, ctx: ctx)
      let %buf = emit_coercion(from_type: atom_type(atom: c), to_type: TyBool, buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_if)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      let %buf = emit_stmts(stmts: tb, buf: %buf, ctx: ctx, in_try: in_try)
      let %buf = emit_atom(atom: tr, buf: %buf, ctx: ctx)
      let %buf = emit_coercion(from_type: atom_type(atom: tr), to_type: rt, buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_return)
      let %buf = push_byte(buf: %buf, byte: op_else)
      let %buf = emit_stmts(stmts: eb, buf: %buf, ctx: ctx, in_try: in_try)
      let %buf = emit_optional_else_ret(buf: %buf, er: er, rt: rt, ctx: ctx)
      let %buf = push_byte(buf: %buf, byte: op_end)
      // Both branches return, so code after this if-else is unreachable.
      // Emit unreachable to prevent WASM validation errors from dead code.
      let %buf = push_byte(buf: %buf, byte: op_unreachable)
      return %buf

    case LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      // block { loop { cond_stmts; cond; br_if 1; body; br 0 } }
      let %buf = push_byte(buf: %buf, byte: op_block)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      let %buf = push_byte(buf: %buf, byte: op_loop)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      let %buf = emit_stmts(stmts: cs, buf: %buf, ctx: ctx, in_try: in_try)
      let %buf = emit_atom(atom: c, buf: %buf, ctx: ctx)
      let %buf = emit_coercion(from_type: atom_type(atom: c), to_type: TyBool, buf: %buf)
      let %buf = push_byte(buf: %buf, byte: op_br_IF)
      let %buf = push_uleb128(buf: %buf, val: 1)  // break outer block
      let %buf = emit_stmts(stmts: b, buf: %buf, ctx: ctx, in_try: in_try)
      let %buf = push_byte(buf: %buf, byte: op_br)
      let %buf = push_uleb128(buf: %buf, val: 0)  // continue loop
      let %buf = push_byte(buf: %buf, byte: op_end)  // end loop
      let %buf = push_byte(buf: %buf, byte: op_end)  // end block
      return %buf

    case LirStmtTryCatch(body: b, body_ret: br, catch_param: cp, catch_param_typ: _,
                          catch_body: cb, catch_ret: cr) ->
      let exn_value = ctx_temps_base(ctx: ctx) + 1
      let exn_flag = ctx_temps_base(ctx: ctx) + 2
      let catch_local_raw = lookup_local(name: cp, entries: ctx_locals(ctx: ctx))
      let catch_local_idx = match catch_local_raw < 0 do case true -> 0 case false -> catch_local_raw end

      // exn_flag = 0
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      let %buf = push_sleb128(buf: %buf, val: 0)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: exn_flag)

      // block { body...; if exn_flag br 0 after each stmt }
      let %buf = push_byte(buf: %buf, byte: op_block)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      let %buf = emit_try_body_stmts(stmts: b, buf: %buf, ctx: ctx, exn_flag: exn_flag)
      // body_ret
      let %buf = match br do
        case Some(val: a) ->
          let %b = emit_atom(atom: a, buf: %buf, ctx: ctx)
          let %b = emit_coercion(from_type: atom_type(atom: a), to_type: ctx_func_ret_type(ctx: ctx), buf: %b)
          push_byte(buf: %b, byte: op_return)
        case None() -> %buf
      end
      let %buf = push_byte(buf: %buf, byte: op_end)  // end block

      // if exn_flag { catch_param = exn_value; exn_flag = 0; catch_body... }
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: exn_flag)
      let %buf = push_byte(buf: %buf, byte: op_if)
      let %buf = push_byte(buf: %buf, byte: bt_void)
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: exn_value)
      if catch_local_idx >= 0 then
        let %buf = push_byte(buf: %buf, byte: op_local_set)
        let %buf = push_uleb128(buf: %buf, val: catch_local_idx)
      end
      // Reset flag
      let %buf = push_byte(buf: %buf, byte: op_i32_const)
      let %buf = push_sleb128(buf: %buf, val: 0)
      let %buf = push_byte(buf: %buf, byte: op_local_set)
      let %buf = push_uleb128(buf: %buf, val: exn_flag)

      // If in outer try, wrap catch body in block too
      if in_try then
        let %buf = push_byte(buf: %buf, byte: op_block)
        let %buf = push_byte(buf: %buf, byte: bt_void)
      end
      let %buf = emit_try_catch_body_stmts(stmts: cb, buf: %buf, ctx: ctx,
                                             exn_flag: exn_flag, in_try: in_try)
      let %buf = match cr do
        case Some(val: a) ->
          let %b = emit_atom(atom: a, buf: %buf, ctx: ctx)
          let %b = emit_coercion(from_type: atom_type(atom: a), to_type: ctx_func_ret_type(ctx: ctx), buf: %b)
          push_byte(buf: %b, byte: op_return)
        case None() -> %buf
      end
      if in_try then
        let %buf = push_byte(buf: %buf, byte: op_end)  // end inner block
      end
      let %buf = push_byte(buf: %buf, byte: op_end)  // end if
      return %buf
  end
end

let emit_stmts = fn (stmts: [LirStmt], buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool) -> %ByteBuffer do
  match stmts do
    case Nil() -> return %buf
    case Cons(v: s, rest: rest) ->
      let %buf = emit_stmt(stmt: s, buf: %buf, ctx: ctx, in_try: in_try)
      return emit_stmts(stmts: rest, buf: %buf, ctx: ctx, in_try: in_try)
  end
end

let emit_try_body_stmts = fn (stmts: [LirStmt], buf: %ByteBuffer, ctx: CodegenCtx,
                               exn_flag: i64) -> %ByteBuffer do
  match stmts do
    case Nil() -> return %buf
    case Cons(v: s, rest: rest) ->
      let %buf = emit_stmt(stmt: s, buf: %buf, ctx: ctx, in_try: true)
      // Check exn_flag after each stmt; br if set
      let %buf = push_byte(buf: %buf, byte: op_local_get)
      let %buf = push_uleb128(buf: %buf, val: exn_flag)
      let %buf = push_byte(buf: %buf, byte: op_br_IF)
      let %buf = push_uleb128(buf: %buf, val: 0)
      return emit_try_body_stmts(stmts: rest, buf: %buf, ctx: ctx, exn_flag: exn_flag)
  end
end

let emit_try_catch_body_stmts = fn (stmts: [LirStmt], buf: %ByteBuffer, ctx: CodegenCtx,
                                     exn_flag: i64, in_try: bool) -> %ByteBuffer do
  match stmts do
    case Nil() -> return %buf
    case Cons(v: s, rest: rest) ->
      let %buf = emit_stmt(stmt: s, buf: %buf, ctx: ctx, in_try: in_try)
      if in_try then
        let %buf = push_byte(buf: %buf, byte: op_local_get)
        let %buf = push_uleb128(buf: %buf, val: exn_flag)
        let %buf = push_byte(buf: %buf, byte: op_br_IF)
        let %buf = push_uleb128(buf: %buf, val: 0)
      end
      return emit_try_catch_body_stmts(stmts: rest, buf: %buf, ctx: ctx,
                                        exn_flag: exn_flag, in_try: in_try)
  end
end

// ─── Function Body Compilation ──────────────────────────────────────────────

// Sort locals by index so WASM declaration order matches registered indices.
// register_local assigns sequential indices but Cons prepends, reversing the list.
let sort_locals_by_index = fn (locals: [LocalEntry]) -> [LocalEntry] do
  return sort_locals_insert(sorted: Nil(), remaining: locals)
end

let sort_locals_insert = fn (sorted: [LocalEntry], remaining: [LocalEntry]) -> [LocalEntry] do
  match remaining do
    case Nil() -> return sorted
    case Cons(v: e, rest: rest) ->
      return sort_locals_insert(sorted: insert_local_sorted(entry: e, into: sorted), remaining: rest)
  end
end

let insert_local_sorted = fn (entry: LocalEntry, into: [LocalEntry]) -> [LocalEntry] do
  match entry do case LocalEntry(name: _, index: ei, valtype: _) ->
    match into do
      case Nil() -> return Cons(v: entry, rest: Nil())
      case Cons(v: head, rest: tail) ->
        match head do case LocalEntry(name: _, index: hi, valtype: _) ->
          if ei <= hi then
            return Cons(v: entry, rest: into)
          else
            return Cons(v: head, rest: insert_local_sorted(entry: entry, into: tail))
          end
        end
    end
  end
end

let emit_local_decls = fn (buf: %ByteBuffer, locals: [LocalEntry], param_count: i64) -> %ByteBuffer do
  // Filter out params (indices < param_count) and count non-param locals
  let non_param = count_non_param_locals(locals: locals, param_count: param_count)
  // Add 13 reserved temp locals
  let total_groups = non_param + 13
  // Sort locals by index so declaration order matches registered indices
  let sorted = sort_locals_by_index(locals: locals)
  // For simplicity, emit each local as a separate group (count=1, type)
  // This is valid WASM, just slightly less compact
  let %buf = push_uleb128(buf: %buf, val: count_local_groups(locals: locals, param_count: param_count))
  let %buf = emit_local_entries(buf: %buf, locals: sorted, param_count: param_count)
  // Reserved temps: 2x i64, 1x i32, 1x i32, 2x i64, 7x i32
  let %buf = push_uleb128(buf: %buf, val: 2)
  let %buf = push_byte(buf: %buf, byte: vt_i64)
  let %buf = push_uleb128(buf: %buf, val: 2)
  let %buf = push_byte(buf: %buf, byte: vt_i32)
  let %buf = push_uleb128(buf: %buf, val: 2)
  let %buf = push_byte(buf: %buf, byte: vt_i64)
  let %buf = push_uleb128(buf: %buf, val: 7)
  let %buf = push_byte(buf: %buf, byte: vt_i32)
  return %buf
end

let count_non_param_locals = fn (locals: [LocalEntry], param_count: i64) -> i64 do
  match locals do
    case Nil() -> return 0
    case Cons(v: e, rest: rest) ->
      match e do case LocalEntry(name: _, index: idx, valtype: _) ->
        if idx >= param_count then
          return 1 + count_non_param_locals(locals: rest, param_count: param_count)
        else
          return count_non_param_locals(locals: rest, param_count: param_count)
        end
      end
  end
end

// Count number of local declaration groups (non-param locals, grouped by type)
// For simplicity, each non-param local is its own group
let count_local_groups = fn (locals: [LocalEntry], param_count: i64) -> i64 do
  let n = count_non_param_locals(locals: locals, param_count: param_count)
  // n individual groups + 4 groups for temps (2 i64, 2 i32, 2 i64, 7 i32)
  return n + 4
end

let emit_local_entries = fn (buf: %ByteBuffer, locals: [LocalEntry], param_count: i64) -> %ByteBuffer do
  match locals do
    case Nil() -> return %buf
    case Cons(v: e, rest: rest) ->
      match e do case LocalEntry(name: _, index: idx, valtype: vt) ->
        if idx >= param_count then
          let %buf = push_uleb128(buf: %buf, val: 1)
          let %buf = push_byte(buf: %buf, byte: vt)
          return emit_local_entries(buf: %buf, locals: rest, param_count: param_count)
        else
          return emit_local_entries(buf: %buf, locals: rest, param_count: param_count)
        end
      end
  end
end

let compile_function_body = fn (func: LirFunction, ctx: CodegenCtx) -> %ByteBuffer do
  match func do case LirFunction(name: _, params: ps, ret_type: rt, body: b, ret: r, span: _) ->
    let param_count = list.length(xs: ps)
    let %body = empty()
    let %body = emit_local_decls(buf: %body, locals: ctx_locals(ctx: ctx), param_count: param_count)
    let %body = emit_stmts(stmts: b, buf: %body, ctx: ctx, in_try: false)
    // Emit return value
    if is_unit(typ: rt) == false then
      let %body = emit_atom(atom: r, buf: %body, ctx: ctx)
      let %body = emit_coercion(from_type: atom_type(atom: r), to_type: rt, buf: %body)
    end
    let %body = push_byte(buf: %body, byte: op_end)
    return %body
  end
end

// WASI CLI run wrapper: calls main, drops result if non-unit, returns i32 0
// If main takes args (i64 parameter), allocate a Nil() list on the heap and push it.
let compile_wasi_run_wrapper = fn (main_idx: i64, main_ret_type: TypeExpr,
                                    main_has_args: bool) -> %ByteBuffer do
  let %body = empty()
  if main_has_args then
    // 1 local (i32) for Nil object pointer
    let %body = push_uleb128(buf: %body, val: 1)
    let %body = push_uleb128(buf: %body, val: 1)
    let %body = push_byte(buf: %body, byte: vt_i32)
    // Allocate Nil() on heap: global.get 0; local.tee 0; i32.const 8; i32.add; global.set 0
    let nil_tag = constructor_tag(name: "Nil", arity: 0)
    let %body = push_byte(buf: %body, byte: op_global_get)
    let %body = push_uleb128(buf: %body, val: heap_global_idx)
    let %body = push_byte(buf: %body, byte: op_local_tee)
    let %body = push_uleb128(buf: %body, val: 0)
    let %body = push_byte(buf: %body, byte: op_i32_const)
    let %body = push_sleb128(buf: %body, val: 8)
    let %body = push_byte(buf: %body, byte: op_i32_add)
    let %body = push_byte(buf: %body, byte: op_global_set)
    let %body = push_uleb128(buf: %body, val: heap_global_idx)
    // Store Nil tag at offset 0
    let %body = push_byte(buf: %body, byte: op_local_get)
    let %body = push_uleb128(buf: %body, val: 0)
    let %body = push_byte(buf: %body, byte: op_i64_const)
    let %body = push_sleb128(buf: %body, val: nil_tag)
    let %body = push_byte(buf: %body, byte: op_i64_store)
    let %body = emit_memarg_i64(buf: %body, offset: 0)
    // Push pointer as i64 for main's args parameter
    let %body = push_byte(buf: %body, byte: op_local_get)
    let %body = push_uleb128(buf: %body, val: 0)
    let %body = push_byte(buf: %body, byte: op_i64_extend_i32_u)
  else
    // 0 locals
    let %body = push_uleb128(buf: %body, val: 0)
  end
  // call main
  let %body = push_byte(buf: %body, byte: op_call)
  let %body = push_uleb128(buf: %body, val: main_idx)
  if is_unit(typ: main_ret_type) == false then
    let %body = push_byte(buf: %body, byte: op_drop)
  end
  let %body = push_byte(buf: %body, byte: op_i32_const)
  let %body = push_sleb128(buf: %body, val: 0)
  let %body = push_byte(buf: %body, byte: op_end)
  return %body
end

// ─── Code Section ───────────────────────────────────────────────────────────

let build_func_ctx = fn (func: LirFunction, internal_funcs: [FuncEntry],
                          external_funcs: [FuncEntry], string_lits: [StringEntry],
                          heap_enabled: bool, functions: [LirFunction],
                          externals: [LirExternal]) -> CodegenCtx do
  match func do case LirFunction(name: _, params: ps, ret_type: rt, body: b, ret: _, span: _) ->
    // Build param locals
    let param_locals = build_param_locals(params: ps, idx: 0)
    let param_count = list.length(xs: ps)
    // Collect body locals
    let r = collect_local_stmts(stmts: b, locals: param_locals, next_idx: param_count)
    let temps_base = r.next_idx
    return CodegenCtx(
      locals: r.locals,
      internal_funcs: internal_funcs,
      external_funcs: external_funcs,
      string_lits: string_lits,
      heap_enabled: heap_enabled,
      temps_base: temps_base,
      func_ret_type: rt,
      functions: functions,
      externals: externals
    )
  end
end

let build_param_locals = fn (params: [LirParam], idx: i64) -> [LocalEntry] do
  match params do
    case Nil() -> return Nil()
    case Cons(v: p, rest: rest) ->
      match p do case LirParam(label: _, name: n, typ: t) ->
        let vt = type_to_valtype(typ: t)
        let entry = LocalEntry(name: n, index: idx, valtype: vt)
        return Cons(v: entry, rest: build_param_locals(params: rest, idx: idx + 1))
      end
  end
end

let emit_code_bodies = fn (buf: %ByteBuffer, funcs: [LirFunction],
                            internal_funcs: [FuncEntry], external_funcs: [FuncEntry],
                            string_lits: [StringEntry], heap_enabled: bool,
                            functions: [LirFunction], externals: [LirExternal]) -> %ByteBuffer do
  match funcs do
    case Nil() -> return %buf
    case Cons(v: f, rest: rest) ->
      let ctx = build_func_ctx(func: f, internal_funcs: internal_funcs,
                                external_funcs: external_funcs, string_lits: string_lits,
                                heap_enabled: heap_enabled, functions: functions,
                                externals: externals)
      let %body = compile_function_body(func: f, ctx: ctx)
      let body_len = bb.length(buf: &body)
      let %buf = push_uleb128(buf: %buf, val: body_len)
      let %buf = push_buf(dst: %buf, src: &body)
      free(buf: %body)
      return emit_code_bodies(buf: %buf, funcs: rest, internal_funcs: internal_funcs,
                               external_funcs: external_funcs, string_lits: string_lits,
                               heap_enabled: heap_enabled, functions: functions,
                               externals: externals)
  end
end

// ─── Module Assembly ────────────────────────────────────────────────────────

let build_internal_func_entries = fn (funcs: [LirFunction], import_count: i64, idx: i64) -> [FuncEntry] do
  match funcs do
    case Nil() -> return Nil()
    case Cons(v: f, rest: rest) ->
      match f do case LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) ->
        let entry = FuncEntry(name: n, index: import_count + idx)
        return Cons(v: entry, rest: build_internal_func_entries(funcs: rest, import_count: import_count, idx: idx + 1))
      end
  end
end

let build_external_func_entries = fn (exts: [LirExternal], idx: i64) -> [FuncEntry] do
  match exts do
    case Nil() -> return Nil()
    case Cons(v: e, rest: rest) ->
      match e do case LirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) ->
        let entry = FuncEntry(name: n, index: idx)
        return Cons(v: entry, rest: build_external_func_entries(exts: rest, idx: idx + 1))
      end
  end
end

pub let compile_lir_to_wasm = fn (program: LirProgram) -> %ByteBuffer do
  match program do case LirProgram(functions: funcs, externals: exts) ->
    let n_exts = list.length(xs: exts)
    let n_funcs = list.length(xs: funcs)
    let import_count = n_exts

    // Build function index maps
    let internal_funcs = build_internal_func_entries(funcs: funcs, import_count: import_count, idx: 0)
    let external_funcs = build_external_func_entries(exts: exts, idx: 0)

    // Find main function index
    let main_idx = lookup_func(name: "main", entries: internal_funcs)
    let main_func = find_function(name: "main", funcs: funcs)
    let main_ret = match main_func do
      case Some(val: f) ->
        match f do case LirFunction(name: _, params: _, ret_type: rt, body: _, ret: _, span: _) -> rt end
      case None() -> TyUnit
    end
    let main_has_args = match main_func do
      case Some(val: f) ->
        match f do case LirFunction(name: _, params: ps, ret_type: _, body: _, ret: _, span: _) ->
          list.length(xs: ps) > 0
        end
      case None() -> false
    end

    // Collect string literals
    let all_strings = collect_program_strings(funcs: funcs, acc: Nil())
    let string_entries = build_string_entries(strings: all_strings, next_offset: string_data_base, acc: Nil())
    let has_strings = list.length(xs: string_entries) > 0

    // Determine memory mode and heap
    let heap_enabled = program_uses_heap(funcs: funcs)
    let mem_mode = choose_memory_mode(externals: exts, has_strings: has_strings, has_heap: heap_enabled)

    // Compute heap base
    let last_string_end = compute_last_string_end(entries: string_entries)
    let heap_base_raw = match last_string_end > string_data_base do case true -> last_string_end case false -> string_data_base end
    let heap_base = align8(v: heap_base_raw)

    // WASI CLI run function index
    let wasi_run_idx = import_count + n_funcs

    // ── Build module ──
    let %mod = empty()

    // Magic + version
    let %mod = push_byte(buf: %mod, byte: 0)
    let %mod = push_byte(buf: %mod, byte: 97)
    let %mod = push_byte(buf: %mod, byte: 115)
    let %mod = push_byte(buf: %mod, byte: 109)
    let %mod = push_byte(buf: %mod, byte: 1)
    let %mod = push_byte(buf: %mod, byte: 0)
    let %mod = push_byte(buf: %mod, byte: 0)
    let %mod = push_byte(buf: %mod, byte: 0)

    // Type section
    let %type_sec = build_type_section(program: program)
    let %mod = emit_section(buf: %mod, id: sec_type, content: %type_sec)

    // Import section
    let has_imports = n_exts > 0 || (mem_mode != "none" && mem_mode != "defined")
    if has_imports then
      let %imp_sec = build_import_section(exts: exts, mem_mode: mem_mode)
      let %mod = emit_section(buf: %mod, id: sec_import, content: %imp_sec)
    end

    // Function section
    let %func_sec = build_function_section(n_funcs: n_funcs, n_exts: n_exts)
    let %mod = emit_section(buf: %mod, id: sec_function, content: %func_sec)

    // Memory section (only if Defined)
    if mem_mode == "defined" then
      let %mem_sec = build_memory_section()
      let %mod = emit_section(buf: %mod, id: sec_memory, content: %mem_sec)
    end

    // Global section (heap pointer)
    if heap_enabled then
      let %glob_sec = build_global_section(heap_base: heap_base)
      let %mod = emit_section(buf: %mod, id: sec_global, content: %glob_sec)
    end

    // Export section
    let %exp_sec = build_export_section(main_idx: main_idx, wasi_run_idx: wasi_run_idx, mem_mode: mem_mode)
    let %mod = emit_section(buf: %mod, id: sec_export, content: %exp_sec)

    // Code section
    let %code_sec = empty()
    let %code_sec = push_uleb128(buf: %code_sec, val: n_funcs + 1)
    let %code_sec = emit_code_bodies(buf: %code_sec, funcs: funcs,
                                      internal_funcs: internal_funcs,
                                      external_funcs: external_funcs,
                                      string_lits: string_entries,
                                      heap_enabled: heap_enabled,
                                      functions: funcs,
                                      externals: exts)
    // WASI CLI run wrapper
    let %wasi_body = compile_wasi_run_wrapper(main_idx: main_idx, main_ret_type: main_ret,
                                                main_has_args: main_has_args)
    let wasi_len = bb.length(buf: &wasi_body)
    let %code_sec = push_uleb128(buf: %code_sec, val: wasi_len)
    let %code_sec = push_buf(dst: %code_sec, src: &wasi_body)
    free(buf: %wasi_body)
    let %mod = emit_section(buf: %mod, id: sec_code, content: %code_sec)

    // Data section
    if has_strings then
      let %data_sec = build_data_section(entries: string_entries)
      let %mod = emit_section(buf: %mod, id: sec_data, content: %data_sec)
    end

    return %mod
  end
end

let compute_last_string_end = fn (entries: [StringEntry]) -> i64 do
  match entries do
    case Nil() -> return string_data_base
    case Cons(v: e, rest: Nil()) ->
      match e do case StringEntry(value: _, offset: off, slen: sl) ->
        return off + sl
      end
    case Cons(v: _, rest: rest) ->
      return compute_last_string_end(entries: rest)
  end
end

let main = fn () -> unit throws { Exn } do
  return ()
end
