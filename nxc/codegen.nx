/**
 * codegen: WASM binary generation from LIR.
 *
 * Compiles LIR (A-Normal Form) to a valid WASM binary module.
 * Uses ByteBuffer for binary construction with LEB128 encoding.
 */
import { ByteBuffer, empty, push_byte, push_i32_le, push_i64_le,
         push_uleb128, push_sleb128, push_string, push_buf,
         free } from stdlib/bytebuffer.nx
import as bb from stdlib/bytebuffer.nx
import { BinaryOp, TypeExpr, NamedType } from nxc/ast.nx
import { LirProgram, LirFunction, LirStmt, LirExpr, LirAtom,
         LirExternal, LirParam, LirCallArg, LirNamedAtom } from nxc/lir.nx
import { join } from stdlib/string.nx
import { char_code } from stdlib/string.nx
import as list from stdlib/list.nx

import external stdlib/stdlib.wasm
external str_length = "__nx_string_length" : (s: string) -> i64
external str_starts_with = "__nx_string_starts_with" : (s: string, prefix: string) -> bool
external str_substring = "__nx_string_substring" : (s: string, start: i64, len: i64) -> string
external str_index_of = "__nx_string_index_of" : (s: string, sub: string) -> i64


// ─── WASM Constants ─────────────────────────────────────────────────────────

// Section IDs
let sec_type = 1
let sec_import = 2
let sec_function = 3
let sec_memory = 5
let sec_global = 6
let sec_export = 7
let sec_code = 10
let sec_data = 11
let sec_custom = 0

// Value types
let vt_i32 = 127
let vt_i64 = 126
let vt_f32 = 125
let vt_f64 = 124

// Block types
let bt_void = 64
let bt_i32 = 127
let bt_i64 = 126

// Import/export descriptor kinds
let desc_func = 0
let desc_memory = 2

// Opcodes
let op_unreachable = 0
let op_block = 2
let op_loop = 3
let op_if = 4
let op_else = 5
let op_end = 11
let op_br = 12
let op_br_IF = 13
let op_return = 15
let op_call = 16
let op_return_CALL = 18
let op_drop = 26
let op_local_get = 32
let op_local_set = 33
let op_local_tee = 34
let op_global_get = 35
let op_global_set = 36
let op_i32_load = 40
let op_i64_load = 41
let op_i32_load8_U = 45
let op_i32_store = 54
let op_i64_store = 55
let op_i32_store8 = 58
let op_i32_const = 65
let op_i64_const = 66
let op_f64_const = 68
let op_i32_eqZ = 69
let op_i32_eq = 70
let op_i32_ne = 71
let op_i32_lt_s = 72
let op_i32_gt_s = 74
let op_i32_le_s = 76
let op_i32_ge_s = 78
let op_i32_ge_u = 79
let op_i64_eqZ = 80
let op_i64_eq = 81
let op_i64_ne = 82
let op_i64_lt_s = 83
let op_i64_gt_s = 85
let op_i64_le_s = 87
let op_i64_ge_s = 89
let op_f64_eq = 97
let op_f64_ne = 98
let op_f64_lt = 99
let op_f64_gt = 100
let op_f64_le = 101
let op_f64_ge = 102
let op_i32_add = 106
let op_i32_sub = 107
let op_i32_mul = 108
let op_i32_and = 113
let op_i32_or = 114
let op_i32_xor = 115
let op_i64_add = 124
let op_i64_sub = 125
let op_i64_mul = 126
let op_i64_div_s = 127
let op_i64_rem_s = 129
