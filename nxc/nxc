#!/usr/bin/env bash
#
# nxc — Nexus self-hosting compiler CLI
#
# Thin wrapper that invokes nxc_driver.wasm via wasmtime.
# Locates driver.wasm from: $NXC_DRIVER, ./nxc_driver.wasm, or project root.
#
# The driver requires WASI preview1 (-S preview2=n) and CWD preopen (--dir=.).
# The seed nxc_driver.wasm must be patched with a _start export
# (see bootstrap.sh for the patching step).
#
set -euo pipefail

# ─── Locate nxc_driver.wasm ─────────────────────────────────────────────────

find_driver() {
  # 1. Explicit override
  if [[ -n "${NXC_DRIVER:-}" ]] && [[ -f "$NXC_DRIVER" ]]; then
    echo "$NXC_DRIVER"
    return
  fi

  # 2. Same directory as this script
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "$script_dir/nxc_driver.wasm" ]]; then
    echo "$script_dir/nxc_driver.wasm"
    return
  fi

  # 3. Project root (one level up from nxc/)
  local project_root="$script_dir/.."
  if [[ -f "$project_root/nxc_driver.wasm" ]]; then
    echo "$project_root/nxc_driver.wasm"
    return
  fi

  # 4. Cached build artifact
  if [[ -f "$project_root/target/nxc/nxc_driver.wasm" ]]; then
    echo "$project_root/target/nxc/nxc_driver.wasm"
    return
  fi

  return 1
}

DRIVER=$(find_driver) || {
  echo "nxc: cannot find nxc_driver.wasm" >&2
  echo "  Set NXC_DRIVER=/path/to/nxc_driver.wasm or run bootstrap.sh first." >&2
  exit 1
}

# ─── Invoke via wasmtime ─────────────────────────────────────────────────────

exec wasmtime run \
  -S preview2=n \
  --dir=. \
  "$DRIVER" \
  "$@"
