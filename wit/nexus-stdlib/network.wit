/// HTTP networking operations.
///
/// Requires PermNet capability.
/// Delegates to the nexus:cli/nexus-host bridge for actual HTTP.
interface network {
    /// An active HTTP server. Linear — must be explicitly stopped.
    resource server {
        /// Accept the next incoming request. Blocks until a request arrives.
        /// Returns a serialized request string (method, path, headers, body).
        accept: func() -> string;

        /// Stop the server and release the listening socket.
        stop: static func(server: server);
    }

    /// Perform an HTTP request.
    /// `method`: HTTP method (GET, POST, etc.)
    /// `url`: full URL
    /// `headers`: serialized headers string (empty string for none)
    /// `body`: request body (empty string for none)
    /// Returns serialized response string.
    http-request: func(method: string, url: string, headers: string, body: string) -> string;

    /// Shorthand for HTTP GET. Returns response body.
    http-get: func(url: string) -> string;

    /// Bind a TCP listener on `addr` (e.g., "127.0.0.1:8080").
    http-listen: func(addr: string) -> server;

    /// Send an HTTP response to a request.
    /// `req-id`: request identifier from accept
    /// `status`: HTTP status code
    /// `headers`: serialized response headers
    /// `body`: response body
    http-respond: func(req-id: s64, status: s64, headers: string, body: string) -> bool;
}
