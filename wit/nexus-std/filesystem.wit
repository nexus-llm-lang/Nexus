/// Filesystem operations.
///
/// Requires PermFs capability.
/// File descriptors are represented as a resource with ownership semantics
/// matching nexus linear types (%Handle).
interface filesystem {
    /// An open file descriptor. Linear — must be explicitly closed.
    resource file-handle {
        /// Read entire file contents from this handle (seeks to 0 first).
        read: func() -> string;

        /// Write content to this handle. Returns true on success.
        write: func(content: string) -> bool;

        /// Get the filesystem path for this handle.
        path: func() -> string;
    }

    // ── Path-level operations ──────────────────────────────────────────

    /// True if a file or directory exists at `path`.
    exists: func(path: string) -> bool;

    /// True if `path` is a regular file.
    is-file: func(path: string) -> bool;

    /// Read entire file contents as a string.
    read-to-string: func(path: string) -> string;

    /// Write string content to a file (creates or truncates).
    write-string: func(path: string, content: string) -> bool;

    /// Append string content to a file (creates if not exists).
    append-string: func(path: string, content: string) -> bool;

    /// Delete a file.
    remove-file: func(path: string) -> bool;

    /// Create directory and all parent directories.
    create-dir-all: func(path: string) -> bool;

    /// List directory entries as newline-separated string (sorted).
    read-dir: func(path: string) -> string;

    // ── Handle-based operations ────────────────────────────────────────

    /// Open a file for reading.
    open-read: func(path: string) -> file-handle;

    /// Open a file for writing (truncate + create).
    open-write: func(path: string) -> file-handle;

    /// Open a file for appending (create if not exists).
    open-append: func(path: string) -> file-handle;
}
