/// Process lifecycle and subprocess execution.
///
/// Requires PermProc capability.
interface proc {
    /// An opaque handle to a completed subprocess execution.
    /// Must be freed after extracting results.
    resource exec-result {
        /// Exit code of the subprocess.
        exit-code: func() -> s64;

        /// Captured stdout of the subprocess.
        stdout: func() -> string;

        /// Captured stderr of the subprocess.
        stderr: func() -> string;
    }

    /// Terminate the current process with the given exit code.
    exit: func(status: s64);

    /// Get command-line arguments as a newline-separated string.
    argv: func() -> string;

    /// Execute a subprocess synchronously.
    /// `cmd`: executable name or path
    /// `args`: newline-separated argument string
    /// Returns a handle to the execution result.
    exec: func(cmd: string, args: string) -> exec-result;
}
