/// String manipulation operations.
///
/// With canonical ABI, strings cross component boundaries as UTF-8 with
/// automatic lift/lower — no more packed i64 (ptr<<32|len).
///
/// Functions that operate on character indices use Unicode scalar values.
/// Functions prefixed with `byte-` operate on raw UTF-8 byte offsets.
interface str {
    // ── Character-level operations ─────────────────────────────────────

    /// Number of Unicode scalar values (characters) in the string.
    length: func(s: string) -> s64;

    /// Number of UTF-8 bytes in the string.
    byte-length: func(s: string) -> s64;

    /// Unicode scalar value at character index. Returns 0 if out of bounds.
    char-at: func(s: string, idx: s64) -> char;

    /// Unicode code point at character index. Returns -1 if out of bounds.
    char-code: func(s: string, idx: s64) -> s64;

    /// Create a single-character string from a Unicode code point.
    from-char-code: func(code: s64) -> string;

    /// Create a single-character string from a char.
    from-char: func(c: char) -> string;

    /// Character ordinal (identity for char→s64 conversion).
    char-ord: func(c: char) -> s64;

    // ── Substring and search ───────────────────────────────────────────

    /// Extract substring by character offset and character length.
    substring: func(s: string, start: s64, len: s64) -> string;

    /// True if `s` contains `sub` as a substring.
    contains: func(s: string, sub: string) -> bool;

    /// Byte offset of first occurrence of `sub` in `s`, or -1 if not found.
    index-of: func(s: string, sub: string) -> s64;

    /// True if `s` starts with `prefix`.
    starts-with: func(s: string, prefix: string) -> bool;

    /// True if `s` ends with `suffix`.
    ends-with: func(s: string, suffix: string) -> bool;

    // ── Transformation ─────────────────────────────────────────────────

    /// Strip leading and trailing whitespace.
    trim: func(s: string) -> string;

    /// Convert all characters to uppercase.
    to-upper: func(s: string) -> string;

    /// Convert all characters to lowercase.
    to-lower: func(s: string) -> string;

    /// Replace all occurrences of `from-str` with `to-str`.
    replace: func(s: string, from-str: string, to-str: string) -> string;

    /// Repeat `s` exactly `n` times.
    repeat: func(s: string, n: s64) -> string;

    /// Left-pad `s` to `width` characters using `fill` string.
    pad-left: func(s: string, width: s64, fill: string) -> string;

    /// Right-pad `s` to `width` characters using `fill` string.
    pad-right: func(s: string, width: s64, fill: string) -> string;

    // ── Conversion ─────────────────────────────────────────────────────

    /// Render a signed 64-bit integer as a decimal string.
    from-i64: func(val: s64) -> string;

    /// Render a float as a string.
    from-float: func(val: f64) -> string;

    /// Render a boolean as "true" or "false".
    from-bool: func(val: bool) -> string;

    /// Parse a string as a signed 64-bit integer. Traps on invalid input.
    to-i64: func(s: string) -> s64;

    /// Parse a string as a float. Returns NaN on invalid input.
    to-f64: func(s: string) -> f64;

    /// True if the string is a valid signed 64-bit integer.
    is-valid-i64: func(s: string) -> bool;

    /// True if the string is a valid float.
    is-valid-f64: func(s: string) -> bool;

    // ── Byte-level scanning (lexer performance primitives) ─────────────

    /// Raw byte value at byte position (0-255). Returns 0 if out of bounds.
    byte-at: func(s: string, idx: s64) -> s32;

    /// Extract substring by byte offset and byte length.
    byte-substring: func(s: string, start: s64, len: s64) -> string;

    /// Scan forward from `start` while ASCII identifier chars (a-z, A-Z, 0-9, _).
    /// Returns byte position of first non-ident character.
    scan-ident: func(s: string, start: s64) -> s64;

    /// Scan forward from `start` while ASCII digits.
    /// Returns byte position of first non-digit character.
    scan-digits: func(s: string, start: s64) -> s64;

    /// Skip ASCII whitespace from `start`.
    /// Returns byte position of first non-whitespace character.
    skip-ws: func(s: string, start: s64) -> s64;

    /// Count newline characters in byte range [start, end).
    count-newlines-in: func(s: string, start: s64, end-pos: s64) -> s64;

    /// Byte position of last newline in range [start, end), or -1.
    last-newline-in: func(s: string, start: s64, end-pos: s64) -> s64;

    /// Find first occurrence of byte `ch` from `start`. Returns -1 if not found.
    find-byte: func(s: string, start: s64, ch: s32) -> s64;
}
