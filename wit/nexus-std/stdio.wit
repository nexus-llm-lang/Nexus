/// Console I/O operations.
///
/// Requires PermConsole capability.
interface stdio {
    /// Print a string to stdout (no trailing newline). Flushes immediately.
    print: func(val: string);

    /// Print a string to stderr (no trailing newline). Flushes immediately.
    eprint: func(val: string);

    /// Read a line from stdin. Strips trailing newline.
    read-line: func() -> string;

    /// Read a single UTF-8 character from stdin.
    getchar: func() -> string;
}
