/// Nexus stdlib — component model interfaces.
///
/// This package defines the component boundary between user programs
/// and the nexus stdlib component. Pure .nx modules (list, option, result,
/// core, tuple, char, exn, set, hashmap, stringmap, bytebuffer, array)
/// compile into the user component and do not appear here.
///
/// With canonical ABI, strings cross as UTF-8 (automatic lift/lower),
/// replacing the packed i64 (ptr<<32|len) encoding used in core WASM.
package nexus:std@0.1.0;

/// A nexus user program compiled as a component.
world user-program {
    // Pure utilities (no permissions required)
    import math;
    import string-ops;

    // I/O and system (require capabilities)
    import stdio;
    import filesystem;
    import network;
    import process;
    import environment;
    import clock;
    import random;

    /// Program entry point.
    export run: func();
}

/// The stdlib component itself — exports all interfaces.
world stdlib {
    export math;
    export string-ops;
    export stdio;
    export filesystem;
    export network;
    export process;
    export environment;
    export clock;
    export random;
}
