/// Integer and floating-point math primitives.
///
/// All functions are pure — no side effects, no permissions required.
interface math {
    /// Absolute value of a signed 64-bit integer.
    abs: func(val: s64) -> s64;

    /// Returns the greater of two integers.
    max: func(a: s64, b: s64) -> s64;

    /// Returns the lesser of two integers.
    min: func(a: s64, b: s64) -> s64;

    /// Integer remainder (a % b). Traps on division by zero.
    mod-i64: func(a: s64, b: s64) -> s64;

    /// Absolute value of a float.
    abs-float: func(val: f64) -> f64;

    /// Square root.
    sqrt: func(val: f64) -> f64;

    /// Floor (round toward negative infinity).
    floor: func(val: f64) -> f64;

    /// Ceiling (round toward positive infinity).
    ceil: func(val: f64) -> f64;

    /// Exponentiation (base^exp).
    pow: func(base: f64, exp: f64) -> f64;

    /// Lossless integer-to-float conversion.
    i64-to-float: func(val: s64) -> f64;

    /// Truncating float-to-integer conversion (toward zero).
    float-to-i64: func(val: f64) -> s64;
}
