package nexus:stdlib;

interface math {
    abs-i64: func(val: s64) -> s64;
    max-i64: func(a: s64, b: s64) -> s64;
    min-i64: func(a: s64, b: s64) -> s64;
    mod-i64: func(a: s64, b: s64) -> s64;
    abs-float: func(val: f64) -> f64;
    sqrt: func(val: f64) -> f64;
    floor: func(val: f64) -> f64;
    ceil: func(val: f64) -> f64;
    pow: func(base: f64, exp: f64) -> f64;
    i64-to-float: func(val: s64) -> f64;
    float-to-i64: func(val: f64) -> s64;
}

interface string-ops {
    string-length: func(s: string) -> s64;
    string-byte-length: func(s: string) -> s64;
    string-contains: func(s: string, sub: string) -> s32;
    string-substring: func(s: string, start: s64, len: s64) -> string;
    string-index-of: func(s: string, sub: string) -> s64;
    string-starts-with: func(s: string, prefix: string) -> s32;
    string-ends-with: func(s: string, suffix: string) -> s32;
    string-trim: func(s: string) -> string;
    string-to-upper: func(s: string) -> string;
    string-to-lower: func(s: string) -> string;
    string-replace: func(s: string, pattern: string, replacement: string) -> string;
    string-char-at: func(s: string, idx: s64) -> s32;
    string-from-char: func(c: s32) -> string;
    string-from-i64: func(val: s64) -> string;
    string-from-float: func(val: f64) -> string;
    string-from-bool: func(val: s32) -> string;
    string-to-i64: func(s: string) -> s64;
    string-repeat: func(s: string, n: s64) -> string;
    string-pad-left: func(s: string, width: s64, fill: string) -> string;
    string-pad-right: func(s: string, width: s64, fill: string) -> string;
    string-is-valid-i64: func(s: string) -> s32;
    string-char-code: func(s: string, idx: s64) -> s64;
    char-ord: func(c: s32) -> s64;
    string-from-char-code: func(code: s64) -> string;
    string-to-f64: func(s: string) -> f64;
    string-is-valid-f64: func(s: string) -> s32;
    string-byte-at: func(s: string, idx: s64) -> s32;
    string-scan-ident: func(s: string, start: s64) -> s64;
    string-scan-digits: func(s: string, start: s64) -> s64;
    string-skip-ws: func(s: string, start: s64) -> s64;
    string-count-newlines-in: func(s: string, start: s64, end: s64) -> s64;
    string-last-newline-in: func(s: string, start: s64, end: s64) -> s64;
    string-find-byte: func(s: string, start: s64, ch: s32) -> s64;
    string-byte-substring: func(s: string, start: s64, len: s64) -> string;
}

interface stdio {
    print: func(s: string);
    eprint: func(s: string);
    read-line: func() -> string;
    getchar: func() -> string;
}

interface filesystem {
    read-to-string: func(path: string) -> string;
    write-string: func(path: string, content: string) -> s32;
    append-string: func(path: string, content: string) -> s32;
    exists: func(path: string) -> s32;
    is-file: func(path: string) -> s32;
    remove-file: func(path: string) -> s32;
    create-dir-all: func(path: string) -> s32;
    read-dir: func(path: string) -> string;
    fd-open-read: func(path: string) -> s64;
    fd-open-write: func(path: string) -> s64;
    fd-open-append: func(path: string) -> s64;
    fd-close: func(fd: s64) -> s32;
    fd-read: func(fd: s64) -> string;
    fd-write: func(fd: s64, content: string) -> s32;
    fd-path: func(fd: s64) -> string;
}

interface network {
    http-get: func(url: string) -> string;
    http-request: func(method: string, url: string, headers: string, body: string) -> string;
    http-listen: func(addr: string) -> s64;
    http-accept: func(server-id: s64) -> string;
    http-respond: func(req-id: s64, status: s64, headers: string, body: string) -> s32;
    http-stop: func(server-id: s64) -> s32;
}

interface process {
    exit: func(status: s64);
    argv: func() -> string;
    exec: func(cmd: string, args: string) -> s64;
    exec-exit-code: func(id: s64) -> s64;
    exec-stdout: func(id: s64) -> string;
    exec-stderr: func(id: s64) -> string;
    exec-free: func(id: s64) -> s32;
}

interface environment {
    get-env: func(key: string) -> string;
    set-env: func(key: string, value: string);
}

interface clock {
    sleep: func(ms: s64);
    now: func() -> s64;
}

interface random {
    random-i64: func() -> s64;
    random-range: func(min: s64, max: s64) -> s64;
}

interface collections {
    array-length: func(ptr: s32, len: s32) -> s64;

    hmap-new: func() -> s64;
    hmap-put: func(id: s64, key: s64, value: s64) -> s64;
    hmap-get: func(id: s64, key: s64, default-val: s64) -> s64;
    hmap-has: func(id: s64, key: s64) -> s32;
    hmap-del: func(id: s64, key: s64) -> s32;
    hmap-size: func(id: s64) -> s64;
    hmap-keys: func(id: s64) -> string;
    hmap-vals: func(id: s64) -> string;
    hmap-key-at: func(id: s64, idx: s64) -> s64;
    hmap-val-at: func(id: s64, idx: s64) -> s64;
    hmap-free: func(id: s64) -> s32;

    hset-new: func() -> s64;
    hset-insert: func(id: s64, val: s64) -> s32;
    hset-contains: func(id: s64, val: s64) -> s32;
    hset-remove: func(id: s64, val: s64) -> s32;
    hset-size: func(id: s64) -> s64;
    hset-to-list: func(id: s64) -> string;
    hset-union: func(id-a: s64, id-b: s64) -> s64;
    hset-intersection: func(id-a: s64, id-b: s64) -> s64;
    hset-difference: func(id-a: s64, id-b: s64) -> s64;
    hset-free: func(id: s64) -> s32;

    smap-new: func() -> s64;
    smap-put: func(id: s64, key: string, value: s64) -> s64;
    smap-get: func(id: s64, key: string, default-val: s64) -> s64;
    smap-has: func(id: s64, key: string) -> s32;
    smap-del: func(id: s64, key: string) -> s32;
    smap-size: func(id: s64) -> s64;
    smap-keys: func(id: s64) -> string;
    smap-vals: func(id: s64) -> string;
    smap-val-count: func(id: s64) -> s64;
    smap-val-at: func(id: s64, idx: s64) -> s64;
    smap-free: func(id: s64) -> s32;
}

interface bytebuffer {
    buf-new: func() -> s64;
    buf-push-byte: func(id: s64, byte: s64);
    buf-push-i32-le: func(id: s64, val: s64);
    buf-push-i64-le: func(id: s64, val: s64);
    buf-push-f64-str-le: func(id: s64, s: string);
    buf-push-leb128-u: func(id: s64, val: s64);
    buf-push-leb128-s: func(id: s64, val: s64);
    buf-push-string: func(id: s64, s: string);
    buf-push-buf: func(id: s64, src-id: s64);
    buf-length: func(id: s64) -> s64;
    buf-get-byte: func(id: s64, idx: s64) -> s64;
    buf-to-string: func(id: s64) -> string;
    buf-write-file: func(id: s64, path: string) -> s32;
    buf-free: func(id: s64) -> s32;
    buf-read-file: func(path: string) -> s64;
    buf-copy-range: func(dst-id: s64, src-id: s64, start: s64, end-pos: s64);
}

interface core {
    array-length: func(ptr: s32, len: s32) -> s64;
}

world stdlib {
    import nexus:cli/nexus-host;

    export math;
    export string-ops;
    export stdio;
    export filesystem;
    export network;
    export process;
    export environment;
    export clock;
    export random;
    export collections;
    export bytebuffer;
    export core;
}
