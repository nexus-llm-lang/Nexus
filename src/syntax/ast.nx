/**
 * ast: Surface AST type definitions for the Nexus self-hosting compiler.
 *
 * Uses concrete Spanned* wrapper types instead of generics (Nexus lacks
 * user-defined generic ADTs).
 *
 * Lexical vocabulary types (Sigil, BinaryOp, UnaryOp, Literal, RdrName,
 * NamedType, VariantField, TypeExpr, VariantDef, EnumDef, RecordDef) live
 * in src/types/ and are imported here for use by the surface AST types
 * defined in this file. Nexus has no re-export syntax; consumers that need
 * only vocabulary types should import directly from src/types/.
 */

import { Span } from "src/types/span.nx"
import {
  Sigil, SigilImmutable, SigilMutable, SigilLinear, SigilBorrow, SigilLazy,
  BinaryOp,
  OpAdd, OpSub, OpMul, OpDiv, OpMod,
  OpFAdd, OpFSub, OpFMul, OpFDiv,
  OpEq, OpNe, OpLt, OpLe, OpGt, OpGe,
  OpFEq, OpFNe, OpFLt, OpFLe, OpFGt, OpFGe,
  OpBitAnd, OpBitOr, OpBitXor, OpShl, OpShr,
  OpAnd, OpOr, OpConcat,
  UnaryOp, OpNeg, OpFNeg, OpNot,
  Literal, LitInt, LitFloat, LitBool, LitChar, LitString, LitUnit,
  RdrName, Unqual, Qual
} from "src/types/vocab.nx"
import {
  NamedType,
  VariantField,
  TypeExpr,
  TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit,
  TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyLazy, TyBorrow,
  TyArray, TyList, TyRecord, TyRow, TyHandler,
  VariantDef, EnumDef, RecordDef
} from "src/types/type_expr.nx"

/** Public type CallArg. */
export type CallArg = CallArg(name: string, value: SpannedExpr)

/** Public type CtorArg. */
export type CtorArg = CtorArg(name: string, value: SpannedExpr)

/** Public type NamedExpr. */
export type NamedExpr = NamedExpr(name: string, value: SpannedExpr)

/** Public type CtorPatternField. */
export type CtorPatternField = CtorPatternField(name: string, pattern: SpannedPattern)

/** Public type RecordPatField. */
export type RecordPatField = RecordPatField(name: string, pattern: SpannedPattern)

/** Public type Pattern. */
export type Pattern =
  PatLiteral(lit: Literal)
  | PatVariable(name: string, sigil: Sigil)
  | PatConstructor(name: RdrName, fields: [ CtorPatternField ], sigil: Sigil)
  | PatConstructorWildcard(name: RdrName, sigil: Sigil)
  | PatRecord(fields: [ RecordPatField ], has_wildcard: bool)
  | PatWildcard
  // `p1 | p2 | ...` — alternatives must bind the same variable set with
  // compatible types (enforced by bind_pattern in typecheck/infer.nx).
  | PatOr(alts: [ SpannedPattern ])

/** Public type SpannedPattern. */
export type SpannedPattern = SpannedPattern(node: Pattern, span: Span)

/** Public type MatchCase. */
export type MatchCase = MatchCase(pattern: SpannedPattern, body: [ SpannedStmt ])

/** Public type CatchArm. */
export type CatchArm = CatchArm(pattern: SpannedPattern, body: [ SpannedStmt ])

/** Public type Expr. */
export type Expr =
  // Atoms
  ExprLiteral(lit: Literal)
  | ExprVariable(name: RdrName, sigil: Sigil)
  | ExprBorrow(name: string, sigil: Sigil)
  // Operators
  | ExprBinaryOp(left: SpannedExpr, op: BinaryOp, right: SpannedExpr)
  | ExprUnaryOp(op: UnaryOp, operand: SpannedExpr)
  // Calls
  | ExprCall(func: RdrName, args: [ CallArg ])
  | ExprCallExpr(callee: SpannedExpr, args: [ CallArg ])
  | ExprConstructor(name: RdrName, args: [ CtorArg ], sigil: Sigil)
  | ExprExternal(symbol: string, type_params: [ string ], arg_names: [ string ], typ: TypeExpr)
  // Collections
  | ExprArray(elements: [ SpannedExpr ])
  | ExprList(elements: [ SpannedExpr ])
  | ExprRecord(fields: [ NamedExpr ])
  // Access
  | ExprIndex(target: SpannedExpr, index: SpannedExpr)
  | ExprFieldAccess(target: SpannedExpr, field: string)
  // Control flow
  | ExprIf(cond: SpannedExpr, then_branch: [ SpannedStmt ], else_branch: [ SpannedStmt ])
  | ExprMatch(target: SpannedExpr, cases: [ MatchCase ])
  | ExprWhile(cond: SpannedExpr, body: [ SpannedStmt ])
  | ExprFor(var: string, start: SpannedExpr, end_expr: SpannedExpr, body: [ SpannedStmt ])
  // Functions & effects
  | ExprLambda(
    type_params: [ string ],
    params: [ Param ],
    ret_type: TypeExpr,
    requires: TypeExpr,
    throw_row: TypeExpr,
    body: [ SpannedStmt ]
  )
  | ExprRaise(value: SpannedExpr)
  | ExprForce(value: SpannedExpr)
  /** `@(expr)` thunk-creation expression: suspends `expr` and yields a `@T` thunk. */
  | ExprThunk(body: SpannedExpr)
  | ExprHandler(coeffect_name: string, requires: TypeExpr, arms: [ HandlerArm ])
  // `inject H do <body> end`. The SOLE inject AST form (statement and
  // expression positions both produce this). The expression's value is its
  // body's trailing value (the inject value-channel), so it is usable in `let x
  // = inject …`, `return inject …`, and argument position. A statement-position
  // `inject` is parsed as this expression and wrapped in a discarded
  // `StmtExpr(ExprInject(...))` by the statement dispatcher, so every existing
  // side-effect inject keeps working (its trailing value is simply dropped).
  | ExprInject(handlers: [ SpannedExpr ], body: [ SpannedStmt ])

/** Public type SpannedExpr. */
export type SpannedExpr = SpannedExpr(node: Expr, span: Span)

/** Public type Stmt. */
export type Stmt =
  StmtLet(name: string, sigil: Sigil, typ: Option<TypeExpr>, value: SpannedExpr)
  | StmtLetPattern(pattern: SpannedPattern, value: SpannedExpr)
  | StmtExpr(expr: SpannedExpr)
  | StmtReturn(value: SpannedExpr)
  | StmtAssign(target: string, value: SpannedExpr)
  | StmtIndexAssign(target: SpannedExpr, index: SpannedExpr, value: SpannedExpr)
  | StmtTry(body: [ SpannedStmt ], catch_arms: [ CatchArm ])

/** Public type SpannedStmt. */
export type SpannedStmt = SpannedStmt(node: Stmt, span: Span)

/** Public type Param. */
export type Param = Param(name: string, sigil: Sigil, typ: TypeExpr)

/** Public type Function. */
export type Function = Function(
  name: string,
  is_public: bool,
  type_params: [ string ],
  params: [ Param ],
  ret_type: TypeExpr,
  requires: TypeExpr,
  throw_row: TypeExpr,
  body: [ SpannedStmt ],
  span: Span
)

/** A handler-arm = an op implementation plus an optional continuation
 *  binder introduced by `fn op(...) -> R with @k do ... end`. The binder,
 *  when present, scopes over the body and represents the captured
 *  delimited continuation of the suspending caller, which lowers to wasm
 *  stack-switching (`cont.new` / `resume` with `on tag → label`).
 *  The `span` field tracks the position of the `fn` keyword opening the arm
 *  for LSP hover/definition precision.
 */
export type HandlerArm = HandlerArm(arm: Function, cont_binder: Option<string>, span: Span)

/** Public type ExceptionDef. */
export type ExceptionDef = ExceptionDef(name: string, is_public: bool, fields: [ VariantField ])

/** Public type ExceptionGroupDef. */
export type ExceptionGroupDef = ExceptionGroupDef(
  name: string,
  is_public: bool,
  members: [ string ]
)

/** Public type ImportItem. */
export type ImportItem = ImportItem(name: string, item_alias: Option<string>)

/** Public type ImportDef. */
export type ImportDef = ImportDef(
  path: string,
  alias: Option<string>,
  items: [ ImportItem ],
  is_external: bool
)

/** Public type FunctionSig. */
export type FunctionSig = FunctionSig(
  name: string,
  params: [ Param ],
  ret_type: TypeExpr,
  requires: TypeExpr,
  throw_row: TypeExpr
)

/** Public type Cap.
 *  type_params: optional generic type parameters, e.g. `cap Yield<T> do ... end`.
 *  Empty for monomorphic caps. Method signatures may reference these params
 *  in their parameter / return / throw / require slots.
 */
export type Cap = Cap(
  name: string,
  is_public: bool,
  type_params: [ string ],
  functions: [ FunctionSig ]
)

/** Public type GlobalLet. */
export type GlobalLet = GlobalLet(
  name: string,
  is_public: bool,
  typ: Option<TypeExpr>,
  value: SpannedExpr
)

/** Public type TopLevel. */
export type TopLevel =
  TLTypeDef(def: RecordDef)
  | TLEnum(def: EnumDef)
  | TLException(def: ExceptionDef)
  | TLExceptionGroup(def: ExceptionGroupDef)
  | TLImport(def: ImportDef)
  | TLCap(def: Cap)
  | TLLet(def: GlobalLet)

/** Public type SpannedTopLevel. */
export type SpannedTopLevel = SpannedTopLevel(node: TopLevel, span: Span)

//
// `module_doc` carries the file-level documentation string captured from a
// leading `/** ... */` block comment by `src/frontend/lexer.extract_module_doc`.
// LSP `textDocument/hover` surfaces this when the cursor is on the first line.
// `None` means the file did not start with a `/** */` block.

/** Public type Program. */
export type Program = Program(definitions: [ SpannedTopLevel ], module_doc: Option<string>)
