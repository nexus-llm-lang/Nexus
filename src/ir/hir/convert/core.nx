/**
 * hir/convert/core: AST → HIR expression and statement conversion.
 *
 * This module holds the entire expr/stmt/match-case/handler-arm conversion
 * SCC. `convert_expr` and `convert_stmts` are mutually recursive (each
 * calls the other for sub-expressions and statement bodies), so splitting
 * them into separate files would create circular imports. Per the vn6n.5
 * strategy, we leave the SCC together and extract only DAG-leaf clusters.
 *
 * Pattern-shape conversion (convert_pattern, pattern_binders) lives in
 * src/ir/hir/pattern.nx, which is a DAG-leaf dependency of this module.
 *
 * Owns:
 * - convert_expr — SpannedExpr → HirExpr (the primary public entry point)
 * - convert_expr_toplevel — lazy-body stub for top-level lambdas
 * - convert_stmts — SpannedStmt list → HirStmt list
 * - convert_params — Param list → HirParam list (exported for build/defs.nx)
 * - convert_match_cases, convert_catch_arms — match/catch lowering
 * - convert_handler_arms, convert_one_function — handler arm lowering
 * - desugar_list — [a,b,c] → a::b::c::[] lowering
 * - ctor-arg sorting and conversion helpers
 *
 * Does not own:
 * - Top-level definition processing (see hir/build/defs.nx)
 * - HirAccum assembly (see hir/build/accum.nx)
 * - Pattern-shape conversion (see src/ir/hir/pattern.nx)
 */
import { Span } from "src/types/span.nx"
import {
  Sigil,
  SigilImmutable,
  SigilLazy,
  SigilMutable,
  RdrName,
  Unqual,
  Qual,
  OpAnd,
  OpOr,
  LitBool
} from "src/types/vocab.nx"
import { TypeExpr, TyUnit, TyRow, TyLazy } from "src/types/type_expr.nx"
import {
  Expr,
  ExprLiteral,
  ExprVariable,
  ExprBinaryOp,
  ExprUnaryOp,
  ExprBorrow,
  ExprCall,
  ExprCallExpr,
  ExprConstructor,
  ExprRecord,
  ExprArray,
  ExprIndex,
  ExprFieldAccess,
  ExprIf,
  ExprMatch,
  ExprWhile,
  ExprFor,
  ExprLambda,
  ExprRaise,
  ExprForce,
  ExprThunk,
  ExprExternal,
  ExprHandler,
  ExprInject,
  ExprList,
  StmtLet,
  StmtLetPattern,
  StmtExpr,
  StmtReturn,
  StmtAssign,
  StmtIndexAssign,
  StmtTry,
  PatVariable,
  SpannedExpr,
  SpannedStmt,
  SpannedPattern,
  Param,
  Function,
  HandlerArm,
  MatchCase,
  CallArg,
  CtorArg,
  NamedExpr,
  CatchArm
} from "src/syntax/ast.nx"
import { HirError } from "src/diagnostics/error.nx"
import { SymbolNotFound, SkInjectHandler } from "src/backend/errors.nx"
import * as rdr from "src/ir/shared/rdrname.nx"
import { RenameEntry }, * as symtab from "src/ir/shared/symtab.nx"
import * as str from "std:str"
import * as list from "std:list"
import {
  HirParam,
  HirExpr,
  HirStmt,
  HirExprKind,
  HirCallArg,
  HirNamedExpr,
  HirMatchCase,
  HirPatternKind,
  PVar,
  PWild,
  POr,
  EagerBody,
  LazyBody,
  HirFunction,
  HirHandlerArm
}, * as hir from "src/ir/hir/types.nx"
import * as hpat from "src/ir/hir/pattern.nx"

/** Convert an AST expression (SpannedExpr) to HIR. */
/** Public entry point. Converts a standalone expression with NO enclosing
 *  local-binding scope (outer_locals = []). Internal recursive conversion uses
 *  `convert_expr_go`, which threads the set of local names bound in strictly
 *  enclosing blocks so that a `let`/for-var that shadows one of them is
 *  alpha-renamed to a fresh unique name (see convert_stmts_go). This keeps
 *  codegen's name→wasm-slot allocation in agreement with the typechecker's
 *  lexical scoping (nexus-i7alf): without it a nested-block shadow reused the
 *  outer binding's slot and clobbered it. */
export let convert_expr = fn (
  expr: SpannedExpr,
  entries: [ RenameEntry ]
) -> HirExpr throws { HirError } do
  return convert_expr_go(expr, entries, outer_locals: [])
end

/** Count the occurrences of `name` in `xs`. Used as the shadow DEPTH when
 *  minting a fresh name for a shadowing binding: the enclosing-locals list is a
 *  MULTISET (one entry per shadowing nesting level), so the count strictly
 *  increases with each live nested shadow of the same name, guaranteeing
 *  `name#depth` is unique along any straight-line scope path. Sibling blocks at
 *  the same depth reuse the same suffix, which is sound because their bindings
 *  have disjoint lifetimes (and so may share a wasm slot). */
let count_str_occ = fn (name: string, xs: [ string ]) -> i64 do
  match xs do
    | [] -> return 0
    | x :: rest ->
      if x == name then return 1 + count_str_occ(name, xs: rest)
      else return count_str_occ(name, xs: rest)
      end
  end
end

/** Mint the alpha-renamed name for a binding `name` that shadows an enclosing
 *  binding. `#` is the internal qualifier separator and is not a legal source
 *  identifier character, so the result can never collide with a user name. */
let shadow_rename = fn (name: string, outer_locals: [ string ]) -> string do
  return name ++ "#" ++ str.from_i64(val: count_str_occ(name, xs: outer_locals))
end

/** Build the alpha-rename map for the BINDERS of a match-arm / catch / let-pattern
 *  whose name shadows a strictly-enclosing local (nexus-x9uw0, the pattern-binder
 *  sibling of i7alf). For each binder `b` in `binders` that appears in
 *  `outer_locals`, add `b → shadow_rename(b)` so (1) the binder occurrence in the
 *  pattern is rewritten to a fresh slot name and (2) references to it inside the
 *  arm body resolve to that fresh name. A binder that does NOT shadow is absent
 *  from the result and keeps its source name (so it still shares no slot with any
 *  enclosing binding — its name was unique to begin with). The depth is taken
 *  against the SAME `outer_locals` for every binder of the arm: sibling arms at
 *  the same nesting depth that bind the same name therefore reuse the same suffix,
 *  which is sound because only one arm runs (disjoint lifetimes — see i7alf). */
let pattern_binder_renames = fn (
  binders: [ string ],
  outer_locals: [ string ]
) -> [ RenameEntry ] do
  return pattern_binder_renames_go(binders, outer_locals, acc: [])
end

let pattern_binder_renames_go = fn (
  binders: [ string ],
  outer_locals: [ string ],
  acc: [ RenameEntry ]
) -> [ RenameEntry ] do
  match binders do
    | [] -> return acc
    | b :: rest ->
      if count_str_occ(name: b, xs: outer_locals) > 0 then
        return pattern_binder_renames_go(
          binders: rest,
          outer_locals,
          acc: symtab.rename_add(
            entries: acc,
            original: b,
            qualified: shadow_rename(name: b, outer_locals)
          )
        )
      else
        return pattern_binder_renames_go(binders: rest, outer_locals, acc)
      end
  end
end

/** Prepend each shadow binder-rename onto the arm body's rename entries so a
 *  reference to a renamed binder inside the arm resolves to the fresh slot name.
 *  Caller passes `entries` with every binder already dropped (rename_drop_many);
 *  re-adding only the shadowing ones on top leaves non-shadowing binders bare
 *  while routing shadowing ones to `b#depth`. Prepended so they win first-match
 *  resolution over any surviving lower-priority entry for the same bare name. */
let merge_binder_renames = fn (
  entries: [ RenameEntry ],
  binder_renames: [ RenameEntry ]
) -> [ RenameEntry ] do
  match binder_renames do
    | [] -> return entries
    | RenameEntry(original: o, qualified: q) :: rest ->
      return merge_binder_renames(
        entries: symtab.rename_add(entries, original: o, qualified: q),
        binder_renames: rest
      )
  end
end

let convert_expr_go = fn (
  expr: SpannedExpr,
  entries: [ RenameEntry ],
  outer_locals: [ string ]
) -> HirExpr throws { HirError } do
  let SpannedExpr(node, span: sp) = expr
  let hir = match node do
    | ExprLiteral(lit) ->
      Literal(lit)
    | ExprVariable(name, sigil: sig) ->
      let renamed = symtab.rename(name: rdr.rdr_to_string(r: name), entries)
      match sig do
        | SigilLazy ->
          Force(expr: HirExpr(node: Variable(name: renamed, sigil: SigilImmutable), span: sp))
        | _ ->
          Variable(name: renamed, sigil: sig)
      end
    | ExprBinaryOp(left: l, op, right: r) ->
      // Desugar short-circuit logical operators into conditionals so that the
      // RHS is only evaluated when its value can affect the result:
      //   a && b  ≡  if a then b else false
      //   a || b  ≡  if a then true else b
      // Bitwise OpBitAnd / OpBitOr remain as BinOp (always eager, no desugar).
      match op do
        | OpAnd ->
          let hir_cond = convert_expr_go(expr: l, entries, outer_locals)
          let hir_rhs = convert_expr_go(expr: r, entries, outer_locals)
          let hir_false = HirExpr(node: Literal(lit: LitBool(val: false)), span: sp)
          If(
            cond: hir_cond,
            then_branch: [ HirStmt(node: hir.Expr(expr: hir_rhs), span: sp) ],
            else_branch: Some(val: [ HirStmt(node: hir.Expr(expr: hir_false), span: sp) ])
          )
        | OpOr ->
          let hir_cond = convert_expr_go(expr: l, entries, outer_locals)
          let hir_rhs = convert_expr_go(expr: r, entries, outer_locals)
          let hir_true = HirExpr(node: Literal(lit: LitBool(val: true)), span: sp)
          If(
            cond: hir_cond,
            then_branch: [ HirStmt(node: hir.Expr(expr: hir_true), span: sp) ],
            else_branch: Some(val: [ HirStmt(node: hir.Expr(expr: hir_rhs), span: sp) ])
          )
        | _ ->
          BinOp(
            left: convert_expr_go(expr: l, entries, outer_locals),
            op,
            right: convert_expr_go(expr: r, entries, outer_locals)
          )
      end
    | ExprUnaryOp(op, operand: o) ->
      UnOp(op, operand: convert_expr_go(expr: o, entries, outer_locals))
    | ExprBorrow(name, sigil: sig) ->
      Borrow(name: symtab.rename(name, entries), sigil: sig)
    | ExprCall(func: f, args) ->
      // Disambiguate record-field calls from module-qualified calls.
      //
      // Module-qualified calls (cap methods, wildcard imports) rename to a
      // canonical form like "path#Name.method" or "path#func" — the rename
      // changes the string. A call where rename is an IDENTITY (the result
      // equals the original) AND the name has a "." is a local-variable
      // field-access call (e.g. `o.run(args)` where `o: Ops`).
      let original = rdr.rdr_to_string(r: f)
      let renamed = symtab.rename(name: original, entries)
      if renamed == original && str.index_of(s: original, sub: ".") >= 0 then
        // Field-access call: split at last dot → CallExpr(FieldAccess(Variable(obj), field), args).
        let len = str.length(s: original)
        let dot_pos = last_dot_pos(s: original, i: len - 1)
        let obj = str.substring(s: original, start: 0, len: dot_pos)
        let field = str.substring(s: original, start: dot_pos + 1, len: len - dot_pos - 1)
        let callee = HirExpr(
          node: FieldAccess(
            target: HirExpr(node: Variable(name: obj, sigil: SigilImmutable), span: sp),
            field
          ),
          span: sp
        )
        CallExpr(callee, args: convert_call_args(args, entries, outer_locals))
      else
        Call(func: renamed, args: convert_call_args(args, entries, outer_locals))
      end
    | ExprCallExpr(callee: c, args) ->
      // Postfix-call on an arbitrary expression: (expr)(args).
      CallExpr(
        callee: convert_expr_go(expr: c, entries, outer_locals),
        args: convert_call_args(args, entries, outer_locals)
      )
    | ExprConstructor(name: v, args, sigil: sig) ->
      let HirCtorResult(
        labels: ctor_labels,
        args: ctor_args
      ) = convert_ctor_args(args, entries, outer_locals)
      // route the ctor occurrence through the import-binding rename
      // map. Bare `MkV` (selective/own) matches a bare entry; `m.MkV` (wildcard)
      // matches the `alias.Ctor` entry. Builtins (Cons/Nil/Some/None) and any
      // unmapped ctor stay bare (rename is identity on miss).
      Ctor(
        variant: symtab.rename_ctor(name: v, entries),
        args: ctor_args,
        labels: ctor_labels,
        sigil: sig
      )
    | ExprRecord(fields: fs) ->
      Record(fields: convert_named_exprs(exprs: fs, entries, outer_locals))
    | ExprArray(elements: es) ->
      Array(elems: convert_expr_list(exprs: es, entries, outer_locals))
    | ExprIndex(target: t, index: i) ->
      Index(
        target: convert_expr_go(expr: t, entries, outer_locals),
        index: convert_expr_go(expr: i, entries, outer_locals)
      )
    | ExprFieldAccess(target: t, field: f) ->
      // Module-qualified value access: `mod.name` in value position parses as
      // FieldAccess(Variable("mod"), "name"). If "mod.name" has a rename
      // entry (added for wildcard-aliased imports), resolve as a qualified
      // variable reference rather than a struct field access. Without this,
      // `wdefs.vt_i32` compiles as a field access on an undefined variable
      // and silently returns garbage — breaking self-hosted codegen.
      let SpannedExpr(node: target_node, span: _) = t
      match target_node do
        | ExprVariable(name: Unqual(name: mod_name), sigil: _) ->
          let qualified_key = mod_name ++ "." ++ f
          if symtab.rename_has(name: qualified_key, entries) then
            Variable(name: symtab.rename(name: qualified_key, entries), sigil: SigilImmutable)
          else
            FieldAccess(target: convert_expr_go(expr: t, entries, outer_locals), field: f)
          end
        | _ ->
          FieldAccess(target: convert_expr_go(expr: t, entries, outer_locals), field: f)
      end
    | ExprIf(cond: c, then_branch: tb, else_branch: eb) ->
      // The branch bodies are child scopes; `outer_locals` already carries the
      // names live at this `if` (convert_stmts_go augmented it before descending
      // here), so a `let` in a branch that shadows one is renamed.
      let hir_else = match eb do
        | [] -> None
        | _ :: _ -> Some(val: convert_stmts_scoped(stmts: eb, entries, outer_locals))
      end
      If(
        cond: convert_expr_go(expr: c, entries, outer_locals),
        then_branch: convert_stmts_scoped(stmts: tb, entries, outer_locals),
        else_branch: hir_else
      )
    | ExprMatch(target: t, cases: cs) ->
      Match(
        target: convert_expr_go(expr: t, entries, outer_locals),
        cases: convert_match_cases(cases: cs, entries, outer_locals)
      )
    | ExprWhile(cond: c, body: b) ->
      While(
        cond: convert_expr_go(expr: c, entries, outer_locals),
        body: convert_stmts_scoped(stmts: b, entries, outer_locals)
      )
    | ExprFor(var: v, start: s, end_expr: e, body: b) ->
      // The loop variable `v` is bound in the for-body scope. If it shadows an
      // enclosing binding, rename it to a fresh name and route references inside
      // the body to it; otherwise drop any top-level rename so `v` stays bare.
      // The for-var is also an enclosing binding for the body, so it joins
      // `outer_locals` when converting the body (a nested `let v` then shadows).
      let shadows_for = count_str_occ(name: v, xs: outer_locals) > 0
      let for_var = if shadows_for then shadow_rename(name: v, outer_locals) else v end
      let body_entries = if shadows_for then
        symtab.rename_add(
          entries: symtab.rename_drop(entries, name: v),
          original: v,
          qualified: for_var
        )
      else
        symtab.rename_drop(entries, name: v)
      end
      For(
        var: for_var,
        start: convert_expr_go(expr: s, entries, outer_locals),
        end_expr: convert_expr_go(expr: e, entries, outer_locals),
        body: convert_stmts_scoped(stmts: b, entries: body_entries, outer_locals: v :: outer_locals)
      )
    | ExprLambda(
      type_params: tps,
      params: ps,
      ret_type: rt,
      requires: req,
      throw_row: tw,
      body: b
    ) ->
      // Lexical shadowing: drop rename entries whose `original` matches a
      // parameter name so references inside the body resolve to the local
      // (parameter) at codegen instead of any toplevel of the same name.
      // The body's enclosing-locals set keeps `outer_locals` (the captured
      // enclosing locals, which closure conversion lifts into params of the
      // lifted function) plus this lambda's own params, so a `let` in the body
      // that shadows either is renamed to a fresh slot.
      let pnames = param_names_of_params(params: ps)
      let inner_entries = symtab.rename_drop_many(entries, names: pnames)
      Lambda(
        type_params: tps,
        params: convert_params(params: ps),
        ret_type: rt,
        requires: req,
        throw_row: tw,
        body: convert_stmts_scoped(
          stmts: b,
          entries: inner_entries,
          outer_locals: list.concat(xs: pnames, ys: outer_locals)
        )
      )
    | ExprRaise(value: e) ->
      Raise(expr: convert_expr_go(expr: e, entries, outer_locals))
    | ExprForce(value: e) ->
      Force(expr: convert_expr_go(expr: e, entries, outer_locals))
    | ExprThunk(body: e) ->
      Thunk(body: convert_expr_go(expr: e, entries, outer_locals))
    | ExprExternal(symbol: sym, type_params: tps, arg_names: names, typ: t) ->
      ExternalRef(symbol: sym, type_params: tps, arg_names: names, typ: t)
    | ExprHandler(coeffect_name: pname, requires: req, arms) ->
      Handler(
        cap_name: symtab.rename(name: pname, entries),
        requires: req,
        arms: convert_handler_arms(arms, entries, outer_locals)
      )
    | ExprInject(handlers: hs, body: b) ->
      // The SOLE inject conversion path: resolve the dotted handler names, apply
      // the rename map, and convert the body under the same entries. Produces the
      // HIR Inject EXPRESSION whose value is the body's trailing value. A
      // statement-position inject reaches here via StmtExpr (convert_stmts_go),
      // wrapped in HirStmtKind::Expr, so a discarded inject runs this same path
      // with its value dropped.
      let handler_names = extract_handler_names(exprs: hs)
      let qualified_handlers = rename_strings(names: handler_names, entries)
      Inject(
        handlers: qualified_handlers,
        body: convert_stmts_scoped(stmts: b, entries, outer_locals)
      )
    | ExprList(elements: es) ->
      // Extract inner node from desugar_list result — span comes from outer wrapping
      let HirExpr(
        node: desugared,
        span: _
      ) = desugar_list(elems: es, entries, span: sp, outer_locals)
      desugared
  end
  return HirExpr(node: hir, span: sp)
end

/** Convert a top-level AST expression, ALWAYS skipping body conversion.
 *  Returns Lambda with empty body for everything — the caller (process_tl_let)
 *  matches on the HirExprKind to distinguish Lambda from External/Handler.
 *  Non-Lambda TLLets get LazyBody too, but resolve_lazy_bodies handles the
 *  empty-body case gracefully (returns empty stmts).
 */
export let convert_expr_toplevel = fn (
  expr: SpannedExpr,
  entries: [ RenameEntry ]
) -> HirExpr throws { HirError } do
  let SpannedExpr(node, span: sp) = expr
  let tps = infer_tparams_from_expr(expr: node)
  let ps = infer_params_from_expr(expr: node)
  let rt = infer_ret_from_expr(expr: node)
  let req = infer_requires_from_expr(expr: node)
  let tw = infer_throw_row_from_expr(expr: node)
  return HirExpr(
    node: Lambda(
      type_params: tps,
      params: ps,
      ret_type: rt,
      requires: req,
      throw_row: tw,
      body: []
    ),
    span: sp
  )
end

/** Desugar [a, b, c] -> a :: b :: c :: []
 *  Args are unlabeled, so they must be in alphabetical field order: (rest, v)
 *  Each synthesised Cons inherits the head element's span so type errors land
 *  on the offending element; the terminating Nil and the outermost wrapper
 *  inherit the surrounding `[...]` span so errors against the empty list shape
 *  (or the whole literal) still point at user-visible source.
 */
let desugar_list = fn (
  elems: [ SpannedExpr ],
  entries: [ RenameEntry ],
  span: Span,
  outer_locals: [ string ]
) -> HirExpr throws { HirError } do
  let reversed = list.reverse(xs: elems)
  let inner = desugar_list_go(elems: reversed, entries, outer_locals,
    acc: HirExpr(node: Ctor(variant: "Nil", args: [], labels: [], sigil: SigilImmutable), span))
  let HirExpr(node: result_node, span: _) = inner
  return HirExpr(node: result_node, span)
end

let desugar_list_go = fn (
  elems: [ SpannedExpr ],
  entries: [ RenameEntry ],
  outer_locals: [ string ],
  acc: HirExpr
) -> HirExpr throws { HirError } do
  match elems do
    | [] -> return acc
    | e :: rest ->
      let SpannedExpr(node: _, span: head_sp) = e
      let head = convert_expr_go(expr: e, entries, outer_locals)
      return desugar_list_go(elems: rest, entries, outer_locals,
        acc: HirExpr(
          node: Ctor(variant: "Cons", args: [ acc, head ], labels: [], sigil: SigilImmutable),
          span: head_sp
        ))
  end
end

let convert_call_args = fn (
  args: [ CallArg ],
  entries: [ RenameEntry ],
  outer_locals: [ string ]
) -> [ HirCallArg ] throws { HirError } do
  return convert_call_args_go(args, entries, outer_locals, acc: [])
end

let convert_call_args_go = fn (
  args: [ CallArg ],
  entries: [ RenameEntry ],
  outer_locals: [ string ],
  acc: [ HirCallArg ]
) -> [ HirCallArg ] throws { HirError } do
  match args do
    | [] -> return list.reverse(xs: acc)
    | CallArg(name: l, value: v) :: rest ->
      return convert_call_args_go(
        args: rest,
        entries,
        outer_locals,
        acc: HirCallArg(label: l, value: convert_expr_go(expr: v, entries, outer_locals)) :: acc
      )
  end
end

let str_less_than_loop = fn (a: string, b: string, idx: i64, la: i64, lb: i64) -> bool do
  if idx >= la then
    return idx < lb
  else if idx >= lb then
    return false
  else
    let ca = str.char_code(s: a, idx)
    let cb = str.char_code(s: b, idx)
    if ca < cb then
      return true
    else if ca > cb then
      return false
    else
      return str_less_than_loop(a, b, idx: idx + 1, la, lb)
    end
  end
end

let str_less_than = fn (a: string, b: string) -> bool do
  return str_less_than_loop(a, b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end

let ctor_arg_name = fn (arg: CtorArg) -> string do
  let CtorArg(name: n, value: _) = arg
  return n
end

let insert_ctor_arg = fn (arg: CtorArg, sorted: [ CtorArg ]) -> [ CtorArg ] do
  return insert_ctor_arg_go(arg, sorted, acc: [])
end

let insert_ctor_arg_go = fn (arg: CtorArg, sorted: [ CtorArg ], acc: [ CtorArg ]) -> [ CtorArg ] do
  match sorted do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: [ arg ])
    | head :: rest ->
      if str_less_than(a: ctor_arg_name(arg), b: ctor_arg_name(arg: head)) then
        return list.concat(xs: list.reverse(xs: acc), ys: arg :: sorted)
      else
        return insert_ctor_arg_go(arg, sorted: rest, acc: head :: acc)
      end
  end
end

let sort_ctor_args = fn (args: [ CtorArg ]) -> [ CtorArg ] do
  return sort_ctor_args_go(args, sorted: [])
end

let sort_ctor_args_go = fn (args: [ CtorArg ], sorted: [ CtorArg ]) -> [ CtorArg ] do
  match args do
    | [] -> return sorted
    | a :: rest -> return sort_ctor_args_go(args: rest, sorted: insert_ctor_arg(arg: a, sorted))
  end
end

// Bundles the sorted user-supplied label list alongside the converted HIR exprs.
// Both lists are parallel and in the same (alphabetical) order; typecheck uses
// `labels` to enforce T-Ctor {ℓ} = {ℓ'}.
type HirCtorResult = HirCtorResult(labels: [ string ], args: [ HirExpr ])

let convert_ctor_args = fn (
  args: [ CtorArg ],
  entries: [ RenameEntry ],
  outer_locals: [ string ]
) -> HirCtorResult throws { HirError } do
  return convert_ctor_args_inner(args: sort_ctor_args(args), entries, outer_locals)
end

let convert_ctor_args_inner = fn (
  args: [ CtorArg ],
  entries: [ RenameEntry ],
  outer_locals: [ string ]
) -> HirCtorResult throws { HirError } do
  return convert_ctor_args_inner_go(args, entries, outer_locals, acc_labels: [], acc_exprs: [])
end

let convert_ctor_args_inner_go = fn (
  args: [ CtorArg ],
  entries: [ RenameEntry ],
  outer_locals: [ string ],
  acc_labels: [ string ],
  acc_exprs: [ HirExpr ]
) -> HirCtorResult throws { HirError } do
  match args do
    | [] ->
      return HirCtorResult(labels: list.reverse(xs: acc_labels), args: list.reverse(xs: acc_exprs))
    | CtorArg(name: n, value: v) :: rest ->
      return convert_ctor_args_inner_go(
        args: rest,
        entries,
        outer_locals,
        acc_labels: n :: acc_labels,
        acc_exprs: convert_expr_go(expr: v, entries, outer_locals) :: acc_exprs
      )
  end
end

let convert_named_exprs = fn (
  exprs: [ NamedExpr ],
  entries: [ RenameEntry ],
  outer_locals: [ string ]
) -> [ HirNamedExpr ] throws { HirError } do
  return convert_named_exprs_go(exprs, entries, outer_locals, acc: [])
end

let convert_named_exprs_go = fn (
  exprs: [ NamedExpr ],
  entries: [ RenameEntry ],
  outer_locals: [ string ],
  acc: [ HirNamedExpr ]
) -> [ HirNamedExpr ] throws { HirError } do
  match exprs do
    | [] -> return list.reverse(xs: acc)
    | NamedExpr(name: n, value: v) :: rest ->
      return convert_named_exprs_go(
        exprs: rest,
        entries,
        outer_locals,
        acc: HirNamedExpr(name: n, value: convert_expr_go(expr: v, entries, outer_locals)) :: acc
      )
  end
end

let convert_expr_list = fn (
  exprs: [ SpannedExpr ],
  entries: [ RenameEntry ],
  outer_locals: [ string ]
) -> [ HirExpr ] throws { HirError } do
  return convert_expr_list_go(exprs, entries, outer_locals, acc: [])
end

let convert_expr_list_go = fn (
  exprs: [ SpannedExpr ],
  entries: [ RenameEntry ],
  outer_locals: [ string ],
  acc: [ HirExpr ]
) -> [ HirExpr ] throws { HirError } do
  match exprs do
    | [] -> return list.reverse(xs: acc)
    | e :: rest ->
      return convert_expr_list_go(
        exprs: rest,
        entries,
        outer_locals,
        acc: convert_expr_go(expr: e, entries, outer_locals) :: acc
      )
  end
end

/** Convert AST statements to HIR statements with NO enclosing local-binding
 *  scope. Used by callers that begin a fresh scope chain. */
let convert_stmts = fn (
  stmts: [ SpannedStmt ],
  entries: [ RenameEntry ]
) -> [ HirStmt ] throws { HirError } do
  return convert_stmts_scoped(stmts, entries, outer_locals: [])
end

/** Convert a child statement block whose strictly-enclosing local names are
 *  `outer_locals`. The block starts with an empty current-block accumulator;
 *  any `let`/for-var whose name appears in `outer_locals` is alpha-renamed to a
 *  fresh slot, so it cannot clobber the enclosing binding's slot (nexus-i7alf).
 */
let convert_stmts_scoped = fn (
  stmts: [ SpannedStmt ],
  entries: [ RenameEntry ],
  outer_locals: [ string ]
) -> [ HirStmt ] throws { HirError } do
  return convert_stmts_go(stmts, entries, acc: [], outer_locals, block_locals: [])
end

/**
 * True if `name` appears as a free-ish call/variable reference anywhere in the
 * given statement list. Used to decide whether a forward block-level sibling
 * let is a genuine MUTUAL-recursion partner of a preceding lambda (and so must
 * be routed to the local binding) vs. an unrelated later shadow whose presence
 * must NOT steal a preceding lambda's reference away from an enclosing
 * top-level of the same name (nexus-grbmk over-rejection).
 *
 * This is a deliberately shadow-agnostic structural walk: any `Unqual(name)`
 * occurrence counts as a reference. That over-approximates across inner
 * rebindings of `name`, which only ever biases toward DROPPING the sibling
 * (preserving the qbxqe mutual-recursion routing) — never toward stealing a
 * legitimate top-level reference.
 */
let block_refs_name = fn (stmts: [ SpannedStmt ], name: string) -> bool do
  match stmts do
    | [] -> return false
    | s :: rest ->
      if stmt_refs_name(stmt: s, name) then return true end
      return block_refs_name(stmts: rest, name)
  end
end

let stmt_refs_name = fn (stmt: SpannedStmt, name: string) -> bool do
  let SpannedStmt(node: sn, span: _) = stmt
  match sn do
    | StmtLet(name: _, sigil: _, typ: _, value: v) -> return expr_refs_name(expr: v, name)
    | StmtLetPattern(pattern: _, value: v) -> return expr_refs_name(expr: v, name)
    | StmtExpr(expr: e) -> return expr_refs_name(expr: e, name)
    | StmtReturn(value: e) -> return expr_refs_name(expr: e, name)
    | StmtAssign(target: _, value: v) -> return expr_refs_name(expr: v, name)
    | StmtIndexAssign(target: a, index: i, value: v) ->
      if expr_refs_name(expr: a, name) then return true end
      if expr_refs_name(expr: i, name) then return true end
      return expr_refs_name(expr: v, name)
    | StmtTry(body: b, catch_arms: arms) ->
      if block_refs_name(stmts: b, name) then return true end
      return catch_arms_ref_name(arms: arms, name)
  end
end

let expr_refs_name = fn (expr: SpannedExpr, name: string) -> bool do
  let SpannedExpr(node: en, span: _) = expr
  match en do
    | ExprLiteral(lit: _) -> return false
    | ExprVariable(name: rn, sigil: _) -> return rdr_is_unqual_named(rn: rn, name)
    | ExprBorrow(name: bn, sigil: _) -> return bn == name
    | ExprBinaryOp(left: l, op: _, right: r) ->
      if expr_refs_name(expr: l, name) then return true end
      return expr_refs_name(expr: r, name)
    | ExprUnaryOp(op: _, operand: o) -> return expr_refs_name(expr: o, name)
    | ExprCall(func: rn, args: args) ->
      if rdr_is_unqual_named(rn: rn, name) then return true end
      return call_args_ref_name(args: args, name)
    | ExprCallExpr(callee: c, args: args) ->
      if expr_refs_name(expr: c, name) then return true end
      return call_args_ref_name(args: args, name)
    | ExprConstructor(name: _, args: args, sigil: _) -> return ctor_args_ref_name(args: args, name)
    | ExprExternal(symbol: _, type_params: _, arg_names: _, typ: _) -> return false
    | ExprArray(elements: es) -> return exprs_ref_name(exprs: es, name)
    | ExprList(elements: es) -> return exprs_ref_name(exprs: es, name)
    | ExprRecord(fields: fs) -> return named_exprs_ref_name(fields: fs, name)
    | ExprIndex(target: t, index: i) ->
      if expr_refs_name(expr: t, name) then return true end
      return expr_refs_name(expr: i, name)
    | ExprFieldAccess(target: t, field: _) -> return expr_refs_name(expr: t, name)
    | ExprIf(cond: c, then_branch: tb, else_branch: eb) ->
      if expr_refs_name(expr: c, name) then return true end
      if block_refs_name(stmts: tb, name) then return true end
      return block_refs_name(stmts: eb, name)
    | ExprMatch(target: t, cases: cs) ->
      if expr_refs_name(expr: t, name) then return true end
      return match_cases_ref_name(cases: cs, name)
    | ExprWhile(cond: c, body: b) ->
      if expr_refs_name(expr: c, name) then return true end
      return block_refs_name(stmts: b, name)
    | ExprFor(var: _, start: s, end_expr: e, body: b) ->
      if expr_refs_name(expr: s, name) then return true end
      if expr_refs_name(expr: e, name) then return true end
      return block_refs_name(stmts: b, name)
    | ExprLambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: b) ->
      return block_refs_name(stmts: b, name)
    | ExprRaise(value: v) -> return expr_refs_name(expr: v, name)
    | ExprForce(value: v) -> return expr_refs_name(expr: v, name)
    | ExprThunk(body: v) -> return expr_refs_name(expr: v, name)
    | ExprHandler(
      coeffect_name: _,
      requires: _,
      arms: arms
    ) -> return handler_arms_ref_name(arms: arms, name)
    | ExprInject(handlers: hs, body: b) ->
      if exprs_ref_name(exprs: hs, name) then return true end
      return block_refs_name(stmts: b, name)
  end
end

let rdr_is_unqual_named = fn (rn: RdrName, name: string) -> bool do
  match rn do
    | Unqual(name: u) -> return u == name
    | Qual(alias: _, name: _) -> return false
  end
end

let exprs_ref_name = fn (exprs: [ SpannedExpr ], name: string) -> bool do
  match exprs do
    | [] -> return false
    | e :: rest ->
      if expr_refs_name(expr: e, name) then return true end
      return exprs_ref_name(exprs: rest, name)
  end
end

let call_args_ref_name = fn (args: [ CallArg ], name: string) -> bool do
  match args do
    | [] -> return false
    | CallArg(name: _, value: v) :: rest ->
      if expr_refs_name(expr: v, name) then return true end
      return call_args_ref_name(args: rest, name)
  end
end

let ctor_args_ref_name = fn (args: [ CtorArg ], name: string) -> bool do
  match args do
    | [] -> return false
    | CtorArg(name: _, value: v) :: rest ->
      if expr_refs_name(expr: v, name) then return true end
      return ctor_args_ref_name(args: rest, name)
  end
end

let named_exprs_ref_name = fn (fields: [ NamedExpr ], name: string) -> bool do
  match fields do
    | [] -> return false
    | NamedExpr(name: _, value: v) :: rest ->
      if expr_refs_name(expr: v, name) then return true end
      return named_exprs_ref_name(fields: rest, name)
  end
end

let match_cases_ref_name = fn (cases: [ MatchCase ], name: string) -> bool do
  match cases do
    | [] -> return false
    | MatchCase(pattern: _, body: b) :: rest ->
      if block_refs_name(stmts: b, name) then return true end
      return match_cases_ref_name(cases: rest, name)
  end
end

let catch_arms_ref_name = fn (arms: [ CatchArm ], name: string) -> bool do
  match arms do
    | [] -> return false
    | CatchArm(pattern: _, body: b) :: rest ->
      if block_refs_name(stmts: b, name) then return true end
      return catch_arms_ref_name(arms: rest, name)
  end
end

let handler_arms_ref_name = fn (arms: [ HandlerArm ], name: string) -> bool do
  match arms do
    | [] -> return false
    | HandlerArm(
      arm: Function(
        name: _,
        is_public: _,
        type_params: _,
        params: _,
        ret_type: _,
        requires: _,
        throw_row: _,
        body: b,
        span: _
      ),
      cont_binder: _,
      span: _
    ) :: rest ->
      if block_refs_name(stmts: b, name) then return true end
      return handler_arms_ref_name(arms: rest, name)
  end
end

/**
 * From the statements that FOLLOW a lambda-RHS `let n = fn ...` at this block
 * level, collect only those later block-level let names that are genuine
 * forward MUTUAL-recursion partners of the lambda named `self_name` whose body
 * is `self_body`: a later `let m = fn ...` whose own body references
 * `self_name`. Names with non-lambda RHS, or lambda RHS that do not refer back
 * to `self_name`, are NOT collected — so a preceding lambda's reference to a
 * same-named enclosing/top-level binding is preserved (nexus-grbmk).
 */
let collect_mutual_sibling_names = fn (
  rest: [ SpannedStmt ],
  self_name: string,
  self_body: [ SpannedStmt ]
) -> [ string ] do
  match rest do
    | [] -> return []
    | SpannedStmt(
      node: StmtLet(
        name: m,
        sigil: _,
        typ: _,
        value: SpannedExpr(
          node: ExprLambda(
            type_params: _,
            params: _,
            ret_type: _,
            requires: _,
            throw_row: _,
            body: mb
          ),
          span: _
        )
      ),
      span: _
    ) :: more ->
      // `m` is a mutual-recursion partner iff the preceding lambda actually
      // refers to `m` AND `m`'s body refers back to `self_name`.
      if block_refs_name(
        stmts: self_body,
        name: m
      ) && block_refs_name(stmts: mb, name: self_name) then
        return m :: collect_mutual_sibling_names(rest: more, self_name, self_body)
      end
      return collect_mutual_sibling_names(rest: more, self_name, self_body)
    | _ :: more -> return collect_mutual_sibling_names(rest: more, self_name, self_body)
  end
end

let convert_stmts_go = fn (
  stmts: [ SpannedStmt ],
  entries: [ RenameEntry ],
  acc: [ HirStmt ],
  outer_locals: [ string ],
  block_locals: [ string ]
) -> [ HirStmt ] throws { HirError } do
  // The MULTISET of local names visible to any CHILD block opened from a
  // sub-expression of the current statement: the strictly-enclosing locals
  // (`outer_locals`) plus everything bound so far in THIS block
  // (`block_locals`). A `let`/for-var in a child block whose name is in this
  // set shadows an enclosing binding and is alpha-renamed (nexus-i7alf).
  let enclosing = list.concat(xs: block_locals, ys: outer_locals)
  match stmts do
    | [] -> return list.reverse(xs: acc)
    | SpannedStmt(node: StmtLet(name: n, sigil: sig, typ: t, value: v), span: sp) :: rest ->
      let SpannedExpr(node: v_node, span: vsp) = v
      // A `let n` whose name is bound in a STRICTLY-ENCLOSING block (n ∈
      // outer_locals) shadows that binding. Codegen keys wasm local slots by
      // name, so leaving both as `n` reuses the outer slot and the inner write
      // clobbers the outer value (nexus-i7alf). Rename the inner binding to a
      // fresh `n#depth` and route references in the rest of this block to it;
      // the enclosing binding keeps name `n` (its own slot) and survives the
      // block. A same-block re-`let` (n ∈ block_locals only) is an intended
      // rebind and KEEPS its name so it shares the slot (flat-rebind semantics).
      let shadows = count_str_occ(name: n, xs: outer_locals) > 0
      let bind_name = if shadows then shadow_rename(name: n, outer_locals) else n end
      // References after this `let` (in the rest of this block) resolve to the
      // bound name: the fresh `bind_name` for a shadow, else bare `n` (with any
      // top-level rename for `n` dropped so it does not re-qualify).
      let inner_entries = if shadows then
        symtab.rename_add(
          entries: symtab.rename_drop(entries, name: n),
          original: n,
          qualified: bind_name
        )
      else
        symtab.rename_drop(entries, name: n)
      end
      // A `let n = fn (...)` is a (possibly mutually) recursive local closure
      // (types.md:236 / the d33l7 lift_lambda_self path): the body may refer
      // to `n` to recurse, and to forward SIBLING local-let lambdas to
      // mutually recurse. Those names must resolve to the LOCAL binding so the
      // self/sibling call is not renamed to a same-named top-level canonical
      // (e.g. `g` → `src#g`) and routed to the OUTER binding instead of
      // recursing.
      //
      // The drop is NARROWED to genuine forward mutual-recursion partners:
      // `n` itself (self-recursion) plus any later block-level `let m = fn ...`
      // such that this body references `m` AND `m`'s body references `n` back
      // (collect_mutual_sibling_names). Dropping every later same-named let
      // unconditionally over-rejected a lambda that legitimately references an
      // enclosing/top-level fn `g` when an UNRELATED later `let g` happens to
      // sit in the same block (nexus-grbmk) — that later `g` does not refer
      // back, so it is no longer dropped and the reference keeps targeting the
      // top-level canonical.
      //
      // Non-lambda RHS keeps the outer entries: a non-recursive `let n = E`
      // does not bring the block locals into scope within E. When this binding
      // is a SHADOW, a recursive lambda's self/sibling references must target
      // the RENAMED binding, so map `n → bind_name` in the lambda's RHS env.
      let rhs_entries = match v_node do
        | ExprLambda(
          type_params: _,
          params: _,
          ret_type: _,
          requires: _,
          throw_row: _,
          body: lam_body
        ) ->
          let dropped = symtab.rename_drop_many(
            entries,
            names: n :: collect_mutual_sibling_names(rest, self_name: n, self_body: lam_body)
          )
          if shadows then
            symtab.rename_add(entries: dropped, original: n, qualified: bind_name)
          else
            dropped
          end
        | _ -> entries
      end
      // RHS is evaluated in the current scope (enclosing), where any nested
      // block it contains sees the names live up to this point.
      let hir_val = match sig do
        | SigilLazy ->
          HirExpr(
            node: Thunk(body: convert_expr_go(expr: v, entries: rhs_entries, outer_locals: enclosing)),
            span: vsp
          )
        | _ ->
          convert_expr_go(expr: v, entries: rhs_entries, outer_locals: enclosing)
      end
      return convert_stmts_go(
        stmts: rest,
        entries: inner_entries,
        acc: HirStmt(
          node: Let(name: bind_name, sigil: sig, typ: t, value: hir_val),
          span: sp
        ) :: acc,
        outer_locals,
        block_locals: n :: block_locals
      )
    | SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp) :: rest ->
      // Desugar: let Pattern = expr; rest → match expr do case Pattern -> rest end
      // The remaining stmts form the case body and must see entries with every
      // pattern-bound variable dropped (lexical shadowing). The case body is a
      // child scope whose enclosing locals are everything bound so far plus the
      // pattern binders, so a deeper `let` shadowing any of them is renamed.
      //
      // A binder of THIS let-pattern that shadows an enclosing local (b ∈
      // enclosing) is alpha-renamed to a fresh slot, mirroring match/catch arms
      // (nexus-x9uw0): the case body here is the rest of the block, so a binder
      // reusing an enclosing name would clobber that slot for the remainder.
      let binders = hpat.pattern_binders(pat)
      let binder_renames = pattern_binder_renames(binders, outer_locals: enclosing)
      let body_entries = merge_binder_renames(
        entries: symtab.rename_drop_many(entries, names: binders),
        binder_renames
      )
      let case_body = convert_stmts_scoped(
        stmts: rest,
        entries: body_entries,
        outer_locals: list.concat(xs: binders, ys: enclosing)
      )
      let match_case = HirMatchCase(
        pattern: hpat.convert_pattern(pat, entries, binder_renames),
        body: case_body
      )
      return list.concat(xs: list.reverse(xs: acc), ys: [ HirStmt(node: Expr(expr: HirExpr(node: Match(
          target: convert_expr_go(expr: v, entries, outer_locals: enclosing),
          cases: [ match_case ]
        ), span: sp)), span: sp) ])
    | SpannedStmt(node: StmtExpr(expr: e), span: sp) :: rest ->
      return convert_stmts_go(
        stmts: rest,
        entries,
        acc: HirStmt(
          node: Expr(expr: convert_expr_go(expr: e, entries, outer_locals: enclosing)),
          span: sp
        ) :: acc,
        outer_locals,
        block_locals
      )
    | SpannedStmt(node: StmtReturn(value: e), span: sp) :: rest ->
      return convert_stmts_go(
        stmts: rest,
        entries,
        acc: HirStmt(
          node: Return(expr: convert_expr_go(expr: e, entries, outer_locals: enclosing)),
          span: sp
        ) :: acc,
        outer_locals,
        block_locals
      )
    | SpannedStmt(node: StmtAssign(target: t, value: v), span: sp) :: rest ->
      // Synthetic Variable target inherits the assignment statement span so
      // unbound-target errors land on the user's `x = ...` line rather than 0.
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Assign(
          target: HirExpr(
            node: Variable(name: symtab.rename(name: t, entries), sigil: SigilMutable),
            span: sp
          ),
          value: convert_expr_go(expr: v, entries, outer_locals: enclosing)
        ), span: sp) :: acc, outer_locals, block_locals)
    | SpannedStmt(node: StmtIndexAssign(target: arr, index: idx, value: v), span: sp) :: rest ->
      // Indexed assignment `arr[idx] <- val`: convert to HIR
      // Assign with an Index target. HIR Assign already takes HirExpr, so
      // downstream IR / typecheck see a uniform shape.
      let arr_hir = convert_expr_go(expr: arr, entries, outer_locals: enclosing)
      let idx_hir = convert_expr_go(expr: idx, entries, outer_locals: enclosing)
      let v_hir = convert_expr_go(expr: v, entries, outer_locals: enclosing)
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Assign(
          target: HirExpr(node: Index(target: arr_hir, index: idx_hir), span: sp),
          value: v_hir
        ), span: sp) :: acc, outer_locals, block_locals)
    | SpannedStmt(
      node: StmtTry(
        body: b,
        catch_arms: CatchArm(
          pattern: SpannedPattern(node: PatVariable(name: n, sigil: _), span: _),
          body: cb
        ) :: []
      ),
      span: sp
    ) :: rest ->
      // Legacy single-arm variable catch: catch param -> body. The try body and
      // catch body are child scopes; the catch param `n` is bound in the catch
      // body, so it joins that body's enclosing locals. If `n` shadows an
      // enclosing local it is alpha-renamed to a fresh slot (nexus-x9uw0):
      // codegen keys the catch-param wasm local by name, so reusing `n` would
      // share — and on entry clobber — the enclosing binding's slot. References
      // to it inside the catch body route to the fresh name via cb_entries; the
      // body's enclosing locals keep the ORIGINAL `n` so a deeper `let n` is
      // renamed past both slots.
      let catch_shadows = count_str_occ(name: n, xs: enclosing) > 0
      let catch_name = if catch_shadows then shadow_rename(
        name: n,
        outer_locals: enclosing
      ) else n end
      let cb_entries = if catch_shadows then
        symtab.rename_add(
          entries: symtab.rename_drop(entries, name: n),
          original: n,
          qualified: catch_name
        )
      else
        symtab.rename_drop(entries, name: n)
      end
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Try(
          body: convert_stmts_scoped(stmts: b, entries, outer_locals: enclosing),
          catch_param: catch_name,
          catch_body: convert_stmts_scoped(
            stmts: cb,
            entries: cb_entries,
            outer_locals: n :: enclosing
          )
        ), span: sp) :: acc, outer_locals, block_locals)
    | SpannedStmt(node: StmtTry(body: b, catch_arms: arms), span: sp) :: rest ->
      // Multi-arm or non-variable: desugar to catch __exn -> match __exn do ... end
      // Append a synthetic catch-all re-throw arm `| __exn_v -> throw __exn_v` so
      // a thrown exception matching no user arm PROPAGATES out via the function's
      // throws row (rather than falling through into the adjacent ctor branch and
      // reading a foreign payload). This also makes the synthesized match
      // exhaustive over `Exn`, so the exhaustiveness check passes without any
      // catch-body suppression hack.
      let user_cases = convert_catch_arms_to_match_cases(arms, entries, outer_locals: enclosing)
      // Only append the synthetic re-throw arm when the user arms don't already
      // include an irrefutable catch-all (a bare variable/wildcard pattern). If
      // they do, the user's own arm handles every variant and appending would
      // produce an unreachable (redundant) arm.
      let mir_cases = if catch_arms_have_catch_all(cases: user_cases) then
        user_cases
      else
        let rethrow_arm = HirMatchCase(
          pattern: hir.PVar(name: "__exn_v", sigil: SigilImmutable),
          body: [ HirStmt(
            node: hir.Expr(expr: HirExpr(
              node: hir.Raise(expr: HirExpr(
                node: hir.Variable(name: "__exn_v", sigil: SigilImmutable),
                span: sp
              )),
              span: sp
            )),
            span: sp
          ) ]
        )
        list.concat(xs: user_cases, ys: rethrow_arm :: [])
      end
      let match_expr = hir.Match(
        target: HirExpr(node: hir.Variable(name: "__exn", sigil: SigilImmutable), span: sp),
        cases: mir_cases
      )
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Try(
          body: convert_stmts_scoped(stmts: b, entries, outer_locals: enclosing),
          catch_param: "__exn",
          catch_body: [ HirStmt(node: hir.Expr(expr: HirExpr(node: match_expr, span: sp)), span: sp) ]
        ), span: sp) :: acc, outer_locals, block_locals)
  end
end

/** Find the last dot position in a string, scanning backwards from index i.
 *  Returns -1 if no dot is found. Used to split "obj.field" for field-access calls.
 */
let last_dot_pos = fn (s: string, i: i64) -> i64 do
  if i < 0 then return -1 end
  if str.char_code(s, idx: i) == 46 then return i end
  return last_dot_pos(s, i: i - 1)
end

let rename_strings = fn (names: [ string ], entries: [ RenameEntry ]) -> [ string ] do
  return rename_strings_go(names, entries, acc: [])
end

let rename_strings_go = fn (
  names: [ string ],
  entries: [ RenameEntry ],
  acc: [ string ]
) -> [ string ] do
  match names do
    | [] -> return list.reverse(xs: acc)
    | n :: rest ->
      return rename_strings_go(names: rest, entries, acc: symtab.rename(name: n, entries) :: acc)
  end
end

/** Extract handler variable names from inject handler expressions. */
let extract_handler_names = fn (exprs: [ SpannedExpr ]) -> [ string ] throws { HirError } do
  return extract_handler_names_go(exprs, acc: [])
end

let extract_handler_names_go = fn (
  exprs: [ SpannedExpr ],
  acc: [ string ]
) -> [ string ] throws { HirError } do
  match exprs do
    | [] -> return list.reverse(xs: acc)
    | e :: rest ->
      let name = extract_handler_name_from_expr(expr: e)
      return extract_handler_names_go(exprs: rest, acc: name :: acc)
  end
end

/** Extract handler name from an expression. Handles both simple variables and dotted access. */
let extract_handler_name_from_expr = fn (expr: SpannedExpr) -> string throws { HirError } do
  let SpannedExpr(node, span: sp) = expr
  return extract_name_from_node(node, span: sp)
end

let extract_name_from_node = fn (node: Expr, span: Span) -> string throws { HirError } do
  match node do
    | ExprVariable(name, sigil: _) -> return rdr.rdr_to_string(r: name)
    | ExprFieldAccess(target: t, field: fld) ->
      let base = extract_handler_name_from_expr(expr: t)
      return base ++ "." ++ fld
    | _ ->
      let Span(offset: _, line: l, col: c) = span
      throw SymbolNotFound(name: "<non-name expression>", kind: SkInjectHandler,
        context: "extract_name_from_node: inject handler must be a variable or dotted path (at line "
          ++ str.from_i64(val: l) ++ ", col " ++ str.from_i64(val: c) ++ ")")
  end
end

// Pure pattern-shape conversion lives in src/ir/hir/pattern.nx. The wrappers
// below stay here because they entangle pattern conversion with statement-body
// conversion (convert_stmts), which would create a circular import.

/** Convert match cases to HIR. */
let convert_match_cases = fn (
  cases: [ MatchCase ],
  entries: [ RenameEntry ],
  outer_locals: [ string ]
) -> [ HirMatchCase ] throws { HirError } do
  return convert_match_cases_go(cases, entries, outer_locals, acc: [])
end

let convert_match_cases_go = fn (
  cases: [ MatchCase ],
  entries: [ RenameEntry ],
  outer_locals: [ string ],
  acc: [ HirMatchCase ]
) -> [ HirMatchCase ] throws { HirError } do
  match cases do
    | [] -> return list.reverse(xs: acc)
    | MatchCase(pattern: p, body: b) :: rest ->
      // Lexical shadowing: the case body sees rename entries with every
      // pattern-bound variable name dropped, so PatVariable bindings shadow
      // any toplevel of the same name within the arm. The arm body is a child
      // scope whose enclosing locals are `outer_locals` plus the arm's pattern
      // binders, so a `let` in the body that shadows either is renamed.
      //
      // A pattern BINDER whose name is itself in `outer_locals` shadows an
      // enclosing local; codegen keys wasm slots by name, so leaving it as `b`
      // would reuse the enclosing binding's slot and the arm's bind would
      // clobber the surviving outer value (nexus-x9uw0). Rename such binders to
      // a fresh `b#depth` in the pattern and route references in the arm body to
      // it; non-shadowing binders keep their name. The body's enclosing-locals
      // multiset keeps the ORIGINAL binder names so a deeper `let b` in the body
      // is renamed PAST both the enclosing `b` slot and this arm's `b#depth`.
      let binders = hpat.pattern_binders(pat: p)
      let binder_renames = pattern_binder_renames(binders, outer_locals)
      let body_entries = merge_binder_renames(
        entries: symtab.rename_drop_many(entries, names: binders),
        binder_renames
      )
      return convert_match_cases_go(cases: rest, entries, outer_locals, acc: HirMatchCase(
          pattern: hpat.convert_pattern(pat: p, entries, binder_renames),
          body: convert_stmts_scoped(
            stmts: b,
            entries: body_entries,
            outer_locals: list.concat(xs: binders, ys: outer_locals)
          )
        ) :: acc)
  end
end

let convert_catch_arms_to_match_cases = fn (
  arms: [ CatchArm ],
  entries: [ RenameEntry ],
  outer_locals: [ string ]
) -> [ HirMatchCase ] throws { HirError } do
  return convert_catch_arms_go(arms, entries, outer_locals, acc: [])
end

/** True when any case is an irrefutable catch-all (bare variable / wildcard,
 *  or an or-pattern containing one). Used to decide whether the selective-catch
 *  desugar needs a synthetic re-throw arm appended. */
let catch_arms_have_catch_all = fn (cases: [ HirMatchCase ]) -> bool do
  match cases do
    | [] -> return false
    | HirMatchCase(pattern: p, body: _) :: rest ->
      if pat_is_catch_all(pat: p) then return true end
      return catch_arms_have_catch_all(cases: rest)
  end
end

let pat_is_catch_all = fn (pat: HirPatternKind) -> bool do
  match pat do
    | PWild -> return true
    | PVar(name: _, sigil: _) -> return true
    | POr(alts: a) -> return any_pat_is_catch_all(pats: a)
    | _ -> return false
  end
end

let any_pat_is_catch_all = fn (pats: [ HirPatternKind ]) -> bool do
  match pats do
    | [] -> return false
    | p :: rest ->
      if pat_is_catch_all(pat: p) then return true end
      return any_pat_is_catch_all(pats: rest)
  end
end

let convert_catch_arms_go = fn (
  arms: [ CatchArm ],
  entries: [ RenameEntry ],
  outer_locals: [ string ],
  acc: [ HirMatchCase ]
) -> [ HirMatchCase ] throws { HirError } do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | CatchArm(pattern: p, body: b) :: rest ->
      // A catch-arm pattern binder (including the bare catch-param of a
      // selective catch) that shadows an enclosing local is alpha-renamed to a
      // fresh slot, mirroring match arms (nexus-x9uw0).
      let binders = hpat.pattern_binders(pat: p)
      let binder_renames = pattern_binder_renames(binders, outer_locals)
      let body_entries = merge_binder_renames(
        entries: symtab.rename_drop_many(entries, names: binders),
        binder_renames
      )
      return convert_catch_arms_go(arms: rest, entries, outer_locals, acc: HirMatchCase(
          pattern: hpat.convert_pattern(pat: p, entries, binder_renames),
          body: convert_stmts_scoped(
            stmts: b,
            entries: body_entries,
            outer_locals: list.concat(xs: binders, ys: outer_locals)
          )
        ) :: acc)
  end
end

/** Convert AST params to HIR params. */
export let convert_params = fn (params: [ Param ]) -> [ HirParam ] do
  return convert_params_go(params, acc: [])
end

let convert_params_go = fn (params: [ Param ], acc: [ HirParam ]) -> [ HirParam ] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | Param(name: n, sigil: sig, typ: t) :: rest ->
      return convert_params_go(
        params: rest,
        acc: HirParam(label: n, name: n, sigil: sig, typ: t) :: acc
      )
  end
end

/** Extract bare parameter names (used for lexical-shadowing rename filtering). */
let param_names_of_params = fn (params: [ Param ]) -> [ string ] do
  return param_names_of_params_go(params, acc: [])
end

let param_names_of_params_go = fn (params: [ Param ], acc: [ string ]) -> [ string ] do
  match params do
    | [] -> return acc
    | Param(name: n, sigil: _, typ: _) :: rest ->
      return param_names_of_params_go(params: rest, acc: n :: acc)
  end
end

/** Convert a handler's HandlerArm list to HIR handler arms. Each arm's
 *  inner Function is converted via convert_one_function; the cont_binder
 *  (if any) propagates through to MIR/codegen for lowering to wasm
 *  stack-switching.
 */
let convert_handler_arms = fn (
  arms: [ HandlerArm ],
  entries: [ RenameEntry ],
  outer_locals: [ string ]
) -> [ HirHandlerArm ] throws { HirError } do
  return convert_handler_arms_go(arms, entries, outer_locals, acc: [])
end

let convert_handler_arms_go = fn (
  arms: [ HandlerArm ],
  entries: [ RenameEntry ],
  outer_locals: [ string ],
  acc: [ HirHandlerArm ]
) -> [ HirHandlerArm ] throws { HirError } do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | HandlerArm(arm: f, cont_binder: kb, span: _) :: rest ->
      // The `with @k` continuation binder is ARM-LOCAL: its `@k` references
      // inside the arm body must stay bare and must NOT be captured by a
      // same-named outer `let` rename entry (e.g. `let k = handler ... with
      // @k ...`). Dropping the binder from the rename map keeps the arm-body
      // `@k` reference name in sync with the cont_binder recorded on the arm,
      // so the force-once linearity check (check_handler_arm_konts) matches.
      let arm_entries = match kb do
        | Some(val: k) -> symtab.rename_drop(entries, name: k)
        | None -> entries
      end
      let hir_fn = convert_one_function(func: f, entries: arm_entries, outer_locals)
      return convert_handler_arms_go(
        arms: rest,
        entries,
        outer_locals,
        acc: HirHandlerArm(arm: hir_fn, cont_binder: kb) :: acc
      )
  end
end

/** Lowers an AST `Function` into a `HirFunction`. The `span` field threads
 *  the source position (e.g. the `fn` keyword for handler arms) through to
 *  HIR so LSP hover/definition queries land on byte-accurate offsets.
 *
 *  `file` is left empty here — only handler arms reach this entry, and
 *  `synthesize_handler` rewrites every arm with the binding's `source_file`
 *  before the arm is exposed via `extract_handler_functions`. Direct
 *  consumers of the unmangled arm function would see the empty sentinel
 * (design choice ii).
 */
let convert_one_function = fn (
  func: Function,
  entries: [ RenameEntry ],
  outer_locals: [ string ]
) -> HirFunction throws { HirError } do
  let Function(
    name: n,
    is_public: _,
    type_params: tps,
    params: ps,
    ret_type: rt,
    requires: req,
    throw_row: tw,
    body: b,
    span: sp
  ) = func
  // Lexical shadowing: parameter names hide any toplevel rename inside the body.
  // The body's enclosing locals carry the inject-site captures (`outer_locals`)
  // plus this arm function's own params, so a `let` in the body that shadows
  // either is renamed to a fresh slot.
  let pnames = param_names_of_params(params: ps)
  let inner_entries = symtab.rename_drop_many(entries, names: pnames)
  return HirFunction(
    name: n,
    type_params: tps,
    params: convert_params(params: ps),
    ret_type: rt,
    throw_row: tw,
    body: EagerBody(stmts: convert_stmts_scoped(
      stmts: b,
      entries: inner_entries,
      outer_locals: list.concat(xs: pnames, ys: outer_locals)
    )),
    span: sp,
    file: "",
    // Preserve the source-level require row for typecheck-time wfCap
    // enforcement.
    requires: req
  )
end

let infer_tparams_from_expr = fn (expr: Expr) -> [ string ] do
  if let ExprLambda(
    type_params: tps,
    params: _,
    ret_type: _,
    requires: _,
    throw_row: _,
    body: _
  ) = expr then
    return tps
  else
    return []
  end
end

let infer_params_from_expr = fn (expr: Expr) -> [ HirParam ] do
  if let ExprLambda(
    type_params: _,
    params: ps,
    ret_type: _,
    requires: _,
    throw_row: _,
    body: _
  ) = expr then
    return convert_params(params: ps)
  else
    return []
  end
end

let infer_ret_from_expr = fn (expr: Expr) -> TypeExpr do
  if let ExprLambda(
    type_params: _,
    params: _,
    ret_type: rt,
    requires: _,
    throw_row: _,
    body: _
  ) = expr then
    return rt
  else
    return TyUnit
  end
end

let infer_requires_from_expr = fn (expr: Expr) -> TypeExpr do
  if let ExprLambda(
    type_params: _,
    params: _,
    ret_type: _,
    requires: req,
    throw_row: _,
    body: _
  ) = expr then
    return req
  else
    return TyRow(types: [], rest: None)
  end
end

let infer_throw_row_from_expr = fn (expr: Expr) -> TypeExpr do
  if let ExprLambda(
    type_params: _,
    params: _,
    ret_type: _,
    requires: _,
    throw_row: tw,
    body: _
  ) = expr then
    return tw
  else
    return TyRow(types: [], rest: None)
  end
end
