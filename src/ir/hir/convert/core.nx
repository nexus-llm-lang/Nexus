/**
 * hir/convert/core: AST → HIR expression and statement conversion.
 *
 * This module holds the entire expr/stmt/match-case/handler-arm conversion
 * SCC. `convert_expr` and `convert_stmts` are mutually recursive (each
 * calls the other for sub-expressions and statement bodies), so splitting
 * them into separate files would create circular imports. Per the vn6n.5
 * strategy, we leave the SCC together and extract only DAG-leaf clusters.
 *
 * Pattern-shape conversion (convert_pattern, pattern_binders) lives in
 * src/ir/hir/pattern.nx, which is a DAG-leaf dependency of this module.
 *
 * Owns:
 * - convert_expr — SpannedExpr → HirExpr (the primary public entry point)
 * - convert_expr_toplevel — lazy-body stub for top-level lambdas
 * - convert_stmts — SpannedStmt list → HirStmt list
 * - convert_params — Param list → HirParam list (exported for build/defs.nx)
 * - convert_match_cases, convert_catch_arms — match/catch lowering
 * - convert_handler_arms, convert_one_function — handler arm lowering
 * - desugar_list — [a,b,c] → a::b::c::[] lowering
 * - ctor-arg sorting and conversion helpers
 *
 * Does not own:
 * - Top-level definition processing (see hir/build/defs.nx)
 * - HirAccum assembly (see hir/build/accum.nx)
 * - Pattern-shape conversion (see src/ir/hir/pattern.nx)
 */
import { Span } from "src/common/token.nx"
import { Sigil, SigilImmutable, SigilLazy, SigilMutable, TypeExpr, TyUnit, TyRow, Expr, ExprLiteral, ExprVariable, ExprBinaryOp, ExprUnaryOp, ExprBorrow, ExprCall, ExprConstructor, ExprRecord, ExprArray, ExprIndex, ExprFieldAccess, ExprIf, ExprMatch, ExprWhile, ExprFor, ExprLambda, ExprRaise, ExprForce, ExprExternal, ExprHandler, ExprList, StmtLet, StmtLetPattern, StmtExpr, StmtReturn, StmtAssign, StmtIndexAssign, StmtTry, StmtInject, PatVariable, SpannedExpr, SpannedStmt, SpannedPattern, Param, Function, HandlerArm, MatchCase, CallArg, CtorArg, NamedExpr, CatchArm, Unqual, TyLazy } from "src/common/ast.nx"
import { HirError } from "src/common/error.nx"
import { SymbolNotFound, SkInjectHandler } from "src/backend/errors.nx"
import * as rdr from "src/ir/shared/rdrname.nx"
import { RenameEntry }, * as symtab from "src/ir/shared/symtab.nx"
import * as str from "std:str"
import * as list from "std:list"
import { HirParam, HirExpr, HirStmt, HirExprKind, HirCallArg, HirNamedExpr, HirMatchCase, EagerBody, LazyBody, HirFunction, HirHandlerArm }, * as hir from "src/ir/hir/types.nx"
import * as hpat from "src/ir/hir/pattern.nx"


/** Convert an AST expression (SpannedExpr) to HIR. */
export let convert_expr = fn (expr: SpannedExpr, entries: [RenameEntry]) -> HirExpr throws { HirError } do
  let SpannedExpr(node, span: sp) = expr
  let hir = match node do
    | ExprLiteral(lit) ->
      Literal(lit)
    | ExprVariable(name, sigil: sig) ->
      let renamed = symtab.rename(name: rdr.rdr_to_string(r: name), entries)
      match sig do
        | SigilLazy ->
          Force(expr: HirExpr(node: Variable(name: renamed, sigil: SigilImmutable), span: sp))
        | _ ->
          Variable(name: renamed, sigil: sig)
      end
    | ExprBinaryOp(left: l, op, right: r) ->
      BinOp(
        left: convert_expr(expr: l, entries),
        op,
        right: convert_expr(expr: r, entries)
      )
    | ExprUnaryOp(op, operand: o) ->
      UnOp(op, operand: convert_expr(expr: o, entries))
    | ExprBorrow(name, sigil: sig) ->
      Borrow(name: symtab.rename(name, entries), sigil: sig)
    | ExprCall(func: f, args) ->
      Call(
        func: symtab.rename(name: rdr.rdr_to_string(r: f), entries),
        args: convert_call_args(args, entries)
      )
    | ExprConstructor(name: v, args, sigil: sig) ->
      let HirCtorResult(labels: ctor_labels, args: ctor_args) = convert_ctor_args(args, entries)
      Ctor(
        variant: rdr.rdr_occ(r: v),
        args: ctor_args,
        labels: ctor_labels,
        sigil: sig
      )
    | ExprRecord(fields: fs) ->
      Record(fields: convert_named_exprs(exprs: fs, entries))
    | ExprArray(elements: es) ->
      Array(elems: convert_expr_list(exprs: es, entries))
    | ExprIndex(target: t, index: i) ->
      Index(
        target: convert_expr(expr: t, entries),
        index: convert_expr(expr: i, entries)
      )
    | ExprFieldAccess(target: t, field: f) ->
      // Module-qualified value access: `mod.name` in value position parses as
      // FieldAccess(Variable("mod"), "name"). If "mod.name" has a rename
      // entry (added for wildcard-aliased imports), resolve as a qualified
      // variable reference rather than a struct field access. Without this,
      // `wdefs.vt_i32` compiles as a field access on an undefined variable
      // and silently returns garbage — breaking self-hosted codegen.
      let SpannedExpr(node: target_node, span: _) = t
      match target_node do
        | ExprVariable(name: Unqual(name: mod_name), sigil: _) ->
          let qualified_key = mod_name ++ "." ++ f
          if symtab.rename_has(name: qualified_key, entries) then
            Variable(name: symtab.rename(name: qualified_key, entries), sigil: SigilImmutable)
          else
            FieldAccess(target: convert_expr(expr: t, entries), field: f)
          end
        | _ ->
          FieldAccess(target: convert_expr(expr: t, entries), field: f)
      end
    | ExprIf(cond: c, then_branch: tb, else_branch: eb) ->
      let hir_else = match eb do
        | [] -> None
        | _ :: _ -> Some(val: convert_stmts(stmts: eb, entries))
      end
      If(
        cond: convert_expr(expr: c, entries),
        then_branch: convert_stmts(stmts: tb, entries),
        else_branch: hir_else
      )
    | ExprMatch(target: t, cases: cs) ->
      Match(
        target: convert_expr(expr: t, entries),
        cases: convert_match_cases(cases: cs, entries)
      )
    | ExprWhile(cond: c, body: b) ->
      While(
        cond: convert_expr(expr: c, entries),
        body: convert_stmts(stmts: b, entries)
      )
    | ExprFor(var: v, start: s, end_expr: e, body: b) ->
      let body_entries = symtab.rename_drop(entries, name: v)
      For(
        var: v,
        start: convert_expr(expr: s, entries),
        end_expr: convert_expr(expr: e, entries),
        body: convert_stmts(stmts: b, entries: body_entries)
      )
    | ExprLambda(type_params: tps, params: ps, ret_type: rt, requires: _, throw_row: _, body: b) ->
      // Lexical shadowing: drop rename entries whose `original` matches a
      // parameter name so references inside the body resolve to the local
      // (parameter) at codegen instead of any toplevel of the same name.
      let inner_entries = symtab.rename_drop_many(entries, names: param_names_of_params(params: ps))
      Lambda(
        type_params: tps,
        params: convert_params(params: ps),
        ret_type: rt,
        body: convert_stmts(stmts: b, entries: inner_entries)
      )
    | ExprRaise(value: e) ->
      Raise(expr: convert_expr(expr: e, entries))
    | ExprForce(value: e) ->
      Force(expr: convert_expr(expr: e, entries))
    | ExprExternal(symbol: sym, type_params: tps, arg_names: names, typ: t) ->
      ExternalRef(symbol: sym, type_params: tps, arg_names: names, typ: t)
    | ExprHandler(coeffect_name: pname, requires: req, arms) ->
      Handler(cap_name: symtab.rename(name: pname, entries), requires: req, arms: convert_handler_arms(arms, entries))
    | ExprList(elements: es) ->
      // Extract inner node from desugar_list result — span comes from outer wrapping
      let HirExpr(node: desugared, span: _) = desugar_list(elems: es, entries, span: sp)
      desugared
  end
  return HirExpr(node: hir, span: sp)
end

/** Convert a top-level AST expression, ALWAYS skipping body conversion.
 *  Returns Lambda with empty body for everything — the caller (process_tl_let)
 *  matches on the HirExprKind to distinguish Lambda from External/Handler.
 *  Non-Lambda TLLets get LazyBody too, but resolve_lazy_bodies handles the
 *  empty-body case gracefully (returns empty stmts).
 */
export let convert_expr_toplevel = fn (expr: SpannedExpr, entries: [RenameEntry]) -> HirExpr throws { HirError } do
  let SpannedExpr(node, span: sp) = expr
  let tps = infer_tparams_from_expr(expr: node)
  let ps = infer_params_from_expr(expr: node)
  let rt = infer_ret_from_expr(expr: node)
  return HirExpr(node: Lambda(type_params: tps, params: ps, ret_type: rt, body: []), span: sp)
end

/** Desugar [a, b, c] -> a :: b :: c :: []
 *  Args are unlabeled, so they must be in alphabetical field order: (rest, v)
 *  Each synthesised Cons inherits the head element's span so type errors land
 *  on the offending element; the terminating Nil and the outermost wrapper
 *  inherit the surrounding `[...]` span so errors against the empty list shape
 *  (or the whole literal) still point at user-visible source.
 */
let desugar_list = fn (elems: [SpannedExpr], entries: [RenameEntry], span: Span) -> HirExpr throws { HirError } do
  let reversed = list.reverse(xs: elems)
  let inner = desugar_list_go(elems: reversed, entries,
    acc: HirExpr(node: Ctor(variant: "Nil", args: [], labels: [], sigil: SigilImmutable), span))
  let HirExpr(node: result_node, span: _) = inner
  return HirExpr(node: result_node, span)
end

let desugar_list_go = fn (elems: [SpannedExpr], entries: [RenameEntry], acc: HirExpr) -> HirExpr throws { HirError } do
  match elems do
    | [] -> return acc
    | e :: rest ->
      let SpannedExpr(node: _, span: head_sp) = e
      let head = convert_expr(expr: e, entries)
      return desugar_list_go(elems: rest, entries,
        acc: HirExpr(node: Ctor(variant: "Cons", args: [acc, head], labels: [], sigil: SigilImmutable), span: head_sp))
  end
end

let convert_call_args = fn (args: [CallArg], entries: [RenameEntry]) -> [HirCallArg] throws { HirError } do
  return convert_call_args_go(args, entries, acc: [])
end

let convert_call_args_go = fn (args: [CallArg], entries: [RenameEntry], acc: [HirCallArg]) -> [HirCallArg] throws { HirError } do
  match args do
    | [] -> return list.reverse(xs: acc)
    | CallArg(name: l, value: v) :: rest ->
      return convert_call_args_go(args: rest, entries, acc: HirCallArg(label: l, value: convert_expr(expr: v, entries)) :: acc)
  end
end


let str_less_than_loop = fn (a: string, b: string, idx: i64, la: i64, lb: i64) -> bool do
  if idx >= la then
    return idx < lb
  else if idx >= lb then
    return false
  else
    let ca = str.char_code(s: a, idx)
    let cb = str.char_code(s: b, idx)
    if ca < cb then
      return true
    else if ca > cb then
      return false
    else
      return str_less_than_loop(a, b, idx: idx + 1, la, lb)
    end
  end
end

let str_less_than = fn (a: string, b: string) -> bool do
  return str_less_than_loop(a, b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end

let ctor_arg_name = fn (arg: CtorArg) -> string do
  match arg do
    | CtorArg(name: n, value: _) -> return n
  end
end

let insert_ctor_arg = fn (arg: CtorArg, sorted: [CtorArg]) -> [CtorArg] do
  return insert_ctor_arg_go(arg, sorted, acc: [])
end

let insert_ctor_arg_go = fn (arg: CtorArg, sorted: [CtorArg], acc: [CtorArg]) -> [CtorArg] do
  match sorted do
    | [] -> return rev_ctor_arg(lst: acc, out: [arg])
    | head :: rest ->
      if str_less_than(a: ctor_arg_name(arg), b: ctor_arg_name(arg: head)) then
        return rev_ctor_arg(lst: acc, out: arg :: sorted)
      else
        return insert_ctor_arg_go(arg, sorted: rest, acc: head :: acc)
      end
  end
end

let sort_ctor_args = fn (args: [CtorArg]) -> [CtorArg] do
  return sort_ctor_args_go(args, sorted: [])
end

let sort_ctor_args_go = fn (args: [CtorArg], sorted: [CtorArg]) -> [CtorArg] do
  match args do
    | [] -> return sorted
    | a :: rest -> return sort_ctor_args_go(args: rest, sorted: insert_ctor_arg(arg: a, sorted))
  end
end

// Bundles the sorted user-supplied label list alongside the converted HIR exprs.
// Both lists are parallel and in the same (alphabetical) order; typecheck uses
// `labels` to enforce T-Ctor {ℓ} = {ℓ'}.
type HirCtorResult = HirCtorResult(labels: [string], args: [HirExpr])

let convert_ctor_args = fn (args: [CtorArg], entries: [RenameEntry]) -> HirCtorResult throws { HirError } do
  return convert_ctor_args_inner(args: sort_ctor_args(args), entries)
end

let convert_ctor_args_inner = fn (args: [CtorArg], entries: [RenameEntry]) -> HirCtorResult throws { HirError } do
  return convert_ctor_args_inner_go(args, entries, acc_labels: [], acc_exprs: [])
end

let convert_ctor_args_inner_go = fn (
  args: [CtorArg], entries: [RenameEntry], acc_labels: [string], acc_exprs: [HirExpr]
) -> HirCtorResult throws { HirError } do
  match args do
    | [] ->
      return HirCtorResult(
        labels: list.reverse(xs: acc_labels),
        args: list.reverse(xs: acc_exprs)
      )
    | CtorArg(name: n, value: v) :: rest ->
      return convert_ctor_args_inner_go(
        args: rest,
        entries,
        acc_labels: n :: acc_labels,
        acc_exprs: convert_expr(expr: v, entries) :: acc_exprs
      )
  end
end

let convert_named_exprs = fn (exprs: [NamedExpr], entries: [RenameEntry]) -> [HirNamedExpr] throws { HirError } do
  return convert_named_exprs_go(exprs, entries, acc: [])
end

let convert_named_exprs_go = fn (exprs: [NamedExpr], entries: [RenameEntry], acc: [HirNamedExpr]) -> [HirNamedExpr] throws { HirError } do
  match exprs do
    | [] -> return list.reverse(xs: acc)
    | NamedExpr(name: n, value: v) :: rest ->
      return convert_named_exprs_go(exprs: rest, entries, acc: HirNamedExpr(name: n, value: convert_expr(expr: v, entries)) :: acc)
  end
end

let convert_expr_list = fn (exprs: [SpannedExpr], entries: [RenameEntry]) -> [HirExpr] throws { HirError } do
  return convert_expr_list_go(exprs, entries, acc: [])
end

let convert_expr_list_go = fn (exprs: [SpannedExpr], entries: [RenameEntry], acc: [HirExpr]) -> [HirExpr] throws { HirError } do
  match exprs do
    | [] -> return list.reverse(xs: acc)
    | e :: rest ->
      return convert_expr_list_go(exprs: rest, entries, acc: convert_expr(expr: e, entries) :: acc)
  end
end


/** Convert AST statements to HIR statements. */
let convert_stmts = fn (stmts: [SpannedStmt], entries: [RenameEntry]) -> [HirStmt] throws { HirError } do
  return convert_stmts_go(stmts, entries, acc: [])
end

let convert_stmts_go = fn (stmts: [SpannedStmt], entries: [RenameEntry], acc: [HirStmt]) -> [HirStmt] throws { HirError } do
  match stmts do
    | [] -> return rev_hir_stmt(lst: acc, out: [])
    | SpannedStmt(node: StmtLet(name: n, sigil: sig, typ: t, value: v), span: sp) :: rest ->
      let SpannedExpr(node: _, span: vsp) = v
      let hir_val = match sig do
        | SigilLazy ->
          HirExpr(node: Thunk(body: convert_expr(expr: v, entries)), span: vsp)
        | _ ->
          convert_expr(expr: v, entries)
      end
      // Lexical shadowing: subsequent statements see entries with `n` dropped
      // so references resolve to the local binding, not any toplevel of the
      // same name. The RHS itself is converted with the outer entries.
      let inner_entries = symtab.rename_drop(entries, name: n)
      return convert_stmts_go(stmts: rest, entries: inner_entries, acc: HirStmt(node: Let(name: n, sigil: sig, typ: t, value: hir_val), span: sp) :: acc)
    | SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp) :: rest ->
      // Desugar: let Pattern = expr; rest → match expr do case Pattern -> rest end
      // The remaining stmts form the case body and must see entries with every
      // pattern-bound variable dropped (lexical shadowing).
      let body_entries = symtab.rename_drop_many(entries, names: hpat.pattern_binders(pat))
      let case_body = convert_stmts(stmts: rest, entries: body_entries)
      let match_case = HirMatchCase(
        pattern: hpat.convert_pattern(pat, entries),
        body: case_body
      )
      return rev_hir_stmt(lst: acc, out: [HirStmt(node: Expr(expr: HirExpr(node: Match(
          target: convert_expr(expr: v, entries),
          cases: [match_case]
        ), span: sp)), span: sp)])
    | SpannedStmt(node: StmtExpr(expr: e), span: sp) :: rest ->
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Expr(expr: convert_expr(expr: e, entries)), span: sp) :: acc)
    | SpannedStmt(node: StmtReturn(value: e), span: sp) :: rest ->
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Return(expr: convert_expr(expr: e, entries)), span: sp) :: acc)
    | SpannedStmt(node: StmtAssign(target: t, value: v), span: sp) :: rest ->
      // Synthetic Variable target inherits the assignment statement span so
      // unbound-target errors land on the user's `x = ...` line rather than 0.
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Assign(
          target: HirExpr(node: Variable(name: symtab.rename(name: t, entries), sigil: SigilMutable), span: sp),
          value: convert_expr(expr: v, entries)
        ), span: sp) :: acc)
    | SpannedStmt(node: StmtIndexAssign(target: arr, index: idx, value: v), span: sp) :: rest ->
      // Indexed assignment `arr[idx] <- val`: convert to HIR
      // Assign with an Index target. HIR Assign already takes HirExpr, so
      // downstream IR / typecheck see a uniform shape.
      let arr_hir = convert_expr(expr: arr, entries)
      let idx_hir = convert_expr(expr: idx, entries)
      let v_hir = convert_expr(expr: v, entries)
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Assign(
          target: HirExpr(node: Index(target: arr_hir, index: idx_hir), span: sp),
          value: v_hir
        ), span: sp) :: acc)
    | SpannedStmt(node: StmtTry(body: b, catch_arms: CatchArm(pattern: SpannedPattern(node: PatVariable(name: n, sigil: _), span: _), body: cb) :: []), span: sp) :: rest ->
      // Legacy single-arm variable catch: catch param -> body
      let cb_entries = symtab.rename_drop(entries, name: n)
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Try(
          body: convert_stmts(stmts: b, entries),
          catch_param: n,
          catch_body: convert_stmts(stmts: cb, entries: cb_entries)
        ), span: sp) :: acc)
    | SpannedStmt(node: StmtTry(body: b, catch_arms: arms), span: sp) :: rest ->
      // Multi-arm or non-variable: desugar to catch __exn -> match __exn do ... end
      let mir_cases = convert_catch_arms_to_match_cases(arms, entries)
      let match_expr = hir.Match(target: HirExpr(node: hir.Variable(name: "__exn", sigil: SigilImmutable), span: sp), cases: mir_cases)
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Try(
          body: convert_stmts(stmts: b, entries),
          catch_param: "__exn",
          catch_body: [HirStmt(node: hir.Expr(expr: HirExpr(node: match_expr, span: sp)), span: sp)]
        ), span: sp) :: acc)
    | SpannedStmt(node: StmtInject(handlers: hs, body: b), span: sp) :: rest ->
      let handler_names = extract_handler_names(exprs: hs)
      let qualified_handlers = rename_strings(names: handler_names, entries)
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Inject(
          handlers: qualified_handlers,
          body: convert_stmts(stmts: b, entries)
        ), span: sp) :: acc)
  end
end

let rename_strings = fn (names: [string], entries: [RenameEntry]) -> [string] do
  return rename_strings_go(names, entries, acc: [])
end

let rename_strings_go = fn (names: [string], entries: [RenameEntry], acc: [string]) -> [string] do
  match names do
    | [] -> return list.reverse(xs: acc)
    | n :: rest ->
      return rename_strings_go(names: rest, entries, acc: symtab.rename(name: n, entries) :: acc)
  end
end

/** Extract handler variable names from inject handler expressions. */
let extract_handler_names = fn (exprs: [SpannedExpr]) -> [string] throws { HirError } do
  return extract_handler_names_go(exprs, acc: [])
end

let extract_handler_names_go = fn (exprs: [SpannedExpr], acc: [string]) -> [string] throws { HirError } do
  match exprs do
    | [] -> return list.reverse(xs: acc)
    | e :: rest ->
      let name = extract_handler_name_from_expr(expr: e)
      return extract_handler_names_go(exprs: rest, acc: name :: acc)
  end
end

/** Extract handler name from an expression. Handles both simple variables and dotted access. */
let extract_handler_name_from_expr = fn (expr: SpannedExpr) -> string throws { HirError } do
  let SpannedExpr(node, span: sp) = expr
  return extract_name_from_node(node, span: sp)
end

let extract_name_from_node = fn (node: Expr, span: Span) -> string throws { HirError } do
  match node do
    | ExprVariable(name, sigil: _) -> return rdr.rdr_to_string(r: name)
    | ExprFieldAccess(target: t, field: fld) ->
      let base = extract_handler_name_from_expr(expr: t)
      return base ++ "." ++ fld
    | _ ->
      let Span(offset: _, line: l, col: c) = span
      throw SymbolNotFound(name: "<non-name expression>", kind: SkInjectHandler,
        context: "extract_name_from_node: inject handler must be a variable or dotted path (at line "
          ++ str.from_i64(val: l) ++ ", col " ++ str.from_i64(val: c) ++ ")")
  end
end

// Pure pattern-shape conversion lives in src/ir/hir/pattern.nx. The wrappers
// below stay here because they entangle pattern conversion with statement-body
// conversion (convert_stmts), which would create a circular import.

/** Convert match cases to HIR. */
let convert_match_cases = fn (cases: [MatchCase], entries: [RenameEntry]) -> [HirMatchCase] throws { HirError } do
  return convert_match_cases_go(cases, entries, acc: [])
end

let convert_match_cases_go = fn (cases: [MatchCase], entries: [RenameEntry], acc: [HirMatchCase]) -> [HirMatchCase] throws { HirError } do
  match cases do
    | [] -> return list.reverse(xs: acc)
    | MatchCase(pattern: p, body: b) :: rest ->
      // Lexical shadowing: the case body sees rename entries with every
      // pattern-bound variable name dropped, so PatVariable bindings shadow
      // any toplevel of the same name within the arm.
      let body_entries = symtab.rename_drop_many(entries, names: hpat.pattern_binders(pat: p))
      return convert_match_cases_go(cases: rest, entries, acc: HirMatchCase(
          pattern: hpat.convert_pattern(pat: p, entries),
          body: convert_stmts(stmts: b, entries: body_entries)
        ) :: acc)
  end
end

let convert_catch_arms_to_match_cases = fn (arms: [CatchArm], entries: [RenameEntry]) -> [HirMatchCase] throws { HirError } do
  return convert_catch_arms_go(arms, entries, acc: [])
end

let convert_catch_arms_go = fn (arms: [CatchArm], entries: [RenameEntry], acc: [HirMatchCase]) -> [HirMatchCase] throws { HirError } do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | CatchArm(pattern: p, body: b) :: rest ->
      let body_entries = symtab.rename_drop_many(entries, names: hpat.pattern_binders(pat: p))
      let mc = HirMatchCase(pattern: hpat.convert_pattern(pat: p, entries), body: convert_stmts(stmts: b, entries: body_entries))
      return convert_catch_arms_go(arms: rest, entries, acc: mc :: acc)
  end
end


/** Convert AST params to HIR params. */
export let convert_params = fn (params: [Param]) -> [HirParam] do
  return convert_params_go(params, acc: [])
end

let convert_params_go = fn (params: [Param], acc: [HirParam]) -> [HirParam] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | Param(name: n, sigil: sig, typ: t) :: rest ->
      return convert_params_go(params: rest, acc: HirParam(label: n, name: n, sigil: sig, typ: t) :: acc)
  end
end

/** Extract bare parameter names (used for lexical-shadowing rename filtering). */
let param_names_of_params = fn (params: [Param]) -> [string] do
  return param_names_of_params_go(params, acc: [])
end

let param_names_of_params_go = fn (params: [Param], acc: [string]) -> [string] do
  match params do
    | [] -> return acc
    | Param(name: n, sigil: _, typ: _) :: rest ->
      return param_names_of_params_go(params: rest, acc: n :: acc)
  end
end

/** Convert a handler's HandlerArm list to HIR handler arms. Each arm's
 *  inner Function is converted via convert_one_function; the cont_binder
 *  (if any) propagates through to MIR/codegen for lowering to wasm
 *  stack-switching.
 */
let convert_handler_arms = fn (arms: [HandlerArm], entries: [RenameEntry]) -> [HirHandlerArm] throws { HirError } do
  return convert_handler_arms_go(arms, entries, acc: [])
end

let convert_handler_arms_go = fn (arms: [HandlerArm], entries: [RenameEntry], acc: [HirHandlerArm]) -> [HirHandlerArm] throws { HirError } do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | HandlerArm(arm: f, cont_binder: kb, span: _) :: rest ->
      let hir_fn = convert_one_function(func: f, entries)
      return convert_handler_arms_go(arms: rest, entries, acc: HirHandlerArm(arm: hir_fn, cont_binder: kb) :: acc)
  end
end

/** Lowers an AST `Function` into a `HirFunction`. The `span` field threads
 *  the source position (e.g. the `fn` keyword for handler arms) through to
 *  HIR so LSP hover/definition queries land on byte-accurate offsets.
 *
 *  `file` is left empty here — only handler arms reach this entry, and
 *  `synthesize_handler` rewrites every arm with the binding's `source_file`
 *  before the arm is exposed via `extract_handler_functions`. Direct
 *  consumers of the unmangled arm function would see the empty sentinel
 * (design choice ii).
 */
let convert_one_function = fn (func: Function, entries: [RenameEntry]) -> HirFunction throws { HirError } do
  let Function(name: n, is_public: _, type_params: tps, params: ps, ret_type: rt, requires: req, throw_row: tw, body: b, span: sp) = func
  // Lexical shadowing: parameter names hide any toplevel rename inside the body.
  let inner_entries = symtab.rename_drop_many(entries, names: param_names_of_params(params: ps))
  return HirFunction(
    name: n,
    type_params: tps,
    params: convert_params(params: ps),
    ret_type: rt,
    throw_row: tw,
    body: EagerBody(stmts: convert_stmts(stmts: b, entries: inner_entries)),
    span: sp,
    file: "",
    // Preserve the source-level require row for typecheck-time wfCap
    // enforcement.
    requires: req
  )
end


let infer_tparams_from_expr = fn (expr: Expr) -> [string] do
  if let ExprLambda(type_params: tps, params: _, ret_type: _, requires: _, throw_row: _, body: _) = expr then
    return tps
  else
    return []
  end
end

let infer_params_from_expr = fn (expr: Expr) -> [HirParam] do
  if let ExprLambda(type_params: _, params: ps, ret_type: _, requires: _, throw_row: _, body: _) = expr then
    return convert_params(params: ps)
  else
    return []
  end
end

let infer_ret_from_expr = fn (expr: Expr) -> TypeExpr do
  if let ExprLambda(type_params: _, params: _, ret_type: rt, requires: _, throw_row: _, body: _) = expr then
    return rt
  else
    return TyUnit
  end
end


let rev_ctor_arg = fn (lst: [CtorArg], out: [CtorArg]) -> [CtorArg] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_ctor_arg(lst: rest, out: x :: out)
  end
end

let rev_hir_stmt = fn (lst: [HirStmt], out: [HirStmt]) -> [HirStmt] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_stmt(lst: rest, out: x :: out)
  end
end
