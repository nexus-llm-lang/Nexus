/**
 * demand: Iterative lazy-body resolution for the Nexus self-hosting compiler.
 *
 * After HIR build, many functions carry LazyBody — the raw AST is stashed
 * instead of converted, so unused imports don't pay the convert_expr cost.
 * This module drives the fixed-point dance that turns reachable LazyBody
 * functions into EagerBody:
 *
 *   1. strip_lazy over the current set gives stubs for reachability.
 *   2. collect_reachable + filter_reachable_functions narrows the work set.
 *   3. resolve_all_lazy_via_convert runs convert_expr on each LazyBody.
 *   4. The newly resolved bodies may expose new callees — loop until the
 *      reachable set stops growing (or max_rounds is hit).
 *
 * Extracted from main.nx to sit as a dedicated pipeline stage alongside
 * hir.nx / resolve.nx / imports.nx.
 */

import { Literal, LitInt, LitFloat, LitString, LitChar, LitBool, LitUnit } from "src/types/vocab.nx"
import { TypeExpr, TyI64, TyF64, TyString, TyChar, TyBool, TyUnit } from "src/types/type_expr.nx"
import { Span } from "src/types/span.nx"
import { HirFunction, HirParam, HirBody, EagerBody, LazyBody,
         HirStmt, HirExpr,
         HirHandlerBindingEntry } from "src/ir/hir/types.nx"
import { convert_expr } from "src/ir/hir/convert/core.nx"
import { with_body } from "src/ir/hir/func_update.nx"
import * as reach from "src/ir/hir/reachability.nx"
import { HirError } from "src/diagnostics/error.nx"
import { StringMap, Found, Missing } from "std:stringmap"
import * as smap from "std:stringmap"

/** Iterative resolve: filter by reachability, resolve LazyBody, repeat.
 *  Each round discovers new reachable functions from resolved bodies.
 */
export let iterative_resolve = fn (
  funcs: [ HirFunction ],
  hb: [ HirHandlerBindingEntry ],
  max_rounds: i64
) -> [ HirFunction ] throws { HirError } do
  return iterative_resolve_go(
    all_funcs: funcs,
    current: funcs,
    current_filtered: false,
    hb,
    max_rounds
  )
end

/** Resolve every LazyBody to EagerBody without applying the reachability
 *  filter. Driver-mode `iterative_resolve` drops unreachable defs because
 *  codegen never emits them; the LSP wants full coverage so cross-file
 *  errors in unreachable-but-typechecked-on-disk-loaded modules surface
 *  as diagnostics. The bodies are resolved in a single pass — cycles in
 *  LazyBody are not possible (LazyBody only wraps the immediate raw AST,
 *  not a thunk that re-enters convert_expr).
 */
export let resolve_all_lazy_no_filter = fn (funcs: [ HirFunction ]) -> [ HirFunction ] throws { HirError } do
  return resolve_all_lazy_via_convert(funcs)
end

let iterative_resolve_go = fn (all_funcs: [ HirFunction ], current: [ HirFunction ], current_filtered: bool,
    hb: [ HirHandlerBindingEntry ], max_rounds: i64)
    -> [ HirFunction ] throws { HirError } do
  if max_rounds <= 0 then return strip_lazy(funcs: current) end
  let filtered = if current_filtered then current else
    reach.filter_reachable_functions(functions: all_funcs,
      reachable: reach.collect_reachable(
        functions: strip_lazy(funcs: current),
        handler_bindings: hb
      ))
  end
  let resolved = resolve_all_lazy_via_convert(funcs: filtered)
  let new_reachable = reach.collect_reachable(functions: resolved, handler_bindings: hb)
  let new_filtered = reach.filter_reachable_functions(
    functions: all_funcs,
    reachable: new_reachable
  )
  let grew = list_longer(a: new_filtered, b: filtered)
  let merged = merge_resolved(orig: new_filtered, resolved)
  if grew then
    let updated_all = merge_resolved(orig: all_funcs, resolved)
    return iterative_resolve_go(
      all_funcs: updated_all,
      current: merged,
      current_filtered: true,
      hb,
      max_rounds: max_rounds - 1
    )
  else
    return merged
  end
end

let list_longer = fn (a: [ HirFunction ], b: [ HirFunction ]) -> bool do
  match a do
    | [] -> return false
    | _ :: ar ->
      match b do
        | [] -> return true
        | _ :: br -> return list_longer(a: ar, b: br)
      end
  end
end

/** Merge: for functions in orig that are already resolved, keep the resolved version.
 *  For functions in orig that are still LazyBody, keep them for the next round.
 */
let merge_resolved = fn (orig: [ HirFunction ], resolved: [ HirFunction ]) -> [ HirFunction ] do
  let %index = build_resolved_index(resolved, acc: smap.empty())
  let merged = merge_resolved_go(orig, index: &index)
  smap.free(map: %index)
  return merged
end

let merge_resolved_go = fn (orig: [ HirFunction ], index: &StringMap<HirFunction>) -> [ HirFunction ] do
  match orig do
    | [] -> return []
    | HirFunction(
      name: n,
      type_params: tps,
      params: ps,
      ret_type: rt,
      throw_row: tw,
      body: b,
      span: sp,
      file: fp,
      requires: req
    ) :: rest ->
      let merged = match b do
        | EagerBody(_) ->
          HirFunction(
            name: n,
            type_params: tps,
            params: ps,
            ret_type: rt,
            throw_row: tw,
            body: b,
            span: sp,
            file: fp,
            requires: req
          )
        | LazyBody(_) ->
          /* Take FULL function from resolved (params/ret_type may differ from
           * orig after desugar_main_if_needed or infer_resolve_constant_type). */
          match smap.get(map: index, key: n) do
            | Found(value: rf) -> rf
            | Missing -> HirFunction(
              name: n,
              type_params: tps,
              params: ps,
              ret_type: rt,
              throw_row: tw,
              body: b,
              span: sp,
              file: fp,
              requires: req
            )
          end
      end
      return merged :: merge_resolved_go(orig: rest, index)
  end
end

/** Build the resolved-function index in a single pass, replacing the former
 *  per-lookup linear scan. The original `lookup_resolved_func` returned the
 *  FIRST `EagerBody` entry whose name matched and ignored `LazyBody` entries
 *  entirely (a same-name `LazyBody` was skipped, and a name with only
 *  `LazyBody` entries yielded `None`). To reproduce that exactly: insert only
 *  `EagerBody` entries, and only when the name is not yet present, so the
 *  first matching `EagerBody` wins. A name absent from the map corresponds to
 *  the former `None`.
 */
let build_resolved_index = fn (
  resolved: [ HirFunction ],
  acc: %StringMap<HirFunction>
) -> %StringMap<HirFunction> do
  match resolved do
    | [] -> return acc
    | f :: rest ->
      let HirFunction(
        name: rn,
        type_params: _,
        params: _,
        ret_type: _,
        throw_row: _,
        body: rb,
        _
      ) = f
      let %next = match rb do
        | EagerBody(_) ->
          if smap.contains_key(map: &acc, key: rn) then acc
          else smap.put(map: acc, key: rn, value: f) end
        | LazyBody(_) -> acc
      end
      return build_resolved_index(resolved: rest, acc: %next)
  end
end

let desugar_main_if_needed = fn (name: string, tps: [ string ], ps: [ HirParam ],
    rt: TypeExpr, tw: TypeExpr, body: HirBody, sp: Span, file: string, requires: TypeExpr) -> HirFunction do
  if name == "main" then
    match ps do
      | HirParam(label: _, name: arg_name, sigil: _, typ: _) :: _ ->
        // Keep main's params — wasi_run wrapper calls argv() and passes to main.
        // Component model exports wasi_run as func(), not main directly.
        return HirFunction(name, type_params: tps, params: ps,
          ret_type: rt, throw_row: tw, body, span: sp, file, requires)
      | _ ->
        return HirFunction(name, type_params: tps, params: ps,
          ret_type: rt, throw_row: tw, body, span: sp, file, requires)
    end
  else
    return HirFunction(name, type_params: tps, params: ps,
      ret_type: rt, throw_row: tw, body, span: sp, file, requires)
  end
end

let resolve_all_lazy_via_convert = fn (funcs: [ HirFunction ]) -> [ HirFunction ] throws { HirError } do
  match funcs do
    | [] -> return []
    | HirFunction(
      name: n,
      type_params: tps,
      params: ps,
      ret_type: rt,
      throw_row: tw,
      body: b,
      span: sp,
      file: fp,
      requires: req
    ) :: rest ->
      let ResolveBodyResult(body: resolved, ret: resolved_rt) = match b do
        | EagerBody(_) -> ResolveBodyResult(body: b, ret: rt)
        | LazyBody(ast_expr: expr, entries) ->
          let hv = convert_expr(expr, entries)
          match hv do
            | HirExpr(
              node: Lambda(
                type_params: _,
                params: lps,
                ret_type: lambda_rt,
                requires: _,
                throw_row: _,
                body
              ),
              span: _
            ) ->
              ResolveBodyResult(body: EagerBody(stmts: body), ret: lambda_rt)
            | non_lambda ->
              // Non-Lambda (constant) → wrap in Return.
              // Preserve an explicit annotation from `rt` when it is not the
              // TyI64 placeholder (set by process_tl_let for unannotated
              // constants). For unannotated globals the placeholder TyI64 is
              // replaced by the expression-derived type so that literal
              // constants like `let x = 3.14` pick up TyF64.
              let HirExpr(node: _, span: const_sp) = non_lambda
              let resolved_ret = match rt do
                | TyI64 -> infer_resolve_constant_type(expr: non_lambda)
                | _ -> rt
              end
              ResolveBodyResult(
                body: EagerBody(stmts: [ HirStmt(node: Return(expr: non_lambda), span: const_sp) ]),
                ret: resolved_ret)
          end
      end
      return desugar_main_if_needed(
        name: n,
        tps,
        ps,
        rt: resolved_rt,
        tw,
        body: resolved,
        sp,
        file: fp,
        requires: req
      ) :: resolve_all_lazy_via_convert(funcs: rest)
  end
end

type ResolveBodyResult = ResolveBodyResult(body: HirBody, ret: TypeExpr)

/** Infer return type for a resolved constant expression. */
let infer_resolve_constant_type = fn (expr: HirExpr) -> TypeExpr do
  let HirExpr(node: inner, span: _) = expr
  if let Literal(lit: lv) = inner then
    match lv do
      | LitInt(_) -> return TyI64
      | LitFloat(_) -> return TyF64
      | LitString(_) -> return TyString
      | LitChar(_) -> return TyChar
      | LitBool(_) -> return TyBool
      | LitUnit -> return TyUnit
    end
  else
    // Mirrors hir.nx:infer_constant_type — non-literal globals get the
    // TyI64 placeholder here, refined during typecheck.
    return TyI64
  end
end

let strip_lazy = fn (funcs: [ HirFunction ]) -> [ HirFunction ] do
  match funcs do
    | [] -> return []
    | f :: rest ->
      let HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: b, _) = f
      let nb = match b do
        | EagerBody(_) -> b
        | LazyBody(_) -> EagerBody(stmts: [])
      end
      return with_body(f: f, body: nb) :: strip_lazy(funcs: rest)
  end
end
