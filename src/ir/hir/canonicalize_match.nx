/**
 * canonicalize_match: HIR-level pattern-match canonicalization pass.
 *
 * Owns:
 * - Phase 1 -- arm dedup + POr fusion: arms with structurally-identical
 *   simple bodies (Return(Literal) or Return(Variable)) are fused into a
 * single arm with a POr pattern. Automating what did
 *   manually.
 * - Phase 2 -- arm sort: PCtor arms are sorted by variant name (lexicographic)
 *   so the LIR decision-tree builder receives them in a stable, compressor-
 *   friendly order.  Wildcard/variable arms are preserved last.
 *
 * Arm reordering (Phase 2 sort + Phase 1 POr-fusion) is gated by the `reorder`
 * argument to `canonicalize_program`.  It is enabled for the codegen program
 * and disabled for the typecheck program: reordering changes both the order
 * and count of arms, which would make the exhaustiveness/redundancy pass
 * report "arm #N is unreachable" against a post-transform position the user
 * never wrote.  With it off, arm bodies are still recursed for nested-match
 * canonicalization, but the top-level arm list is left in source order.
 *
 * Phase 3 (silent stripping of arms after the first wildcard) is intentionally
 * absent: the typecheck exhaustiveness pass (check_redundancy) is the
 * authoritative reporter for unreachable arms.  Stripping here would prevent
 * E2001 from ever firing for `_ | specific` patterns.
 *
 * Phase 4 (list-pattern head peeling) is skipped -- too complex / separate
 * concern.
 *
 * Does not own:
 * - Pattern conversion (src/ir/hir/pattern.nx)
 * - HIR type definitions (src/ir/hir/types.nx)
 * - Any MIR/LIR concerns
 */

import {
  HirProgram,
  HirFunction,
  HirHandlerArm,
  HirHandlerBinding,
  HirHandlerBindingEntry,
  HirStmt,
  HirStmtKind,
  HirExpr,
  HirExprKind,
  HirMatchCase,
  HirPatternKind,
  HirPatternField,
  HirRecordPatField,
  HirCallArg,
  HirNamedExpr,
  EagerBody,
  LazyBody
} from "src/ir/hir/types.nx"
import {
  Literal,
  LitInt,
  LitFloat,
  LitBool,
  LitChar,
  LitString,
  LitUnit,
  Sigil,
  SigilImmutable
} from "src/types/vocab.nx"
import { EnumDef, VariantDef } from "src/types/type_expr.nx"
import * as list from "std:list"
import * as str from "std:str"

// Literal equality

let lit_eq = fn (a: Literal, b: Literal) -> bool do
  match a do
    | LitInt(val: va) ->
      match b do
        | LitInt(val: vb) -> return va == vb
        | _ -> return false
      end
    | LitBool(val: va) ->
      match b do
        | LitBool(val: vb) -> return va == vb
        | _ -> return false
      end
    | LitString(val: va) ->
      match b do
        | LitString(val: vb) -> return va == vb
        | _ -> return false
      end
    | LitChar(val: va) ->
      match b do
        | LitChar(val: vb) -> return va == vb
        | _ -> return false
      end
    | LitFloat(val: va) ->
      match b do
        | LitFloat(val: vb) -> return va == vb
        | _ -> return false
      end
    | LitUnit ->
      match b do
        | LitUnit -> return true
        | _ -> return false
      end
  end
end

// Simple body equality (conservative).
// Nexus has no structural equality for HirStmt, so we detect only the
// "trivially equal" shapes:
//   - single Return(Literal)
//   - single Return(Variable)
//   - empty body []
// Any other shape returns false (safe: we skip dedup rather than mis-fuse).

type SimpleBody =
  SBLit(lit: Literal)
  | SBVar(name: string)
  | SBUnit
  | SBComplex

let classify_body = fn (stmts: [ HirStmt ]) -> SimpleBody do
  match stmts do
    | [] -> return SBUnit
    | HirStmt(node: Return(expr: HirExpr(node: Literal(lit: l), span: _)), span: _) :: [] ->
      return SBLit(lit: l)
    | HirStmt(
      node: Return(expr: HirExpr(node: Variable(name: n, sigil: _), span: _)),
      span: _
    ) :: [] ->
      return SBVar(name: n)
    | _ -> return SBComplex
  end
end

let simple_body_eq = fn (a: SimpleBody, b: SimpleBody) -> bool do
  match a do
    | SBUnit ->
      match b do | SBUnit -> return true | _ -> return false end
    | SBLit(lit: la) ->
      match b do | SBLit(lit: lb) -> return lit_eq(a: la, b: lb) | _ -> return false end
    | SBVar(name: na) ->
      match b do | SBVar(name: nb) -> return na == nb | _ -> return false end
    | SBComplex -> return false
  end
end

// Pattern classification

let pat_is_wildcard = fn (pat: HirPatternKind) -> bool do
  match pat do
    | PWild -> return true
    | PVar(name: _, sigil: _) -> return true
    | _ -> return false
  end
end

let pat_or_eligible = fn (pat: HirPatternKind) -> bool do
  match pat do
    | PCtor(variant: _, fields: _, sigil: _) -> return true
    | PLit(_) -> return true
    | _ -> return false
  end
end

// Lexicographic string comparison (std:str has no compare function).

let str_leq_loop = fn (a: string, b: string, idx: i64, la: i64, lb: i64) -> bool do
  if idx >= la then return true end
  if idx >= lb then return false end
  let ca = str.char_at(s: a, idx)
  let cb = str.char_at(s: b, idx)
  if ca == cb then
    return str_leq_loop(a, b, idx: idx + 1, la, lb)
  else
    return ca < cb
  end
end

let str_leq = fn (a: string, b: string) -> bool do
  return str_leq_loop(a, b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end

let pat_sort_key = fn (pat: HirPatternKind) -> string do
  match pat do
    | PCtor(variant: v, fields: _, sigil: _) -> return v
    | PLit(lit: l) ->
      match l do
        | LitInt(val: v) -> return str.from_i64(val: v)
        | LitBool(val: v) -> if v then return "true" else return "false" end
        | LitString(val: v) -> return v
        | LitChar(val: v) -> return str.from_i64(val: v)
        | LitFloat(val: v) -> return v
        | LitUnit -> return "()"
      end
    | _ -> return ""
  end
end

// Phase 1: POr fusion.
// Walk the arm list linearly. Keep a "current group" = (simple_body, pats).
// When the next arm has the same simple_body and an or-eligible pattern,
// extend the group. Otherwise emit the group and start a new one.
// A group of size 1 emits as-is. A group of size >=2 emits as a single
// arm with a POr pattern.

type ArmGroup = ArmGroup(body: SimpleBody, pats: [ HirPatternKind ], stmts: [ HirStmt ])

let flush_group = fn (grp: ArmGroup, acc: [ HirMatchCase ]) -> [ HirMatchCase ] do
  let ArmGroup(body: _, pats: ps, stmts: ss) = grp
  match ps do
    | [] -> return acc
    | p :: [] -> return HirMatchCase(pattern: p, body: ss) :: acc
    | _ ->
      let ordered = list.reverse(xs: ps)
      return HirMatchCase(pattern: POr(alts: ordered), body: ss) :: acc
  end
end

let phase1_cases = fn (cases: [ HirMatchCase ]) -> [ HirMatchCase ] do
  match cases do
    | [] -> return []
    | _ ->
      let reversed = phase1_go(cases: cases, group: None, acc: [])
      return list.reverse(xs: reversed)
  end
end

let phase1_go = fn (
  cases: [ HirMatchCase ],
  group: Option<ArmGroup>,
  acc: [ HirMatchCase ]
) -> [ HirMatchCase ] do
  match cases do
    | [] ->
      match group do
        | None -> return acc
        | Some(val: grp) -> return flush_group(grp: grp, acc: acc)
      end
    | HirMatchCase(pattern: pat, body: stmts) :: rest ->
      let sb = classify_body(stmts)
      let eligible = pat_or_eligible(pat)
      match group do
        | None ->
          if eligible then
            let grp = ArmGroup(body: sb, pats: pat :: [], stmts)
            return phase1_go(cases: rest, group: Some(val: grp), acc)
          else
            return phase1_go(
              cases: rest,
              group: None,
              acc: HirMatchCase(pattern: pat, body: stmts) :: acc
            )
          end
        | Some(val: ArmGroup(body: gsb, pats: gps, stmts: gss)) ->
          if eligible && simple_body_eq(a: sb, b: gsb) then
            let grp2 = ArmGroup(body: gsb, pats: pat :: gps, stmts: gss)
            return phase1_go(cases: rest, group: Some(val: grp2), acc)
          else
            let old_grp = ArmGroup(body: gsb, pats: gps, stmts: gss)
            let acc2 = flush_group(grp: old_grp, acc: acc)
            if eligible then
              let grp2 = ArmGroup(body: sb, pats: pat :: [], stmts)
              return phase1_go(cases: rest, group: Some(val: grp2), acc: acc2)
            else
              return phase1_go(
                cases: rest,
                group: None,
                acc: HirMatchCase(pattern: pat, body: stmts) :: acc2
              )
            end
          end
      end
  end
end

// Phase 2: arm sort (enum-defs-aware).
// Partition into specific (PCtor/PLit/POr) and wildcard (PWild/PVar) arms.
// For PCtor specifics: only sort when all PCtor arms belong to the same enum
// (as determined by enum_defs).  This prevents reordering list `Cons` arms
// against custom-type constructors that share the PCtor namespace.
// Sort key: declaration order within the enum (stable, compressor-friendly).
// Wildcard arms are always preserved last.

type PartitionResult = PartitionResult(specific: [ HirMatchCase ], wildcard: [ HirMatchCase ])

let partition_cases = fn (
  cases: [ HirMatchCase ],
  sp_acc: [ HirMatchCase ],
  wc_acc: [ HirMatchCase ]
) -> PartitionResult do
  match cases do
    | [] ->
      return PartitionResult(specific: list.reverse(xs: sp_acc), wildcard: list.reverse(xs: wc_acc))
    | HirMatchCase(pattern: pat, body: b) :: rest ->
      if pat_is_wildcard(pat) then
        return partition_cases(
          cases: rest,
          sp_acc,
          wc_acc: HirMatchCase(pattern: pat, body: b) :: wc_acc
        )
      else
        return partition_cases(
          cases: rest,
          sp_acc: HirMatchCase(pattern: pat, body: b) :: sp_acc,
          wc_acc
        )
      end
  end
end

// --- Enum-def helpers for Phase 2 ---

// Return the declaration-order index of variant `vname` in the given variant list.
// Returns -1 when not found.
let find_variant_index = fn (variants: [ VariantDef ], vname: string, idx: i64) -> i64 do
  match variants do
    | [] -> return 0 - 1
    | VariantDef(name: n, fields: _) :: rest ->
      if n == vname then
        return idx
      else
        return find_variant_index(variants: rest, vname: vname, idx: idx + 1)
      end
  end
end

// Return the name of the enum that declares variant `vname`, if any.
let find_enum_for_variant = fn (defs: [ EnumDef ], vname: string) -> Option<string> do
  match defs do
    | [] -> return None
    | EnumDef(name: ename, is_public: _, is_opaque: _, type_params: _, variants: vs) :: rest ->
      let idx = find_variant_index(variants: vs, vname: vname, idx: 0)
      if idx >= 0 then
        return Some(val: ename)
      else
        return find_enum_for_variant(defs: rest, vname: vname)
      end
  end
end

// Return the declaration index of variant `vname` within enum named `ename`.
// Returns -1 when the enum or variant is not found.
let variant_index_in_named_enum = fn (defs: [ EnumDef ], ename: string, vname: string) -> i64 do
  match defs do
    | [] -> return 0 - 1
    | EnumDef(name: n, is_public: _, is_opaque: _, type_params: _, variants: vs) :: rest ->
      if n == ename then
        return find_variant_index(variants: vs, vname: vname, idx: 0)
      else
        return variant_index_in_named_enum(defs: rest, ename: ename, vname: vname)
      end
  end
end

// Extract the leading variant name of a pattern (for enum-group detection).
// Returns "" for non-PCtor patterns.
let pat_ctor_name = fn (pat: HirPatternKind) -> string do
  match pat do
    | PCtor(variant: v, fields: _, sigil: _) -> return v
    | POr(alts: a :: _) ->
      match a do
        | PCtor(variant: v, fields: _, sigil: _) -> return v
        | _ -> return ""
      end
    | _ -> return ""
  end
end

// Check that all cases in `specific` are PCtor arms belonging to `expected_enum`.
// Returns false if any arm is a non-PCtor or belongs to a different/unknown enum.
let all_pctors_in_enum = fn (
  cases: [ HirMatchCase ],
  defs: [ EnumDef ],
  expected_enum: string
) -> bool do
  match cases do
    | [] -> return true
    | HirMatchCase(pattern: pat, body: _) :: rest ->
      let vname = pat_ctor_name(pat: pat)
      if str.length(s: vname) == 0 then
        // PLit or other non-PCtor: not part of any enum group
        return false
      else
        let found = find_enum_for_variant(defs: defs, vname: vname)
        match found do
          | None -> return false
          | Some(val: ename) ->
            if ename == expected_enum then
              return all_pctors_in_enum(cases: rest, defs: defs, expected_enum: expected_enum)
            else
              return false
            end
        end
      end
  end
end

// Determine whether all PCtor-specific arms belong to the same enum.
// Returns Some(enum_name) if yes, None otherwise.
let all_pctors_same_enum = fn (cases: [ HirMatchCase ], defs: [ EnumDef ]) -> Option<string> do
  match cases do
    | [] -> return None
    | HirMatchCase(pattern: pat, body: _) :: rest ->
      let vname = pat_ctor_name(pat: pat)
      if str.length(s: vname) == 0 then
        // First arm is non-PCtor: no enum-sort possible
        return None
      else
        let found = find_enum_for_variant(defs: defs, vname: vname)
        match found do
          | None -> return None
          | Some(val: ename) ->
            if all_pctors_in_enum(cases: rest, defs: defs, expected_enum: ename) then
              return Some(val: ename)
            else
              return None
            end
        end
      end
  end
end

// Sort key for an arm when sorting by enum declaration order.
let case_enum_index = fn (c: HirMatchCase, defs: [ EnumDef ], ename: string) -> i64 do
  let HirMatchCase(pattern: pat, body: _) = c
  let vname = pat_ctor_name(pat: pat)
  return variant_index_in_named_enum(defs: defs, ename: ename, vname: vname)
end

// Insertion sort by enum declaration index.
let isort_by_enum_index = fn (
  xs: [ HirMatchCase ],
  defs: [ EnumDef ],
  ename: string
) -> [ HirMatchCase ] do
  return isort_enum_go(xs: xs, acc: [], defs: defs, ename: ename)
end

let isort_enum_go = fn (
  xs: [ HirMatchCase ],
  acc: [ HirMatchCase ],
  defs: [ EnumDef ],
  ename: string
) -> [ HirMatchCase ] do
  match xs do
    | [] -> return acc
    | x :: rest -> return isort_enum_go(
      xs: rest,
      acc: insert_by_enum(c: x, into: acc, defs: defs, ename: ename),
      defs: defs,
      ename: ename
    )
  end
end

let insert_by_enum = fn (
  c: HirMatchCase,
  into: [ HirMatchCase ],
  defs: [ EnumDef ],
  ename: string
) -> [ HirMatchCase ] do
  match into do
    | [] -> return c :: []
    | h :: rest ->
      let ic = case_enum_index(c: c, defs: defs, ename: ename)
      let ih = case_enum_index(c: h, defs: defs, ename: ename)
      // Use strict less-than for a stable sort: arms with equal declaration
      // indices (same variant name, different field patterns) keep their
      // original relative order.  This matters when one variant has multiple
      // arms differing only in field patterns (e.g. TyUserDefined(args: [])
      // before TyUserDefined(args: targs)) — swapping them would change which
      // arm fires first.
      if ic < ih then
        return c :: h :: rest
      else
        return h :: insert_by_enum(c: c, into: rest, defs: defs, ename: ename)
      end
  end
end

// Fallback: lexicographic sort key for PLit/other non-enum specifics.
let case_key = fn (c: HirMatchCase) -> string do
  let HirMatchCase(pattern: pat, body: _) = c
  match pat do
    | POr(alts: a :: _) -> return pat_sort_key(a)
    | _ -> return pat_sort_key(pat)
  end
end

let isort_cases = fn (xs: [ HirMatchCase ]) -> [ HirMatchCase ] do
  return isort_go(xs: xs, acc: [])
end

let isort_go = fn (xs: [ HirMatchCase ], acc: [ HirMatchCase ]) -> [ HirMatchCase ] do
  match xs do
    | [] -> return acc
    | x :: rest -> return isort_go(xs: rest, acc: insert_case(c: x, into: acc))
  end
end

let insert_case = fn (c: HirMatchCase, into: [ HirMatchCase ]) -> [ HirMatchCase ] do
  match into do
    | [] -> return c :: []
    | h :: rest ->
      if str_leq(a: case_key(c), b: case_key(h)) then
        return c :: h :: rest
      else
        return h :: insert_case(c: c, into: rest)
      end
  end
end

let concat_cases = fn (a: [ HirMatchCase ], b: [ HirMatchCase ]) -> [ HirMatchCase ] do
  return concat_cases_go(a: a, b: b, acc: [])
end

let concat_cases_go = fn (
  a: [ HirMatchCase ],
  b: [ HirMatchCase ],
  acc: [ HirMatchCase ]
) -> [ HirMatchCase ] do
  match a do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: b)
    | x :: rest -> return concat_cases_go(a: rest, b: b, acc: x :: acc)
  end
end

// Returns true iff some wildcard (PWild/PVar) arm precedes a non-wildcard arm
// in the original list.  Used by Phase 2 to skip reordering when that would
// hide the redundancy that the typecheck exhaustiveness pass is supposed to
// catch and report.
let has_wildcard_before_specific = fn (cases: [ HirMatchCase ]) -> bool do
  return has_wbs_go(cases: cases, seen_wildcard: false)
end

let has_wbs_go = fn (cases: [ HirMatchCase ], seen_wildcard: bool) -> bool do
  match cases do
    | [] -> return false
    | HirMatchCase(pattern: pat, body: _) :: rest ->
      match pat_is_wildcard(pat) do
        | true -> return has_wbs_go(cases: rest, seen_wildcard: true)
        | false ->
          if seen_wildcard then return true end
          return has_wbs_go(cases: rest, seen_wildcard: false)
      end
  end
end

// Phase 2 entry point: enum-defs-aware arm sort.
// If all PCtor-specific arms belong to the same enum, sort by declaration order.
// Otherwise fall back to no-sort (preserve original order) to avoid cross-enum
// reordering (e.g. list Cons vs custom-type ctors).
// Skipped entirely when a wildcard precedes a specific arm: reordering in that
// case would hide a redundant-arm error that the typecheck must report.
let phase2_cases = fn (cases: [ HirMatchCase ], enum_defs: [ EnumDef ]) -> [ HirMatchCase ] do
  if has_wildcard_before_specific(cases: cases) then return cases end
  let PartitionResult(
    specific: sp,
    wildcard: wc
  ) = partition_cases(cases: cases, sp_acc: [], wc_acc: [])
  let same_enum = all_pctors_same_enum(cases: sp, defs: enum_defs)
  let sorted = match same_enum do
    | Some(val: ename) -> isort_by_enum_index(xs: sp, defs: enum_defs, ename)
    | None -> sp
  end
  return concat_cases(a: sorted, b: wc)
end

// Full canonicalization of a single match case list.
// enum_defs is threaded through to enable Phase 2 enum-aware arm sort.
// Phase 3 (strip arms after first wildcard) is intentionally absent: the
// typecheck exhaustiveness pass (check_redundancy in exhaustive/decision.nx)
// is the authoritative detector for unreachable arms.  Silent stripping here
// would prevent that diagnostic from ever firing.

let canonicalize_cases = fn (
  cases: [ HirMatchCase ], enum_defs: [ EnumDef ], reorder: bool
) -> [ HirMatchCase ] do
  // Arm reordering (Phase 2 sort + Phase 1 POr-fusion) is a codegen-only
  // canonicalization that changes both the order and the count of arms.  It is
  // skipped (`reorder = false`) for the typecheck program so the
  // exhaustiveness/redundancy pass reports arm indices in the user's source
  // order: with reordering on, "arm #N is unreachable" would name a post-sort
  // (or post-fusion) position the user never wrote.
  if !reorder then return cases end
  // Phase 2: sort PCtor arms by enum declaration order when all arms belong to
  // the same enum.  Falls back to no-sort when arms span multiple enums or
  // include list Cons (which is not a user-defined enum variant).
  let after_p2 = phase2_cases(cases: cases, enum_defs: enum_defs)
  // Phase 1: fuse arms with identical simple bodies into a single POr arm.
  let after_p1 = phase1_cases(cases: after_p2)
  return after_p1
end

// HIR tree rewriter: recurse into every HirExpr/HirStmt and rewrite Match nodes.
// enum_defs is threaded through every traversal function so Phase 2 can use it.

let canon_expr = fn (e: HirExpr, enum_defs: [ EnumDef ], reorder: bool) -> HirExpr do
  let HirExpr(node: k, span: sp) = e
  return HirExpr(node: canon_expr_kind(k: k, enum_defs: enum_defs, reorder: reorder), span: sp)
end

let canon_expr_kind = fn (k: HirExprKind, enum_defs: [ EnumDef ], reorder: bool) -> HirExprKind do
  match k do
    | Literal(_) | Variable(_) | Borrow(_) | ExternalRef(_) -> return k
    | BinOp(left: l, op, right: r) ->
      return BinOp(
        left: canon_expr(e: l, enum_defs: enum_defs, reorder: reorder),
        op,
        right: canon_expr(e: r, enum_defs: enum_defs, reorder: reorder)
      )
    | UnOp(op, operand: o) ->
      return UnOp(op, operand: canon_expr(e: o, enum_defs: enum_defs, reorder: reorder))
    | Call(func: f, args) ->
      return Call(
        func: f,
        args: canon_call_args(args: args, enum_defs: enum_defs, reorder: reorder)
      )
    | CallExpr(callee: c, args) ->
      return CallExpr(
        callee: canon_expr(e: c, enum_defs: enum_defs, reorder: reorder),
        args: canon_call_args(args: args, enum_defs: enum_defs, reorder: reorder)
      )
    | Ctor(variant: v, args, labels, sigil: sig) ->
      return Ctor(
        variant: v,
        args: canon_expr_list(es: args, enum_defs: enum_defs, reorder: reorder),
        labels,
        sigil: sig
      )
    | Record(fields: fs) ->
      return Record(fields: canon_named_exprs(fs: fs, enum_defs: enum_defs, reorder: reorder))
    | Array(elems: es) ->
      return Array(elems: canon_expr_list(es: es, enum_defs: enum_defs, reorder: reorder))
    | Index(target: t, index: i) ->
      return Index(
        target: canon_expr(e: t, enum_defs: enum_defs, reorder: reorder),
        index: canon_expr(e: i, enum_defs: enum_defs, reorder: reorder)
      )
    | FieldAccess(target: t, field: f) ->
      return FieldAccess(target: canon_expr(e: t, enum_defs: enum_defs, reorder: reorder), field: f)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let new_eb = match eb do
        | None -> None
        | Some(val: s) -> Some(val: canon_stmts(stmts: s, enum_defs: enum_defs, reorder: reorder))
      end
      return If(
        cond: canon_expr(e: c, enum_defs: enum_defs, reorder: reorder),
        then_branch: canon_stmts(stmts: tb, enum_defs: enum_defs, reorder: reorder),
        else_branch: new_eb
      )
    | Match(target: t, cases: cs) ->
      let new_cs = canonicalize_cases(cases: cs, enum_defs: enum_defs, reorder: reorder)
      let rewritten = canon_cases(cases: new_cs, enum_defs: enum_defs, reorder: reorder)
      return Match(
        target: canon_expr(e: t, enum_defs: enum_defs, reorder: reorder),
        cases: rewritten
      )
    | While(cond: c, body: b) ->
      return While(
        cond: canon_expr(e: c, enum_defs: enum_defs, reorder: reorder),
        body: canon_stmts(stmts: b, enum_defs: enum_defs, reorder: reorder)
      )
    | For(var: v, start: s, end_expr: ee, body: b) ->
      return For(
        var: v,
        start: canon_expr(e: s, enum_defs: enum_defs, reorder: reorder),
        end_expr: canon_expr(e: ee, enum_defs: enum_defs, reorder: reorder),
        body: canon_stmts(stmts: b, enum_defs: enum_defs, reorder: reorder)
      )
    | Lambda(type_params: tp, params, ret_type: rt, requires: req, throw_row: tw, body: b) ->
      return Lambda(
        type_params: tp,
        params,
        ret_type: rt,
        requires: req,
        throw_row: tw,
        body: canon_stmts(stmts: b, enum_defs: enum_defs, reorder: reorder)
      )
    | Raise(expr: e) -> return Raise(expr: canon_expr(e: e, enum_defs: enum_defs, reorder: reorder))
    | Force(expr: e) -> return Force(expr: canon_expr(e: e, enum_defs: enum_defs, reorder: reorder))
    | Thunk(body: b) -> return Thunk(body: canon_expr(e: b, enum_defs: enum_defs, reorder: reorder))
    | Handler(cap_name: pn, requires: req, arms) ->
      return Handler(
        cap_name: pn,
        requires: req,
        arms: canon_handler_arms(arms: arms, enum_defs: enum_defs, reorder: reorder)
      )
    | Inject(handlers: hs, body: b) ->
      return Inject(
        handlers: hs,
        body: canon_stmts(stmts: b, enum_defs: enum_defs, reorder: reorder)
      )
  end
end

let canon_stmts = fn (stmts: [ HirStmt ], enum_defs: [ EnumDef ], reorder: bool) -> [ HirStmt ] do
  return canon_stmts_go(stmts: stmts, acc: [], enum_defs: enum_defs, reorder: reorder)
end

let canon_stmts_go = fn (
  stmts: [ HirStmt ],
  acc: [ HirStmt ],
  enum_defs: [ EnumDef ],
  reorder: bool
) -> [ HirStmt ] do
  match stmts do
    | [] -> return list.reverse(xs: acc)
    | HirStmt(node: s, span: sp) :: rest ->
      return canon_stmts_go(
        stmts: rest,
        acc: HirStmt(node: canon_stmt_kind(s: s, enum_defs: enum_defs, reorder: reorder), span: sp)
          :: acc,
        enum_defs: enum_defs,
        reorder: reorder
      )
  end
end

let canon_stmt_kind = fn (s: HirStmtKind, enum_defs: [ EnumDef ], reorder: bool) -> HirStmtKind do
  match s do
    | Let(name: n, sigil: sig, typ: t, value: v) ->
      return Let(
        name: n,
        sigil: sig,
        typ: t,
        value: canon_expr(e: v, enum_defs: enum_defs, reorder: reorder)
      )
    | Expr(expr: e) -> return Expr(expr: canon_expr(e: e, enum_defs: enum_defs, reorder: reorder))
    | Return(expr: e) ->
      return Return(expr: canon_expr(e: e, enum_defs: enum_defs, reorder: reorder))
    | Assign(target: t, value: v) ->
      return Assign(
        target: canon_expr(e: t, enum_defs: enum_defs, reorder: reorder),
        value: canon_expr(e: v, enum_defs: enum_defs, reorder: reorder)
      )
    | Try(body: b, catch_param: cp, catch_body: cb) ->
      return Try(
        body: canon_stmts(stmts: b, enum_defs: enum_defs, reorder: reorder),
        catch_param: cp,
        catch_body: canon_stmts(stmts: cb, enum_defs: enum_defs, reorder: reorder)
      )
  end
end

let canon_cases = fn (
  cases: [ HirMatchCase ], enum_defs: [ EnumDef ], reorder: bool
) -> [ HirMatchCase ] do
  return canon_cases_go(cases: cases, acc: [], enum_defs: enum_defs, reorder: reorder)
end

let canon_cases_go = fn (
  cases: [ HirMatchCase ],
  acc: [ HirMatchCase ],
  enum_defs: [ EnumDef ],
  reorder: bool
) -> [ HirMatchCase ] do
  match cases do
    | [] -> return list.reverse(xs: acc)
    | HirMatchCase(pattern: pat, body: b) :: rest ->
      return canon_cases_go(
        cases: rest,
        acc: HirMatchCase(
          pattern: pat,
          body: canon_stmts(stmts: b, enum_defs: enum_defs, reorder: reorder)
        ) :: acc,
        enum_defs: enum_defs,
        reorder: reorder
      )
  end
end

let canon_call_args = fn (
  args: [ HirCallArg ], enum_defs: [ EnumDef ], reorder: bool
) -> [ HirCallArg ] do
  return canon_call_args_go(args: args, acc: [], enum_defs: enum_defs, reorder: reorder)
end

let canon_call_args_go = fn (
  args: [ HirCallArg ],
  acc: [ HirCallArg ],
  enum_defs: [ EnumDef ],
  reorder: bool
) -> [ HirCallArg ] do
  match args do
    | [] -> return list.reverse(xs: acc)
    | HirCallArg(label: l, value: v) :: rest ->
      return canon_call_args_go(
        args: rest,
        acc: HirCallArg(label: l, value: canon_expr(e: v, enum_defs: enum_defs, reorder: reorder))
          :: acc,
        enum_defs: enum_defs,
        reorder: reorder
      )
  end
end

let canon_expr_list = fn (es: [ HirExpr ], enum_defs: [ EnumDef ], reorder: bool) -> [ HirExpr ] do
  return canon_expr_list_go(es: es, acc: [], enum_defs: enum_defs, reorder: reorder)
end

let canon_expr_list_go = fn (
  es: [ HirExpr ],
  acc: [ HirExpr ],
  enum_defs: [ EnumDef ],
  reorder: bool
) -> [ HirExpr ] do
  match es do
    | [] -> return list.reverse(xs: acc)
    | e :: rest -> return canon_expr_list_go(
      es: rest,
      acc: canon_expr(e: e, enum_defs: enum_defs, reorder: reorder) :: acc,
      enum_defs: enum_defs,
      reorder: reorder
    )
  end
end

let canon_named_exprs = fn (
  fs: [ HirNamedExpr ], enum_defs: [ EnumDef ], reorder: bool
) -> [ HirNamedExpr ] do
  return canon_named_exprs_go(fs: fs, acc: [], enum_defs: enum_defs, reorder: reorder)
end

let canon_named_exprs_go = fn (
  fs: [ HirNamedExpr ],
  acc: [ HirNamedExpr ],
  enum_defs: [ EnumDef ],
  reorder: bool
) -> [ HirNamedExpr ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | HirNamedExpr(name: n, value: v) :: rest ->
      return canon_named_exprs_go(
        fs: rest,
        acc: HirNamedExpr(name: n, value: canon_expr(e: v, enum_defs: enum_defs, reorder: reorder))
          :: acc,
        enum_defs: enum_defs,
        reorder: reorder
      )
  end
end

let canon_handler_arms = fn (
  arms: [ HirHandlerArm ],
  enum_defs: [ EnumDef ],
  reorder: bool
) -> [ HirHandlerArm ] do
  return canon_handler_arms_go(arms: arms, acc: [], enum_defs: enum_defs, reorder: reorder)
end

let canon_handler_arms_go = fn (
  arms: [ HirHandlerArm ],
  acc: [ HirHandlerArm ],
  enum_defs: [ EnumDef ],
  reorder: bool
) -> [ HirHandlerArm ] do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | HirHandlerArm(arm: f, cont_binder: cb) :: rest ->
      return canon_handler_arms_go(
        arms: rest,
        acc: HirHandlerArm(
          arm: canon_function(f: f, enum_defs: enum_defs, reorder: reorder),
          cont_binder: cb
        ) :: acc,
        enum_defs: enum_defs,
        reorder: reorder
      )
  end
end

let canon_function = fn (f: HirFunction, enum_defs: [ EnumDef ], reorder: bool) -> HirFunction do
  let HirFunction(
    name: n,
    type_params: tp,
    params: ps,
    ret_type: rt,
    throw_row: tr,
    body: b,
    span: sp,
    file: fi,
    requires: req
  ) = f
  let new_body = match b do
    | LazyBody(_) -> b
    | EagerBody(stmts: ss) ->
      EagerBody(stmts: canon_stmts(stmts: ss, enum_defs: enum_defs, reorder: reorder))
  end
  return HirFunction(
    name: n,
    type_params: tp,
    params: ps,
    ret_type: rt,
    throw_row: tr,
    body: new_body,
    span: sp,
    file: fi,
    requires: req
  )
end

let canon_functions = fn (
  funcs: [ HirFunction ], enum_defs: [ EnumDef ], reorder: bool
) -> [ HirFunction ] do
  return canon_functions_go(funcs: funcs, acc: [], enum_defs: enum_defs, reorder: reorder)
end

let canon_functions_go = fn (
  funcs: [ HirFunction ],
  acc: [ HirFunction ],
  enum_defs: [ EnumDef ],
  reorder: bool
) -> [ HirFunction ] do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      return canon_functions_go(
        funcs: rest,
        acc: canon_function(f: f, enum_defs: enum_defs, reorder: reorder) :: acc,
        enum_defs: enum_defs,
        reorder: reorder
      )
  end
end

let canon_handler_bindings = fn (
  bindings: [ HirHandlerBindingEntry ],
  enum_defs: [ EnumDef ],
  reorder: bool
) -> [ HirHandlerBindingEntry ] do
  return canon_handler_bindings_go(
    bindings: bindings,
    acc: [],
    enum_defs: enum_defs,
    reorder: reorder
  )
end

let canon_handler_bindings_go = fn (
  bindings: [ HirHandlerBindingEntry ],
  acc: [ HirHandlerBindingEntry ],
  enum_defs: [ EnumDef ],
  reorder: bool
) -> [ HirHandlerBindingEntry ] do
  match bindings do
    | [] -> return list.reverse(xs: acc)
    | HirHandlerBindingEntry(
      name: n,
      binding: HirHandlerBinding(cap_name: pn, requires: req, arms)
    ) :: rest ->
      let new_arms = canon_handler_arms(arms: arms, enum_defs: enum_defs, reorder: reorder)
      return canon_handler_bindings_go(
        bindings: rest,
        acc: HirHandlerBindingEntry(
          name: n,
          binding: HirHandlerBinding(cap_name: pn, requires: req, arms: new_arms)
        ) :: acc,
        enum_defs: enum_defs,
        reorder: reorder
      )
  end
end

/** Run all canonicalization phases over a HirProgram.
 *  Returns a new HirProgram with canonicalized match expressions in every
 *  function body and handler arm.
 *  `reorder` enables arm reordering (Phase 2 sort + Phase 1 POr-fusion); the
 *  codegen program uses it for a stable, compressor-friendly decision tree.
 *  The typecheck program passes `reorder = false` so arm bodies are still
 *  recursed for nested-match canonicalization but the top-level arm order and
 *  count are preserved — the exhaustiveness pass needs source-order indices.
 *  Phase 2 uses enum_defs to safely sort only arms of the same user-defined
 *  enum.
 */
export let canonicalize_program = fn (prog: HirProgram, reorder: bool) -> HirProgram do
  let HirProgram(
      caps: hp,
      functions: hf,
      externals: he,
      handler_bindings: hb,
      enum_defs: hed,
      exception_groups: heg,
      value_binding_names: hvbns,
      type_defs: htds,
      visible_enum_names: hven,
      ext_wasm_deps: hewds
    ) = prog
  let new_funcs = canon_functions(funcs: hf, enum_defs: hed, reorder: reorder)
      let new_hb = canon_handler_bindings(bindings: hb, enum_defs: hed, reorder: reorder)
      return HirProgram(
        caps: hp,
        functions: new_funcs,
        externals: he,
        handler_bindings: new_hb,
        enum_defs: hed,
        exception_groups: heg,
        value_binding_names: hvbns,
        type_defs: htds,
        visible_enum_names: hven,
        ext_wasm_deps: hewds
      )
end
