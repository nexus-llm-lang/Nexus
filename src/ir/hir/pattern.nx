/**
 * pattern: pure AST → HIR pattern-shape conversion.
 *
 * Owns:
 * - SpannedPattern → HirPatternKind conversion (convert_pattern)
 * - Pattern-binder collection for lexical-shadowing rename filtering
 *   (pattern_binders + recursive helpers)
 * - Constructor / record field pattern conversion
 *   (convert_pattern_fields, convert_record_pat_fields)
 *
 * Does not own:
 * - Match-case body conversion / catch-arm desugaring (stay in src/ir/hir/hir.nx —
 *   they entangle statement-binder logic).
 * - HIR type definitions (see src/ir/hir/types.nx).
 *
 * Consumers: imported by src/ir/hir/hir.nx for statement / match-case / catch-arm
 * conversion. No other module needs these — patterns aren't re-converted
 * downstream.
 */
import {
  SpannedPattern,
  PatLiteral,
  PatVariable,
  PatConstructor,
  PatConstructorWildcard,
  PatRecord,
  PatWildcard,
  PatOr,
  CtorPatternField,
  RecordPatField
} from "src/syntax/ast.nx"
import { RenameEntry }, * as symtab from "src/ir/shared/symtab.nx"
import * as rdr from "src/ir/shared/rdrname.nx"
import * as list from "std:list"
import { HirPatternKind, HirPatternField, HirRecordPatField }, * as hir from "src/ir/hir/types.nx"
import { str_in_list } from "src/ir/hir/reachability.nx"

/** Convert a pattern to HIR pattern.
 *
 *  `binder_renames` carries the alpha-renames for pattern BINDERS that shadow a
 *  strictly-enclosing local (nexus-x9uw0, the pattern-binder sibling of the
 *  i7alf nested-`let` fix). A binder `b` that reuses an enclosing local's name
 *  would, at codegen, reuse that local's wasm slot (slots are keyed by name) and
 *  the arm's bind would clobber the surviving outer value. The caller computes a
 *  fresh `b#depth` for each such binder and passes the `b → b#depth` map here so
 *  the BINDER occurrence in the pattern is rewritten; the same map is added to
 *  the arm body's rename entries so references inside the arm follow the binder.
 *  Non-shadowing binders are absent from the map and pass through unchanged, so
 *  this is a no-op for the common case (and `binder_renames = []`).
 *
 *  `binder_renames` is applied ONLY to PatVariable names — never to constructor,
 *  record-field, or type names — because a binder is a fresh local introduction,
 *  not a reference; routing it through the general `entries` import-rename map
 *  would wrongly re-qualify a binder that happens to collide with an import. */
export let convert_pattern = fn (
  pat: SpannedPattern,
  entries: [ RenameEntry ],
  binder_renames: [ RenameEntry ]
) -> HirPatternKind do
  match pat do
    | SpannedPattern(node: PatLiteral(lit), span: _) ->
      return hir.PLit(lit)
    | SpannedPattern(node: PatVariable(name, sigil: sig), span: _) ->
      // Rewrite the binder to its fresh shadow name when it shadows an enclosing
      // local; identity (passthrough) for a non-shadowing binder.
      return hir.PVar(name: symtab.rename(name, entries: binder_renames), sigil: sig)
    | SpannedPattern(node: PatConstructor(name: v, fields: fs, sigil: sig), span: _) ->
      // P-Ctor must resolve through the same import-binding rename
      // map as the construction site so both agree on the canonical ctor name
      // the runtime tag is hashed from.
      return hir.PCtor(
        variant: symtab.rename_ctor(name: v, entries),
        fields: convert_pattern_fields(fs, entries, binder_renames),
        sigil: sig
      )
    | SpannedPattern(node: PatConstructorWildcard(name: v, sigil: sig), span: _) ->
      return hir.PCtor(variant: symtab.rename_ctor(name: v, entries), fields: [], sigil: sig)
    | SpannedPattern(node: PatRecord(fields: fs, has_wildcard: p), span: _) ->
      return hir.PRec(fields: convert_record_pat_fields(fs, entries, binder_renames), is_partial: p)
    | SpannedPattern(node: PatWildcard, span: _) ->
      return hir.PWild
    | SpannedPattern(node: PatOr(alts), span: _) ->
      return hir.POr(alts: convert_or_alts(alts, entries, binder_renames, acc: []))
  end
end

let convert_or_alts = fn (
  alts: [ SpannedPattern ],
  entries: [ RenameEntry ],
  binder_renames: [ RenameEntry ],
  acc: [ HirPatternKind ]
) -> [ HirPatternKind ] do
  match alts do
    | [] -> return list.reverse(xs: acc)
    | a :: rest -> return convert_or_alts(
      alts: rest,
      entries,
      binder_renames,
      acc: convert_pattern(pat: a, entries, binder_renames) :: acc
    )
  end
end

/** Collect every variable name introduced by a pattern (for shadowing).
 *  Recurses through nested ctor / record / or patterns. Does not collect
 *  constructor / type / field names — only PatVariable identifiers.
 */
export let pattern_binders = fn (pat: SpannedPattern) -> [ string ] do
  return pattern_binders_go(pat, acc: [])
end

let pattern_binders_go = fn (pat: SpannedPattern, acc: [ string ]) -> [ string ] do
  let SpannedPattern(node, span: _) = pat
  match node do
    | PatLiteral(_) | PatWildcard | PatConstructorWildcard(name: _, sigil: _) -> return acc
    | PatVariable(name: n, sigil: _) -> return n :: acc
    | PatConstructor(name: _, fields: fs, sigil: _) -> return pattern_binders_fields(fs, acc)
    | PatRecord(fields: fs, has_wildcard: _) -> return pattern_binders_record_fields(fs, acc)
    | PatOr(alts) -> return pattern_binders_alts(alts, acc)
  end
end

let pattern_binders_fields = fn (fs: [ CtorPatternField ], acc: [ string ]) -> [ string ] do
  match fs do
    | [] -> return acc
    | CtorPatternField(name: _, pattern: p) :: rest ->
      return pattern_binders_fields(fs: rest, acc: pattern_binders_go(pat: p, acc))
  end
end

let pattern_binders_record_fields = fn (fs: [ RecordPatField ], acc: [ string ]) -> [ string ] do
  match fs do
    | [] -> return acc
    | RecordPatField(name: _, pattern: p) :: rest ->
      return pattern_binders_record_fields(fs: rest, acc: pattern_binders_go(pat: p, acc))
  end
end

/** Filter `candidates` to only those names that also appear in `other`'s binder set. */
let intersect_with_alt = fn (
  candidates: [ string ],
  other: SpannedPattern,
  acc: [ string ]
) -> [ string ] do
  let other_binders = pattern_binders_go(pat: other, acc: [])
  return intersect_go(candidates, other_binders, acc)
end

/** Keep only elements of `candidates` that are present in `pool`. */
let intersect_go = fn (candidates: [ string ], pool: [ string ], acc: [ string ]) -> [ string ] do
  match candidates do
    | [] -> return list.reverse(xs: acc)
    | c :: rest ->
      if str_in_list(s: c, xs: pool) then
        return intersect_go(candidates: rest, pool, acc: c :: acc)
      else
        return intersect_go(candidates: rest, pool, acc)
      end
  end
end

/** Filter `candidates` against every remaining alternative; returns the intersection. */
let intersect_with_alts = fn (candidates: [ string ], alts: [ SpannedPattern ]) -> [ string ] do
  match alts do
    | [] -> return candidates
    | a :: rest ->
      let narrowed = intersect_with_alt(candidates, other: a, acc: [])
      return intersect_with_alts(candidates: narrowed, alts: rest)
  end
end

/** Compute the INTERSECTION of binders across all POr alternatives and prepend to `acc`.
 *
 *  A name enters the result only if every alternative binds it.  This makes
 *  lexical shadowing in convert_match_cases / convert_catch_arms_go / StmtLetPattern
 *  safe regardless of whether typecheck has already enforced that all alternatives
 *  bind the same set — a name that only some alternatives bind is not shadowed.
 */
let pattern_binders_alts = fn (alts: [ SpannedPattern ], acc: [ string ]) -> [ string ] do
  match alts do
    | [] -> return acc
    | first :: rest ->
      let first_binders = pattern_binders_go(pat: first, acc: [])
      let inter = intersect_with_alts(candidates: first_binders, alts: rest)
      return list.concat(xs: inter, ys: acc)
  end
end

let convert_pattern_fields = fn (
  fs: [ CtorPatternField ],
  entries: [ RenameEntry ],
  binder_renames: [ RenameEntry ]
) -> [ HirPatternField ] do
  return convert_pattern_fields_go(fs, entries, binder_renames, acc: [])
end

let convert_pattern_fields_go = fn (
  fs: [ CtorPatternField ],
  entries: [ RenameEntry ],
  binder_renames: [ RenameEntry ],
  acc: [ HirPatternField ]
) -> [ HirPatternField ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | CtorPatternField(name: n, pattern: p) :: rest ->
      return convert_pattern_fields_go(
        fs: rest,
        entries,
        binder_renames,
        acc: HirPatternField(
          name: Some(val: n),
          pattern: convert_pattern(pat: p, entries, binder_renames)
        ) :: acc
      )
  end
end

let convert_record_pat_fields = fn (
  fs: [ RecordPatField ],
  entries: [ RenameEntry ],
  binder_renames: [ RenameEntry ]
) -> [ HirRecordPatField ] do
  return convert_record_pat_fields_go(fs, entries, binder_renames, acc: [])
end

let convert_record_pat_fields_go = fn (
  fs: [ RecordPatField ],
  entries: [ RenameEntry ],
  binder_renames: [ RenameEntry ],
  acc: [ HirRecordPatField ]
) -> [ HirRecordPatField ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | RecordPatField(name: n, pattern: p) :: rest ->
      return convert_record_pat_fields_go(
        fs: rest,
        entries,
        binder_renames,
        acc: HirRecordPatField(
          name: n,
          pattern: convert_pattern(pat: p, entries, binder_renames)
        ) :: acc
      )
  end
end
