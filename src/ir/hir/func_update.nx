/**
 * hir/func_update: Functional-update helpers for HirFunction.
 *
 * Each `with_<field>` helper takes a HirFunction plus a new value and
 * returns a fresh HirFunction with only that single field replaced; the
 * other eight fields are copied verbatim. This removes the
 * full-decompose-then-rebuild-one-field boilerplate at the use sites.
 *
 * Mirrors the `ctx_with_*` functional-update helpers in src/ir/mir/utils.nx.
 */
import { HirFunction, HirBody } from "src/ir/hir/types.nx"

/** Return `f` with only its `body` field replaced by `body`. */
export let with_body = fn (f: HirFunction, body: HirBody) -> HirFunction do
  let HirFunction(
    name: n,
    type_params: tps,
    params: ps,
    ret_type: rt,
    throw_row: tw,
    body: _,
    span: sp,
    file: fp,
    requires: req
  ) = f
  return HirFunction(
    name: n,
    type_params: tps,
    params: ps,
    ret_type: rt,
    throw_row: tw,
    body: body,
    span: sp,
    file: fp,
    requires: req
  )
end

/** Return `f` with only its `name` field replaced by `name`. */
export let with_name = fn (f: HirFunction, name: string) -> HirFunction do
  let HirFunction(
    name: _,
    type_params: tps,
    params: ps,
    ret_type: rt,
    throw_row: tw,
    body: b,
    span: sp,
    file: fp,
    requires: req
  ) = f
  return HirFunction(
    name: name,
    type_params: tps,
    params: ps,
    ret_type: rt,
    throw_row: tw,
    body: b,
    span: sp,
    file: fp,
    requires: req
  )
end
