/**
 * hir_types: HIR type definitions for the Nexus self-hosting compiler.
 *
 * Pure data types extracted from hir.nx. No logic, no helpers.
 * Consumers should use: import * as hir from "src/ir/hir/types.nx"
 */

import { Span } from "src/types/span.nx"
import { Sigil, BinaryOp, UnaryOp, Literal } from "src/types/vocab.nx"
import { TypeExpr, EnumDef, RecordDef } from "src/types/type_expr.nx"
import { RenameEntry } from "src/ir/shared/symtab.nx"

/** `sigil` carries the parameter binding qualifier from the source
 *  (`fn (%x: T)`, `fn (@k: T)`, …). Linearity classification at param
 *  binders is sigil OR type, mirroring `let` bindings — see
 *  `let_binds_linear` in src/typecheck/linearity.nx.
 */
export type HirParam = HirParam(label: string, name: string, sigil: Sigil, typ: TypeExpr)

/** Public type HirCapMethod.
 *  Carries the full method signature so that wfCap/wfThrow (D-Cap
 *  introduction-site well-formedness, spec §D-Cap) can be
 *  enforced at cap-registration time and in the pre-DCE whole-program
 *  walk (tcwf.check_program_wf_rows).
 */
export type HirCapMethod = HirCapMethod(
  name: string,
  requires: TypeExpr,
  span: Span,
  throw_row: TypeExpr,
  typ_params: [ HirParam ],
  typ_ret: TypeExpr
)

/** Public type HirCap.
 *  type_params: generic type parameters of the cap (empty for monomorphic caps).
 *  When non-empty, the cap's method signatures may reference these params, and
 *  call-site cap-method schemes are registered polymorphically over them so that
 *  each `Cap.method(...)` call is instantiated independently (mirrors generic fns).
 */
export type HirCap = HirCap(name: string, type_params: [ string ], methods: [ HirCapMethod ])

/** Public type HirExternal. */
export type HirExternal = HirExternal(
  name: string,
  wasm_module: string,
  wasm_name: string,
  type_params: [ string ],
  params: [ HirParam ],
  ret_type: TypeExpr,
  throw_row: TypeExpr
)

/** Public type HirExpr. */
export type HirExpr = HirExpr(node: HirExprKind, span: Span)

/** Public type HirExprKind. */
export type HirExprKind =
  Literal(lit: Literal)
  | Variable(name: string, sigil: Sigil)
  | BinOp(left: HirExpr, op: BinaryOp, right: HirExpr)
  | UnOp(op: UnaryOp, operand: HirExpr)
  | Borrow(name: string, sigil: Sigil)
  | Call(func: string, args: [ HirCallArg ])
  | CallExpr(callee: HirExpr, args: [ HirCallArg ])
  | Ctor(variant: string, args: [ HirExpr ], labels: [ string ], sigil: Sigil)
  | Record(fields: [ HirNamedExpr ])
  | Array(elems: [ HirExpr ])
  | Index(target: HirExpr, index: HirExpr)
  | FieldAccess(target: HirExpr, field: string)
  | If(cond: HirExpr, then_branch: [ HirStmt ], else_branch: Option<[ HirStmt ]>)
  | Match(target: HirExpr, cases: [ HirMatchCase ])
  | While(cond: HirExpr, body: [ HirStmt ])
  | For(var: string, start: HirExpr, end_expr: HirExpr, body: [ HirStmt ])
  | Lambda(
    type_params: [ string ],
    params: [ HirParam ],
    ret_type: TypeExpr,
    requires: TypeExpr,
    throw_row: TypeExpr,
    body: [ HirStmt ]
  )
  | Raise(expr: HirExpr)
  | Force(expr: HirExpr)
  | Thunk(body: HirExpr)
  | ExternalRef(symbol: string, type_params: [ string ], arg_names: [ string ], typ: TypeExpr)
  | Handler(cap_name: string, requires: TypeExpr, arms: [ HirHandlerArm ])

/** Public type HirCallArg. */
export type HirCallArg = HirCallArg(label: string, value: HirExpr)

/** Public type HirNamedExpr. */
export type HirNamedExpr = HirNamedExpr(name: string, value: HirExpr)

/** Public type HirStmt. */
export type HirStmt = HirStmt(node: HirStmtKind, span: Span)

/** Public type HirStmtKind. */
export type HirStmtKind =
  Let(name: string, sigil: Sigil, typ: Option<TypeExpr>, value: HirExpr)
  | Expr(expr: HirExpr)
  | Return(expr: HirExpr)
  | Assign(target: HirExpr, value: HirExpr)
  | Try(body: [ HirStmt ], catch_param: string, catch_body: [ HirStmt ])
  | Inject(handlers: [ string ], body: [ HirStmt ])

/** Public type HirMatchCase. */
export type HirMatchCase = HirMatchCase(pattern: HirPatternKind, body: [ HirStmt ])

/** Public type HirPatternKind. */
export type HirPatternKind =
  PLit(lit: Literal)
  | PVar(name: string, sigil: Sigil)
  | PCtor(variant: string, fields: [ HirPatternField ], sigil: Sigil)
  | PRec(fields: [ HirRecordPatField ], is_partial: bool)
  | PWild
  // `p1 | p2 | ...` — alternatives must bind the same variable set with
  // compatible types.
  | POr(alts: [ HirPatternKind ])

/** Public type HirPatternField. */
export type HirPatternField = HirPatternField(name: Option<string>, pattern: HirPatternKind)

/** Public type HirRecordPatField. */
export type HirRecordPatField = HirRecordPatField(name: string, pattern: HirPatternKind)

/** Public type ExceptionGroupEntry. */
export type ExceptionGroupEntry = ExceptionGroupEntry(name: string, members: [ string ])

/** Eager: fully converted HIR statements. Lazy: original AST expr for deferred convert_expr. */
export type HirBody =
  EagerBody(stmts: [ HirStmt ])
  | LazyBody(ast_expr: SpannedExpr, entries: [ RenameEntry ])

/** `file` is the source-file path that originated this function. HIR
 *  `Span` values carry only `(offset, line, col)`; cross-file LSP
 *  diagnostics need to know which file the span belongs to. Storing the
 * path at the function root (— design choice ii)
 *  keeps every per-expr/per-stmt span small and lets diagnostic emitters
 *  look up the file via the enclosing function. Empty string is the
 *  sentinel for synthesised functions whose origin is the link unit
 *  itself (e.g. handler-arm name-mangling) — those are not surfaced to
 *  LSP clients as standalone files.
 */
export type HirFunction = HirFunction(
  name: string,
  type_params: [ string ],
  params: [ HirParam ],
  ret_type: TypeExpr,
  throw_row: TypeExpr,
  body: HirBody,
  span: Span,
  file: string,
  // Source-level `require { ... }` row preserved for typecheck-time wfCap
  // enforcement. Empty TyRow when the surface had no
  // require clause. Other passes (MIR/LIR/codegen) ignore this field;
  // require is a typecheck-only concern.
  requires: TypeExpr
)

/** HIR-level handler arm wrapper. Mirrors AST HandlerArm: an op
 *  implementation plus optional continuation binder from `with @k`.
 */
export type HirHandlerArm = HirHandlerArm(arm: HirFunction, cont_binder: Option<string>)

/** Public type HirHandlerBinding. */
export type HirHandlerBinding = HirHandlerBinding(
  cap_name: string,
  requires: TypeExpr,
  arms: [ HirHandlerArm ]
)

/** Public type HirHandlerBindingEntry. */
export type HirHandlerBindingEntry = HirHandlerBindingEntry(
  name: string,
  binding: HirHandlerBinding
)

/** ExtWasmDep: one external WASM dependency collected from
 *  `import external "X.wasm"` declarations.
 *  module_name: the verbatim import-module name (e.g. "add.wasm") used as the
 *    wasm import module string in codegen and as DepSpec.module_prefix for merge.
 *  wasm_path: resolved path to the .wasm file (relative to source file dir or
 *    absolute) — fed as DepSpec.wasm_path to merge_with_deps.
 */
export type ExtWasmDep = ExtWasmDep(module_name: string, wasm_path: string)

/** `value_binding_names`: top-level `let x = <non-lambda>`
 *  names; MIR uses it to skip closure-pointer wrapping for constants whose
 *  post-resolution shape is identical to arity-0 lambda bindings.
 */
export type HirProgram = HirProgram(
  caps: [ HirCap ],
  functions: [ HirFunction ],
  externals: [ HirExternal ],
  handler_bindings: [ HirHandlerBindingEntry ],
  enum_defs: [ EnumDef ],
  exception_groups: [ ExceptionGroupEntry ],
  value_binding_names: [ string ],
  type_defs: [ RecordDef ],
  visible_enum_names: [ string ],
  ext_wasm_deps: [ ExtWasmDep ]
)

/** Public type HirAccum. */
export type HirAccum = HirAccum(
  caps: [ HirCap ],
  functions: [ HirFunction ],
  externals: [ HirExternal ],
  handler_bindings: [ HirHandlerBindingEntry ],
  enum_defs: [ EnumDef ],
  wasm_module: Option<string>,
  exception_groups: [ ExceptionGroupEntry ],
  value_binding_names: [ string ],
  type_defs: [ RecordDef ],
  visible_enum_names: [ string ],
  ext_wasm_deps: [ ExtWasmDep ]
)
