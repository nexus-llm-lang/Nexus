/**
 * hir/build/accum: HirAccum assembly, exception-group expansion,
 * and HirProgram construction.
 *
 * Owns:
 * - empty_accum / register_exn_variant — accum initialisation
 * - expand_groups_in_* — post-processing pass that rewrites group-name
 *   constructor patterns in catch arms and handler bindings into per-member
 *   match cases
 * - accum_to_program — final HirAccum → HirProgram assembly
 *
 * Does not own:
 * - AST → HIR expression / statement conversion (see hir/convert/core.nx)
 * - Top-level definition processing (see hir/build/defs.nx)
 * - HIR type definitions (see src/ir/hir/types.nx)
 */
import { Sigil } from "src/types/vocab.nx"
import {
  EnumDef,
  RecordDef,
  VariantDef,
  VariantField,
  TyI64,
  TyString
} from "src/types/type_expr.nx"
import * as list from "std:list"
import {
  HirExpr,
  HirStmt,
  HirStmtKind,
  HirExprKind,
  HirCallArg,
  HirNamedExpr,
  HirMatchCase,
  HirPatternKind,
  HirPatternField,
  HirFunction,
  HirHandlerArm,
  HirHandlerBinding,
  HirHandlerBindingEntry,
  HirProgram,
  HirAccum,
  ExceptionGroupEntry,
  EagerBody,
  ExtWasmDep
} from "src/ir/hir/types.nx"
import { HirError } from "src/diagnostics/error.nx"

/** Create an empty HirAccum. */
export let empty_accum = fn () -> HirAccum do
  return HirAccum(
    caps: [], functions: [], externals: [],
    handler_bindings: [],
    // Seed Exn enum with built-in exception variants.
    // User-defined exceptions are added as variants via register_exn_variant.
    enum_defs: [ EnumDef(name: "Exn", is_public: true, is_opaque: false,
      type_params: [],
      variants: [
        VariantDef(
          name: "RuntimeError",
          fields: [ VariantField(name: Some(val: "val"), typ: TyString) ]
        ),
        VariantDef(
          name: "InvalidIndex",
          fields: [ VariantField(name: Some(val: "val"), typ: TyI64) ]
        ) ],
      layout_variants: []) ],
    wasm_module: None,
    exception_groups: [],
    value_binding_names: [],
    // Exn is always visible (built-in, always defining).
    visible_enum_names: [ "Exn"],
    type_defs: [],
    ext_wasm_deps: []
  )
end

/** Register an exception as a variant of the Exn enum in enum_defs. */
export let register_exn_variant = fn (
  enum_defs: [ EnumDef ],
  vname: string,
  vfields: [ VariantField ]
) -> [ EnumDef ] do
  return register_exn_variant_go(enum_defs, vname, vfields, acc: [])
end

let register_exn_variant_go = fn (
  enum_defs: [ EnumDef ],
  vname: string,
  vfields: [ VariantField ],
  acc: [ EnumDef ]
) -> [ EnumDef ] do
  match enum_defs do
    | [] -> return list.reverse(xs: acc)
    | ed :: rest ->
      let EnumDef(name: n, is_public: pub_, is_opaque: opq, type_params: tp, variants: vs, layout_variants: lvs) = ed
      if n == "Exn" then
          let new_variant = VariantDef(name: vname, fields: vfields)
          return list.concat(xs: list.reverse(xs: acc), ys: EnumDef(name: n, is_public: pub_, is_opaque: opq, type_params: tp,
            variants: new_variant :: vs, layout_variants: lvs) :: rest)
        else
          return register_exn_variant_go(enum_defs: rest, vname, vfields, acc: ed :: acc)
        end
  end
end

// Post-processing pass: expand group constructor patterns in catch arms.
// When a catch arm matches a group name (e.g., CompileError), expand it to
// one match case per member exception (e.g., UnexpectedToken, UnexpectedEof).

/** Look up a group name and return its members, or None if not a group. */
let lookup_group = fn (name: string, groups: [ ExceptionGroupEntry ]) -> Option<[ string ]> do
  match groups do
    | [] -> return None
    | ExceptionGroupEntry(name: gn, members: ms) :: rest ->
      if gn == name then return Some(val: ms)
      else return lookup_group(name, groups: rest) end
  end
end

/** Expand group patterns in a list of match cases.
 *  For each case with a PCtor whose variant is a group name, emit one case per member.
 */
let expand_groups_in_cases = fn (
  cases: [ HirMatchCase ],
  groups: [ ExceptionGroupEntry ]
) -> [ HirMatchCase ] do
  return expand_groups_in_cases_go(cases, groups, acc: [])
end

let expand_groups_in_cases_go = fn (
  cases: [ HirMatchCase ],
  groups: [ ExceptionGroupEntry ],
  acc: [ HirMatchCase ]
) -> [ HirMatchCase ] do
  match cases do
    | [] -> return list.reverse(xs: acc)
    | HirMatchCase(pattern: pat, body) :: rest ->
      let expanded_body = expand_groups_in_stmts(stmts: body, groups)
      match pat do
        | PCtor(variant: vname, fields: fs, sigil: sig) ->
          match lookup_group(name: vname, groups) do
            | Some(val: members) ->
              let member_cases = expand_group_members(
                members,
                fields: fs,
                body: expanded_body,
                sigil: sig
              )
              return expand_groups_in_cases_go(cases: rest, groups,
                acc: prepend_cases(cases: member_cases, acc))
            | None ->
              return expand_groups_in_cases_go(cases: rest, groups,
                acc: HirMatchCase(
                  pattern: PCtor(variant: vname, fields: fs, sigil: sig),
                  body: expanded_body
                ) :: acc)
          end
        | _ ->
          return expand_groups_in_cases_go(cases: rest, groups,
            acc: HirMatchCase(pattern: pat, body: expanded_body) :: acc)
      end
  end
end

/** Create one HirMatchCase per member, preserving the same fields and body. */
let expand_group_members = fn (
  members: [ string ],
  fields: [ HirPatternField ],
  body: [ HirStmt ],
  sigil: Sigil
) -> [ HirMatchCase ] do
  return expand_group_members_go(members, fields, body, sigil, acc: [])
end

let expand_group_members_go = fn (
  members: [ string ],
  fields: [ HirPatternField ],
  body: [ HirStmt ],
  sigil: Sigil,
  acc: [ HirMatchCase ]
) -> [ HirMatchCase ] do
  match members do
    | [] -> return acc
    | m :: rest ->
      return expand_group_members_go(members: rest, fields, body, sigil,
        acc: HirMatchCase(pattern: PCtor(variant: m, fields, sigil), body) :: acc)
  end
end

/** Prepend a list of cases onto an accumulator (in order). */
let prepend_cases = fn (cases: [ HirMatchCase ], acc: [ HirMatchCase ]) -> [ HirMatchCase ] do
  match cases do
    | [] -> return acc
    | c :: rest -> return prepend_cases(cases: rest, acc: c :: acc)
  end
end

/** Expand group patterns in a list of statements. */
let expand_groups_in_stmts = fn (
  stmts: [ HirStmt ],
  groups: [ ExceptionGroupEntry ]
) -> [ HirStmt ] do
  return expand_groups_in_stmts_go(stmts, groups, acc: [])
end

let expand_groups_in_stmts_go = fn (
  stmts: [ HirStmt ],
  groups: [ ExceptionGroupEntry ],
  acc: [ HirStmt ]
) -> [ HirStmt ] do
  match stmts do
    | [] -> return list.reverse(xs: acc)
    | HirStmt(node: sk, span: sp) :: rest ->
      let expanded = expand_groups_in_stmt_kind(stmt: sk, groups)
      return expand_groups_in_stmts_go(stmts: rest, groups,
        acc: HirStmt(node: expanded, span: sp) :: acc)
  end
end

let expand_groups_in_stmt_kind = fn (
  stmt: HirStmtKind,
  groups: [ ExceptionGroupEntry ]
) -> HirStmtKind do
  match stmt do
    | Let(name: n, sigil: sig, typ: t, value: v) ->
      return Let(name: n, sigil: sig, typ: t, value: expand_groups_in_expr(expr: v, groups))
    | Expr(expr: e) ->
      return Expr(expr: expand_groups_in_expr(expr: e, groups))
    | Return(expr: e) ->
      return Return(expr: expand_groups_in_expr(expr: e, groups))
    | Assign(target: t, value: v) ->
      return Assign(
        target: expand_groups_in_expr(expr: t, groups),
        value: expand_groups_in_expr(expr: v, groups))
    | Try(body: b, catch_param: cp, catch_body: cb) ->
      return Try(
        body: expand_groups_in_stmts(stmts: b, groups),
        catch_param: cp,
        catch_body: expand_groups_in_stmts(stmts: cb, groups))
  end
end

let expand_groups_in_expr = fn (expr: HirExpr, groups: [ ExceptionGroupEntry ]) -> HirExpr do
  let HirExpr(node: inner, span: sp) = expr
  return HirExpr(node: expand_groups_in_expr_kind(expr: inner, groups), span: sp)
end

let expand_groups_in_expr_kind = fn (
  expr: HirExprKind,
  groups: [ ExceptionGroupEntry ]
) -> HirExprKind do
  match expr do
    | Literal(lit: l) -> return Literal(lit: l)
    | Variable(name: n, sigil: s) -> return Variable(name: n, sigil: s)
    | BinOp(left: l, op: o, right: r) ->
      return BinOp(
        left: expand_groups_in_expr(expr: l, groups),
        op: o,
        right: expand_groups_in_expr(expr: r, groups))
    | UnOp(op: o, operand: x) ->
      return UnOp(op: o, operand: expand_groups_in_expr(expr: x, groups))
    | Borrow(name: n, sigil: s) -> return Borrow(name: n, sigil: s)
    | Call(func: f, args) ->
      return Call(func: f, args: expand_groups_in_call_args(args, groups))
    | CallExpr(callee: c, args) ->
      return CallExpr(
        callee: expand_groups_in_expr(expr: c, groups),
        args: expand_groups_in_call_args(args, groups))
    | Ctor(variant: v, args, labels, sigil: sig) ->
      return Ctor(
        variant: v,
        args: expand_groups_in_expr_list(exprs: args, groups),
        labels,
        sigil: sig
      )
    | Record(fields: fs) ->
      return Record(fields: expand_groups_in_named_exprs(exprs: fs, groups))
    | Array(elems: es) ->
      return Array(elems: expand_groups_in_expr_list(exprs: es, groups))
    | Index(target: t, index: i) ->
      return Index(
        target: expand_groups_in_expr(expr: t, groups),
        index: expand_groups_in_expr(expr: i, groups))
    | FieldAccess(target: t, field: f) ->
      return FieldAccess(target: expand_groups_in_expr(expr: t, groups), field: f)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let new_eb = match eb do
        | None -> None
        | Some(val: stmts) -> Some(val: expand_groups_in_stmts(stmts, groups))
      end
      return If(
        cond: expand_groups_in_expr(expr: c, groups),
        then_branch: expand_groups_in_stmts(stmts: tb, groups),
        else_branch: new_eb)
    | Match(target: t, cases: cs) ->
      return Match(
        target: expand_groups_in_expr(expr: t, groups),
        cases: expand_groups_in_cases(cases: cs, groups))
    | While(cond: c, body: b) ->
      return While(
        cond: expand_groups_in_expr(expr: c, groups),
        body: expand_groups_in_stmts(stmts: b, groups))
    | For(var: v, start: s, end_expr: e, body: b) ->
      return For(var: v,
        start: expand_groups_in_expr(expr: s, groups),
        end_expr: expand_groups_in_expr(expr: e, groups),
        body: expand_groups_in_stmts(stmts: b, groups))
    | Lambda(type_params: tps, params: ps, ret_type: rt, requires: req, throw_row: tw, body: b) ->
      return Lambda(type_params: tps, params: ps, ret_type: rt, requires: req, throw_row: tw,
        body: expand_groups_in_stmts(stmts: b, groups))
    | Raise(expr: e) ->
      return Raise(expr: expand_groups_in_expr(expr: e, groups))
    | Force(expr: e) ->
      return Force(expr: expand_groups_in_expr(expr: e, groups))
    | Thunk(body: b) ->
      return Thunk(body: expand_groups_in_expr(expr: b, groups))
    | ExternalRef(symbol: s, type_params: tps, arg_names: an, typ: t) ->
      return ExternalRef(symbol: s, type_params: tps, arg_names: an, typ: t)
    | Handler(cap_name: pn, requires: req, arms) ->
      return Handler(cap_name: pn, requires: req, arms: expand_groups_in_hir_arms(arms, groups))
    | Inject(handlers: hs, body: b) ->
      return Inject(handlers: hs, body: expand_groups_in_stmts(stmts: b, groups))
  end
end

let expand_groups_in_call_args = fn (
  args: [ HirCallArg ],
  groups: [ ExceptionGroupEntry ]
) -> [ HirCallArg ] do
  return expand_groups_in_call_args_go(args, groups, acc: [])
end

let expand_groups_in_call_args_go = fn (
  args: [ HirCallArg ],
  groups: [ ExceptionGroupEntry ],
  acc: [ HirCallArg ]
) -> [ HirCallArg ] do
  match args do
    | [] -> return list.reverse(xs: acc)
    | HirCallArg(label: l, value: v) :: rest ->
      return expand_groups_in_call_args_go(args: rest, groups,
        acc: HirCallArg(label: l, value: expand_groups_in_expr(expr: v, groups)) :: acc)
  end
end

let expand_groups_in_expr_list = fn (
  exprs: [ HirExpr ],
  groups: [ ExceptionGroupEntry ]
) -> [ HirExpr ] do
  return expand_groups_in_expr_list_go(exprs, groups, acc: [])
end

let expand_groups_in_expr_list_go = fn (
  exprs: [ HirExpr ],
  groups: [ ExceptionGroupEntry ],
  acc: [ HirExpr ]
) -> [ HirExpr ] do
  match exprs do
    | [] -> return list.reverse(xs: acc)
    | e :: rest ->
      return expand_groups_in_expr_list_go(exprs: rest, groups,
        acc: expand_groups_in_expr(expr: e, groups) :: acc)
  end
end

let expand_groups_in_named_exprs = fn (
  exprs: [ HirNamedExpr ],
  groups: [ ExceptionGroupEntry ]
) -> [ HirNamedExpr ] do
  return expand_groups_in_named_exprs_go(exprs, groups, acc: [])
end

let expand_groups_in_named_exprs_go = fn (
  exprs: [ HirNamedExpr ],
  groups: [ ExceptionGroupEntry ],
  acc: [ HirNamedExpr ]
) -> [ HirNamedExpr ] do
  match exprs do
    | [] -> return list.reverse(xs: acc)
    | HirNamedExpr(name: n, value: v) :: rest ->
      return expand_groups_in_named_exprs_go(exprs: rest, groups,
        acc: HirNamedExpr(name: n, value: expand_groups_in_expr(expr: v, groups)) :: acc)
  end
end

/** Expand groups in a list of HirFunctions. */
let expand_groups_in_hir_functions = fn (
  funcs: [ HirFunction ],
  groups: [ ExceptionGroupEntry ]
) -> [ HirFunction ] do
  return expand_groups_in_hir_functions_go(funcs, groups, acc: [])
end

let expand_groups_in_hir_functions_go = fn (
  funcs: [ HirFunction ],
  groups: [ ExceptionGroupEntry ],
  acc: [ HirFunction ]
) -> [ HirFunction ] do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | HirFunction(
      name: n,
      type_params: tps,
      params: ps,
      ret_type: rt,
      throw_row: tw,
      body: EagerBody(stmts: b),
      span: sp,
      file: fp,
      requires: req
    ) :: rest ->
      return expand_groups_in_hir_functions_go(funcs: rest, groups,
        acc: HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, throw_row: tw,
          body: EagerBody(stmts: expand_groups_in_stmts(stmts: b, groups)), span: sp, file: fp, requires: req) :: acc)
    | HirFunction(
      name: n,
      type_params: tps,
      params: ps,
      ret_type: rt,
      throw_row: tw,
      body: b,
      span: sp,
      file: fp,
      requires: req
    ) :: rest ->
      return expand_groups_in_hir_functions_go(funcs: rest, groups,
        acc: HirFunction(
          name: n,
          type_params: tps,
          params: ps,
          ret_type: rt,
          throw_row: tw,
          body: b,
          span: sp,
          file: fp,
          requires: req
        ) :: acc)
  end
end

/** Top-level: expand groups in all program functions. */
export let expand_groups_in_functions = fn (
  funcs: [ HirFunction ],
  groups: [ ExceptionGroupEntry ]
) -> [ HirFunction ] do
  match groups do
    | [] -> return funcs
    | _ :: _ -> return expand_groups_in_hir_functions(funcs, groups)
  end
end

/** Top-level: expand groups in handler bindings. */
export let expand_groups_in_handler_bindings = fn (
  bindings: [ HirHandlerBindingEntry ],
  groups: [ ExceptionGroupEntry ]
) -> [ HirHandlerBindingEntry ] do
  match groups do
    | [] -> return bindings
    | _ :: _ -> return expand_groups_in_handler_bindings_go(bindings, groups, acc: [])
  end
end

let expand_groups_in_handler_bindings_go = fn (
  bindings: [ HirHandlerBindingEntry ],
  groups: [ ExceptionGroupEntry ],
  acc: [ HirHandlerBindingEntry ]
) -> [ HirHandlerBindingEntry ] do
  match bindings do
    | [] -> return list.reverse(xs: acc)
    | HirHandlerBindingEntry(
      name: n,
      binding: HirHandlerBinding(cap_name: pn, requires: req, arms)
    ) :: rest ->
      let expanded_arms = expand_groups_in_hir_arms(arms, groups)
      return expand_groups_in_handler_bindings_go(bindings: rest, groups,
        acc: HirHandlerBindingEntry(
          name: n,
          binding: HirHandlerBinding(cap_name: pn, requires: req, arms: expanded_arms)
        ) :: acc)
  end
end

/** Run group-expansion over each arm's inner function, preserving the
 *  arm's cont_binder.
 */
let expand_groups_in_hir_arms = fn (
  arms: [ HirHandlerArm ],
  groups: [ ExceptionGroupEntry ]
) -> [ HirHandlerArm ] do
  return expand_groups_in_hir_arms_go(arms, groups, acc: [])
end

let expand_groups_in_hir_arms_go = fn (
  arms: [ HirHandlerArm ],
  groups: [ ExceptionGroupEntry ],
  acc: [ HirHandlerArm ]
) -> [ HirHandlerArm ] do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | HirHandlerArm(arm: f, cont_binder: kb) :: rest ->
      let expanded = expand_groups_in_hir_functions(funcs: [ f ], groups)
      let f2 = match expanded do | h :: _ -> h | [] -> f end
      return expand_groups_in_hir_arms_go(arms: rest, groups,
        acc: HirHandlerArm(arm: f2, cont_binder: kb) :: acc)
  end
end

let handler_arm_functions = fn (arms: [ HirHandlerArm ]) -> [ HirFunction ] do
  return handler_arm_functions_go(arms, acc: [])
end

let handler_arm_functions_go = fn (
  arms: [ HirHandlerArm ],
  acc: [ HirFunction ]
) -> [ HirFunction ] do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | HirHandlerArm(arm: f, cont_binder: _) :: rest ->
      return handler_arm_functions_go(arms: rest, acc: f :: acc)
  end
end

let extract_handler_functions = fn (bindings: [ HirHandlerBindingEntry ]) -> [ HirFunction ] throws { HirError } do
  match bindings do
    | [] -> return []
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      return append_hir_funcs(
        a: handler_arm_functions(arms),
        b: extract_handler_functions(bindings: rest)
      )
  end
end

let append_hir_funcs = fn (
  a: [ HirFunction ],
  b: [ HirFunction ]
) -> [ HirFunction ] throws { HirError } do
  match a do
    | [] -> return b
    | h :: t -> return h :: append_hir_funcs(a: t, b)
  end
end

/** Assemble a HirProgram from an accumulator with reachability filtering. */
export let accum_to_program = fn (accum: HirAccum) -> HirProgram throws { HirError } do
  let HirAccum(
    caps: ps,
    functions: fs,
    externals: exts,
    handler_bindings: hbs,
    enum_defs: eds,
    wasm_module: _,
    exception_groups: egs,
    value_binding_names: vbns,
    type_defs: tds,
    visible_enum_names: vens,
    ext_wasm_deps: ewds
  ) = accum
  // Expand exception group patterns in catch arms before reachability filtering.
  let expanded_fs = expand_groups_in_functions(funcs: fs, groups: egs)
  let expanded_hbs = expand_groups_in_handler_bindings(bindings: hbs, groups: egs)
  let filtered_funcs = expanded_fs
  let filtered_exts = exts
  // Note: LazyBody functions are NOT resolved here. The caller (main.nx)
  // resolves them after accum_to_program returns, because resolution requires
  // Fs capability to re-read source files.
  // Handler arm functions are lowered separately via lower_handler_functions
  // (which sets cont_binders for `with @k` arms). Don't merge them into the
  // global function table — they would otherwise be lowered twice.
  let all_funcs = filtered_funcs
  return HirProgram(
    caps: ps,
    functions: all_funcs,
    externals: filtered_exts,
    handler_bindings: expanded_hbs,
    enum_defs: eds,
    exception_groups: egs,
    value_binding_names: vbns,
    type_defs: tds,
    visible_enum_names: vens,
    ext_wasm_deps: ewds
  )
end

/** Extract the enum_defs field from a HirProgram. */
export let get_enum_defs = fn (hir: HirProgram) -> [ EnumDef ] do
  let HirProgram(caps: _, functions: _, externals: _, handler_bindings: _, enum_defs: eds, _) = hir
  eds
end

/** Extract the type_defs field from a HirProgram. */
export let get_type_defs = fn (hir: HirProgram) -> [ RecordDef ] do
  let HirProgram(
    caps: _,
    functions: _,
    externals: _,
    handler_bindings: _,
    enum_defs: _,
    exception_groups: _,
    value_binding_names: _,
    type_defs: tds,
    visible_enum_names: _
  ) = hir
  tds
end

/** Extract every enum name from a list of EnumDefs.
 *  Used by the whole-program typecheck to widen `visible_enum_names`
 *  to include private types so imported-module bodies can be body-checked
 *  without false-positive E2001 "unknown constructor" errors.
 */
export let all_enum_def_names = fn (defs: [ EnumDef ]) -> [ string ] do
  return all_enum_def_names_go(defs, acc: [])
end

let all_enum_def_names_go = fn (defs: [ EnumDef ], acc: [ string ]) -> [ string ] do
  match defs do
    | [] -> return acc
    | EnumDef(name: n, _) :: rest -> return all_enum_def_names_go(defs: rest, acc: n :: acc)
  end
end
