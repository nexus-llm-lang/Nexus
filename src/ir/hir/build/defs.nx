/**
 * hir/build/defs: top-level definition processing.
 *
 * Owns:
 * - process_defs / process_top_level / process_tl_let — fold SpannedTopLevel
 *   list into HirAccum
 * - synthesize_handler / synthesize_handler_arms — create named arm entries
 *   from ExprHandler, threading source_file onto each arm function
 * - handler_arm_functions — extract inner HirFunctions from a binding's arms
 * - make_hir_external / named_types_to_hir_params — ExternalRef lowering
 * - convert_cap_sigs — Cap signature → HirCap methods
 * - WIT-mapping helpers (stem_to_wit, map_stdlib_to_wit, etc.)
 * - infer_{tparams,params,ret}_from_expr / infer_constant_type — expr-shape
 *   probing without full conversion
 *
 * Does not own:
 * - AST → HIR expression/statement conversion (see hir/convert/core.nx)
 * - HirAccum assembly and exception-group expansion (see hir/build/accum.nx)
 */
import { Span } from "src/common/token.nx"
import * as naming from "src/common/naming.nx"
import {
  Sigil,
  SigilImmutable,
  SigilLazy,
  TypeExpr,
  TyI64,
  TyUnit,
  TyRow,
  TyArrow,
  TyLazy,
  TyString,
  TyBool,
  TyChar,
  TyF64,
  Expr,
  ExprLambda,
  ExprHandler,
  ExprExternal,
  NamedType,
  EnumDef,
  ImportDef,
  FunctionSig,
  Cap,
  GlobalLet,
  ExceptionDef,
  ExceptionGroupDef,
  SpannedExpr,
  SpannedTopLevel,
  TopLevel,
  TLImport,
  TLLet,
  TLCap,
  TLEnum,
  TLTypeDef,
  TLException,
  TLExceptionGroup,
  LitInt,
  LitFloat,
  LitString,
  LitChar,
  LitBool,
  LitUnit,
  Literal
} from "src/common/ast.nx"
import { HirError } from "src/common/error.nx"
import { MainExported } from "src/typecheck/errors.nx"
import { SymbolNotFound, SkExternal } from "src/backend/errors.nx"
import { RenameEntry }, * as symtab from "src/ir/shared/symtab.nx"
import * as str from "std:str"
import * as list from "std:list"
import {
  HirParam,
  HirCapMethod,
  HirCap,
  HirExternal,
  HirExpr,
  HirStmt,
  HirStmtKind,
  HirExprKind,
  EagerBody,
  LazyBody,
  HirFunction,
  HirHandlerArm,
  HirHandlerBinding,
  HirHandlerBindingEntry,
  HirAccum,
  ExceptionGroupEntry
} from "src/ir/hir/types.nx"
import { convert_expr, convert_expr_toplevel, convert_params } from "src/ir/hir/convert/core.nx"
import { register_exn_variant } from "src/ir/hir/build/accum.nx"

let stem_to_wit = fn (stem: string) -> string do
  if stem == "math" then return "nexus:std/math" end
  if stem == "str" then return "nexus:std/str" end
  if stem == "stdio" then return "nexus:std/stdio" end
  if stem == "fs" then return "nexus:std/fs" end
  if stem == "network" then return "nexus:std/network" end
  if stem == "proc" then return "nexus:std/proc" end
  if stem == "env" then return "nexus:std/env" end
  if stem == "clock" then return "nexus:std/clock" end
  if stem == "rand" then return "nexus:std/rand" end
  if stem == "char" then return "nexus:std/str" end
  if stem == "bytebuffer" then return "nexus:std/bytebuffer" end
  if stem == "hashmap" then return "nexus:std/collections" end
  if stem == "stringmap" then return "nexus:std/collections" end
  if stem == "set" then return "nexus:std/collections" end
  if stem == "array" then return "nexus:std/collections" end
  if stem == "core" then return "nexus:std/core" end
  return ""
end

/** Extract file stem from a path: "stdlib/str.nx" → "string", "src/backend/foo.nx" → "foo" */
let extract_nx_stem = fn (path: string) -> string do
  let dot_pos = str.index_of(s: path, sub: ".nx")
  if dot_pos < 0 then return "" end
  let stem_start = find_last_slash(s: path, pos: dot_pos - 1) + 1
  return str.substring(s: path, start: stem_start, len: dot_pos - stem_start)
end

/** Convert `pkg:path` to `nexus:pkg/path` per the package-resolver convention.
 *  Returns the empty string for paths without a `:` separator.
 */
let qualified_to_wit = fn (ext_path: string) -> string do
  // `nexus:intrinsic` is the special compiler-intrinsic module — the codegen
  // recognises this exact wasm-module name and inlines the op (no host import).
  // It has no `/`, so leave it verbatim rather than expanding to `nexus:nexus/intrinsic`.
  if ext_path == "nexus:intrinsic" then return ext_path end
  let colon_pos = str.index_of(s: ext_path, sub: ":")
  if colon_pos < 0 then return "" end
  let pkg = str.substring(s: ext_path, start: 0, len: colon_pos)
  let rest = str.substring(
    s: ext_path,
    start: colon_pos + 1,
    len: str.byte_length(s: ext_path) - colon_pos - 1
  )
  if str.length(s: pkg) == 0 then return "" end
  if str.length(s: rest) == 0 then return "" end
  // Already a `namespace:pkg/iface` import-module name — leave it alone.
  if str.contains(s: rest, sub: "/") then return ext_path end
  return "nexus:" ++ pkg ++ "/" ++ rest
end

let map_stdlib_to_wit = fn (ext_path: string, source_file: string) -> string do
  // New convention: `pkg:iface` resolves to `nexus:pkg/iface` directly.
  let qual = qualified_to_wit(ext_path)
  if str.length(s: qual) > 0 then return qual end
  // Legacy "stdlib/stdlib.wasm" form: derive import-module name from source file stem.
  if str.ends_with(s: ext_path, suffix: "stdlib.wasm") then
    let stem = extract_nx_stem(path: source_file)
    let wit = stem_to_wit(stem)
    if str.length(s: wit) > 0 then return wit end
    return ext_path
  end
  // Legacy ".nx" form: derive from the .nx file's stem.
  if str.ends_with(s: ext_path, suffix: ".nx") then
    let stem = extract_nx_stem(path: ext_path)
    let wit = stem_to_wit(stem)
    if str.length(s: wit) > 0 then return wit end
  end
  return ext_path
end

/** Check if ffi_name has the __nx_ prefix.
 *  Uses substring+equality instead of starts_with (historical OOM workaround;
 *  keep until the avoidance is verified unnecessary on the self-hosted path).
 */
let has_nx_prefix = fn (ffi_name: string) -> bool do
  if str.byte_length(s: ffi_name) < 5 then return false end
  return str.substring(s: ffi_name, start: 0, len: 5) == "__nx_"
end

/** Check if source_file is a stdlib path ("stdlib/" or "nxlib/stdlib/").
 *  Uses intrinsics (byte_length+substring) to avoid starts_with OOM.
 */
let is_stdlib_source = fn (path: string) -> bool do
  if str.byte_length(s: path) >= 7 then
    if str.substring(s: path, start: 0, len: 7) == "stdlib/" then return true end
  end
  if str.byte_length(s: path) >= 13 then
    if str.substring(s: path, start: 0, len: 13) == "nxlib/stdlib/" then return true end
  end
  return false
end

/** Build kebab-cased import name from position pos to end, replacing '_' with '-'. */
let build_wit_name = fn (s: string, pos: i64, len: i64, acc: string) -> string do
  if pos >= len then return acc end
  let b = str.byte_at(s, idx: pos)
  let ch = if b == '_' then "-" else str.substring(s, start: pos, len: 1) end
  return build_wit_name(s, pos: pos + 1, len, acc: acc ++ ch)
end

/** Convert FFI name to kebab-cased stdlib export name.
 *  Strips a leading __nx_ prefix when present, then kebab-cases
 *  ('_' -> '-') unconditionally so `mem_load_i32` and `__nx_mem_load_i32`
 *  both produce `mem-load-i32`.
 *  "__nx_abs_i64" -> "abs-i64", "mem_load_i32" -> "mem-load-i32"
 *  "allocate" -> "allocate", "f64-sqrt" -> "f64-sqrt"
 */
let wit_canonical_name = fn (ffi_name: string) -> string do
  let pos = if has_nx_prefix(ffi_name) then 5 else 0 end
  return build_wit_name(s: ffi_name, pos, len: str.byte_length(s: ffi_name), acc: "")
end

let find_last_slash = fn (s: string, pos: i64) -> i64 do
  if pos < 0 then return -1 end
  let c = str.byte_at(s, idx: pos)
  if c == '/' then return pos end
  return find_last_slash(s, pos: pos - 1)
end

/** Extract type params from a raw AST expression. */
let infer_tparams_from_expr = fn (expr: Expr) -> [ string ] do
  if let ExprLambda(
    type_params: tps,
    params: _,
    ret_type: _,
    requires: _,
    throw_row: _,
    body: _
  ) = expr then
    return tps
  else
    return []
  end
end

/** Extract HirParam list from a raw AST expression (ExprLambda → params, else []). */
let infer_params_from_expr = fn (expr: Expr) -> [ HirParam ] do
  if let ExprLambda(
    type_params: _,
    params: ps,
    ret_type: _,
    requires: _,
    throw_row: _,
    body: _
  ) = expr then
    return convert_params(params: ps)
  else
    return []
  end
end

/** Extract return type from a raw AST expression (ExprLambda → ret_type, else TyUnit). */
let infer_ret_from_expr = fn (expr: Expr) -> TypeExpr do
  if let ExprLambda(
    type_params: _,
    params: _,
    ret_type: rt,
    requires: _,
    throw_row: _,
    body: _
  ) = expr then
    return rt
  else
    return TyUnit
  end
end

let infer_constant_type = fn (expr: HirExpr) -> TypeExpr do
  let HirExpr(node: inner, span: _) = expr
  if let Literal(lit: l) = inner then
    match l do
      | LitInt(_) -> return TyI64
      | LitFloat(_) -> return TyF64
      | LitString(_) -> return TyString
      | LitChar(_) -> return TyChar
      | LitBool(_) -> return TyBool
      | LitUnit -> return TyUnit
    end
  else
    // Non-literal globals reach here only at HIR-build time, before typecheck
    // has run. The TyI64 placeholder is overwritten with the real inferred
    // type during typecheck (see check.check_function: the env_insert for a
    // zero-arg let rebinds at the real type once body inference completes).
    // We cannot run inference here because the env is not yet populated.
    // Raising would reject legitimate non-annotated globals like
    // `let x = Some(val: 1)` whose type typecheck derives from the body.
    return TyI64
  end
end

/** Build HirExternal from an external declaration's type arrow. */
let make_hir_external = fn (
  name: string,
  wasm_module: string,
  wasm_name: string,
  type_params: [ string ],
  arg_names: [ string ],
  typ: TypeExpr
) -> HirExternal do
  if let TyArrow(params, ret, requires: _, throw_row: tw) = typ then
    return HirExternal(name, wasm_module, wasm_name, type_params,
      params: named_types_to_hir_params(nts: params),
      ret_type: ret, throw_row: tw)
  else
    return HirExternal(name, wasm_module, wasm_name, type_params,
      params: [], ret_type: typ, throw_row: TyUnit)
  end
end

let named_types_to_hir_params = fn (nts: [ NamedType ]) -> [ HirParam ] do
  return named_types_to_hir_params_go(nts, acc: [])
end

let named_types_to_hir_params_go = fn (nts: [ NamedType ], acc: [ HirParam ]) -> [ HirParam ] do
  match nts do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: n, typ: t) :: rest ->
      // NamedType has no sigil — externals/cap sigs use type-only linearity.
      return named_types_to_hir_params_go(
        nts: rest,
        acc: HirParam(label: n, name: n, sigil: SigilImmutable, typ: t) :: acc
      )
  end
end

let convert_cap_sigs = fn (sigs: [ FunctionSig ], span: Span) -> [ HirCapMethod ] do
  return convert_cap_sigs_go(sigs, span, acc: [])
end

let convert_cap_sigs_go = fn (
  sigs: [ FunctionSig ],
  span: Span,
  acc: [ HirCapMethod ]
) -> [ HirCapMethod ] do
  match sigs do
    | [] -> return list.reverse(xs: acc)
    | FunctionSig(name: n, params: ps, ret_type: ret, requires: req, throw_row: tw) :: rest ->
      return convert_cap_sigs_go(
        sigs: rest,
        span,
        acc: HirCapMethod(
          name: n,
          requires: req,
          span,
          throw_row: tw,
          typ_params: convert_params(params: ps),
          typ_ret: ret
        ) :: acc
      )
  end
end

/** Synthesize handler binding: create named arm entries for each method.
 *  `source_file` is the path of the file declaring the handler binding —
 *  every synthesised arm function is tagged with it so cross-file LSP
 *  diagnostics can attribute typecheck failures inside the arm body to
 * the right file.
 */
let synthesize_handler = fn (
  binding_name: string,
  cap_name: string,
  requires: TypeExpr,
  arms: [ HirHandlerArm ],
  source_file: string
) -> HirHandlerBindingEntry do
  let synth_arms = synthesize_handler_arms(binding_name, arms, source_file)
  return HirHandlerBindingEntry(
    name: binding_name,
    binding: HirHandlerBinding(cap_name, requires, arms: synth_arms)
  )
end

let synthesize_handler_arms = fn (
  binding_name: string,
  arms: [ HirHandlerArm ],
  source_file: string
) -> [ HirHandlerArm ] do
  return synthesize_handler_arms_go(binding_name, arms, source_file, acc: [])
end

let synthesize_handler_arms_go = fn (
  binding_name: string,
  arms: [ HirHandlerArm ],
  source_file: string,
  acc: [ HirHandlerArm ]
) -> [ HirHandlerArm ] do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | HirHandlerArm(
      arm: HirFunction(
        name: n,
        type_params: tps,
        params: ps,
        ret_type: rt,
        throw_row: tw,
        body: b,
        span: sp,
        file: _,
        requires: req
      ),
      cont_binder: kb
    ) :: rest ->
      let synth_name = naming.handler_func_name(handler_name: binding_name, method_name: n)
      let synth_params = match kb do
        | Some(val: k) ->
          // Synthesised `with @k` continuation binder: TyLazy already triggers
          // type-side linearity; sigil mirrors the implicit `@k` shape.
          let k_p = HirParam(label: k, name: k, sigil: SigilLazy, typ: TyLazy(inner: rt))
          list.concat(xs: ps, ys: [ k_p ])
        | None -> ps
      end
      let synth_arm = HirHandlerArm(
        arm: HirFunction(
          name: synth_name,
          type_params: tps,
          params: synth_params,
          ret_type: rt,
          throw_row: tw,
          body: b,
          span: sp,
          file: source_file,
          requires: req
        ),
        cont_binder: kb
      )
      return synthesize_handler_arms_go(
        binding_name,
        arms: rest,
        source_file,
        acc: synth_arm :: acc
      )
  end
end

let process_tl_let = fn (qname: string, orig_name: string, val: SpannedExpr, type_ann: Option<TypeExpr>,
    entries: [ RenameEntry ], span: Span, accum: HirAccum, source_file: string) -> HirAccum throws { HirError } do
  let HirAccum(
    caps: ps,
    functions: fs,
    externals: exts,
    handler_bindings: hbs,
    enum_defs: eds,
    wasm_module: wmod,
    exception_groups: egs,
    value_binding_names: vbns,
    type_defs: tds,
    visible_enum_names: vens
  ) = accum
  // Stdlib files: full convert_expr (handlers/externals/constants are cheap,
  // and keeping them as EagerBody avoids cumulative OOM during lazy resolve).
  // Non-stdlib: convert_expr_toplevel for Lambda bodies (deferred via LazyBody),
  // but convert_expr for Handler/External (cheap and must be handled correctly).
  let is_stdlib = is_stdlib_source(path: source_file)
  let SpannedExpr(node: val_peek, span: _) = val
  let hir_val = if is_stdlib then convert_expr(expr: val, entries)
    else match val_peek do
      | ExprHandler(_) | ExprExternal(_) -> convert_expr(expr: val, entries)
      | _ -> convert_expr_toplevel(expr: val, entries)
    end
  end
  let HirExpr(node: hir_val_node, span: _) = hir_val
  match hir_val_node do
    | Lambda(type_params: tps, params: lps, ret_type: rt, requires: _, throw_row: _, body: _) ->
      // Lambdas get LazyBody — ret_type is the user-declared return type (rt).
      // Non-lambda globals wrapped as Lambda (by convert_expr_toplevel) reach
      // here for `let x = <expr>`. The TyI64 fallback for un-annotated cases
      // is a placeholder: resolve_all_lazy_via_convert re-runs body inference
      // and overwrites the HirFunction ret_type with the real type before
      // typecheck sees it. Raising here would reject legitimate un-annotated
      // globals like `let x = Some(val: 1)`.
      let effective_rt = match val_peek do
        | ExprLambda(_) -> rt
        | _ -> match type_ann do | Some(val: t) -> t | None -> TyI64 end
      end
      // Pull throw_row from the ExprLambda when present; non-lambda lazy bodies
      // (e.g. constant `let x = expr`) carry no row, so default to empty.
      let lambda_throw_row = match val_peek do
        | ExprLambda(
          type_params: _,
          params: _,
          ret_type: _,
          requires: _,
          throw_row: tw,
          body: _
        ) -> tw
        | _ -> TyRow(types: [], rest: None)
      end
      // Preserve the source-level require row for typecheck-time wfCap
      // enforcement. Non-lambda value bindings carry no row.
      let lambda_requires = match val_peek do
        | ExprLambda(
          type_params: _,
          params: _,
          ret_type: _,
          requires: req,
          throw_row: _,
          body: _
        ) -> req
        | _ -> TyRow(types: [], rest: None)
      end
      // track constants wrapped as Lambda by convert_expr_toplevel.
      let new_vbns = match val_peek do
        | ExprLambda(_) -> vbns
        | _ -> qname :: vbns
      end
      let func = HirFunction(name: qname, type_params: tps, params: lps,
        ret_type: effective_rt, throw_row: lambda_throw_row, body: LazyBody(
          ast_expr: val,
          entries
        ), span, file: source_file, requires: lambda_requires)
      return HirAccum(caps: ps, functions: func :: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs, value_binding_names: new_vbns, type_defs: tds, visible_enum_names: vens)
    | Handler(cap_name: pname, requires: handler_req, arms: handler_arms) ->
      let binding = synthesize_handler(
        binding_name: qname, cap_name: pname, requires: handler_req, arms: handler_arms, source_file)
      return HirAccum(caps: ps, functions: fs, externals: exts,
        handler_bindings: binding :: hbs,
        enum_defs: eds, wasm_module: wmod, exception_groups: egs, value_binding_names: vbns, type_defs: tds, visible_enum_names: vens)
    | ExternalRef(symbol: sym, type_params: tps, arg_names: anames, typ: t) ->
      match wmod do
        | Some(val: wm) ->
          // Only kebab-canonicalize for namespaced modules (wm contains ':').
          // Raw-path modules (e.g. "stdlib/stdlib.wasm" fallback from map_stdlib_to_wit)
          // keep __nx_ snake names as-is to match the actual wasm exports.
          let effective_sym = if str.contains(s: wm, sub: ":") then
              wit_canonical_name(ffi_name: sym)
            else sym
          end
          let ext = make_hir_external(name: qname, wasm_module: wm,
            wasm_name: effective_sym, type_params: tps, arg_names: anames, typ: t)
          return HirAccum(caps: ps, functions: fs,
            externals: ext :: exts,
            handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs, value_binding_names: vbns, type_defs: tds, visible_enum_names: vens)
        | None ->
          let Span(offset: _, line: l, col: c) = span
          throw SymbolNotFound(name: qname, kind: SkExternal,
            context: "hir.convert_global: external declaration requires a preceding 'import external \"path/to.wasm\"' — none found in this file (at line "
              ++ str.from_i64(val: l) ++ ", col " ++ str.from_i64(val: c) ++ ")")
      end
    | _ ->
      let rt = match type_ann do
        | Some(val: t) -> t
        | None -> infer_constant_type(expr: hir_val)
      end
        let debug_name = qname
      let func = HirFunction(
        name: debug_name, type_params: [], params: [], ret_type: rt,
        throw_row: TyRow(types: [], rest: None),
        body: EagerBody(stmts: [ HirStmt(node: Return(expr: hir_val), span) ]),
        span,
        file: source_file,
        requires: TyRow(types: [], rest: None))
      return HirAccum(caps: ps, functions: func :: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs, value_binding_names: qname :: vbns, type_defs: tds, visible_enum_names: vens)
  end
end

let process_top_level = fn (
  node: TopLevel,
  span: Span,
  entries: [ RenameEntry ],
  accum: HirAccum,
  source_file: string,
  is_defining: i64
) -> HirAccum throws { HirError } do
  let HirAccum(
    caps: ps,
    functions: fs,
    externals: exts,
    handler_bindings: hbs,
    enum_defs: eds,
    wasm_module: wmod,
    exception_groups: egs,
    value_binding_names: vbns,
    type_defs: tds,
    visible_enum_names: vens
  ) = accum
  match node do
    | TLImport(def: ImportDef(path, alias: _, items: _, is_external: is_ext)) ->
      if is_ext then
        let mapped = map_stdlib_to_wit(ext_path: path, source_file)
        return HirAccum(caps: ps, functions: fs, externals: exts,
          handler_bindings: hbs, enum_defs: eds, wasm_module: Some(val: mapped), exception_groups: egs, value_binding_names: vbns, type_defs: tds, visible_enum_names: vens)
      else
        return accum
      end
    | TLLet(def: GlobalLet(name, is_public, typ: type_ann, value: val)) ->
      if name == "main" && is_public then
        throw MainExported
      end
      let qname = symtab.rename(name, entries)
      return process_tl_let(qname, orig_name: name, val, type_ann, entries,
        span, accum, source_file)
    | TLCap(def: Cap(name: pname, is_public: _, functions: sigs)) ->
      let qname = symtab.rename(name: pname, entries)
      let hir_cap = HirCap(name: qname, methods: convert_cap_sigs(sigs, span))
      return HirAccum(caps: hir_cap :: ps, functions: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs, value_binding_names: vbns, type_defs: tds, visible_enum_names: vens)
    | TLEnum(def: ed) ->
      // D-Export: non-public enums from imported files must not expose their
      // constructors to the importing module. We track which enum names are
      // "visible" (constructor-registerable) in visible_enum_names:
      // an enum is visible iff it is from the defining file (is_defining == 1)
      // OR it is exported (is_public). Non-visible enums are still kept in
      // enum_defs so the VariantIndex has their field layout for correct codegen.
      //
      // D-Type-Sum-Opaque: when processing an imported file, opaque
      // enum constructors are withheld by stripping variants to []. The type name
      // itself still enters typedef (so the type can be used as a type annotation),
      // but Γ-lookup of c_i fails (T-App / P-Ctor find nothing in env), enforcing
      // the spec's "constructors withheld from importing modules" premise.
      match ed do
        | EnumDef(name: n, is_public: pub_, is_opaque: opq, type_params: tps, variants: vs) ->
          let ed_stored = if opq && is_defining == 0 then
            EnumDef(name: n, is_public: pub_, is_opaque: opq, type_params: tps, variants: [])
          else
            EnumDef(name: n, is_public: pub_, is_opaque: opq, type_params: tps, variants: vs)
          end
          // Add to visible_enum_names only if constructors should be accessible:
          // defining file (is_defining == 1) or publicly exported.
          let new_vens = if is_defining == 1 || pub_ then
            n :: vens
          else
            vens
          end
          return HirAccum(caps: ps, functions: fs, externals: exts,
            handler_bindings: hbs,
            enum_defs: ed_stored :: eds, wasm_module: wmod, exception_groups: egs, value_binding_names: vbns, type_defs: tds, visible_enum_names: new_vens)
      end
    | TLTypeDef(def: rd) ->
      return HirAccum(caps: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: eds, wasm_module: wmod,
        exception_groups: egs, value_binding_names: vbns, type_defs: rd :: tds, visible_enum_names: vens)
    | TLException(def: ExceptionDef(name: ename, is_public: _, fields: efields)) ->
      let updated_eds = register_exn_variant(enum_defs: eds, vname: ename, vfields: efields)
      return HirAccum(caps: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: updated_eds, wasm_module: wmod, exception_groups: egs, value_binding_names: vbns, type_defs: tds, visible_enum_names: vens)
    | TLExceptionGroup(def: ExceptionGroupDef(name: gname, is_public: _, members: gmembers)) ->
      return HirAccum(caps: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: eds, wasm_module: wmod,
        exception_groups: ExceptionGroupEntry(
          name: gname,
          members: gmembers
        ) :: egs, value_binding_names: vbns, type_defs: tds, visible_enum_names: vens)
  end
end

/** Process a list of top-level definitions into HIR components.
 *  `is_defining` must be `true` when processing the entry file being compiled
 *  and `false` when processing an imported module. Opaque enum constructors
 *  are withheld (variants stripped to []) when `is_defining` is `false`,
 *  implementing D-Type-Sum-Opaque.
 */
export let process_defs = fn (
  defs: [ SpannedTopLevel ],
  entries: [ RenameEntry ],
  accum: HirAccum,
  source_file: string,
  is_defining: i64
) -> HirAccum throws { HirError } do
  match defs do
    | [] -> return accum
    | SpannedTopLevel(node, span: sp) :: rest ->
      let new_accum = process_top_level(node, span: sp, entries, accum, source_file, is_defining)
      return process_defs(
        defs: rest,
        entries: entries,
        accum: new_accum,
        source_file: source_file,
        is_defining: is_defining
      )
  end
end
