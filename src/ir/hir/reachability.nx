/**
 * reachability: dead-function elimination via call-graph worklist from "main".
 *
 * Owns:
 * - HIR expression/statement call-site collection (collect_calls_*)
 * - Worklist reachability (collect_reachable, reachable_go)
 * - Reachability-filtered function / external lists (filter_reachable_*)
 *
 * Does not own:
 * - AST → HIR conversion (stays in src/ir/hir.nx)
 * - HirProgram assembly / exception-group expansion (accum_to_program, in hir.nx)
 *
 * Consumers: called from src/ir/demand.nx via the iterative-resolve loop.
 * src/ir/hir.nx re-imports and re-exports nothing from this module; consumers
 * import the public API directly (collect_reachable, filter_reachable_functions,
 * collect_calls_stmts).
 */
import { HirStmt, HirStmtKind, HirExpr, HirExprKind, HirCallArg, HirNamedExpr, HirMatchCase, HirFunction, HirHandlerArm, HirHandlerBinding, HirHandlerBindingEntry, EagerBody, LazyBody } from "src/ir/hir_types.nx"
import * as str from "std:str"
import { StrMap }, * as smap from "src/common/strmap.nx"

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_string = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_string(lst: rest, out: x :: out)
  end
end

let rev_hir_function = fn (lst: [HirFunction], out: [HirFunction]) -> [HirFunction] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_function(lst: rest, out: x :: out)
  end
end

// ─── String list helpers ────────────────────────────────────────────────────

let concat_str_lists = fn (a: [string], b: [string]) -> [string] do
  return concat_str_lists_go(a, b, acc: [])
end

let concat_str_lists_go = fn (a: [string], b: [string], acc: [string]) -> [string] do
  match a do
    | [] -> return rev_string(lst: acc, out: b)
    | x :: rest ->
      return concat_str_lists_go(a: rest, b, acc: x :: acc)
  end
end

let str_in_list = fn (s: string, xs: [string]) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true
      else return str_in_list(s, xs: rest)
      end
  end
end

// ─── Call-Site Collection ───────────────────────────────────────────────────
//
// All collectors thread an accumulator and *prepend* names onto it, so the
// whole traversal allocates exactly one cons cell per collected name — no
// intermediate `[string]` lists, no `concat_str_lists` reversal churn. Result
// order is unspecified (callers use these only as reachability worklist seeds).

/** Collect all function names called from a list of HIR statements. */
export let collect_calls_stmts = fn (stmts: [HirStmt]) -> [string] do
  return collect_calls_stmts_into(stmts, acc: [])
end

let collect_calls_stmts_into = fn (stmts: [HirStmt], acc: [string]) -> [string] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: s, span: _) :: rest ->
      return collect_calls_stmts_into(stmts: rest, acc: collect_calls_stmt_kind_into(stmt: s, acc))
  end
end

let collect_calls_stmt_kind_into = fn (stmt: HirStmtKind, acc: [string]) -> [string] do
  match stmt do
    | Let(name: _, sigil: _, typ: _, value: v) -> return collect_calls_expr_into(expr: v, acc)
    | Expr(expr: e) -> return collect_calls_expr_into(expr: e, acc)
    | Return(expr: e) -> return collect_calls_expr_into(expr: e, acc)
    | Assign(target: t, value: v) ->
      return collect_calls_expr_into(expr: t, acc: collect_calls_expr_into(expr: v, acc))
    | Try(body: b, catch_param: _, catch_body: cb) ->
      return collect_calls_stmts_into(stmts: b, acc: collect_calls_stmts_into(stmts: cb, acc))
    | Inject(handlers: hs, body: b) ->
      return concat_str_lists(a: hs, b: collect_calls_stmts_into(stmts: b, acc))
  end
end

let collect_calls_expr_into = fn (expr: HirExpr, acc: [string]) -> [string] do
  let HirExpr(node: inner, span: _) = expr
  return collect_calls_expr_kind_into(expr: inner, acc)
end

let collect_calls_expr_kind_into = fn (expr: HirExprKind, acc: [string]) -> [string] do
  match expr do
    | Literal(_) -> return acc
    | Variable(name: n, sigil: _) -> return n :: acc
    | BinOp(left: l, op: _, right: r) ->
      return collect_calls_expr_into(expr: l, acc: collect_calls_expr_into(expr: r, acc))
    | UnOp(op: _, operand: o) -> return collect_calls_expr_into(expr: o, acc)
    | Borrow(_) -> return acc
    | Call(func: f, args) ->
      return f :: collect_calls_args_into(args, acc)
    | Ctor(variant: _, args, sigil: _) -> return collect_calls_expr_list_into(exprs: args, acc)
    | Record(fields: fs) -> return collect_calls_named_exprs_into(exprs: fs, acc)
    | Array(elems: es) -> return collect_calls_expr_list_into(exprs: es, acc)
    | Index(target: t, index: i) ->
      return collect_calls_expr_into(expr: t, acc: collect_calls_expr_into(expr: i, acc))
    | FieldAccess(target: t, field: _) -> return collect_calls_expr_into(expr: t, acc)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let after_then = collect_calls_stmts_into(stmts: tb, acc)
      let after_else = match eb do
        | Some(val: stmts) -> collect_calls_stmts_into(stmts, acc: after_then)
        | None -> after_then
      end
      return collect_calls_expr_into(expr: c, acc: after_else)
    | Match(target: t, cases: cs) ->
      return collect_calls_expr_into(expr: t, acc: collect_calls_cases_into(cases: cs, acc))
    | While(cond: c, body: b) ->
      return collect_calls_expr_into(expr: c, acc: collect_calls_stmts_into(stmts: b, acc))
    | For(var: _, start: s, end_expr: e, body: b) ->
      return collect_calls_expr_into(expr: s,
        acc: collect_calls_expr_into(expr: e, acc: collect_calls_stmts_into(stmts: b, acc)))
    | Lambda(type_params: _, params: _, ret_type: _, body: b) -> return collect_calls_stmts_into(stmts: b, acc)
    | Raise(expr: e) -> return collect_calls_expr_into(expr: e, acc)
    | Force(expr: e) -> return collect_calls_expr_into(expr: e, acc)
    | Thunk(body: b) -> return collect_calls_expr_into(expr: b, acc)
    | ExternalRef(_) -> return acc
    | Handler(port_name: _, arms) -> return collect_calls_functions_into(funcs: arms_to_funcs(arms), acc)
  end
end

let collect_calls_args_into = fn (args: [HirCallArg], acc: [string]) -> [string] do
  match args do
    | [] -> return acc
    | HirCallArg(label: _, value: v) :: rest ->
      return collect_calls_args_into(args: rest, acc: collect_calls_expr_into(expr: v, acc))
  end
end

let collect_calls_named_exprs_into = fn (exprs: [HirNamedExpr], acc: [string]) -> [string] do
  match exprs do
    | [] -> return acc
    | HirNamedExpr(name: _, value: v) :: rest ->
      return collect_calls_named_exprs_into(exprs: rest, acc: collect_calls_expr_into(expr: v, acc))
  end
end

let collect_calls_expr_list_into = fn (exprs: [HirExpr], acc: [string]) -> [string] do
  match exprs do
    | [] -> return acc
    | e :: rest ->
      return collect_calls_expr_list_into(exprs: rest, acc: collect_calls_expr_into(expr: e, acc))
  end
end

let collect_calls_cases_into = fn (cases: [HirMatchCase], acc: [string]) -> [string] do
  match cases do
    | [] -> return acc
    | HirMatchCase(pattern: _, body: b) :: rest ->
      return collect_calls_cases_into(cases: rest, acc: collect_calls_stmts_into(stmts: b, acc))
  end
end

let collect_calls_functions = fn (funcs: [HirFunction]) -> [string] do
  return collect_calls_functions_into(funcs, acc: [])
end

let collect_calls_functions_into = fn (funcs: [HirFunction], acc: [string]) -> [string] do
  match funcs do
    | [] -> return acc
    | HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: EagerBody(stmts: b), _) :: rest ->
      return collect_calls_functions_into(funcs: rest, acc: collect_calls_stmts_into(stmts: b, acc))
    | HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: LazyBody(_), _) :: rest ->
      return collect_calls_functions_into(funcs: rest, acc)
  end
end

// ─── Worklist Reachability ──────────────────────────────────────────────────

/** Worklist reachability: starting from "main", collect all transitively called functions. */
export let collect_reachable = fn (functions: [HirFunction], handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  let handler_seeds = collect_handler_seeds(bindings: handler_bindings, acc: [])
  let intrinsic_seeds = collect_intrinsic_seeds(functions, acc: [])
  let worklist = concat_str_lists(a: ["main"], b: concat_str_lists(a: handler_seeds, b: intrinsic_seeds))
  let func_index = build_func_index(functions, acc: smap.empty())
  // `seen` is a membership set; the value is a dummy (1). Using i64 rather than
  // unit keeps the StrMap instantiation a plain pointer-or-int — codegen for a
  // zero-width generic argument is fragile in the bootstrap seed.
  let seen0: StrMap<i64> = smap.empty()
  return reachable_go(worklist, visited: [], seen: seen0, func_index, handler_bindings)
end

/** name → defining function, so worklist steps are a hash lookup rather than */
/** an O(|functions|) list scan. Later entries shadow earlier ones; the */
/** compiler has already rejected genuine duplicate definitions upstream. */
let build_func_index = fn (functions: [HirFunction], acc: StrMap<HirFunction>) -> StrMap<HirFunction> do
  match functions do
    | [] -> return acc
    | f :: rest ->
      let HirFunction(name: n, type_params: _, params: _, ret_type: _, _) = f
      return build_func_index(functions: rest, acc: smap.insert(m: acc, k: n, v: f))
  end
end

/** Extra reachability roots: functions that are referenced indirectly by codegen */
/** intrinsics rather than by an explicit call in user code. The sched-spawn */
/** intrinsic emits `ref.func $__nx_sched_trampoline_body` to seed cont.new for */
/** each spawned fiber; without anchoring it as a root the dead-function pass */
/** would prune it before codegen ever asks for the funcref. */
let collect_intrinsic_seeds = fn (functions: [HirFunction], acc: [string]) -> [string] do
  match functions do
    | [] -> return acc
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, _) :: rest ->
      if str_ends_with_trampoline_body(s: n) then
        return collect_intrinsic_seeds(functions: rest, acc: n :: acc)
      end
      if str_ends_with_suffix(s: n, suffix: "wasi_thread_start") then
        return collect_intrinsic_seeds(functions: rest, acc: n :: acc)
      end
      return collect_intrinsic_seeds(functions: rest, acc)
  end
end

let str_ends_with_suffix = fn (s: string, suffix: string) -> bool do
  let slen = str.length(s)
  let suflen = str.length(s: suffix)
  if slen < suflen then return false end
  return str.substring(s, start: slen - suflen, len: suflen) == suffix
end

let str_ends_with_trampoline_body = fn (s: string) -> bool do
  return str_ends_with_suffix(s, suffix: "__nx_sched_trampoline_body")
end

let collect_handler_seeds = fn (bindings: [HirHandlerBindingEntry], acc: [string]) -> [string] do
  match bindings do
    | [] -> return acc
    | HirHandlerBindingEntry(name: bname, binding: HirHandlerBinding(port_name: _, arms)) :: rest ->
      let fs = arms_to_funcs(arms)
      let calls = collect_calls_functions(funcs: fs)
      let func_names = collect_handler_func_names(funcs: fs)
      return collect_handler_seeds(bindings: rest, acc: concat_str_lists(a: bname :: concat_str_lists(a: func_names, b: calls), b: acc))
  end
end

/** Strip cont_binder wrappers from a handler-arm list, yielding plain */
/** HirFunctions for the existing reachability traversal. The cont_binder */
/** itself does not affect call-graph reachability — it's a binder */
/** resolved at codegen, not a function reference. */
let arms_to_funcs = fn (arms: [HirHandlerArm]) -> [HirFunction] do
  match arms do
    | [] -> return []
    | HirHandlerArm(arm: f, cont_binder: _) :: rest -> return f :: arms_to_funcs(arms: rest)
  end
end

let collect_handler_func_names = fn (funcs: [HirFunction]) -> [string] do
  match funcs do
    | [] -> return []
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, _) :: rest ->
      return n :: collect_handler_func_names(funcs: rest)
  end
end

let reachable_go = fn (worklist: [string], visited: [string], seen: StrMap<i64>, func_index: StrMap<HirFunction>, handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  match worklist do
    | [] -> return visited
    | name :: rest ->
      if smap.contains(m: seen, k: name) then
        return reachable_go(worklist: rest, visited, seen, func_index, handler_bindings)
      else
        let new_visited = name :: visited
        let new_seen = smap.insert(m: seen, k: name, v: 1)
        let calls = find_calls_for_name(name, func_index, handler_bindings)
        let new_worklist = concat_str_lists(a: calls, b: rest)
        return reachable_go(worklist: new_worklist, visited: new_visited, seen: new_seen, func_index, handler_bindings)
      end
  end
end

let find_calls_for_name = fn (name: string, func_index: StrMap<HirFunction>, handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  match smap.get(m: func_index, k: name) do
    | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: EagerBody(stmts: b), _)) ->
      return collect_calls_stmts(stmts: b)
    | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: LazyBody(_), _)) ->
      return []
    | None ->
      return find_calls_in_handlers(name, bindings: handler_bindings)
  end
end

let find_function = fn (name: string, functions: [HirFunction]) -> Option<HirFunction> do
  match functions do
    | [] -> return None
    | f :: rest ->
      let HirFunction(name: n, type_params: _, params: _, ret_type: _, _) = f
      if n == name then return Some(val: f)
      else return find_function(name, functions: rest)
      end
  end
end

let find_calls_in_handlers = fn (name: string, bindings: [HirHandlerBindingEntry]) -> [string] do
  match bindings do
    | [] -> return []
    | HirHandlerBindingEntry(name: bname, binding: HirHandlerBinding(port_name: _, arms)) :: rest ->
      let fs = arms_to_funcs(arms)
      if bname == name then
        return collect_calls_functions(funcs: fs)
      else
        let found = find_function(name, functions: fs)
        match found do
          | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: EagerBody(stmts: body), _)) ->
            return collect_calls_stmts(stmts: body)
          | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: LazyBody(_), _)) ->
            return []
          | None -> return find_calls_in_handlers(name, bindings: rest)
        end
      end
  end
end

// ─── Reachability-Filtered Lists ────────────────────────────────────────────

/** Filter functions to only reachable ones (plus __handler_* functions, always kept). */
export let filter_reachable_functions = fn (functions: [HirFunction], reachable: [string]) -> [HirFunction] do
  return filter_reachable_functions_go(functions, reachable, acc: [])
end

let filter_reachable_functions_go = fn (functions: [HirFunction], reachable: [string], acc: [HirFunction]) -> [HirFunction] do
  match functions do
    | [] -> return rev_hir_function(lst: acc, out: [])
    | f :: rest ->
      let HirFunction(name: n, type_params: _, params: _, ret_type: _, _) = f
      if str_in_list(s: n, xs: reachable) || str.starts_with(s: n, prefix: "__handler_") then
        return filter_reachable_functions_go(functions: rest, reachable, acc: f :: acc)
      else
        return filter_reachable_functions_go(functions: rest, reachable, acc)
      end
  end
end

