/**
 * reachability: dead-function elimination via call-graph worklist from "main".
 *
 * Owns:
 * - HIR expression/statement call-site collection (collect_calls_*)
 * - Worklist reachability (collect_reachable, reachable_go)
 * - Reachability-filtered function / external lists (filter_reachable_*)
 *
 * Does not own:
 * - AST → HIR conversion (stays in src/ir/hir.nx)
 * - HirProgram assembly / exception-group expansion (accum_to_program, in hir.nx)
 *
 * Consumers: called from src/ir/demand.nx via the iterative-resolve loop.
 * src/ir/hir.nx re-imports and re-exports nothing from this module; consumers
 * import the public API directly (collect_reachable, filter_reachable_functions,
 * filter_reachable_externals, collect_calls_stmts).
 */
import { HirStmt, HirStmtKind, HirExpr, HirExprKind, HirCallArg, HirNamedExpr, HirMatchCase, HirFunction, HirHandlerArm, HirExternal, HirHandlerBinding, HirHandlerBindingEntry, EagerBody, LazyBody } from "src/ir/hir_types.nx"
import * as str from "std:string_ops"

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_string = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_string(lst: rest, out: x :: out)
  end
end

let rev_hir_function = fn (lst: [HirFunction], out: [HirFunction]) -> [HirFunction] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_function(lst: rest, out: x :: out)
  end
end

let rev_hir_external = fn (lst: [HirExternal], out: [HirExternal]) -> [HirExternal] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_external(lst: rest, out: x :: out)
  end
end

// ─── String list helpers ────────────────────────────────────────────────────

let concat_str_lists = fn (a: [string], b: [string]) -> [string] do
  return concat_str_lists_go(a, b, acc: [])
end

let concat_str_lists_go = fn (a: [string], b: [string], acc: [string]) -> [string] do
  match a do
    | [] -> return rev_string(lst: acc, out: b)
    | x :: rest ->
      return concat_str_lists_go(a: rest, b, acc: x :: acc)
  end
end

let str_in_list = fn (s: string, xs: [string]) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true
      else return str_in_list(s, xs: rest)
      end
  end
end

// ─── Call-Site Collection ───────────────────────────────────────────────────

/// Collect all function names called from a list of HIR statements.
export let collect_calls_stmts = fn (stmts: [HirStmt]) -> [string] do
  return collect_calls_stmts_go(stmts, acc: [])
end

let collect_calls_stmts_go = fn (stmts: [HirStmt], acc: [string]) -> [string] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: s, span: _) :: rest ->
      let calls = collect_calls_stmt_kind(stmt: s)
      return collect_calls_stmts_go(stmts: rest, acc: concat_str_lists(a: calls, b: acc))
  end
end

let collect_calls_stmt_kind = fn (stmt: HirStmtKind) -> [string] do
  match stmt do
    | Let(name: _, typ: _, value: v) -> return collect_calls_expr(expr: v)
    | Expr(expr: e) -> return collect_calls_expr(expr: e)
    | Return(expr: e) -> return collect_calls_expr(expr: e)
    | Assign(target: t, value: v) ->
      return concat_str_lists(a: collect_calls_expr(expr: t), b: collect_calls_expr(expr: v))
    | Try(body: b, catch_param: _, catch_body: cb) ->
      return concat_str_lists(a: collect_calls_stmts(stmts: b), b: collect_calls_stmts(stmts: cb))
    | Inject(handlers: hs, body: b) ->
      return concat_str_lists(a: hs, b: collect_calls_stmts(stmts: b))
  end
end

let collect_calls_expr = fn (expr: HirExpr) -> [string] do
  let HirExpr(node: inner, span: _) = expr
  return collect_calls_expr_kind(expr: inner)
end

let collect_calls_expr_kind = fn (expr: HirExprKind) -> [string] do
  match expr do
    | Literal(_) -> return []
    | Variable(name: n, sigil: _) -> return [n]
    | BinOp(left: l, op: _, right: r) ->
      return concat_str_lists(a: collect_calls_expr(expr: l), b: collect_calls_expr(expr: r))
    | UnOp(op: _, operand: o) -> return collect_calls_expr(expr: o)
    | Borrow(_) -> return []
    | Call(func: f, args) ->
      return f :: collect_calls_args(args)
    | Ctor(variant: _, args) -> return collect_calls_expr_list(exprs: args)
    | Record(fields: fs) -> return collect_calls_named_exprs(exprs: fs)
    | Array(elems: es) -> return collect_calls_expr_list(exprs: es)
    | Index(target: t, index: i) ->
      return concat_str_lists(a: collect_calls_expr(expr: t), b: collect_calls_expr(expr: i))
    | FieldAccess(target: t, field: _) -> return collect_calls_expr(expr: t)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let base = concat_str_lists(a: collect_calls_expr(expr: c), b: collect_calls_stmts(stmts: tb))
      match eb do
        | Some(val: stmts) -> return concat_str_lists(a: base, b: collect_calls_stmts(stmts))
        | None -> return base
      end
    | Match(target: t, cases: cs) ->
      return concat_str_lists(a: collect_calls_expr(expr: t), b: collect_calls_cases(cases: cs))
    | While(cond: c, body: b) ->
      return concat_str_lists(a: collect_calls_expr(expr: c), b: collect_calls_stmts(stmts: b))
    | For(var: _, start: s, end_expr: e, body: b) ->
      return concat_str_lists(
        a: collect_calls_expr(expr: s),
        b: concat_str_lists(a: collect_calls_expr(expr: e), b: collect_calls_stmts(stmts: b))
      )
    | Lambda(type_params: _, params: _, ret_type: _, body: b) -> return collect_calls_stmts(stmts: b)
    | Raise(expr: e) -> return collect_calls_expr(expr: e)
    | Force(expr: e) -> return collect_calls_expr(expr: e)
    | Thunk(body: b) -> return collect_calls_expr(expr: b)
    | ExternalRef(_) -> return []
    | Handler(port_name: _, arms: arms) -> return collect_calls_functions(funcs: arms_to_funcs(arms))
  end
end

let collect_calls_args = fn (args: [HirCallArg]) -> [string] do
  return collect_calls_args_go(args, acc: [])
end

let collect_calls_args_go = fn (args: [HirCallArg], acc: [string]) -> [string] do
  match args do
    | [] -> return acc
    | HirCallArg(label: _, value: v) :: rest ->
      return collect_calls_args_go(args: rest, acc: concat_str_lists(a: collect_calls_expr(expr: v), b: acc))
  end
end

let collect_calls_named_exprs = fn (exprs: [HirNamedExpr]) -> [string] do
  return collect_calls_named_exprs_go(exprs, acc: [])
end

let collect_calls_named_exprs_go = fn (exprs: [HirNamedExpr], acc: [string]) -> [string] do
  match exprs do
    | [] -> return acc
    | HirNamedExpr(name: _, value: v) :: rest ->
      return collect_calls_named_exprs_go(exprs: rest, acc: concat_str_lists(a: collect_calls_expr(expr: v), b: acc))
  end
end

let collect_calls_expr_list = fn (exprs: [HirExpr]) -> [string] do
  return collect_calls_expr_list_go(exprs, acc: [])
end

let collect_calls_expr_list_go = fn (exprs: [HirExpr], acc: [string]) -> [string] do
  match exprs do
    | [] -> return acc
    | e :: rest ->
      return collect_calls_expr_list_go(exprs: rest, acc: concat_str_lists(a: collect_calls_expr(expr: e), b: acc))
  end
end

let collect_calls_cases = fn (cases: [HirMatchCase]) -> [string] do
  return collect_calls_cases_go(cases, acc: [])
end

let collect_calls_cases_go = fn (cases: [HirMatchCase], acc: [string]) -> [string] do
  match cases do
    | [] -> return acc
    | HirMatchCase(pattern: _, body: b) :: rest ->
      return collect_calls_cases_go(cases: rest, acc: concat_str_lists(a: collect_calls_stmts(stmts: b), b: acc))
  end
end

let collect_calls_functions = fn (funcs: [HirFunction]) -> [string] do
  return collect_calls_functions_go(funcs, acc: [])
end

let collect_calls_functions_go = fn (funcs: [HirFunction], acc: [string]) -> [string] do
  match funcs do
    | [] -> return acc
    | HirFunction(name: _, type_params: _, params: _, ret_type: _, body: EagerBody(stmts: b), span: _) :: rest ->
      return collect_calls_functions_go(funcs: rest, acc: concat_str_lists(a: collect_calls_stmts(stmts: b), b: acc))
    | HirFunction(name: _, type_params: _, params: _, ret_type: _, body: LazyBody(_), span: _) :: rest ->
      return collect_calls_functions_go(funcs: rest, acc)
  end
end

// ─── Worklist Reachability ──────────────────────────────────────────────────

/// Worklist reachability: starting from "main", collect all transitively called functions.
export let collect_reachable = fn (functions: [HirFunction], handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  let handler_seeds = collect_handler_seeds(bindings: handler_bindings, acc: [])
  let intrinsic_seeds = collect_intrinsic_seeds(functions, acc: [])
  let worklist = concat_str_lists(a: ["main"], b: concat_str_lists(a: handler_seeds, b: intrinsic_seeds))
  return reachable_go(worklist, visited: [], functions, handler_bindings)
end

/// Extra reachability roots: functions that are referenced indirectly by codegen
/// intrinsics rather than by an explicit call in user code. The sched-spawn
/// intrinsic emits `ref.func $__nx_sched_trampoline_body` to seed cont.new for
/// each spawned fiber; without anchoring it as a root the dead-function pass
/// would prune it before codegen ever asks for the funcref.
let collect_intrinsic_seeds = fn (functions: [HirFunction], acc: [string]) -> [string] do
  match functions do
    | [] -> return acc
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, body: _, span: _) :: rest ->
      if str_ends_with_trampoline_body(s: n) then
        return collect_intrinsic_seeds(functions: rest, acc: n :: acc)
      end
      return collect_intrinsic_seeds(functions: rest, acc)
  end
end

let str_ends_with_trampoline_body = fn (s: string) -> bool do
  let suffix = "__nx_sched_trampoline_body"
  let slen = str.length(s: s)
  let suflen = str.length(s: suffix)
  if slen < suflen then return false end
  return str.substring(s: s, start: slen - suflen, len: suflen) == suffix
end

let collect_handler_seeds = fn (bindings: [HirHandlerBindingEntry], acc: [string]) -> [string] do
  match bindings do
    | [] -> return acc
    | HirHandlerBindingEntry(name: bname, binding: HirHandlerBinding(port_name: _, arms: arms)) :: rest ->
      let fs = arms_to_funcs(arms)
      let calls = collect_calls_functions(funcs: fs)
      let func_names = collect_handler_func_names(funcs: fs)
      return collect_handler_seeds(bindings: rest, acc: concat_str_lists(a: bname :: concat_str_lists(a: func_names, b: calls), b: acc))
  end
end

/// Strip cont_binder wrappers from a handler-arm list, yielding plain
/// HirFunctions for the existing reachability traversal. The cont_binder
/// itself does not affect call-graph reachability — it's a binder
/// resolved at codegen, not a function reference.
let arms_to_funcs = fn (arms: [HirHandlerArm]) -> [HirFunction] do
  match arms do
    | [] -> return []
    | HirHandlerArm(arm: f, cont_binder: _) :: rest -> return f :: arms_to_funcs(arms: rest)
  end
end

let collect_handler_func_names = fn (funcs: [HirFunction]) -> [string] do
  match funcs do
    | [] -> return []
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, body: _, span: _) :: rest ->
      return n :: collect_handler_func_names(funcs: rest)
  end
end

let reachable_go = fn (worklist: [string], visited: [string], functions: [HirFunction], handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  match worklist do
    | [] -> return visited
    | name :: rest ->
      if str_in_list(s: name, xs: visited) then
        return reachable_go(worklist: rest, visited, functions, handler_bindings)
      else
        let new_visited = name :: visited
        let calls = find_calls_for_name(name, functions, handler_bindings)
        let new_worklist = concat_str_lists(a: calls, b: rest)
        return reachable_go(worklist: new_worklist, visited: new_visited, functions, handler_bindings)
      end
  end
end

let find_calls_for_name = fn (name: string, functions: [HirFunction], handler_bindings: [HirHandlerBindingEntry]) -> [string] do
  let func = find_function(name, functions)
  match func do
    | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, body: EagerBody(stmts: b), span: _)) ->
      return collect_calls_stmts(stmts: b)
    | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, body: LazyBody(_), span: _)) ->
      return []
    | None ->
      return find_calls_in_handlers(name, bindings: handler_bindings)
  end
end

let find_function = fn (name: string, functions: [HirFunction]) -> Option<HirFunction> do
  match functions do
    | [] -> return None
    | f :: rest ->
      let HirFunction(name: n, type_params: _, params: _, ret_type: _, body: _, span: _) = f
      if n == name then return Some(val: f)
      else return find_function(name, functions: rest)
      end
  end
end

let find_calls_in_handlers = fn (name: string, bindings: [HirHandlerBindingEntry]) -> [string] do
  match bindings do
    | [] -> return []
    | HirHandlerBindingEntry(name: bname, binding: HirHandlerBinding(port_name: _, arms: arms)) :: rest ->
      let fs = arms_to_funcs(arms)
      if bname == name then
        return collect_calls_functions(funcs: fs)
      else
        let found = find_function(name, functions: fs)
        match found do
          | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, body: EagerBody(stmts: body), span: _)) ->
            return collect_calls_stmts(stmts: body)
          | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, body: LazyBody(_), span: _)) ->
            return []
          | None -> return find_calls_in_handlers(name, bindings: rest)
        end
      end
  end
end

// ─── Reachability-Filtered Lists ────────────────────────────────────────────

/// Filter functions to only reachable ones (plus __handler_* functions, always kept).
export let filter_reachable_functions = fn (functions: [HirFunction], reachable: [string]) -> [HirFunction] do
  return filter_reachable_functions_go(functions, reachable, acc: [])
end

let filter_reachable_functions_go = fn (functions: [HirFunction], reachable: [string], acc: [HirFunction]) -> [HirFunction] do
  match functions do
    | [] -> return rev_hir_function(lst: acc, out: [])
    | f :: rest ->
      let HirFunction(name: n, type_params: _, params: _, ret_type: _, body: _, span: _) = f
      if str_in_list(s: n, xs: reachable) || str.starts_with(s: n, prefix: "__handler_") then
        return filter_reachable_functions_go(functions: rest, reachable, acc: f :: acc)
      else
        return filter_reachable_functions_go(functions: rest, reachable, acc)
      end
  end
end

/// Filter externals to only reachable ones.
export let filter_reachable_externals = fn (externals: [HirExternal], reachable: [string]) -> [HirExternal] do
  return filter_reachable_externals_go(externals, reachable, acc: [])
end

let filter_reachable_externals_go = fn (externals: [HirExternal], reachable: [string], acc: [HirExternal]) -> [HirExternal] do
  match externals do
    | [] -> return rev_hir_external(lst: acc, out: [])
    | ext :: rest ->
      let HirExternal(name: n, wasm_module: _, wasm_name: _, type_params: _, params: _, ret_type: _, throw_row: _) = ext
      if str_in_list(s: n, xs: reachable) then
        return filter_reachable_externals_go(externals: rest, reachable, acc: ext :: acc)
      else
        return filter_reachable_externals_go(externals: rest, reachable, acc)
      end
  end
end
