/**
 * reachability: dead-function elimination via call-graph worklist from "main".
 *
 * Owns:
 * - HIR expression/statement call-site collection (collect_calls_*)
 * - Worklist reachability (collect_reachable, reachable_go)
 * - Reachability-filtered function / external lists (filter_reachable_*)
 *
 * Does not own:
 * - AST → HIR conversion (stays in src/ir/hir/hir.nx)
 * - HirProgram assembly / exception-group expansion (accum_to_program, in hir.nx)
 *
 */
import {
  HirStmt,
  HirStmtKind,
  HirExpr,
  HirExprKind,
  HirCallArg,
  HirNamedExpr,
  HirMatchCase,
  HirFunction,
  HirHandlerArm,
  HirHandlerBinding,
  HirHandlerBindingEntry,
  HirExternal,
  EagerBody,
  LazyBody
} from "src/ir/hir/types.nx"
import * as list from "std:list"
import * as str from "std:str"
import { StrMap }, * as smap from "src/util/strmap.nx"

let rev_string = fn (lst: [ string ], out: [ string ]) -> [ string ] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_string(lst: rest, out: x :: out)
  end
end

let concat_str_lists = fn (a: [ string ], b: [ string ]) -> [ string ] do
  return concat_str_lists_go(a, b, acc: [])
end

let concat_str_lists_go = fn (a: [ string ], b: [ string ], acc: [ string ]) -> [ string ] do
  match a do
    | [] -> return rev_string(lst: acc, out: b)
    | x :: rest ->
      return concat_str_lists_go(a: rest, b, acc: x :: acc)
  end
end

let str_in_list = fn (s: string, xs: [ string ]) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true
      else return str_in_list(s, xs: rest)
      end
  end
end

//
// All collectors thread an accumulator and *prepend* names onto it, so the
// whole traversal allocates exactly one cons cell per collected name — no
// intermediate `[string]` lists, no `concat_str_lists` reversal churn. Result
// order is unspecified (callers use these only as reachability worklist seeds).

/** Collect all function names called from a list of HIR statements. The internal
 *  `_into` helpers stay private — only the seed entry point is exported. */
export let collect_calls_stmts = fn (stmts: [ HirStmt ]) -> [ string ] do
  return collect_calls_stmts_into(stmts, acc: [])
end

let collect_calls_stmts_into = fn (stmts: [ HirStmt ], acc: [ string ]) -> [ string ] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: s, span: _) :: rest ->
      return collect_calls_stmts_into(stmts: rest, acc: collect_calls_stmt_kind_into(stmt: s, acc))
  end
end

let collect_calls_stmt_kind_into = fn (stmt: HirStmtKind, acc: [ string ]) -> [ string ] do
  match stmt do
    | Let(name: _, sigil: _, typ: _, value: v) -> return collect_calls_expr_into(expr: v, acc)
    | Expr(expr: e) | Return(expr: e) -> return collect_calls_expr_into(expr: e, acc)
    | Assign(target: t, value: v) ->
      return collect_calls_expr_into(expr: t, acc: collect_calls_expr_into(expr: v, acc))
    | Try(body: b, catch_param: _, catch_body: cb) ->
      return collect_calls_stmts_into(stmts: b, acc: collect_calls_stmts_into(stmts: cb, acc))
    | Inject(handlers: hs, body: b) ->
      return concat_str_lists(a: hs, b: collect_calls_stmts_into(stmts: b, acc))
  end
end

let collect_calls_expr_into = fn (expr: HirExpr, acc: [ string ]) -> [ string ] do
  let HirExpr(node: inner, span: _) = expr
  return collect_calls_expr_kind_into(expr: inner, acc)
end

let collect_calls_expr_kind_into = fn (expr: HirExprKind, acc: [ string ]) -> [ string ] do
  match expr do
    | Literal(_) | Borrow(_) | ExternalRef(_) -> return acc
    | Variable(name: n, sigil: _) -> return n :: acc
    | BinOp(left: l, op: _, right: r) ->
      return collect_calls_expr_into(expr: l, acc: collect_calls_expr_into(expr: r, acc))
    | UnOp(op: _, operand: o) -> return collect_calls_expr_into(expr: o, acc)
    | Call(func: f, args) ->
      return f :: collect_calls_args_into(args, acc)
    | CallExpr(callee: c, args) ->
      return collect_calls_expr_into(expr: c, acc: collect_calls_args_into(args, acc))
    | Ctor(
      variant: _,
      args,
      labels: _,
      sigil: _
    ) -> return collect_calls_expr_list_into(exprs: args, acc)
    | Record(fields: fs) -> return collect_calls_named_exprs_into(exprs: fs, acc)
    | Array(elems: es) -> return collect_calls_expr_list_into(exprs: es, acc)
    | Index(target: t, index: i) ->
      return collect_calls_expr_into(expr: t, acc: collect_calls_expr_into(expr: i, acc))
    | FieldAccess(target: t, field: _) -> return collect_calls_expr_into(expr: t, acc)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let after_then = collect_calls_stmts_into(stmts: tb, acc)
      let after_else = match eb do
        | Some(val: stmts) -> collect_calls_stmts_into(stmts, acc: after_then)
        | None -> after_then
      end
      return collect_calls_expr_into(expr: c, acc: after_else)
    | Match(target: t, cases: cs) ->
      return collect_calls_expr_into(expr: t, acc: collect_calls_cases_into(cases: cs, acc))
    | While(cond: c, body: b) ->
      return collect_calls_expr_into(expr: c, acc: collect_calls_stmts_into(stmts: b, acc))
    | For(var: _, start: s, end_expr: e, body: b) ->
      return collect_calls_expr_into(expr: s,
        acc: collect_calls_expr_into(expr: e, acc: collect_calls_stmts_into(stmts: b, acc)))
    | Lambda(
      type_params: _,
      params: _,
      ret_type: _,
      requires: _,
      throw_row: _,
      body: b
    ) -> return collect_calls_stmts_into(stmts: b, acc)
    | Raise(expr: e) | Force(expr: e) -> return collect_calls_expr_into(expr: e, acc)
    | Thunk(body: b) -> return collect_calls_expr_into(expr: b, acc)
    | Handler(
      cap_name: _,
      requires: _,
      arms
    ) -> return collect_calls_functions_into(funcs: arms_to_funcs(arms), acc)
  end
end

let collect_calls_args_into = fn (args: [ HirCallArg ], acc: [ string ]) -> [ string ] do
  match args do
    | [] -> return acc
    | HirCallArg(label: _, value: v) :: rest ->
      return collect_calls_args_into(args: rest, acc: collect_calls_expr_into(expr: v, acc))
  end
end

let collect_calls_named_exprs_into = fn (exprs: [ HirNamedExpr ], acc: [ string ]) -> [ string ] do
  match exprs do
    | [] -> return acc
    | HirNamedExpr(name: _, value: v) :: rest ->
      return collect_calls_named_exprs_into(exprs: rest, acc: collect_calls_expr_into(expr: v, acc))
  end
end

let collect_calls_expr_list_into = fn (exprs: [ HirExpr ], acc: [ string ]) -> [ string ] do
  match exprs do
    | [] -> return acc
    | e :: rest ->
      return collect_calls_expr_list_into(exprs: rest, acc: collect_calls_expr_into(expr: e, acc))
  end
end

let collect_calls_cases_into = fn (cases: [ HirMatchCase ], acc: [ string ]) -> [ string ] do
  match cases do
    | [] -> return acc
    | HirMatchCase(pattern: _, body: b) :: rest ->
      return collect_calls_cases_into(cases: rest, acc: collect_calls_stmts_into(stmts: b, acc))
  end
end

let collect_calls_functions = fn (funcs: [ HirFunction ]) -> [ string ] do
  return collect_calls_functions_into(funcs, acc: [])
end

let collect_calls_functions_into = fn (funcs: [ HirFunction ], acc: [ string ]) -> [ string ] do
  match funcs do
    | [] -> return acc
    | HirFunction(
      name: _,
      type_params: _,
      params: _,
      ret_type: _,
      throw_row: _,
      body: EagerBody(stmts: b),
      _
    ) :: rest ->
      return collect_calls_functions_into(funcs: rest, acc: collect_calls_stmts_into(stmts: b, acc))
    | HirFunction(
      name: _,
      type_params: _,
      params: _,
      ret_type: _,
      throw_row: _,
      body: LazyBody(_),
      _
    ) :: rest ->
      return collect_calls_functions_into(funcs: rest, acc)
  end
end

/** Worklist reachability: starting from "main", collect all transitively called functions. */
export let collect_reachable = fn (
  functions: [ HirFunction ],
  handler_bindings: [ HirHandlerBindingEntry ]
) -> [ string ] do
  let handler_seeds = collect_handler_seeds(bindings: handler_bindings, acc: [])
  let intrinsic_seeds = collect_intrinsic_seeds(functions, acc: [])
  let worklist = concat_str_lists(
    a: [ "main"],
    b: concat_str_lists(a: handler_seeds, b: intrinsic_seeds)
  )
  let func_index = build_func_index(functions, acc: smap.empty())
  // `seen` is a membership set; the value is a dummy (1). Using i64 rather than
  // unit keeps the StrMap instantiation a plain pointer-or-int — codegen for a
  // zero-width generic argument is fragile in the bootstrap seed.
  let seen0: StrMap<i64> = smap.empty()
  return reachable_go(worklist, visited: [], seen: seen0, func_index, handler_bindings)
end

/** Like `collect_reachable` but skips the `wasi_thread_start` codegen anchor
 * seed. Driver post-processing uses this variant to
 *  decide whether the WASI-threads callback is actually used; importing
 *  `std:lazy` without invoking `lazy.spawn` should not drag in the
 *  `lazy_run_task`/`force_closure` chain that wasmtime cannot instantiate.
 */
export let collect_reachable_no_thread_start = fn (
  functions: [ HirFunction ],
  handler_bindings: [ HirHandlerBindingEntry ]
) -> [ string ] do
  let handler_seeds = collect_handler_seeds(bindings: handler_bindings, acc: [])
  let trampoline_seeds = collect_trampoline_seeds(functions, acc: [])
  let func_index = build_func_index(functions, acc: smap.empty())
  let seen0: StrMap<i64> = smap.empty()
  let worklist = concat_str_lists(
    a: [ "main"],
    b: concat_str_lists(a: handler_seeds, b: trampoline_seeds)
  )
  return reachable_go(worklist, visited: [], seen: seen0, func_index, handler_bindings)
end

/** Reachability set starting only from `main` (no handler/trampoline seeds).
 *  Used exclusively for filtering externals: a wasm import is kept only when
 *  an actual call-path from `main` reaches the external's canonical name.
 *
 *  Why this differs from `collect_reachable_no_thread_start`:
 *  - Handler seeds unconditionally mark every handler-arm body as reachable,
 *    including handlers whose capability is never injected in the program.
 *    For externals this is wrong: if `Net` is never injected, the
 *    `http_request` wasm import must NOT appear in the binary (preview1
 *    wasmtime cannot satisfy it).
 *  - The Inject stmt collector already adds the handler binding name to
 *    reachable when the capability IS injected, so programs that do inject
 *    Net will transitively reach `http_request` via
 *    find_calls_in_handlers → arm bodies → callee chain.
 *  - `filter_reachable_functions` still uses the handler-seeded set so that
 *    `__handler_*` functions and inject-targeted arm functions remain in the
 *    final function list (they are needed by inject codegen even when DCE
 *    prunes the handler binding name itself from the main-only reachable set).
 */
export let collect_reachable_from_main = fn (
  functions: [ HirFunction ],
  handler_bindings: [ HirHandlerBindingEntry ]
) -> [ string ] do
  let func_index = build_func_index(functions, acc: smap.empty())
  let seen0: StrMap<i64> = smap.empty()
  return reachable_go(worklist: [ "main"], visited: [], seen: seen0, func_index, handler_bindings)
end

/** name → defining function, so worklist steps are a hash lookup rather than
 *  an O(|functions|) list scan. Later entries shadow earlier ones; the
 *  compiler has already rejected genuine duplicate definitions upstream.
 */
let build_func_index = fn (
  functions: [ HirFunction ],
  acc: StrMap<HirFunction>
) -> StrMap<HirFunction> do
  match functions do
    | [] -> return acc
    | f :: rest ->
      let HirFunction(name: n, type_params: _, params: _, ret_type: _, _) = f
      return build_func_index(functions: rest, acc: smap.insert(m: acc, k: n, v: f))
  end
end

/** Extra reachability roots: functions that are referenced indirectly by codegen
 *  intrinsics rather than by an explicit call in user code. The sched-spawn
 *  intrinsic emits `ref.func $__nx_sched_trampoline_body` to seed cont.new for
 *  each spawned fiber; without anchoring it as a root the dead-function pass
 *  would prune it before codegen ever asks for the funcref.
 */
let collect_intrinsic_seeds = fn (functions: [ HirFunction ], acc: [ string ]) -> [ string ] do
  match functions do
    | [] -> return acc
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, _) :: rest ->
      if str_ends_with_trampoline_body(s: n) then
        return collect_intrinsic_seeds(functions: rest, acc: n :: acc)
      end
      if str_ends_with_suffix(s: n, suffix: "wasi_thread_start") then
        return collect_intrinsic_seeds(functions: rest, acc: n :: acc)
      end
      return collect_intrinsic_seeds(functions: rest, acc)
  end
end

/** Subset of `collect_intrinsic_seeds` excluding the `wasi_thread_start`
 *  anchor; used by `collect_reachable_no_thread_start`.
 */
let collect_trampoline_seeds = fn (functions: [ HirFunction ], acc: [ string ]) -> [ string ] do
  match functions do
    | [] -> return acc
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, _) :: rest ->
      if str_ends_with_trampoline_body(s: n) then
        return collect_trampoline_seeds(functions: rest, acc: n :: acc)
      end
      return collect_trampoline_seeds(functions: rest, acc)
  end
end

/** True when any canonical name in `names` ends with `#lazy_spawn`. The driver
 *  uses this as the proxy for "this program needs WASI-threads plumbing",
 * flipping post-`iterative_resolve` DCE on or off.
 */
export let any_canonical_lazy_spawn = fn (names: [ string ]) -> bool do
  match names do
    | [] -> return false
    | n :: rest ->
      if str_ends_with_suffix(s: n, suffix: "#lazy_spawn") then return true end
      return any_canonical_lazy_spawn(names: rest)
  end
end

let str_ends_with_suffix = fn (s: string, suffix: string) -> bool do
  let slen = str.length(s)
  let suflen = str.length(s: suffix)
  if slen < suflen then return false end
  return str.substring(s, start: slen - suflen, len: suflen) == suffix
end

let str_ends_with_trampoline_body = fn (s: string) -> bool do
  return str_ends_with_suffix(s, suffix: "__nx_sched_trampoline_body")
end

let collect_handler_seeds = fn (
  bindings: [ HirHandlerBindingEntry ],
  acc: [ string ]
) -> [ string ] do
  match bindings do
    | [] -> return acc
    | HirHandlerBindingEntry(
      name: bname,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      let fs = arms_to_funcs(arms)
      let calls = collect_calls_functions(funcs: fs)
      let func_names = collect_handler_func_names(funcs: fs)
      return collect_handler_seeds(
        bindings: rest,
        acc: concat_str_lists(a: bname :: concat_str_lists(a: func_names, b: calls), b: acc)
      )
  end
end

/** Strip cont_binder wrappers from a handler-arm list, yielding plain
 *  HirFunctions for the existing reachability traversal. The cont_binder
 *  itself does not affect call-graph reachability — it's a binder
 *  resolved at codegen, not a function reference.
 */
let arms_to_funcs = fn (arms: [ HirHandlerArm ]) -> [ HirFunction ] do
  match arms do
    | [] -> return []
    | HirHandlerArm(arm: f, cont_binder: _) :: rest -> return f :: arms_to_funcs(arms: rest)
  end
end

let collect_handler_func_names = fn (funcs: [ HirFunction ]) -> [ string ] do
  match funcs do
    | [] -> return []
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, _) :: rest ->
      return n :: collect_handler_func_names(funcs: rest)
  end
end

let reachable_go = fn (
  worklist: [ string ],
  visited: [ string ],
  seen: StrMap<i64>,
  func_index: StrMap<HirFunction>,
  handler_bindings: [ HirHandlerBindingEntry ]
) -> [ string ] do
  match worklist do
    | [] -> return visited
    | name :: rest ->
      if smap.contains(m: seen, k: name) then
        return reachable_go(worklist: rest, visited, seen, func_index, handler_bindings)
      else
        let new_visited = name :: visited
        let new_seen = smap.insert(m: seen, k: name, v: 1)
        let calls = find_calls_for_name(name, func_index, handler_bindings)
        let new_worklist = concat_str_lists(a: calls, b: rest)
        return reachable_go(
          worklist: new_worklist,
          visited: new_visited,
          seen: new_seen,
          func_index,
          handler_bindings
        )
      end
  end
end

let find_calls_for_name = fn (
  name: string,
  func_index: StrMap<HirFunction>,
  handler_bindings: [ HirHandlerBindingEntry ]
) -> [ string ] do
  match smap.get(m: func_index, k: name) do
    | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: EagerBody(stmts: b), _)) ->
      return collect_calls_stmts(stmts: b)
    | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: LazyBody(_), _)) ->
      return []
    | None ->
      return find_calls_in_handlers(name, bindings: handler_bindings)
  end
end

let lookup_function = fn (name: string, functions: [ HirFunction ]) -> Option<HirFunction> do
  match functions do
    | [] -> return None
    | f :: rest ->
      let HirFunction(name: n, type_params: _, params: _, ret_type: _, _) = f
      if n == name then return Some(val: f)
      else return lookup_function(name, functions: rest)
      end
  end
end

/** Check if `name` looks like a capability method call (`<module>#<Cap>.<method>`)
 *  by testing whether any handler binding's cap_name is a prefix of `name`
 *  followed by `.`.  Returns the method name substring on success, or "" on
 *  failure (empty string is not a valid method name so it is safe as a sentinel).
 */
let detect_cap_method_call = fn (name: string, bindings: [ HirHandlerBindingEntry ]) -> string do
  match bindings do
    | [] -> return ""
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: cname, requires: _, arms: _)
    ) :: rest ->
      let prefix = cname ++ "."
      let plen = str.length(s: prefix)
      let nlen = str.length(s: name)
      if nlen > plen && str.substring(s: name, start: 0, len: plen) == prefix then
        return str.substring(s: name, start: plen, len: nlen - plen)
      end
      return detect_cap_method_call(name, bindings: rest)
  end
end

/** When a name looks like a cap method call, find the handler arm for that cap+method
 *  and return its function name plus body calls (so the worklist expands correctly).
 */
let find_arm_for_cap_method = fn (
  name: string,
  method_name: string,
  bindings: [ HirHandlerBindingEntry ]
) -> [ string ] do
  match bindings do
    | [] -> return []
    | HirHandlerBindingEntry(
      name: bname,
      binding: HirHandlerBinding(cap_name: cname, requires: _, arms)
    ) :: rest ->
      let prefix = cname ++ "."
      let plen = str.length(s: prefix)
      let nlen = str.length(s: name)
      if nlen > plen && str.substring(s: name, start: 0, len: plen) == prefix then
        let fs = arms_to_funcs(arms)
        let arm_func = lookup_function_by_method(method_name, funcs: fs)
        match arm_func do
          | Some(val: HirFunction(name: arm_n, type_params: _, params: _, ret_type: _, throw_row: _, body: EagerBody(stmts: body), _)) ->
            // Include the binding name (`bname`) so that
            // `filter_reachable_handler_bindings` recognises this handler as
            // used and keeps it in `injected_hb`.
            return bname :: arm_n :: collect_calls_stmts(stmts: body)
          | Some(val: HirFunction(name: arm_n, type_params: _, params: _, ret_type: _, throw_row: _, body: LazyBody(_), _)) ->
            return bname :: arm_n :: []
          | None ->
            // The binding has this cap but no matching arm — skip and try next
            return find_arm_for_cap_method(name, method_name, bindings: rest)
        end
      end
      return find_arm_for_cap_method(name, method_name, bindings: rest)
  end
end

/** Look up a handler arm function by its method name suffix.
 *  Handler arm functions are named `__handler_<binding>_<method>`, so we
 *  match by checking if the name ends with `_<method>`.
 */
let lookup_function_by_method = fn (
  method_name: string,
  funcs: [ HirFunction ]
) -> Option<HirFunction> do
  match funcs do
    | [] -> return None
    | f :: rest ->
      let HirFunction(name: n, type_params: _, params: _, ret_type: _, _) = f
      let suffix = "_" ++ method_name
      if str_ends_with_suffix(s: n, suffix) then return Some(val: f)
      else return lookup_function_by_method(method_name, funcs: rest)
      end
  end
end

let find_calls_in_handlers = fn (
  name: string,
  bindings: [ HirHandlerBindingEntry ]
) -> [ string ] do
  let result = find_calls_in_handlers_exact(name, bindings)
  if str_list_nonempty(result) then return result end
  // Last resort: check if `name` is a cap method call (e.g.
  // `nxlib_stdlib_io_stdio_nx#Console.println`) and resolve to the
  // corresponding handler arm.  This allows `collect_reachable_from_main`
  // (which does not unconditionally seed all handler arms) to still follow
  // cap calls that are not guarded by an explicit `inject` stmt (i.e.
  // implicit Console / Fs / Clock usage).
  let method = detect_cap_method_call(name, bindings)
  if str.length(s: method) > 0 then
    return find_arm_for_cap_method(name, method_name: method, bindings)
  end
  return []
end

let str_list_nonempty = fn (xs: [ string ]) -> bool do
  match xs do
    | [] -> return false
    | _ -> return true
  end
end

let find_calls_in_handlers_exact = fn (
  name: string,
  bindings: [ HirHandlerBindingEntry ]
) -> [ string ] do
  match bindings do
    | [] -> return []
    | HirHandlerBindingEntry(
      name: bname,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      let fs = arms_to_funcs(arms)
      if bname == name then
        // When the handler BINDING name is looked up (e.g. because an `inject`
        // stmt named it), add BOTH the arm function names AND the direct calls
        // from arm bodies. The arm function names enter the worklist so that
        // `reachable_go` can transitively walk their own bodies (via the `else`
        // branch below), ensuring every callee of every arm — including
        // externals like `w_fd_close` — reaches `visited`.
        let func_names = collect_handler_func_names(funcs: fs)
        let calls = collect_calls_functions(funcs: fs)
        return concat_str_lists(a: func_names, b: calls)
      else
        let found = lookup_function(name, functions: fs)
        match found do
          | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: EagerBody(stmts: body), _)) ->
            return collect_calls_stmts(stmts: body)
          | Some(val: HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: LazyBody(_), _)) ->
            return []
          | None -> return find_calls_in_handlers_exact(name, bindings: rest)
        end
      end
  end
end

/** Filter functions to only reachable ones.
 *  Handler arm functions (`__handler_*`) that are actually used will be in
 *  `reachable` via the handler-binding seeds produced by
 *  `collect_reachable_no_thread_start`; those for capabilities not in
 *  `injected_hb` (e.g. Net when never injected) must NOT be kept, because
 *  their callees (e.g. `w_http_request`, `exists_path`) will also be absent
 *  from the filtered function list, causing E3001 at codegen.
 */
export let filter_reachable_functions = fn (
  functions: [ HirFunction ],
  reachable: [ string ]
) -> [ HirFunction ] do
  return filter_reachable_functions_go(functions, reachable, acc: [])
end

let filter_reachable_functions_go = fn (
  functions: [ HirFunction ],
  reachable: [ string ],
  acc: [ HirFunction ]
) -> [ HirFunction ] do
  match functions do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      let HirFunction(name: n, type_params: _, params: _, ret_type: _, _) = f
      if str_in_list(s: n, xs: reachable) then
        return filter_reachable_functions_go(functions: rest, reachable, acc: f :: acc)
      else
        return filter_reachable_functions_go(functions: rest, reachable, acc)
      end
  end
end

/** Filter handler bindings to those whose binding name appears in `reachable`.
 *  Used to restrict `lower_handler_functions` to only handlers that are
 *  actually injected (directly or transitively) from `main`, so that
 *  handler arm functions for uninvoked capabilities (e.g. Net when the
 *  program never injects Net) are not emitted — avoiding unsatisfied WASM
 *  imports (e.g. `wasi_snapshot_preview1::http_request`) in preview1 builds.
 */
export let filter_reachable_handler_bindings = fn (
  bindings: [ HirHandlerBindingEntry ],
  reachable: [ string ]
) -> [ HirHandlerBindingEntry ] do
  return filter_reachable_handler_bindings_go(bindings, reachable, acc: [])
end

let filter_reachable_handler_bindings_go = fn (
  bindings: [ HirHandlerBindingEntry ],
  reachable: [ string ],
  acc: [ HirHandlerBindingEntry ]
) -> [ HirHandlerBindingEntry ] do
  match bindings do
    | [] -> return list.reverse(xs: acc)
    | b :: rest ->
      let HirHandlerBindingEntry(name: n, binding: _) = b
      if str_in_list(s: n, xs: reachable) then
        return filter_reachable_handler_bindings_go(bindings: rest, reachable, acc: b :: acc)
      else
        return filter_reachable_handler_bindings_go(bindings: rest, reachable, acc)
      end
  end
end

/** Filter externals down to those whose canonical name appears in `reachable`.
 *  `reachable` is produced by `collect_reachable`, which `visited`s every name
 *  off the worklist — external callees included — so set membership suffices.
 *  Unreachable externals would otherwise emit wasm imports that no caller
 * references , preventing wasmtime instantiation when the
 *  import resolver can't satisfy the spurious declaration.
 */
export let filter_reachable_externals = fn (
  externals: [ HirExternal ],
  reachable: [ string ]
) -> [ HirExternal ] do
  return filter_reachable_externals_go(externals, reachable, acc: [])
end

let filter_reachable_externals_go = fn (
  externals: [ HirExternal ],
  reachable: [ string ],
  acc: [ HirExternal ]
) -> [ HirExternal ] do
  match externals do
    | [] -> return list.reverse(xs: acc)
    | e :: rest ->
      let HirExternal(
        name: n,
        wasm_module: m,
        wasm_name: _,
        type_params: _,
        params: _,
        ret_type: _,
        throw_row: _
      ) = e
      // nexus:intrinsic and nexus:runtime/* externals are emitted as inline WASM
      // instructions by codegen rather than as host imports; they must always be
      // kept in filtered_exts so codegen can register them in the external_func_map
      // for emit_atom_var name lookups. Reachability filtering applies only to
      // genuine host imports (wasi_snapshot_preview1, etc.) where emitting an
      // unsatisfied import prevents wasmtime instantiation.
      let is_intrinsic = m == "nexus:intrinsic" || str.starts_with(
        s: m,
        prefix: "nexus:runtime/"
      ) || str.starts_with(s: m, prefix: "nexus:std/")
      if is_intrinsic || str_in_list(s: n, xs: reachable) then
        return filter_reachable_externals_go(externals: rest, reachable, acc: e :: acc)
      else
        return filter_reachable_externals_go(externals: rest, reachable, acc)
      end
  end
end
