/**
 * lir_opt: LIR optimization passes for the self-hosting compiler.
 *
 * Chains two passes: fold+propagate → DCE
 *
 * 1. Constant folding: evaluates binary ops on literal atoms at compile time
 * 2. Constant propagation + copy propagation: substitutes known bindings into
 *    use sites (literal constants AND variable-to-variable copies)
 * 3. Dead branch elimination: inlines the live branch of if-statements with
 *    constant conditions
 * 4. Dead code elimination: removes unused pure let bindings
 *
 * Passes 1-3 are combined in a single forward walk (opt_fp_stmts).
 * Pass 4 runs separately afterward (opt_dce_stmts).
 */

// ─── Backtrace Stability Contract ───────────────────────────────────────────
//
// ALL optimization passes MUST maintain these invariants:
//
// 1. FUNCTION BOUNDARIES: Never merge or split functions. Codegen emits
//    bt_push(name) at function entry and bt_pop() at every exit. Changing
//    function boundaries breaks push/pop pairing.
//
// 2. RAISE PRESERVATION: Never remove or reorder LirExprRaise. Codegen
//    emits bt_freeze() before each Raise to snapshot the call stack.
//
// 3. RETURN PRESERVATION: Never remove explicit returns. Codegen emits
//    bt_pop() before each Return/ReturnCall.
//
// 4. TRY-CATCH STRUCTURE: Never eliminate or restructure LirStmtTryCatch.
//
// 5. TAIL CALL PRESERVATION: LirExprTailCall includes bt_pop() before the
//    return_call in codegen. Never remove tail calls.
//
// The passes below operate only on LirStmtLet bindings, atoms, and
// constant-condition branches, naturally preserving these invariants.
// DCE explicitly checks for side effects before removing any binding.
// ─────────────────────────────────────────────────────────────────────────────

import { BinaryOp } from "src/common/ast.nx"
import { LirProgram, LirFunction, LirStmt, LirExpr, LirAtom,
         LirCallArg, LirNamedAtom } from "src/ir/lir_types.nx"

// ─── Helper Types ───────────────────────────────────────────────────────────

type OptSubstEntry = OptSubstEntry(name: string, atom: LirAtom)
type FoldResult = FoldResult(stmts: [LirStmt], subst: [OptSubstEntry])

// ─── Core Helpers ───────────────────────────────────────────────────────────

let opt_lookup = fn (name: string, entries: [OptSubstEntry]) -> Option<LirAtom> do
  match entries do
    case [] -> return None
    case OptSubstEntry(name: n, atom: a) :: rest ->
      if n == name then return Some(val: a) end
      return opt_lookup(name: name, entries: rest)
  end
end

let opt_has_name = fn (name: string, names: [string]) -> bool do
  match names do
    case [] -> return false
    case n :: rest ->
      if n == name then return true end
      return opt_has_name(name: name, names: rest)
  end
end

let opt_is_pure = fn (expr: LirExpr) -> bool do
  match expr do
    case LirExprAtom(_) -> true
    case LirExprBinary(_) -> true
    case LirExprConstructor(_) -> true
    case LirExprRecord(_) -> true
    case LirExprObjectTag(_) -> true
    case LirExprObjectField(_) -> true
    case LirExprMakeClosure(_) -> true
    case LirExprCall(_) -> false
    case LirExprTailCall(_) -> false
    case LirExprRaise(_) -> false
    case LirExprForce(_) -> true
    case LirExprCallClosure(_) -> false
  end
end

let opt_append_names = fn (a: [string], b: [string]) -> [string] do
  return opt_append_names_go(xs: a, ys: b, acc: [])
end

let opt_append_names_go = fn (xs: [string], ys: [string], acc: [string]) -> [string] do
  match xs do
    case [] -> return reverse_strings(lst: acc, out: ys)
    case x :: rest -> return opt_append_names_go(xs: rest, ys: ys, acc: x :: acc)
  end
end

// ─── Multiply-Bound Name Detection ─────────────────────────────────────────
//
// Variables bound by Let more than once (across all scopes in a function)
// are NOT safe for copy propagation. Match-expression lowering binds the
// same result_name in multiple if-branches plus a default, so the compile-
// time value may differ from the runtime value.

let opt_let_names_stmt = fn (stmt: LirStmt) -> [string] do
  match stmt do
    case LirStmtLet(name: n, typ: _, expr: _) ->
      [n]
    case LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
      opt_append_names(a: opt_let_names_stmts(stmts: tb),
                       b: opt_let_names_stmts(stmts: eb))
    case LirStmtIfReturn(cond: _, then_body: tb, then_ret: _,
                          else_body: eb, else_ret: _, ret_type: _) ->
      opt_append_names(a: opt_let_names_stmts(stmts: tb),
                       b: opt_let_names_stmts(stmts: eb))
    case LirStmtLoop(cond_stmts: cs, cond: _, body: bd) ->
      opt_append_names(a: opt_let_names_stmts(stmts: cs),
                       b: opt_let_names_stmts(stmts: bd))
    case LirStmtTryCatch(body: bd, body_ret: _, catch_param: _,
                          catch_param_typ: _, catch_body: cb, catch_ret: _) ->
      opt_append_names(a: opt_let_names_stmts(stmts: bd),
                       b: opt_let_names_stmts(stmts: cb))
  end
end

let opt_let_names_stmts = fn (stmts: [LirStmt]) -> [string] do
  match stmts do
    case [] -> []
    case s :: rest ->
      opt_append_names(a: opt_let_names_stmt(stmt: s),
                       b: opt_let_names_stmts(stmts: rest))
  end
end

let opt_find_multi_go = fn (names: [string], seen: [string], multi: [string]) -> [string] do
  match names do
    case [] -> multi
    case nm :: rest ->
      if opt_has_name(name: nm, names: multi) then
        return opt_find_multi_go(names: rest, seen: seen, multi: multi)
      end
      if opt_has_name(name: nm, names: seen) then
        return opt_find_multi_go(names: rest, seen: seen,
                                 multi: nm :: multi)
      end
      return opt_find_multi_go(names: rest, seen: nm :: seen,
                               multi: multi)
  end
end

let opt_find_multi = fn (names: [string]) -> [string] do
  opt_find_multi_go(names: names, seen: [], multi: [])
end

// ─── Constant Folding ───────────────────────────────────────────────────────

let opt_fold_int_binary = fn (op: BinaryOp, a: i64, b: i64) -> Option<LirAtom> do
  match op do
    case OpAdd -> return Some(val: LirAtomInt(val: a + b))
    case OpSub -> return Some(val: LirAtomInt(val: a - b))
    case OpMul -> return Some(val: LirAtomInt(val: a * b))
    case OpDiv ->
      if b == 0 then return None end
      return Some(val: LirAtomInt(val: a / b))
    case OpMod ->
      if b == 0 then return None end
      return Some(val: LirAtomInt(val: a - (a / b) * b))
    case OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    case OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    case OpLt ->
      if a < b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    case OpLe ->
      if a <= b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    case OpGt ->
      if a > b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    case OpGe ->
      if a >= b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    case _ -> return None
  end
end

let opt_fold_bool_binary = fn (op: BinaryOp, a: bool, b: bool) -> Option<LirAtom> do
  match op do
    case OpAnd ->
      match a do
        case true -> return Some(val: LirAtomBool(val: b))
        case false -> return Some(val: LirAtomBool(val: false))
      end
    case OpOr ->
      match a do
        case true -> return Some(val: LirAtomBool(val: true))
        case false -> return Some(val: LirAtomBool(val: b))
      end
    case OpEq ->
      match a do
        case true -> return Some(val: LirAtomBool(val: b))
        case false ->
          match b do
            case true -> return Some(val: LirAtomBool(val: false))
            case false -> return Some(val: LirAtomBool(val: true))
          end
      end
    case OpNe ->
      match a do
        case true ->
          match b do
            case true -> return Some(val: LirAtomBool(val: false))
            case false -> return Some(val: LirAtomBool(val: true))
          end
        case false -> return Some(val: LirAtomBool(val: b))
      end
    case _ -> return None
  end
end

let opt_fold_str_binary = fn (op: BinaryOp, a: string, b: string) -> Option<LirAtom> do
  match op do
    case OpConcat -> return Some(val: LirAtomString(val: a ++ b))
    case OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    case OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    case _ -> return None
  end
end

let opt_fold_char_binary = fn (op: BinaryOp, a: i64, b: i64) -> Option<LirAtom> do
  match op do
    case OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    case OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    case _ -> return None
  end
end

let opt_try_fold_binary = fn (op: BinaryOp, lhs: LirAtom, rhs: LirAtom) -> Option<LirAtom> do
  match lhs do
    case LirAtomInt(val: ia) ->
      match rhs do
        case LirAtomInt(val: ib) -> return opt_fold_int_binary(op: op, a: ia, b: ib)
        case _ -> return None
      end
    case LirAtomBool(val: ba) ->
      match rhs do
        case LirAtomBool(val: bb) -> return opt_fold_bool_binary(op: op, a: ba, b: bb)
        case _ -> return None
      end
    case LirAtomString(val: sa) ->
      match rhs do
        case LirAtomString(val: sb) -> return opt_fold_str_binary(op: op, a: sa, b: sb)
        case _ -> return None
      end
    case LirAtomChar(val: ca) ->
      match rhs do
        case LirAtomChar(val: cb) -> return opt_fold_char_binary(op: op, a: ca, b: cb)
        case _ -> return None
      end
    case _ -> return None
  end
end

// ─── Identity / Absorbing Element Simplification ────────────────────────────

let opt_simplify_binary = fn (op: BinaryOp, lhs: LirAtom, rhs: LirAtom) -> Option<LirAtom> do
  match op do
    case OpAdd ->
      match lhs do
        case LirAtomInt(val: 0) -> return Some(val: rhs)
        case _ ->
          match rhs do
            case LirAtomInt(val: 0) -> return Some(val: lhs)
            case _ -> return None
          end
      end
    case OpSub ->
      match rhs do
        case LirAtomInt(val: 0) -> return Some(val: lhs)
        case _ -> return None
      end
    case OpMul ->
      match lhs do
        case LirAtomInt(val: 0) -> return Some(val: LirAtomInt(val: 0))
        case LirAtomInt(val: 1) -> return Some(val: rhs)
        case _ ->
          match rhs do
            case LirAtomInt(val: 0) -> return Some(val: LirAtomInt(val: 0))
            case LirAtomInt(val: 1) -> return Some(val: lhs)
            case _ -> return None
          end
      end
    case OpDiv ->
      match rhs do
        case LirAtomInt(val: 1) -> return Some(val: lhs)
        case _ -> return None
      end
    case OpAnd ->
      match lhs do
        case LirAtomBool(val: false) -> return Some(val: LirAtomBool(val: false))
        case LirAtomBool(val: true) -> return Some(val: rhs)
        case _ ->
          match rhs do
            case LirAtomBool(val: false) -> return Some(val: LirAtomBool(val: false))
            case LirAtomBool(val: true) -> return Some(val: lhs)
            case _ -> return None
          end
      end
    case OpOr ->
      match lhs do
        case LirAtomBool(val: true) -> return Some(val: LirAtomBool(val: true))
        case LirAtomBool(val: false) -> return Some(val: rhs)
        case _ ->
          match rhs do
            case LirAtomBool(val: true) -> return Some(val: LirAtomBool(val: true))
            case LirAtomBool(val: false) -> return Some(val: lhs)
            case _ -> return None
          end
      end
    case _ -> return None
  end
end

let opt_fold_expr = fn (expr: LirExpr) -> LirExpr do
  if let LirExprBinary(op: op, lhs: l, rhs: r, typ: _) = expr then
    match opt_try_fold_binary(op: op, lhs: l, rhs: r) do
      case Some(val: result) -> return LirExprAtom(atom: result)
      case None ->
        match opt_simplify_binary(op: op, lhs: l, rhs: r) do
          case Some(val: result) -> return LirExprAtom(atom: result)
          case None -> return expr
        end
    end
  end
  return expr
end

// ─── Atom Substitution ──────────────────────────────────────────────────────

let opt_subst_atom = fn (atom: LirAtom, subst: [OptSubstEntry]) -> LirAtom do
  if let LirAtomVar(name: n, typ: _) = atom then
    match opt_lookup(name: n, entries: subst) do
      case Some(val: a) -> return a
      case None -> return atom
    end
  end
  return atom
end

let opt_subst_opt_atom = fn (opt: Option<LirAtom>, subst: [OptSubstEntry]) -> Option<LirAtom> do
  match opt do
    case Some(val: a) -> Some(val: opt_subst_atom(atom: a, subst: subst))
    case None -> None
  end
end

let opt_subst_atoms = fn (atoms: [LirAtom], subst: [OptSubstEntry]) -> [LirAtom] do
  return opt_subst_atoms_go(xs: atoms, subst: subst, acc: [])
end

let opt_subst_atoms_go = fn (xs: [LirAtom], subst: [OptSubstEntry], acc: [LirAtom]) -> [LirAtom] do
  match xs do
    case [] -> return reverse_atoms(lst: acc, out: [])
    case a :: rest ->
      return opt_subst_atoms_go(xs: rest, subst: subst,
                                acc: opt_subst_atom(atom: a, subst: subst) :: acc)
  end
end

let opt_subst_call_args = fn (args: [LirCallArg], subst: [OptSubstEntry]) -> [LirCallArg] do
  return opt_subst_call_args_go(xs: args, subst: subst, acc: [])
end

let opt_subst_call_args_go = fn (xs: [LirCallArg], subst: [OptSubstEntry], acc: [LirCallArg]) -> [LirCallArg] do
  match xs do
    case [] -> return reverse_call_args(lst: acc, out: [])
    case LirCallArg(label: l, value: v) :: rest ->
      return opt_subst_call_args_go(xs: rest, subst: subst,
                                    acc: LirCallArg(label: l, value: opt_subst_atom(atom: v, subst: subst)) :: acc)
  end
end

let opt_subst_named_atoms = fn (fields: [LirNamedAtom], subst: [OptSubstEntry]) -> [LirNamedAtom] do
  return opt_subst_named_atoms_go(xs: fields, subst: subst, acc: [])
end

let opt_subst_named_atoms_go = fn (xs: [LirNamedAtom], subst: [OptSubstEntry], acc: [LirNamedAtom]) -> [LirNamedAtom] do
  match xs do
    case [] -> return reverse_named_atoms(lst: acc, out: [])
    case LirNamedAtom(name: n, value: v) :: rest ->
      return opt_subst_named_atoms_go(xs: rest, subst: subst,
                                      acc: LirNamedAtom(name: n, value: opt_subst_atom(atom: v, subst: subst)) :: acc)
  end
end

let opt_subst_expr = fn (expr: LirExpr, subst: [OptSubstEntry]) -> LirExpr do
  match expr do
    case LirExprAtom(atom: a) ->
      LirExprAtom(atom: opt_subst_atom(atom: a, subst: subst))
    case LirExprBinary(op: op, lhs: l, rhs: r, typ: t) ->
      LirExprBinary(op: op,
                    lhs: opt_subst_atom(atom: l, subst: subst),
                    rhs: opt_subst_atom(atom: r, subst: subst), typ: t)
    case LirExprCall(func: f, args: args, typ: t) ->
      LirExprCall(func: f, args: opt_subst_call_args(args: args, subst: subst), typ: t)
    case LirExprTailCall(func: f, args: args, typ: t) ->
      LirExprTailCall(func: f, args: opt_subst_call_args(args: args, subst: subst), typ: t)
    case LirExprConstructor(name: n, args: args, typ: t) ->
      LirExprConstructor(name: n, args: opt_subst_atoms(atoms: args, subst: subst), typ: t)
    case LirExprRecord(fields: fs, typ: t) ->
      LirExprRecord(fields: opt_subst_named_atoms(fields: fs, subst: subst), typ: t)
    case LirExprObjectTag(value: v, typ: t) ->
      LirExprObjectTag(value: opt_subst_atom(atom: v, subst: subst), typ: t)
    case LirExprObjectField(value: v, index: i, typ: t) ->
      LirExprObjectField(value: opt_subst_atom(atom: v, subst: subst), index: i, typ: t)
    case LirExprRaise(value: v, typ: t) ->
      LirExprRaise(value: opt_subst_atom(atom: v, subst: subst), typ: t)
    case LirExprForce(value: v, typ: t) ->
      LirExprForce(value: opt_subst_atom(atom: v, subst: subst), typ: t)
    case LirExprMakeClosure(func_name: f, captures: cs, typ: t) ->
      LirExprMakeClosure(func_name: f,
                         captures: opt_subst_atoms(atoms: cs, subst: subst), typ: t)
    case LirExprCallClosure(closure: c, args: args, typ: t) ->
      LirExprCallClosure(closure: opt_subst_atom(atom: c, subst: subst),
                         args: opt_subst_call_args(args: args, subst: subst), typ: t)
  end
end

// ─── Combined Fold + Propagate Pass ─────────────────────────────────────────
//
// Single forward walk: substitutes constants/copies, folds binary expressions,
// and eliminates dead branches for LirStmtIf with constant conditions.

let opt_fp_stmts = fn (stmts: [LirStmt], subst: [OptSubstEntry], multi: [string]) -> FoldResult do
  return opt_fp_stmts_go(stmts: stmts, subst: subst, multi: multi, acc: [])
end

let opt_fp_stmts_go = fn (stmts: [LirStmt], subst: [OptSubstEntry], multi: [string], acc: [LirStmt]) -> FoldResult do
  match stmts do
    case [] -> return FoldResult(stmts: reverse_stmts_opt(lst: acc, out: []), subst: subst)
    case s :: rest ->
      match opt_fp_stmt(stmt: s, subst: subst, multi: multi) do case FoldResult(stmts: processed, subst: new_subst) ->
        let new_acc = opt_prepend_reversed(stmts: processed, acc: acc)
        return opt_fp_stmts_go(stmts: rest, subst: new_subst, multi: multi, acc: new_acc)
      end
  end
end

// Prepend a short list (processed stmts) to acc in reverse order (for later reversal)
let opt_prepend_reversed = fn (stmts: [LirStmt], acc: [LirStmt]) -> [LirStmt] do
  match stmts do
    case [] -> return acc
    case s :: rest -> return opt_prepend_reversed(stmts: rest, acc: s :: acc)
  end
end

let opt_fp_stmt = fn (stmt: LirStmt, subst: [OptSubstEntry], multi: [string]) -> FoldResult do
  match stmt do
    case LirStmtLet(name: n, typ: t, expr: e) ->
      let subst_expr = opt_subst_expr(expr: e, subst: subst)
      let folded_expr = opt_fold_expr(expr: subst_expr)
      // Track for propagation: if result is atom (literal or variable copy)
      // Skip multiply-bound names — not SSA-safe for copy propagation
      let new_subst = match folded_expr do
        case LirExprAtom(atom: a) ->
          match opt_has_name(name: n, names: multi) do
            case true -> subst
            case false -> OptSubstEntry(name: n, atom: a) :: subst
          end
        case _ -> subst
      end
      return FoldResult(
        stmts: [LirStmtLet(name: n, typ: t, expr: folded_expr)],
        subst: new_subst
      )

    case LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let new_c = opt_subst_atom(atom: c, subst: subst)
      // Dead branch elimination: constant condition → inline live branch
      match new_c do
        case LirAtomBool(val: true) ->
          return opt_fp_stmts(stmts: tb, subst: subst, multi: multi)
        case LirAtomBool(val: false) ->
          return opt_fp_stmts(stmts: eb, subst: subst, multi: multi)
        case _ ->
          let tb_r = opt_fp_stmts(stmts: tb, subst: subst, multi: multi)
          let eb_r = opt_fp_stmts(stmts: eb, subst: subst, multi: multi)
          match tb_r do case FoldResult(stmts: new_tb, subst: _) ->
            match eb_r do case FoldResult(stmts: new_eb, subst: _) ->
              return FoldResult(
                stmts: [LirStmtIf(cond: new_c, then_body: new_tb,
                                          else_body: new_eb)],
                subst: subst
              )
            end
          end
      end

    case LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr,
                          else_body: eb, else_ret: er, ret_type: rt) ->
      let new_c = opt_subst_atom(atom: c, subst: subst)
      let tb_r = opt_fp_stmts(stmts: tb, subst: subst, multi: multi)
      let eb_r = opt_fp_stmts(stmts: eb, subst: subst, multi: multi)
      match tb_r do case FoldResult(stmts: new_tb, subst: tb_subst) ->
        match eb_r do case FoldResult(stmts: new_eb, subst: eb_subst) ->
          return FoldResult(
            stmts: [LirStmtIfReturn(
              cond: new_c,
              then_body: new_tb,
              then_ret: opt_subst_atom(atom: tr, subst: tb_subst),
              else_body: new_eb,
              else_ret: opt_subst_opt_atom(opt: er, subst: eb_subst),
              ret_type: rt
            )],
            subst: subst
          )
        end
      end

    case LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      let cs_r = opt_fp_stmts(stmts: cs, subst: subst, multi: multi)
      match cs_r do case FoldResult(stmts: new_cs, subst: cs_subst) ->
        let new_c = opt_subst_atom(atom: c, subst: cs_subst)
        let b_r = opt_fp_stmts(stmts: b, subst: cs_subst, multi: multi)
        match b_r do case FoldResult(stmts: new_b, subst: _) ->
          return FoldResult(
            stmts: [LirStmtLoop(cond_stmts: new_cs, cond: new_c,
                                        body: new_b)],
            subst: subst
          )
        end
      end

    case LirStmtTryCatch(body: b, body_ret: br, catch_param: cp,
                          catch_param_typ: cpt, catch_body: cb, catch_ret: cr) ->
      let b_r = opt_fp_stmts(stmts: b, subst: subst, multi: multi)
      let cb_r = opt_fp_stmts(stmts: cb, subst: subst, multi: multi)
      match b_r do case FoldResult(stmts: new_b, subst: b_subst) ->
        match cb_r do case FoldResult(stmts: new_cb, subst: cb_subst) ->
          return FoldResult(
            stmts: [LirStmtTryCatch(
              body: new_b,
              body_ret: opt_subst_opt_atom(opt: br, subst: b_subst),
              catch_param: cp, catch_param_typ: cpt,
              catch_body: new_cb,
              catch_ret: opt_subst_opt_atom(opt: cr, subst: cb_subst)
            )],
            subst: subst
          )
        end
      end

  end
end

// ─── Use Collection (for DCE) ───────────────────────────────────────────────

let opt_collect_atom = fn (atom: LirAtom, used: [string]) -> [string] do
  if let LirAtomVar(name: n, typ: _) = atom then n :: used else used end
end

let opt_collect_opt_atom = fn (opt: Option<LirAtom>, used: [string]) -> [string] do
  if let Some(val: a) = opt then opt_collect_atom(atom: a, used: used) else used end
end

let opt_collect_atoms = fn (atoms: [LirAtom], used: [string]) -> [string] do
  match atoms do
    case [] -> used
    case a :: rest -> opt_collect_atoms(atoms: rest, used: opt_collect_atom(atom: a, used: used))
  end
end

let opt_collect_call_args = fn (args: [LirCallArg], used: [string]) -> [string] do
  match args do
    case [] -> used
    case LirCallArg(label: _, value: v) :: rest ->
      opt_collect_call_args(args: rest, used: opt_collect_atom(atom: v, used: used))
  end
end

let opt_collect_named_atoms = fn (fields: [LirNamedAtom], used: [string]) -> [string] do
  match fields do
    case [] -> used
    case LirNamedAtom(name: _, value: v) :: rest ->
      opt_collect_named_atoms(fields: rest, used: opt_collect_atom(atom: v, used: used))
  end
end


let opt_collect_expr = fn (expr: LirExpr, used: [string]) -> [string] do
  match expr do
    case LirExprAtom(atom: a) -> opt_collect_atom(atom: a, used: used)
    case LirExprBinary(op: _, lhs: l, rhs: r, typ: _) ->
      opt_collect_atom(atom: r, used: opt_collect_atom(atom: l, used: used))
    case LirExprCall(func: _, args: args, typ: _) ->
      opt_collect_call_args(args: args, used: used)
    case LirExprTailCall(func: _, args: args, typ: _) ->
      opt_collect_call_args(args: args, used: used)
    case LirExprConstructor(name: _, args: args, typ: _) ->
      opt_collect_atoms(atoms: args, used: used)
    case LirExprRecord(fields: fs, typ: _) ->
      opt_collect_named_atoms(fields: fs, used: used)
    case LirExprObjectTag(value: v, typ: _) ->
      opt_collect_atom(atom: v, used: used)
    case LirExprObjectField(value: v, index: _, typ: _) ->
      opt_collect_atom(atom: v, used: used)
    case LirExprRaise(value: v, typ: _) ->
      opt_collect_atom(atom: v, used: used)
    case LirExprForce(value: v, typ: _) ->
      opt_collect_atom(atom: v, used: used)
    case LirExprMakeClosure(func_name: _, captures: cs, typ: _) ->
      opt_collect_atoms(atoms: cs, used: used)
    case LirExprCallClosure(closure: c, args: args, typ: _) ->
      opt_collect_call_args(args: args, used: opt_collect_atom(atom: c, used: used))
  end
end

let opt_collect_stmt = fn (stmt: LirStmt, used: [string]) -> [string] do
  match stmt do
    case LirStmtLet(name: _, typ: _, expr: e) ->
      opt_collect_expr(expr: e, used: used)
    case LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let u1 = opt_collect_atom(atom: c, used: used)
      let u2 = opt_collect_stmts(stmts: tb, used: u1)
      opt_collect_stmts(stmts: eb, used: u2)
    case LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr,
                          else_body: eb, else_ret: er, ret_type: _) ->
      let u1 = opt_collect_atom(atom: c, used: used)
      let u2 = opt_collect_stmts(stmts: tb, used: u1)
      let u3 = opt_collect_atom(atom: tr, used: u2)
      let u4 = opt_collect_stmts(stmts: eb, used: u3)
      opt_collect_opt_atom(opt: er, used: u4)
    case LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      let u1 = opt_collect_stmts(stmts: cs, used: used)
      let u2 = opt_collect_atom(atom: c, used: u1)
      opt_collect_stmts(stmts: b, used: u2)
    case LirStmtTryCatch(body: b, body_ret: br, catch_param: _,
                          catch_param_typ: _, catch_body: cb, catch_ret: cr) ->
      let u1 = opt_collect_stmts(stmts: b, used: used)
      let u2 = opt_collect_opt_atom(opt: br, used: u1)
      let u3 = opt_collect_stmts(stmts: cb, used: u2)
      opt_collect_opt_atom(opt: cr, used: u3)
  end
end

let opt_collect_stmts = fn (stmts: [LirStmt], used: [string]) -> [string] do
  match stmts do
    case [] -> used
    case s :: rest -> opt_collect_stmts(stmts: rest, used: opt_collect_stmt(stmt: s, used: used))
  end
end

// ─── Dead Code Elimination ──────────────────────────────────────────────────
//
// Removes LirStmtLet bindings where the bound name has zero uses AND the
// expression is pure (no side effects). Recurses into nested blocks.

let opt_dce_stmts = fn (stmts: [LirStmt], used: [string]) -> [LirStmt] do
  return opt_dce_stmts_go(stmts: stmts, used: used, acc: [])
end

let opt_dce_stmts_go = fn (stmts: [LirStmt], used: [string], acc: [LirStmt]) -> [LirStmt] do
  match stmts do
    case [] -> return reverse_stmts_opt(lst: acc, out: [])
    case s :: rest ->
      match opt_dce_one(stmt: s, used: used) do
        case Some(val: stmt) -> return opt_dce_stmts_go(stmts: rest, used: used, acc: stmt :: acc)
        case None -> return opt_dce_stmts_go(stmts: rest, used: used, acc: acc)
      end
  end
end

let opt_dce_one = fn (stmt: LirStmt, used: [string]) -> Option<LirStmt> do
  match stmt do
    case LirStmtLet(name: n, typ: t, expr: e) ->
      if opt_has_name(name: n, names: used) then
        return Some(val: LirStmtLet(name: n, typ: t, expr: e))
      end
      match opt_is_pure(expr: e) do
        case true -> return None
        case false -> return Some(val: LirStmtLet(name: n, typ: t, expr: e))
      end
    case LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      return Some(val: LirStmtIf(cond: c,
                         then_body: opt_dce_stmts(stmts: tb, used: used),
                         else_body: opt_dce_stmts(stmts: eb, used: used)))
    case LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr,
                          else_body: eb, else_ret: er, ret_type: rt) ->
      return Some(val: LirStmtIfReturn(cond: c,
                               then_body: opt_dce_stmts(stmts: tb, used: used),
                               then_ret: tr,
                               else_body: opt_dce_stmts(stmts: eb, used: used),
                               else_ret: er, ret_type: rt))
    case LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      return Some(val: LirStmtLoop(cond_stmts: opt_dce_stmts(stmts: cs, used: used),
                           cond: c,
                           body: opt_dce_stmts(stmts: b, used: used)))
    case LirStmtTryCatch(body: b, body_ret: br, catch_param: cp,
                          catch_param_typ: cpt, catch_body: cb, catch_ret: cr) ->
      return Some(val: LirStmtTryCatch(body: opt_dce_stmts(stmts: b, used: used),
                               body_ret: br, catch_param: cp,
                               catch_param_typ: cpt,
                               catch_body: opt_dce_stmts(stmts: cb, used: used),
                               catch_ret: cr))
  end
end

// ─── Entry Points ───────────────────────────────────────────────────────────

let opt_function = fn (func: LirFunction) -> LirFunction do
  let LirFunction(name: n, params: p, ret_type: rt,
                  body: body, ret: ret, span: sp) = func
  let multi = opt_find_multi(names: opt_let_names_stmts(stmts: body))
  let fp_result = opt_fp_stmts(stmts: body, subst: [], multi: multi)
  let FoldResult(stmts: fp_body, subst: final_subst) = fp_result
  let fp_ret = opt_subst_atom(atom: ret, subst: final_subst)
  let used = opt_collect_stmts(stmts: fp_body,
                               used: opt_collect_atom(atom: fp_ret, used: []))
  let dce_body = opt_dce_stmts(stmts: fp_body, used: used)
  LirFunction(name: n, params: p, ret_type: rt,
              body: dce_body, ret: fp_ret, span: sp)
end

let opt_functions = fn (funcs: [LirFunction]) -> [LirFunction] do
  return opt_functions_go(funcs: funcs, acc: [])
end

let opt_functions_go = fn (funcs: [LirFunction], acc: [LirFunction]) -> [LirFunction] do
  match funcs do
    case [] -> return reverse_funcs(lst: acc, out: [])
    case f :: rest ->
      return opt_functions_go(funcs: rest, acc: opt_function(func: f) :: acc)
  end
end

// ─── Monomorphic reverse helpers (list.reverse has codegen issues in nxc) ────

let reverse_funcs = fn (lst: [LirFunction], out: [LirFunction]) -> [LirFunction] do
  match lst do
    case [] -> return out
    case x :: rest -> return reverse_funcs(lst: rest, out: x :: out)
  end
end

let reverse_stmts_opt = fn (lst: [LirStmt], out: [LirStmt]) -> [LirStmt] do
  match lst do
    case [] -> return out
    case x :: rest -> return reverse_stmts_opt(lst: rest, out: x :: out)
  end
end

let reverse_strings = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    case [] -> return out
    case x :: rest -> return reverse_strings(lst: rest, out: x :: out)
  end
end

let reverse_atoms = fn (lst: [LirAtom], out: [LirAtom]) -> [LirAtom] do
  match lst do
    case [] -> return out
    case x :: rest -> return reverse_atoms(lst: rest, out: x :: out)
  end
end

let reverse_call_args = fn (lst: [LirCallArg], out: [LirCallArg]) -> [LirCallArg] do
  match lst do
    case [] -> return out
    case x :: rest -> return reverse_call_args(lst: rest, out: x :: out)
  end
end

let reverse_named_atoms = fn (lst: [LirNamedAtom], out: [LirNamedAtom]) -> [LirNamedAtom] do
  match lst do
    case [] -> return out
    case x :: rest -> return reverse_named_atoms(lst: rest, out: x :: out)
  end
end

export let optimize_lir = fn (program: LirProgram) -> LirProgram do
  let LirProgram(functions: funcs, externals: exts) = program
  LirProgram(functions: opt_functions(funcs: funcs), externals: exts)
end
