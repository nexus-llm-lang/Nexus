/**
 * lir_opt: LIR optimization passes for the self-hosting compiler.
 *
 * Chains the following passes:
 *
 * 0. Stream fusion (build/foldr): rewrites `foldr(k, z, build(g))` to
 *    `g(k, z)` when k is pure per the supplied EffectMap. Eliminates the
 *    intermediate list created by `build`. Entry point:
 *    `optimize_lir_with_effects`.
 * 1. Constant folding: evaluates binary ops on literal atoms at compile time
 * 2. Constant propagation + copy propagation: substitutes known bindings into
 *    use sites (literal constants AND variable-to-variable copies)
 * 3. Dead branch elimination: inlines the live branch of if-statements with
 *    constant conditions
 * 4. Dead code elimination: removes unused pure let bindings
 *
 * Passes 1-3 are combined in a single forward walk (opt_fp_stmts).
 * Pass 4 runs separately afterward (opt_dce_stmts).
 *
 * `optimize_lir(program)` runs passes 1-4 with no fusion (effect map empty);
 * `optimize_lir_with_effects(program, effects)` adds pass 0 in front so
 * fusion sees the precomputed per-function effect summaries.
 */

// ─── Backtrace Stability Contract ───────────────────────────────────────────
//
// ALL optimization passes MUST maintain these invariants:
//
// 1. FUNCTION BOUNDARIES: Never merge or split functions. Codegen emits
//    bt_push(name) at function entry and bt_pop() at every exit. Changing
//    function boundaries breaks push/pop pairing.
//
// 2. RAISE PRESERVATION: Never remove or reorder LirExprRaise. Codegen
//    emits bt_freeze() before each Raise to snapshot the call stack.
//
// 3. RETURN PRESERVATION: Never remove explicit returns. Codegen emits
//    bt_pop() before each Return/ReturnCall.
//
// 4. TRY-CATCH STRUCTURE: Never eliminate or restructure LirStmtTryCatch.
//
// 5. TAIL CALL PRESERVATION: LirExprTailCall includes bt_pop() before the
//    return_call in codegen. Never remove tail calls.
//
// The passes below operate only on LirStmtLet bindings, atoms, and
// constant-condition branches, naturally preserving these invariants.
// DCE explicitly checks for side effects before removing any binding.
// ─────────────────────────────────────────────────────────────────────────────

import { BinaryOp, TypeExpr } from "src/common/ast.nx"
import { LirProgram, LirFunction, LirStmt, LirExpr, LirAtom,
         LirCallArg, LirNamedAtom } from "src/ir/lir_types.nx"
import { EffectMap, lookup_summary, EffectSummary } from "src/backend/effect_analysis.nx"

// ─── Helper Types ───────────────────────────────────────────────────────────

type OptSubstEntry = OptSubstEntry(name: string, atom: LirAtom)
type FoldResult = FoldResult(stmts: [LirStmt], subst: [OptSubstEntry])

// ─── Core Helpers ───────────────────────────────────────────────────────────

let opt_lookup = fn (name: string, entries: [OptSubstEntry]) -> Option<LirAtom> do
  match entries do
    | [] -> return None
    | OptSubstEntry(name: n, atom: a) :: rest ->
      if n == name then return Some(val: a) end
      return opt_lookup(name, entries: rest)
  end
end

let opt_has_name = fn (name: string, names: [string]) -> bool do
  match names do
    | [] -> return false
    | n :: rest ->
      if n == name then return true end
      return opt_has_name(name, names: rest)
  end
end

let opt_is_pure = fn (expr: LirExpr) -> bool do
  match expr do
    | LirExprAtom(_) -> true
    | LirExprBinary(_) -> true
    | LirExprConstructor(_) -> true
    | LirExprRecord(_) -> true
    | LirExprObjectTag(_) -> true
    | LirExprObjectField(_) -> true
    | LirExprMakeClosure(_) -> true
    | LirExprCall(_) -> false
    | LirExprTailCall(_) -> false
    | LirExprRaise(_) -> false
    | LirExprForce(_) -> true
    | LirExprCallClosure(_) -> false
    | LirExprSuspend(_) -> false
    | LirExprResume(_) -> false
    | LirExprContNew(_) -> false
    | LirExprInjectResume(_) -> false
  end
end

let opt_append_names = fn (a: [string], b: [string]) -> [string] do
  return opt_append_names_go(xs: a, ys: b, acc: [])
end

let opt_append_names_go = fn (xs: [string], ys: [string], acc: [string]) -> [string] do
  match xs do
    | [] -> return reverse_strings(lst: acc, out: ys)
    | x :: rest -> return opt_append_names_go(xs: rest, ys, acc: x :: acc)
  end
end

// ─── Multiply-Bound Name Detection ─────────────────────────────────────────
//
// Variables bound by Let more than once (across all scopes in a function)
// are NOT safe for copy propagation. Match-expression lowering binds the
// same result_name in multiple if-branches plus a default, so the compile-
// time value may differ from the runtime value.

let opt_let_names_stmt = fn (stmt: LirStmt) -> [string] do
  match stmt do
    | LirStmtLet(name: n, typ: _, expr: _) ->
      [n]
    | LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
      opt_append_names(a: opt_let_names_stmts(stmts: tb),
                       b: opt_let_names_stmts(stmts: eb))
    | LirStmtIfReturn(cond: _, then_body: tb, then_ret: _,
                          else_body: eb, else_ret: _, ret_type: _) ->
      opt_append_names(a: opt_let_names_stmts(stmts: tb),
                       b: opt_let_names_stmts(stmts: eb))
    | LirStmtLoop(cond_stmts: cs, cond: _, body: bd) ->
      opt_append_names(a: opt_let_names_stmts(stmts: cs),
                       b: opt_let_names_stmts(stmts: bd))
    | LirStmtTryCatch(body: bd, body_ret: _, catch_param: _,
                          catch_param_typ: _, catch_body: cb, catch_ret: _) ->
      opt_append_names(a: opt_let_names_stmts(stmts: bd),
                       b: opt_let_names_stmts(stmts: cb))
  end
end

let opt_let_names_stmts = fn (stmts: [LirStmt]) -> [string] do
  match stmts do
    | [] -> []
    | s :: rest ->
      opt_append_names(a: opt_let_names_stmt(stmt: s),
                       b: opt_let_names_stmts(stmts: rest))
  end
end

let opt_find_multi_go = fn (names: [string], seen: [string], multi: [string]) -> [string] do
  match names do
    | [] -> multi
    | nm :: rest ->
      if opt_has_name(name: nm, names: multi) then
        return opt_find_multi_go(names: rest, seen, multi)
      end
      if opt_has_name(name: nm, names: seen) then
        return opt_find_multi_go(names: rest, seen,
                                 multi: nm :: multi)
      end
      return opt_find_multi_go(names: rest, seen: nm :: seen,
                               multi)
  end
end

let opt_find_multi = fn (names: [string]) -> [string] do
  opt_find_multi_go(names, seen: [], multi: [])
end

// ─── Constant Folding ───────────────────────────────────────────────────────

let opt_fold_int_binary = fn (op: BinaryOp, a: i64, b: i64) -> Option<LirAtom> do
  match op do
    | OpAdd -> return Some(val: LirAtomInt(val: a + b))
    | OpSub -> return Some(val: LirAtomInt(val: a - b))
    | OpMul -> return Some(val: LirAtomInt(val: a * b))
    | OpDiv ->
      if b == 0 then return None end
      return Some(val: LirAtomInt(val: a / b))
    | OpMod ->
      if b == 0 then return None end
      return Some(val: LirAtomInt(val: a - (a / b) * b))
    | OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    | OpLt ->
      if a < b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpLe ->
      if a <= b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpGt ->
      if a > b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpGe ->
      if a >= b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | _ -> return None
  end
end

let opt_fold_bool_binary = fn (op: BinaryOp, a: bool, b: bool) -> Option<LirAtom> do
  match op do
    | OpAnd -> return Some(val: LirAtomBool(val: a && b))
    | OpOr -> return Some(val: LirAtomBool(val: a || b))
    | OpEq -> return Some(val: LirAtomBool(val: a == b))
    | OpNe -> return Some(val: LirAtomBool(val: a != b))
    | _ -> return None
  end
end

let opt_fold_str_binary = fn (op: BinaryOp, a: string, b: string) -> Option<LirAtom> do
  match op do
    | OpConcat -> return Some(val: LirAtomString(val: a ++ b))
    | OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    | _ -> return None
  end
end

let opt_fold_char_binary = fn (op: BinaryOp, a: i64, b: i64) -> Option<LirAtom> do
  match op do
    | OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    | _ -> return None
  end
end

let opt_try_fold_binary = fn (op: BinaryOp, lhs: LirAtom, rhs: LirAtom) -> Option<LirAtom> do
  match lhs do
    | LirAtomInt(val: ia) ->
      if let LirAtomInt(val: ib) = rhs then
        return opt_fold_int_binary(op, a: ia, b: ib)
      else
        return None
      end
    | LirAtomBool(val: ba) ->
      if let LirAtomBool(val: bb) = rhs then
        return opt_fold_bool_binary(op, a: ba, b: bb)
      else
        return None
      end
    | LirAtomString(val: sa) ->
      if let LirAtomString(val: sb) = rhs then
        return opt_fold_str_binary(op, a: sa, b: sb)
      else
        return None
      end
    | LirAtomChar(val: ca) ->
      if let LirAtomChar(val: cb) = rhs then
        return opt_fold_char_binary(op, a: ca, b: cb)
      else
        return None
      end
    | _ -> return None
  end
end

// ─── Identity / Absorbing Element Simplification ────────────────────────────

let opt_simplify_binary = fn (op: BinaryOp, lhs: LirAtom, rhs: LirAtom) -> Option<LirAtom> do
  match op do
    | OpAdd ->
      match lhs do
        | LirAtomInt(val: 0) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomInt(val: 0) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | OpSub ->
      match rhs do
        | LirAtomInt(val: 0) -> return Some(val: lhs)
        | _ -> return None
      end
    | OpMul ->
      match lhs do
        | LirAtomInt(val: 0) -> return Some(val: LirAtomInt(val: 0))
        | LirAtomInt(val: 1) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomInt(val: 0) -> return Some(val: LirAtomInt(val: 0))
            | LirAtomInt(val: 1) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | OpDiv ->
      match rhs do
        | LirAtomInt(val: 1) -> return Some(val: lhs)
        | _ -> return None
      end
    | OpAnd ->
      match lhs do
        | LirAtomBool(val: false) -> return Some(val: LirAtomBool(val: false))
        | LirAtomBool(val: true) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomBool(val: false) -> return Some(val: LirAtomBool(val: false))
            | LirAtomBool(val: true) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | OpOr ->
      match lhs do
        | LirAtomBool(val: true) -> return Some(val: LirAtomBool(val: true))
        | LirAtomBool(val: false) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomBool(val: true) -> return Some(val: LirAtomBool(val: true))
            | LirAtomBool(val: false) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | _ -> return None
  end
end

let opt_fold_expr = fn (expr: LirExpr) -> LirExpr do
  if let LirExprBinary(op, lhs: l, rhs: r, typ: _) = expr then
    match opt_try_fold_binary(op, lhs: l, rhs: r) do
      | Some(val: result) -> return LirExprAtom(atom: result)
      | None ->
        match opt_simplify_binary(op, lhs: l, rhs: r) do
          | Some(val: result) -> return LirExprAtom(atom: result)
          | None -> return expr
        end
    end
  end
  return expr
end

// ─── Atom Substitution ──────────────────────────────────────────────────────

let opt_subst_atom = fn (atom: LirAtom, subst: [OptSubstEntry]) -> LirAtom do
  if let LirAtomVar(name: n, typ: _) = atom then
    match opt_lookup(name: n, entries: subst) do
      | Some(val: a) -> return a
      | None -> return atom
    end
  end
  return atom
end

let opt_subst_opt_atom = fn (opt: Option<LirAtom>, subst: [OptSubstEntry]) -> Option<LirAtom> do
  match opt do
    | Some(val: a) -> Some(val: opt_subst_atom(atom: a, subst))
    | None -> None
  end
end

let opt_subst_atoms = fn (atoms: [LirAtom], subst: [OptSubstEntry]) -> [LirAtom] do
  return opt_subst_atoms_go(xs: atoms, subst, acc: [])
end

let opt_subst_atoms_go = fn (xs: [LirAtom], subst: [OptSubstEntry], acc: [LirAtom]) -> [LirAtom] do
  match xs do
    | [] -> return reverse_atoms(lst: acc, out: [])
    | a :: rest ->
      return opt_subst_atoms_go(xs: rest, subst,
                                acc: opt_subst_atom(atom: a, subst) :: acc)
  end
end

let opt_subst_call_args = fn (args: [LirCallArg], subst: [OptSubstEntry]) -> [LirCallArg] do
  return opt_subst_call_args_go(xs: args, subst, acc: [])
end

let opt_subst_call_args_go = fn (xs: [LirCallArg], subst: [OptSubstEntry], acc: [LirCallArg]) -> [LirCallArg] do
  match xs do
    | [] -> return reverse_call_args(lst: acc, out: [])
    | LirCallArg(label: l, value: v) :: rest ->
      return opt_subst_call_args_go(xs: rest, subst,
                                    acc: LirCallArg(label: l, value: opt_subst_atom(atom: v, subst)) :: acc)
  end
end

let opt_subst_named_atoms = fn (fields: [LirNamedAtom], subst: [OptSubstEntry]) -> [LirNamedAtom] do
  return opt_subst_named_atoms_go(xs: fields, subst, acc: [])
end

let opt_subst_named_atoms_go = fn (xs: [LirNamedAtom], subst: [OptSubstEntry], acc: [LirNamedAtom]) -> [LirNamedAtom] do
  match xs do
    | [] -> return reverse_named_atoms(lst: acc, out: [])
    | LirNamedAtom(name: n, value: v) :: rest ->
      return opt_subst_named_atoms_go(xs: rest, subst,
                                      acc: LirNamedAtom(name: n, value: opt_subst_atom(atom: v, subst)) :: acc)
  end
end

let opt_subst_expr = fn (expr: LirExpr, subst: [OptSubstEntry]) -> LirExpr do
  match expr do
    | LirExprAtom(atom: a) ->
      LirExprAtom(atom: opt_subst_atom(atom: a, subst))
    | LirExprBinary(op, lhs: l, rhs: r, typ: t) ->
      LirExprBinary(op,
                    lhs: opt_subst_atom(atom: l, subst),
                    rhs: opt_subst_atom(atom: r, subst), typ: t)
    | LirExprCall(func: f, args, typ: t) ->
      LirExprCall(func: f, args: opt_subst_call_args(args, subst), typ: t)
    | LirExprTailCall(func: f, args, typ: t) ->
      LirExprTailCall(func: f, args: opt_subst_call_args(args, subst), typ: t)
    | LirExprConstructor(name: n, args, typ: t) ->
      LirExprConstructor(name: n, args: opt_subst_atoms(atoms: args, subst), typ: t)
    | LirExprRecord(fields: fs, typ: t) ->
      LirExprRecord(fields: opt_subst_named_atoms(fields: fs, subst), typ: t)
    | LirExprObjectTag(value: v, typ: t) ->
      LirExprObjectTag(value: opt_subst_atom(atom: v, subst), typ: t)
    | LirExprObjectField(value: v, index: i, typ: t) ->
      LirExprObjectField(value: opt_subst_atom(atom: v, subst), index: i, typ: t)
    | LirExprRaise(value: v, typ: t) ->
      LirExprRaise(value: opt_subst_atom(atom: v, subst), typ: t)
    | LirExprForce(value: v, typ: t) ->
      LirExprForce(value: opt_subst_atom(atom: v, subst), typ: t)
    | LirExprMakeClosure(func_name: f, captures: cs, typ: t) ->
      LirExprMakeClosure(func_name: f,
                         captures: opt_subst_atoms(atoms: cs, subst), typ: t)
    | LirExprCallClosure(closure: c, args, typ: t) ->
      LirExprCallClosure(closure: opt_subst_atom(atom: c, subst),
                         args: opt_subst_call_args(args, subst), typ: t)
    | LirExprSuspend(tag_name: tn, payload: p, typ: t) ->
      LirExprSuspend(tag_name: tn, payload: opt_subst_atom(atom: p, subst), typ: t)
    | LirExprResume(cont: c, value: v, typ: t) ->
      LirExprResume(cont: opt_subst_atom(atom: c, subst),
                    value: opt_subst_atom(atom: v, subst), typ: t)
    | LirExprContNew(func_ref: f, typ: t) ->
      LirExprContNew(func_ref: f, typ: t)
    | LirExprInjectResume(body_fn: f, arm_fns: a, arm_tags: ats, typ: t) ->
      LirExprInjectResume(body_fn: f, arm_fns: a, arm_tags: ats, typ: t)
  end
end

// ─── Combined Fold + Propagate Pass ─────────────────────────────────────────
//
// Single forward walk: substitutes constants/copies, folds binary expressions,
// and eliminates dead branches for LirStmtIf with constant conditions.

let opt_fp_stmts = fn (stmts: [LirStmt], subst: [OptSubstEntry], multi: [string]) -> FoldResult do
  return opt_fp_stmts_go(stmts, subst, multi, acc: [])
end

let opt_fp_stmts_go = fn (stmts: [LirStmt], subst: [OptSubstEntry], multi: [string], acc: [LirStmt]) -> FoldResult do
  match stmts do
    | [] -> return FoldResult(stmts: reverse_stmts_opt(lst: acc, out: []), subst)
    | s :: rest ->
      match opt_fp_stmt(stmt: s, subst, multi) do | FoldResult(stmts: processed, subst: new_subst) ->
        let new_acc = opt_prepend_reversed(stmts: processed, acc)
        return opt_fp_stmts_go(stmts: rest, subst: new_subst, multi, acc: new_acc)
      end
  end
end

// Prepend a short list (processed stmts) to acc in reverse order (for later reversal)
let opt_prepend_reversed = fn (stmts: [LirStmt], acc: [LirStmt]) -> [LirStmt] do
  match stmts do
    | [] -> return acc
    | s :: rest -> return opt_prepend_reversed(stmts: rest, acc: s :: acc)
  end
end

let opt_fp_stmt = fn (stmt: LirStmt, subst: [OptSubstEntry], multi: [string]) -> FoldResult do
  match stmt do
    | LirStmtLet(name: n, typ: t, expr: e) ->
      let subst_expr = opt_subst_expr(expr: e, subst)
      let folded_expr = opt_fold_expr(expr: subst_expr)
      // Track for propagation: if result is atom (literal or variable copy)
      // Skip multiply-bound names — not SSA-safe for copy propagation
      let new_subst = match folded_expr do
        | LirExprAtom(atom: a) ->
          if opt_has_name(name: n, names: multi) then
            subst
          else
            OptSubstEntry(name: n, atom: a) :: subst
          end
        | _ -> subst
      end
      return FoldResult(
        stmts: [LirStmtLet(name: n, typ: t, expr: folded_expr)],
        subst: new_subst
      )

    | LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let new_c = opt_subst_atom(atom: c, subst)
      // Dead branch elimination: constant condition → inline live branch
      match new_c do
        | LirAtomBool(val: true) ->
          return opt_fp_stmts(stmts: tb, subst, multi)
        | LirAtomBool(val: false) ->
          return opt_fp_stmts(stmts: eb, subst, multi)
        | _ ->
          let tb_r = opt_fp_stmts(stmts: tb, subst, multi)
          let eb_r = opt_fp_stmts(stmts: eb, subst, multi)
          match tb_r do | FoldResult(stmts: new_tb, subst: _) ->
            match eb_r do | FoldResult(stmts: new_eb, subst: _) ->
              return FoldResult(
                stmts: [LirStmtIf(cond: new_c, then_body: new_tb,
                                          else_body: new_eb)],
                subst: subst
              )
            end
          end
      end

    | LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr,
                          else_body: eb, else_ret: er, ret_type: rt) ->
      let new_c = opt_subst_atom(atom: c, subst)
      let tb_r = opt_fp_stmts(stmts: tb, subst, multi)
      let eb_r = opt_fp_stmts(stmts: eb, subst, multi)
      match tb_r do | FoldResult(stmts: new_tb, subst: tb_subst) ->
        match eb_r do | FoldResult(stmts: new_eb, subst: eb_subst) ->
          return FoldResult(
            stmts: [LirStmtIfReturn(
              cond: new_c,
              then_body: new_tb,
              then_ret: opt_subst_atom(atom: tr, subst: tb_subst),
              else_body: new_eb,
              else_ret: opt_subst_opt_atom(opt: er, subst: eb_subst),
              ret_type: rt
            )],
            subst: subst
          )
        end
      end

    | LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      let cs_r = opt_fp_stmts(stmts: cs, subst, multi)
      match cs_r do | FoldResult(stmts: new_cs, subst: cs_subst) ->
        let new_c = opt_subst_atom(atom: c, subst: cs_subst)
        let b_r = opt_fp_stmts(stmts: b, subst: cs_subst, multi)
        match b_r do | FoldResult(stmts: new_b, subst: _) ->
          return FoldResult(
            stmts: [LirStmtLoop(cond_stmts: new_cs, cond: new_c,
                                        body: new_b)],
            subst: subst
          )
        end
      end

    | LirStmtTryCatch(body: b, body_ret: br, catch_param: cp,
                          catch_param_typ: cpt, catch_body: cb, catch_ret: cr) ->
      let b_r = opt_fp_stmts(stmts: b, subst, multi)
      let cb_r = opt_fp_stmts(stmts: cb, subst, multi)
      match b_r do | FoldResult(stmts: new_b, subst: b_subst) ->
        match cb_r do | FoldResult(stmts: new_cb, subst: cb_subst) ->
          return FoldResult(
            stmts: [LirStmtTryCatch(
              body: new_b,
              body_ret: opt_subst_opt_atom(opt: br, subst: b_subst),
              catch_param: cp, catch_param_typ: cpt,
              catch_body: new_cb,
              catch_ret: opt_subst_opt_atom(opt: cr, subst: cb_subst)
            )],
            subst: subst
          )
        end
      end

  end
end

// ─── Use Collection (for DCE) ───────────────────────────────────────────────

let opt_collect_atom = fn (atom: LirAtom, used: [string]) -> [string] do
  if let LirAtomVar(name: n, typ: _) = atom then n :: used else used end
end

let opt_collect_opt_atom = fn (opt: Option<LirAtom>, used: [string]) -> [string] do
  if let Some(val: a) = opt then opt_collect_atom(atom: a, used) else used end
end

let opt_collect_atoms = fn (atoms: [LirAtom], used: [string]) -> [string] do
  match atoms do
    | [] -> used
    | a :: rest -> opt_collect_atoms(atoms: rest, used: opt_collect_atom(atom: a, used))
  end
end

let opt_collect_call_args = fn (args: [LirCallArg], used: [string]) -> [string] do
  match args do
    | [] -> used
    | LirCallArg(label: _, value: v) :: rest ->
      opt_collect_call_args(args: rest, used: opt_collect_atom(atom: v, used))
  end
end

let opt_collect_named_atoms = fn (fields: [LirNamedAtom], used: [string]) -> [string] do
  match fields do
    | [] -> used
    | LirNamedAtom(name: _, value: v) :: rest ->
      opt_collect_named_atoms(fields: rest, used: opt_collect_atom(atom: v, used))
  end
end


let opt_collect_expr = fn (expr: LirExpr, used: [string]) -> [string] do
  match expr do
    | LirExprAtom(atom: a) -> opt_collect_atom(atom: a, used)
    | LirExprBinary(op: _, lhs: l, rhs: r, typ: _) ->
      opt_collect_atom(atom: r, used: opt_collect_atom(atom: l, used))
    | LirExprCall(func: _, args, typ: _) ->
      opt_collect_call_args(args, used)
    | LirExprTailCall(func: _, args, typ: _) ->
      opt_collect_call_args(args, used)
    | LirExprConstructor(name: _, args, typ: _) ->
      opt_collect_atoms(atoms: args, used)
    | LirExprRecord(fields: fs, typ: _) ->
      opt_collect_named_atoms(fields: fs, used)
    | LirExprObjectTag(value: v, typ: _) ->
      opt_collect_atom(atom: v, used)
    | LirExprObjectField(value: v, index: _, typ: _) ->
      opt_collect_atom(atom: v, used)
    | LirExprRaise(value: v, typ: _) ->
      opt_collect_atom(atom: v, used)
    | LirExprForce(value: v, typ: _) ->
      opt_collect_atom(atom: v, used)
    | LirExprMakeClosure(func_name: _, captures: cs, typ: _) ->
      opt_collect_atoms(atoms: cs, used)
    | LirExprCallClosure(closure: c, args, typ: _) ->
      opt_collect_call_args(args, used: opt_collect_atom(atom: c, used))
    | LirExprSuspend(tag_name: _, payload: p, typ: _) ->
      opt_collect_atom(atom: p, used)
    | LirExprResume(cont: c, value: v, typ: _) ->
      opt_collect_atom(atom: v, used: opt_collect_atom(atom: c, used))
    | LirExprContNew(func_ref: _, typ: _) -> used
    | LirExprInjectResume(body_fn: _, arm_fns: _, arm_tags: _, typ: _) -> used
  end
end

let opt_collect_stmt = fn (stmt: LirStmt, used: [string]) -> [string] do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) ->
      opt_collect_expr(expr: e, used)
    | LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let u1 = opt_collect_atom(atom: c, used)
      let u2 = opt_collect_stmts(stmts: tb, used: u1)
      opt_collect_stmts(stmts: eb, used: u2)
    | LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr,
                          else_body: eb, else_ret: er, ret_type: _) ->
      let u1 = opt_collect_atom(atom: c, used)
      let u2 = opt_collect_stmts(stmts: tb, used: u1)
      let u3 = opt_collect_atom(atom: tr, used: u2)
      let u4 = opt_collect_stmts(stmts: eb, used: u3)
      opt_collect_opt_atom(opt: er, used: u4)
    | LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      let u1 = opt_collect_stmts(stmts: cs, used)
      let u2 = opt_collect_atom(atom: c, used: u1)
      opt_collect_stmts(stmts: b, used: u2)
    | LirStmtTryCatch(body: b, body_ret: br, catch_param: _,
                          catch_param_typ: _, catch_body: cb, catch_ret: cr) ->
      let u1 = opt_collect_stmts(stmts: b, used)
      let u2 = opt_collect_opt_atom(opt: br, used: u1)
      let u3 = opt_collect_stmts(stmts: cb, used: u2)
      opt_collect_opt_atom(opt: cr, used: u3)
  end
end

let opt_collect_stmts = fn (stmts: [LirStmt], used: [string]) -> [string] do
  match stmts do
    | [] -> used
    | s :: rest -> opt_collect_stmts(stmts: rest, used: opt_collect_stmt(stmt: s, used))
  end
end

// ─── Dead Code Elimination ──────────────────────────────────────────────────
//
// Removes LirStmtLet bindings where the bound name has zero uses AND the
// expression is pure (no side effects). Recurses into nested blocks.

let opt_dce_stmts = fn (stmts: [LirStmt], used: [string]) -> [LirStmt] do
  return opt_dce_stmts_go(stmts, used, acc: [])
end

let opt_dce_stmts_go = fn (stmts: [LirStmt], used: [string], acc: [LirStmt]) -> [LirStmt] do
  match stmts do
    | [] -> return reverse_stmts_opt(lst: acc, out: [])
    | s :: rest ->
      match opt_dce_one(stmt: s, used) do
        | Some(val: stmt) -> return opt_dce_stmts_go(stmts: rest, used, acc: stmt :: acc)
        | None -> return opt_dce_stmts_go(stmts: rest, used, acc)
      end
  end
end

let opt_dce_one = fn (stmt: LirStmt, used: [string]) -> Option<LirStmt> do
  match stmt do
    | LirStmtLet(name: n, typ: t, expr: e) ->
      if opt_has_name(name: n, names: used) then
        return Some(val: LirStmtLet(name: n, typ: t, expr: e))
      end
      if opt_is_pure(expr: e) then
        return None
      else
        return Some(val: LirStmtLet(name: n, typ: t, expr: e))
      end
    | LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      return Some(val: LirStmtIf(cond: c,
                         then_body: opt_dce_stmts(stmts: tb, used),
                         else_body: opt_dce_stmts(stmts: eb, used)))
    | LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr,
                          else_body: eb, else_ret: er, ret_type: rt) ->
      return Some(val: LirStmtIfReturn(cond: c,
                               then_body: opt_dce_stmts(stmts: tb, used),
                               then_ret: tr,
                               else_body: opt_dce_stmts(stmts: eb, used),
                               else_ret: er, ret_type: rt))
    | LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      return Some(val: LirStmtLoop(cond_stmts: opt_dce_stmts(stmts: cs, used),
                           cond: c,
                           body: opt_dce_stmts(stmts: b, used)))
    | LirStmtTryCatch(body: b, body_ret: br, catch_param: cp,
                          catch_param_typ: cpt, catch_body: cb, catch_ret: cr) ->
      return Some(val: LirStmtTryCatch(body: opt_dce_stmts(stmts: b, used),
                               body_ret: br, catch_param: cp,
                               catch_param_typ: cpt,
                               catch_body: opt_dce_stmts(stmts: cb, used),
                               catch_ret: cr))
  end
end

// ─── Entry Points ───────────────────────────────────────────────────────────

let opt_function = fn (func: LirFunction) -> LirFunction do
  let LirFunction(name: n, params: p, ret_type: rt,
                  body, ret, span: sp) = func
  let multi = opt_find_multi(names: opt_let_names_stmts(stmts: body))
  let fp_result = opt_fp_stmts(stmts: body, subst: [], multi)
  let FoldResult(stmts: fp_body, subst: final_subst) = fp_result
  let fp_ret = opt_subst_atom(atom: ret, subst: final_subst)
  let used = opt_collect_stmts(stmts: fp_body,
                               used: opt_collect_atom(atom: fp_ret, used: []))
  let dce_body = opt_dce_stmts(stmts: fp_body, used)
  LirFunction(name: n, params: p, ret_type: rt,
              body: dce_body, ret: fp_ret, span: sp)
end

let opt_functions = fn (funcs: [LirFunction]) -> [LirFunction] do
  return opt_functions_go(funcs, acc: [])
end

let opt_functions_go = fn (funcs: [LirFunction], acc: [LirFunction]) -> [LirFunction] do
  match funcs do
    | [] -> return reverse_funcs(lst: acc, out: [])
    | f :: rest ->
      return opt_functions_go(funcs: rest, acc: opt_function(func: f) :: acc)
  end
end

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let reverse_funcs = fn (lst: [LirFunction], out: [LirFunction]) -> [LirFunction] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_funcs(lst: rest, out: x :: out)
  end
end

let reverse_stmts_opt = fn (lst: [LirStmt], out: [LirStmt]) -> [LirStmt] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_stmts_opt(lst: rest, out: x :: out)
  end
end

let reverse_strings = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_strings(lst: rest, out: x :: out)
  end
end

let reverse_atoms = fn (lst: [LirAtom], out: [LirAtom]) -> [LirAtom] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_atoms(lst: rest, out: x :: out)
  end
end

let reverse_call_args = fn (lst: [LirCallArg], out: [LirCallArg]) -> [LirCallArg] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_call_args(lst: rest, out: x :: out)
  end
end

let reverse_named_atoms = fn (lst: [LirNamedAtom], out: [LirNamedAtom]) -> [LirNamedAtom] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_named_atoms(lst: rest, out: x :: out)
  end
end

export let optimize_lir = fn (program: LirProgram) -> LirProgram do
  let LirProgram(functions: funcs, externals: exts) = program
  LirProgram(functions: opt_functions(funcs), externals: exts)
end

// ─── Stream Fusion (build/foldr) ────────────────────────────────────────────
//
// Implements the GHC-style shortcut deforestation rule
//
//     foldr(k, z, build(g)) ≡ g(k, z)
//
// where `list.build` and `list.foldr` are the conventions defined in
// nxlib/stdlib/list.nx. Concretely the rewriter looks for the local
// 2-statement pattern
//
//     let built  = Call(list_build, [g_clos])
//     let result = Call(list_foldr, [xs=built, init=z, f=k_clos])
//
// where `built` is used exactly once (so removing it is safe), `g_clos` is
// a MakeClosure on a top-level lifted lambda, and `k_clos` is also a
// MakeClosure whose target function the EffectMap reports as `is_pure`.
// Pure-only is the safety gate (see issue body): if the combining function
// could throw, capture, or perform I/O, fusion would change the
// observable order/duplication of effects relative to the unfused walk
// and is therefore disabled.
//
// The rewrite drops the build call and replaces the foldr call with a
// direct closure invocation `CallClosure(g_clos, [k_clos, z])`. The build
// statement is left in place; downstream DCE removes it because its sole
// use just disappeared. We do not relocate `g_clos` or `k_clos`
// definitions: they must dominate the foldr statement (which they do
// since they were already arguments to `Call`s preceding it).

// Canonical names of the stdlib build/foldr functions. Defined as
// zero-arg functions because Nexus does not currently allow top-level
// `let` bindings for non-function values; calling them at the
// pattern-match site is a one-call no-op.
let foldr_fn_name = fn () -> string do return "nxlib_stdlib_list_nx#foldr" end
let build_fn_name = fn () -> string do return "nxlib_stdlib_list_nx#build" end

type FusionVarDef = FusionVarDef(name: string, expr: LirExpr)
type FusionUseEntry = FusionUseEntry(name: string, count: i64)
type FusionCtx = FusionCtx(
  defs: [FusionVarDef],
  uses: [FusionUseEntry],
  effects: EffectMap
)

let fus_lookup_def = fn (name: string, defs: [FusionVarDef]) -> Option<LirExpr> do
  match defs do
    | [] -> return None
    | FusionVarDef(name: n, expr: e) :: rest ->
      if n == name then return Some(val: e) end
      return fus_lookup_def(name, defs: rest)
  end
end

// Sum the count field of every entry whose name equals the queried one.
// Combined with the now O(1) bump, this gives a true linear-pass use map.
let fus_lookup_use = fn (name: string, uses: [FusionUseEntry]) -> i64 do
  return fus_lookup_use_go(name: name, uses: uses, total: 0)
end

let fus_lookup_use_go = fn (name: string, uses: [FusionUseEntry], total: i64) -> i64 do
  match uses do
    | [] -> return total
    | FusionUseEntry(name: n, count: c) :: rest ->
      if n == name then
        return fus_lookup_use_go(name: name, uses: rest, total: total + c)
      end
      return fus_lookup_use_go(name: name, uses: rest, total: total)
  end
end

// Single-use check: returns true iff `name` is referenced exactly once in
// the surrounding statement list. Multi-use disables fusion because the
// build call's result would otherwise be observed under cons/nil semantics
// elsewhere, where the rewritten direct invocation is no longer a list.
let fus_single_use = fn (name: string, ctx: FusionCtx) -> bool do
  let FusionCtx(defs: _, uses, effects: _) = ctx
  return fus_lookup_use(name, uses) == 1
end

// Record one occurrence of `name`. Implementation is O(1) amortised:
// every use is prepended as a fresh entry, and `fus_lookup_use` later
// counts occurrences in a single pass. The earlier amortised-association
// scheme was O(uses^2) per function; on a 2000-function compiler that
// drove stage-1 OOM during self-host bootstrap.
let fus_bump_use = fn (name: string, uses: [FusionUseEntry]) -> [FusionUseEntry] do
  return FusionUseEntry(name: name, count: 1) :: uses
end

let reverse_use_entries = fn (lst: [FusionUseEntry], out: [FusionUseEntry]) -> [FusionUseEntry] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_use_entries(lst: rest, out: x :: out)
  end
end

let reverse_var_defs = fn (lst: [FusionVarDef], out: [FusionVarDef]) -> [FusionVarDef] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_var_defs(lst: rest, out: x :: out)
  end
end

// Count uses across one statement (atom + nested-statement walk).
let fus_count_uses_atom = fn (atom: LirAtom, uses: [FusionUseEntry]) -> [FusionUseEntry] do
  if let LirAtomVar(name: n, typ: _) = atom then
    return fus_bump_use(name: n, uses)
  end
  return uses
end

let fus_count_uses_opt_atom = fn (opt: Option<LirAtom>, uses: [FusionUseEntry]) -> [FusionUseEntry] do
  match opt do
    | Some(val: a) -> return fus_count_uses_atom(atom: a, uses)
    | None -> return uses
  end
end

let fus_count_uses_atoms = fn (xs: [LirAtom], uses: [FusionUseEntry]) -> [FusionUseEntry] do
  match xs do
    | [] -> return uses
    | a :: rest -> return fus_count_uses_atoms(xs: rest, uses: fus_count_uses_atom(atom: a, uses))
  end
end

let fus_count_uses_call_args = fn (args: [LirCallArg], uses: [FusionUseEntry]) -> [FusionUseEntry] do
  match args do
    | [] -> return uses
    | LirCallArg(label: _, value: v) :: rest ->
      return fus_count_uses_call_args(args: rest, uses: fus_count_uses_atom(atom: v, uses))
  end
end

let fus_count_uses_named = fn (fs: [LirNamedAtom], uses: [FusionUseEntry]) -> [FusionUseEntry] do
  match fs do
    | [] -> return uses
    | LirNamedAtom(name: _, value: v) :: rest ->
      return fus_count_uses_named(fs: rest, uses: fus_count_uses_atom(atom: v, uses))
  end
end

let fus_count_uses_expr = fn (expr: LirExpr, uses: [FusionUseEntry]) -> [FusionUseEntry] do
  match expr do
    | LirExprAtom(atom: a) -> return fus_count_uses_atom(atom: a, uses)
    | LirExprBinary(op: _, lhs: l, rhs: r, typ: _) ->
      return fus_count_uses_atom(atom: r, uses: fus_count_uses_atom(atom: l, uses))
    | LirExprCall(func: _, args, typ: _) -> return fus_count_uses_call_args(args, uses)
    | LirExprTailCall(func: _, args, typ: _) -> return fus_count_uses_call_args(args, uses)
    | LirExprConstructor(name: _, args, typ: _) -> return fus_count_uses_atoms(xs: args, uses)
    | LirExprRecord(fields: fs, typ: _) -> return fus_count_uses_named(fs, uses)
    | LirExprObjectTag(value: v, typ: _) -> return fus_count_uses_atom(atom: v, uses)
    | LirExprObjectField(value: v, index: _, typ: _) -> return fus_count_uses_atom(atom: v, uses)
    | LirExprRaise(value: v, typ: _) -> return fus_count_uses_atom(atom: v, uses)
    | LirExprForce(value: v, typ: _) -> return fus_count_uses_atom(atom: v, uses)
    | LirExprMakeClosure(func_name: _, captures: cs, typ: _) -> return fus_count_uses_atoms(xs: cs, uses)
    | LirExprCallClosure(closure: c, args, typ: _) ->
      return fus_count_uses_call_args(args, uses: fus_count_uses_atom(atom: c, uses))
    | LirExprSuspend(tag_name: _, payload: p, typ: _) -> return fus_count_uses_atom(atom: p, uses)
    | LirExprResume(cont: c, value: v, typ: _) ->
      return fus_count_uses_atom(atom: v, uses: fus_count_uses_atom(atom: c, uses))
    | LirExprContNew(_) -> return uses
    | LirExprInjectResume(_) -> return uses
  end
end

let fus_count_uses_stmt = fn (stmt: LirStmt, uses: [FusionUseEntry]) -> [FusionUseEntry] do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) -> return fus_count_uses_expr(expr: e, uses)
    | LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let u1 = fus_count_uses_atom(atom: c, uses)
      let u2 = fus_count_uses_stmts(stmts: tb, uses: u1)
      return fus_count_uses_stmts(stmts: eb, uses: u2)
    | LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr,
                      else_body: eb, else_ret: er, ret_type: _) ->
      let u1 = fus_count_uses_atom(atom: c, uses)
      let u2 = fus_count_uses_stmts(stmts: tb, uses: u1)
      let u3 = fus_count_uses_atom(atom: tr, uses: u2)
      let u4 = fus_count_uses_stmts(stmts: eb, uses: u3)
      return fus_count_uses_opt_atom(opt: er, uses: u4)
    | LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      let u1 = fus_count_uses_stmts(stmts: cs, uses)
      let u2 = fus_count_uses_atom(atom: c, uses: u1)
      return fus_count_uses_stmts(stmts: b, uses: u2)
    | LirStmtTryCatch(body: b, body_ret: br, catch_param: _, catch_param_typ: _,
                      catch_body: cb, catch_ret: cr) ->
      let u1 = fus_count_uses_stmts(stmts: b, uses)
      let u2 = fus_count_uses_opt_atom(opt: br, uses: u1)
      let u3 = fus_count_uses_stmts(stmts: cb, uses: u2)
      return fus_count_uses_opt_atom(opt: cr, uses: u3)
  end
end

let fus_count_uses_stmts = fn (stmts: [LirStmt], uses: [FusionUseEntry]) -> [FusionUseEntry] do
  match stmts do
    | [] -> return uses
    | s :: rest -> return fus_count_uses_stmts(stmts: rest, uses: fus_count_uses_stmt(stmt: s, uses))
  end
end

// Build the local def map: every Let in this scope contributes name → expr.
let fus_collect_defs_stmts = fn (stmts: [LirStmt], acc: [FusionVarDef]) -> [FusionVarDef] do
  match stmts do
    | [] -> return reverse_var_defs(lst: acc, out: [])
    | LirStmtLet(name: n, typ: _, expr: e) :: rest ->
      return fus_collect_defs_stmts(stmts: rest, acc: FusionVarDef(name: n, expr: e) :: acc)
    | _ :: rest -> return fus_collect_defs_stmts(stmts: rest, acc)
  end
end

// Locate a labelled call argument; returns None if missing. Labels in
// LirCallArg are positional names, so e.g. foldr's args carry "xs",
// "init", "f".
let fus_find_arg = fn (label: string, args: [LirCallArg]) -> Option<LirAtom> do
  match args do
    | [] -> return None
    | LirCallArg(label: l, value: v) :: rest ->
      if l == label then return Some(val: v) end
      return fus_find_arg(label, args: rest)
  end
end

// Effect gate: return true iff the closure's underlying function is pure
// per the EffectMap. Treat missing summaries as impure (fail closed) so a
// missing entry never silently enables fusion.
let fus_is_closure_pure = fn (clos_expr: LirExpr, effects: EffectMap) -> bool do
  if let LirExprMakeClosure(func_name: fn_name, captures: _, typ: _) = clos_expr then
    match lookup_summary(em: effects, name: fn_name) do
      | Some(val: s) ->
        let EffectSummary(capabilities_used: _, can_throw: _, is_pure: pure) = s
        return pure
      | None -> return false
    end
  end
  return false
end

// Resolve an atom to a closure expression in the local def map. Fusion
// requires both g and k to be MakeClosure; FuncRef-via-atom is not yet
// supported.
let fus_resolve_closure = fn (atom: LirAtom, defs: [FusionVarDef]) -> Option<LirExpr> do
  if let LirAtomVar(name: n, typ: _) = atom then
    return fus_lookup_def(name: n, defs)
  end
  return None
end

// Helper: resolve the inner build call from xs's atom. Returns the `g`
// closure atom from `Call(build, g=...)` if the chain matches; None
// otherwise (xs not a variable, multi-use, not a build call, missing g).
let fus_unfold_build = fn (xs_atom: LirAtom, ctx: FusionCtx) -> Option<LirAtom> do
  let FusionCtx(defs, uses: _, effects: _) = ctx
  if let LirAtomVar(name: xs_name, typ: _) = xs_atom then
    if !fus_single_use(name: xs_name, ctx) then return None end
    match fus_lookup_def(name: xs_name, defs) do
      | None -> return None
      | Some(val: xs_expr) ->
        if let LirExprCall(func: build_fn, args: build_args, typ: _) = xs_expr then
          if build_fn != build_fn_name() then return None end
          return fus_find_arg(label: "g", args: build_args)
        end
        return None
    end
  end
  return None
end

// Helper: verify a foldr argument atom resolves to a MakeClosure. Returns
// the closure expression on success; None if it is anything else (literal,
// param-only var, FuncRef-style atom, …) — fusion is conservative and
// only fires when both g and k are explicit MakeClosure values that
// effect_analysis can index.
let fus_require_closure = fn (atom: LirAtom, defs: [FusionVarDef]) -> Option<LirExpr> do
  match fus_resolve_closure(atom, defs) do
    | None -> return None
    | Some(val: e) ->
      if let LirExprMakeClosure(_) = e then return Some(val: e) end
      return None
  end
end

// The core rewrite: given a foldr Let, decide whether it fuses with a
// preceding build, and produce the replacement statement(s).
//
// Returns Some(new_stmt) when fusion fires; None otherwise. The build
// Let is not rewritten in place — we leave it as-is so the surrounding
// pipeline (already-running DCE) collects it once its single use has
// vanished. This keeps the rewrite local and avoids stmt-list surgery.
let fus_try_fuse_foldr = fn (
  let_name: string,
  let_typ: TypeExpr,
  args: [LirCallArg],
  ctx: FusionCtx
) -> Option<LirStmt> do
  let FusionCtx(defs, uses: _, effects) = ctx
  match fus_find_arg(label: "xs", args) do
    | None -> return None
    | Some(val: xs_atom) ->
      match fus_find_arg(label: "init", args) do
        | None -> return None
        | Some(val: init_atom) ->
          match fus_find_arg(label: "f", args) do
            | None -> return None
            | Some(val: f_atom) ->
              match fus_unfold_build(xs_atom, ctx) do
                | None -> return None
                | Some(val: g_atom) ->
                  match fus_require_closure(atom: g_atom, defs) do
                    | None -> return None
                    | Some(_) ->
                      match fus_require_closure(atom: f_atom, defs) do
                        | None -> return None
                        | Some(val: k_expr) ->
                          if !fus_is_closure_pure(clos_expr: k_expr, effects) then
                            return None
                          end
                          // Synthesise the direct closure call:
                          //   CallClosure(g, [cons=k, nil=z])
                          let new_args = [
                            LirCallArg(label: "cons", value: f_atom),
                            LirCallArg(label: "nil", value: init_atom)
                          ]
                          let new_expr = LirExprCallClosure(
                            closure: g_atom,
                            args: new_args,
                            typ: let_typ
                          )
                          return Some(val: LirStmtLet(name: let_name, typ: let_typ, expr: new_expr))
                      end
                  end
              end
          end
      end
  end
end

// Rewrite a single statement in-place if it is the foldr we want to fuse.
let fus_rewrite_stmt = fn (stmt: LirStmt, ctx: FusionCtx) -> LirStmt do
  match stmt do
    | LirStmtLet(name: n, typ: t, expr: e) ->
      if let LirExprCall(func: fname, args: a, typ: _) = e then
        if fname == foldr_fn_name() then
          match fus_try_fuse_foldr(let_name: n, let_typ: t, args: a, ctx) do
            | Some(val: new_stmt) -> return new_stmt
            | None -> return stmt
          end
        end
      end
      return stmt
    | LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      return LirStmtIf(cond: c,
                       then_body: fus_rewrite_stmts_in(stmts: tb, effects: fus_effects(ctx)),
                       else_body: fus_rewrite_stmts_in(stmts: eb, effects: fus_effects(ctx)))
    | LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr,
                      else_body: eb, else_ret: er, ret_type: rt) ->
      return LirStmtIfReturn(cond: c,
                             then_body: fus_rewrite_stmts_in(stmts: tb, effects: fus_effects(ctx)),
                             then_ret: tr,
                             else_body: fus_rewrite_stmts_in(stmts: eb, effects: fus_effects(ctx)),
                             else_ret: er, ret_type: rt)
    | LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      return LirStmtLoop(cond_stmts: fus_rewrite_stmts_in(stmts: cs, effects: fus_effects(ctx)),
                         cond: c,
                         body: fus_rewrite_stmts_in(stmts: b, effects: fus_effects(ctx)))
    | LirStmtTryCatch(body: b, body_ret: br, catch_param: cp,
                      catch_param_typ: cpt, catch_body: cb, catch_ret: cr) ->
      return LirStmtTryCatch(body: fus_rewrite_stmts_in(stmts: b, effects: fus_effects(ctx)),
                             body_ret: br, catch_param: cp, catch_param_typ: cpt,
                             catch_body: fus_rewrite_stmts_in(stmts: cb, effects: fus_effects(ctx)),
                             catch_ret: cr)
  end
end

let fus_effects = fn (ctx: FusionCtx) -> EffectMap do
  let FusionCtx(defs: _, uses: _, effects) = ctx
  return effects
end

// Iterate over a stmt list with a freshly built ctx for that scope.
let fus_rewrite_stmts_in = fn (stmts: [LirStmt], effects: EffectMap) -> [LirStmt] do
  let defs = fus_collect_defs_stmts(stmts: stmts, acc: [])
  let uses = fus_count_uses_stmts(stmts: stmts, uses: [])
  let ctx = FusionCtx(defs: defs, uses: uses, effects: effects)
  return fus_rewrite_stmts_go(stmts: stmts, ctx: ctx, acc: [])
end

let fus_rewrite_stmts_go = fn (stmts: [LirStmt], ctx: FusionCtx, acc: [LirStmt]) -> [LirStmt] do
  match stmts do
    | [] -> return reverse_stmts_opt(lst: acc, out: [])
    | s :: rest ->
      let new_s = fus_rewrite_stmt(stmt: s, ctx: ctx)
      return fus_rewrite_stmts_go(stmts: rest, ctx: ctx, acc: new_s :: acc)
  end
end

let fus_rewrite_function = fn (func: LirFunction, effects: EffectMap) -> LirFunction do
  let LirFunction(name: n, params: p, ret_type: rt, body: bd, ret: rv, span: sp) = func
  let new_body = fus_rewrite_stmts_in(stmts: bd, effects: effects)
  return LirFunction(name: n, params: p, ret_type: rt, body: new_body, ret: rv, span: sp)
end

let fus_rewrite_functions = fn (funcs: [LirFunction], effects: EffectMap) -> [LirFunction] do
  return fus_rewrite_functions_go(funcs: funcs, effects: effects, acc: [])
end

let fus_rewrite_functions_go = fn (funcs: [LirFunction], effects: EffectMap, acc: [LirFunction]) -> [LirFunction] do
  match funcs do
    | [] -> return reverse_funcs(lst: acc, out: [])
    | f :: rest ->
      return fus_rewrite_functions_go(funcs: rest, effects: effects,
                                      acc: fus_rewrite_function(func: f, effects: effects) :: acc)
  end
end

// Public entry: run stream fusion over a program using the provided
// EffectMap, then run the existing fold/propagate/DCE pipeline on the
// result so the now-dead build call is collected.
export let optimize_lir_with_effects = fn (program: LirProgram, effects: EffectMap) -> LirProgram do
  let LirProgram(functions: funcs, externals: exts) = program
  let fused = fus_rewrite_functions(funcs: funcs, effects: effects)
  let optimised = opt_functions(funcs: fused)
  return LirProgram(functions: optimised, externals: exts)
end
