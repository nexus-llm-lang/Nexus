/**
 * resolve: Name resolution for the Nexus self-hosting compiler.
 *
 * Provides:
 * - build_rename_map: construct rename entries from an import definition
 * - default_alias: extract module stem from import path
 * - register_top_level: populate symbol table from top-level definitions
 * - collect_enum_defs: gather all enum definitions
 * - extract_imports: gather all import definitions
 * - would_cycle: import cycle detection
 * - merge_rename_entries / apply_rename / make_rename_entry: rename utilities
 */
import { SpannedExpr, SpannedTopLevel, TopLevel,
         GlobalLet, Port, VariantDef, EnumDef, RecordDef,
         ExceptionDef, ExceptionGroupDef, ImportDef, ImportItem,
         TLExceptionGroup } from "src/common/ast.nx"
import { RenameEntry, ScopeState }, * as symtab from "src/ir/symtab.nx"
import * as str from "stdlib/string.nx"
import * as list from "stdlib/list.nx"
import { StringMap } from "stdlib/stringmap.nx"
import * as rdr from "src/ir/rdrname.nx"

// ─── Path utilities ───────────────────────────────────────────────────────────

let find_last_slash_go = fn (s: string, pos: i64, last: i64) -> i64 do
  if pos >= str.length(s: s) then return last
  else
    let ch = str.substring(s: s, start: pos, len: 1)
    if ch == "/" then return find_last_slash_go(s: s, pos: pos + 1, last: pos)
    else return find_last_slash_go(s: s, pos: pos + 1, last: last)
    end
  end
end

/// Extract the module stem from an import path.
/// e.g., "stdlib/string.nx" -> "string", "foo.nx" -> "foo"
export let default_alias = fn (path: string) -> string do
  let slash_pos = find_last_slash_go(s: path, pos: 0, last: -1)
  let start = slash_pos + 1
  let rest = str.substring(s: path, start: start, len: str.length(s: path) - start)
  let dot_pos = str.index_of(s: rest, sub: ".")
  if dot_pos < 0 then return rest
  else return str.substring(s: rest, start: 0, len: dot_pos)
  end
end

// ─── Rename map construction ──────────────────────────────────────────────────

/// Check if name is in the import items list. Returns the visible name (alias or original).
let find_selected = fn (name: string, items: [ImportItem]) -> Option<string> do
  match items do
    case [] -> return None
    case ImportItem(name: item_name, item_alias: alias_opt) :: rest ->
      if item_name == name then
        match alias_opt do
          case Some(val: a) -> return Some(val: a)
          case None -> return Some(val: name)
        end
      else return find_selected(name: name, items: rest)
      end
  end
end

/// Build internal-view rename entries for an imported module: each top-level
/// def gets mapped to its canonical name (source#name). Produced once per
/// import and used for the imported module's own internal calls.
let build_internal_rename_go = fn (defs: [SpannedTopLevel], source: string, acc: [RenameEntry]) -> [RenameEntry] do
  match defs do
    case [] -> return acc
    case SpannedTopLevel(node: TLLet(def: GlobalLet(name: name, is_public: _, typ: _, value: _)), span: _) :: rest ->
      let acc2 = symtab.rename_add(entries: acc, original: name, qualified: rdr.canonical_name(source_path: source, name: name))
      return build_internal_rename_go(defs: rest, source: source, acc: acc2)
    case SpannedTopLevel(node: TLPort(def: Port(name: name, is_public: _, functions: _)), span: _) :: rest ->
      let acc2 = symtab.rename_add(entries: acc, original: name, qualified: rdr.canonical_name(source_path: source, name: name))
      return build_internal_rename_go(defs: rest, source: source, acc: acc2)
    case _ :: rest ->
      return build_internal_rename_go(defs: rest, source: source, acc: acc)
  end
end

/// Build the internal-view rename map for an imported module: entries for
/// the module's own top-level defs, each mapped to its canonical name.
/// Used when processing the imported module's function bodies.
export let build_rename_map = fn (imported_defs: [SpannedTopLevel], import_def: ImportDef, import_depth: i64) -> [RenameEntry] do
  match import_def do
    case ImportDef(path: path, alias: _, items: _, is_external: is_ext) ->
      if is_ext then return []
      else
        return build_internal_rename_go(defs: imported_defs, source: path, acc: [])
      end
  end
end

/// For wildcard import `import * as a from "A"`: caller sees `a.foo -> canonical(A, foo)`.
let build_wildcard_importer_go = fn (defs: [SpannedTopLevel], source: string, alias: string, acc: [RenameEntry]) -> [RenameEntry] do
  match defs do
    case [] -> return acc
    case SpannedTopLevel(node: TLLet(def: GlobalLet(name: name, is_public: _, typ: _, value: _)), span: _) :: rest ->
      let key = alias ++ "." ++ name
      let acc2 = symtab.rename_add(entries: acc, original: key, qualified: rdr.canonical_name(source_path: source, name: name))
      return build_wildcard_importer_go(defs: rest, source: source, alias: alias, acc: acc2)
    case SpannedTopLevel(node: TLPort(def: Port(name: name, is_public: _, functions: _)), span: _) :: rest ->
      let key = alias ++ "." ++ name
      let acc2 = symtab.rename_add(entries: acc, original: key, qualified: rdr.canonical_name(source_path: source, name: name))
      return build_wildcard_importer_go(defs: rest, source: source, alias: alias, acc: acc2)
    case _ :: rest ->
      return build_wildcard_importer_go(defs: rest, source: source, alias: alias, acc: acc)
  end
end

/// For selective import `import { foo as bar } from "A"`: caller sees `bar -> canonical(A, foo)`.
let build_selective_importer_go = fn (defs: [SpannedTopLevel], items: [ImportItem], source: string, acc: [RenameEntry]) -> [RenameEntry] do
  match defs do
    case [] -> return acc
    case SpannedTopLevel(node: TLLet(def: GlobalLet(name: name, is_public: _, typ: _, value: _)), span: _) :: rest ->
      match find_selected(name: name, items: items) do
        case Some(val: visible) ->
          let acc2 = symtab.rename_add(entries: acc, original: visible, qualified: rdr.canonical_name(source_path: source, name: name))
          return build_selective_importer_go(defs: rest, items: items, source: source, acc: acc2)
        case None ->
          return build_selective_importer_go(defs: rest, items: items, source: source, acc: acc)
      end
    case SpannedTopLevel(node: TLPort(def: Port(name: name, is_public: _, functions: _)), span: _) :: rest ->
      match find_selected(name: name, items: items) do
        case Some(val: visible) ->
          let acc2 = symtab.rename_add(entries: acc, original: visible, qualified: rdr.canonical_name(source_path: source, name: name))
          return build_selective_importer_go(defs: rest, items: items, source: source, acc: acc2)
        case None ->
          return build_selective_importer_go(defs: rest, items: items, source: source, acc: acc)
      end
    case _ :: rest ->
      return build_selective_importer_go(defs: rest, items: items, source: source, acc: acc)
  end
end

/// Build the importer-view rename entries for an import: the entries that
/// the importing scope needs so its own calls (alias.foo or bare visible
/// names from selective imports) rename to the canonical target.
export let build_importer_entries = fn (imported_defs: [SpannedTopLevel], import_def: ImportDef) -> [RenameEntry] do
  match import_def do
    case ImportDef(path: path, alias: alias_opt, items: items, is_external: is_ext) ->
      if is_ext then return []
      else
        match items do
          case [] ->
            let alias = match alias_opt do
              case Some(val: a) -> a
              case None -> default_alias(path: path)
            end
            return build_wildcard_importer_go(defs: imported_defs, source: path, alias: alias, acc: [])
          case _ :: _ ->
            let selective = build_selective_importer_go(defs: imported_defs, items: items, source: path, acc: [])
            match alias_opt do
              case Some(val: alias) ->
                return build_wildcard_importer_go(defs: imported_defs, source: path, alias: alias, acc: selective)
              case None -> return selective
            end
        end
      end
  end
end

// ─── Symbol registration ──────────────────────────────────────────────────────

let register_variants_go = fn (tab: %StringMap, state: ScopeState, variants: [VariantDef]) -> %StringMap throws { Exn } do
  match variants do
    case [] -> return tab
    case VariantDef(name: vname, fields: _) :: rest ->
      let %tab2 = symtab.define_constructor(tab: tab, state: state, name: vname)
      return register_variants_go(tab: %tab2, state: state, variants: rest)
  end
end

let collect_enum_defs_go = fn (defs: [SpannedTopLevel], acc: [EnumDef]) -> [EnumDef] do
  match defs do
    case [] -> return acc
    case SpannedTopLevel(node: TLEnum(def: ed), span: _) :: rest ->
      return collect_enum_defs_go(defs: rest, acc: ed :: acc)
    case _ :: rest ->
      return collect_enum_defs_go(defs: rest, acc: acc)
  end
end

/// Collect all enum definitions from top-level definitions.
export let collect_enum_defs = fn (defs: [SpannedTopLevel]) -> [EnumDef] do
  return list.reverse(xs: collect_enum_defs_go(defs: defs, acc: []))
end

// ─── Import extraction ────────────────────────────────────────────────────────

let extract_imports_go = fn (defs: [SpannedTopLevel], acc: [ImportDef]) -> [ImportDef] do
  match defs do
    case [] -> return acc
    case head :: rest ->
      // Avoid nested constructor pattern (nxc codegen discards inner tag checks).
      // Use shallow match + separate match on extracted node instead.
      match head do case SpannedTopLevel(node: node, span: _) ->
        match node do
          case TLImport(def: imp) ->
            return extract_imports_go(defs: rest, acc: imp :: acc)
          case _ ->
            return extract_imports_go(defs: rest, acc: acc)
        end
      end
  end
end

/// Extract all import definitions from a program's top-level.
export let extract_imports = fn (defs: [SpannedTopLevel]) -> [ImportDef] do
  return list.reverse(xs: extract_imports_go(defs: defs, acc: []))
end

// ─── Cycle detection ──────────────────────────────────────────────────────────

let has_path = fn (stack: [string], path: string) -> bool do
  match stack do
    case [] -> return false
    case p :: rest ->
      if p == path then return true
      else return has_path(stack: rest, path: path)
      end
  end
end

/// Check if importing a path would create a cycle.
export let would_cycle = fn (import_stack: [string], path: string) -> bool do
  return has_path(stack: import_stack, path: path)
end

// ─── Merge rename entries ─────────────────────────────────────────────────────

let merge_entries_go = fn (src: [RenameEntry], dst: [RenameEntry]) -> [RenameEntry] do
  match src do
    case [] -> return dst
    case entry :: rest ->
      return merge_entries_go(src: rest, dst: entry :: dst)
  end
end

/// Merge two rename entry lists (prepend src onto dst).
export let merge_rename_entries = fn (src: [RenameEntry], dst: [RenameEntry]) -> [RenameEntry] do
  return merge_entries_go(src: src, dst: dst)
end

// ─── Convenience re-exports for downstream use ────────────────────────────────

/// Apply a rename map to a name. Returns qualified name if found, original otherwise.
export let apply_rename = fn (name: string, entries: [RenameEntry]) -> string do
  return symtab.rename(name: name, entries: entries)
end

/// Build a single rename entry list from original -> qualified.
export let make_rename_entry = fn (original: string, qualified: string) -> [RenameEntry] do
  return symtab.rename_add(entries: [], original: original, qualified: qualified)
end
