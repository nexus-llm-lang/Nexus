/**
 * mir: HIR → MIR lowering.
 *
 * Owns:
 * - Expression / statement / pattern lowering from HIR to MIR
 * - Inject-scope inlining (compile-time effect, no runtime representation)
 * - For-loop → while-loop desugaring
 * - Lambda / handler expressions dropped to Unit (lifted during HIR build)
 * - MirCtx construction + threading; lower_port_call uses port.nx for detection
 *   but the call-emission happens here because it calls lower_call_args
 * - Handler-function lowering (lower_handler_functions)
 *
 * Does not own:
 * - MIR type definitions (see src/ir/mir_types.nx)
 * - Port-layout construction, port-call detection, return-type lookup,
 *   handler-port name inference (see src/ir/mir/port.nx)
 * - Generic reverse helpers (see src/common/mono_reverse.nx)
 */
import { MirPortHandlerNotFound } from "src/common/error.nx"
import { None } from "std:option"
import * as naming from "src/common/naming.nx"
import * as str from "std:str"
import * as list from "std:list"
import { Literal, TypeExpr } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"
import * as hir from "src/ir/hir_types.nx"
import { HirStmtKind, HirCallArg, HirParam, HirFunction, HirHandlerArm, HirMatchCase, HirPatternKind, HirPatternField, HirRecordPatField, HirPort, HirPortMethod, HirExternal, HirHandlerBinding, HirHandlerBindingEntry, HirProgram, HirNamedExpr, HirExpr, HirStmt, EagerBody, LazyBody } from "src/ir/hir_types.nx"
import { MirParam, MirExternal, MirFunction, MirCallArg, MirExpr, MirNamedExpr, MirStmt, MirMatchCase, MirPattern, MirPatternField, MirRecordPatField, MirProgram, NamePair, PortEntry, PortCallResult, PortCallFound, PortCallNotFound, MirCtx, MirExprResult, MirStmtsResult, MirCallArgsResult, MirExprListResult, MirNamedExprsResult, MirMatchCasesResult, LowerFunctionsResult, LowerFunctionResult } from "src/ir/mir_types.nx"
import { build_port_layouts, lookup_port, infer_handler_port_names, find_handler_by_port, reverse_lookup, lookup_ret_type, lookup_known_ret_type, detect_port_call } from "src/ir/mir/port.nx"

// ─── Cont-binder helpers ────────────────────────────────────────────────────

let ctx_cont_binders = fn (ctx: MirCtx) -> [string] do
  match ctx do | MirCtx(scope: _, port_layouts: _, handler_port_names: _, all_funcs: _, all_handlers: _, all_exts: _, closure_counter: _, lifted_funcs: _, cont_binders: cb) -> return cb end
end

let cb_has_any = fn (cb: [string]) -> bool do
  match cb do | [] -> return false | _ -> return true end
end

let list_has = fn (name: string, names: [string]) -> bool do
  match names do
    | [] -> return false
    | h :: rest ->
      if h == name then return true end
      return list_has(name, names: rest)
  end
end

// ─── Lookup helpers (list-based maps) ────────────────────────────────────────

let lookup = fn (key: string, pairs: [NamePair]) -> Option<string> throws { Exn } do
  match pairs do
    | [] -> return None
    | NamePair(key: k, value: v) :: rest ->
      if k == key then return Some(val: v)
      else return lookup(key, pairs: rest)
      end
  end
end

let insert_or_replace = fn (key: string, value: string, pairs: [NamePair]) -> [NamePair] throws { Exn } do
  return NamePair(key, value) :: remove_key(key, pairs)
end

/// Insert (key, value) only if `key` is not already present — user bindings
/// take precedence over compiler-intrinsic defaults.
let insert_if_absent = fn (key: string, value: string, pairs: [NamePair]) -> [NamePair] throws { Exn } do
  match lookup(key, pairs) do
    | Some(_) -> return pairs
    | None -> return NamePair(key, value) :: pairs
  end
end

let remove_key = fn (key: string, pairs: [NamePair]) -> [NamePair] throws { Exn } do
  return remove_key_go(key, pairs, acc: [])
end

let remove_key_go = fn (key: string, pairs: [NamePair], acc: [NamePair]) -> [NamePair] throws { Exn } do
  match pairs do
    | [] -> return rev_name_pairs(lst: acc, out: [])
    | NamePair(key: k, value: val) :: rest ->
      if k == key then return remove_key_go(key, pairs: rest, acc)
      else return remove_key_go(key, pairs: rest, acc: NamePair(key: k, value: val) :: acc)
      end
  end
end


// ─── Handler Mapping ────────────────────────────────────────────────────────

/// Build handler_binding_name → port_name mapping.
let build_handler_port_names = fn (bindings: [HirHandlerBindingEntry]) -> [NamePair] throws { Exn } do
  return build_handler_port_names_go(bindings, acc: [])
end

let build_handler_port_names_go = fn (bindings: [HirHandlerBindingEntry], acc: [NamePair]) -> [NamePair] throws { Exn } do
  match bindings do
    | [] -> return rev_name_pairs(lst: acc, out: [])
    | HirHandlerBindingEntry(name: bname, binding: HirHandlerBinding(port_name: pname, arms: _)) :: rest ->
      return build_handler_port_names_go(bindings: rest, acc: NamePair(key: bname, value: pname) :: acc)
  end
end

let arms_to_funcs = fn (arms: [HirHandlerArm]) -> [HirFunction] do
  match arms do
    | [] -> return []
    | HirHandlerArm(arm: f, cont_binder: _) :: rest -> return f :: arms_to_funcs(arms: rest)
  end
end

/// Build global port_name → handler_binding_name mapping (last handler wins).
let build_global_port_handlers = fn (handler_port_names: [NamePair]) -> [NamePair] throws { Exn } do
  return build_global_go(pairs: handler_port_names, accum: [])
end

let build_global_go = fn (pairs: [NamePair], accum: [NamePair]) -> [NamePair] throws { Exn } do
  match pairs do
    | [] -> return accum
    | NamePair(key: binding_name, value: port_name) :: rest ->
      let new_accum = insert_or_replace(key: port_name, value: binding_name, pairs: accum)
      return build_global_go(pairs: rest, accum: new_accum)
  end
end


// ─── Lower HIR → MIR ───────────────────────────────────────────────────────

export let lower_hir_to_mir = fn (hir: HirProgram) -> MirProgram throws { Exn } do
  let HirProgram(ports, functions: funcs, externals: exts, handler_bindings: hbs, enum_defs: _, _) = hir
  let port_layouts = build_port_layouts(ports)
  let handler_port_names = build_handler_port_names(bindings: hbs)
  // If handler_port_names is empty (ExprHandler matching failed in component model),
  // infer from function names + port methods.
  let inferred = infer_handler_port_names(funcs, ports)
  let effective_hpn = match handler_port_names do
    | [] -> inferred
    | _ -> append_name_pairs(a: handler_port_names, b: inferred)
  end
  let global_scope_base = build_global_port_handlers(handler_port_names: effective_hpn)
  // Add Console/Fs/Clock → system_handler ONLY if the user hasn't already
  // bound them. Previously used insert_or_replace, which overrode user
  // bindings silently — see nexus-9lp4.29. insert_if_absent preserves any
  // user-supplied handler for these standard ports while still providing the
  // implicit default so code like `Console.println("hi")` works without an
  // explicit `inject stdio.system_handler do ... end`.
  let global_scope = insert_if_absent(key: "Console", value: "stdio.system_handler",
    pairs: insert_if_absent(key: "Fs", value: "fs_mod.system_handler",
    pairs: insert_if_absent(key: "Clock", value: "clock_mod.system_handler",
    pairs: global_scope_base)))

  let ctx = MirCtx(
    scope: global_scope,
    port_layouts,
    handler_port_names: effective_hpn,
    all_funcs: funcs,
    all_handlers: hbs,
    all_exts: exts,
    closure_counter: 0,
    lifted_funcs: [],
    cont_binders: []
  )

  let mir_externals = lower_externals(exts)
  // Thread ctx through lowering so inline-lambda lifts accumulate across all
  // functions (and all handler functions), then append lifted __closure_* funcs.
  let funcs_r = lower_functions(functions: funcs, ctx)
  match funcs_r do | LowerFunctionsResult(ctx: ctx1, funcs: mir_funcs) ->
    let hfuncs_r = lower_handler_functions(bindings: hbs, ctx: ctx1)
    match hfuncs_r do | LowerFunctionsResult(ctx: ctx2, funcs: mir_handler_funcs) ->
      let MirCtx(scope: _, port_layouts: _, handler_port_names: _, all_funcs: _, all_handlers: _, all_exts: _, closure_counter: _, lifted_funcs: lifted, cont_binders: _) = ctx2
      let user_plus_handlers = concat_mir_funcs(a: mir_funcs, b: mir_handler_funcs)
      let all_mir_funcs = concat_mir_funcs(a: user_plus_handlers, b: lifted)
      return MirProgram(functions: all_mir_funcs, externals: mir_externals)
    end
  end
end

// ─── Lower Externals ────────────────────────────────────────────────────────

let lower_externals = fn (exts: [HirExternal]) -> [MirExternal] throws { Exn } do
  return lower_externals_go(exts, acc: [])
end

let lower_externals_go = fn (exts: [HirExternal], acc: [MirExternal]) -> [MirExternal] throws { Exn } do
  match exts do
    | [] -> return rev_mir_externals(lst: acc, out: [])
    | HirExternal(name: n, wasm_module: wm, wasm_name: wn, type_params: _, params: ps, ret_type: rt, throw_row: tr) :: rest ->
      let mir_params = lower_hir_params(params: ps)
      return lower_externals_go(exts: rest, acc: MirExternal(name: n, wasm_module: wm, wasm_name: wn,
                       params: mir_params, ret_type: rt, throw_row: tr) :: acc)
  end
end

let lower_hir_params = fn (params: [HirParam]) -> [MirParam] throws { Exn } do
  return lower_hir_params_go(params, acc: [])
end

let lower_hir_params_go = fn (params: [HirParam], acc: [MirParam]) -> [MirParam] throws { Exn } do
  match params do
    | [] -> return rev_mir_params(lst: acc, out: [])
    | HirParam(name: n, label: l, typ: t) :: rest ->
      return lower_hir_params_go(params: rest, acc: MirParam(label: l, name: n, typ: t) :: acc)
  end
end

// ─── Lower Functions ────────────────────────────────────────────────────────

let lower_functions = fn (functions: [HirFunction], ctx: MirCtx) -> LowerFunctionsResult throws { Exn } do
  return lower_functions_go(functions, ctx, acc: [])
end

let lower_functions_go = fn (functions: [HirFunction], ctx: MirCtx, acc: [MirFunction]) -> LowerFunctionsResult throws { Exn } do
  match functions do
    | [] -> return LowerFunctionsResult(ctx, funcs: rev_mir_funcs(lst: acc, out: []))
    | f :: rest ->
      match lower_function(func: f, ctx) do | LowerFunctionResult(ctx: ctx2, func: mir_f) ->
        return lower_functions_go(functions: rest, ctx: ctx2, acc: mir_f :: acc)
      end
  end
end

let lower_handler_functions = fn (bindings: [HirHandlerBindingEntry], ctx: MirCtx) -> LowerFunctionsResult throws { Exn } do
  return lower_handler_functions_go(bindings, ctx, acc: [])
end

let lower_handler_functions_go = fn (bindings: [HirHandlerBindingEntry], ctx: MirCtx, acc: [MirFunction]) -> LowerFunctionsResult throws { Exn } do
  match bindings do
    | [] -> return LowerFunctionsResult(ctx, funcs: rev_mir_funcs(lst: acc, out: []))
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, arms: arms)) :: rest ->
      // Lower each arm with its cont_binder (if any) installed in ctx so
      // that `force k` inside the arm body resolves to MirResume.
      match lower_arms_with_konts(arms, ctx) do | LowerFunctionsResult(ctx: ctx2, funcs: lowered) ->
        let new_acc = prepend_reversed(src: lowered, dst: acc)
        return lower_handler_functions_go(bindings: rest, ctx: ctx2, acc: new_acc)
      end
  end
end

let lower_arms_with_konts = fn (arms: [HirHandlerArm], ctx: MirCtx) -> LowerFunctionsResult throws { Exn } do
  return lower_arms_with_konts_go(arms, ctx, acc: [])
end

let lower_arms_with_konts_go = fn (arms: [HirHandlerArm], ctx: MirCtx, acc: [MirFunction]) -> LowerFunctionsResult throws { Exn } do
  match arms do
    | [] -> return LowerFunctionsResult(ctx, funcs: rev_mir_funcs(lst: acc, out: []))
    | HirHandlerArm(arm: f, cont_binder: kb) :: rest ->
      let arm_ctx = match kb do
        | Some(val: k) -> ctx_with_cont_binders(ctx, binders: [k])
        | None -> ctx
      end
      match lower_function(func: f, ctx: arm_ctx) do | LowerFunctionResult(ctx: ctx2, func: mf) ->
        let restored = ctx_with_cont_binders(ctx: ctx2, binders: ctx_cont_binders(ctx))
        return lower_arms_with_konts_go(arms: rest, ctx: restored, acc: mf :: acc)
      end
  end
end

let ctx_with_cont_binders = fn (ctx: MirCtx, binders: [string]) -> MirCtx do
  match ctx do | MirCtx(scope: sc, port_layouts: pl, handler_port_names: hpn, all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: cc, lifted_funcs: lf, cont_binders: _) ->
    return MirCtx(scope: sc, port_layouts: pl, handler_port_names: hpn, all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: cc, lifted_funcs: lf, cont_binders: binders)
  end
end

/// Push each element of `src` (in order) onto `dst`, reversing it. The outer
/// caller's final rev_mir_funcs restores original order.
let prepend_reversed = fn (src: [MirFunction], dst: [MirFunction]) -> [MirFunction] throws { Exn } do
  match src do
    | [] -> return dst
    | x :: rest -> return prepend_reversed(src: rest, dst: x :: dst)
  end
end

let lower_function = fn (func: HirFunction, ctx: MirCtx) -> LowerFunctionResult throws { Exn } do
  let HirFunction(name: n, type_params: _, params: ps, ret_type: rt, throw_row: _, body: hir_body, span: sp) = func
  let body = match hir_body do | EagerBody(stmts: s) -> s | LazyBody(_) -> [] end
  let mir_params = lower_hir_params(params: ps)
  match lower_stmts(stmts: body, ctx) do | MirStmtsResult(ctx: ctx2, stmts: mir_body) ->
    return LowerFunctionResult(ctx: ctx2, func: MirFunction(name: n, params: mir_params, ret_type: rt, body: mir_body, span: sp))
  end
end

// ─── Lower Statements ───────────────────────────────────────────────────────

let lower_stmts = fn (stmts: [HirStmt], ctx: MirCtx) -> MirStmtsResult throws { Exn } do
  return lower_stmts_go(stmts, ctx, acc: [])
end

let lower_stmts_go = fn (stmts: [HirStmt], ctx: MirCtx, acc: [MirStmt]) -> MirStmtsResult throws { Exn } do
  match stmts do
    | [] -> return MirStmtsResult(ctx, stmts: rev_mir_stmts(lst: acc, out: []))
    | HirStmt(node: s, span: _) :: rest ->
      match lower_stmt(stmt: s, ctx) do | MirStmtsResult(ctx: ctx2, stmts: lowered) ->
        let new_acc = prepend_stmts_reversed(src: lowered, dst: acc)
        return lower_stmts_go(stmts: rest, ctx: ctx2, acc: new_acc)
      end
  end
end

let prepend_stmts_reversed = fn (src: [MirStmt], dst: [MirStmt]) -> [MirStmt] throws { Exn } do
  match src do
    | [] -> return dst
    | x :: rest -> return prepend_stmts_reversed(src: rest, dst: x :: dst)
  end
end

/// Lower a statement. Inject/for desugar may produce multiple MIR stmts;
/// the ctx also carries forward any `__closure_*` lifts from lambdas inside.
let lower_stmt = fn (stmt: HirStmtKind, ctx: MirCtx) -> MirStmtsResult throws { Exn } do
  match stmt do
    | Let(name: n, typ: t, value: v) ->
      // HIR Let.typ is None when the user omits the annotation and typecheck
      // has not back-patched it — the HIR is not rewritten after typecheck.
      // LIR lowering recovers the real type via atom_type / semantic_vars
      // tables (see src/ir/lir/context.nx), so the TyUnit placeholder here
      // is only observed by passes that walk MirStmtLet without consulting
      // the atom table (e.g. dump utilities). Pipe work that depends on
      // accurate MIR types is blocked on propagating typecheck's subst into
      // HIR; tracked as nexus-9lp4.19.
      let mir_typ = match t do
        | Some(val: te) -> te
        | None -> TyUnit
      end
      match lower_expr(expr: v, ctx) do | MirExprResult(ctx: ctx2, expr: mir_val) ->
        return MirStmtsResult(ctx: ctx2, stmts: [MirStmtLet(name: n, typ: mir_typ, expr: mir_val)])
      end

    | Expr(expr: se) ->
      let HirExpr(node: e, span: _) = se
      match e do
        | For(var, start: s, end_expr: end_e, body: b) ->
          return desugar_for(var, start_expr: s, end_expr: end_e, body: b, ctx)
        | _ ->
          match lower_expr(expr: se, ctx) do | MirExprResult(ctx: ctx2, expr: mir_e) ->
            return MirStmtsResult(ctx: ctx2, stmts: [MirStmtExpr(expr: mir_e)])
          end
      end

    | Return(expr: e) ->
      match lower_expr(expr: e, ctx) do | MirExprResult(ctx: ctx2, expr: mir_e) ->
        return MirStmtsResult(ctx: ctx2, stmts: [MirStmtReturn(expr: mir_e)])
      end

    | Assign(target: t, value: v) ->
      match lower_expr(expr: t, ctx) do | MirExprResult(ctx: ctx2, expr: mir_t) ->
        match lower_expr(expr: v, ctx: ctx2) do | MirExprResult(ctx: ctx3, expr: mir_v) ->
          return MirStmtsResult(ctx: ctx3, stmts: [MirStmtAssign(target: mir_t, value: mir_v)])
        end
      end

    | Try(body: b, catch_param: cp, catch_body: cb) ->
      match lower_stmts(stmts: b, ctx) do | MirStmtsResult(ctx: ctx2, stmts: mir_b) ->
        match lower_stmts(stmts: cb, ctx: ctx2) do | MirStmtsResult(ctx: ctx3, stmts: mir_cb) ->
          return MirStmtsResult(ctx: ctx3, stmts: [MirStmtTry(body: mir_b, catch_param: cp, catch_body: mir_cb)])
        end
      end

    | Inject(handlers: hs, body: b) ->
      let MirCtx(scope, port_layouts: pl, handler_port_names: hpn, all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: cc, lifted_funcs: lf, cont_binders: cb) = ctx
      let new_scope = activate_handlers(handler_names: hs, handler_port_names: hpn, scope)
      let new_ctx = MirCtx(scope: new_scope, port_layouts: pl, handler_port_names: hpn,
                           all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: cc, lifted_funcs: lf, cont_binders: cb)
      // If any handler in this inject has any arm capturing a continuation,
      // route the body through a stack-switching resume frame: lift the body
      // to a fresh MirFunction and replace the inject site with a single
      // MirStmtInjectResume statement that codegen will expand to
      // ref.func + cont.new + resume + on-clauses.
      if any_handler_has_kont(handler_names: hs, bindings: ah) then
        match lift_inject_body(stmts: b, ctx: new_ctx) do | LiftInjectResult(ctx: ctx2, body_fn: bfn) ->
          let arm_fns = collect_with_kont_arm_fns(handler_names: hs, bindings: ah)
          let arm_tags = collect_with_kont_arm_tags(handler_names: hs, bindings: ah)
          let MirCtx(scope: _, port_layouts: pl2, handler_port_names: hpn2, all_funcs: af2, all_handlers: ah2, all_exts: ae2, closure_counter: cc2, lifted_funcs: lf2, cont_binders: cb2) = ctx2
          let restored = MirCtx(scope, port_layouts: pl2, handler_port_names: hpn2,
                                all_funcs: af2, all_handlers: ah2, all_exts: ae2, closure_counter: cc2, lifted_funcs: lf2, cont_binders: cb2)
          return MirStmtsResult(ctx: restored, stmts: [MirStmtInjectResume(body_fn: bfn, handler_arm_fns: arm_fns, handler_arm_tags: arm_tags)])
        end
      end
      // No with-kont arms: existing behaviour — inline body under injected scope.
      match lower_stmts(stmts: b, ctx: new_ctx) do | MirStmtsResult(ctx: ctx2, stmts: lowered) ->
        let MirCtx(scope: _, port_layouts: pl2, handler_port_names: hpn2, all_funcs: af2, all_handlers: ah2, all_exts: ae2, closure_counter: cc2, lifted_funcs: lf2, cont_binders: cb2) = ctx2
        let restored = MirCtx(scope, port_layouts: pl2, handler_port_names: hpn2,
                              all_funcs: af2, all_handlers: ah2, all_exts: ae2, closure_counter: cc2, lifted_funcs: lf2, cont_binders: cb2)
        return MirStmtsResult(ctx: restored, stmts: lowered)
      end
  end
end

type LiftInjectResult = LiftInjectResult(ctx: MirCtx, body_fn: string)

/// Lift an inject body to a fresh top-level MirFunction. Naming convention:
/// `__inject_<n>` shares the closure_counter so codegen's table-registration
/// machinery picks it up alongside `__closure_*` lifts.
let lift_inject_body = fn (stmts: [HirStmt], ctx: MirCtx) -> LiftInjectResult throws { Exn } do
  let MirCtx(scope: sc, port_layouts: pl, handler_port_names: hpn, all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: n, lifted_funcs: lf, cont_binders: cb) = ctx
  let lifted_name = "__inject_" ++ i64_to_str(n)
  let ctx_after_name = MirCtx(scope: sc, port_layouts: pl, handler_port_names: hpn,
                              all_funcs: af, all_handlers: ah, all_exts: ae,
                              closure_counter: n + 1, lifted_funcs: lf, cont_binders: cb)
  match lower_stmts(stmts, ctx: ctx_after_name) do | MirStmtsResult(ctx: ctx_body, stmts: mir_body) ->
    let MirCtx(scope: sc2, port_layouts: pl2, handler_port_names: hpn2, all_funcs: af2, all_handlers: ah2, all_exts: ae2, closure_counter: n2, lifted_funcs: lf2, cont_binders: cb2) = ctx_body
    let lifted_fn = MirFunction(name: lifted_name, params: [], ret_type: TyUnit,
                                body: mir_body, span: Span(offset: 0, line: 0, col: 0))
    let new_lf = append_mir_funcs(a: lf2, b: [lifted_fn])
    let ctx_final = MirCtx(scope: sc2, port_layouts: pl2, handler_port_names: hpn2,
                           all_funcs: af2, all_handlers: ah2, all_exts: ae2,
                           closure_counter: n2, lifted_funcs: new_lf, cont_binders: cb2)
    return LiftInjectResult(ctx: ctx_final, body_fn: lifted_name)
  end
end

let any_handler_has_kont = fn (handler_names: [string], bindings: [HirHandlerBindingEntry]) -> bool throws { Exn } do
  match handler_names do
    | [] -> return false
    | h :: rest ->
      if handler_has_any_kont(handler_name: h, bindings) then return true end
      return any_handler_has_kont(handler_names: rest, bindings)
  end
end

let handler_has_any_kont = fn (handler_name: string, bindings: [HirHandlerBindingEntry]) -> bool throws { Exn } do
  match bindings do
    | [] -> return false
    | HirHandlerBindingEntry(name: bn, binding: HirHandlerBinding(port_name: _, arms)) :: rest ->
      if bn == handler_name then return arms_have_any_kont(arms) end
      return handler_has_any_kont(handler_name, bindings: rest)
  end
end

let arms_have_any_kont = fn (arms: [HirHandlerArm]) -> bool throws { Exn } do
  match arms do
    | [] -> return false
    | HirHandlerArm(arm: _, cont_binder: Some(_)) :: _ -> return true
    | _ :: rest -> return arms_have_any_kont(arms: rest)
  end
end

let collect_with_kont_arm_fns = fn (handler_names: [string], bindings: [HirHandlerBindingEntry]) -> [string] throws { Exn } do
  return collect_with_kont_arm_fns_go(handler_names, bindings, acc: [])
end

let collect_with_kont_arm_fns_go = fn (handler_names: [string], bindings: [HirHandlerBindingEntry], acc: [string]) -> [string] throws { Exn } do
  match handler_names do
    | [] -> return acc
    | h :: rest ->
      let new_acc = arm_fns_for_handler(handler_name: h, bindings, acc)
      return collect_with_kont_arm_fns_go(handler_names: rest, bindings, acc: new_acc)
  end
end

let arm_fns_for_handler = fn (handler_name: string, bindings: [HirHandlerBindingEntry], acc: [string]) -> [string] throws { Exn } do
  match bindings do
    | [] -> return acc
    | HirHandlerBindingEntry(name: bn, binding: HirHandlerBinding(port_name: _, arms)) :: rest ->
      if bn == handler_name then return arm_fns_collect(arms, acc) end
      return arm_fns_for_handler(handler_name, bindings: rest, acc)
  end
end

let arm_fns_collect = fn (arms: [HirHandlerArm], acc: [string]) -> [string] throws { Exn } do
  match arms do
    | [] -> return acc
    | HirHandlerArm(arm: HirFunction(name: fname, type_params: _, params: _, ret_type: _, _), cont_binder: Some(_)) :: rest ->
      return arm_fns_collect(arms: rest, acc: fname :: acc)
    | _ :: rest -> return arm_fns_collect(arms: rest, acc)
  end
end

/// Parallel collector to `collect_with_kont_arm_fns`: returns the per-arm
/// suspend-tag name (`<port>::<method>`), in lockstep order with the arm-fn
/// list, so the InjectResume codegen can wire each `on tag → label` clause
/// directly to its matching arm without a runtime dispatch table.
let collect_with_kont_arm_tags = fn (handler_names: [string], bindings: [HirHandlerBindingEntry]) -> [string] throws { Exn } do
  return collect_with_kont_arm_tags_go(handler_names, bindings, acc: [])
end

let collect_with_kont_arm_tags_go = fn (handler_names: [string], bindings: [HirHandlerBindingEntry], acc: [string]) -> [string] throws { Exn } do
  match handler_names do
    | [] -> return acc
    | h :: rest ->
      let new_acc = arm_tags_for_handler(handler_name: h, bindings, acc)
      return collect_with_kont_arm_tags_go(handler_names: rest, bindings, acc: new_acc)
  end
end

let arm_tags_for_handler = fn (handler_name: string, bindings: [HirHandlerBindingEntry], acc: [string]) -> [string] throws { Exn } do
  match bindings do
    | [] -> return acc
    | HirHandlerBindingEntry(name: bn, binding: HirHandlerBinding(port_name: pn, arms)) :: rest ->
      if bn == handler_name then return arm_tags_collect(port_name: pn, arms, acc) end
      return arm_tags_for_handler(handler_name, bindings: rest, acc)
  end
end

let arm_tags_collect = fn (port_name: string, arms: [HirHandlerArm], acc: [string]) -> [string] throws { Exn } do
  match arms do
    | [] -> return acc
    | HirHandlerArm(arm: HirFunction(name: fname, type_params: _, params: _, ret_type: _, _), cont_binder: Some(_)) :: rest ->
      let method_name = strip_handler_arm_prefix(fname)
      let tag = port_name ++ "::" ++ method_name
      return arm_tags_collect(port_name, arms: rest, acc: tag :: acc)
    | _ :: rest -> return arm_tags_collect(port_name, arms: rest, acc)
  end
end

/// Recover the source-level method name from a synthesised handler arm
/// function name. `synthesize_handler_arms` (hir.nx) names arms via
/// `naming.handler_func_name(handler_name, method_name)`, which produces
/// `__handler_<binding_module>#<binding_name>_<method>` — the method tail
/// after the last underscore.
let strip_handler_arm_prefix = fn (fname: string) -> string throws { Exn } do
  let last_underscore = last_underscore_idx(s: fname, idx: str.length(s: fname) - 1)
  if last_underscore < 0 then return fname end
  let after = last_underscore + 1
  return str.substring(s: fname, start: after, len: str.length(s: fname) - after)
end

let last_underscore_idx = fn (s: string, idx: i64) -> i64 throws { Exn } do
  if idx < 0 then return -1 end
  if str.char_code(s, idx) == 95 then return idx end
  return last_underscore_idx(s, idx: idx - 1)
end

let activate_handlers = fn (handler_names: [string], handler_port_names: [NamePair], scope: [NamePair]) -> [NamePair] throws { Exn } do
  match handler_names do
    | [] -> return scope
    | hname :: rest ->
      let port_opt = lookup(key: hname, pairs: handler_port_names)
      let new_scope = match port_opt do
        | Some(val: pname) -> insert_or_replace(key: pname, value: hname, pairs: scope)
        | None -> scope
      end
      return activate_handlers(handler_names: rest, handler_port_names, scope: new_scope)
  end
end

// ─── For-loop Desugaring ────────────────────────────────────────────────────

let desugar_for = fn (var: string, start_expr: HirExpr, end_expr: HirExpr, body: [HirStmt], ctx: MirCtx) -> MirStmtsResult throws { Exn } do
  let end_name = "__for_end_" ++ var
  match lower_expr(expr: start_expr, ctx) do | MirExprResult(ctx: ctx1, expr: mir_start) ->
    match lower_expr(expr: end_expr, ctx: ctx1) do | MirExprResult(ctx: ctx2, expr: mir_end) ->
      match lower_stmts(stmts: body, ctx: ctx2) do | MirStmtsResult(ctx: ctx3, stmts: mir_body) ->
        let incr = MirStmtAssign(
          target: MirVariable(name: var),
          value: MirBinaryOp(left: MirVariable(name: var), op: OpAdd, right: MirLiteral(lit: LitInt(val: 1)))
        )
        let full_body = concat_mir_stmts(a: mir_body, b: [incr])
        let stmts = [
          MirStmtLet(name: var, typ: TyI64, expr: mir_start),
          MirStmtLet(name: end_name, typ: TyI64, expr: mir_end),
          MirStmtExpr(expr: MirWhile(
            cond: MirBinaryOp(left: MirVariable(name: var), op: OpLt, right: MirVariable(name: end_name)),
            body: full_body
          ))
        ]
        return MirStmtsResult(ctx: ctx3, stmts)
      end
    end
  end
end

// ─── Lower Expressions ─────────────────────────────────────────────────────

let lower_expr = fn (expr: HirExpr, ctx: MirCtx) -> MirExprResult throws { Exn } do
  let HirExpr(node, span: _) = expr
  match node do
    | Literal(lit: l) -> return MirExprResult(ctx, expr: MirLiteral(lit: l))
    | Variable(name: n, sigil: _) -> return MirExprResult(ctx, expr: MirVariable(name: n))
    | BinOp(left: l, op, right: r) ->
      match lower_expr(expr: l, ctx) do | MirExprResult(ctx: ctx1, expr: le) ->
        match lower_expr(expr: r, ctx: ctx1) do | MirExprResult(ctx: ctx2, expr: re) ->
          return MirExprResult(ctx: ctx2, expr: MirBinaryOp(left: le, op, right: re))
        end
      end
    | UnOp(op, operand: o) ->
      match lower_expr(expr: o, ctx) do | MirExprResult(ctx: ctx1, expr: oe) ->
        // Desugar to BinaryOp at MIR boundary so codegen / LIR opt stay
        // unchanged. For OpNeg / OpFNeg the lir_opt binary fold absorbs
        // the synthetic zero literal when operand is a constant.
        let lowered = match op do
          | OpNeg -> MirBinaryOp(left: MirLiteral(lit: LitInt(val: 0)), op: OpSub, right: oe)
          | OpFNeg -> MirBinaryOp(left: MirLiteral(lit: LitFloat(val: "0.0")), op: OpFSub, right: oe)
          | OpNot -> MirBinaryOp(left: oe, op: OpEq, right: MirLiteral(lit: LitBool(val: false)))
        end
        return MirExprResult(ctx: ctx1, expr: lowered)
      end
    | Borrow(name: n, sigil: _) -> return MirExprResult(ctx, expr: MirBorrow(name: n))
    | Call(func: f, args) ->
      let MirCtx(scope: _, port_layouts: pl, handler_port_names: _, all_funcs: _, all_handlers: _, all_exts: _, closure_counter: _, lifted_funcs: _, cont_binders: _) = ctx
      match detect_port_call(func: f, port_layouts: pl) do
        | PortCallFound(port_name: pname, method_name: mname) ->
          return lower_port_call(port_name: pname, method_name: mname, args, ctx)
        | PortCallNotFound ->
          match lower_call_args(args, ctx) do | MirCallArgsResult(ctx: ctx1, args: mir_args) ->
            match lookup_known_ret_type(name: f, ctx: ctx1) do
              | Some(val: ret_type) ->
                return MirExprResult(ctx: ctx1, expr: MirCall(func: f, args: mir_args, ret_type))
              | None ->
                // f is a local / parameter holding a closure. LIR recovers
                // the real return type from semantic_vars.
                return MirExprResult(ctx: ctx1, expr: MirCallClosure(closure: MirVariable(name: f), args: mir_args, ret_type: TyI64))
            end
          end
      end
    | Ctor(variant: v, args) ->
      match lower_expr_list(exprs: args, ctx) do | MirExprListResult(ctx: ctx1, exprs: mir_args) ->
        return MirExprResult(ctx: ctx1, expr: MirConstructor(name: v, args: mir_args))
      end
    | Record(fields: fs) ->
      match lower_named_exprs(exprs: fs, ctx) do | MirNamedExprsResult(ctx: ctx1, exprs: mir_fs) ->
        return MirExprResult(ctx: ctx1, expr: MirRecord(fields: mir_fs))
      end
    | Array(elems: es) ->
      match lower_expr_list(exprs: es, ctx) do | MirExprListResult(ctx: ctx1, exprs: mir_es) ->
        return MirExprResult(ctx: ctx1, expr: MirArray(elems: mir_es))
      end
    | Index(target: t, index: i) ->
      match lower_expr(expr: t, ctx) do | MirExprResult(ctx: ctx1, expr: mir_t) ->
        match lower_expr(expr: i, ctx: ctx1) do | MirExprResult(ctx: ctx2, expr: mir_i) ->
          return MirExprResult(ctx: ctx2, expr: MirIndex(target: mir_t, index: mir_i))
        end
      end
    | FieldAccess(target: t, field: f) ->
      match lower_expr(expr: t, ctx) do | MirExprResult(ctx: ctx1, expr: mir_t) ->
        return MirExprResult(ctx: ctx1, expr: MirFieldAccess(target: mir_t, field: f))
      end
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      match lower_expr(expr: c, ctx) do | MirExprResult(ctx: ctx1, expr: mir_cond) ->
        match lower_stmts(stmts: tb, ctx: ctx1) do | MirStmtsResult(ctx: ctx2, stmts: mir_then) ->
          match eb do
            | Some(val: stmts) ->
              match lower_stmts(stmts, ctx: ctx2) do | MirStmtsResult(ctx: ctx3, stmts: mir_else_body) ->
                return MirExprResult(ctx: ctx3, expr: MirIf(cond: mir_cond, then_body: mir_then, else_body: Some(val: mir_else_body)))
              end
            | None ->
              return MirExprResult(ctx: ctx2, expr: MirIf(cond: mir_cond, then_body: mir_then, else_body: None))
          end
        end
      end
    | Match(target: t, cases: cs) ->
      match lower_expr(expr: t, ctx) do | MirExprResult(ctx: ctx1, expr: mir_target) ->
        match lower_match_cases(cases: cs, ctx: ctx1) do | MirMatchCasesResult(ctx: ctx2, cases: mir_cases) ->
          return MirExprResult(ctx: ctx2, expr: MirMatch(target: mir_target, cases: mir_cases))
        end
      end
    | While(cond: c, body: b) ->
      match lower_expr(expr: c, ctx) do | MirExprResult(ctx: ctx1, expr: mir_cond) ->
        match lower_stmts(stmts: b, ctx: ctx1) do | MirStmtsResult(ctx: ctx2, stmts: mir_body) ->
          return MirExprResult(ctx: ctx2, expr: MirWhile(cond: mir_cond, body: mir_body))
        end
      end
    | For(var, start: _, end_expr: _, body: b) ->
      // For in expression position — desugar to while. (Start/end already
      // lowered and bound via Let at statement position for top-level fors;
      // this fallback handles for-in-expr by assuming end_name already exists.)
      let end_name = "__for_end_" ++ var
      match lower_stmts(stmts: b, ctx) do | MirStmtsResult(ctx: ctx1, stmts: mir_body) ->
        let incr = MirStmtAssign(
          target: MirVariable(name: var),
          value: MirBinaryOp(left: MirVariable(name: var), op: OpAdd, right: MirLiteral(lit: LitInt(val: 1)))
        )
        return MirExprResult(ctx: ctx1, expr: MirWhile(
          cond: MirBinaryOp(left: MirVariable(name: var), op: OpLt, right: MirVariable(name: end_name)),
          body: concat_mir_stmts(a: mir_body, b: [incr])
        ))
      end
    | Lambda(type_params: _, params: lps, ret_type: lret, body: lbody) ->
      return lift_lambda(params: lps, ret_type: lret, body: lbody, span: expr, ctx)
    | Raise(expr: e) ->
      match lower_expr(expr: e, ctx) do | MirExprResult(ctx: ctx1, expr: mir_e) ->
        return MirExprResult(ctx: ctx1, expr: MirRaise(expr: mir_e))
      end
    | Force(expr: e) ->
      // Force on a cont_binder name in the enclosing arm scope lowers to
      // MirResume — codegen emits op_resume to transfer control back to the
      // suspended caller. Other Force forms remain regular MirForce (lazy
      // thunk invocation).
      let HirExpr(node: inner_node, span: _) = e
      match inner_node do
        | Variable(name: vn, sigil: _) ->
          // PROBE: emit Resume if cont_binders is non-empty (any cont binder set).
          let cb = ctx_cont_binders(ctx)
          if cb_has_any(cb) then
            return MirExprResult(ctx,
              expr: MirResume(cont_var: vn, value: MirLiteral(lit: LitUnit), ret_type: TyUnit))
          end
          match lower_expr(expr: e, ctx) do | MirExprResult(ctx: ctx1, expr: mir_e) ->
            return MirExprResult(ctx: ctx1, expr: MirForce(expr: mir_e))
          end
        | _ ->
          match lower_expr(expr: e, ctx) do | MirExprResult(ctx: ctx1, expr: mir_e) ->
            return MirExprResult(ctx: ctx1, expr: MirForce(expr: mir_e))
          end
      end
    | Thunk(body: b) ->
      let HirExpr(node: _, span: sp) = expr
      return lift_lambda(
        params: [],
        ret_type: TyI64,
        body: [HirStmt(node: Return(expr: b), span: sp)],
        span: expr,
        ctx)
    | ExternalRef(symbol: sym, type_params: _, arg_names: _, typ: _) ->
      return MirExprResult(ctx, expr: MirVariable(name: sym))
    | Handler(_) ->
      return MirExprResult(ctx, expr: MirLiteral(lit: LitUnit))
  end
end

// ─── Port Call Resolution ───────────────────────────────────────────────────

let lower_port_call = fn (port_name: string, method_name: string, args: [HirCallArg], ctx: MirCtx) -> MirExprResult throws { Exn } do
  let MirCtx(scope, port_layouts: _, handler_port_names: hpn, all_funcs: _, all_handlers: all_hbs, all_exts: _, closure_counter: _, lifted_funcs: _, cont_binders: _) = ctx
  let handler_name = match lookup(key: port_name, pairs: scope) do
    | Some(val: h) -> h
    | None ->
      match reverse_lookup(value: port_name, pairs: hpn) do
        | Some(val: bname) -> bname
        | None ->
          match find_handler_by_port(port_name, bindings: all_hbs) do
            | Some(val: bname2) -> bname2
            | None -> raise MirPortHandlerNotFound(port_name, method_name, span: None)
          end
      end
  end
  let func_name = naming.handler_func_name(handler_name, method_name)
  let ret_type = lookup_ret_type(name: func_name, ctx)
  match lower_call_args(args, ctx) do | MirCallArgsResult(ctx: ctx1, args: mir_args) ->
    match arm_cont_binder(handler_name, method_name, bindings: all_hbs) do
      | Some(_) ->
        let tag = port_name ++ "::" ++ method_name
        let payload = match mir_args do
          | MirCallArg(label: _, value: v) :: _ -> v
          | [] -> MirLiteral(lit: LitUnit)
        end
        return MirExprResult(ctx: ctx1,
          expr: MirSuspend(tag_name: tag, payload, ret_type))
      | None ->
        return MirExprResult(ctx: ctx1, expr: MirCall(func: func_name, args: mir_args, ret_type))
    end
  end
end

/// Find the arm matching `method_name` inside the handler binding named
/// `handler_name`, and return its cont_binder (Some(k) for `with @k`,
/// None for plain arms / unknown binding).
let arm_cont_binder = fn (handler_name: string, method_name: string, bindings: [HirHandlerBindingEntry]) -> Option<string> throws { Exn } do
  match bindings do
    | [] -> return None
    | HirHandlerBindingEntry(name: bn, binding: HirHandlerBinding(port_name: _, arms)) :: rest ->
      if bn == handler_name then
        let synth_name = naming.handler_func_name(handler_name, method_name)
        return arm_cont_binder_in_arms(synth_name, arms)
      end
      return arm_cont_binder(handler_name, method_name, bindings: rest)
  end
end

let arm_cont_binder_in_arms = fn (synth_name: string, arms: [HirHandlerArm]) -> Option<string> throws { Exn } do
  match arms do
    | [] -> return None
    | HirHandlerArm(arm: HirFunction(name: fname, type_params: _, params: _, ret_type: _, _), cont_binder: kb) :: rest ->
      if fname == synth_name then return kb end
      return arm_cont_binder_in_arms(synth_name, arms: rest)
  end
end

/// Infer handler_binding_name → port_name from function names and port list.
/// Scans for functions named __handler_<binding>_<method> and matches against port methods.

let append_name_pairs = fn (a: [NamePair], b: [NamePair]) -> [NamePair] throws { Exn } do
  match a do
    | [] -> return b
    | h :: t -> return h :: append_name_pairs(a: t, b)
  end
end


// ─── Lower Arguments/Patterns/Cases ─────────────────────────────────────────

let lower_call_args = fn (args: [HirCallArg], ctx: MirCtx) -> MirCallArgsResult throws { Exn } do
  return lower_call_args_go(args, ctx, acc: [])
end

let lower_call_args_go = fn (args: [HirCallArg], ctx: MirCtx, acc: [MirCallArg]) -> MirCallArgsResult throws { Exn } do
  match args do
    | [] -> return MirCallArgsResult(ctx, args: rev_mir_call_args(lst: acc, out: []))
    | HirCallArg(label: l, value: v) :: rest ->
      match lower_expr(expr: v, ctx) do | MirExprResult(ctx: ctx1, expr: mir_v) ->
        return lower_call_args_go(args: rest, ctx: ctx1, acc: MirCallArg(label: l, value: mir_v) :: acc)
      end
  end
end

let lower_expr_list = fn (exprs: [HirExpr], ctx: MirCtx) -> MirExprListResult throws { Exn } do
  return lower_expr_list_go(exprs, ctx, acc: [])
end

let lower_expr_list_go = fn (exprs: [HirExpr], ctx: MirCtx, acc: [MirExpr]) -> MirExprListResult throws { Exn } do
  match exprs do
    | [] -> return MirExprListResult(ctx, exprs: rev_mir_exprs(lst: acc, out: []))
    | e :: rest ->
      match lower_expr(expr: e, ctx) do | MirExprResult(ctx: ctx1, expr: mir_e) ->
        return lower_expr_list_go(exprs: rest, ctx: ctx1, acc: mir_e :: acc)
      end
  end
end

let lower_named_exprs = fn (exprs: [HirNamedExpr], ctx: MirCtx) -> MirNamedExprsResult throws { Exn } do
  return lower_named_exprs_go(exprs, ctx, acc: [])
end

let lower_named_exprs_go = fn (exprs: [HirNamedExpr], ctx: MirCtx, acc: [MirNamedExpr]) -> MirNamedExprsResult throws { Exn } do
  match exprs do
    | [] -> return MirNamedExprsResult(ctx, exprs: rev_mir_named_exprs(lst: acc, out: []))
    | HirNamedExpr(name: n, value: v) :: rest ->
      match lower_expr(expr: v, ctx) do | MirExprResult(ctx: ctx1, expr: mir_v) ->
        return lower_named_exprs_go(exprs: rest, ctx: ctx1, acc: MirNamedExpr(name: n, value: mir_v) :: acc)
      end
  end
end

let lower_match_cases = fn (cases: [HirMatchCase], ctx: MirCtx) -> MirMatchCasesResult throws { Exn } do
  return lower_match_cases_go(cases, ctx, acc: [])
end

let lower_match_cases_go = fn (cases: [HirMatchCase], ctx: MirCtx, acc: [MirMatchCase]) -> MirMatchCasesResult throws { Exn } do
  match cases do
    | [] -> return MirMatchCasesResult(ctx, cases: rev_mir_match_cases(lst: acc, out: []))
    | HirMatchCase(pattern: p, body: b) :: rest ->
      match lower_stmts(stmts: b, ctx) do | MirStmtsResult(ctx: ctx1, stmts: mir_body) ->
        let case_mir = MirMatchCase(pattern: lower_pattern(pat: p), body: mir_body)
        return lower_match_cases_go(cases: rest, ctx: ctx1, acc: case_mir :: acc)
      end
  end
end

// ─── Lambda Lifting ─────────────────────────────────────────────────────────

/// Lift an inline `fn (...)` expression to a top-level `__closure_<N>` MIR
/// function. The lifted function receives `__env: i64` as its first parameter
/// (prepended before the original params) and opens the body with one
/// `let <cap_i> = MirEnvLoad("__env", i)` per captured free variable. The
/// callsite is replaced with `MirMakeClosure(func_name, captures)` so the
/// existing LIR/codegen closure machinery (`__closure_` prefix auto-registers
/// into the WASM closure table) picks it up.
let lift_lambda = fn (params: [HirParam], ret_type: TypeExpr, body: [HirStmt], span: HirExpr, ctx: MirCtx) -> MirExprResult throws { Exn } do
  let MirCtx(scope: sc, port_layouts: pl, handler_port_names: hpn, all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: n, lifted_funcs: lf, cont_binders: cb) = ctx
  let lifted_name = "__closure_" ++ i64_to_str(n)
  let ctx_after_name = MirCtx(scope: sc, port_layouts: pl, handler_port_names: hpn,
                              all_funcs: af, all_handlers: ah, all_exts: ae,
                              closure_counter: n + 1, lifted_funcs: lf, cont_binders: cb)

  // Free variables: referenced in body but not bound by params or known at
  // top level (functions, externals, handler methods).
  let param_names = param_names_of(params)
  let known = build_known_names(ctx: ctx_after_name)
  let captures = collect_hir_free_vars(body, params: param_names, known)

  // Lower the original body once; capture names inside resolve to locals
  // bound by the env-load preamble below.
  match lower_stmts(stmts: body, ctx: ctx_after_name) do | MirStmtsResult(ctx: ctx_body, stmts: mir_body) ->
    // Build the env-load preamble, then prepend to lowered body.
    let preamble = build_env_load_preamble(captures, index: 0)
    let full_body = concat_mir_stmts(a: preamble, b: mir_body)

    // Params: [__env: i64, *orig_params_with_closure_types]. Arrow types in
    // the original `params` must be swapped to TyI64 so WASM signatures line
    // up — captures and closure args are all passed as i64 closure pointers.
    let env_param = MirParam(label: "__env", name: "__env", typ: TyI64)
    let orig_params = lower_lambda_params(params)
    let all_params = env_param :: orig_params
    let HirExpr(node: _, span: sp) = span
    let lifted_fn = MirFunction(name: lifted_name, params: all_params,
                                ret_type: lower_lambda_ret_type(t: ret_type),
                                body: full_body, span: sp)

    // Append lifted fn to ctx.lifted_funcs (preserves creation order so
    // nested lambdas are emitted outer-last — matches Rust side).
    let MirCtx(scope: sc2, port_layouts: pl2, handler_port_names: hpn2, all_funcs: af2, all_handlers: ah2, all_exts: ae2, closure_counter: n2, lifted_funcs: lf2, cont_binders: cb2) = ctx_body
    let new_lf = append_mir_funcs(a: lf2, b: [lifted_fn])
    let ctx_final = MirCtx(scope: sc2, port_layouts: pl2, handler_port_names: hpn2,
                           all_funcs: af2, all_handlers: ah2, all_exts: ae2,
                           closure_counter: n2, lifted_funcs: new_lf, cont_binders: cb2)

    let capture_exprs = captures_to_mir_exprs(caps: captures, acc: [])
    return MirExprResult(ctx: ctx_final, expr: MirMakeClosure(func_name: lifted_name, captures: capture_exprs))
  end
end

/// Coerce arrow-typed lambda params to i64 (closure pointer). Non-arrow
/// param types (i64, string, records) pass through unchanged.
let lower_lambda_params = fn (params: [HirParam]) -> [MirParam] throws { Exn } do
  return lower_lambda_params_go(params, acc: [])
end

let lower_lambda_params_go = fn (params: [HirParam], acc: [MirParam]) -> [MirParam] throws { Exn } do
  match params do
    | [] -> return rev_mir_params(lst: acc, out: [])
    | HirParam(name: n, label: l, typ: t) :: rest ->
      return lower_lambda_params_go(params: rest, acc: MirParam(label: l, name: n, typ: coerce_arrow_to_i64(t)) :: acc)
  end
end

/// If the lambda's return type is an arrow, coerce to i64 for closure return.
let lower_lambda_ret_type = fn (t: TypeExpr) -> TypeExpr throws { Exn } do
  return coerce_arrow_to_i64(t)
end

let coerce_arrow_to_i64 = fn (t: TypeExpr) -> TypeExpr throws { Exn } do
  match t do
    | TyArrow(_) -> return TyI64
    | _ -> return t
  end
end

/// Emit `let <cap_i> = MirEnvLoad("__env", i)` for each capture in order,
/// starting at `index`. Captures are loaded as i64; a later sigil-aware
/// pass (not yet implemented) may refine their semantic types.
let build_env_load_preamble = fn (captures: [string], index: i64) -> [MirStmt] throws { Exn } do
  match captures do
    | [] -> return []
    | capture :: rest ->
      let stmt = MirStmtLet(name: capture, typ: TyI64, expr: MirEnvLoad(env_var: "__env", index))
      return stmt :: build_env_load_preamble(captures: rest, index: index + 1)
  end
end

let captures_to_mir_exprs = fn (caps: [string], acc: [MirExpr]) -> [MirExpr] throws { Exn } do
  match caps do
    | [] -> return rev_mir_exprs(lst: acc, out: [])
    | c :: rest -> return captures_to_mir_exprs(caps: rest, acc: MirVariable(name: c) :: acc)
  end
end

let param_names_of = fn (params: [HirParam]) -> [string] throws { Exn } do
  return param_names_of_go(params, acc: [])
end

let param_names_of_go = fn (params: [HirParam], acc: [string]) -> [string] throws { Exn } do
  match params do
    | [] -> return rev_strings(lst: acc, out: [])
    | HirParam(name: n, label: _, typ: _) :: rest -> return param_names_of_go(params: rest, acc: n :: acc)
  end
end

/// Names that are statically resolvable at the lambda's callsite and must
/// NOT be treated as free variables: top-level function names, externals,
/// and handler-method names.
let build_known_names = fn (ctx: MirCtx) -> [string] throws { Exn } do
  let MirCtx(scope: _, port_layouts: _, handler_port_names: _, all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: _, lifted_funcs: _, cont_binders: _) = ctx
  let from_funcs = fn_names_of(funcs: af, acc: [])
  let from_exts = ext_names_of(exts: ae, acc: [])
  let from_handlers = handler_fn_names_of(bindings: ah, acc: [])
  let a = concat_strings(a: from_funcs, b: from_exts)
  return concat_strings(a, b: from_handlers)
end

let fn_names_of = fn (funcs: [HirFunction], acc: [string]) -> [string] throws { Exn } do
  match funcs do
    | [] -> return rev_strings(lst: acc, out: [])
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, _) :: rest ->
      return fn_names_of(funcs: rest, acc: n :: acc)
  end
end

let ext_names_of = fn (exts: [HirExternal], acc: [string]) -> [string] throws { Exn } do
  match exts do
    | [] -> return rev_strings(lst: acc, out: [])
    | HirExternal(name: n, wasm_module: _, wasm_name: _, type_params: _, params: _, ret_type: _, throw_row: _) :: rest ->
      return ext_names_of(exts: rest, acc: n :: acc)
  end
end

let handler_fn_names_of = fn (bindings: [HirHandlerBindingEntry], acc: [string]) -> [string] throws { Exn } do
  match bindings do
    | [] -> return rev_strings(lst: acc, out: [])
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, arms: arms)) :: rest ->
      return handler_fn_names_of(bindings: rest, acc: prepend_fn_names(funcs: arms_to_funcs(arms), acc))
  end
end

let prepend_fn_names = fn (funcs: [HirFunction], acc: [string]) -> [string] throws { Exn } do
  match funcs do
    | [] -> return acc
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, _) :: rest ->
      return prepend_fn_names(funcs: rest, acc: n :: acc)
  end
end

let concat_strings = fn (a: [string], b: [string]) -> [string] throws { Exn } do
  match a do
    | [] -> return b
    | x :: rest -> return x :: concat_strings(a: rest, b)
  end
end

// ─── Free-Variable Collection (HIR walk) ─────────────────────────────────────

/// Walk HIR stmts, returning the names referenced but not locally bound
/// and not in `known` (top-level functions, externals, handler methods).
/// Preserves first-reference order and deduplicates.
let collect_hir_free_vars = fn (body: [HirStmt], params: [string], known: [string]) -> [string] throws { Exn } do
  let defined = params
  let seen = []
  let refs = []
  match walk_stmts(stmts: body, defined, known, seen, refs) do
    | WalkResult(defined: _, seen: _, refs: r) -> return rev_strings(lst: r, out: [])
  end
end

/// Accumulator threaded through the HIR free-var walk.
type WalkResult = WalkResult(defined: [string], seen: [string], refs: [string])

let walk_stmts = fn (stmts: [HirStmt], defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult throws { Exn } do
  match stmts do
    | [] -> return WalkResult(defined, seen, refs)
    | HirStmt(node: s, span: _) :: rest ->
      match walk_stmt(stmt: s, defined, known, seen, refs) do
        | WalkResult(defined: d2, seen: s2, refs: r2) ->
          return walk_stmts(stmts: rest, defined: d2, known, seen: s2, refs: r2)
      end
  end
end

let walk_stmt = fn (stmt: HirStmtKind, defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult throws { Exn } do
  match stmt do
    | Let(name: n, typ: _, value: v) ->
      match walk_expr(expr: v, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s2, refs: r2) ->
          return WalkResult(defined: n :: defined, seen: s2, refs: r2)
      end
    | Expr(expr: e) ->
      return walk_expr(expr: e, defined, known, seen, refs)
    | Return(expr: e) ->
      return walk_expr(expr: e, defined, known, seen, refs)
    | Assign(target: t, value: v) ->
      match walk_expr(expr: t, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_expr(expr: v, defined, known, seen: s1, refs: r1)
      end
    | Try(body: b, catch_param: cp, catch_body: cb) ->
      match walk_stmts(stmts: b, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          match walk_stmts(stmts: cb, defined: cp :: defined, known, seen: s1, refs: r1) do
            | WalkResult(defined: _, seen: s2, refs: r2) ->
              return WalkResult(defined, seen: s2, refs: r2)
          end
      end
    | Inject(handlers: _, body: b) ->
      return walk_stmts(stmts: b, defined, known, seen, refs)
  end
end

let walk_expr = fn (expr: HirExpr, defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult throws { Exn } do
  let HirExpr(node, span: _) = expr
  match node do
    | Literal(_) -> return WalkResult(defined, seen, refs)
    | Variable(name: n, sigil: _) ->
      return record_ref(name: n, defined, known, seen, refs)
    | Borrow(name: n, sigil: _) ->
      return record_ref(name: n, defined, known, seen, refs)
    | BinOp(left: l, op: _, right: r) ->
      match walk_expr(expr: l, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_expr(expr: r, defined, known, seen: s1, refs: r1)
      end
    | UnOp(op: _, operand: o) ->
      return walk_expr(expr: o, defined, known, seen, refs)
    | Call(func: f, args) ->
      match record_ref(name: f, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s0, refs: r0) ->
          return walk_call_args(args, defined, known, seen: s0, refs: r0)
      end
    | Ctor(variant: _, args) ->
      return walk_expr_list(exprs: args, defined, known, seen, refs)
    | Record(fields: fs) ->
      return walk_named_exprs(exprs: fs, defined, known, seen, refs)
    | Array(elems: es) ->
      return walk_expr_list(exprs: es, defined, known, seen, refs)
    | Index(target: t, index: i) ->
      match walk_expr(expr: t, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_expr(expr: i, defined, known, seen: s1, refs: r1)
      end
    | FieldAccess(target: t, field: _) ->
      return walk_expr(expr: t, defined, known, seen, refs)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      match walk_expr(expr: c, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          match walk_stmts(stmts: tb, defined, known, seen: s1, refs: r1) do
            | WalkResult(defined: _, seen: s2, refs: r2) ->
              match eb do
                | Some(val: stmts) -> return walk_stmts(stmts, defined, known, seen: s2, refs: r2)
                | None -> return WalkResult(defined, seen: s2, refs: r2)
              end
          end
      end
    | Match(target: t, cases: cs) ->
      match walk_expr(expr: t, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_match_cases(cases: cs, defined, known, seen: s1, refs: r1)
      end
    | While(cond: c, body: b) ->
      match walk_expr(expr: c, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_stmts(stmts: b, defined, known, seen: s1, refs: r1)
      end
    | For(var, start: s, end_expr: e, body: b) ->
      match walk_expr(expr: s, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          match walk_expr(expr: e, defined, known, seen: s1, refs: r1) do
            | WalkResult(defined: _, seen: s2, refs: r2) ->
              return walk_stmts(stmts: b, defined: var :: defined, known, seen: s2, refs: r2)
          end
      end
    | Lambda(type_params: _, params: lps, ret_type: _, body: lbody) ->
      // Nested lambda: its params shadow captures; treat its body with
      // its params added to `defined` so its own free vars are reported.
      let inner_defined = concat_strings(a: param_names_of(params: lps), b: defined)
      return walk_stmts(stmts: lbody, defined: inner_defined, known, seen, refs)
    | Raise(expr: e) -> return walk_expr(expr: e, defined, known, seen, refs)
    | Force(expr: e) -> return walk_expr(expr: e, defined, known, seen, refs)
    | Thunk(body: b) -> return walk_expr(expr: b, defined, known, seen, refs)
    | ExternalRef(symbol: _, type_params: _, arg_names: _, typ: _) -> return WalkResult(defined, seen, refs)
    | Handler(_) -> return WalkResult(defined, seen, refs)
  end
end

/// If `name` isn't already defined or known and wasn't seen yet, record it.
let record_ref = fn (name: string, defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult throws { Exn } do
  if string_mem(x: name, xs: defined) then return WalkResult(defined, seen, refs) end
  if string_mem(x: name, xs: known) then return WalkResult(defined, seen, refs) end
  if string_mem(x: name, xs: seen) then return WalkResult(defined, seen, refs) end
  return WalkResult(defined, seen: name :: seen, refs: name :: refs)
end

let string_mem = fn (x: string, xs: [string]) -> bool throws { Exn } do
  match xs do
    | [] -> return false
    | y :: rest ->
      if x == y then return true end
      return string_mem(x, xs: rest)
  end
end

let walk_expr_list = fn (exprs: [HirExpr], defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult throws { Exn } do
  match exprs do
    | [] -> return WalkResult(defined, seen, refs)
    | e :: rest ->
      match walk_expr(expr: e, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_expr_list(exprs: rest, defined, known, seen: s1, refs: r1)
      end
  end
end

let walk_call_args = fn (args: [HirCallArg], defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult throws { Exn } do
  match args do
    | [] -> return WalkResult(defined, seen, refs)
    | HirCallArg(label: _, value: v) :: rest ->
      match walk_expr(expr: v, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_call_args(args: rest, defined, known, seen: s1, refs: r1)
      end
  end
end

let walk_named_exprs = fn (exprs: [HirNamedExpr], defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult throws { Exn } do
  match exprs do
    | [] -> return WalkResult(defined, seen, refs)
    | HirNamedExpr(name: _, value: v) :: rest ->
      match walk_expr(expr: v, defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_named_exprs(exprs: rest, defined, known, seen: s1, refs: r1)
      end
  end
end

let walk_match_cases = fn (cases: [HirMatchCase], defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult throws { Exn } do
  match cases do
    | [] -> return WalkResult(defined, seen, refs)
    | HirMatchCase(pattern: p, body: b) :: rest ->
      let case_defined = concat_strings(a: pattern_bindings(pat: p, acc: []), b: defined)
      match walk_stmts(stmts: b, defined: case_defined, known, seen, refs) do
        | WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_match_cases(cases: rest, defined, known, seen: s1, refs: r1)
      end
  end
end

let pattern_bindings = fn (pat: HirPatternKind, acc: [string]) -> [string] throws { Exn } do
  match pat do
    | hir.PLit(_) -> return acc
    | hir.PVar(name: n, sigil: _) -> return n :: acc
    | hir.PWild -> return acc
    | hir.PCtor(variant: _, fields: fs) -> return pattern_field_bindings(fs, acc)
    | hir.PRec(fields: fs, is_partial: _) -> return record_pattern_field_bindings(fs, acc)
    // Or-pattern alternatives bind the same variables (typecheck enforces this);
    // walking the first alternative is sufficient.
    | hir.POr(alts) ->
      match alts do
        | first :: _ -> return pattern_bindings(pat: first, acc)
        | [] -> return acc
      end
  end
end

let pattern_field_bindings = fn (fs: [HirPatternField], acc: [string]) -> [string] throws { Exn } do
  match fs do
    | [] -> return acc
    | HirPatternField(name: _, pattern: p) :: rest -> return pattern_field_bindings(fs: rest, acc: pattern_bindings(pat: p, acc))
  end
end

let record_pattern_field_bindings = fn (fs: [HirRecordPatField], acc: [string]) -> [string] throws { Exn } do
  match fs do
    | [] -> return acc
    | HirRecordPatField(name: _, pattern: p) :: rest -> return record_pattern_field_bindings(fs: rest, acc: pattern_bindings(pat: p, acc))
  end
end

// ─── Integer → string (tiny) ─────────────────────────────────────────────────

let i64_to_str = fn (n: i64) -> string throws { Exn } do
  if n == 0 then return "0"
  end
  if n < 0 then return "-" ++ i64_to_str_pos(n: -n, acc: "")
  end
  return i64_to_str_pos(n, acc: "")
end

let i64_to_str_pos = fn (n: i64, acc: string) -> string throws { Exn } do
  if n == 0 then return acc
  end
  let digit = n % 10
  let ch = digit_to_char(d: digit)
  let next_n = n / 10
  return i64_to_str_pos(n: next_n, acc: ch ++ acc)
end

let digit_to_char = fn (d: i64) -> string throws { Exn } do
  if d == 0 then return "0" end
  if d == 1 then return "1" end
  if d == 2 then return "2" end
  if d == 3 then return "3" end
  if d == 4 then return "4" end
  if d == 5 then return "5" end
  if d == 6 then return "6" end
  if d == 7 then return "7" end
  if d == 8 then return "8" end
  return "9"
end

let append_mir_funcs = fn (a: [MirFunction], b: [MirFunction]) -> [MirFunction] throws { Exn } do
  match a do
    | [] -> return b
    | x :: rest -> return x :: append_mir_funcs(a: rest, b)
  end
end

export let lower_pattern = fn (pat: HirPatternKind) -> MirPattern throws { Exn } do
  match pat do
    | hir.PLit(lit: l) -> return MirPatLiteral(lit: l)
    | hir.PVar(name: n, sigil: s) -> return MirPatVariable(name: n, sigil: s)
    | hir.PCtor(variant: v, fields: fs) ->
      return MirPatConstructor(name: v, fields: lower_pattern_fields(fs))
    | hir.PRec(fields: fs, is_partial: p) ->
      return MirPatRecord(fields: lower_record_pat_fields(fs), is_partial: p)
    | hir.PWild -> return MirPatWildcard
    | hir.POr(alts) ->
      return MirPatOr(alts: lower_or_alts(alts, acc: []))
  end
end

let lower_or_alts = fn (alts: [HirPatternKind], acc: [MirPattern]) -> [MirPattern] throws { Exn } do
  match alts do
    | [] -> return list.reverse(xs: acc)
    | a :: rest -> return lower_or_alts(alts: rest, acc: lower_pattern(pat: a) :: acc)
  end
end

let lower_pattern_fields = fn (fs: [HirPatternField]) -> [MirPatternField] throws { Exn } do
  return lower_pattern_fields_go(fs, acc: [])
end

let lower_pattern_fields_go = fn (fs: [HirPatternField], acc: [MirPatternField]) -> [MirPatternField] throws { Exn } do
  match fs do
    | [] -> return rev_mir_pattern_fields(lst: acc, out: [])
    | HirPatternField(name: n, pattern: p) :: rest ->
      return lower_pattern_fields_go(fs: rest, acc: MirPatternField(name: n, pattern: lower_pattern(pat: p)) :: acc)
  end
end

let lower_record_pat_fields = fn (fs: [HirRecordPatField]) -> [MirRecordPatField] throws { Exn } do
  return lower_record_pat_fields_go(fs, acc: [])
end

let lower_record_pat_fields_go = fn (fs: [HirRecordPatField], acc: [MirRecordPatField]) -> [MirRecordPatField] throws { Exn } do
  match fs do
    | [] -> return rev_mir_record_pat_fields(lst: acc, out: [])
    | HirRecordPatField(name: n, pattern: p) :: rest ->
      return lower_record_pat_fields_go(fs: rest, acc: MirRecordPatField(name: n, pattern: lower_pattern(pat: p)) :: acc)
  end
end

// ─── List Helpers ───────────────────────────────────────────────────────────

let concat_mir_funcs = fn (a: [MirFunction], b: [MirFunction]) -> [MirFunction] throws { Exn } do
  return concat_mir_funcs_go(xs: a, ys: b, acc: [])
end

let concat_mir_funcs_go = fn (xs: [MirFunction], ys: [MirFunction], acc: [MirFunction]) -> [MirFunction] throws { Exn } do
  match xs do
    | [] -> return rev_mir_funcs(lst: acc, out: ys)
    | x :: rest -> return concat_mir_funcs_go(xs: rest, ys, acc: x :: acc)
  end
end

let concat_mir_stmts = fn (a: [MirStmt], b: [MirStmt]) -> [MirStmt] throws { Exn } do
  return concat_mir_stmts_go(xs: a, ys: b, acc: [])
end

let concat_mir_stmts_go = fn (xs: [MirStmt], ys: [MirStmt], acc: [MirStmt]) -> [MirStmt] throws { Exn } do
  match xs do
    | [] -> return rev_mir_stmts(lst: acc, out: ys)
    | x :: rest -> return concat_mir_stmts_go(xs: rest, ys, acc: x :: acc)
  end
end

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_name_pairs = fn (lst: [NamePair], out: [NamePair]) -> [NamePair] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_name_pairs(lst: rest, out: x :: out)
  end
end

let rev_strings = fn (lst: [string], out: [string]) -> [string] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_strings(lst: rest, out: x :: out)
  end
end

let rev_mir_externals = fn (lst: [MirExternal], out: [MirExternal]) -> [MirExternal] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_externals(lst: rest, out: x :: out)
  end
end

let rev_mir_params = fn (lst: [MirParam], out: [MirParam]) -> [MirParam] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_params(lst: rest, out: x :: out)
  end
end

let rev_mir_funcs = fn (lst: [MirFunction], out: [MirFunction]) -> [MirFunction] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_funcs(lst: rest, out: x :: out)
  end
end

let rev_mir_stmts = fn (lst: [MirStmt], out: [MirStmt]) -> [MirStmt] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_stmts(lst: rest, out: x :: out)
  end
end

let rev_mir_call_args = fn (lst: [MirCallArg], out: [MirCallArg]) -> [MirCallArg] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_call_args(lst: rest, out: x :: out)
  end
end

let rev_mir_exprs = fn (lst: [MirExpr], out: [MirExpr]) -> [MirExpr] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_exprs(lst: rest, out: x :: out)
  end
end

let rev_mir_named_exprs = fn (lst: [MirNamedExpr], out: [MirNamedExpr]) -> [MirNamedExpr] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_named_exprs(lst: rest, out: x :: out)
  end
end

let rev_mir_match_cases = fn (lst: [MirMatchCase], out: [MirMatchCase]) -> [MirMatchCase] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_match_cases(lst: rest, out: x :: out)
  end
end

let rev_mir_pattern_fields = fn (lst: [MirPatternField], out: [MirPatternField]) -> [MirPatternField] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_pattern_fields(lst: rest, out: x :: out)
  end
end

let rev_mir_record_pat_fields = fn (lst: [MirRecordPatField], out: [MirRecordPatField]) -> [MirRecordPatField] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_record_pat_fields(lst: rest, out: x :: out)
  end
end
