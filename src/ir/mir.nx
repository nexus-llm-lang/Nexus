/**
 * mir: HIR → MIR lowering.
 *
 * Owns:
 * - Expression / statement / pattern lowering from HIR to MIR
 * - Inject-scope inlining (compile-time effect, no runtime representation)
 * - For-loop → while-loop desugaring
 * - Lambda / handler expressions dropped to Unit (lifted during HIR build)
 * - MirCtx construction + threading; lower_port_call uses port.nx for detection
 *   but the call-emission happens here because it calls lower_call_args
 * - Handler-function lowering (lower_handler_functions)
 *
 * Does not own:
 * - MIR type definitions (see src/ir/mir_types.nx)
 * - Port-layout construction, port-call detection, return-type lookup,
 *   handler-port name inference (see src/ir/mir/port.nx)
 * - Generic reverse helpers (see src/common/mono_reverse.nx)
 */
import * as naming from "src/common/naming.nx"
import * as str from "stdlib/string_ops.nx"
import { Literal, TypeExpr } from "src/common/ast.nx"
import * as hir from "src/ir/hir_types.nx"
import { HirStmtKind, HirCallArg, HirParam, HirFunction, HirMatchCase, HirPatternKind, HirPatternField, HirRecordPatField, HirPort, HirPortMethod, HirExternal, HirHandlerBinding, HirHandlerBindingEntry, HirProgram, HirNamedExpr, HirExpr, HirStmt, EagerBody, LazyBody } from "src/ir/hir_types.nx"
import { MirParam, MirExternal, MirFunction, MirCallArg, MirExpr, MirNamedExpr, MirStmt, MirMatchCase, MirPattern, MirPatternField, MirRecordPatField, MirProgram, NamePair, PortEntry, PortCallResult, PortCallFound, PortCallNotFound, MirCtx, MirExprResult, MirStmtsResult, MirCallArgsResult, MirExprListResult, MirNamedExprsResult, MirMatchCasesResult, LowerFunctionsResult, LowerFunctionResult } from "src/ir/mir_types.nx"
import { build_port_layouts, lookup_port, infer_handler_port_names, find_handler_by_port, reverse_lookup, lookup_ret_type, lookup_known_ret_type, detect_port_call } from "src/ir/mir/port.nx"

// ─── Lookup helpers (list-based maps) ────────────────────────────────────────

let lookup = fn (key: string, pairs: [NamePair]) -> Option<string> do
  match pairs do
    case [] -> return None
    case NamePair(key: k, value: v) :: rest ->
      if k == key then return Some(val: v)
      else return lookup(key: key, pairs: rest)
      end
  end
end

let insert_or_replace = fn (key: string, value: string, pairs: [NamePair]) -> [NamePair] do
  return NamePair(key: key, value: value) :: remove_key(key: key, pairs: pairs)
end

let remove_key = fn (key: string, pairs: [NamePair]) -> [NamePair] do
  return remove_key_go(key: key, pairs: pairs, acc: [])
end

let remove_key_go = fn (key: string, pairs: [NamePair], acc: [NamePair]) -> [NamePair] do
  match pairs do
    case [] -> return rev_name_pairs(lst: acc, out: [])
    case NamePair(key: k, value: val) :: rest ->
      if k == key then return remove_key_go(key: key, pairs: rest, acc: acc)
      else return remove_key_go(key: key, pairs: rest, acc: NamePair(key: k, value: val) :: acc)
      end
  end
end


// ─── Handler Mapping ────────────────────────────────────────────────────────

/// Build handler_binding_name → port_name mapping.
let build_handler_port_names = fn (bindings: [HirHandlerBindingEntry]) -> [NamePair] do
  return build_handler_port_names_go(bindings: bindings, acc: [])
end

let build_handler_port_names_go = fn (bindings: [HirHandlerBindingEntry], acc: [NamePair]) -> [NamePair] do
  match bindings do
    case [] -> return rev_name_pairs(lst: acc, out: [])
    case HirHandlerBindingEntry(name: bname, binding: HirHandlerBinding(port_name: pname, functions: _)) :: rest ->
      return build_handler_port_names_go(bindings: rest, acc: NamePair(key: bname, value: pname) :: acc)
  end
end

/// Build global port_name → handler_binding_name mapping (last handler wins).
let build_global_port_handlers = fn (handler_port_names: [NamePair]) -> [NamePair] do
  return build_global_go(pairs: handler_port_names, accum: [])
end

let build_global_go = fn (pairs: [NamePair], accum: [NamePair]) -> [NamePair] do
  match pairs do
    case [] -> return accum
    case NamePair(key: binding_name, value: port_name) :: rest ->
      let new_accum = insert_or_replace(key: port_name, value: binding_name, pairs: accum)
      return build_global_go(pairs: rest, accum: new_accum)
  end
end


// ─── Lower HIR → MIR ───────────────────────────────────────────────────────

export let lower_hir_to_mir = fn (hir: HirProgram) -> MirProgram do
  let HirProgram(ports: ports, functions: funcs, externals: exts, handler_bindings: hbs, enum_defs: _) = hir
  let port_layouts = build_port_layouts(ports: ports)
  let handler_port_names = build_handler_port_names(bindings: hbs)
  // If handler_port_names is empty (ExprHandler matching failed in component model),
  // infer from function names + port methods.
  let inferred = infer_handler_port_names(funcs: funcs, ports: ports)
  let effective_hpn = match handler_port_names do
    case [] -> inferred
    case _ -> append_name_pairs(a: handler_port_names, b: inferred)
  end
  let global_scope_base = build_global_port_handlers(handler_port_names: effective_hpn)
  // Always add known port→handler mappings as fallback
  let global_scope = insert_or_replace(key: "Console", value: "stdio.system_handler",
    pairs: insert_or_replace(key: "Fs", value: "fs_mod.system_handler",
    pairs: insert_or_replace(key: "Clock", value: "clock_mod.system_handler",
    pairs: global_scope_base)))

  let ctx = MirCtx(
    scope: global_scope,
    port_layouts: port_layouts,
    handler_port_names: effective_hpn,
    all_funcs: funcs,
    all_handlers: hbs,
    all_exts: exts,
    closure_counter: 0,
    lifted_funcs: []
  )

  let mir_externals = lower_externals(exts: exts)
  // Thread ctx through lowering so inline-lambda lifts accumulate across all
  // functions (and all handler functions), then append lifted __closure_* funcs.
  let funcs_r = lower_functions(functions: funcs, ctx: ctx)
  match funcs_r do case LowerFunctionsResult(ctx: ctx1, funcs: mir_funcs) ->
    let hfuncs_r = lower_handler_functions(bindings: hbs, ctx: ctx1)
    match hfuncs_r do case LowerFunctionsResult(ctx: ctx2, funcs: mir_handler_funcs) ->
      let MirCtx(scope: _, port_layouts: _, handler_port_names: _, all_funcs: _, all_handlers: _, all_exts: _, closure_counter: _, lifted_funcs: lifted) = ctx2
      let user_plus_handlers = concat_mir_funcs(a: mir_funcs, b: mir_handler_funcs)
      let all_mir_funcs = concat_mir_funcs(a: user_plus_handlers, b: lifted)
      return MirProgram(functions: all_mir_funcs, externals: mir_externals)
    end
  end
end

// ─── Lower Externals ────────────────────────────────────────────────────────

let lower_externals = fn (exts: [HirExternal]) -> [MirExternal] do
  return lower_externals_go(exts: exts, acc: [])
end

let lower_externals_go = fn (exts: [HirExternal], acc: [MirExternal]) -> [MirExternal] do
  match exts do
    case [] -> return rev_mir_externals(lst: acc, out: [])
    case HirExternal(name: n, wasm_module: wm, wasm_name: wn, params: ps, ret_type: rt, throw_row: tr) :: rest ->
      let mir_params = lower_hir_params(params: ps)
      return lower_externals_go(exts: rest, acc: MirExternal(name: n, wasm_module: wm, wasm_name: wn,
                       params: mir_params, ret_type: rt, throw_row: tr) :: acc)
  end
end

let lower_hir_params = fn (params: [HirParam]) -> [MirParam] do
  return lower_hir_params_go(params: params, acc: [])
end

let lower_hir_params_go = fn (params: [HirParam], acc: [MirParam]) -> [MirParam] do
  match params do
    case [] -> return rev_mir_params(lst: acc, out: [])
    case HirParam(name: n, label: l, typ: t) :: rest ->
      return lower_hir_params_go(params: rest, acc: MirParam(label: l, name: n, typ: t) :: acc)
  end
end

// ─── Lower Functions ────────────────────────────────────────────────────────

let lower_functions = fn (functions: [HirFunction], ctx: MirCtx) -> LowerFunctionsResult do
  return lower_functions_go(functions: functions, ctx: ctx, acc: [])
end

let lower_functions_go = fn (functions: [HirFunction], ctx: MirCtx, acc: [MirFunction]) -> LowerFunctionsResult do
  match functions do
    case [] -> return LowerFunctionsResult(ctx: ctx, funcs: rev_mir_funcs(lst: acc, out: []))
    case f :: rest ->
      match lower_function(func: f, ctx: ctx) do case LowerFunctionResult(ctx: ctx2, func: mir_f) ->
        return lower_functions_go(functions: rest, ctx: ctx2, acc: mir_f :: acc)
      end
  end
end

let lower_handler_functions = fn (bindings: [HirHandlerBindingEntry], ctx: MirCtx) -> LowerFunctionsResult do
  return lower_handler_functions_go(bindings: bindings, ctx: ctx, acc: [])
end

let lower_handler_functions_go = fn (bindings: [HirHandlerBindingEntry], ctx: MirCtx, acc: [MirFunction]) -> LowerFunctionsResult do
  match bindings do
    case [] -> return LowerFunctionsResult(ctx: ctx, funcs: rev_mir_funcs(lst: acc, out: []))
    case HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, functions: fs)) :: rest ->
      match lower_functions(functions: fs, ctx: ctx) do case LowerFunctionsResult(ctx: ctx2, funcs: lowered) ->
        let new_acc = prepend_reversed(src: lowered, dst: acc)
        return lower_handler_functions_go(bindings: rest, ctx: ctx2, acc: new_acc)
      end
  end
end

/// Push each element of `src` (in order) onto `dst`, reversing it. The outer
/// caller's final rev_mir_funcs restores original order.
let prepend_reversed = fn (src: [MirFunction], dst: [MirFunction]) -> [MirFunction] do
  match src do
    case [] -> return dst
    case x :: rest -> return prepend_reversed(src: rest, dst: x :: dst)
  end
end

let lower_function = fn (func: HirFunction, ctx: MirCtx) -> LowerFunctionResult do
  let HirFunction(name: n, type_params: _, params: ps, ret_type: rt, body: hir_body, span: sp) = func
  let body = match hir_body do case EagerBody(stmts: s) -> s case LazyBody(_) -> [] end
  let mir_params = lower_hir_params(params: ps)
  match lower_stmts(stmts: body, ctx: ctx) do case MirStmtsResult(ctx: ctx2, stmts: mir_body) ->
    return LowerFunctionResult(ctx: ctx2, func: MirFunction(name: n, params: mir_params, ret_type: rt, body: mir_body, span: sp))
  end
end

// ─── Lower Statements ───────────────────────────────────────────────────────

let lower_stmts = fn (stmts: [HirStmt], ctx: MirCtx) -> MirStmtsResult do
  return lower_stmts_go(stmts: stmts, ctx: ctx, acc: [])
end

let lower_stmts_go = fn (stmts: [HirStmt], ctx: MirCtx, acc: [MirStmt]) -> MirStmtsResult do
  match stmts do
    case [] -> return MirStmtsResult(ctx: ctx, stmts: rev_mir_stmts(lst: acc, out: []))
    case HirStmt(node: s, span: _) :: rest ->
      match lower_stmt(stmt: s, ctx: ctx) do case MirStmtsResult(ctx: ctx2, stmts: lowered) ->
        let new_acc = prepend_stmts_reversed(src: lowered, dst: acc)
        return lower_stmts_go(stmts: rest, ctx: ctx2, acc: new_acc)
      end
  end
end

let prepend_stmts_reversed = fn (src: [MirStmt], dst: [MirStmt]) -> [MirStmt] do
  match src do
    case [] -> return dst
    case x :: rest -> return prepend_stmts_reversed(src: rest, dst: x :: dst)
  end
end

/// Lower a statement. Inject/for desugar may produce multiple MIR stmts;
/// the ctx also carries forward any `__closure_*` lifts from lambdas inside.
let lower_stmt = fn (stmt: HirStmtKind, ctx: MirCtx) -> MirStmtsResult do
  match stmt do
    case Let(name: n, typ: t, value: v) ->
      let mir_typ = match t do
        case Some(val: te) -> te
        case None -> TyUnit
      end
      match lower_expr(expr: v, ctx: ctx) do case MirExprResult(ctx: ctx2, expr: mir_val) ->
        return MirStmtsResult(ctx: ctx2, stmts: [MirStmtLet(name: n, typ: mir_typ, expr: mir_val)])
      end

    case Expr(expr: se) ->
      let HirExpr(node: e, span: _) = se
      match e do
        case For(var: var, start: s, end_expr: end_e, body: b) ->
          return desugar_for(var: var, start_expr: s, end_expr: end_e, body: b, ctx: ctx)
        case _ ->
          match lower_expr(expr: se, ctx: ctx) do case MirExprResult(ctx: ctx2, expr: mir_e) ->
            return MirStmtsResult(ctx: ctx2, stmts: [MirStmtExpr(expr: mir_e)])
          end
      end

    case Return(expr: e) ->
      match lower_expr(expr: e, ctx: ctx) do case MirExprResult(ctx: ctx2, expr: mir_e) ->
        return MirStmtsResult(ctx: ctx2, stmts: [MirStmtReturn(expr: mir_e)])
      end

    case Assign(target: t, value: v) ->
      match lower_expr(expr: t, ctx: ctx) do case MirExprResult(ctx: ctx2, expr: mir_t) ->
        match lower_expr(expr: v, ctx: ctx2) do case MirExprResult(ctx: ctx3, expr: mir_v) ->
          return MirStmtsResult(ctx: ctx3, stmts: [MirStmtAssign(target: mir_t, value: mir_v)])
        end
      end

    case Try(body: b, catch_param: cp, catch_body: cb) ->
      match lower_stmts(stmts: b, ctx: ctx) do case MirStmtsResult(ctx: ctx2, stmts: mir_b) ->
        match lower_stmts(stmts: cb, ctx: ctx2) do case MirStmtsResult(ctx: ctx3, stmts: mir_cb) ->
          return MirStmtsResult(ctx: ctx3, stmts: [MirStmtTry(body: mir_b, catch_param: cp, catch_body: mir_cb)])
        end
      end

    case Inject(handlers: hs, body: b) ->
      let MirCtx(scope: scope, port_layouts: pl, handler_port_names: hpn, all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: cc, lifted_funcs: lf) = ctx
      let new_scope = activate_handlers(handler_names: hs, handler_port_names: hpn, scope: scope)
      let new_ctx = MirCtx(scope: new_scope, port_layouts: pl, handler_port_names: hpn,
                           all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: cc, lifted_funcs: lf)
      // lower body under injected scope; restore caller's scope but keep ctx's
      // updated closure_counter/lifted_funcs.
      match lower_stmts(stmts: b, ctx: new_ctx) do case MirStmtsResult(ctx: ctx2, stmts: lowered) ->
        let MirCtx(scope: _, port_layouts: pl2, handler_port_names: hpn2, all_funcs: af2, all_handlers: ah2, all_exts: ae2, closure_counter: cc2, lifted_funcs: lf2) = ctx2
        let restored = MirCtx(scope: scope, port_layouts: pl2, handler_port_names: hpn2,
                              all_funcs: af2, all_handlers: ah2, all_exts: ae2, closure_counter: cc2, lifted_funcs: lf2)
        return MirStmtsResult(ctx: restored, stmts: lowered)
      end
  end
end

let activate_handlers = fn (handler_names: [string], handler_port_names: [NamePair], scope: [NamePair]) -> [NamePair] do
  match handler_names do
    case [] -> return scope
    case hname :: rest ->
      let port_opt = lookup(key: hname, pairs: handler_port_names)
      let new_scope = match port_opt do
        case Some(val: pname) -> insert_or_replace(key: pname, value: hname, pairs: scope)
        case None -> scope
      end
      return activate_handlers(handler_names: rest, handler_port_names: handler_port_names, scope: new_scope)
  end
end

// ─── For-loop Desugaring ────────────────────────────────────────────────────

let desugar_for = fn (var: string, start_expr: HirExpr, end_expr: HirExpr, body: [HirStmt], ctx: MirCtx) -> MirStmtsResult do
  let end_name = "__for_end_" ++ var
  match lower_expr(expr: start_expr, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: mir_start) ->
    match lower_expr(expr: end_expr, ctx: ctx1) do case MirExprResult(ctx: ctx2, expr: mir_end) ->
      match lower_stmts(stmts: body, ctx: ctx2) do case MirStmtsResult(ctx: ctx3, stmts: mir_body) ->
        let incr = MirStmtAssign(
          target: MirVariable(name: var),
          value: MirBinaryOp(left: MirVariable(name: var), op: OpAdd, right: MirLiteral(lit: LitInt(val: 1)))
        )
        let full_body = concat_mir_stmts(a: mir_body, b: [incr])
        let stmts = [
          MirStmtLet(name: var, typ: TyI64, expr: mir_start),
          MirStmtLet(name: end_name, typ: TyI64, expr: mir_end),
          MirStmtExpr(expr: MirWhile(
            cond: MirBinaryOp(left: MirVariable(name: var), op: OpLt, right: MirVariable(name: end_name)),
            body: full_body
          ))
        ]
        return MirStmtsResult(ctx: ctx3, stmts: stmts)
      end
    end
  end
end

// ─── Lower Expressions ─────────────────────────────────────────────────────

let lower_expr = fn (expr: HirExpr, ctx: MirCtx) -> MirExprResult do
  let HirExpr(node: node, span: _) = expr
  match node do
    case Literal(lit: l) -> return MirExprResult(ctx: ctx, expr: MirLiteral(lit: l))
    case Variable(name: n, sigil: _) -> return MirExprResult(ctx: ctx, expr: MirVariable(name: n))
    case BinOp(left: l, op: op, right: r) ->
      match lower_expr(expr: l, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: le) ->
        match lower_expr(expr: r, ctx: ctx1) do case MirExprResult(ctx: ctx2, expr: re) ->
          return MirExprResult(ctx: ctx2, expr: MirBinaryOp(left: le, op: op, right: re))
        end
      end
    case Borrow(name: n, sigil: _) -> return MirExprResult(ctx: ctx, expr: MirBorrow(name: n))
    case Call(func: f, args: args) ->
      let MirCtx(scope: _, port_layouts: pl, handler_port_names: _, all_funcs: _, all_handlers: _, all_exts: _, closure_counter: _, lifted_funcs: _) = ctx
      match detect_port_call(func: f, port_layouts: pl) do
        case PortCallFound(port_name: pname, method_name: mname) ->
          return lower_port_call(port_name: pname, method_name: mname, args: args, ctx: ctx)
        case PortCallNotFound ->
          match lower_call_args(args: args, ctx: ctx) do case MirCallArgsResult(ctx: ctx1, args: mir_args) ->
            match lookup_known_ret_type(name: f, ctx: ctx1) do
              case Some(val: ret_type) ->
                return MirExprResult(ctx: ctx1, expr: MirCall(func: f, args: mir_args, ret_type: ret_type))
              case None ->
                // f is a local / parameter holding a closure. LIR recovers
                // the real return type from semantic_vars.
                return MirExprResult(ctx: ctx1, expr: MirCallClosure(closure: MirVariable(name: f), args: mir_args, ret_type: TyI64))
            end
          end
      end
    case Ctor(variant: v, args: args) ->
      match lower_expr_list(exprs: args, ctx: ctx) do case MirExprListResult(ctx: ctx1, exprs: mir_args) ->
        return MirExprResult(ctx: ctx1, expr: MirConstructor(name: v, args: mir_args))
      end
    case Record(fields: fs) ->
      match lower_named_exprs(exprs: fs, ctx: ctx) do case MirNamedExprsResult(ctx: ctx1, exprs: mir_fs) ->
        return MirExprResult(ctx: ctx1, expr: MirRecord(fields: mir_fs))
      end
    case Array(elems: es) ->
      match lower_expr_list(exprs: es, ctx: ctx) do case MirExprListResult(ctx: ctx1, exprs: mir_es) ->
        return MirExprResult(ctx: ctx1, expr: MirArray(elems: mir_es))
      end
    case Index(target: t, index: i) ->
      match lower_expr(expr: t, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: mir_t) ->
        match lower_expr(expr: i, ctx: ctx1) do case MirExprResult(ctx: ctx2, expr: mir_i) ->
          return MirExprResult(ctx: ctx2, expr: MirIndex(target: mir_t, index: mir_i))
        end
      end
    case FieldAccess(target: t, field: f) ->
      match lower_expr(expr: t, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: mir_t) ->
        return MirExprResult(ctx: ctx1, expr: MirFieldAccess(target: mir_t, field: f))
      end
    case If(cond: c, then_branch: tb, else_branch: eb) ->
      match lower_expr(expr: c, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: mir_cond) ->
        match lower_stmts(stmts: tb, ctx: ctx1) do case MirStmtsResult(ctx: ctx2, stmts: mir_then) ->
          match eb do
            case Some(val: stmts) ->
              match lower_stmts(stmts: stmts, ctx: ctx2) do case MirStmtsResult(ctx: ctx3, stmts: mir_else_body) ->
                return MirExprResult(ctx: ctx3, expr: MirIf(cond: mir_cond, then_body: mir_then, else_body: Some(val: mir_else_body)))
              end
            case None ->
              return MirExprResult(ctx: ctx2, expr: MirIf(cond: mir_cond, then_body: mir_then, else_body: None))
          end
        end
      end
    case Match(target: t, cases: cs) ->
      match lower_expr(expr: t, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: mir_target) ->
        match lower_match_cases(cases: cs, ctx: ctx1) do case MirMatchCasesResult(ctx: ctx2, cases: mir_cases) ->
          return MirExprResult(ctx: ctx2, expr: MirMatch(target: mir_target, cases: mir_cases))
        end
      end
    case While(cond: c, body: b) ->
      match lower_expr(expr: c, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: mir_cond) ->
        match lower_stmts(stmts: b, ctx: ctx1) do case MirStmtsResult(ctx: ctx2, stmts: mir_body) ->
          return MirExprResult(ctx: ctx2, expr: MirWhile(cond: mir_cond, body: mir_body))
        end
      end
    case For(var: var, start: _, end_expr: _, body: b) ->
      // For in expression position — desugar to while. (Start/end already
      // lowered and bound via Let at statement position for top-level fors;
      // this fallback handles for-in-expr by assuming end_name already exists.)
      let end_name = "__for_end_" ++ var
      match lower_stmts(stmts: b, ctx: ctx) do case MirStmtsResult(ctx: ctx1, stmts: mir_body) ->
        let incr = MirStmtAssign(
          target: MirVariable(name: var),
          value: MirBinaryOp(left: MirVariable(name: var), op: OpAdd, right: MirLiteral(lit: LitInt(val: 1)))
        )
        return MirExprResult(ctx: ctx1, expr: MirWhile(
          cond: MirBinaryOp(left: MirVariable(name: var), op: OpLt, right: MirVariable(name: end_name)),
          body: concat_mir_stmts(a: mir_body, b: [incr])
        ))
      end
    case Lambda(type_params: _, params: lps, ret_type: lret, body: lbody) ->
      return lift_lambda(params: lps, ret_type: lret, body: lbody, span: expr, ctx: ctx)
    case Raise(expr: e) ->
      match lower_expr(expr: e, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: mir_e) ->
        return MirExprResult(ctx: ctx1, expr: MirRaise(expr: mir_e))
      end
    case Force(expr: e) ->
      match lower_expr(expr: e, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: mir_e) ->
        return MirExprResult(ctx: ctx1, expr: MirForce(expr: mir_e))
      end
    case ExternalRef(symbol: sym, arg_names: _, typ: _) ->
      return MirExprResult(ctx: ctx, expr: MirVariable(name: sym))
    case Handler(_) ->
      return MirExprResult(ctx: ctx, expr: MirLiteral(lit: LitUnit))
  end
end

// ─── Port Call Resolution ───────────────────────────────────────────────────

let lower_port_call = fn (port_name: string, method_name: string, args: [HirCallArg], ctx: MirCtx) -> MirExprResult do
  let MirCtx(scope: scope, port_layouts: _, handler_port_names: hpn, all_funcs: _, all_handlers: all_hbs, all_exts: _, closure_counter: _, lifted_funcs: _) = ctx
  let handler_name = match lookup(key: port_name, pairs: scope) do
    case Some(val: h) -> h
    case None ->
      match reverse_lookup(value: port_name, pairs: hpn) do
        case Some(val: bname) -> bname
        case None ->
          match find_handler_by_port(port_name: port_name, bindings: all_hbs) do
            case Some(val: bname2) -> bname2
            // Last resort: check if port_name.system_handler exists
            case None -> port_name
          end
      end
  end
  let func_name = naming.handler_func_name(handler_name: handler_name, method_name: method_name)
  let ret_type = lookup_ret_type(name: func_name, ctx: ctx)
  match lower_call_args(args: args, ctx: ctx) do case MirCallArgsResult(ctx: ctx1, args: mir_args) ->
    return MirExprResult(ctx: ctx1, expr: MirCall(func: func_name, args: mir_args, ret_type: ret_type))
  end
end

/// Infer handler_binding_name → port_name from function names and port list.
/// Scans for functions named __handler_<binding>_<method> and matches against port methods.

let append_name_pairs = fn (a: [NamePair], b: [NamePair]) -> [NamePair] do
  match a do
    case [] -> return b
    case h :: t -> return h :: append_name_pairs(a: t, b: b)
  end
end


// ─── Lower Arguments/Patterns/Cases ─────────────────────────────────────────

let lower_call_args = fn (args: [HirCallArg], ctx: MirCtx) -> MirCallArgsResult do
  return lower_call_args_go(args: args, ctx: ctx, acc: [])
end

let lower_call_args_go = fn (args: [HirCallArg], ctx: MirCtx, acc: [MirCallArg]) -> MirCallArgsResult do
  match args do
    case [] -> return MirCallArgsResult(ctx: ctx, args: rev_mir_call_args(lst: acc, out: []))
    case HirCallArg(label: l, value: v) :: rest ->
      match lower_expr(expr: v, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: mir_v) ->
        return lower_call_args_go(args: rest, ctx: ctx1, acc: MirCallArg(label: l, value: mir_v) :: acc)
      end
  end
end

let lower_expr_list = fn (exprs: [HirExpr], ctx: MirCtx) -> MirExprListResult do
  return lower_expr_list_go(exprs: exprs, ctx: ctx, acc: [])
end

let lower_expr_list_go = fn (exprs: [HirExpr], ctx: MirCtx, acc: [MirExpr]) -> MirExprListResult do
  match exprs do
    case [] -> return MirExprListResult(ctx: ctx, exprs: rev_mir_exprs(lst: acc, out: []))
    case e :: rest ->
      match lower_expr(expr: e, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: mir_e) ->
        return lower_expr_list_go(exprs: rest, ctx: ctx1, acc: mir_e :: acc)
      end
  end
end

let lower_named_exprs = fn (exprs: [HirNamedExpr], ctx: MirCtx) -> MirNamedExprsResult do
  return lower_named_exprs_go(exprs: exprs, ctx: ctx, acc: [])
end

let lower_named_exprs_go = fn (exprs: [HirNamedExpr], ctx: MirCtx, acc: [MirNamedExpr]) -> MirNamedExprsResult do
  match exprs do
    case [] -> return MirNamedExprsResult(ctx: ctx, exprs: rev_mir_named_exprs(lst: acc, out: []))
    case HirNamedExpr(name: n, value: v) :: rest ->
      match lower_expr(expr: v, ctx: ctx) do case MirExprResult(ctx: ctx1, expr: mir_v) ->
        return lower_named_exprs_go(exprs: rest, ctx: ctx1, acc: MirNamedExpr(name: n, value: mir_v) :: acc)
      end
  end
end

let lower_match_cases = fn (cases: [HirMatchCase], ctx: MirCtx) -> MirMatchCasesResult do
  return lower_match_cases_go(cases: cases, ctx: ctx, acc: [])
end

let lower_match_cases_go = fn (cases: [HirMatchCase], ctx: MirCtx, acc: [MirMatchCase]) -> MirMatchCasesResult do
  match cases do
    case [] -> return MirMatchCasesResult(ctx: ctx, cases: rev_mir_match_cases(lst: acc, out: []))
    case HirMatchCase(pattern: p, body: b) :: rest ->
      match lower_stmts(stmts: b, ctx: ctx) do case MirStmtsResult(ctx: ctx1, stmts: mir_body) ->
        let case_mir = MirMatchCase(pattern: lower_pattern(pat: p), body: mir_body)
        return lower_match_cases_go(cases: rest, ctx: ctx1, acc: case_mir :: acc)
      end
  end
end

// ─── Lambda Lifting ─────────────────────────────────────────────────────────

/// Lift an inline `fn (...)` expression to a top-level `__closure_<N>` MIR
/// function. The lifted function receives `__env: i64` as its first parameter
/// (prepended before the original params) and opens the body with one
/// `let <cap_i> = MirEnvLoad("__env", i)` per captured free variable. The
/// callsite is replaced with `MirMakeClosure(func_name, captures)` so the
/// existing LIR/codegen closure machinery (`__closure_` prefix auto-registers
/// into the WASM closure table) picks it up.
let lift_lambda = fn (params: [HirParam], ret_type: TypeExpr, body: [HirStmt], span: HirExpr, ctx: MirCtx) -> MirExprResult do
  let MirCtx(scope: sc, port_layouts: pl, handler_port_names: hpn, all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: n, lifted_funcs: lf) = ctx
  let lifted_name = "__closure_" ++ i64_to_str(n: n)
  let ctx_after_name = MirCtx(scope: sc, port_layouts: pl, handler_port_names: hpn,
                              all_funcs: af, all_handlers: ah, all_exts: ae,
                              closure_counter: n + 1, lifted_funcs: lf)

  // Free variables: referenced in body but not bound by params or known at
  // top level (functions, externals, handler methods).
  let param_names = param_names_of(params: params)
  let known = build_known_names(ctx: ctx_after_name)
  let captures = collect_hir_free_vars(body: body, params: param_names, known: known)

  // Lower the original body once; capture names inside resolve to locals
  // bound by the env-load preamble below.
  match lower_stmts(stmts: body, ctx: ctx_after_name) do case MirStmtsResult(ctx: ctx_body, stmts: mir_body) ->
    // Build the env-load preamble, then prepend to lowered body.
    let preamble = build_env_load_preamble(captures: captures, index: 0)
    let full_body = concat_mir_stmts(a: preamble, b: mir_body)

    // Params: [__env: i64, *orig_params_with_closure_types]. Arrow types in
    // the original `params` must be swapped to TyI64 so WASM signatures line
    // up — captures and closure args are all passed as i64 closure pointers.
    let env_param = MirParam(label: "__env", name: "__env", typ: TyI64)
    let orig_params = lower_lambda_params(params: params)
    let all_params = env_param :: orig_params
    let HirExpr(node: _, span: sp) = span
    let lifted_fn = MirFunction(name: lifted_name, params: all_params,
                                ret_type: lower_lambda_ret_type(t: ret_type),
                                body: full_body, span: sp)

    // Append lifted fn to ctx.lifted_funcs (preserves creation order so
    // nested lambdas are emitted outer-last — matches Rust side).
    let MirCtx(scope: sc2, port_layouts: pl2, handler_port_names: hpn2, all_funcs: af2, all_handlers: ah2, all_exts: ae2, closure_counter: n2, lifted_funcs: lf2) = ctx_body
    let new_lf = append_mir_funcs(a: lf2, b: [lifted_fn])
    let ctx_final = MirCtx(scope: sc2, port_layouts: pl2, handler_port_names: hpn2,
                           all_funcs: af2, all_handlers: ah2, all_exts: ae2,
                           closure_counter: n2, lifted_funcs: new_lf)

    let capture_exprs = captures_to_mir_exprs(caps: captures, acc: [])
    return MirExprResult(ctx: ctx_final, expr: MirMakeClosure(func_name: lifted_name, captures: capture_exprs))
  end
end

/// Coerce arrow-typed lambda params to i64 (closure pointer). Non-arrow
/// param types (i64, string, records) pass through unchanged.
let lower_lambda_params = fn (params: [HirParam]) -> [MirParam] do
  return lower_lambda_params_go(params: params, acc: [])
end

let lower_lambda_params_go = fn (params: [HirParam], acc: [MirParam]) -> [MirParam] do
  match params do
    case [] -> return rev_mir_params(lst: acc, out: [])
    case HirParam(name: n, label: l, typ: t) :: rest ->
      return lower_lambda_params_go(params: rest, acc: MirParam(label: l, name: n, typ: coerce_arrow_to_i64(t: t)) :: acc)
  end
end

/// If the lambda's return type is an arrow, coerce to i64 for closure return.
let lower_lambda_ret_type = fn (t: TypeExpr) -> TypeExpr do
  return coerce_arrow_to_i64(t: t)
end

let coerce_arrow_to_i64 = fn (t: TypeExpr) -> TypeExpr do
  match t do
    case TyArrow(_) -> return TyI64
    case _ -> return t
  end
end

/// Emit `let <cap_i> = MirEnvLoad("__env", i)` for each capture in order,
/// starting at `index`. Captures are loaded as i64; a later sigil-aware
/// pass (not yet implemented) may refine their semantic types.
let build_env_load_preamble = fn (captures: [string], index: i64) -> [MirStmt] do
  match captures do
    case [] -> return []
    case cap :: rest ->
      let stmt = MirStmtLet(name: cap, typ: TyI64, expr: MirEnvLoad(env_var: "__env", index: index))
      return stmt :: build_env_load_preamble(captures: rest, index: index + 1)
  end
end

let captures_to_mir_exprs = fn (caps: [string], acc: [MirExpr]) -> [MirExpr] do
  match caps do
    case [] -> return rev_mir_exprs(lst: acc, out: [])
    case c :: rest -> return captures_to_mir_exprs(caps: rest, acc: MirVariable(name: c) :: acc)
  end
end

let param_names_of = fn (params: [HirParam]) -> [string] do
  return param_names_of_go(params: params, acc: [])
end

let param_names_of_go = fn (params: [HirParam], acc: [string]) -> [string] do
  match params do
    case [] -> return rev_strings(lst: acc, out: [])
    case HirParam(name: n, label: _, typ: _) :: rest -> return param_names_of_go(params: rest, acc: n :: acc)
  end
end

/// Names that are statically resolvable at the lambda's callsite and must
/// NOT be treated as free variables: top-level function names, externals,
/// and handler-method names.
let build_known_names = fn (ctx: MirCtx) -> [string] do
  let MirCtx(scope: _, port_layouts: _, handler_port_names: _, all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: _, lifted_funcs: _) = ctx
  let from_funcs = fn_names_of(funcs: af, acc: [])
  let from_exts = ext_names_of(exts: ae, acc: [])
  let from_handlers = handler_fn_names_of(bindings: ah, acc: [])
  let a = concat_strings(a: from_funcs, b: from_exts)
  return concat_strings(a: a, b: from_handlers)
end

let fn_names_of = fn (funcs: [HirFunction], acc: [string]) -> [string] do
  match funcs do
    case [] -> return rev_strings(lst: acc, out: [])
    case HirFunction(name: n, type_params: _, params: _, ret_type: _, body: _, span: _) :: rest ->
      return fn_names_of(funcs: rest, acc: n :: acc)
  end
end

let ext_names_of = fn (exts: [HirExternal], acc: [string]) -> [string] do
  match exts do
    case [] -> return rev_strings(lst: acc, out: [])
    case HirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) :: rest ->
      return ext_names_of(exts: rest, acc: n :: acc)
  end
end

let handler_fn_names_of = fn (bindings: [HirHandlerBindingEntry], acc: [string]) -> [string] do
  match bindings do
    case [] -> return rev_strings(lst: acc, out: [])
    case HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, functions: fs)) :: rest ->
      return handler_fn_names_of(bindings: rest, acc: prepend_fn_names(funcs: fs, acc: acc))
  end
end

let prepend_fn_names = fn (funcs: [HirFunction], acc: [string]) -> [string] do
  match funcs do
    case [] -> return acc
    case HirFunction(name: n, type_params: _, params: _, ret_type: _, body: _, span: _) :: rest ->
      return prepend_fn_names(funcs: rest, acc: n :: acc)
  end
end

let concat_strings = fn (a: [string], b: [string]) -> [string] do
  match a do
    case [] -> return b
    case x :: rest -> return x :: concat_strings(a: rest, b: b)
  end
end

// ─── Free-Variable Collection (HIR walk) ─────────────────────────────────────

/// Walk HIR stmts, returning the names referenced but not locally bound
/// and not in `known` (top-level functions, externals, handler methods).
/// Preserves first-reference order and deduplicates.
let collect_hir_free_vars = fn (body: [HirStmt], params: [string], known: [string]) -> [string] do
  let defined = params
  let seen = []
  let refs = []
  match walk_stmts(stmts: body, defined: defined, known: known, seen: seen, refs: refs) do
    case WalkResult(defined: _, seen: _, refs: r) -> return rev_strings(lst: r, out: [])
  end
end

/// Accumulator threaded through the HIR free-var walk.
type WalkResult = WalkResult(defined: [string], seen: [string], refs: [string])

let walk_stmts = fn (stmts: [HirStmt], defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult do
  match stmts do
    case [] -> return WalkResult(defined: defined, seen: seen, refs: refs)
    case HirStmt(node: s, span: _) :: rest ->
      match walk_stmt(stmt: s, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: d2, seen: s2, refs: r2) ->
          return walk_stmts(stmts: rest, defined: d2, known: known, seen: s2, refs: r2)
      end
  end
end

let walk_stmt = fn (stmt: HirStmtKind, defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult do
  match stmt do
    case Let(name: n, typ: _, value: v) ->
      match walk_expr(expr: v, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s2, refs: r2) ->
          return WalkResult(defined: n :: defined, seen: s2, refs: r2)
      end
    case Expr(expr: e) ->
      return walk_expr(expr: e, defined: defined, known: known, seen: seen, refs: refs)
    case Return(expr: e) ->
      return walk_expr(expr: e, defined: defined, known: known, seen: seen, refs: refs)
    case Assign(target: t, value: v) ->
      match walk_expr(expr: t, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_expr(expr: v, defined: defined, known: known, seen: s1, refs: r1)
      end
    case Try(body: b, catch_param: cp, catch_body: cb) ->
      match walk_stmts(stmts: b, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          match walk_stmts(stmts: cb, defined: cp :: defined, known: known, seen: s1, refs: r1) do
            case WalkResult(defined: _, seen: s2, refs: r2) ->
              return WalkResult(defined: defined, seen: s2, refs: r2)
          end
      end
    case Inject(handlers: _, body: b) ->
      return walk_stmts(stmts: b, defined: defined, known: known, seen: seen, refs: refs)
  end
end

let walk_expr = fn (expr: HirExpr, defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult do
  let HirExpr(node: node, span: _) = expr
  match node do
    case Literal(_) -> return WalkResult(defined: defined, seen: seen, refs: refs)
    case Variable(name: n, sigil: _) ->
      return record_ref(name: n, defined: defined, known: known, seen: seen, refs: refs)
    case Borrow(name: n, sigil: _) ->
      return record_ref(name: n, defined: defined, known: known, seen: seen, refs: refs)
    case BinOp(left: l, op: _, right: r) ->
      match walk_expr(expr: l, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_expr(expr: r, defined: defined, known: known, seen: s1, refs: r1)
      end
    case Call(func: f, args: args) ->
      match record_ref(name: f, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s0, refs: r0) ->
          return walk_call_args(args: args, defined: defined, known: known, seen: s0, refs: r0)
      end
    case Ctor(variant: _, args: args) ->
      return walk_expr_list(exprs: args, defined: defined, known: known, seen: seen, refs: refs)
    case Record(fields: fs) ->
      return walk_named_exprs(exprs: fs, defined: defined, known: known, seen: seen, refs: refs)
    case Array(elems: es) ->
      return walk_expr_list(exprs: es, defined: defined, known: known, seen: seen, refs: refs)
    case Index(target: t, index: i) ->
      match walk_expr(expr: t, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_expr(expr: i, defined: defined, known: known, seen: s1, refs: r1)
      end
    case FieldAccess(target: t, field: _) ->
      return walk_expr(expr: t, defined: defined, known: known, seen: seen, refs: refs)
    case If(cond: c, then_branch: tb, else_branch: eb) ->
      match walk_expr(expr: c, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          match walk_stmts(stmts: tb, defined: defined, known: known, seen: s1, refs: r1) do
            case WalkResult(defined: _, seen: s2, refs: r2) ->
              match eb do
                case Some(val: stmts) -> return walk_stmts(stmts: stmts, defined: defined, known: known, seen: s2, refs: r2)
                case None -> return WalkResult(defined: defined, seen: s2, refs: r2)
              end
          end
      end
    case Match(target: t, cases: cs) ->
      match walk_expr(expr: t, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_match_cases(cases: cs, defined: defined, known: known, seen: s1, refs: r1)
      end
    case While(cond: c, body: b) ->
      match walk_expr(expr: c, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_stmts(stmts: b, defined: defined, known: known, seen: s1, refs: r1)
      end
    case For(var: var, start: s, end_expr: e, body: b) ->
      match walk_expr(expr: s, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          match walk_expr(expr: e, defined: defined, known: known, seen: s1, refs: r1) do
            case WalkResult(defined: _, seen: s2, refs: r2) ->
              return walk_stmts(stmts: b, defined: var :: defined, known: known, seen: s2, refs: r2)
          end
      end
    case Lambda(type_params: _, params: lps, ret_type: _, body: lbody) ->
      // Nested lambda: its params shadow captures; treat its body with
      // its params added to `defined` so its own free vars are reported.
      let inner_defined = concat_strings(a: param_names_of(params: lps), b: defined)
      return walk_stmts(stmts: lbody, defined: inner_defined, known: known, seen: seen, refs: refs)
    case Raise(expr: e) -> return walk_expr(expr: e, defined: defined, known: known, seen: seen, refs: refs)
    case Force(expr: e) -> return walk_expr(expr: e, defined: defined, known: known, seen: seen, refs: refs)
    case ExternalRef(symbol: _, arg_names: _, typ: _) -> return WalkResult(defined: defined, seen: seen, refs: refs)
    case Handler(_) -> return WalkResult(defined: defined, seen: seen, refs: refs)
  end
end

/// If `name` isn't already defined or known and wasn't seen yet, record it.
let record_ref = fn (name: string, defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult do
  if string_mem(x: name, xs: defined) then return WalkResult(defined: defined, seen: seen, refs: refs) end
  if string_mem(x: name, xs: known) then return WalkResult(defined: defined, seen: seen, refs: refs) end
  if string_mem(x: name, xs: seen) then return WalkResult(defined: defined, seen: seen, refs: refs) end
  return WalkResult(defined: defined, seen: name :: seen, refs: name :: refs)
end

let string_mem = fn (x: string, xs: [string]) -> bool do
  match xs do
    case [] -> return false
    case y :: rest ->
      if x == y then return true end
      return string_mem(x: x, xs: rest)
  end
end

let walk_expr_list = fn (exprs: [HirExpr], defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult do
  match exprs do
    case [] -> return WalkResult(defined: defined, seen: seen, refs: refs)
    case e :: rest ->
      match walk_expr(expr: e, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_expr_list(exprs: rest, defined: defined, known: known, seen: s1, refs: r1)
      end
  end
end

let walk_call_args = fn (args: [HirCallArg], defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult do
  match args do
    case [] -> return WalkResult(defined: defined, seen: seen, refs: refs)
    case HirCallArg(label: _, value: v) :: rest ->
      match walk_expr(expr: v, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_call_args(args: rest, defined: defined, known: known, seen: s1, refs: r1)
      end
  end
end

let walk_named_exprs = fn (exprs: [HirNamedExpr], defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult do
  match exprs do
    case [] -> return WalkResult(defined: defined, seen: seen, refs: refs)
    case HirNamedExpr(name: _, value: v) :: rest ->
      match walk_expr(expr: v, defined: defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_named_exprs(exprs: rest, defined: defined, known: known, seen: s1, refs: r1)
      end
  end
end

let walk_match_cases = fn (cases: [HirMatchCase], defined: [string], known: [string], seen: [string], refs: [string]) -> WalkResult do
  match cases do
    case [] -> return WalkResult(defined: defined, seen: seen, refs: refs)
    case HirMatchCase(pattern: p, body: b) :: rest ->
      let case_defined = concat_strings(a: pattern_bindings(pat: p, acc: []), b: defined)
      match walk_stmts(stmts: b, defined: case_defined, known: known, seen: seen, refs: refs) do
        case WalkResult(defined: _, seen: s1, refs: r1) ->
          return walk_match_cases(cases: rest, defined: defined, known: known, seen: s1, refs: r1)
      end
  end
end

let pattern_bindings = fn (pat: HirPatternKind, acc: [string]) -> [string] do
  match pat do
    case hir.PLit(_) -> return acc
    case hir.PVar(name: n, sigil: _) -> return n :: acc
    case hir.PWild -> return acc
    case hir.PCtor(variant: _, fields: fs) -> return pattern_field_bindings(fs: fs, acc: acc)
    case hir.PRec(fields: fs, is_partial: _) -> return record_pattern_field_bindings(fs: fs, acc: acc)
  end
end

let pattern_field_bindings = fn (fs: [HirPatternField], acc: [string]) -> [string] do
  match fs do
    case [] -> return acc
    case HirPatternField(name: _, pattern: p) :: rest -> return pattern_field_bindings(fs: rest, acc: pattern_bindings(pat: p, acc: acc))
  end
end

let record_pattern_field_bindings = fn (fs: [HirRecordPatField], acc: [string]) -> [string] do
  match fs do
    case [] -> return acc
    case HirRecordPatField(name: _, pattern: p) :: rest -> return record_pattern_field_bindings(fs: rest, acc: pattern_bindings(pat: p, acc: acc))
  end
end

// ─── Integer → string (tiny) ─────────────────────────────────────────────────

let i64_to_str = fn (n: i64) -> string do
  if n == 0 then return "0"
  end
  if n < 0 then return "-" ++ i64_to_str_pos(n: 0 - n, acc: "")
  end
  return i64_to_str_pos(n: n, acc: "")
end

let i64_to_str_pos = fn (n: i64, acc: string) -> string do
  if n == 0 then return acc
  end
  let digit = n % 10
  let ch = digit_to_char(d: digit)
  let next_n = n / 10
  return i64_to_str_pos(n: next_n, acc: ch ++ acc)
end

let digit_to_char = fn (d: i64) -> string do
  if d == 0 then return "0" end
  if d == 1 then return "1" end
  if d == 2 then return "2" end
  if d == 3 then return "3" end
  if d == 4 then return "4" end
  if d == 5 then return "5" end
  if d == 6 then return "6" end
  if d == 7 then return "7" end
  if d == 8 then return "8" end
  return "9"
end

let append_mir_funcs = fn (a: [MirFunction], b: [MirFunction]) -> [MirFunction] do
  match a do
    case [] -> return b
    case x :: rest -> return x :: append_mir_funcs(a: rest, b: b)
  end
end

export let lower_pattern = fn (pat: HirPatternKind) -> MirPattern do
  match pat do
    case hir.PLit(lit: l) -> return MirPatLiteral(lit: l)
    case hir.PVar(name: n, sigil: s) -> return MirPatVariable(name: n, sigil: s)
    case hir.PCtor(variant: v, fields: fs) ->
      return MirPatConstructor(name: v, fields: lower_pattern_fields(fs: fs))
    case hir.PRec(fields: fs, is_partial: p) ->
      return MirPatRecord(fields: lower_record_pat_fields(fs: fs), is_partial: p)
    case hir.PWild -> return MirPatWildcard
  end
end

let lower_pattern_fields = fn (fs: [HirPatternField]) -> [MirPatternField] do
  return lower_pattern_fields_go(fs: fs, acc: [])
end

let lower_pattern_fields_go = fn (fs: [HirPatternField], acc: [MirPatternField]) -> [MirPatternField] do
  match fs do
    case [] -> return rev_mir_pattern_fields(lst: acc, out: [])
    case HirPatternField(name: n, pattern: p) :: rest ->
      return lower_pattern_fields_go(fs: rest, acc: MirPatternField(name: n, pattern: lower_pattern(pat: p)) :: acc)
  end
end

let lower_record_pat_fields = fn (fs: [HirRecordPatField]) -> [MirRecordPatField] do
  return lower_record_pat_fields_go(fs: fs, acc: [])
end

let lower_record_pat_fields_go = fn (fs: [HirRecordPatField], acc: [MirRecordPatField]) -> [MirRecordPatField] do
  match fs do
    case [] -> return rev_mir_record_pat_fields(lst: acc, out: [])
    case HirRecordPatField(name: n, pattern: p) :: rest ->
      return lower_record_pat_fields_go(fs: rest, acc: MirRecordPatField(name: n, pattern: lower_pattern(pat: p)) :: acc)
  end
end

// ─── List Helpers ───────────────────────────────────────────────────────────

let concat_mir_funcs = fn (a: [MirFunction], b: [MirFunction]) -> [MirFunction] do
  return concat_mir_funcs_go(xs: a, ys: b, acc: [])
end

let concat_mir_funcs_go = fn (xs: [MirFunction], ys: [MirFunction], acc: [MirFunction]) -> [MirFunction] do
  match xs do
    case [] -> return rev_mir_funcs(lst: acc, out: ys)
    case x :: rest -> return concat_mir_funcs_go(xs: rest, ys: ys, acc: x :: acc)
  end
end

let concat_mir_stmts = fn (a: [MirStmt], b: [MirStmt]) -> [MirStmt] do
  return concat_mir_stmts_go(xs: a, ys: b, acc: [])
end

let concat_mir_stmts_go = fn (xs: [MirStmt], ys: [MirStmt], acc: [MirStmt]) -> [MirStmt] do
  match xs do
    case [] -> return rev_mir_stmts(lst: acc, out: ys)
    case x :: rest -> return concat_mir_stmts_go(xs: rest, ys: ys, acc: x :: acc)
  end
end

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_name_pairs = fn (lst: [NamePair], out: [NamePair]) -> [NamePair] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_name_pairs(lst: rest, out: x :: out)
  end
end

let rev_strings = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_strings(lst: rest, out: x :: out)
  end
end

