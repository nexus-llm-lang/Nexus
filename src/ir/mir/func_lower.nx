/**
 * mir/func_lower: HIR function / handler lowering.
 *
 * Owns:
 * - HirParam → MirParam conversion (lower_hir_params)
 * - Single-function body lowering (lower_function)
 * - Function-list lowering (lower_functions, lower_functions_go)
 * - Handler-binding lowering (lower_handler_functions)
 * - Handler-arm lowering with continuation binders (lower_arms_with_konts)
 *
 * All entry points that recurse into statement bodies receive
 * `lower_stmts_fn` as a callback from mir.nx, where the authoritative
 * `lower_stmts` definition lives.  This avoids a cyclic import
 * (lower_stmts → lower_stmt → lower_expr → lower_stmts) while still
 * keeping each function list-walker in a dedicated file.
 *
 * Extracted from src/ir/mir/mir.nx.
 */

import {
  HirFunction,
  HirHandlerBindingEntry,
  HirHandlerBinding,
  HirHandlerArm,
  HirParam,
  HirStmt,
  EagerBody,
  LazyBody
} from "src/ir/hir/types.nx"
import {
  MirParam,
  MirFunction,
  MirCtx,
  MirStmtsResult,
  LowerFunctionsResult,
  LowerFunctionResult
} from "src/ir/mir/types.nx"
import { MirError } from "src/ir/mir/errors.nx"
import { SigilLazy, TyLazy, TypeExpr } from "src/syntax/ast.nx"
import * as list from "std:list"

let ctx_cont_binders = fn (ctx: MirCtx) -> [ string ] do
  let MirCtx(
    scope: _,
    cap_layouts: _,
    handler_cap_names: _,
    all_funcs: _,
    all_handlers: _,
    all_exts: _,
    closure_counter: _,
    lifted_funcs: _,
    cont_binders: cb,
    _
  ) = ctx
  return cb
end

let ctx_with_cont_binders = fn (ctx: MirCtx, binders: [ string ]) -> MirCtx do
  let MirCtx(
    scope: sc,
    cap_layouts: pl,
    handler_cap_names: hpn,
    all_funcs: af,
    all_handlers: ah,
    all_exts: ae,
    closure_counter: cc,
    lifted_funcs: lf,
    cont_binders: _,
    value_binding_names: vbns,
    thunk_param_names: tpn
  ) = ctx
  return MirCtx(
      scope: sc,
      cap_layouts: pl,
      handler_cap_names: hpn,
      all_funcs: af,
      all_handlers: ah,
      all_exts: ae,
      closure_counter: cc,
      lifted_funcs: lf,
      cont_binders: binders,
      value_binding_names: vbns,
      thunk_param_names: tpn
    )
end

let set_thunk_param_names = fn (ctx: MirCtx, names: [ string ]) -> MirCtx do
  let MirCtx(
    scope: sc,
    cap_layouts: pl,
    handler_cap_names: hpn,
    all_funcs: af,
    all_handlers: ah,
    all_exts: ae,
    closure_counter: cc,
    lifted_funcs: lf,
    cont_binders: cb,
    value_binding_names: vbns,
    thunk_param_names: _
  ) = ctx
  return MirCtx(
      scope: sc,
      cap_layouts: pl,
      handler_cap_names: hpn,
      all_funcs: af,
      all_handlers: ah,
      all_exts: ae,
      closure_counter: cc,
      lifted_funcs: lf,
      cont_binders: cb,
      value_binding_names: vbns,
      thunk_param_names: names
    )
end

let collect_thunk_param_names = fn (
  params: [ HirParam ],
  acc: [ string ]
) -> [ string ] throws { MirError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: _, name: n, sigil: sig, typ: t) :: rest ->
      let is_thunk = match sig do
        | SigilLazy -> true
        | _ ->
          match t do
            | TyLazy(inner: _, require_row: _, throw_row: _) -> true
            | _ -> false
          end
      end
      if is_thunk then
        return collect_thunk_param_names(params: rest, acc: n :: acc)
      end
      return collect_thunk_param_names(params: rest, acc)
  end
end

/** Push each element of `src` (in order) onto `dst`, reversing it. */
let prepend_reversed = fn (
  src: [ MirFunction ],
  dst: [ MirFunction ]
) -> [ MirFunction ] throws { MirError } do
  match src do
    | [] -> return dst
    | x :: rest -> return prepend_reversed(src: rest, dst: x :: dst)
  end
end

export let lower_hir_params = fn (params: [ HirParam ]) -> [ MirParam ] throws { MirError } do
  return lower_hir_params_go(params, acc: [])
end

let lower_hir_params_go = fn (
  params: [ HirParam ],
  acc: [ MirParam ]
) -> [ MirParam ] throws { MirError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: l, name: n, sigil: _, typ: t) :: rest ->
      return lower_hir_params_go(params: rest, acc: MirParam(label: l, name: n, typ: t) :: acc)
  end
end

export let lower_function = fn (func: HirFunction, ctx: MirCtx,
    lower_stmts_fn: (stmts: [ HirStmt ], ctx: MirCtx) -> MirStmtsResult throws { MirError }
  ) -> LowerFunctionResult throws { MirError } do
  let HirFunction(
    name: n,
    type_params: _,
    params: ps,
    ret_type: rt,
    throw_row: _,
    body: hir_body,
    span: sp,
    file: _,
    requires: _
  ) = func
  let body = match hir_body do | EagerBody(stmts: s) -> s | LazyBody(_) -> [] end
  let mir_params = lower_hir_params(params: ps)
  let thunk_names = collect_thunk_param_names(params: ps, acc: [])
  let ctx_with_thunks = set_thunk_param_names(ctx, names: thunk_names)
  let MirStmtsResult(ctx: ctx2, stmts: mir_body) = lower_stmts_fn(stmts: body, ctx: ctx_with_thunks)
  return LowerFunctionResult(
      ctx: ctx2,
      func: MirFunction(name: n, params: mir_params, ret_type: rt, body: mir_body, span: sp)
    )
end

export let lower_functions = fn (functions: [ HirFunction ], ctx: MirCtx,
    lower_stmts_fn: (stmts: [ HirStmt ], ctx: MirCtx) -> MirStmtsResult throws { MirError }
  ) -> LowerFunctionsResult throws { MirError } do
  return lower_functions_go(functions, ctx, acc: [], lower_stmts_fn)
end

let lower_functions_go = fn (functions: [ HirFunction ], ctx: MirCtx, acc: [ MirFunction ],
    lower_stmts_fn: (stmts: [ HirStmt ], ctx: MirCtx) -> MirStmtsResult throws { MirError }
  ) -> LowerFunctionsResult throws { MirError } do
  match functions do
    | [] -> return LowerFunctionsResult(ctx, funcs: list.reverse(xs: acc))
    | f :: rest ->
      let LowerFunctionResult(ctx: ctx2, func: mir_f) = lower_function(func: f, ctx, lower_stmts_fn)
      return lower_functions_go(functions: rest, ctx: ctx2, acc: mir_f :: acc, lower_stmts_fn)
  end
end

export let lower_handler_functions = fn (bindings: [ HirHandlerBindingEntry ], ctx: MirCtx,
    lower_stmts_fn: (stmts: [ HirStmt ], ctx: MirCtx) -> MirStmtsResult throws { MirError }
  ) -> LowerFunctionsResult throws { MirError } do
  return lower_handler_functions_go(bindings, ctx, acc: [], lower_stmts_fn)
end

let lower_handler_functions_go = fn (bindings: [ HirHandlerBindingEntry ], ctx: MirCtx, acc: [ MirFunction ],
    lower_stmts_fn: (stmts: [ HirStmt ], ctx: MirCtx) -> MirStmtsResult throws { MirError }
  ) -> LowerFunctionsResult throws { MirError } do
  match bindings do
    | [] -> return LowerFunctionsResult(ctx, funcs: list.reverse(xs: acc))
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      let LowerFunctionsResult(ctx: ctx2, funcs: lowered) = lower_arms_with_konts(
        arms,
        ctx,
        lower_stmts_fn
      )
      let new_acc = prepend_reversed(src: lowered, dst: acc)
        return lower_handler_functions_go(bindings: rest, ctx: ctx2, acc: new_acc, lower_stmts_fn)
  end
end

let lower_arms_with_konts = fn (arms: [ HirHandlerArm ], ctx: MirCtx,
    lower_stmts_fn: (stmts: [ HirStmt ], ctx: MirCtx) -> MirStmtsResult throws { MirError }
  ) -> LowerFunctionsResult throws { MirError } do
  return lower_arms_with_konts_go(arms, ctx, acc: [], lower_stmts_fn)
end

let lower_arms_with_konts_go = fn (arms: [ HirHandlerArm ], ctx: MirCtx, acc: [ MirFunction ],
    lower_stmts_fn: (stmts: [ HirStmt ], ctx: MirCtx) -> MirStmtsResult throws { MirError }
  ) -> LowerFunctionsResult throws { MirError } do
  match arms do
    | [] -> return LowerFunctionsResult(ctx, funcs: list.reverse(xs: acc))
    | HirHandlerArm(arm: f, cont_binder: kb) :: rest ->
      let arm_ctx = match kb do
        | Some(val: k) -> ctx_with_cont_binders(ctx, binders: [ k ])
        | None -> ctx
      end
      let LowerFunctionResult(ctx: ctx2, func: mf) = lower_function(
        func: f,
        ctx: arm_ctx,
        lower_stmts_fn
      )
      let restored = ctx_with_cont_binders(ctx: ctx2, binders: ctx_cont_binders(ctx))
        return lower_arms_with_konts_go(arms: rest, ctx: restored, acc: mf :: acc, lower_stmts_fn)
  end
end
