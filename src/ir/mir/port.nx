/**
 * port: Port-call resolution and port-layout bookkeeping for MIR lowering.
 *
 * Owns:
 * - Port layout construction (build_port_layouts)
 * - Handler → port name mapping (infer_handler_port_names)
 * - Return-type lookup across funcs / handlers / externals
 * - Port-call detection (detect_port_call)
 * - Small-map utilities over NamePair lists scoped to the above
 *
 * Does not own:
 * - The HIR → MIR expression lowering (stays in src/ir/mir.nx)
 * - lower_port_call (stays in mir.nx because it calls lower_call_args,
 *   which is part of MIR's mutual-recursive expression lowering and cannot
 *   be imported backwards without a cycle)
 *
 * Types (NamePair, PortEntry, PortCallResult, MirCtx) live in mir_types.nx.
 */
import { NamePair, PortEntry, PortCallResult, PortCallFound, PortCallNotFound, MirCtx } from "src/ir/mir_types.nx"
import { HirPort, HirPortMethod, HirFunction, HirHandlerBindingEntry, HirHandlerBinding, HirExternal } from "src/ir/hir_types.nx"
import { TypeExpr, TyI64 } from "src/common/ast.nx"
import { SymbolNotFound } from "src/common/error.nx"
import * as str from "std:string_ops"

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_name_pairs = fn (lst: [NamePair], out: [NamePair]) -> [NamePair] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_name_pairs(lst: rest, out: x :: out)
  end
end

// ─── Port Layout Building ───────────────────────────────────────────────────

export let build_port_layouts = fn (ports: [HirPort]) -> [PortEntry] do
  return build_port_layouts_go(ports, acc: [])
end

let build_port_layouts_go = fn (ports: [HirPort], acc: [PortEntry]) -> [PortEntry] do
  match ports do
    | [] -> return rev_name_pairs_as_ports(lst: acc, out: [])
    | HirPort(name: n, methods: ms) :: rest ->
      let method_names = extract_method_names(methods: ms)
      return build_port_layouts_go(ports: rest, acc: PortEntry(name: n, prefix: n ++ ".", methods: method_names) :: acc)
  end
end

let rev_name_pairs_as_ports = fn (lst: [PortEntry], out: [PortEntry]) -> [PortEntry] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_name_pairs_as_ports(lst: rest, out: x :: out)
  end
end

let extract_method_names = fn (methods: [HirPortMethod]) -> [string] do
  return extract_method_names_go(methods, acc: [])
end

let extract_method_names_go = fn (methods: [HirPortMethod], acc: [string]) -> [string] do
  match methods do
    | [] -> return rev_strings(lst: acc, out: [])
    | HirPortMethod(name: n) :: rest ->
      return extract_method_names_go(methods: rest, acc: n :: acc)
  end
end

let rev_strings = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_strings(lst: rest, out: x :: out)
  end
end

export let lookup_port = fn (name: string, ports: [PortEntry]) -> Option<[string]> do
  match ports do
    | [] -> return None
    | PortEntry(name: n, prefix: _, methods: ms) :: rest ->
      if n == name then return Some(val: ms)
      else return lookup_port(name, ports: rest)
      end
  end
end

// ─── Handler → Port Name Inference ──────────────────────────────────────────

/// Infer handler_binding_name → port_name from function names and port list.
/// Scans for functions named __handler_<binding>_<method> and matches against port methods.
export let infer_handler_port_names = fn (funcs: [HirFunction], ports: [HirPort]) -> [NamePair] do
  return infer_hpn_go(funcs, ports, acc: [])
end

let infer_hpn_go = fn (funcs: [HirFunction], ports: [HirPort], acc: [NamePair]) -> [NamePair] do
  match funcs do
    | [] -> return acc
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, body: _, span: _) :: rest ->
      if str.starts_with(s: n, prefix: "__handler_") then
        match infer_port_from_handler(name: n, ports) do
          | Some(val: pair) ->
            if name_pair_in_list(key: pair, pairs: acc) == false then
              return infer_hpn_go(funcs: rest, ports, acc: pair :: acc)
            else
              return infer_hpn_go(funcs: rest, ports, acc)
            end
          | None -> return infer_hpn_go(funcs: rest, ports, acc)
        end
      else
        return infer_hpn_go(funcs: rest, ports, acc)
      end
  end
end

let name_pair_in_list = fn (key: NamePair, pairs: [NamePair]) -> bool do
  match pairs do
    | [] -> return false
    | NamePair(key: k, value: _) :: rest ->
      let NamePair(key: nk, value: _) = key
      if k == nk then return true
      else return name_pair_in_list(key, pairs: rest)
      end
  end
end

let infer_port_from_handler = fn (name: string, ports: [HirPort]) -> Option<NamePair> do
  match ports do
    | [] -> return None
    | HirPort(name: pname, methods) :: rest ->
      match infer_binding_from_methods(handler_name: name, port_name: pname, methods) do
        | Some(val: binding) -> return Some(val: NamePair(key: binding, value: pname))
        | None -> return infer_port_from_handler(name, ports: rest)
      end
  end
end

let infer_binding_from_methods = fn (handler_name: string, port_name: string, methods: [HirPortMethod]) -> Option<string> do
  match methods do
    | [] -> return None
    | HirPortMethod(name: mname) :: rest ->
      let suffix = "_" ++ mname
      if str.ends_with(s: handler_name, suffix) then
        let prefix_len = 10 // length("__handler_")
        let suffix_len = str.length(s: suffix)
        let total_len = str.length(s: handler_name)
        let binding = str.substring(s: handler_name, start: prefix_len, len: total_len - prefix_len - suffix_len)
        return Some(val: binding)
      else
        return infer_binding_from_methods(handler_name, port_name, methods: rest)
      end
  end
end

export let find_handler_by_port = fn (port_name: string, bindings: [HirHandlerBindingEntry]) -> Option<string> do
  match bindings do
    | [] -> return None
    | HirHandlerBindingEntry(name: bname, binding: HirHandlerBinding(port_name: pname, functions: _)) :: rest ->
      if pname == port_name then return Some(val: bname)
      else return find_handler_by_port(port_name, bindings: rest)
      end
  end
end

export let reverse_lookup = fn (value: string, pairs: [NamePair]) -> Option<string> do
  match pairs do
    | [] -> return None
    | NamePair(key: k, value: v) :: rest ->
      if v == value then return Some(val: k)
      else return reverse_lookup(value, pairs: rest)
      end
  end
end

// ─── Return Type Lookup ─────────────────────────────────────────────────────

/// Check if `name` refers to a known top-level callable (function, handler
/// method, or external). Returns the declared return type if found, or None
/// when the name is a local variable / parameter (caller should emit an
/// indirect call in that case).
export let lookup_known_ret_type = fn (name: string, ctx: MirCtx) -> Option<TypeExpr> do
  match ctx do
    | MirCtx(scope: _, port_layouts: _, handler_port_names: _, all_funcs: funcs, all_handlers: handlers, all_exts: exts, closure_counter: _, lifted_funcs: _) ->
      let from_funcs = lookup_ret_in_functions(name, functions: funcs)
      match from_funcs do
        | Some(_) -> return from_funcs
        | None ->
          let from_handlers = lookup_ret_in_handlers(name, bindings: handlers)
          match from_handlers do
            | Some(_) -> return from_handlers
            | None -> return lookup_ret_in_externals(name, externals: exts)
          end
      end
  end
end

/// lookup_ret_type: handler-call return-type resolution.
///
/// Returns TyI64 on miss. This looks like a silent default but is structurally
/// necessary at this site: handler_func_name concatenates port-binding + method
/// to produce the callee, and the lookup may legitimately miss when a fallback
/// handler path (e.g. global_scope's Console → stdio.system_handler override)
/// was chosen ahead of a user-bound handler that existed under a different
/// binding name. Downstream codegen re-resolves via the WASM linker / stdlib
/// symbol table, and the TyI64 placeholder is never observed at WASM level
/// because every object reference is packed to i64. See nexus-9lp4.21 —
/// closing this out requires refactoring the Console/Fs/Clock hardcodes (see
/// nexus-9lp4.29), not a local raise here.
export let lookup_ret_type = fn (name: string, ctx: MirCtx) -> TypeExpr throws { Exn } do
  match lookup_known_ret_type(name, ctx) do
    | Some(val: t) -> return t
    | None -> return TyI64
  end
end

let lookup_ret_in_functions = fn (name: string, functions: [HirFunction]) -> Option<TypeExpr> do
  match functions do
    | [] -> return None
    | HirFunction(name: n, type_params: _, params: _, ret_type: rt, body: _, span: _) :: rest ->
      if n == name then return Some(val: rt)
      else return lookup_ret_in_functions(name, functions: rest)
      end
  end
end

let lookup_ret_in_handlers = fn (name: string, bindings: [HirHandlerBindingEntry]) -> Option<TypeExpr> do
  match bindings do
    | [] -> return None
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, functions: fs)) :: rest ->
      let found = lookup_ret_in_functions(name, functions: fs)
      match found do
        | Some(_) -> return found
        | None -> return lookup_ret_in_handlers(name, bindings: rest)
      end
  end
end

let lookup_ret_in_externals = fn (name: string, externals: [HirExternal]) -> Option<TypeExpr> do
  match externals do
    | [] -> return None
    | HirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: rt, throw_row: _) :: rest ->
      if n == name then return Some(val: rt)
      else return lookup_ret_in_externals(name, externals: rest)
      end
  end
end

// ─── Port Call Detection ────────────────────────────────────────────────────

/// Check if a function name is a port-qualified call. Returns (port_name, method_name) if so.
export let detect_port_call = fn (func: string, port_layouts: [PortEntry]) -> PortCallResult do
  match port_layouts do
    | [] -> return PortCallNotFound
    | PortEntry(name: pname, prefix, methods: _) :: rest ->
      if str.starts_with(s: func, prefix) then
        let plen = str.length(s: prefix)
        let method = str.substring(s: func, start: plen, len: str.length(s: func) - plen)
        return PortCallFound(port_name: pname, method_name: method)
      else
        return detect_port_call(func, port_layouts: rest)
      end
  end
end
