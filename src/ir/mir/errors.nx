/**
 * mir/errors: MIR-phase exception types.
 *
 * Raised when MIR construction cannot resolve a port-handler binding.
 * E5xxx codes in `format_error`.
 */

// ─── MIR exceptions ─────────────────────────────────────────────────────────

/** Public exception MirPortHandlerNotFound. */
export exception MirPortHandlerNotFound(port_name: string, method_name: string)

/** Public exception group MirError. */
export exception group MirError = MirPortHandlerNotFound
