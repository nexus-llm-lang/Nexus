/**
 * mir/errors: MIR-phase exception types.
 *
 * Raised when MIR construction cannot resolve a cap-handler binding.
 * E5xxx codes in `format_error`.
 */


/** Public exception MirCapHandlerNotFound. */
export exception MirCapHandlerNotFound(cap_name: string, method_name: string)

/** Public exception MirMultiArgSuspend: cap method with `with @k` called with
 *  more than one argument. The wasm suspend instruction carries a single payload
 *  value; multi-arg packing across the suspend/resume boundary is unspecified.
 *  Rejected defensively until a spec amendment defines the ABI.
 */
export exception MirMultiArgSuspend(cap_name: string, method_name: string, arg_count: i64)

/** Public exception group MirError. */
export exception group MirError = MirCapHandlerNotFound | MirMultiArgSuspend
