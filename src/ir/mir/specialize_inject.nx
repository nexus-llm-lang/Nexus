/**
 * specialize_inject: MIR analysis and direct-call confirmation pass for
 * inject-handler specialization.
 *
 * Owns:
 * - Walking MirProgram to identify __handler_* call sites (Phase 1 analysis).
 * - Confirming that every cap-method call inside an inject scope has been
 *   resolved to a direct MirCall (Phase 2 rewrite confirmation — the actual
 *   rewrite is done by lower_port_call in mir.nx during HIR→MIR lowering).
 * - Counting and reporting specialized vs. total call sites (Phase 3 summary).
 *
 * Context:
 * The HIR→MIR lowering pass (src/ir/mir/mir.nx, lower_port_call) already
 * converts every `Console.println(...)` form to
 * `MirCall(func: "__handler_<binding>_<method>", ...)` at injection time.
 * This pass validates that result and provides the specialization statistics
 * described in (132 inject-scope call sites, 103 in driver main).
 *
 * Does not own:
 * - The actual HIR→MIR port-call rewrite (see src/ir/mir/mir.nx lower_port_call).
 * - LIR DCE pass that removes unused __handler_* functions after specialization
 *   (see src/ir/lir/opt.nx).
 */
import { MirProgram, MirFunction, MirStmt, MirExpr, MirCallArg, MirMatchCase, MirNamedExpr } from "src/ir/mir/types.nx"
import { MirError } from "src/ir/mir/errors.nx"
import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"


/** Summary of the inject-handler specialization analysis.
 *  `specialized` = number of MirCall sites whose callee is a `__handler_*`
 *  function (i.e., calls that were converted from port-dispatch to direct-call
 *  by lower_port_call during HIR→MIR lowering).
 *  `total_calls` = total MirCall + MirCallClosure sites scanned.
 */
export type SpecializeResult = SpecializeResult(specialized: i64, total_calls: i64)


/** Scan `mir` and return specialization statistics.
 *
 *  This is a pure analysis pass — it does not mutate `mir`.  The returned
 *  SpecializeResult lets the driver report how many call sites were resolved to
 *  direct handler calls during HIR→MIR lowering.
 *
 *  The scan uses an iterative worklist (DFS via a list-as-stack) rather than
 *  mutual recursion, so it does not overflow the call stack on large MirPrograms
 *  like main.nx.  All statement kinds are fully visited including
 *  MirStmtTry body + catch_body, MirIf then/else bodies, MirMatch arms, and
 *  MirWhile body.
 */
export let analyze_specialization = fn (mir: MirProgram) -> SpecializeResult throws { MirError } do
  let MirProgram(functions: funcs, externals: _) = mir
  return scan_functions(funcs: funcs, specialized: 0, total_calls: 0)
end


let scan_functions = fn (funcs: [MirFunction], specialized: i64, total_calls: i64) -> SpecializeResult throws { MirError } do
  match funcs do
    | [] -> return SpecializeResult(specialized, total_calls)
    | MirFunction(name: _, params: _, ret_type: _, body: stmts, span: _) :: rest ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_worklist(worklist: stmts, specialized, total_calls)
      return scan_functions(funcs: rest, specialized: s2, total_calls: t2)
  end
end


/** Iterative DFS over a [MirStmt] worklist.
 *
 *  Instead of recursing from scan_stmt into scan_expr and back into nested
 *  scan_stmts (which overflows on large functions), we keep a flat worklist
 *  of statements.  When a statement's expression contains nested statement
 *  lists (MirIf then/else, MirMatch arms, MirWhile body, MirStmtTry bodies)
 *  we prepend those lists to the worklist and continue iterating.
 *
 *  Expression sub-expressions that are NOT statement containers (MirBinaryOp
 *  children, MirConstructor args, etc.) are scanned eagerly in scan_expr_deep
 *  which only recurses into expressions, never back into stmt-lists.
 *
 *  This keeps the Nexus call stack depth bounded at:
 *    scan_functions → scan_worklist → scan_expr_deep → scan_call_args
 *  (4 frames, regardless of nesting depth in the source program).
 */
let scan_worklist = fn (worklist: [MirStmt], specialized: i64, total_calls: i64) -> SpecializeResult throws { MirError } do
  match worklist do
    | [] -> return SpecializeResult(specialized, total_calls)
    | stmt :: rest ->
      let ScanStmtResult(next_stmts: extra, specialized: s2, total_calls: t2) =
        process_stmt(stmt: stmt, specialized, total_calls)
      // prepend extra stmts (nested bodies) to the remaining worklist
      let new_worklist = list.concat(xs: extra, ys: rest)
      return scan_worklist(worklist: new_worklist, specialized: s2, total_calls: t2)
  end
end


/** Intermediate result of processing one statement.
 *  `next_stmts` = nested statement lists to push onto the worklist (DFS order).
 */
type ScanStmtResult = ScanStmtResult(next_stmts: [MirStmt], specialized: i64, total_calls: i64)

/** Process a single MirStmt:
 *  - scan its direct expression(s) for call sites;
 *  - collect any nested [MirStmt] bodies into `next_stmts` for the worklist.
 */
let process_stmt = fn (stmt: MirStmt, specialized: i64, total_calls: i64) -> ScanStmtResult throws { MirError } do
  match stmt do
    | MirStmtLet(name: _, typ: _, expr: e) ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_deep(expr: e, specialized, total_calls)
      let extra = collect_expr_stmts(expr: e)
      return ScanStmtResult(next_stmts: extra, specialized: s2, total_calls: t2)

    | MirStmtExpr(expr: e) ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_deep(expr: e, specialized, total_calls)
      let extra = collect_expr_stmts(expr: e)
      return ScanStmtResult(next_stmts: extra, specialized: s2, total_calls: t2)

    | MirStmtReturn(expr: e) ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_deep(expr: e, specialized, total_calls)
      let extra = collect_expr_stmts(expr: e)
      return ScanStmtResult(next_stmts: extra, specialized: s2, total_calls: t2)

    | MirStmtAssign(target: t, value: v) ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_deep(expr: t, specialized, total_calls)
      let SpecializeResult(specialized: s3, total_calls: t3) = scan_expr_deep(expr: v, specialized: s2, total_calls: t2)
      let extra_t = collect_expr_stmts(expr: t)
      let extra_v = collect_expr_stmts(expr: v)
      let extra = list.concat(xs: extra_t, ys: extra_v)
      return ScanStmtResult(next_stmts: extra, specialized: s3, total_calls: t3)

    | MirStmtTry(body: try_body, catch_param: _, catch_body: catch_stmts) ->
      // Both the try body and catch body are pushed onto the worklist.
      let extra = list.concat(xs: try_body, ys: catch_stmts)
      return ScanStmtResult(next_stmts: extra, specialized, total_calls)

    | MirStmtInjectResume(body_fn: _, handler_arm_fns: _, handler_arm_tags: _) ->
      // Stack-switching inject resume — body is a lifted function; call sites
      // are already counted when scanning the lifted __inject_N function.
      return ScanStmtResult(next_stmts: [], specialized, total_calls)
  end
end


/** Collect all nested [MirStmt] bodies directly owned by an expression.
 *  These are the bodies that need to be added to the worklist so the
 *  iterative walk visits them.  We only collect ONE level of nesting here;
 *  the worklist loop handles the rest.
 */
let collect_expr_stmts = fn (expr: MirExpr) -> [MirStmt] do
  match expr do
    | MirIf(cond: _, then_body: tb, else_body: eb) ->
      match eb do
        | None -> return tb
        | Some(val: else_stmts) -> return list.concat(xs: tb, ys: else_stmts)
      end
    | MirMatch(target: _, cases: mc) ->
      return collect_match_case_stmts(cases: mc)
    | MirWhile(cond: _, body: wb) ->
      return wb
    | _ -> return []
  end
end

/** Flatten MirMatchCase bodies into a single [MirStmt] list. */
let collect_match_case_stmts = fn (cases: [MirMatchCase]) -> [MirStmt] do
  match cases do
    | [] -> return []
    | MirMatchCase(pattern: _, body: b) :: rest ->
      return list.concat(xs: b, ys: collect_match_case_stmts(cases: rest))
  end
end


/** Scan an expression for direct MirCall sites.
 *
 *  This function recurses into expression sub-trees (MirBinaryOp operands,
 *  MirConstructor args, MirRaise/MirForce inner exprs, call args, etc.) but
 *  does NOT recurse into nested statement lists (MirIf then/else, MirMatch
 *  arms, MirWhile body).  Those statement lists are handled by the worklist
 *  in scan_worklist / collect_expr_stmts.
 *
 *  Stack depth is bounded by expression nesting depth, which in practice is
 *  shallow (a few levels of BinaryOp / MirIf cond / call-arg nesting).
 */
let scan_expr_deep = fn (expr: MirExpr, specialized: i64, total_calls: i64) -> SpecializeResult throws { MirError } do
  match expr do
    | MirCall(func: f, args, ret_type: _) ->
      let new_total = total_calls + 1
      let new_spec = if str.starts_with(s: f, prefix: "__handler_") then specialized + 1 else specialized end
      return scan_call_args(args: args, specialized: new_spec, total_calls: new_total)

    | MirCallClosure(closure: cl, args: cargs, ret_type: _) ->
      let new_total = total_calls + 1
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_deep(expr: cl, specialized, total_calls: new_total)
      return scan_call_args(args: cargs, specialized: s2, total_calls: t2)

    | MirBinaryOp(left: lhs, op: _, right: rhs) ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_deep(expr: lhs, specialized, total_calls)
      return scan_expr_deep(expr: rhs, specialized: s2, total_calls: t2)

    | MirConstructor(name: _, args: ctor_args) ->
      return scan_expr_list(exprs: ctor_args, specialized, total_calls)

    | MirArray(elems) ->
      return scan_expr_list(exprs: elems, specialized, total_calls)

    | MirRecord(fields: fs) ->
      return scan_named_expr_list(fields: fs, specialized, total_calls)

    | MirIndex(target: tgt, index: idx) ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_deep(expr: tgt, specialized, total_calls)
      return scan_expr_deep(expr: idx, specialized: s2, total_calls: t2)

    | MirFieldAccess(target: tgt, field: _) ->
      return scan_expr_deep(expr: tgt, specialized, total_calls)

    | MirRaise(expr: inner) ->
      return scan_expr_deep(expr: inner, specialized, total_calls)

    | MirForce(expr: inner) ->
      return scan_expr_deep(expr: inner, specialized, total_calls)

    | MirMakeClosure(func_name: _, captures: caps) ->
      return scan_expr_list(exprs: caps, specialized, total_calls)

    | MirSuspend(tag_name: _, payload: p, ret_type: _) ->
      return scan_expr_deep(expr: p, specialized, total_calls)

    | MirResume(cont_var: _, value: v, ret_type: _) ->
      return scan_expr_deep(expr: v, specialized, total_calls)

    // Compound exprs with stmt-list bodies: scan the cond/target expr only;
    // the nested stmt-lists are handled by collect_expr_stmts + worklist.
    | MirIf(cond: c, then_body: _, else_body: _) ->
      return scan_expr_deep(expr: c, specialized, total_calls)

    | MirMatch(target: tgt, cases: _) ->
      return scan_expr_deep(expr: tgt, specialized, total_calls)

    | MirWhile(cond: c, body: _) ->
      return scan_expr_deep(expr: c, specialized, total_calls)

    // Leaf expressions with no sub-expressions.
    | MirLiteral(_) -> return SpecializeResult(specialized, total_calls)
    | MirVariable(_) -> return SpecializeResult(specialized, total_calls)
    | MirBorrow(_) -> return SpecializeResult(specialized, total_calls)
    | MirEnvLoad(env_var: _, index: _) -> return SpecializeResult(specialized, total_calls)
  end
end


let scan_expr_list = fn (exprs: [MirExpr], specialized: i64, total_calls: i64) -> SpecializeResult throws { MirError } do
  match exprs do
    | [] -> return SpecializeResult(specialized, total_calls)
    | e :: rest ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_deep(expr: e, specialized, total_calls)
      return scan_expr_list(exprs: rest, specialized: s2, total_calls: t2)
  end
end

let scan_named_expr_list = fn (fields: [MirNamedExpr], specialized: i64, total_calls: i64) -> SpecializeResult throws { MirError } do
  match fields do
    | [] -> return SpecializeResult(specialized, total_calls)
    | MirNamedExpr(name: _, value: v) :: rest ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_deep(expr: v, specialized, total_calls)
      return scan_named_expr_list(fields: rest, specialized: s2, total_calls: t2)
  end
end


/** Scan call arguments for nested handler calls. */
let scan_call_args = fn (args: [MirCallArg], specialized: i64, total_calls: i64) -> SpecializeResult throws { MirError } do
  match args do
    | [] -> return SpecializeResult(specialized, total_calls)
    | MirCallArg(label: _, value: v) :: rest ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_deep(expr: v, specialized, total_calls)
      return scan_call_args(args: rest, specialized: s2, total_calls: t2)
  end
end
