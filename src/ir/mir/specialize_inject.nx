/**
 * specialize_inject: MIR analysis and direct-call confirmation pass for
 * inject-handler specialization (nexus-p2d8.1).
 *
 * Owns:
 * - Walking MirProgram to identify __handler_* call sites (Phase 1 analysis).
 * - Confirming that every cap-method call inside an inject scope has been
 *   resolved to a direct MirCall (Phase 2 rewrite confirmation — the actual
 *   rewrite is done by lower_port_call in mir.nx during HIR→MIR lowering).
 * - Counting and reporting specialized vs. total call sites (Phase 3 summary).
 *
 * Context:
 * The HIR→MIR lowering pass (src/ir/mir/mir.nx, lower_port_call) already
 * converts every `Console.println(...)` form to
 * `MirCall(func: "__handler_<binding>_<method>", ...)` at injection time.
 * This pass validates that result and provides the specialization statistics
 * described in nexus-p2d8.1 (132 inject-scope call sites, 103 in driver main).
 *
 * Does not own:
 * - The actual HIR→MIR port-call rewrite (see src/ir/mir/mir.nx lower_port_call).
 * - LIR DCE pass that removes unused __handler_* functions after specialization
 *   (see src/ir/lir/opt.nx).
 */
import { MirProgram, MirFunction, MirStmt, MirExpr, MirCallArg, MirMatchCase, MirNamedExpr } from "src/ir/mir/types.nx"
import { MirError } from "src/common/error.nx"
import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"

// ─── Result type ────────────────────────────────────────────────────────────

/** Summary of the inject-handler specialization analysis.
 *  `specialized` = number of MirCall sites whose callee is a `__handler_*`
 *  function (i.e., calls that were converted from port-dispatch to direct-call
 *  by lower_port_call during HIR→MIR lowering).
 *  `total_calls` = total MirCall + MirCallClosure sites scanned.
 */
export type SpecializeResult = SpecializeResult(specialized: i64, total_calls: i64)

// ─── Public entry point ──────────────────────────────────────────────────────

/** Scan `mir` and return specialization statistics.
 *
 *  This is a pure analysis pass — it does not mutate `mir`.  The returned
 *  SpecializeResult lets the driver report how many call sites were resolved to
 *  direct handler calls during HIR→MIR lowering.
 *
 *  The scan is deliberately shallow: only the top-level statements of each
 *  MirFunction body are inspected (not recursing into sub-expressions such as
 *  if-then-else bodies or match arms).  This keeps the call stack depth bounded
 *  regardless of MIR complexity, while still capturing all inject-scope handler
 *  calls (which appear as direct MirStmtLet / MirStmtExpr / MirStmtReturn at
 *  the top level of the function body after HIR→MIR inject-inlining).
 */
export let analyze_specialization = fn (mir: MirProgram) -> SpecializeResult throws { MirError } do
  let MirProgram(functions: funcs, externals: _) = mir
  return scan_functions(funcs: funcs, specialized: 0, total_calls: 0)
end

// ─── Function-level scan ────────────────────────────────────────────────────

let scan_functions = fn (funcs: [MirFunction], specialized: i64, total_calls: i64) -> SpecializeResult throws { MirError } do
  match funcs do
    | [] -> return SpecializeResult(specialized, total_calls)
    | MirFunction(name: _, params: _, ret_type: _, body: stmts, span: _) :: rest ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_stmts(stmts: stmts, specialized, total_calls)
      return scan_functions(funcs: rest, specialized: s2, total_calls: t2)
  end
end

// ─── Statement-level scan (shallow: recurse into stmt exprs, not into
//     nested stmt-lists like if-bodies or match arms) ────────────────────────

let scan_stmts = fn (stmts: [MirStmt], specialized: i64, total_calls: i64) -> SpecializeResult throws { MirError } do
  match stmts do
    | [] -> return SpecializeResult(specialized, total_calls)
    | stmt :: rest ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_stmt_top(stmt: stmt, specialized, total_calls)
      return scan_stmts(stmts: rest, specialized: s2, total_calls: t2)
  end
end

/** Shallow statement scan: inspect the direct expression of a statement.
 *  For compound statements (Try, Assign) we also inspect the immediate
 *  sub-expressions.  We do NOT recurse into nested statement lists
 *  (then-bodies, else-bodies, match arms, while bodies) to keep depth bounded.
 */
let scan_stmt_top = fn (stmt: MirStmt, specialized: i64, total_calls: i64) -> SpecializeResult throws { MirError } do
  match stmt do
    | MirStmtLet(name: _, typ: _, expr: e) ->
      return scan_expr_shallow(expr: e, specialized, total_calls)
    | MirStmtExpr(expr: e) ->
      return scan_expr_shallow(expr: e, specialized, total_calls)
    | MirStmtReturn(expr: e) ->
      return scan_expr_shallow(expr: e, specialized, total_calls)
    | MirStmtAssign(target: t, value: v) ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_shallow(expr: t, specialized, total_calls)
      return scan_expr_shallow(expr: v, specialized: s2, total_calls: t2)
    | MirStmtTry(body: _, catch_param: _, catch_body: _) ->
      // Try bodies will be scanned as part of the outer function body loop;
      // skip recursing here to keep depth bounded.
      return SpecializeResult(specialized, total_calls)
    | MirStmtInjectResume(body_fn: _, handler_arm_fns: _, handler_arm_tags: _) ->
      // Stack-switching inject resume — body is a lifted function; call sites
      // are already counted when scanning the lifted __inject_N function.
      return SpecializeResult(specialized, total_calls)
  end
end

// ─── Shallow expression scan ────────────────────────────────────────────────

/** Inspect an expression for direct MirCall sites.  Only looks at the
 *  expression itself and its immediate call arguments; does not recurse into
 *  nested if-bodies, match arms, or while bodies to avoid unbounded stack depth.
 */
let scan_expr_shallow = fn (expr: MirExpr, specialized: i64, total_calls: i64) -> SpecializeResult throws { MirError } do
  match expr do
    | MirCall(func: f, args, ret_type: _) ->
      let new_total = total_calls + 1
      let new_spec = if str.starts_with(s: f, prefix: "__handler_") then specialized + 1 else specialized end
      return scan_call_args(args: args, specialized: new_spec, total_calls: new_total)

    | MirCallClosure(closure: _, args: cargs, ret_type: _) ->
      let new_total = total_calls + 1
      return scan_call_args(args: cargs, specialized, total_calls: new_total)

    | MirLiteral(_) -> return SpecializeResult(specialized, total_calls)
    | MirVariable(_) -> return SpecializeResult(specialized, total_calls)
    | MirBorrow(_) -> return SpecializeResult(specialized, total_calls)
    | MirEnvLoad(env_var: _, index: _) -> return SpecializeResult(specialized, total_calls)
    | MirBinaryOp(left: _, op: _, right: _) -> return SpecializeResult(specialized, total_calls)
    | MirConstructor(name: _, args: _) -> return SpecializeResult(specialized, total_calls)
    | MirArray(elems: _) -> return SpecializeResult(specialized, total_calls)
    | MirIndex(target: _, index: _) -> return SpecializeResult(specialized, total_calls)
    | MirFieldAccess(target: _, field: _) -> return SpecializeResult(specialized, total_calls)
    | MirIf(cond: _, then_body: _, else_body: _) -> return SpecializeResult(specialized, total_calls)
    | MirMatch(target: _, cases: _) -> return SpecializeResult(specialized, total_calls)
    | MirWhile(cond: _, body: _) -> return SpecializeResult(specialized, total_calls)
    | MirRaise(expr: _) -> return SpecializeResult(specialized, total_calls)
    | MirForce(expr: _) -> return SpecializeResult(specialized, total_calls)
    | MirRecord(fields: _) -> return SpecializeResult(specialized, total_calls)
    | MirMakeClosure(func_name: _, captures: _) -> return SpecializeResult(specialized, total_calls)
    | MirSuspend(tag_name: _, payload: _, ret_type: _) -> return SpecializeResult(specialized, total_calls)
    | MirResume(cont_var: _, value: _, ret_type: _) -> return SpecializeResult(specialized, total_calls)
  end
end

// ─── Argument scanner ────────────────────────────────────────────────────────

/** Scan call arguments for nested handler calls. */
let scan_call_args = fn (args: [MirCallArg], specialized: i64, total_calls: i64) -> SpecializeResult throws { MirError } do
  match args do
    | [] -> return SpecializeResult(specialized, total_calls)
    | MirCallArg(label: _, value: v) :: rest ->
      let SpecializeResult(specialized: s2, total_calls: t2) = scan_expr_shallow(expr: v, specialized, total_calls)
      return scan_call_args(args: rest, specialized: s2, total_calls: t2)
  end
end
