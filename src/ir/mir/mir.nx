/**
 * mir: HIR → MIR lowering.
 *
 * Owns:
 * - Expression / statement / pattern lowering from HIR to MIR (the SCC)
 * - Inject-scope inlining (compile-time effect, no runtime representation)
 * - For-loop → while-loop desugaring
 * - Lambda / handler expressions dropped to Unit (lifted during HIR build)
 * - MirCtx construction + threading; lower_cap_call uses cap.nx for detection
 *   but the call-emission happens here because it calls lower_call_args
 * - Handler-function lowering orchestration via callback injection
 * - lift_lambda orchestrator — calls lower_stmts (mutual recursion with
 *   expression lowering), so it cannot live in mir/lambda_lift.nx without a
 *   cyclic import. The supporting helpers (free-var walker, env-load preamble,
 *   param/ret coercion, top-level-fn wrappers) do live there.
 *
 * Does not own:
 * - MIR type definitions (see src/ir/mir/types.nx)
 * - Cap-layout construction, cap-call detection, return-type lookup,
 *   handler-cap name inference (see src/ir/mir/cap.nx)
 * - Lambda-lift support: free-variable collection, env-load preamble,
 *   lambda param/return coercion, first-class top-level fn wrapping
 *   (see src/ir/mir/lambda_lift.nx)
 * - HirParam → MirParam conversion, single/list/handler function lowering
 *   (see src/ir/mir/func_lower.nx; receives lower_stmts as a callback)
 * - Non-SCC helpers: ctx accessors, scope manipulation, kont helpers,
 *   pattern lowering, list combinators (see src/ir/mir/utils.nx)
 */
import { MirError, MirCapHandlerNotFound, MirMultiArgSuspend } from "src/ir/mir/errors.nx"
import { None } from "std:option"
import * as naming from "src/ir/support/naming.nx"
import * as list from "std:list"
import { SigilLazy } from "src/types/vocab.nx"
import { TypeExpr, TyLazy } from "src/types/type_expr.nx"
import { Span } from "src/types/span.nx"
import {
  HirStmtKind,
  HirExprKind,
  HirCallArg,
  HirParam,
  HirHandlerBindingEntry,
  HirProgram,
  HirNamedExpr,
  HirExpr,
  HirStmt,
  HirMatchCase,
  EagerBody,
  LazyBody
}, * as hir from "src/ir/hir/types.nx"
import {
  MirParam,
  MirFunction,
  MirCallArg,
  MirExpr,
  MirNamedExpr,
  MirStmt,
  MirMatchCase,
  MirProgram,
  NamePair,
  CapEntry,
  CapCallFound,
  CapCallNotFound,
  MirCtx,
  MirExprResult,
  MirStmtsResult,
  MirCallArgsResult,
  MirExprListResult,
  MirNamedExprsResult,
  MirMatchCasesResult,
  LowerFunctionsResult
} from "src/ir/mir/types.nx"
import {
  build_cap_layouts,
  infer_handler_cap_names,
  lookup_handler_by_cap,
  reverse_lookup,
  lookup_ret_type,
  lookup_known_ret_type,
  detect_cap_call,
  cap_index,
  handler_id,
  cap_needs_runtime_dispatch,
  handlers_for_cap
} from "src/ir/mir/cap.nx"
import {
  lower_lambda_params,
  lower_lambda_ret_type,
  lookup_top_level_fn,
  wrap_top_level_fn,
  build_env_load_preamble,
  captures_to_mir_exprs,
  param_names_of,
  build_known_names,
  collect_hir_free_vars
} from "src/ir/mir/lambda_lift.nx"
import { lower_functions, lower_handler_functions } from "src/ir/mir/func_lower.nx"
import { build_cap_dispatchers } from "src/ir/mir/dispatch.nx"
import {
  ctx_cont_binders, ctx_value_binding_names, ctx_thunk_param_names, ctx_with_thunk_param_names,
  list_has,
  lookup, insert_or_replace, insert_if_absent, activate_handlers, append_name_pairs,
  build_handler_cap_names, build_global_cap_handlers,
  lower_externals,
  any_handler_has_kont, collect_with_kont_arm_fns, collect_with_kont_arm_tags,
  resolve_alias_call_target, arm_cont_binder,
  i64_to_str, append_mir_funcs, concat_mir_funcs, concat_mir_stmts,
  lower_pattern
} from "src/ir/mir/utils.nx"

/** Public function lower_hir_to_mir. */
export let lower_hir_to_mir = fn (hir: HirProgram) -> MirProgram throws { MirError } do
  let HirProgram(
    caps,
    functions: funcs,
    externals: exts,
    handler_bindings: hbs,
    enum_defs: _,
    exception_groups: _,
    value_binding_names: vbns,
    type_defs: _,
    visible_enum_names: _
  ) = hir
  let cap_layouts = build_cap_layouts(caps)
  let handler_cap_names = build_handler_cap_names(bindings: hbs)
  // If handler_cap_names is empty (ExprHandler matching failed at HIR build),
  // infer from function names + cap methods.
  let inferred = infer_handler_cap_names(funcs, caps)
  let effective_hpn = match handler_cap_names do
    | [] -> inferred
    | _ -> append_name_pairs(a: inferred, b: handler_cap_names)
  end
  let global_scope_base = build_global_cap_handlers(handler_cap_names: effective_hpn)
  // Add Console/Fs/Clock → system_handler ONLY if the user hasn't already
  // bound them. insert_if_absent preserves any user-supplied
  // handler for these standard caps while still providing the implicit
  // default so code like `Console.println("hi")` works without an explicit
  // `inject stdio.system_handler do ... end`.
  let global_scope = insert_if_absent(key: "Console", value: "stdio.system_handler",
    pairs: insert_if_absent(key: "Fs", value: "fs_mod.system_handler",
    pairs: insert_if_absent(key: "Clock", value: "clock_mod.system_handler",
    pairs: global_scope_base)))

  let ctx = MirCtx(
    scope: global_scope,
    cap_layouts,
    handler_cap_names: effective_hpn,
    all_funcs: funcs,
    all_handlers: hbs,
    all_exts: exts,
    closure_counter: 0,
    lifted_funcs: [],
    cont_binders: [],
    value_binding_names: vbns,
    thunk_param_names: []
  )

  let mir_externals = lower_externals(exts)
  // Thread ctx through lowering so inline-lambda lifts accumulate across all
  // functions (and all handler functions), then append lifted __closure_* funcs.
  let funcs_r = lower_functions(functions: funcs, ctx, lower_stmts_fn: lower_stmts)
  let LowerFunctionsResult(ctx: ctx1, funcs: mir_funcs) = funcs_r
  let hfuncs_r = lower_handler_functions(bindings: hbs, ctx: ctx1, lower_stmts_fn: lower_stmts)
    let LowerFunctionsResult(ctx: ctx2, funcs: mir_handler_funcs) = hfuncs_r
    let MirCtx(
        scope: _,
        cap_layouts: _,
        handler_cap_names: _,
        all_funcs: _,
        all_handlers: _,
        all_exts: _,
        closure_counter: _,
        lifted_funcs: lifted,
        cont_binders: _,
        _
      ) = ctx2
      let user_plus_handlers = concat_mir_funcs(a: mir_funcs, b: mir_handler_funcs)
      let with_lifted = concat_mir_funcs(a: user_plus_handlers, b: lifted)
      // Append the runtime dispatchers for any cap with two or more handler
      // bindings (lower_cap_call routes those caps' calls through these).
      let dispatchers = build_cap_dispatchers(caps, bindings: hbs, cap_layouts)
      let all_mir_funcs = concat_mir_funcs(a: with_lifted, b: dispatchers)
      return MirProgram(functions: all_mir_funcs, externals: mir_externals)
end

let lower_stmts = fn (stmts: [ HirStmt ], ctx: MirCtx) -> MirStmtsResult throws { MirError } do
  return lower_stmts_go(stmts, ctx, acc: [])
end

let lower_stmts_go = fn (
  stmts: [ HirStmt ],
  ctx: MirCtx,
  acc: [ MirStmt ]
) -> MirStmtsResult throws { MirError } do
  match stmts do
    | [] -> return MirStmtsResult(ctx, stmts: list.reverse(xs: acc))
    | HirStmt(node: s, span: sp) :: rest ->
      let MirStmtsResult(ctx: ctx2, stmts: lowered) = lower_stmt(stmt: s, span: sp, ctx)
      let new_acc = prepend_stmts_reversed(src: lowered, dst: acc)
        return lower_stmts_go(stmts: rest, ctx: ctx2, acc: new_acc)
  end
end

let prepend_stmts_reversed = fn (
  src: [ MirStmt ],
  dst: [ MirStmt ]
) -> [ MirStmt ] throws { MirError } do
  match src do
    | [] -> return dst
    | x :: rest -> return prepend_stmts_reversed(src: rest, dst: x :: dst)
  end
end

/** Lower a statement. Inject/for desugar may produce multiple MIR stmts;
 *  the ctx also carries forward any `__closure_*` lifts from lambdas inside.
 */
let lower_stmt = fn (
  stmt: HirStmtKind,
  span: Span,
  ctx: MirCtx
) -> MirStmtsResult throws { MirError } do
  match stmt do
    | Let(name: n, sigil: sig, typ: t, value: v) ->
      // HIR Let.typ is None when the user omits the annotation and typecheck
      // has not back-patched it — the HIR is not rewritten after typecheck.
      // LIR lowering recovers the real type via atom_type / semantic_vars
      // tables (see src/ir/lir/context.nx), so the TyUnit placeholder here
      // is only observed by passes that walk MirStmtLet without consulting
      // the atom table (e.g. dump utilities). Pipe work that depends on
      // accurate MIR types is blocked on propagating typecheck's subst into
      // HIR;.
      let mir_typ = match t do
        | Some(val: te) -> te
        | None -> TyUnit
      end
      // Track thunk-typed let bindings so Call(func: n, args) can insert
      // an implicit MirForce when n is a thunk (T-App thunk-callee codegen).
      let is_thunk_let = match sig do
        | SigilLazy -> true
        | _ ->
          match t do
            | Some(val: TyLazy(inner: _, require_row: _, throw_row: _)) -> true
            | _ -> false
          end
      end
      let ctx_for_val = if is_thunk_let then
        let existing = ctx_thunk_param_names(ctx)
        ctx_with_thunk_param_names(ctx, names: n :: existing)
      else
        ctx
      end
      // A `let <n> = fn (...) do ... end` whose body refers to `n` is a
      // recursive local closure (spec types.md:236). Lift it with `n` as the
      // self-name so the self-reference resolves via `__env` rather than being
      // captured by value before the closure cell exists.
      let HirExpr(node: v_node, span: _) = v
      let MirExprResult(ctx: ctx2, expr: mir_val) = match v_node do
        | Lambda(type_params: _, params: lps, ret_type: lret, requires: _, throw_row: _, body: lbody) ->
          lift_lambda_self(params: lps, ret_type: lret, body: lbody, span: v, self_name: n, ctx: ctx_for_val)
        | _ -> lower_expr(expr: v, ctx: ctx_for_val)
      end
      return MirStmtsResult(
          ctx: ctx2,
          stmts: [ MirStmtLet(name: n, typ: mir_typ, expr: mir_val) ]
        )

    | Expr(expr: se) ->
      let HirExpr(node: e, span: _) = se
      match e do
        | For(var, start: s, end_expr: end_e, body: b) ->
          return desugar_for(var, start_expr: s, end_expr: end_e, body: b, ctx)
        | _ ->
          let MirExprResult(ctx: ctx2, expr: mir_e) = lower_expr(expr: se, ctx)
          return MirStmtsResult(ctx: ctx2, stmts: [ MirStmtExpr(expr: mir_e) ])
      end

    | Return(expr: e) ->
      let MirExprResult(ctx: ctx2, expr: mir_e) = lower_expr(expr: e, ctx)
      return MirStmtsResult(ctx: ctx2, stmts: [ MirStmtReturn(expr: mir_e) ])

    | Assign(target: t, value: v) ->
      let MirExprResult(ctx: ctx2, expr: mir_t) = lower_expr(expr: t, ctx)
      let MirExprResult(ctx: ctx3, expr: mir_v) = lower_expr(expr: v, ctx: ctx2)
      return MirStmtsResult(ctx: ctx3, stmts: [ MirStmtAssign(target: mir_t, value: mir_v) ])

    | Try(body: b, catch_param: cp, catch_body: cb) ->
      let MirStmtsResult(ctx: ctx2, stmts: mir_b) = lower_stmts(stmts: b, ctx)
      let MirStmtsResult(ctx: ctx3, stmts: mir_cb) = lower_stmts(stmts: cb, ctx: ctx2)
      return MirStmtsResult(
            ctx: ctx3,
            stmts: [ MirStmtTry(body: mir_b, catch_param: cp, catch_body: mir_cb) ]
          )

    | Inject(handlers: hs, body: b) ->
      let MirCtx(
        scope,
        cap_layouts: pl,
        handler_cap_names: hpn,
        all_funcs: af,
        all_handlers: ah,
        all_exts: ae,
        closure_counter: cc,
        lifted_funcs: lf,
        cont_binders: cb,
        value_binding_names: vbns,
        thunk_param_names: tpn
      ) = ctx
      let new_scope = activate_handlers(handler_names: hs, handler_cap_names: hpn, scope)
      let new_ctx = MirCtx(scope: new_scope, cap_layouts: pl, handler_cap_names: hpn,
                           all_funcs: af, all_handlers: ah, all_exts: ae, closure_counter: cc, lifted_funcs: lf, cont_binders: cb, value_binding_names: vbns, thunk_param_names: tpn)
      // If any handler in this inject has any arm capturing a continuation,
      // route the body through a stack-switching resume frame: lift the body
      // to a fresh MirFunction and replace the inject site with a single
      // MirStmtInjectResume statement that codegen will expand to
      // ref.func + cont.new + resume + on-clauses.
      if any_handler_has_kont(handler_names: hs, bindings: ah) then
        let LiftInjectResult(ctx: ctx2, body_fn: bfn, ret_type: inj_rt, captures: caps) = lift_inject_body(
          stmts: b,
          span,
          ctx: new_ctx
        )
        let arm_fns = collect_with_kont_arm_fns(handler_names: hs, bindings: ah)
          let arm_tags = collect_with_kont_arm_tags(handler_names: hs, bindings: ah)
          let MirCtx(
            scope: _,
            cap_layouts: pl2,
            handler_cap_names: hpn2,
            all_funcs: af2,
            all_handlers: ah2,
            all_exts: ae2,
            closure_counter: cc2,
            lifted_funcs: lf2,
            cont_binders: cb2,
            value_binding_names: vbns2,
            thunk_param_names: tpn2
          ) = ctx2
          // Build the env object from the captured enclosing variables (in scope
          // here at the inject site) and hand it off through the fixed inject-env
          // cell right before the resume frame runs; `__inject_N` reads it back.
          // `MirMakeClosure` gives the `[func_idx@0, cap0@1, ...]` layout the
          // body's env-load preamble expects. When there are no captures the
          // body never calls `__inject_env_get` meaningfully, but the env object
          // (a single func-idx word) is still built and stored harmlessly.
          let env_obj = MirMakeClosure(func_name: bfn, captures: captures_to_mir_exprs(caps, acc: []))
          let env_set = MirStmtExpr(expr: MirCall(
            func: "__inject_env_set",
            args: [ MirCallArg(label: "env", value: env_obj) ],
            ret_type: TyUnit
          ))
          let inject_resume = MirStmtInjectResume(body_fn: bfn, handler_arm_fns: arm_fns, handler_arm_tags: arm_tags, ret_type: inj_rt)
          // For each injected handler whose cap dispatches dynamically (>=2
          // handler bindings program-wide), push its handler id onto the cap's
          // register slot for the dynamic extent of the resume frame and restore
          // it on exit — EXACTLY as the non-kont inject path does via
          // `wrap_inject_register`. Without this, a `with @k` inject leaves the
          // cap's `__hreg` slot holding an enclosing (e.g. outer plain) handler's
          // id, so a same-cap call inside the body dispatches to the WRONG
          // handler, violating inner-shadows-outer. The runtime dispatcher's
          // with-kont arm only fires when the slot holds THIS kont handler's id.
          let runtime_hs = runtime_dispatch_handlers(
            handler_names: hs,
            handler_cap_names: hpn2,
            cap_layouts: pl2,
            bindings: ah2
          )
          let wrapped = wrap_inject_resume_register(
            runtime_hs,
            env_set,
            inject_resume,
            ret_type: inj_rt,
            uniq: cc2
          )
          let cc3 = match runtime_hs do | [] -> cc2 | _ -> cc2 + 1 end
          let restored3 = MirCtx(scope, cap_layouts: pl2, handler_cap_names: hpn2,
                                 all_funcs: af2, all_handlers: ah2, all_exts: ae2, closure_counter: cc3, lifted_funcs: lf2, cont_binders: cb2, value_binding_names: vbns2, thunk_param_names: tpn2)
          return MirStmtsResult(
            ctx: restored3,
            stmts: wrapped
          )
      end
      // No with-kont arms: existing behaviour — inline body under injected scope.
      let MirStmtsResult(ctx: ctx2, stmts: lowered) = lower_stmts(stmts: b, ctx: new_ctx)
      let MirCtx(
          scope: _,
          cap_layouts: pl2,
          handler_cap_names: hpn2,
          all_funcs: af2,
          all_handlers: ah2,
          all_exts: ae2,
          closure_counter: cc2,
          lifted_funcs: lf2,
          cont_binders: cb2,
          value_binding_names: vbns2,
          thunk_param_names: tpn2
        ) = ctx2
        // For each injected handler whose cap dispatches dynamically (>=2 handler
        // bindings program-wide), push its handler id onto the cap's register
        // slot for the dynamic extent of the body and pop (restore) on exit,
        // including exceptional exit. Single-handler caps need no register
        // bookkeeping — their calls keep the static direct path.
        let runtime_hs = runtime_dispatch_handlers(
          handler_names: hs,
          handler_cap_names: hpn2,
          cap_layouts: pl2,
          bindings: ah2
        )
        let wrapped = wrap_inject_register(runtime_hs, body: lowered, uniq: cc2)
        let cc3 = match runtime_hs do | [] -> cc2 | _ -> cc2 + 1 end
        let restored = MirCtx(scope, cap_layouts: pl2, handler_cap_names: hpn2,
                              all_funcs: af2, all_handlers: ah2, all_exts: ae2, closure_counter: cc3, lifted_funcs: lf2, cont_binders: cb2, value_binding_names: vbns2, thunk_param_names: tpn2)
        return MirStmtsResult(ctx: restored, stmts: wrapped)
  end
end

/** A runtime-dispatch handler activation in an inject: the cap's register slot
 *  index and the handler id to push onto it. */
type RuntimeHandler = RuntimeHandler(cap_idx: i64, handler_id: i64)

/** Wrap a lowered inject body so that, for the dynamic extent of the body, each
 *  runtime-dispatch cap's register slot holds its injected handler's id, and is
 *  restored to its previous value on EVERY exit path: normal completion,
 *  exception, AND early `return` out of the inject body.
 *
 *  Emits:
 *    let __hsave_<uniq>_<k> = __hreg_get(cap_idx_k)   // save each slot
 *    __hreg_set(cap_idx_k, id_k)                       // set each slot
 *    try
 *      <body'>                                         // body with returns rewritten
 *      __hreg_set(cap_idx_k, __hsave_<uniq>_<k>)       // restore (normal path)
 *    catch __hexn_<uniq> ->
 *      __hreg_set(cap_idx_k, __hsave_<uniq>_<k>)        // restore (throw path)
 *      throw __hexn_<uniq>                               // rethrow
 *    end
 *
 *  <body'> is the original body with every `return e` rewritten to
 *    `let __hret_<uniq> = e; <restores>; return __hret_<uniq>`
 *  so the register slot is discharged on the return path too. Without this
 *  rewrite an early return out of the inject body would leak the inner
 *  handler's id into the enclosing dynamic scope, causing subsequent same-cap
 *  calls to dispatch to the wrong handler. Nested injects compose naturally
 *  because their own wrap already produced inner-restore-then-return tails;
 *  the outer rewrite then layers its restore before each such return.
 *
 *  With no runtime handlers, the body is returned unchanged.
 */
let wrap_inject_register = fn (
  runtime_hs: [ RuntimeHandler ],
  body: [ MirStmt ],
  uniq: i64
) -> [ MirStmt ] throws { MirError } do
  match runtime_hs do
    | [] -> return body
    | _ ->
      let saves = build_saves(runtime_hs, uniq, idx: 0, acc: [])
      let sets = build_sets(runtime_hs, acc: [])
      let restores = build_restores(runtime_hs, uniq, idx: 0, acc: [])
      let exn_name = "__hexn_" ++ i64_to_str(uniq)
      let ret_tmp = "__hret_" ++ i64_to_str(uniq)
      let hval_tmp = "__hval_" ++ i64_to_str(uniq)
      let body_rw = rewrite_returns_in_stmts(stmts: body, restores, ret_tmp)
      let catch_body = concat_mir_stmts(
        a: restores,
        b: [ MirStmtExpr(expr: MirRaise(expr: MirVariable(name: exn_name))) ]
      )
      let rev = list.reverse(xs: body_rw)
      match rev do
        | MirStmtExpr(expr: trailing_e) :: rest_rev ->
          // The inject body has an implicit trailing-value expression.  The
          // register-restore statements (which evaluate to unit) must run
          // BEFORE yielding that value, but they cannot be appended after the
          // trailing MirStmtExpr because LIR's lower_block (used for try
          // bodies) ignores trailing bare expressions — it never captures them
          // as the block result.
          //
          // Fix: thread the value through a local variable slot (__hval_N)
          // that is visible both inside and outside the try body:
          //
          //   let __hval_N = 0          // initialise slot (default)
          //   saves; sets
          //   try {
          //     <prefix stmts>
          //     __hval_N = trailing_e   // assign slot inside try
          //     restores
          //   } catch exn { restores; throw exn }
          //   MirStmtExpr(__hval_N)     // yield value OUTSIDE the try
          //
          // The MirStmtExpr(__hval_N) outside the try is the last stmt of
          // the inject's lowered form.  When inject is the last statement of
          // a function body, lir_lower_stmts (which DOES capture trailing
          // bare expressions) sees it and uses it as the function's return
          // value.  When inject is mid-function the value is discarded (same
          // as the old behaviour for unit-inject).
          //
          // Wasm local variables persist across try_table boundaries (they
          // are not scoped to blocks), so local.set inside the try body and
          // local.get after are correctly sequenced.
          //
          // For nested injects, the inner inject's trailing MirStmtExpr
          // (__hval_inner) becomes the last stmt of the outer inject's body,
          // where the outer hoist picks it up and assigns it to __hval_outer.
          let prefix = list.reverse(xs: rest_rev)
          // Initialize slot to a zero-value (default in case of early throw).
          let init_stmt = MirStmtLet(
            name: hval_tmp,
            typ: TyI64,
            expr: MirLiteral(lit: LitInt(val: 0))
          )
          // Assign the trailing value to the slot inside the try body.
          let assign_stmt = MirStmtAssign(
            target: MirVariable(name: hval_tmp),
            value: trailing_e
          )
          let try_body = concat_mir_stmts(
            a: prefix,
            b: concat_mir_stmts(a: [ assign_stmt ], b: restores)
          )
          let try_stmt = MirStmtTry(body: try_body, catch_param: exn_name, catch_body)
          // Expose the slot value as a trailing bare expression so the caller
          // (lir_lower_stmts for function bodies) can capture it.
          let result_stmt = MirStmtExpr(expr: MirVariable(name: hval_tmp))
          return concat_mir_stmts(
            a: [ init_stmt ],
            b: concat_mir_stmts(
              a: saves,
              b: concat_mir_stmts(
                a: sets,
                b: concat_mir_stmts(a: [ try_stmt ], b: [ result_stmt ])
              )
            )
          )
        | _ ->
          // No implicit trailing value.  Covers: empty body, all-return
          // bodies, nested inject where the inner inject's trailing
          // MirStmtExpr is already in place and will be picked up by the
          // outer hoist, and any unit-producing body where the trailing stmt
          // is MirStmtLet/MirStmtTry/MirStmtAssign.
          let try_body = concat_mir_stmts(a: body_rw, b: restores)
          let try_stmt = MirStmtTry(body: try_body, catch_param: exn_name, catch_body)
          return concat_mir_stmts(a: saves, b: concat_mir_stmts(a: sets, b: [ try_stmt ]))
      end
  end
end

/** Rewrite every `MirStmtReturn(e)` inside `stmts` to a sequence that runs the
 *  inject's restores BEFORE the return: `let <ret_tmp> = e; <restores>; return <ret_tmp>`.
 *  Recurses through control-flow stmts (Try, If/While/Match/Block in expression
 *  position via MirStmtExpr) but does NOT cross MirMakeClosure boundaries —
 *  returns inside a nested lambda body belong to that lambda's separately-lifted
 *  MirFunction, not the current inject's enclosing function. */
let rewrite_returns_in_stmts = fn (
  stmts: [ MirStmt ],
  restores: [ MirStmt ],
  ret_tmp: string
) -> [ MirStmt ] throws { MirError } do
  match stmts do
    | [] -> return []
    | s :: rest ->
      let s2 = rewrite_returns_in_stmt(stmt: s, restores, ret_tmp)
      let rest2 = rewrite_returns_in_stmts(stmts: rest, restores, ret_tmp)
      return concat_mir_stmts(a: s2, b: rest2)
  end
end

let rewrite_returns_in_stmt = fn (
  stmt: MirStmt,
  restores: [ MirStmt ],
  ret_tmp: string
) -> [ MirStmt ] throws { MirError } do
  match stmt do
    | MirStmtReturn(expr: e) ->
      // The return expression itself does not produce a nested return, so we
      // do not recurse into it. Hoist e into ret_tmp, run restores, then return.
      let let_stmt = MirStmtLet(name: ret_tmp, typ: TyI64, expr: e)
      let tail = [ MirStmtReturn(expr: MirVariable(name: ret_tmp)) ]
      return concat_mir_stmts(a: [ let_stmt ], b: concat_mir_stmts(a: restores, b: tail))
    | MirStmtTry(body: b, catch_param: cp, catch_body: cb) ->
      // Nested try: rewrite returns in both arms. The cp binding does not
      // shadow anything we touch (ret_tmp is __hret_<uniq>, exn names use a
      // disjoint __hexn_<uniq> namespace).
      let b2 = rewrite_returns_in_stmts(stmts: b, restores, ret_tmp)
      let cb2 = rewrite_returns_in_stmts(stmts: cb, restores, ret_tmp)
      return [ MirStmtTry(body: b2, catch_param: cp, catch_body: cb2) ]
    | MirStmtExpr(expr: e) ->
      let e2 = rewrite_returns_in_expr(expr: e, restores, ret_tmp)
      return [ MirStmtExpr(expr: e2) ]
    | MirStmtLet(name: n, typ: t, expr: e) ->
      let e2 = rewrite_returns_in_expr(expr: e, restores, ret_tmp)
      return [ MirStmtLet(name: n, typ: t, expr: e2) ]
    | MirStmtAssign(target: tgt, value: v) ->
      // No returns can appear inside target/value expression trees in the
      // surface language; pass through.
      return [ MirStmtAssign(target: tgt, value: v) ]
    | MirStmtInjectResume(body_fn: _, handler_arm_fns: _, handler_arm_tags: _, ret_type: _) ->
      // body_fn is a separately-lifted MirFunction; its returns are not ours.
      return [ stmt ]
  end
end

/** Recurse into expressions that carry nested stmt lists (If/While/Match/Block
 *  in expression position). Other expression shapes are pass-through. We do NOT
 *  descend into MirMakeClosure / nested closures — those bind their own returns
 *  via their lifted MirFunction body. */
let rewrite_returns_in_expr = fn (
  expr: MirExpr,
  restores: [ MirStmt ],
  ret_tmp: string
) -> MirExpr throws { MirError } do
  match expr do
    | MirIf(cond: c, then_body: tb, else_body: eb) ->
      let tb2 = rewrite_returns_in_stmts(stmts: tb, restores, ret_tmp)
      let eb2 = match eb do
        | Some(val: ebs) -> Some(val: rewrite_returns_in_stmts(stmts: ebs, restores, ret_tmp))
        | None -> None
      end
      return MirIf(cond: c, then_body: tb2, else_body: eb2)
    | MirMatch(target: t, cases: cs) ->
      let cs2 = rewrite_returns_in_cases(cases: cs, restores, ret_tmp)
      return MirMatch(target: t, cases: cs2)
    | MirWhile(cond: c, body: b) ->
      let b2 = rewrite_returns_in_stmts(stmts: b, restores, ret_tmp)
      return MirWhile(cond: c, body: b2)
    | MirBlock(stmts: ss) ->
      let ss2 = rewrite_returns_in_stmts(stmts: ss, restores, ret_tmp)
      return MirBlock(stmts: ss2)
    | _ -> return expr
  end
end

let rewrite_returns_in_cases = fn (
  cases: [ MirMatchCase ],
  restores: [ MirStmt ],
  ret_tmp: string
) -> [ MirMatchCase ] throws { MirError } do
  match cases do
    | [] -> return []
    | MirMatchCase(pattern: p, body: b) :: rest ->
      let b2 = rewrite_returns_in_stmts(stmts: b, restores, ret_tmp)
      return MirMatchCase(
        pattern: p,
        body: b2
      ) :: rewrite_returns_in_cases(cases: rest, restores, ret_tmp)
  end
end

let hreg_save_name = fn (uniq: i64, idx: i64) -> string do
  return "__hsave_" ++ i64_to_str(uniq) ++ "_" ++ i64_to_str(idx)
end

let build_saves = fn (
  runtime_hs: [ RuntimeHandler ],
  uniq: i64,
  idx: i64,
  acc: [ MirStmt ]
) -> [ MirStmt ] do
  match runtime_hs do
    | [] -> return list.reverse(xs: acc)
    | RuntimeHandler(cap_idx: cidx, handler_id: _) :: rest ->
      let stmt = MirStmtLet(
        name: hreg_save_name(uniq, idx),
        typ: TyI64,
        expr: MirCall(
          func: "__hreg_get",
          args: [ MirCallArg(label: "cap_idx", value: MirLiteral(lit: LitInt(val: cidx))) ],
          ret_type: TyI64
        )
      )
      return build_saves(runtime_hs: rest, uniq, idx: idx + 1, acc: stmt :: acc)
  end
end

let build_sets = fn (runtime_hs: [ RuntimeHandler ], acc: [ MirStmt ]) -> [ MirStmt ] do
  match runtime_hs do
    | [] -> return list.reverse(xs: acc)
    | RuntimeHandler(cap_idx: cidx, handler_id: hid) :: rest ->
      let stmt = MirStmtExpr(expr: MirCall(
        func: "__hreg_set",
        args: [
          MirCallArg(label: "cap_idx", value: MirLiteral(lit: LitInt(val: cidx))),
          MirCallArg(label: "id", value: MirLiteral(lit: LitInt(val: hid)))
        ],
        ret_type: TyUnit
      ))
      return build_sets(runtime_hs: rest, acc: stmt :: acc)
  end
end

let build_restores = fn (
  runtime_hs: [ RuntimeHandler ],
  uniq: i64,
  idx: i64,
  acc: [ MirStmt ]
) -> [ MirStmt ] do
  match runtime_hs do
    | [] -> return list.reverse(xs: acc)
    | RuntimeHandler(cap_idx: cidx, handler_id: _) :: rest ->
      let stmt = MirStmtExpr(expr: MirCall(
        func: "__hreg_set",
        args: [
          MirCallArg(label: "cap_idx", value: MirLiteral(lit: LitInt(val: cidx))),
          MirCallArg(label: "id", value: MirVariable(name: hreg_save_name(uniq, idx)))
        ],
        ret_type: TyUnit
      ))
      return build_restores(runtime_hs: rest, uniq, idx: idx + 1, acc: stmt :: acc)
  end
end

/** Wrap a `with @k` inject's `[env_set, inject_resume]` so each runtime-dispatch
 *  cap's register slot holds its injected handler's id for the dynamic extent of
 *  the resume frame, then is restored on exit. This is the kont-arm analogue of
 *  `wrap_inject_register` (non-kont path). It is required so that a same-cap call
 *  reached inside the body dispatches to THIS injected handler — without it the
 *  slot keeps an enclosing (e.g. outer plain) handler's id and the dispatcher
 *  forwards to the wrong handler, violating inner-shadows-outer.
 *
 *  - With no runtime handlers (single-handler caps), returns the pair unchanged.
 *  - For a unit-yielding inject, wraps in `saves; sets; try { env_set;
 *    inject_resume; restores } catch e { restores; throw e }` so the slot is
 *    restored on normal AND exceptional exit.
 *  - For a value-yielding inject, `inject_resume` must remain the trailing
 *    statement for `lir_lower_stmts` to surface the body's value (delivered
 *    out-of-band via the ss_inject_value global). We therefore emit
 *    `saves; sets; env_set; inject_resume` and rely on the enclosing inject's
 *    own wrap to restore the slot: a trailing value-inject is the function's
 *    last statement, so any later same-cap call in the dynamic scope occurs in
 *    an OUTER inject whose wrap restores the slot. Burying inject_resume inside
 *    a try would drop its value (try bodies do not capture trailing exprs). */
let wrap_inject_resume_register = fn (
  runtime_hs: [ RuntimeHandler ],
  env_set: MirStmt,
  inject_resume: MirStmt,
  ret_type: TypeExpr,
  uniq: i64
) -> [ MirStmt ] do
  match runtime_hs do
    | [] -> return [ env_set, inject_resume ]
    | _ ->
      let saves = build_saves(runtime_hs, uniq, idx: 0, acc: [])
      let sets = build_sets(runtime_hs, acc: [])
      let restores = build_restores(runtime_hs, uniq, idx: 0, acc: [])
      match ret_type do
        | TyUnit ->
          let exn_name = "__hexn_" ++ i64_to_str(uniq)
          let try_body = concat_mir_stmts(
            a: [ env_set, inject_resume ],
            b: restores
          )
          let catch_body = concat_mir_stmts(
            a: restores,
            b: [ MirStmtExpr(expr: MirRaise(expr: MirVariable(name: exn_name))) ]
          )
          let try_stmt = MirStmtTry(body: try_body, catch_param: exn_name, catch_body)
          return concat_mir_stmts(a: saves, b: concat_mir_stmts(a: sets, b: [ try_stmt ]))
        | _ ->
          // Value-yielding: keep inject_resume trailing so its out-of-band value
          // is captured; enclosing inject's wrap restores the slot (see above).
          return concat_mir_stmts(a: saves, b: concat_mir_stmts(a: sets, b: [ env_set, inject_resume ]))
      end
  end
end

/** Of the handler bindings injected here, keep only those whose cap dispatches
 *  dynamically (>=2 handler bindings program-wide), paired with the cap's
 *  register slot index and the binding's runtime id. */
let runtime_dispatch_handlers = fn (
  handler_names: [ string ],
  handler_cap_names: [ NamePair ],
  cap_layouts: [ CapEntry ],
  bindings: [ HirHandlerBindingEntry ]
) -> [ RuntimeHandler ] throws { MirError } do
  match handler_names do
    | [] -> return []
    | hname :: rest ->
      let tail = runtime_dispatch_handlers(
        handler_names: rest,
        handler_cap_names,
        cap_layouts,
        bindings
      )
      match lookup(key: hname, pairs: handler_cap_names) do
        | None -> return tail
        | Some(val: cname) ->
          if cap_needs_runtime_dispatch(cap_name: cname, bindings) then
            let cidx = cap_index(cap_name: cname, cap_layouts)
            let hid = handler_id(binding_name: hname, bindings)
            return RuntimeHandler(cap_idx: cidx, handler_id: hid) :: tail
          else
            return tail
          end
      end
  end
end

type LiftInjectResult = LiftInjectResult(ctx: MirCtx, body_fn: string, ret_type: TypeExpr, captures: [ string ])

/** Classify the trailing-value type of a lifted inject body. The inject site
 *  yields whatever value the body's last bare expression produces; codegen
 *  carries that value out of the `() -> ()` body continuation out-of-band via
 *  the ss_inject_value global. Every non-unit value is i64-carried in this
 *  backend (records/ctors/strings are heap handles, bool/i64 are scalars), so
 *  the channel type collapses to TyI64 vs TyUnit. A value-less body (trailing
 *  statement is a let/assign/return/try, or a unit-typed trailing expression)
 * keeps TyUnit and the inject site yields unit. */
let mir_inject_result_type = fn (stmts: [ MirStmt ]) -> TypeExpr do
  // An explicit `return <v>` exit (anywhere in the body, including inside
  // if/match/while/block/try) yields its value at the inject site exactly like
  // a trailing expression does — codegen routes both through the
  // ss_inject_value global. So if any return path carries a non-unit value,
  // the channel is i64 even when the body's trailing statement is unit-typed
  if mir_stmts_have_value_return(stmts) then return TyI64 end
  match list.reverse(xs: stmts) do
    | [] -> return TyUnit
    | last :: _ ->
      match last do
        | MirStmtExpr(expr: e) ->
          match e do
            | MirLiteral(lit: LitUnit) -> return TyUnit
            | MirCall(func: _, args: _, ret_type: rt) -> return mir_value_channel(rt)
            | MirCallClosure(closure: _, args: _, ret_type: rt) -> return mir_value_channel(rt)
            | MirSuspend(tag_name: _, payload: _, ret_type: rt) -> return mir_value_channel(rt)
            | MirResume(cont_var: _, value: _, ret_type: rt) -> return mir_value_channel(rt)
            | MirWhile(cond: _, body: _) -> return TyUnit
            | MirBlock(stmts: _) -> return TyUnit
            | _ -> return TyI64
          end
        | _ -> return TyUnit
      end
  end
end

/** True if any statement in `stmts` is (or contains, in nested control flow) a
 *  `return <v>` whose value is non-unit. A `return ()` (MirLiteral(LitUnit))
 *  is value-less and does not count. Recurses through If/Match/While/Block (in
 *  expression position) and Try, but does NOT cross MirStmtInjectResume — a
 *  nested inject body's returns belong to its own lifted function, not ours.
 * Used to classify the inject result channel. */
let mir_stmts_have_value_return = fn (stmts: [ MirStmt ]) -> bool do
  match stmts do
    | [] -> return false
    | s :: rest ->
      if mir_stmt_has_value_return(stmt: s) then return true end
      return mir_stmts_have_value_return(stmts: rest)
  end
end

let mir_stmt_has_value_return = fn (stmt: MirStmt) -> bool do
  match stmt do
    | MirStmtReturn(expr: e) ->
      match e do
        | MirLiteral(lit: LitUnit) -> return false
        | _ -> return true
      end
    | MirStmtExpr(expr: e) -> return mir_expr_has_value_return(expr: e)
    | MirStmtLet(name: _, typ: _, expr: e) -> return mir_expr_has_value_return(expr: e)
    | MirStmtTry(body: b, catch_param: _, catch_body: cb) ->
      if mir_stmts_have_value_return(stmts: b) then return true end
      return mir_stmts_have_value_return(stmts: cb)
    | _ -> return false
  end
end

let mir_expr_has_value_return = fn (expr: MirExpr) -> bool do
  match expr do
    | MirIf(cond: _, then_body: tb, else_body: eb) ->
      if mir_stmts_have_value_return(stmts: tb) then return true end
      match eb do
        | Some(val: ebs) -> return mir_stmts_have_value_return(stmts: ebs)
        | None -> return false
      end
    | MirMatch(target: _, cases: cs) -> return mir_cases_have_value_return(cases: cs)
    | MirWhile(cond: _, body: b) -> return mir_stmts_have_value_return(stmts: b)
    | MirBlock(stmts: ss) -> return mir_stmts_have_value_return(stmts: ss)
    | _ -> return false
  end
end

let mir_cases_have_value_return = fn (cases: [ MirMatchCase ]) -> bool do
  match cases do
    | [] -> return false
    | MirMatchCase(pattern: _, body: b) :: rest ->
      if mir_stmts_have_value_return(stmts: b) then return true end
      return mir_cases_have_value_return(cases: rest)
  end
end

/** Collapse a non-unit type to the i64 value channel; unit stays unit. */
let mir_value_channel = fn (rt: TypeExpr) -> TypeExpr do
  match rt do
    | TyUnit -> return TyUnit
    | _ -> return TyI64
  end
end

/** Lift an inject body to a fresh top-level MirFunction. Naming convention:
 *  `__inject_<n>` shares the closure_counter so codegen's table-registration
 *  machinery picks it up alongside `__closure_*` lifts.
 */
let lift_inject_body = fn (
  stmts: [ HirStmt ],
  span: Span,
  ctx: MirCtx
) -> LiftInjectResult throws { MirError } do
  let MirCtx(
    scope: sc,
    cap_layouts: pl,
    handler_cap_names: hpn,
    all_funcs: af,
    all_handlers: ah,
    all_exts: ae,
    closure_counter: n,
    lifted_funcs: lf,
    cont_binders: cb,
    value_binding_names: vbns,
    thunk_param_names: tpn
  ) = ctx
  let lifted_name = "__inject_" ++ i64_to_str(n)
  let ctx_after_name = MirCtx(scope: sc, cap_layouts: pl, handler_cap_names: hpn,
                              all_funcs: af, all_handlers: ah, all_exts: ae,
                              closure_counter: n + 1, lifted_funcs: lf, cont_binders: cb, value_binding_names: vbns, thunk_param_names: tpn)
  // Free variables of the inject body that refer to the ENCLOSING scope. The
  // lifted `__inject_N` is reified by `cont.new` over a parameterless `() -> ()`
  // funcref, so these cannot arrive through parameters. Compute them with the
  // same machinery as lambda lifting (`collect_hir_free_vars` over the HIR body,
  // minus top-level funcs / externals / cap-method names), then bind them inside
  // the lifted body from a closure-env object the inject site hands off through
  // the fixed inject-env cell. Cap-method calls (`Gen.tick`) stay out of the
  // capture set via `build_known_names`, so only real enclosing locals/params
  // are captured.
  let known = build_known_names(ctx: ctx_after_name)
  let captures = collect_hir_free_vars(body: stmts, params: [], known)
  let MirStmtsResult(ctx: ctx_body, stmts: mir_body_inner) = lower_stmts(stmts, ctx: ctx_after_name)
  // Env-load preamble: `let __env = __inject_env_get()` recovers the env object
  // pointer the inject site stored before `resume`; each capture is then read
  // from it by field index, matching the `MirMakeClosure` object layout the
  // site builds (`[func_idx@0, cap0@1, ...]`, and `MirEnvLoad` adds the +1).
  let env_load = MirStmtLet(name: "__env", typ: TyI64,
                            expr: MirCall(func: "__inject_env_get", args: [], ret_type: TyI64))
  let cap_preamble = build_env_load_preamble(captures, index: 0)
  let mir_body = concat_mir_stmts(a: env_load :: cap_preamble, b: mir_body_inner)
  let MirCtx(
      scope: sc2,
      cap_layouts: pl2,
      handler_cap_names: hpn2,
      all_funcs: af2,
      all_handlers: ah2,
      all_exts: ae2,
      closure_counter: n2,
      lifted_funcs: lf2,
      cont_binders: cb2,
      value_binding_names: vbns2,
      thunk_param_names: tpn2
    ) = ctx_body
    // The body continuation must keep the single program cont type () -> ()
    //so the lifted function stays unit-returning at
    // the wasm signature level. The body's trailing VALUE is delivered to the
    // inject site out-of-band via the ss_inject_value global; result_ty records
    // whether there is such a value (TyI64) or none (TyUnit) so the InjectResume
    // expression yields the right thing.
    let result_ty = mir_inject_result_type(stmts: mir_body)
    let lifted_fn = MirFunction(name: lifted_name, params: [], ret_type: TyUnit,
                                body: mir_body, span)
    let new_lf = append_mir_funcs(a: lf2, b: [ lifted_fn ])
    let ctx_final = MirCtx(scope: sc2, cap_layouts: pl2, handler_cap_names: hpn2,
                           all_funcs: af2, all_handlers: ah2, all_exts: ae2,
                           closure_counter: n2, lifted_funcs: new_lf, cont_binders: cb2, value_binding_names: vbns2, thunk_param_names: tpn2)
    return LiftInjectResult(ctx: ctx_final, body_fn: lifted_name, ret_type: result_ty, captures)
end

let desugar_for = fn (
  var: string,
  start_expr: HirExpr,
  end_expr: HirExpr,
  body: [ HirStmt ],
  ctx: MirCtx
) -> MirStmtsResult throws { MirError } do
  let MirExprResult(ctx: ctx1, expr: mir_start) = lower_expr(expr: start_expr, ctx)
  let MirExprResult(ctx: ctx2, expr: mir_end) = lower_expr(expr: end_expr, ctx: ctx1)
  let MirStmtsResult(ctx: ctx3, stmts: mir_body) = lower_stmts(stmts: body, ctx: ctx2)
  // Hygiene: the counter and end-bound locals must be unique per loop so that
  // nested loops reusing the same surface variable name (`for i .. for i ..`)
  // do not alias each other's slots. We allocate a fresh suffix from the
  // closure_counter (shared uniq source, cf. wrap_inject_register's
  // __hexn_<uniq>/__hval_<uniq>) AFTER lowering the body, so any inner loops
  // have already consumed their own suffixes. The surface name `var` is
  // re-bound per iteration (`let <var> = <ctr_name>`) so body references read
  // the current counter value while the increment targets the unique slot.
  let MirCtx(
    scope: sc,
    cap_layouts: pl,
    handler_cap_names: hpn,
    all_funcs: af,
    all_handlers: ah,
    all_exts: ae,
    closure_counter: cc,
    lifted_funcs: lf,
    cont_binders: cb,
    value_binding_names: vbns,
    thunk_param_names: tpn
  ) = ctx3
  let ctr_name = "__for_ctr_" ++ i64_to_str(cc)
  let end_name = "__for_end_" ++ i64_to_str(cc)
  let ctx4 = MirCtx(scope: sc, cap_layouts: pl, handler_cap_names: hpn,
                    all_funcs: af, all_handlers: ah, all_exts: ae,
                    closure_counter: cc + 1, lifted_funcs: lf, cont_binders: cb,
                    value_binding_names: vbns, thunk_param_names: tpn)
  let incr = MirStmtAssign(
          target: MirVariable(name: ctr_name),
          value: MirBinaryOp(
            left: MirVariable(name: ctr_name),
            op: OpAdd,
            right: MirLiteral(lit: LitInt(val: 1))
          )
        )
        let var_bind = MirStmtLet(name: var, typ: TyI64, expr: MirVariable(name: ctr_name))
        let full_body = concat_mir_stmts(a: [ var_bind ], b: concat_mir_stmts(a: mir_body, b: [ incr ]))
        let stmts = [
          MirStmtLet(name: ctr_name, typ: TyI64, expr: mir_start),
          MirStmtLet(name: end_name, typ: TyI64, expr: mir_end),
          MirStmtExpr(expr: MirWhile(
            cond: MirBinaryOp(
              left: MirVariable(name: ctr_name),
              op: OpLt,
              right: MirVariable(name: end_name)
            ),
            body: full_body
          ))
        ]
        return MirStmtsResult(ctx: ctx4, stmts)
end

let lower_expr = fn (expr: HirExpr, ctx: MirCtx) -> MirExprResult throws { MirError } do
  let HirExpr(node, span: _) = expr
  match node do
    | Literal(lit: l) -> return MirExprResult(ctx, expr: MirLiteral(lit: l))
    | Variable(name: n, sigil: _) ->
      // top-level fn ref is a closure-pointer value, not auto-call.
      if list_has(name: n, names: ctx_value_binding_names(ctx)) then
        return MirExprResult(ctx, expr: MirVariable(name: n))
      end
      let hf_opt = lookup_top_level_fn(name: n, ctx)
      match hf_opt do
        | Some(val: hf) -> return wrap_top_level_fn(name: n, hf, ctx)
        | None -> return MirExprResult(ctx, expr: MirVariable(name: n))
      end
    | BinOp(left: l, op, right: r) ->
      let MirExprResult(ctx: ctx1, expr: le) = lower_expr(expr: l, ctx)
      let MirExprResult(ctx: ctx2, expr: re) = lower_expr(expr: r, ctx: ctx1)
      return MirExprResult(ctx: ctx2, expr: MirBinaryOp(left: le, op, right: re))
    | UnOp(op, operand: o) ->
      let MirExprResult(ctx: ctx1, expr: oe) = lower_expr(expr: o, ctx)
      let lowered = match op do
          | OpNeg -> MirBinaryOp(left: MirLiteral(lit: LitInt(val: 0)), op: OpSub, right: oe)
          | OpFNeg -> MirBinaryOp(
            left: MirLiteral(lit: LitFloat(val: "0.0")),
            op: OpFSub,
            right: oe
          )
          | OpNot -> MirBinaryOp(left: oe, op: OpEq, right: MirLiteral(lit: LitBool(val: false)))
        end
        return MirExprResult(ctx: ctx1, expr: lowered)
    | Borrow(name: n, sigil: _) -> return MirExprResult(ctx, expr: MirBorrow(name: n))
    | Call(func: f, args) ->
      // Resolve top-level alias before cap-call detection and
      // ret-type lookup. `let g = inc` lowers `g` as a 0-param stub; redirect
      // to the real callee so args and ret_type come from `inc`, not the stub.
      let f_resolved = resolve_alias_call_target(f, ctx)
      let MirCtx(
        scope: _,
        cap_layouts: pl,
        handler_cap_names: _,
        all_funcs: _,
        all_handlers: _,
        all_exts: _,
        closure_counter: _,
        lifted_funcs: _,
        cont_binders: _,
        _
      ) = ctx
      match detect_cap_call(func: f_resolved, cap_layouts: pl) do
        | CapCallFound(cap_name: pname, method_name: mname) ->
          return lower_cap_call(cap_name: pname, method_name: mname, args, ctx)
        | CapCallNotFound ->
          let MirCallArgsResult(ctx: ctx1, args: mir_args) = lower_call_args(args, ctx)
          match lookup_known_ret_type(name: f_resolved, ctx: ctx1) do
              | Some(val: ret_type) ->
                return MirExprResult(
                  ctx: ctx1,
                  expr: MirCall(func: f_resolved, args: mir_args, ret_type)
                )
              | None ->
                // f_resolved is a local / parameter holding a closure. LIR
                // recovers the real return type from semantic_vars.
                // If the callee is a thunk-typed param/let, insert an implicit
                // MirForce first (T-App thunk-callee: `f(args)` → `(@f)(args)`).
                let thunk_names = ctx_thunk_param_names(ctx: ctx1)
                let callee_expr = if list_has(name: f_resolved, names: thunk_names) then
                  MirForce(expr: MirVariable(name: f_resolved))
                else
                  MirVariable(name: f_resolved)
                end
                return MirExprResult(
                  ctx: ctx1,
                  expr: MirCallClosure(closure: callee_expr, args: mir_args, ret_type: TyI64)
                )
            end
      end
    | CallExpr(callee: c, args) ->
      // Record-field call or postfix-call on an expression: lower to
      // MirCallClosure.  The return type is recovered by LIR from semantic_vars.
      let MirExprResult(ctx: ctx1, expr: mir_callee) = lower_expr(expr: c, ctx)
      let MirCallArgsResult(ctx: ctx2, args: mir_args) = lower_call_args(args, ctx: ctx1)
      return MirExprResult(
            ctx: ctx2,
            expr: MirCallClosure(closure: mir_callee, args: mir_args, ret_type: TyI64)
          )
    | Ctor(variant: v, args, labels: _, sigil: _) ->
      let MirExprListResult(ctx: ctx1, exprs: mir_args) = lower_expr_list(exprs: args, ctx)
      return MirExprResult(ctx: ctx1, expr: MirConstructor(name: v, args: mir_args))
    | Record(fields: fs) ->
      let MirNamedExprsResult(ctx: ctx1, exprs: mir_fs) = lower_named_exprs(exprs: fs, ctx)
      return MirExprResult(ctx: ctx1, expr: MirRecord(fields: mir_fs))
    | Array(elems: es) ->
      let MirExprListResult(ctx: ctx1, exprs: mir_es) = lower_expr_list(exprs: es, ctx)
      return MirExprResult(ctx: ctx1, expr: MirArray(elems: mir_es))
    | Index(target: t, index: i) ->
      let MirExprResult(ctx: ctx1, expr: mir_t) = lower_expr(expr: t, ctx)
      let MirExprResult(ctx: ctx2, expr: mir_i) = lower_expr(expr: i, ctx: ctx1)
      return MirExprResult(ctx: ctx2, expr: MirIndex(target: mir_t, index: mir_i))
    | FieldAccess(target: t, field: f) ->
      let MirExprResult(ctx: ctx1, expr: mir_t) = lower_expr(expr: t, ctx)
      return MirExprResult(ctx: ctx1, expr: MirFieldAccess(target: mir_t, field: f))
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let MirExprResult(ctx: ctx1, expr: mir_cond) = lower_expr(expr: c, ctx)
      let MirStmtsResult(ctx: ctx2, stmts: mir_then) = lower_stmts(stmts: tb, ctx: ctx1)
      match eb do
            | Some(val: stmts) ->
              let MirStmtsResult(ctx: ctx3, stmts: mir_else_body) = lower_stmts(stmts, ctx: ctx2)
              return MirExprResult(
                  ctx: ctx3,
                  expr: MirIf(
                    cond: mir_cond,
                    then_body: mir_then,
                    else_body: Some(val: mir_else_body)
                  )
                )
            | None ->
              return MirExprResult(
                ctx: ctx2,
                expr: MirIf(cond: mir_cond, then_body: mir_then, else_body: None)
              )
          end
    | Match(target: t, cases: cs) ->
      let MirExprResult(ctx: ctx1, expr: mir_target) = lower_expr(expr: t, ctx)
      let MirMatchCasesResult(ctx: ctx2, cases: mir_cases) = lower_match_cases(
          cases: cs,
          ctx: ctx1
        )
      return MirExprResult(ctx: ctx2, expr: MirMatch(target: mir_target, cases: mir_cases))
    | While(cond: c, body: b) ->
      let MirExprResult(ctx: ctx1, expr: mir_cond) = lower_expr(expr: c, ctx)
      let MirStmtsResult(ctx: ctx2, stmts: mir_body) = lower_stmts(stmts: b, ctx: ctx1)
      return MirExprResult(ctx: ctx2, expr: MirWhile(cond: mir_cond, body: mir_body))
    | For(var, start: s, end_expr: end_e, body: b) ->
      // For in expression position — desugar via desugar_for, then wrap the
      // resulting statements in MirBlock so LIR can lower them in-line (same
      // scope, so mutable-ref captures work correctly).
      // desugar_for emits:
      //   let <var>            = <start>;
      //   let __for_end_<var>  = <end_expr>;
      //   while <var> < __for_end_<var> { body; <var>++ }
      let MirStmtsResult(ctx: ctx1, stmts: loop_stmts) = desugar_for(
        var,
        start_expr: s,
        end_expr: end_e,
        body: b,
        ctx
      )
      return MirExprResult(ctx: ctx1, expr: MirBlock(stmts: loop_stmts))
    | Lambda(type_params: _, params: lps, ret_type: lret, requires: _, throw_row: _, body: lbody) ->
      return lift_lambda(params: lps, ret_type: lret, body: lbody, span: expr, ctx)
    | Raise(expr: e) ->
      let MirExprResult(ctx: ctx1, expr: mir_e) = lower_expr(expr: e, ctx)
      return MirExprResult(ctx: ctx1, expr: MirRaise(expr: mir_e))
    | Force(expr: e) ->
      // Force on a cont_binder name in the enclosing arm scope lowers to
      // MirResume — codegen emits op_resume to transfer control back to the
      // suspended caller. Other Force forms remain regular MirForce (lazy
      // thunk invocation).
      let HirExpr(node: inner_node, span: _) = e
      match inner_node do
        | Variable(name: vn, sigil: _) ->
          // Emit Resume only when the variable being forced is itself a cont binder.
          let cb = ctx_cont_binders(ctx)
          if list_has(name: vn, names: cb) then
            return MirExprResult(ctx,
              expr: MirResume(cont_var: vn, value: MirLiteral(lit: LitUnit), ret_type: TyUnit))
          end
          let MirExprResult(ctx: ctx1, expr: mir_e) = lower_expr(expr: e, ctx)
          return MirExprResult(ctx: ctx1, expr: MirForce(expr: mir_e))
        | _ ->
          let MirExprResult(ctx: ctx1, expr: mir_e) = lower_expr(expr: e, ctx)
          return MirExprResult(ctx: ctx1, expr: MirForce(expr: mir_e))
      end
    | Thunk(body: b) ->
      let HirExpr(node: _, span: sp) = expr
      return lift_lambda(
        params: [],
        ret_type: TyI64,
        body: [ HirStmt(node: Return(expr: b), span: sp) ],
        span: expr,
        ctx)
    | ExternalRef(symbol: sym, type_params: _, arg_names: _, typ: _) ->
      return MirExprResult(ctx, expr: MirVariable(name: sym))
    | Handler(_) ->
      return MirExprResult(ctx, expr: MirLiteral(lit: LitUnit))
  end
end

let lower_cap_call = fn (
  cap_name: string,
  method_name: string,
  args: [ HirCallArg ],
  ctx: MirCtx
) -> MirExprResult throws { MirError } do
  let MirCtx(
    scope,
    cap_layouts: _,
    handler_cap_names: hpn,
    all_funcs: _,
    all_handlers: all_hbs,
    all_exts: _,
    closure_counter: _,
    lifted_funcs: _,
    cont_binders: _,
    _
  ) = ctx
  let handler_name = match lookup(key: cap_name, pairs: scope) do
    | Some(val: h) -> h
    | None ->
      match reverse_lookup(value: cap_name, pairs: hpn) do
        | Some(val: bname) -> bname
        | None ->
          match lookup_handler_by_cap(cap_name, bindings: all_hbs) do
            | Some(val: bname2) -> bname2
            | None -> throw MirCapHandlerNotFound(cap_name, method_name)
          end
      end
  end
  let func_name = naming.handler_func_name(handler_name, method_name)
  let ret_type = lookup_ret_type(name: func_name, ctx)
  let MirCallArgsResult(ctx: ctx1, args: mir_args) = lower_call_args(args, ctx)
  match arm_cont_binder(handler_name, method_name, bindings: all_hbs) do
      | Some(_) ->
        let tag = cap_name ++ "::" ++ method_name
        let n_args = list.length(xs: mir_args)
        if n_args > 1 then
          throw MirMultiArgSuspend(cap_name, method_name, arg_count: n_args)
        end
        let payload = match mir_args do
          | MirCallArg(label: _, value: v) :: _ -> v
          | [] -> MirLiteral(lit: LitUnit)
        end
        return MirExprResult(ctx: ctx1,
          expr: MirSuspend(tag_name: tag, payload, ret_type))
      | None ->
        // Runtime dispatch: when the program declares two or more handlers for
        // this cap, route the call through the generated dispatcher that reads
        // the cap's handler-register slot and forwards to the dynamically-active
        // handler (so a cap call reached through a helper observes the innermost
        // inject). A single-handler cap can never be shadowed, so it keeps the
        // cheaper direct call to its one `__handler_*` method.
        if cap_needs_runtime_dispatch(cap_name, bindings: all_hbs) then
          let dispatch_name = naming.cap_dispatch_func_name(cap_name, method_name)
          return MirExprResult(
            ctx: ctx1,
            expr: MirCall(func: dispatch_name, args: mir_args, ret_type)
          )
        end
        return MirExprResult(ctx: ctx1, expr: MirCall(func: func_name, args: mir_args, ret_type))
    end
end

let lower_call_args = fn (
  args: [ HirCallArg ],
  ctx: MirCtx
) -> MirCallArgsResult throws { MirError } do
  return lower_call_args_go(args, ctx, acc: [])
end

let lower_call_args_go = fn (
  args: [ HirCallArg ],
  ctx: MirCtx,
  acc: [ MirCallArg ]
) -> MirCallArgsResult throws { MirError } do
  match args do
    | [] -> return MirCallArgsResult(ctx, args: list.reverse(xs: acc))
    | HirCallArg(label: l, value: v) :: rest ->
      let MirExprResult(ctx: ctx1, expr: mir_v) = lower_expr(expr: v, ctx)
      return lower_call_args_go(
          args: rest,
          ctx: ctx1,
          acc: MirCallArg(label: l, value: mir_v) :: acc
        )
  end
end

let lower_expr_list = fn (
  exprs: [ HirExpr ],
  ctx: MirCtx
) -> MirExprListResult throws { MirError } do
  return lower_expr_list_go(exprs, ctx, acc: [])
end

let lower_expr_list_go = fn (
  exprs: [ HirExpr ],
  ctx: MirCtx,
  acc: [ MirExpr ]
) -> MirExprListResult throws { MirError } do
  match exprs do
    | [] -> return MirExprListResult(ctx, exprs: list.reverse(xs: acc))
    | e :: rest ->
      let MirExprResult(ctx: ctx1, expr: mir_e) = lower_expr(expr: e, ctx)
      return lower_expr_list_go(exprs: rest, ctx: ctx1, acc: mir_e :: acc)
  end
end

let lower_named_exprs = fn (
  exprs: [ HirNamedExpr ],
  ctx: MirCtx
) -> MirNamedExprsResult throws { MirError } do
  return lower_named_exprs_go(exprs, ctx, acc: [])
end

let lower_named_exprs_go = fn (
  exprs: [ HirNamedExpr ],
  ctx: MirCtx,
  acc: [ MirNamedExpr ]
) -> MirNamedExprsResult throws { MirError } do
  match exprs do
    | [] -> return MirNamedExprsResult(ctx, exprs: list.reverse(xs: acc))
    | HirNamedExpr(name: n, value: v) :: rest ->
      let MirExprResult(ctx: ctx1, expr: mir_v) = lower_expr(expr: v, ctx)
      return lower_named_exprs_go(
          exprs: rest,
          ctx: ctx1,
          acc: MirNamedExpr(name: n, value: mir_v) :: acc
        )
  end
end

let lower_match_cases = fn (
  cases: [ HirMatchCase ],
  ctx: MirCtx
) -> MirMatchCasesResult throws { MirError } do
  return lower_match_cases_go(cases, ctx, acc: [])
end

let lower_match_cases_go = fn (
  cases: [ HirMatchCase ],
  ctx: MirCtx,
  acc: [ MirMatchCase ]
) -> MirMatchCasesResult throws { MirError } do
  match cases do
    | [] -> return MirMatchCasesResult(ctx, cases: list.reverse(xs: acc))
    | HirMatchCase(pattern: p, body: b) :: rest ->
      let MirStmtsResult(ctx: ctx1, stmts: mir_body) = lower_stmts(stmts: b, ctx)
      let case_mir = MirMatchCase(pattern: lower_pattern(pat: p), body: mir_body)
        return lower_match_cases_go(cases: rest, ctx: ctx1, acc: case_mir :: acc)
  end
end

/** Remove every occurrence of `name` from `names`, preserving order. */
let remove_capture_name = fn (
  name: string,
  names: [ string ],
  acc: [ string ]
) -> [ string ] throws { MirError } do
  match names do
    | [] -> return list.reverse(xs: acc)
    | hd :: rest ->
      let acc2 = if hd == name then acc else hd :: acc end
      return remove_capture_name(name, names: rest, acc: acc2)
  end
end

/** Lift an inline `fn (...)` expression to a top-level `__closure_<N>` MIR
 *  function. The lifted function receives `__env: i64` as its first parameter
 *  (prepended before the original params) and opens the body with one
 *  `let <cap_i> = MirEnvLoad("__env", i)` per captured free variable. The
 *  callsite is replaced with `MirMakeClosure(func_name, captures)` so the
 *  existing LIR/codegen closure machinery (`__closure_` prefix auto-registers
 *  into the WASM closure table) picks it up.
 */
let lift_lambda = fn (
  params: [ HirParam ],
  ret_type: TypeExpr,
  body: [ HirStmt ],
  span: HirExpr,
  ctx: MirCtx
) -> MirExprResult throws { MirError } do
  return lift_lambda_self(params, ret_type, body, span, self_name: "", ctx)
end

/** Like `lift_lambda`, but `self_name` (when non-empty) is the name of the
 *  immutable `let` binding whose RHS is this lambda — i.e. a recursive local
 *  closure (`let go: (...) -> ... = fn (...) do ... go(...) ... end`).
 *
 *  A self-recursive lambda references its own binding inside its body. If that
 *  name were collected as an ordinary free variable it would be captured *by
 *  value* into env slot 0 at the construction site — but the closure cell does
 *  not exist yet when the capture is read (the `let go = closure(...)` only
 *  binds it afterwards), so the slot holds garbage and the self `call_indirect`
 *  jumps to table index 0 → "undefined element: out of bounds table access".
 *
 *  Fix: exclude `self_name` from the capture set, and bind it in the lifted
 *  body to `__env` — which IS the closure object pointer the callee receives.
 *  A `callcl <self_name>(...)` then re-extracts the table index from that same
 *  object, so the self-call reaches the correct closure with no by-value
 *  capture and no construction-site back-patch.
 */
let lift_lambda_self = fn (
  params: [ HirParam ],
  ret_type: TypeExpr,
  body: [ HirStmt ],
  span: HirExpr,
  self_name: string,
  ctx: MirCtx
) -> MirExprResult throws { MirError } do
  let MirCtx(
    scope: sc,
    cap_layouts: pl,
    handler_cap_names: hpn,
    all_funcs: af,
    all_handlers: ah,
    all_exts: ae,
    closure_counter: n,
    lifted_funcs: lf,
    cont_binders: cb,
    value_binding_names: vbns,
    thunk_param_names: tpn
  ) = ctx
  let lifted_name = "__closure_" ++ i64_to_str(n)
  let ctx_after_name = MirCtx(scope: sc, cap_layouts: pl, handler_cap_names: hpn,
                              all_funcs: af, all_handlers: ah, all_exts: ae,
                              closure_counter: n + 1, lifted_funcs: lf, cont_binders: cb, value_binding_names: vbns, thunk_param_names: tpn)

  // Free variables: referenced in body but not bound by params or known at
  // top level (functions, externals, handler methods).
  let param_names = param_names_of(params)
  let known = build_known_names(ctx: ctx_after_name)
  let raw_captures = collect_hir_free_vars(body, params: param_names, known)

  // A recursive local closure references its own `let` binding inside its
  // body, so `self_name` shows up among the raw free vars. Capturing it by
  // value is impossible — the closure cell does not exist yet when the env
  // slot is filled at the construction site (env slot garbage → self
  // `call_indirect` to table index 0 → "undefined element: out of bounds
  // table access"). Drop it from the capture set and bind it from `__env`
  // (the closure object pointer the callee receives IS the self value) so
  // `callcl <self_name>(...)` re-extracts the table index from that same
  // object. Non-recursive lambdas never have `self_name` free → unchanged.
  let is_recursive_self = (self_name != "") && list_has(name: self_name, names: raw_captures)
  let captures = if is_recursive_self then remove_capture_name(name: self_name, names: raw_captures, acc: [])
    else raw_captures end

  // Lower the original body once; capture names inside resolve to locals
  // bound by the env-load preamble below.
  let MirStmtsResult(ctx: ctx_body, stmts: mir_body) = lower_stmts(stmts: body, ctx: ctx_after_name)
  let env_preamble = build_env_load_preamble(captures, index: 0)
  let preamble = if is_recursive_self then
      MirStmtLet(name: self_name, typ: TyI64, expr: MirVariable(name: "__env")) :: env_preamble
    else env_preamble
    end
    let full_body = concat_mir_stmts(a: preamble, b: mir_body)

    // Params: [__env: i64, *orig_params_with_closure_types]. Arrow types in
    // the original `params` must be swapped to TyI64 so WASM signatures line
    // up — captures and closure args are all passed as i64 closure pointers.
    let env_param = MirParam(label: "__env", name: "__env", typ: TyI64)
    let orig_params = lower_lambda_params(params)
    let all_params = env_param :: orig_params
    let HirExpr(node: _, span: sp) = span
    let lifted_fn = MirFunction(name: lifted_name, params: all_params,
                                ret_type: lower_lambda_ret_type(t: ret_type),
                                body: full_body, span: sp)

    // Append lifted fn to ctx.lifted_funcs (preserves creation order so
    // nested lambdas are emitted outer-last).
    let MirCtx(
      scope: sc2,
      cap_layouts: pl2,
      handler_cap_names: hpn2,
      all_funcs: af2,
      all_handlers: ah2,
      all_exts: ae2,
      closure_counter: n2,
      lifted_funcs: lf2,
      cont_binders: cb2,
      value_binding_names: vbns2,
      thunk_param_names: tpn2
    ) = ctx_body
    let new_lf = append_mir_funcs(a: lf2, b: [ lifted_fn ])
    let ctx_final = MirCtx(scope: sc2, cap_layouts: pl2, handler_cap_names: hpn2,
                           all_funcs: af2, all_handlers: ah2, all_exts: ae2,
                           closure_counter: n2, lifted_funcs: new_lf, cont_binders: cb2, value_binding_names: vbns2, thunk_param_names: tpn2)

    let capture_exprs = captures_to_mir_exprs(caps: captures, acc: [])
    return MirExprResult(
      ctx: ctx_final,
      expr: MirMakeClosure(func_name: lifted_name, captures: capture_exprs)
    )
end
