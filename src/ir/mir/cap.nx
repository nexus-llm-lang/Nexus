/**
 * cap: Cap-call resolution and cap-layout bookkeeping for MIR lowering.
 *
 * Owns:
 * - Cap layout construction (build_cap_layouts)
 * - Handler → cap name mapping (infer_handler_cap_names)
 * - Return-type lookup across funcs / handlers / externals
 * - Cap-call detection (detect_cap_call)
 * - Small-map utilities over NamePair lists scoped to the above
 *
 * Does not own:
 * - The HIR → MIR expression lowering (stays in src/ir/mir/mir.nx)
 * - lower_cap_call (stays in mir.nx because it calls lower_call_args,
 *   which is part of MIR's mutual-recursive expression lowering and cannot
 *   be imported backwards without a cycle)
 *
 * Types (NamePair, CapEntry, CapCallResult, MirCtx) live in mir_types.nx.
 */
import {
  NamePair,
  CapEntry,
  CapCallResult,
  CapCallFound,
  CapCallNotFound,
  MirCtx
} from "src/ir/mir/types.nx"
import * as list from "std:list"
import {
  HirCap,
  HirCapMethod,
  HirFunction,
  HirHandlerArm,
  HirHandlerBindingEntry,
  HirHandlerBinding,
  HirExternal
} from "src/ir/hir/types.nx"
import { arms_to_funcs } from "src/ir/shared/linearity.nx"
import { TypeExpr, TyI64 } from "src/syntax/ast.nx"
import * as str from "std:str"

/** Public function build_cap_layouts. */
export let build_cap_layouts = fn (caps: [ HirCap ]) -> [ CapEntry ] do
  return build_cap_layouts_go(caps, acc: [])
end

let build_cap_layouts_go = fn (caps: [ HirCap ], acc: [ CapEntry ]) -> [ CapEntry ] do
  match caps do
    | [] -> return list.reverse(xs: acc)
    | HirCap(name: n, methods: ms) :: rest ->
      let method_names = extract_method_names(methods: ms)
      return build_cap_layouts_go(
        caps: rest,
        acc: CapEntry(name: n, prefix: n ++ ".", methods: method_names) :: acc
      )
  end
end

let extract_method_names = fn (methods: [ HirCapMethod ]) -> [ string ] do
  return extract_method_names_go(methods, acc: [])
end

let extract_method_names_go = fn (methods: [ HirCapMethod ], acc: [ string ]) -> [ string ] do
  match methods do
    | [] -> return list.reverse(xs: acc)
    | HirCapMethod(
      name: n,
      requires: _,
      span: _,
      throw_row: _,
      typ_params: _,
      typ_ret: _
    ) :: rest ->
      return extract_method_names_go(methods: rest, acc: n :: acc)
  end
end

let lookup_cap = fn (name: string, caps: [ CapEntry ]) -> Option<[ string ]> do
  match caps do
    | [] -> return None
    | CapEntry(name: n, prefix: _, methods: ms) :: rest ->
      if n == name then return Some(val: ms)
      else return lookup_cap(name, caps: rest)
      end
  end
end

/** Infer handler_binding_name → cap_name from function names and cap list.
 *  Scans for functions named __handler_<binding>_<method> and matches against cap methods.
 */
export let infer_handler_cap_names = fn (
  funcs: [ HirFunction ],
  caps: [ HirCap ]
) -> [ NamePair ] do
  return infer_hcn_go(funcs, caps, acc: [])
end

let infer_hcn_go = fn (
  funcs: [ HirFunction ],
  caps: [ HirCap ],
  acc: [ NamePair ]
) -> [ NamePair ] do
  match funcs do
    | [] -> return acc
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, _) :: rest ->
      if str.starts_with(s: n, prefix: "__handler_") then
        match infer_cap_from_handler(name: n, caps) do
          | Some(val: pair) ->
            if !name_pair_in_list(key: pair, pairs: acc) then
              return infer_hcn_go(funcs: rest, caps, acc: pair :: acc)
            else
              return infer_hcn_go(funcs: rest, caps, acc)
            end
          | None -> return infer_hcn_go(funcs: rest, caps, acc)
        end
      else
        return infer_hcn_go(funcs: rest, caps, acc)
      end
  end
end

let name_pair_in_list = fn (key: NamePair, pairs: [ NamePair ]) -> bool do
  match pairs do
    | [] -> return false
    | NamePair(key: k, value: _) :: rest ->
      let NamePair(key: nk, value: _) = key
      if k == nk then return true
      else return name_pair_in_list(key, pairs: rest)
      end
  end
end

let infer_cap_from_handler = fn (name: string, caps: [ HirCap ]) -> Option<NamePair> do
  match caps do
    | [] -> return None
    | HirCap(name: cname, methods) :: rest ->
      match infer_binding_from_methods(handler_name: name, cap_name: cname, methods) do
        | Some(val: binding) -> return Some(val: NamePair(key: binding, value: cname))
        | None -> return infer_cap_from_handler(name, caps: rest)
      end
  end
end

let infer_binding_from_methods = fn (
  handler_name: string,
  cap_name: string,
  methods: [ HirCapMethod ]
) -> Option<string> do
  match methods do
    | [] -> return None
    | HirCapMethod(
      name: mname,
      requires: _,
      span: _,
      throw_row: _,
      typ_params: _,
      typ_ret: _
    ) :: rest ->
      let suffix = "_" ++ mname
      if str.ends_with(s: handler_name, suffix) then
        let prefix_len = 10 // length("__handler_")
        let suffix_len = str.length(s: suffix)
        let total_len = str.length(s: handler_name)
        let binding = str.substring(
          s: handler_name,
          start: prefix_len,
          len: total_len - prefix_len - suffix_len
        )
        return Some(val: binding)
      else
        return infer_binding_from_methods(handler_name, cap_name, methods: rest)
      end
  end
end

/** Public function lookup_handler_by_cap. */
export let lookup_handler_by_cap = fn (
  cap_name: string,
  bindings: [ HirHandlerBindingEntry ]
) -> Option<string> do
  match bindings do
    | [] -> return None
    | HirHandlerBindingEntry(
      name: bname,
      binding: HirHandlerBinding(cap_name: cname, requires: _, arms: _)
    ) :: rest ->
      if cname == cap_name then return Some(val: bname)
      else return lookup_handler_by_cap(cap_name, bindings: rest)
      end
  end
end

/** Public function reverse_lookup. */
export let reverse_lookup = fn (value: string, pairs: [ NamePair ]) -> Option<string> do
  match pairs do
    | [] -> return None
    | NamePair(key: k, value: v) :: rest ->
      if v == value then return Some(val: k)
      else return reverse_lookup(value, pairs: rest)
      end
  end
end

/** Check if `name` refers to a known top-level callable (function, handler
 *  method, or external). Returns the declared return type if found, or None
 *  when the name is a local variable / parameter (caller should emit an
 *  indirect call in that case).
 */
export let lookup_known_ret_type = fn (name: string, ctx: MirCtx) -> Option<TypeExpr> do
  let MirCtx(
      scope: _,
      cap_layouts: _,
      handler_cap_names: _,
      all_funcs: funcs,
      all_handlers: handlers,
      all_exts: exts,
      closure_counter: _,
      lifted_funcs: _,
      cont_binders: _,
      _
    ) = ctx
  let from_funcs = lookup_ret_in_functions(name, functions: funcs)
      match from_funcs do
        | Some(_) -> return from_funcs
        | None ->
          let from_handlers = lookup_ret_in_handlers(name, bindings: handlers)
          match from_handlers do
            | Some(_) -> return from_handlers
            | None -> return lookup_ret_in_externals(name, externals: exts)
          end
      end
end

/** lookup_ret_type: handler-call return-type resolution.
 *
 *  Returns TyI64 on miss. This looks like a silent default but is structurally
 *  necessary at this site: handler_func_name concatenates cap-binding + method
 *  to produce the callee, and the lookup may legitimately miss when a fallback
 *  handler path (e.g. global_scope's Console → stdio.system_handler override)
 *  was chosen ahead of a user-bound handler that existed under a different
 *  binding name. Downstream codegen re-resolves via the WASM linker / stdlib
 *  symbol table, and the TyI64 placeholder is never observed at WASM level
 * because every object reference is packed to i64. —
 *  closing this out requires refactoring the Console/Fs/Clock hardcodes (see
 * ), not a local throw here.
 */
export let lookup_ret_type = fn (name: string, ctx: MirCtx) -> TypeExpr do
  match lookup_known_ret_type(name, ctx) do
    | Some(val: t) -> return t
    | None -> return TyI64
  end
end

let lookup_ret_in_functions = fn (name: string, functions: [ HirFunction ]) -> Option<TypeExpr> do
  match functions do
    | [] -> return None
    | HirFunction(name: n, type_params: _, params: _, ret_type: rt, _) :: rest ->
      if n == name then return Some(val: rt)
      else return lookup_ret_in_functions(name, functions: rest)
      end
  end
end

let lookup_ret_in_handlers = fn (
  name: string,
  bindings: [ HirHandlerBindingEntry ]
) -> Option<TypeExpr> do
  match bindings do
    | [] -> return None
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      let found = lookup_ret_in_functions(name, functions: arms_to_funcs(arms))
      match found do
        | Some(_) -> return found
        | None -> return lookup_ret_in_handlers(name, bindings: rest)
      end
  end
end

let lookup_ret_in_externals = fn (name: string, externals: [ HirExternal ]) -> Option<TypeExpr> do
  match externals do
    | [] -> return None
    | HirExternal(
      name: n,
      wasm_module: _,
      wasm_name: _,
      type_params: _,
      params: _,
      ret_type: rt,
      throw_row: _
    ) :: rest ->
      if n == name then return Some(val: rt)
      else return lookup_ret_in_externals(name, externals: rest)
      end
  end
end

/** Check if a function name is a cap-qualified call. Returns (cap_name, method_name) if so. */
export let detect_cap_call = fn (func: string, cap_layouts: [ CapEntry ]) -> CapCallResult do
  match cap_layouts do
    | [] -> return CapCallNotFound
    | CapEntry(name: cname, prefix, methods: _) :: rest ->
      if str.starts_with(s: func, prefix) then
        let plen = str.length(s: prefix)
        let method = str.substring(s: func, start: plen, len: str.length(s: func) - plen)
        return CapCallFound(cap_name: cname, method_name: method)
      else
        return detect_cap_call(func, cap_layouts: rest)
      end
  end
end

// ─── Runtime handler-register dispatch bookkeeping ───────────────────────────
//
// A cap is dispatched dynamically (through the runtime handler register) only
// when the whole program declares two or more handler bindings for it: a single
// reachable handler can never be shadowed, so it keeps the cheaper static
// rewrite. The compiler's own IO caps (Console/Fs/Clock/Env/Proc/Net/Random)
// each have exactly one system_handler, so self-hosting stays on the static
// path; only the documented handler-swap idiom (nested injects of two handlers
// for the same cap) switches to runtime dispatch.

/** Stable cap index = position of `cap_name` in the program's cap layout list.
 *  This is the slot index into the handler register. Returns -1 if absent. */
export let cap_index = fn (cap_name: string, cap_layouts: [ CapEntry ]) -> i64 do
  return cap_index_go(cap_name, cap_layouts, idx: 0)
end

let cap_index_go = fn (cap_name: string, cap_layouts: [ CapEntry ], idx: i64) -> i64 do
  match cap_layouts do
    | [] -> return 0 - 1
    | CapEntry(name: cname, prefix: _, methods: _) :: rest ->
      if cname == cap_name then return idx
      else return cap_index_go(cap_name, cap_layouts: rest, idx: idx + 1)
      end
  end
end

/** Stable, nonzero runtime id for a handler binding = 1 + its position in the
 *  program's handler-binding list. Id 0 is reserved to mean "no dynamic handler
 *  active — use the static default", matching zero-initialised register memory.
 *  Returns 0 if the binding is absent. */
export let handler_id = fn (binding_name: string, bindings: [ HirHandlerBindingEntry ]) -> i64 do
  return handler_id_go(binding_name, bindings, idx: 1)
end

let handler_id_go = fn (
  binding_name: string,
  bindings: [ HirHandlerBindingEntry ],
  idx: i64
) -> i64 do
  match bindings do
    | [] -> return 0
    | HirHandlerBindingEntry(
      name: bname,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms: _)
    ) :: rest ->
      if bname == binding_name then return idx
      else return handler_id_go(binding_name, bindings: rest, idx: idx + 1)
      end
  end
end

/** Number of handler bindings declared for `cap_name` across the whole program. */
export let count_handlers_for_cap = fn (
  cap_name: string,
  bindings: [ HirHandlerBindingEntry ]
) -> i64 do
  match bindings do
    | [] -> return 0
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: cname, requires: _, arms: _)
    ) :: rest ->
      let here = if cname == cap_name then 1 else 0 end
      return here + count_handlers_for_cap(cap_name, bindings: rest)
  end
end

/** True when `cap_name` must dispatch dynamically: two or more handler bindings
 *  for it are declared in the program (so nested injects can shadow). */
export let cap_needs_runtime_dispatch = fn (
  cap_name: string,
  bindings: [ HirHandlerBindingEntry ]
) -> bool do
  return count_handlers_for_cap(cap_name, bindings) >= 2
end

/** All handler-binding names declared for `cap_name`, in program order. */
export let handlers_for_cap = fn (
  cap_name: string,
  bindings: [ HirHandlerBindingEntry ]
) -> [ string ] do
  match bindings do
    | [] -> return []
    | HirHandlerBindingEntry(
      name: bname,
      binding: HirHandlerBinding(cap_name: cname, requires: _, arms: _)
    ) :: rest ->
      if cname == cap_name then return bname :: handlers_for_cap(cap_name, bindings: rest)
      else return handlers_for_cap(cap_name, bindings: rest)
      end
  end
end
