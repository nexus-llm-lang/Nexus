/**
 * lambda_lift: Closure / lambda lifting support for MIR lowering.
 *
 * Owns:
 * - Free-variable collection over HIR (walks the HIR tree, returns names
 *   referenced but not defined locally or globally known)
 * - Lambda parameter / return-type coercion to the canonical closure-call
 *   slot (`(env: i64, args: i64...) -> i64`)
 * - First-class top-level function reference wrapping
 *   (`wrap_top_level_fn` builds a `__closure_wrap_<target>` MirFunction)
 * - `__env`-load preamble construction for lifted lambda bodies
 * - Names that are statically resolvable at a lambda's callsite and must
 *   NOT be treated as free variables (top-level fns, externals, handler
 *   methods)
 *
 * Does not own:
 * - The orchestrator `lift_lambda` itself (stays in mir.nx — it calls
 *   `lower_stmts`, which is mutually recursive with HIR→MIR expression
 *   lowering and cannot be imported backwards without a cycle)
 * - The HIR → MIR expression / statement lowering (mir.nx)
 */
import { MirError } from "src/ir/mir/errors.nx"
import * as list from "std:list"
import { None, Some } from "std:option"
import { TypeExpr, TyArrow, TyBool, TyI32, TyChar, TyI64, TyF32, TyF64, TyUnit } from "src/types/type_expr.nx"
import {
  HirParam,
  HirFunction,
  HirHandlerArm,
  HirMatchCase,
  HirPatternKind,
  HirPatternField,
  HirRecordPatField,
  HirExternal,
  HirHandlerBinding,
  HirHandlerBindingEntry,
  HirNamedExpr,
  HirExpr,
  HirStmt,
  HirStmtKind,
  HirCallArg
}, * as hir from "src/ir/hir/types.nx"
import {
  MirParam,
  MirFunction,
  MirCallArg,
  MirExpr,
  MirStmt,
  MirCtx,
  MirExprResult,
  CapEntry
} from "src/ir/mir/types.nx"
import { arms_to_funcs } from "src/ir/shared/linearity.nx"
import { append_mir_funcs } from "src/ir/mir/utils.nx"

let concat_strings = fn (a: [ string ], b: [ string ]) -> [ string ] throws { MirError } do
  match a do
    | [] -> return b
    | x :: rest -> return x :: concat_strings(a: rest, b)
  end
end

/** Coerce arrow-typed lambda params to i64 (closure pointer). Non-arrow
 *  param types (i64, string, records) pass through unchanged.
 */
export let lower_lambda_params = fn (params: [ HirParam ]) -> [ MirParam ] throws { MirError } do
  return lower_lambda_params_go(params, acc: [])
end

let lower_lambda_params_go = fn (
  params: [ HirParam ],
  acc: [ MirParam ]
) -> [ MirParam ] throws { MirError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: l, name: n, sigil: _, typ: t) :: rest ->
      // use coerce_to_closure_slot so bool/i32/char params get
      // declared as i64 in the lifted lambda's wasm sig, matching the
      // canonical (env: i64, args: i64...) -> i64 type expected by the
      // call_indirect at fold_left's HOF site. Previously only arrow types
      // were coerced (via coerce_arrow_to_i64), leaving bool params as i32
      // and triggering "current function requires result type [i32] but
      // callee returns [i64]" / "indirect call type mismatch".
      return lower_lambda_params_go(
        params: rest,
        acc: MirParam(label: l, name: n, typ: coerce_to_closure_slot(t)) :: acc
      )
  end
end

/** Coerce a lifted lambda's return type to the canonical closure-call slot.
 *  Lifted lambdas (`__closure_*`) are invoked through `call_indirect` against
 *  a uniform `(env: i64, args: i64...) -> i64` type, so the wasm function
 *  itself must declare the same return slot. Source-level types that do not
 *  pack into `i64` (`bool`/`i32`/`char` -> `i32`, `f32`/`f64` -> `f32`/`f64`)
 *  would mismatch the indirect-call type and trap. Coerce them to `TyI64`;
 *  `emit_return_value` then bridges the body's actual return value via
 *  `emit_coercion` (e.g. `i64.extend_i32_s` for bool). `TyUnit` is also
 *  coerced to `TyI64` here so that the declared wasm function type matches
 *  the canonical `-> i64` slot; `emit_return_value` inserts an `i64.const 0`
 *  placeholder when the body result is unit.
 */
export let lower_lambda_ret_type = fn (t: TypeExpr) -> TypeExpr throws { MirError } do
  match t do
    | TyUnit -> return TyI64
    | _ -> return coerce_to_closure_slot(t)
  end
end

let coerce_arrow_to_i64 = fn (t: TypeExpr) -> TypeExpr throws { MirError } do
  match t do
    | TyArrow(_) -> return TyI64
    | _ -> return t
  end
end

/** Coerce a value type that crosses the closure-call ABI up to the canonical
 *  `TyI64` slot so a lifted lambda's wasm signature matches the registered
 *  `(env: i64, args: i64...) -> i64` closure-call type. `emit_coercion`
 *  bridges the body's actual value to `i64` (sign-extend for `bool`/`i32`/
 *  `char`, bit-reinterpret for `f64`/`f32`). Without this coercion a
 *  `(a: f64, b: f64) -> f64` callback wrapper would declare wasm sig
 *  `(i64 f64 f64) -> f64` and trap the call_indirect at the HOF site with
 *  `indirect call type mismatch` once direct float args/returns started
 *  reinterpreting at the i64-erasure boundary. `TyUnit` remains unchanged:
 *  an existing codegen path inserts an `i64.const 0` placeholder.
 */
let coerce_to_closure_slot = fn (t: TypeExpr) -> TypeExpr throws { MirError } do
  match t do
    | TyArrow(_) | TyBool | TyI32 | TyChar | TyF32 | TyF64 -> return TyI64
    | _ -> return t
  end
end

//
// Named top-level functions referenced in value position (record field,
// argument, let-binding) are wrapped into a `__closure_wrap_<target>` lifted
// MirFunction. The wrapper has the canonical closure-call signature
// `(__env: i64, args...) -> ret`, body is a single `MirCall(target, args)`
// that forwards to the named target. Returning `MirMakeClosure(wrapper, [])`
// hands the value off to the existing closure machinery — the closure table
// auto-includes any `__closure_*` name and `collect_closure_arities` reads
// the wrapper's param count to register the matching call_indirect type.

/** Public function lookup_top_level_fn. */
export let lookup_top_level_fn = fn (name: string, ctx: MirCtx) -> Option<HirFunction> do
  let MirCtx(
      scope: _,
      cap_layouts: _,
      handler_cap_names: _,
      all_funcs: af,
      all_handlers: ah,
      all_exts: _,
      closure_counter: _,
      lifted_funcs: _,
      cont_binders: _,
      _
    ) = ctx
  match lookup_hir_func(name, funcs: af) do
        | Some(val: f) -> return Some(val: f)
        | None -> return lookup_hir_func_in_handlers(name, bindings: ah)
      end
end

let lookup_hir_func = fn (name: string, funcs: [ HirFunction ]) -> Option<HirFunction> do
  match funcs do
    | [] -> return None
    | HirFunction(
      name: n,
      type_params: tps,
      params: ps,
      ret_type: rt,
      throw_row: tw,
      body: bd,
      span: sp,
      file: fp,
      requires: req
    ) :: rest ->
      if n == name then
        return Some(val: HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, throw_row: tw, body: bd, span: sp, file: fp, requires: req))
      end
      return lookup_hir_func(name, funcs: rest)
  end
end

let lookup_hir_func_in_handlers = fn (
  name: string,
  bindings: [ HirHandlerBindingEntry ]
) -> Option<HirFunction> do
  match bindings do
    | [] -> return None
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      match lookup_hir_func(name, funcs: arms_to_funcs(arms)) do
        | Some(val: f) -> return Some(val: f)
        | None -> return lookup_hir_func_in_handlers(name, bindings: rest)
      end
  end
end

let funcref_wrapper_name = fn (target: string) -> string do
  return "__closure_wrap_" ++ target
end

let mir_func_named = fn (name: string, funcs: [ MirFunction ]) -> bool do
  match funcs do
    | [] -> return false
    | MirFunction(name: n, params: _, ret_type: _, body: _, span: _) :: rest ->
      if n == name then return true
      else return mir_func_named(name, funcs: rest)
      end
  end
end

let hir_params_to_call_args = fn (params: [ HirParam ]) -> [ MirCallArg ] throws { MirError } do
  return hir_params_to_call_args_go(params, acc: [])
end

let hir_params_to_call_args_go = fn (
  params: [ HirParam ],
  acc: [ MirCallArg ]
) -> [ MirCallArg ] throws { MirError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: l, name: n, sigil: _, typ: _) :: rest ->
      return hir_params_to_call_args_go(params: rest,
        acc: MirCallArg(label: l, value: MirVariable(name: n)) :: acc)
  end
end

/** Build a `__closure_wrap_<target>` MirFunction that forwards a closure call
 *  to a named top-level function. Generated lazily — `wrap_top_level_fn`
 *  dedupes by checking `lifted_funcs` for an existing wrapper before
 *  appending.
 */
let build_funcref_wrapper = fn (
  target: string,
  hf: HirFunction
) -> MirFunction throws { MirError } do
  let HirFunction(
    name: _,
    type_params: _,
    params: ps,
    ret_type: rt,
    throw_row: _,
    body: _,
    span: sp,
    file: _,
    requires: _
  ) = hf
  let env_param = MirParam(label: "__env", name: "__env", typ: TyI64)
  let orig_params = lower_lambda_params(params: ps)
  let all_params = env_param :: orig_params
  let call_args = hir_params_to_call_args(params: ps)
  let body = [ MirStmtReturn(expr: MirCall(func: target, args: call_args, ret_type: rt)) ]
  return MirFunction(name: funcref_wrapper_name(target),
                     params: all_params,
                     ret_type: lower_lambda_ret_type(t: rt),
                     body, span: sp)
end

/** Public function wrap_top_level_fn. */
export let wrap_top_level_fn = fn (
  name: string,
  hf: HirFunction,
  ctx: MirCtx
) -> MirExprResult throws { MirError } do
  let wrapper_name = funcref_wrapper_name(target: name)
  let MirCtx(
      scope: sc,
      cap_layouts: pl,
      handler_cap_names: hpn,
      all_funcs: af,
      all_handlers: ah,
      all_exts: ae,
      closure_counter: cc,
      lifted_funcs: lf,
      cont_binders: cb,
      value_binding_names: vbns,
      thunk_param_names: tpn
    ) = ctx
  if mir_func_named(name: wrapper_name, funcs: lf) then
        return MirExprResult(ctx, expr: MirMakeClosure(func_name: wrapper_name, captures: []))
      end
      let wrapper = build_funcref_wrapper(target: name, hf)
      let new_lf = append_mir_funcs(a: lf, b: [ wrapper ])
      let ctx2 = MirCtx(scope: sc, cap_layouts: pl, handler_cap_names: hpn,
                        all_funcs: af, all_handlers: ah, all_exts: ae,
                        closure_counter: cc, lifted_funcs: new_lf, cont_binders: cb, value_binding_names: vbns, thunk_param_names: tpn)
      return MirExprResult(ctx: ctx2, expr: MirMakeClosure(func_name: wrapper_name, captures: []))
end

/** Emit `let <cap_i> = MirEnvLoad("__env", i)` for each capture in order,
 *  starting at `index`. Captures are loaded as i64; a later sigil-aware
 *  pass (not yet implemented) may refine their semantic types.
 */
export let build_env_load_preamble = fn (
  captures: [ string ],
  index: i64
) -> [ MirStmt ] throws { MirError } do
  match captures do
    | [] -> return []
    | capture :: rest ->
      let stmt = MirStmtLet(name: capture, typ: TyI64, expr: MirEnvLoad(env_var: "__env", index))
      return stmt :: build_env_load_preamble(captures: rest, index: index + 1)
  end
end

/** Public function captures_to_mir_exprs. */
export let captures_to_mir_exprs = fn (
  caps: [ string ],
  acc: [ MirExpr ]
) -> [ MirExpr ] throws { MirError } do
  match caps do
    | [] -> return list.reverse(xs: acc)
    | c :: rest -> return captures_to_mir_exprs(caps: rest, acc: MirVariable(name: c) :: acc)
  end
end

/** Public function param_names_of. */
export let param_names_of = fn (params: [ HirParam ]) -> [ string ] throws { MirError } do
  return param_names_of_go(params, acc: [])
end

let param_names_of_go = fn (
  params: [ HirParam ],
  acc: [ string ]
) -> [ string ] throws { MirError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(
      label: _,
      name: n,
      sigil: _,
      typ: _
    ) :: rest -> return param_names_of_go(params: rest, acc: n :: acc)
  end
end

/** Names that are statically resolvable at the lambda's callsite and must
 *  NOT be treated as free variables: top-level function names, externals,
 *  and handler-method names.
 */
export let build_known_names = fn (ctx: MirCtx) -> [ string ] throws { MirError } do
  let MirCtx(
    scope: _,
    cap_layouts: pl,
    handler_cap_names: _,
    all_funcs: af,
    all_handlers: ah,
    all_exts: ae,
    closure_counter: _,
    lifted_funcs: _,
    cont_binders: _,
    _
  ) = ctx
  let from_funcs = fn_names_of(funcs: af, acc: [])
  let from_exts = ext_names_of(exts: ae, acc: [])
  let from_handlers = handler_fn_names_of(bindings: ah, acc: [])
  // Cap-method qualified names (e.g. "<mod>#Tag.name") resolve to a
  // top-level handler function during cap-call lowering, so they MUST NOT
  // be treated as free variables of a lifted lambda / thunk body. Without
  // this entry, a cap call inside a thunk body is captured as a closure
  // var and codegen later fails with E3001 (variable not found).
  let from_caps = cap_qualified_method_names(caps: pl, acc: [])
  let a = concat_strings(a: from_funcs, b: from_exts)
  let b = concat_strings(a, b: from_handlers)
  return concat_strings(a: b, b: from_caps)
end

/** Build the set of "<prefix><method>" strings (e.g. "<mod>#Tag.name")
 *  that the HIR Call.func field uses to denote a cap-method invocation.
 *  These are NOT real top-level functions; cap-call lowering rewrites
 *  each into a concrete `__handler_<binding>_<method>` call (static)
 *  or a `__dispatch_<Cap>_<method>` dispatcher (runtime). Reporting them
 *  as free variables would force the lifter to capture them as closure
 *  environment slots, which is wrong (no such variable exists).
 */
let cap_qualified_method_names = fn (
  caps: [ CapEntry ],
  acc: [ string ]
) -> [ string ] throws { MirError } do
  match caps do
    | [] -> return acc
    | CapEntry(name: _, prefix: px, methods: ms) :: rest ->
      let with_this = prefix_methods(prefix: px, methods: ms, acc)
      return cap_qualified_method_names(caps: rest, acc: with_this)
  end
end

let prefix_methods = fn (
  prefix: string,
  methods: [ string ],
  acc: [ string ]
) -> [ string ] throws { MirError } do
  match methods do
    | [] -> return acc
    | m :: rest -> return prefix_methods(prefix, methods: rest, acc: (prefix ++ m) :: acc)
  end
end

let fn_names_of = fn (funcs: [ HirFunction ], acc: [ string ]) -> [ string ] throws { MirError } do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, _) :: rest ->
      return fn_names_of(funcs: rest, acc: n :: acc)
  end
end

let ext_names_of = fn (exts: [ HirExternal ], acc: [ string ]) -> [ string ] throws { MirError } do
  match exts do
    | [] -> return list.reverse(xs: acc)
    | HirExternal(
      name: n,
      wasm_module: _,
      wasm_name: _,
      type_params: _,
      params: _,
      ret_type: _,
      throw_row: _
    ) :: rest ->
      return ext_names_of(exts: rest, acc: n :: acc)
  end
end

let handler_fn_names_of = fn (
  bindings: [ HirHandlerBindingEntry ],
  acc: [ string ]
) -> [ string ] throws { MirError } do
  match bindings do
    | [] -> return list.reverse(xs: acc)
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      return handler_fn_names_of(
        bindings: rest,
        acc: prepend_fn_names(funcs: arms_to_funcs(arms), acc)
      )
  end
end

let prepend_fn_names = fn (
  funcs: [ HirFunction ],
  acc: [ string ]
) -> [ string ] throws { MirError } do
  match funcs do
    | [] -> return acc
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, _) :: rest ->
      return prepend_fn_names(funcs: rest, acc: n :: acc)
  end
end

/** Walk HIR stmts, returning the names referenced but not locally bound
 *  and not in `known` (top-level functions, externals, handler methods).
 *  Preserves first-reference order and deduplicates.
 */
export let collect_hir_free_vars = fn (
  body: [ HirStmt ],
  params: [ string ],
  known: [ string ]
) -> [ string ] throws { MirError } do
  let defined = params
  let seen = []
  let refs = []
  let WalkResult(defined: _, seen: _, refs: r) = walk_stmts(stmts: body, defined, known, seen, refs)
  return list.reverse(xs: r)
end

/** Accumulator threaded through the HIR free-var walk. */
type WalkResult = WalkResult(defined: [ string ], seen: [ string ], refs: [ string ])

let walk_stmts = fn (
  stmts: [ HirStmt ],
  defined: [ string ],
  known: [ string ],
  seen: [ string ],
  refs: [ string ]
) -> WalkResult throws { MirError } do
  match stmts do
    | [] -> return WalkResult(defined, seen, refs)
    | HirStmt(node: s, span: _) :: rest ->
      let WalkResult(
        defined: d2,
        seen: s2,
        refs: r2
      ) = walk_stmt(stmt: s, defined, known, seen, refs)
      return walk_stmts(stmts: rest, defined: d2, known, seen: s2, refs: r2)
  end
end

let walk_stmt = fn (
  stmt: HirStmtKind,
  defined: [ string ],
  known: [ string ],
  seen: [ string ],
  refs: [ string ]
) -> WalkResult throws { MirError } do
  match stmt do
    | Let(name: n, sigil: _, typ: _, value: v) ->
      let WalkResult(
        defined: _,
        seen: s2,
        refs: r2
      ) = walk_expr(expr: v, defined, known, seen, refs)
      return WalkResult(defined: n :: defined, seen: s2, refs: r2)
    | Expr(expr: e) | Return(expr: e) ->
      return walk_expr(expr: e, defined, known, seen, refs)
    | Assign(target: t, value: v) ->
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_expr(expr: t, defined, known, seen, refs)
      return walk_expr(expr: v, defined, known, seen: s1, refs: r1)
    | Try(body: b, catch_param: cp, catch_body: cb) ->
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_stmts(stmts: b, defined, known, seen, refs)
      let WalkResult(
        defined: _,
        seen: s2,
        refs: r2
      ) = walk_stmts(stmts: cb, defined: cp :: defined, known, seen: s1, refs: r1)
      return WalkResult(defined, seen: s2, refs: r2)
    | Inject(handlers: _, body: b) ->
      return walk_stmts(stmts: b, defined, known, seen, refs)
  end
end

let walk_expr = fn (
  expr: HirExpr,
  defined: [ string ],
  known: [ string ],
  seen: [ string ],
  refs: [ string ]
) -> WalkResult throws { MirError } do
  let HirExpr(node, span: _) = expr
  match node do
    | Literal(_) -> return WalkResult(defined, seen, refs)
    | Variable(name: n, sigil: _) | Borrow(name: n, sigil: _) ->
      return record_ref(name: n, defined, known, seen, refs)
    | BinOp(left: l, op: _, right: r) ->
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_expr(expr: l, defined, known, seen, refs)
      return walk_expr(expr: r, defined, known, seen: s1, refs: r1)
    | UnOp(op: _, operand: o) ->
      return walk_expr(expr: o, defined, known, seen, refs)
    | Call(func: f, args) ->
      let WalkResult(
        defined: _,
        seen: s0,
        refs: r0
      ) = record_ref(name: f, defined, known, seen, refs)
      return walk_call_args(args, defined, known, seen: s0, refs: r0)
    | CallExpr(callee: c, args) ->
      let WalkResult(
        defined: _,
        seen: s0,
        refs: r0
      ) = walk_expr(expr: c, defined, known, seen, refs)
      return walk_call_args(args, defined, known, seen: s0, refs: r0)
    | Ctor(variant: _, args, labels: _, sigil: _) ->
      return walk_expr_list(exprs: args, defined, known, seen, refs)
    | Record(fields: fs) ->
      return walk_named_exprs(exprs: fs, defined, known, seen, refs)
    | Array(elems: es) ->
      return walk_expr_list(exprs: es, defined, known, seen, refs)
    | Index(target: t, index: i) ->
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_expr(expr: t, defined, known, seen, refs)
      return walk_expr(expr: i, defined, known, seen: s1, refs: r1)
    | FieldAccess(target: t, field: _) ->
      return walk_expr(expr: t, defined, known, seen, refs)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_expr(expr: c, defined, known, seen, refs)
      let WalkResult(
        defined: _,
        seen: s2,
        refs: r2
      ) = walk_stmts(stmts: tb, defined, known, seen: s1, refs: r1)
      match eb do
                | Some(val: stmts) -> return walk_stmts(stmts, defined, known, seen: s2, refs: r2)
                | None -> return WalkResult(defined, seen: s2, refs: r2)
              end
    | Match(target: t, cases: cs) ->
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_expr(expr: t, defined, known, seen, refs)
      return walk_match_cases(cases: cs, defined, known, seen: s1, refs: r1)
    | While(cond: c, body: b) ->
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_expr(expr: c, defined, known, seen, refs)
      return walk_stmts(stmts: b, defined, known, seen: s1, refs: r1)
    | For(var, start: s, end_expr: e, body: b) ->
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_expr(expr: s, defined, known, seen, refs)
      let WalkResult(
        defined: _,
        seen: s2,
        refs: r2
      ) = walk_expr(expr: e, defined, known, seen: s1, refs: r1)
      return walk_stmts(stmts: b, defined: var :: defined, known, seen: s2, refs: r2)
    | Lambda(type_params: _, params: lps, ret_type: _, requires: _, throw_row: _, body: lbody) ->
      // Nested lambda: its params shadow captures; treat its body with
      // its params added to `defined` so its own free vars are reported.
      let inner_defined = concat_strings(a: param_names_of(params: lps), b: defined)
      return walk_stmts(stmts: lbody, defined: inner_defined, known, seen, refs)
    | Raise(expr: e) | Force(expr: e) -> return walk_expr(expr: e, defined, known, seen, refs)
    | Thunk(body: b) -> return walk_expr(expr: b, defined, known, seen, refs)
    | ExternalRef(
      symbol: _,
      type_params: _,
      arg_names: _,
      typ: _
    ) | Handler(_) -> return WalkResult(defined, seen, refs)
  end
end

/** If `name` isn't already defined or known and wasn't seen yet, record it. */
let record_ref = fn (
  name: string,
  defined: [ string ],
  known: [ string ],
  seen: [ string ],
  refs: [ string ]
) -> WalkResult throws { MirError } do
  if string_mem(x: name, xs: defined) then return WalkResult(defined, seen, refs) end
  if string_mem(x: name, xs: known) then return WalkResult(defined, seen, refs) end
  if string_mem(x: name, xs: seen) then return WalkResult(defined, seen, refs) end
  return WalkResult(defined, seen: name :: seen, refs: name :: refs)
end

let string_mem = fn (x: string, xs: [ string ]) -> bool throws { MirError } do
  match xs do
    | [] -> return false
    | y :: rest ->
      if x == y then return true end
      return string_mem(x, xs: rest)
  end
end

let walk_expr_list = fn (
  exprs: [ HirExpr ],
  defined: [ string ],
  known: [ string ],
  seen: [ string ],
  refs: [ string ]
) -> WalkResult throws { MirError } do
  match exprs do
    | [] -> return WalkResult(defined, seen, refs)
    | e :: rest ->
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_expr(expr: e, defined, known, seen, refs)
      return walk_expr_list(exprs: rest, defined, known, seen: s1, refs: r1)
  end
end

let walk_call_args = fn (
  args: [ HirCallArg ],
  defined: [ string ],
  known: [ string ],
  seen: [ string ],
  refs: [ string ]
) -> WalkResult throws { MirError } do
  match args do
    | [] -> return WalkResult(defined, seen, refs)
    | HirCallArg(label: _, value: v) :: rest ->
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_expr(expr: v, defined, known, seen, refs)
      return walk_call_args(args: rest, defined, known, seen: s1, refs: r1)
  end
end

let walk_named_exprs = fn (
  exprs: [ HirNamedExpr ],
  defined: [ string ],
  known: [ string ],
  seen: [ string ],
  refs: [ string ]
) -> WalkResult throws { MirError } do
  match exprs do
    | [] -> return WalkResult(defined, seen, refs)
    | HirNamedExpr(name: _, value: v) :: rest ->
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_expr(expr: v, defined, known, seen, refs)
      return walk_named_exprs(exprs: rest, defined, known, seen: s1, refs: r1)
  end
end

let walk_match_cases = fn (
  cases: [ HirMatchCase ],
  defined: [ string ],
  known: [ string ],
  seen: [ string ],
  refs: [ string ]
) -> WalkResult throws { MirError } do
  match cases do
    | [] -> return WalkResult(defined, seen, refs)
    | HirMatchCase(pattern: p, body: b) :: rest ->
      let case_defined = concat_strings(a: pattern_bindings(pat: p, acc: []), b: defined)
      let WalkResult(
        defined: _,
        seen: s1,
        refs: r1
      ) = walk_stmts(stmts: b, defined: case_defined, known, seen, refs)
      return walk_match_cases(cases: rest, defined, known, seen: s1, refs: r1)
  end
end

let pattern_bindings = fn (
  pat: HirPatternKind,
  acc: [ string ]
) -> [ string ] throws { MirError } do
  match pat do
    | hir.PLit(_) | hir.PWild -> return acc
    | hir.PVar(name: n, sigil: _) -> return n :: acc
    | hir.PCtor(variant: _, fields: fs, sigil: _) -> return pattern_field_bindings(fs, acc)
    | hir.PRec(fields: fs, is_partial: _) -> return record_pattern_field_bindings(fs, acc)
    // Or-pattern alternatives bind the same variables (typecheck enforces this);
    // walking the first alternative is sufficient.
    | hir.POr(alts) ->
      match alts do
        | first :: _ -> return pattern_bindings(pat: first, acc)
        | [] -> return acc
      end
  end
end

let pattern_field_bindings = fn (
  fs: [ HirPatternField ],
  acc: [ string ]
) -> [ string ] throws { MirError } do
  match fs do
    | [] -> return acc
    | HirPatternField(
      name: _,
      pattern: p
    ) :: rest -> return pattern_field_bindings(fs: rest, acc: pattern_bindings(pat: p, acc))
  end
end

let record_pattern_field_bindings = fn (
  fs: [ HirRecordPatField ],
  acc: [ string ]
) -> [ string ] throws { MirError } do
  match fs do
    | [] -> return acc
    | HirRecordPatField(
      name: _,
      pattern: p
    ) :: rest -> return record_pattern_field_bindings(fs: rest, acc: pattern_bindings(pat: p, acc))
  end
end
