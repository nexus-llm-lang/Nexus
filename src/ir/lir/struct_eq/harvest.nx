/**
 * struct_eq/harvest: type-HARVESTING — discovery of which types need a generated
 * `__streq_*` helper.
 *
 * Owns:
 *  - List-element seeding from the program's DECLARED shapes (primitives, named
 *    aggregates, one nested list level, every record/variant field's list types)
 *    plus the dedup-push primitives (`push_elem`, `push_inst`) and
 *    `make_list_helpers`.
 *  - ANONYMOUS-record list-element recovery from the MIR via
 *    `infer_semantic_type` (`harvest_expr` / `harvest_stmt` / `harvest_func` …),
 *    so `[{ col: mk(7) }]` keys the SAME helper the `==` call site does.
 *  - The `#EQSITE#` worklist SEEDING: marking `==`/`!=` operand types, then
 *    unwrapping them to the concrete per-instantiation compare TARGETS
 *    (`eq_site_marker`, `harvested_eq_site_insts`, `targets_in_type`).
 *
 * Imports the emission/keying leaf (struct_eq/emit.nx). Imported by
 * struct_eq/inst.nx (which reuses `targets_in_type` / `push_inst`) and the
 * struct_eq.nx facade.
 */
import { TypeExpr, TyRecord, TyUserDefined, TyBool, TyI64, TyF64, TyChar,
         TyString, TyList, TyVar, NamedType,
         EnumDef, RecordDef, VariantDef, VariantField } from "src/types/type_expr.nx"
import { LirFunction } from "src/ir/lir/types.nx"
import { LowerCtx, TypeEntry, insert_type } from "src/ir/lir/context.nx"
import { infer_semantic_type } from "src/ir/lir/semantic_types.nx"
import { register_pattern_binders } from "src/ir/lir/lower_helpers.nx"
import { LirError } from "src/ir/lir/errors.nx"
import { Some, None, Option } from "std:option"
import * as list from "std:list"
import { VariantIndex }, * as vidx from "src/ir/support/variant_index.nx"
import {
  MirFunction,
  MirParam,
  MirExpr,
  MirBinaryOp,
  MirCall,
  MirConstructor,
  MirRecord,
  MirArray,
  MirIndex,
  MirFieldAccess,
  MirIf,
  MirMatch,
  MirWhile,
  MirRaise,
  MirForce,
  MirMakeClosure,
  MirCallClosure,
  MirSuspend,
  MirResume,
  MirBlock,
  MirInjectValue,
  MirNamedExpr,
  MirCallArg,
  MirStmt,
  MirStmtLet,
  MirStmtExpr,
  MirStmtReturn,
  MirStmtAssign,
  MirStmtTry,
  MirMatchCase
} from "src/ir/mir/types.nx"
import {
  list_type_name,
  inst_key,
  is_struct_eq_op,
  is_concrete_generic_inst,
  make_list_helper
} from "src/ir/lir/struct_eq/emit.nx"

// ─── List-helper element-type collection ────────────────────────────────────
//
// `[elem] == [elem]` lowers to a CALL of `__streq_List$<key(elem)>`. One such
// helper must be synthesized per distinct element type that any list `==`/`!=`
// compares. The element type lives at the `==` site (in the MIR/semantic type)
// and is NOT recovered here, so the set is over-approximated from the program's
// declared shapes plus the primitive base set: every concrete element type a
// list literal/value can carry is covered (primitives, every named aggregate,
// one level of list-of-list per the spec's nested-list requirement). Unused
// helpers are harmless — they reference only themselves and `elem`'s helper,
// both of which are generated. An element type outside this set (e.g. an
// uncommon deeper nesting) falls back to the generic `T`-keyed helper, whose
// element compare is the i64 value compare (the type-erased precedent).

// Add `e` to `acc` keyed by `list_type_name` (dedup by helper name).
export let push_elem = fn (e: TypeExpr, acc: [ TypeExpr ]) -> [ TypeExpr ] do
  return push_elem_go(e, key: list_type_name(elem: e), rest: acc, full: acc)
end

let push_elem_go = fn (
  e: TypeExpr,
  key: string,
  rest: [ TypeExpr ],
  full: [ TypeExpr ]
) -> [ TypeExpr ] do
  match rest do
    | [] -> return e :: full
    | h :: tl ->
      if list_type_name(elem: h) == key then return full
      else return push_elem_go(e, key, rest: tl, full)
      end
  end
end

// Harvest the list element types reachable from a field type: a `[e]` field
// contributes `[e]`, and the recursion into `e` contributes any nested `[[..]]`.
let harvest_type = fn (t: TypeExpr, acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match t do
    | TyList(elem: e) ->
      // record `[e]` itself as a needed helper; recurse into `e` (covers `[[x]]`).
      let acc1 = push_elem(e, acc)
      return harvest_type(t: e, acc: acc1)
    | _ -> return acc
  end
end

export let enum_field_types = fn (defs: [ EnumDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | EnumDef(
      name: _,
      is_public: _,
      is_opaque: _,
      type_params: _,
      variants: vs,
      layout_variants: _
    ) :: rest ->
      return enum_field_types(defs: rest, acc: variant_list_field_types(vs, acc))
  end
end

let variant_list_field_types = fn (vs: [ VariantDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match vs do
    | [] -> return acc
    | VariantDef(name: _, fields: fs) :: rest ->
      return variant_list_field_types(vs: rest, acc: variant_field_types_go(fs, acc))
  end
end

let variant_field_types_go = fn (fs: [ VariantField ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match fs do
    | [] -> return acc
    | VariantField(
      name: _,
      typ: t
    ) :: rest -> return variant_field_types_go(fs: rest, acc: harvest_type(t, acc))
  end
end

export let record_field_types = fn (defs: [ RecordDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | RecordDef(name: _, is_public: _, type_params: _, fields: fs) :: rest ->
      return record_field_types(defs: rest, acc: record_field_types_go(fs, acc))
  end
end

let record_field_types_go = fn (fs: [ NamedType ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match fs do
    | [] -> return acc
    | NamedType(
      name: _,
      typ: t
    ) :: rest -> return record_field_types_go(fs: rest, acc: harvest_type(t, acc))
  end
end

// Element types whose `[elem]` list helper is always synthesized: the primitive
// base set, every named aggregate (record/enum), and one nested level of
// list-of-each so a bare `[[1], [2]]` (`[[i64]]`) compare resolves its helper.
export let enum_name_elems = fn (defs: [ EnumDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | EnumDef(
      name: en,
      is_public: _,
      is_opaque: _,
      type_params: _,
      variants: vs,
      layout_variants: _
    ) :: rest ->
      let acc2 = match vs do
        | [] -> acc
        | _ -> push_elem(e: TyUserDefined(name: en, args: []), acc)
      end
      return enum_name_elems(defs: rest, acc: acc2)
  end
end

export let record_name_elems = fn (defs: [ RecordDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | RecordDef(name: rn, is_public: _, type_params: _, fields: _) :: rest ->
      return record_name_elems(
        defs: rest,
        acc: push_elem(e: TyUserDefined(name: rn, args: []), acc)
      )
  end
end

export let primitive_elems = fn () -> [ TypeExpr ] do
  return [ TyI64, TyString, TyBool, TyF64, TyChar ]
end

export let seed_elems_into = fn (xs: [ TypeExpr ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match xs do
    | [] -> return acc
    | x :: rest -> return seed_elems_into(xs: rest, acc: push_elem(e: x, acc))
  end
end

// Add `[base]` as a new element for every base element, so a bare list-of-list
// (`[[i64]]`) compare has its helper. One nesting level covers the spec's
// nested-list requirement; deeper nesting falls back to the generic helper.
export let nest_one_level = fn (bases: [ TypeExpr ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match bases do
    | [] -> return acc
    | b :: rest -> return nest_one_level(bases: rest, acc: push_elem(e: TyList(elem: b), acc))
  end
end

export let make_list_helpers = fn (
  elems: [ TypeExpr ],
  enum_defs: VariantIndex,
  acc: [ LirFunction ]
) -> [ LirFunction ] throws { LirError } do
  match elems do
    | [] -> return list.reverse(xs: acc)
    | e :: rest -> return make_list_helpers(
      elems: rest,
      enum_defs,
      acc: make_list_helper(
        type_name: list_type_name(elem: e),
        elem: e,
        gen_inst: false,
        enum_defs
      ) :: acc
    )
  end
end

// ─── ANONYMOUS-record list-element harvesting (from MIR, with a semantic env) ─
//
// A list whose element is an ANONYMOUS record (`[{a, b}]` / `[{ col: mk(7) }]`)
// has no declared type name, so its `__streq_List$Rec$...` helper cannot be seeded
// from the EnumDef / RecordDef tables — the element shape lives only in the MIR.
// A list literal desugars to `Cons(rest, v)` / `Nil`, so for every `Cons` we
// recover the list ELEMENT type from the head value `v` and, when it (or a nesting
// of it) carries an anonymous record, push that element type so the matching helper
// is synthesized.
//
// KEY (nexus-h69yj): the element type MUST be recovered with the SAME
// `infer_semantic_type` the `==` CALL SITE uses, because an anon-record FIELD value
// may be a call / variable / match / field-access (`{ col: mk(7) }`) whose type is
// semantic, not a syntactic literal. The previous `mir_field_type` walk had a
// catch-all that erased those to `TyI64`, so the harvested helper name
// (`…col=i64…`) diverged from the call site's (`…col=Color…`) → the helper was
// never generated → E3001 codegen abort. We therefore thread the SAME running
// semantic-variable env the real LIR lowering builds (function params + each `let`
// binding's recovered type) and type each `Cons` head with `infer_semantic_type`.
//
// The recursive walk threads a SINGLE flat `[TypeExpr]` accumulator of the raw
// recovered list types (NOT yet filtered) — mirroring the known-good single-
// accumulator shape; the anon-record FILTER runs in a SEPARATE, non-recursive pass
// (harvested_anon_record_elems). This deliberately avoids threading a richer record
// through the deep mutual recursion, which the self-host seed miscompiles.

// Walk an expr, pushing the RAW recovered semantic type of every `MirConstructor`
// (a `Cons` yields `TyList(elem)`), and always recursing into sub-exprs so nested
// list literals (`[[{...}]]`, `f([{...}])`) are caught.
let harvest_expr = fn (
  e: MirExpr,
  ctx: LowerCtx,
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { LirError } do
  match e do
    | MirConstructor(name: _, args: cargs) ->
      let acc1 = infer_semantic_type(expr: e, ctx) :: acc
      return harvest_exprs(es: cargs, ctx, acc: acc1)
    | MirRecord(fields: fs) -> return harvest_named_exprs(fs, ctx, acc)
    | MirArray(elems: es) -> return harvest_exprs(es, ctx, acc)
    | MirBinaryOp(left: l, op, right: r) ->
      // At a `==` / `!=` SITE, record both operands' recovered semantic types
      // (wrapped in the `#EQSITE#` marker) so the per-instantiation worklist is
      // seeded STRICTLY from comparison sites — never from an incidental
      // `Some(...)` construction elsewhere (worklist rule 1). The marker name
      // carries `#`, so it can never collide with a real type; the worklist
      // post-pass (`harvested_eq_site_insts`) unwraps it.
      let acc_eq = if is_struct_eq_op(op) then eq_site_marker(t: infer_semantic_type(expr: r, ctx)) :: (eq_site_marker(t: infer_semantic_type(expr: l, ctx)) :: acc) else acc end
      return harvest_expr(e: r, ctx, acc: harvest_expr(e: l, ctx, acc: acc_eq))
    | MirCall(func: _, args: cas, ret_type: _) -> return harvest_call_args(cas, ctx, acc)
    | MirCallClosure(
      closure: c,
      args: cas,
      ret_type: _
    ) -> return harvest_call_args(cas, ctx, acc: harvest_expr(e: c, ctx, acc))
    | MirIndex(
      target: t,
      index: i
    ) -> return harvest_expr(e: i, ctx, acc: harvest_expr(e: t, ctx, acc))
    | MirFieldAccess(target: t, field: _) -> return harvest_expr(e: t, ctx, acc)
    | MirIf(cond: c, then_body: tb, else_body: eb) ->
      let acc1 = harvest_expr(e: c, ctx, acc)
      let acc2 = harvest_stmts(stmts: tb, ctx, acc: acc1)
      match eb do
        | Some(val: ebs) -> return harvest_stmts(stmts: ebs, ctx, acc: acc2)
        | None -> return acc2
      end
    | MirMatch(target: t, cases: cs) -> return harvest_cases(
      cs,
      scrutinee_sem: infer_semantic_type(expr: t, ctx),
      ctx,
      acc: harvest_expr(e: t, ctx, acc)
    )
    | MirWhile(
      cond: c,
      body: b
    ) -> return harvest_stmts(stmts: b, ctx, acc: harvest_expr(e: c, ctx, acc))
    | MirRaise(expr: x) -> return harvest_expr(e: x, ctx, acc)
    | MirForce(expr: x) -> return harvest_expr(e: x, ctx, acc)
    | MirMakeClosure(func_name: _, captures: cs) -> return harvest_exprs(es: cs, ctx, acc)
    | MirSuspend(tag_name: _, payload: p, ret_type: _) -> return harvest_expr(e: p, ctx, acc)
    | MirResume(cont_var: _, value: v, ret_type: _) -> return harvest_expr(e: v, ctx, acc)
    | MirBlock(stmts: ss) -> return harvest_stmts(stmts: ss, ctx, acc)
    | MirInjectValue(stmts: ss, ret_type: _) -> return harvest_stmts(stmts: ss, ctx, acc)
    | _ -> return acc
  end
end

let harvest_exprs = fn (
  es: [ MirExpr ],
  ctx: LowerCtx,
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { LirError } do
  match es do
    | [] -> return acc
    | x :: rest -> return harvest_exprs(es: rest, ctx, acc: harvest_expr(e: x, ctx, acc))
  end
end

let harvest_named_exprs = fn (
  fs: [ MirNamedExpr ],
  ctx: LowerCtx,
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { LirError } do
  match fs do
    | [] -> return acc
    | MirNamedExpr(
      name: _,
      value: v
    ) :: rest -> return harvest_named_exprs(fs: rest, ctx, acc: harvest_expr(e: v, ctx, acc))
  end
end

let harvest_call_args = fn (
  cas: [ MirCallArg ],
  ctx: LowerCtx,
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { LirError } do
  match cas do
    | [] -> return acc
    | MirCallArg(
      label: _,
      value: v
    ) :: rest -> return harvest_call_args(cas: rest, ctx, acc: harvest_expr(e: v, ctx, acc))
  end
end

let harvest_cases = fn (
  cs: [ MirMatchCase ],
  scrutinee_sem: TypeExpr,
  ctx: LowerCtx,
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { LirError } do
  match cs do
    | [] -> return acc
    // Match-arm bodies run in a nested scope. Register the arm's pattern binders
    // (typed from the scrutinee) into a PER-ARM ctx so a binder referenced in the
    // body (`hh.c` from `| Wrapped(h: hh) -> [{ col: hh.c }]`) recovers its real
    // record/sum type — matching the `==` call site, so the harvested helper name
    // (`col=Color`) agrees with the call site's (else E3001 / identity compare).
    // The extended ctx is local to this arm; the recursion uses the original.
    | MirMatchCase(pattern: pat, body: b) :: rest ->
      let arm_ctx = register_pattern_binders(pattern: pat, scrutinee_sem, ctx)
      return harvest_cases(
        cs: rest,
        scrutinee_sem,
        ctx,
        acc: harvest_stmts(stmts: b, ctx: arm_ctx, acc)
      )
  end
end

// Walk statements threading the running env: a `let` extends the env with the
// binding's recovered semantic type so a LATER list literal that references the
// variable recovers the same element type the real lowering does.
let harvest_stmts = fn (
  stmts: [ MirStmt ],
  ctx: LowerCtx,
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { LirError } do
  match stmts do
    | [] -> return acc
    | s :: rest ->
      let HarvestStmtResult(ctx: ctx1, acc: acc1) = harvest_stmt(s, ctx, acc)
      return harvest_stmts(stmts: rest, ctx: ctx1, acc: acc1)
  end
end

type HarvestStmtResult = HarvestStmtResult(ctx: LowerCtx, acc: [ TypeExpr ])

let harvest_stmt = fn (
  s: MirStmt,
  ctx: LowerCtx,
  acc: [ TypeExpr ]
) -> HarvestStmtResult throws { LirError } do
  match s do
    | MirStmtLet(name: n, typ: _, expr: e) ->
      let acc1 = harvest_expr(e, ctx, acc)
      let inst = infer_semantic_type(expr: e, ctx)
      let LowerCtx(vars: v, semantic_vars: sv, stmts: st, temp_counter: tc, enum_defs: ed) = ctx
      return HarvestStmtResult(
        ctx: LowerCtx(
          vars: v,
          semantic_vars: insert_type(name: n, typ: inst, entries: sv),
          stmts: st,
          temp_counter: tc,
          enum_defs: ed
        ),
        acc: acc1
      )
    | MirStmtExpr(expr: e) -> return HarvestStmtResult(ctx, acc: harvest_expr(e, ctx, acc))
    | MirStmtReturn(expr: e) -> return HarvestStmtResult(ctx, acc: harvest_expr(e, ctx, acc))
    | MirStmtAssign(target: t, value: vv) -> return HarvestStmtResult(
      ctx,
      acc: harvest_expr(e: vv, ctx, acc: harvest_expr(e: t, ctx, acc))
    )
    | MirStmtTry(body: b, catch_param: _, catch_body: cb) ->
      let acc1 = harvest_stmts(stmts: b, ctx, acc)
      return HarvestStmtResult(ctx, acc: harvest_stmts(stmts: cb, ctx, acc: acc1))
    | _ -> return HarvestStmtResult(ctx, acc)
  end
end

let seed_param_env = fn (params: [ MirParam ], acc: [ TypeEntry ]) -> [ TypeEntry ] do
  match params do
    | [] -> return acc
    | MirParam(
      label: _,
      name: n,
      typ: t
    ) :: rest -> return seed_param_env(params: rest, acc: TypeEntry(name: n, typ: t) :: acc)
  end
end

let harvest_func = fn (
  f: MirFunction,
  enum_defs: VariantIndex,
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { LirError } do
  let MirFunction(name: _, params: ps, ret_type: _, body: b, span: _) = f
  let ctx0 = LowerCtx(
    vars: [],
    semantic_vars: seed_param_env(params: ps, acc: []),
    stmts: [],
    temp_counter: 0,
    enum_defs
  )
  return harvest_stmts(stmts: b, ctx: ctx0, acc)
end

export let harvest_mir_funcs = fn (
  funcs: [ MirFunction ],
  enum_defs: VariantIndex,
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { LirError } do
  match funcs do
    | [] -> return acc
    | f :: rest -> return harvest_mir_funcs(
      funcs: rest,
      enum_defs,
      acc: harvest_func(f, enum_defs, acc)
    )
  end
end

// Does a list-element type carry an anonymous record anywhere a generated helper
// would need it (the element itself, or under one or more `[..]` nestings)?
let elem_carries_anon_record = fn (t: TypeExpr) -> bool do
  match t do
    | TyRecord(fields: _) -> return true
    | TyList(elem: inner) -> return elem_carries_anon_record(t: inner)
    | _ -> return false
  end
end

// Non-recursive post-pass: from the flat raw list of recovered constructor types,
// push the ELEMENT type of every `TyList(elem)` whose element carries an anonymous
// record (dedup by helper name via push_elem).
export let harvested_anon_record_elems = fn (
  raw: [ TypeExpr ],
  acc: [ TypeExpr ]
) -> [ TypeExpr ] do
  match raw do
    | [] -> return acc
    | TyList(elem: el) :: rest ->
      let acc1 = if elem_carries_anon_record(t: el) then push_elem(e: el, acc) else acc end
      return harvested_anon_record_elems(raw: rest, acc: acc1)
    | _ :: rest -> return harvested_anon_record_elems(raw: rest, acc)
  end
end

// ─── Per-instantiation helper worklist seeding (generic-enum-at-concrete) ────
//
// `==`/`!=` on a generic enum at a concrete structural instantiation
// (`Some(Red(7)) == Some(Red(7))`, operand type `Option<Color>`) must compare the
// type-parameter payload STRUCTURALLY (spec § T-Cmp), not by the heap-pointer
// identity the type-erased bare `__streq_Option` emits. The per-instantiation set
// is seeded STRICTLY from `==`/`!=` SITES (the `#EQSITE#`-marked operand types
// harvested above), then transitively closed (see struct_eq/inst.nx) over the
// generic instantiations those helpers recurse into. It is NOT seeded from
// arbitrary declared type fields.
//
// All shapes are seed-safe: flat `[TypeExpr]` / `[string]` accumulators threaded
// as separate params (never a rich record through deep recursion).

// Marker wrapping a `==`-site operand type in the flat harvest accumulator. The
// `#` in the name guarantees no collision with a real `TyUserDefined` type.
let eq_site_marker = fn (t: TypeExpr) -> TypeExpr do
  return TyUserDefined(name: "#EQSITE#", args: [ t ])
end

// Non-recursive post-pass: unwrap every `#EQSITE#` marker and keep the operand
// types that name a per-instantiation COMPARE TARGET — a concrete generic-enum
// instantiation (`Option<Color>`) or a list whose element carries one
// (`[Option<Color>]`). Everything else (primitives, bare enums, anon records,
// `==` on non-generic types) contributes no per-inst helper.
export let harvested_eq_site_insts = fn (
  raw: [ TypeExpr ],
  enum_defs: VariantIndex,
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { LirError } do
  match raw do
    | [] -> return acc
    | TyUserDefined(name: "#EQSITE#", args: [ operand ]) :: rest ->
      return harvested_eq_site_insts(
        raw: rest,
        enum_defs,
        acc: targets_in_type(t: operand, enum_defs, acc)
      )
    | _ :: rest -> return harvested_eq_site_insts(raw: rest, enum_defs, acc)
  end
end

// Collect, from a single type, every per-instantiation compare TARGET it
// contains: a concrete generic-enum instantiation `Enum<concrete>` (one for which
// a `__streq_Enum$args` helper is keyed) and, for a `[elem]`, the list itself when
// its element carries a target plus the element's own targets. Walks the finite
// TypeExpr structure, threading a single flat accumulator (dedup by helper name
// via `push_inst`).
export let targets_in_type = fn (
  t: TypeExpr,
  enum_defs: VariantIndex,
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { LirError } do
  match t do
    | TyUserDefined(name: en, args: ats) ->
      if is_concrete_generic_inst(t) then
        match vidx.variants_of_enum(idx: enum_defs, enum_name: en) do
          // Only a generic ENUM (known in-scope variants) gets a per-inst helper;
          // a generic RECORD/struct instantiation (e.g. `Map<…>`) is left to its
          // bare helper (its declared fields are not `==`-seeded).
          | [] -> return targets_in_type_list(ts: ats, enum_defs, acc)
          | _ -> return targets_in_type_list(ts: ats, enum_defs, acc: push_inst(e: t, acc))
        end
      else
        return targets_in_type_list(ts: ats, enum_defs, acc)
      end
    | TyList(elem: el) ->
      // A list whose element carries a target needs its OWN per-inst list helper
      // (`__streq_List$Option$Color`); recurse into the element for nested targets.
      let acc1 = if type_carries_inst_target(
        t: el,
        enum_defs
      ) then push_inst(e: t, acc) else acc end
      return targets_in_type(t: el, enum_defs, acc: acc1)
    | _ -> return acc
  end
end

let targets_in_type_list = fn (
  ts: [ TypeExpr ],
  enum_defs: VariantIndex,
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { LirError } do
  match ts do
    | [] -> return acc
    | x :: rest -> return targets_in_type_list(
      ts: rest,
      enum_defs,
      acc: targets_in_type(t: x, enum_defs, acc)
    )
  end
end

// True iff `t` (a list element) contains a per-instantiation target anywhere, so
// the enclosing `[t]` warrants a per-inst list helper rather than the bare one.
let type_carries_inst_target = fn (
  t: TypeExpr,
  enum_defs: VariantIndex
) -> bool throws { LirError } do
  match targets_in_type(t, enum_defs, acc: []) do
    | [] -> return false
    | _ -> return true
  end
end

// Dedup-push a target by its per-instantiation helper-bearing name (`inst_key`).
export let push_inst = fn (e: TypeExpr, acc: [ TypeExpr ]) -> [ TypeExpr ] do
  return push_inst_go(e, key: inst_key(t: e), rest: acc, full: acc)
end

let push_inst_go = fn (
  e: TypeExpr,
  key: string,
  rest: [ TypeExpr ],
  full: [ TypeExpr ]
) -> [ TypeExpr ] do
  match rest do
    | [] -> return e :: full
    | h :: tl -> if inst_key(t: h) == key then return full else return push_inst_go(
      e,
      key,
      rest: tl,
      full
    ) end
  end
end
