/**
 * lir_opt: LIR optimization passes for the self-hosting compiler.
 *
 * Chains the following passes:
 *
 * 0. Stream fusion (build/foldr): rewrites `foldr(k, z, build(g))` to
 *    `g(k, z)` when k is pure per the supplied EffectMap. Eliminates the
 *    intermediate list created by `build`. Re-sweeps each scope to a
 *    fixed point so multi-stage chains (e.g. map_b . filter_b . map_b)
 *    collapse stage-by-stage as orphan-build drops unblock new fusion
 *    sites. Entry point: `optimize_lir_with_effects`.
 * 1. Constant folding: evaluates binary ops on literal atoms at compile time
 * 2. Constant propagation + copy propagation: substitutes known bindings into
 *    use sites (literal constants AND variable-to-variable copies)
 * 3. Dead branch elimination: inlines the live branch of if-statements with
 *    constant conditions
 * 4. Dead code elimination: removes unused pure let bindings. The
 *    effect-aware variant additionally drops `LirExprCall(callee, ...)`
 *    bindings whose result is unused when the EffectMap reports the
 *    callee as is_pure (e.g. orphaned `build` calls left behind by the
 *    fusion rewrite). Externals are excluded — they are host-capability
 *    calls and never DCE candidates.
 *
 * Passes 1-3 are combined in a single forward walk (opt_fp_stmts).
 * Pass 4 runs separately afterward (opt_dce_stmts / opt_dce_stmts_eff).
 *
 * `optimize_lir(program)` runs passes 1-4 with no fusion (effect map empty);
 * `optimize_lir_with_effects(program, effects)` adds pass 0 in front and
 * routes pass 4 through the effect-aware DCE, so fusion's orphaned build
 * call vanishes alongside any other unused-result pure call.
 *
 * Per-pass implementations live under src/ir/lir/opt/:
 *   helpers.nx      — shared types, lookups, multi-bind detection, reverses
 *   folding.nx      — constant folding + identity/absorbing rules
 *   substitution.nx — atom / call-arg / named-atom / expr substitution
 *   propagate.nx    — combined fold+propagate forward walk
 *   dce.nx          — use collection + (effect-aware) DCE
 *   fusion.nx       — stream fusion (build/foldr shortcut deforestation)
 *   autovec.nx      — autovec call-target swap (scalar → SIMD intrinsic)
 */

//
// ALL optimization passes MUST maintain these invariants:
//
// 1. FUNCTION BOUNDARIES: Never merge or split functions. Codegen emits
//    bt_push(name) at function entry and bt_pop() at every exit. Changing
//    function boundaries breaks push/pop pairing.
//
// 2. RAISE PRESERVATION: Never remove or reorder LirExprRaise. Codegen
//    emits bt_freeze() before each Raise to snapshot the call stack.
//
// 3. RETURN PRESERVATION: Never remove explicit returns. Codegen emits
//    bt_pop() before each Return/ReturnCall.
//
// 4. TRY-CATCH STRUCTURE: Never eliminate or restructure LirStmtTryCatch.
//
// 5. TAIL CALL PRESERVATION: LirExprTailCall includes bt_pop() before the
//    return_call in codegen. Never remove tail calls.
//
// The passes below operate only on LirStmtLet bindings, atoms, and
// constant-condition branches, naturally preserving these invariants.
// DCE explicitly checks for side effects before removing any binding.

import { LirProgram, LirFunction, LirExternal } from "src/ir/lir/types.nx"
import * as list from "std:list"
import { EffectMap } from "src/ir/shared/effect_map.nx"
import { FoldResult, opt_find_multi, opt_let_names_stmts } from "src/ir/lir/opt/helpers.nx"
import { opt_subst_atom } from "src/ir/lir/opt/substitution.nx"
import { opt_fp_stmts } from "src/ir/lir/opt/propagate.nx"
import { opt_collect_atom, opt_collect_stmts, opt_dce_stmts,
         opt_dce_stmts_eff } from "src/ir/lir/opt/dce.nx"
import { fus_rewrite_functions } from "src/ir/lir/opt/fusion.nx"
import { opt_autovectorize } from "src/ir/lir/opt/autovec.nx"

let opt_function = fn (func: LirFunction) -> LirFunction do
  let LirFunction(name: n, params: p, ret_type: rt,
                  body, ret, span: sp) = func
  let multi = opt_find_multi(names: opt_let_names_stmts(stmts: body))
  let fp_result = opt_fp_stmts(stmts: body, subst: [], multi)
  let FoldResult(stmts: fp_body, subst: final_subst) = fp_result
  let fp_ret = opt_subst_atom(atom: ret, subst: final_subst)
  let used = opt_collect_stmts(stmts: fp_body,
                               used: opt_collect_atom(atom: fp_ret, used: []))
  let dce_body = opt_dce_stmts(stmts: fp_body, used)
  LirFunction(name: n, params: p, ret_type: rt,
              body: dce_body, ret: fp_ret, span: sp)
end

// Effect-aware variant: same fold/propagate front, plus EffectMap-driven
// DCE that drops unused-result pure calls. Used when the driver supplies
// a precomputed EffectMap (path that runs after stream fusion).
let opt_function_with_effects = fn (
  func: LirFunction,
  effects: &EffectMap,
  exts: [ LirExternal ]
) -> LirFunction do
  let LirFunction(name: n, params: p, ret_type: rt,
                  body, ret, span: sp) = func
  let multi = opt_find_multi(names: opt_let_names_stmts(stmts: body))
  let fp_result = opt_fp_stmts(stmts: body, subst: [], multi)
  let FoldResult(stmts: fp_body, subst: final_subst) = fp_result
  let fp_ret = opt_subst_atom(atom: ret, subst: final_subst)
  let used = opt_collect_stmts(stmts: fp_body,
                               used: opt_collect_atom(atom: fp_ret, used: []))
  let dce_body = opt_dce_stmts_eff(stmts: fp_body, used, effects, exts)
  LirFunction(name: n, params: p, ret_type: rt,
              body: dce_body, ret: fp_ret, span: sp)
end

let opt_functions = fn (funcs: [ LirFunction ]) -> [ LirFunction ] do
  return opt_functions_go(funcs, acc: [])
end

let opt_functions_go = fn (funcs: [ LirFunction ], acc: [ LirFunction ]) -> [ LirFunction ] do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      return opt_functions_go(funcs: rest, acc: opt_function(func: f) :: acc)
  end
end

let opt_functions_with_effects = fn (
  funcs: [ LirFunction ],
  effects: &EffectMap,
  exts: [ LirExternal ]
) -> [ LirFunction ] do
  return opt_functions_with_effects_go(funcs, effects, exts, acc: [])
end

let opt_functions_with_effects_go = fn (
  funcs: [ LirFunction ],
  effects: &EffectMap,
  exts: [ LirExternal ],
  acc: [ LirFunction ]
) -> [ LirFunction ] do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      return opt_functions_with_effects_go(
        funcs: rest, effects, exts,
        acc: opt_function_with_effects(func: f, effects, exts) :: acc
      )
  end
end

let optimize_lir = fn (program: LirProgram) -> LirProgram do
  let LirProgram(functions: funcs, externals: exts) = program
  LirProgram(functions: opt_functions(funcs), externals: exts)
end

// Public entry: run stream fusion over a program using the provided
// EffectMap, then run the fold/propagate/DCE pipeline with effect-aware
// DCE so the now-dead build call (and any other unused-result call to a
// pure callee) is collected. The EffectMap is computed pre-fusion; the
// fusion rewrite never introduces new statically-named callers, so the
// summary remains conservative for the post-fusion program.
//
// Autovectorize runs AFTER fusion+DCE: fusion may simplify call shapes, and
// DCE drops orphaned scalar wrappers when they become dead. The
// autovectorize swap is byte-equal at the LIR-call level (same signature,
// same args), so it does not perturb any earlier-pass invariant.
/** Public function optimize_lir_with_effects. */
export let optimize_lir_with_effects = fn (
  program: LirProgram,
  effects: &EffectMap
) -> LirProgram do
  let LirProgram(functions: funcs, externals: exts) = program
  let fused = fus_rewrite_functions(funcs, effects)
  let optimised = opt_functions_with_effects(funcs: fused, effects, exts)
  let av_input = LirProgram(functions: optimised, externals: exts)
  return opt_autovectorize(program: av_input)
end
