/**
 * lir_opt/folding: constant folding and identity/absorbing-element
 * simplification on binary LirExpr nodes.
 *
 * Extracted from src/ir/lir/opt.nx. Pure rewrites — no
 * statement-list surgery, no atom substitution. The propagate pass
 * (lir_opt/propagate.nx) chains this with substitution so that the
 * combined forward walk does both copy/constant propagation and
 * arithmetic folding in one go.
 *
 * Preserves the backtrace-stability contract trivially: only LirExprBinary
 * nodes are rewritten and the rewrite always yields another expression
 * (LirExprAtom or the original binary), never a statement-level edit.
 */

import { BinaryOp } from "src/types/vocab.nx"
import { LirExpr, LirAtom } from "src/ir/lir/types.nx"
import { TypeExpr, TyI32 } from "src/types/type_expr.nx"

/** Truncate a folded integer result to the binary op's declared width.
 *  Integer arithmetic folds in full i64 precision (`a * b` etc.), but an
 *  `i32`-typed binary node must wrap to 32 bits to match the `i32.*` opcode
 *  the codegen would otherwise emit at runtime — without this, a constant
 *  `let p: i32 = 65536 * 65536` folds to `4294967296` instead of `0`, and the
 *  miscompile (nexus-iap3b) survives even after the LIR carries the narrow
 *  type, because the optimizer evaluates the product before codegen runs.
 *  Wraps to the SIGNED i32 range `[-2^31, 2^31)` using only `%`/`+`/`-`
 *  (no i64 bitwise primitive in folding's source), so the sign bit is set
 *  correctly (`i32 INT_MAX + 1` → negative, `1 << 31` is left to runtime). */
let wrap_to_decl_width = fn (typ: TypeExpr, atom: LirAtom) -> LirAtom do
  match typ do
    | TyI32 ->
      match atom do
        | LirAtomInt(val: n) ->
          let two32 = 4294967296
          let m = (((n % two32) + two32) % two32)
          if m >= 2147483648 then return LirAtomInt(val: m - two32)
          else return LirAtomInt(val: m) end
        | _ -> return atom
      end
    | _ -> return atom
  end
end

let opt_fold_int_binary = fn (op: BinaryOp, a: i64, b: i64, typ: TypeExpr) -> Option<LirAtom> do
  // i64::MIN expressed without the out-of-range literal 9223372036854775808.
  let i64_min = 0 - 9223372036854775807 - 1
  // i32::MIN; for an i32-typed node, i32.div_s(INT_MIN, -1) traps like i64.div_s.
  let i32_min = 0 - 2147483647 - 1
  let is_i32 = match typ do | TyI32 -> true | _ -> false end
  match op do
    | OpAdd -> return Some(val: LirAtomInt(val: a + b))
    | OpSub -> return Some(val: LirAtomInt(val: a - b))
    | OpMul -> return Some(val: LirAtomInt(val: a * b))
    | OpDiv ->
      // Guard div-by-zero and INT_MIN / -1 (div_s traps on both). i32's INT_MIN
      // differs from i64's, so guard it on the node's declared width — else a
      // foldable i32 INT_MIN/-1 silently yields a value while the runtime path traps.
      if b == 0 || (a == i64_min && b == -1) || (is_i32 && a == i32_min && b == -1) then return None end
      return Some(val: LirAtomInt(val: a / b))
    | OpMod ->
      // Guard both mod-by-zero and INT_MIN % -1 (a / b inside would trap).
      if b == 0 || (a == i64_min && b == -1) then return None end
      return Some(val: LirAtomInt(val: a - (a / b) * b))
    | OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    | OpLt ->
      if a < b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpLe ->
      if a <= b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpGt ->
      if a > b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpGe ->
      if a >= b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | _ -> return None
  end
end

let opt_fold_bool_binary = fn (op: BinaryOp, a: bool, b: bool) -> Option<LirAtom> do
  match op do
    | OpAnd -> return Some(val: LirAtomBool(val: a && b))
    | OpOr -> return Some(val: LirAtomBool(val: a || b))
    | OpEq -> return Some(val: LirAtomBool(val: a == b))
    | OpNe -> return Some(val: LirAtomBool(val: a != b))
    | _ -> return None
  end
end

let opt_fold_str_binary = fn (op: BinaryOp, a: string, b: string) -> Option<LirAtom> do
  match op do
    | OpConcat -> return Some(val: LirAtomString(val: a ++ b))
    | OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    | _ -> return None
  end
end

let opt_fold_char_binary = fn (op: BinaryOp, a: i64, b: i64) -> Option<LirAtom> do
  match op do
    | OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    | _ -> return None
  end
end

let opt_try_fold_binary = fn (op: BinaryOp, lhs: LirAtom, rhs: LirAtom, typ: TypeExpr) -> Option<LirAtom> do
  match lhs do
    | LirAtomInt(val: ia) ->
      if let LirAtomInt(val: ib) = rhs then
        return opt_fold_int_binary(op, a: ia, b: ib, typ)
      else
        return None
      end
    | LirAtomBool(val: ba) ->
      if let LirAtomBool(val: bb) = rhs then
        return opt_fold_bool_binary(op, a: ba, b: bb)
      else
        return None
      end
    | LirAtomString(val: sa) ->
      if let LirAtomString(val: sb) = rhs then
        return opt_fold_str_binary(op, a: sa, b: sb)
      else
        return None
      end
    | LirAtomChar(val: ca) ->
      if let LirAtomChar(val: cb) = rhs then
        return opt_fold_char_binary(op, a: ca, b: cb)
      else
        return None
      end
    | _ -> return None
  end
end

let opt_simplify_binary = fn (op: BinaryOp, lhs: LirAtom, rhs: LirAtom) -> Option<LirAtom> do
  match op do
    | OpAdd ->
      match lhs do
        | LirAtomInt(val: 0) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomInt(val: 0) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | OpSub ->
      match rhs do
        | LirAtomInt(val: 0) -> return Some(val: lhs)
        | _ -> return None
      end
    | OpMul ->
      match lhs do
        | LirAtomInt(val: 0) -> return Some(val: LirAtomInt(val: 0))
        | LirAtomInt(val: 1) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomInt(val: 0) -> return Some(val: LirAtomInt(val: 0))
            | LirAtomInt(val: 1) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | OpDiv ->
      match rhs do
        | LirAtomInt(val: 1) -> return Some(val: lhs)
        | _ -> return None
      end
    | OpAnd ->
      match lhs do
        | LirAtomBool(val: false) -> return Some(val: LirAtomBool(val: false))
        | LirAtomBool(val: true) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomBool(val: false) -> return Some(val: LirAtomBool(val: false))
            | LirAtomBool(val: true) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | OpOr ->
      match lhs do
        | LirAtomBool(val: true) -> return Some(val: LirAtomBool(val: true))
        | LirAtomBool(val: false) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomBool(val: true) -> return Some(val: LirAtomBool(val: true))
            | LirAtomBool(val: false) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | _ -> return None
  end
end

/** Public function opt_fold_expr. */
export let opt_fold_expr = fn (expr: LirExpr) -> LirExpr do
  if let LirExprBinary(op, lhs: l, rhs: r, typ: bt) = expr then
    match opt_try_fold_binary(op, lhs: l, rhs: r, typ: bt) do
      | Some(val: result) -> return LirExprAtom(atom: wrap_to_decl_width(typ: bt, atom: result))
      | None ->
        match opt_simplify_binary(op, lhs: l, rhs: r) do
          | Some(val: result) -> return LirExprAtom(atom: wrap_to_decl_width(typ: bt, atom: result))
          | None -> return expr
        end
    end
  end
  return expr
end
