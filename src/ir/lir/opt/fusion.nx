/**
 * lir_opt/fusion: stream fusion (build/foldr shortcut deforestation).
 *
 * Extracted from src/ir/lir/opt.nx. Runs BEFORE the
 * fold/propagate/DCE pipeline so effect-aware DCE can clean up the
 * orphaned `build` calls fusion turns dead. Entry point:
 * `fus_rewrite_functions`, invoked from `optimize_lir_with_effects` in
 * the parent file.
 *
 * Backtrace-stability contract: never touches function boundaries,
 * raises, returns, try-catch, or tail calls. Fusion turns
 * `Call(foldr, ...)` into `CallClosure(g, ...)` and drops the now-dead
 * orphaned `Call(build, ...)` binding from the same scope.
 */

import { TypeExpr } from "src/common/ast.nx"
import * as list from "std:list"
import { LirFunction, LirStmt, LirExpr, LirAtom,
         LirCallArg, LirNamedAtom } from "src/ir/lir/types.nx"
import { EffectMap, lookup_bits, EffectBits } from "src/ir/shared/effect_map.nx"

//
// Implements the GHC-style shortcut deforestation rule
//
//     foldr(k, z, build(g)) ≡ g(k, z)
//
// where `list.build` and `list.foldr` are the conventions defined in
// nxlib/stdlib/list.nx. Concretely the rewriter looks for the local
// 2-statement pattern
//
//     let built  = Call(list_build, [g_clos])
//     let result = Call(list_foldr, [xs=built, init=z, f=k_clos])
//
// where `built` is used exactly once (so removing it is safe), `g_clos` is
// a MakeClosure on a top-level lifted lambda, and `k_clos` is also a
// MakeClosure whose target function the EffectMap reports as `is_pure`.
// Pure-only is the safety gate (see issue body): if the combining function
// could throw, capture, or perform I/O, fusion would change the
// observable order/duplication of effects relative to the unfused walk
// and is therefore disabled.
//
// The rewrite drops the build call and replaces the foldr call with a
// direct closure invocation `CallClosure(g_clos, [k_clos, z])`. The build
// statement is left in place; downstream DCE removes it because its sole
// use just disappeared. We do not relocate `g_clos` or `k_clos`
// definitions: they must dominate the foldr statement (which they do
// since they were already arguments to `Call`s preceding it).

// Canonical names of the stdlib build/foldr functions. Wrapped as
// zero-arg accessor functions to keep the call sites self-documenting
// at the pattern-match boundary.
let foldr_fn_name = "nxlib_stdlib_list_nx#foldr"
let build_fn_name = "nxlib_stdlib_list_nx#build"
type FusionVarDef = FusionVarDef(name: string, expr: LirExpr)
type FusionUseEntry = FusionUseEntry(name: string, count: i64)
// EffectMap is an opaque linear handle (`%StringMap`-backed); borrows
// can't live inside records, so the surrounding pass threads
// `effects: &EffectMap` as a sibling parameter alongside `ctx: FusionCtx`
//
type FusionCtx = FusionCtx(
  defs: [ FusionVarDef ],
  uses: [ FusionUseEntry ]
)

let fus_lookup_def = fn (name: string, defs: [ FusionVarDef ]) -> Option<LirExpr> do
  match defs do
    | [] -> return None
    | FusionVarDef(name: n, expr: e) :: rest ->
      if n == name then return Some(val: e) end
      return fus_lookup_def(name, defs: rest)
  end
end

// Sum the count field of every entry whose name equals the queried one.
// Combined with the now O(1) bump, this gives a true linear-pass use map.
let fus_lookup_use = fn (name: string, uses: [ FusionUseEntry ]) -> i64 do
  return fus_lookup_use_go(name, uses, total: 0)
end

let fus_lookup_use_go = fn (name: string, uses: [ FusionUseEntry ], total: i64) -> i64 do
  match uses do
    | [] -> return total
    | FusionUseEntry(name: n, count: c) :: rest ->
      if n == name then
        return fus_lookup_use_go(name, uses: rest, total: total + c)
      end
      return fus_lookup_use_go(name, uses: rest, total)
  end
end

// Single-use check: returns true iff `name` is referenced exactly once in
// the surrounding statement list. Multi-use disables fusion because the
// build call's result would otherwise be observed under cons/nil semantics
// elsewhere, where the rewritten direct invocation is no longer a list.
let fus_single_use = fn (name: string, ctx: FusionCtx) -> bool do
  let FusionCtx(defs: _, uses) = ctx
  return fus_lookup_use(name, uses) == 1
end

// Record one occurrence of `name`. Implementation is O(1) amortised:
// every use is prepended as a fresh entry, and `fus_lookup_use` later
// counts occurrences in a single pass. The earlier amortised-association
// scheme was O(uses^2) per function; on a 2000-function compiler that
// drove stage-1 OOM during self-host bootstrap.
let fus_bump_use = fn (name: string, uses: [ FusionUseEntry ]) -> [ FusionUseEntry ] do
  return FusionUseEntry(name, count: 1) :: uses
end

// Count uses across one statement (atom + nested-statement walk).
let fus_count_uses_atom = fn (atom: LirAtom, uses: [ FusionUseEntry ]) -> [ FusionUseEntry ] do
  if let LirAtomVar(name: n, typ: _) = atom then
    return fus_bump_use(name: n, uses)
  end
  return uses
end

let fus_count_uses_opt_atom = fn (opt: Option<LirAtom>, uses: [ FusionUseEntry ]) -> [ FusionUseEntry ] do
  match opt do
    | Some(val: a) -> return fus_count_uses_atom(atom: a, uses)
    | None -> return uses
  end
end

let fus_count_uses_atoms = fn (xs: [ LirAtom ], uses: [ FusionUseEntry ]) -> [ FusionUseEntry ] do
  match xs do
    | [] -> return uses
    | a :: rest -> return fus_count_uses_atoms(xs: rest, uses: fus_count_uses_atom(atom: a, uses))
  end
end

let fus_count_uses_call_args = fn (args: [ LirCallArg ], uses: [ FusionUseEntry ]) -> [ FusionUseEntry ] do
  match args do
    | [] -> return uses
    | LirCallArg(label: _, value: v) :: rest ->
      return fus_count_uses_call_args(args: rest, uses: fus_count_uses_atom(atom: v, uses))
  end
end

let fus_count_uses_named = fn (fs: [ LirNamedAtom ], uses: [ FusionUseEntry ]) -> [ FusionUseEntry ] do
  match fs do
    | [] -> return uses
    | LirNamedAtom(name: _, value: v) :: rest ->
      return fus_count_uses_named(fs: rest, uses: fus_count_uses_atom(atom: v, uses))
  end
end

let fus_count_uses_expr = fn (expr: LirExpr, uses: [ FusionUseEntry ]) -> [ FusionUseEntry ] do
  match expr do
    | LirExprAtom(atom: a) -> return fus_count_uses_atom(atom: a, uses)
    | LirExprBinary(op: _, lhs: l, rhs: r, typ: _) ->
      return fus_count_uses_atom(atom: r, uses: fus_count_uses_atom(atom: l, uses))
    | LirExprCall(func: _, args, typ: _) | LirExprTailCall(func: _, args, typ: _) -> return fus_count_uses_call_args(args, uses)
    | LirExprConstructor(name: _, args, typ: _) -> return fus_count_uses_atoms(xs: args, uses)
    | LirExprRecord(fields: fs, typ: _) -> return fus_count_uses_named(fs, uses)
    | LirExprObjectTag(value: v, typ: _)
    | LirExprObjectField(value: v, index: _, typ: _)
    | LirExprRaise(value: v, typ: _)
    | LirExprForce(value: v, typ: _) -> return fus_count_uses_atom(atom: v, uses)
    | LirExprMakeClosure(func_name: _, captures: cs, typ: _) -> return fus_count_uses_atoms(xs: cs, uses)
    | LirExprCallClosure(closure: c, args, typ: _) ->
      return fus_count_uses_call_args(args, uses: fus_count_uses_atom(atom: c, uses))
    | LirExprSuspend(tag_name: _, payload: p, typ: _) -> return fus_count_uses_atom(atom: p, uses)
    | LirExprResume(cont: c, value: v, typ: _) ->
      return fus_count_uses_atom(atom: v, uses: fus_count_uses_atom(atom: c, uses))
    | LirExprContNew(_) | LirExprInjectResume(_) -> return uses
  end
end

let fus_count_uses_stmt = fn (stmt: LirStmt, uses: [ FusionUseEntry ]) -> [ FusionUseEntry ] do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) -> return fus_count_uses_expr(expr: e, uses)
    | LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let u1 = fus_count_uses_atom(atom: c, uses)
      let u2 = fus_count_uses_stmts(stmts: tb, uses: u1)
      return fus_count_uses_stmts(stmts: eb, uses: u2)
    | LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr,
                      else_body: eb, else_ret: er, ret_type: _) ->
      let u1 = fus_count_uses_atom(atom: c, uses)
      let u2 = fus_count_uses_stmts(stmts: tb, uses: u1)
      let u3 = fus_count_uses_atom(atom: tr, uses: u2)
      let u4 = fus_count_uses_stmts(stmts: eb, uses: u3)
      return fus_count_uses_opt_atom(opt: er, uses: u4)
    | LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      let u1 = fus_count_uses_stmts(stmts: cs, uses)
      let u2 = fus_count_uses_atom(atom: c, uses: u1)
      return fus_count_uses_stmts(stmts: b, uses: u2)
    | LirStmtTryCatch(body: b, body_ret: br, catch_param: _, catch_param_typ: _,
                      catch_body: cb, catch_ret: cr) ->
      let u1 = fus_count_uses_stmts(stmts: b, uses)
      let u2 = fus_count_uses_opt_atom(opt: br, uses: u1)
      let u3 = fus_count_uses_stmts(stmts: cb, uses: u2)
      return fus_count_uses_opt_atom(opt: cr, uses: u3)
  end
end

let fus_count_uses_stmts = fn (stmts: [ LirStmt ], uses: [ FusionUseEntry ]) -> [ FusionUseEntry ] do
  match stmts do
    | [] -> return uses
    | s :: rest -> return fus_count_uses_stmts(stmts: rest, uses: fus_count_uses_stmt(stmt: s, uses))
  end
end

// Build the local def map: every Let in this scope contributes name → expr.
let fus_collect_defs_stmts = fn (stmts: [ LirStmt ], acc: [ FusionVarDef ]) -> [ FusionVarDef ] do
  match stmts do
    | [] -> return list.reverse(xs: acc)
    | LirStmtLet(name: n, typ: _, expr: e) :: rest ->
      return fus_collect_defs_stmts(stmts: rest, acc: FusionVarDef(name: n, expr: e) :: acc)
    | _ :: rest -> return fus_collect_defs_stmts(stmts: rest, acc)
  end
end

// Locate a labelled call argument; returns None if missing. Labels in
// LirCallArg are positional names, so e.g. foldr's args carry "xs",
// "init", "f".
let fus_find_arg = fn (label: string, args: [ LirCallArg ]) -> Option<LirAtom> do
  match args do
    | [] -> return None
    | LirCallArg(label: l, value: v) :: rest ->
      if l == label then return Some(val: v) end
      return fus_find_arg(label, args: rest)
  end
end

// Effect gate: return true iff the closure's underlying function is pure
// per the EffectMap. Treat missing summaries as impure (fail closed) so a
// missing entry never silently enables fusion.
let fus_is_closure_pure = fn (clos_expr: LirExpr, effects: &EffectMap) -> bool do
  if let LirExprMakeClosure(func_name: fn_name, captures: _, typ: _) = clos_expr then
    match lookup_bits(em: effects, name: fn_name) do
      | Some(val: EffectBits(can_throw: _, is_pure: pure)) -> return pure
      | None -> return false
    end
  end
  return false
end

// Resolve an atom to a closure expression in the local def map. Fusion
// requires both g and k to be MakeClosure; FuncRef-via-atom is not yet
// supported.
let fus_resolve_closure = fn (atom: LirAtom, defs: [ FusionVarDef ]) -> Option<LirExpr> do
  if let LirAtomVar(name: n, typ: _) = atom then
    return fus_lookup_def(name: n, defs)
  end
  return None
end

// Helper: resolve the inner build call from xs's atom. Returns the `g`
// closure atom from `Call(build, g=...)` if the chain matches; None
// otherwise (xs not a variable, multi-use, not a build call, missing g).
let fus_unfold_build = fn (xs_atom: LirAtom, ctx: FusionCtx) -> Option<LirAtom> do
  let FusionCtx(defs, uses: _) = ctx
  if let LirAtomVar(name: xs_name, typ: _) = xs_atom then
    if !fus_single_use(name: xs_name, ctx) then return None end
    match fus_lookup_def(name: xs_name, defs) do
      | None -> return None
      | Some(val: xs_expr) ->
        if let LirExprCall(func: build_fn, args: build_args, typ: _) = xs_expr then
          if build_fn != build_fn_name then return None end
          return fus_find_arg(label: "g", args: build_args)
        end
        return None
    end
  end
  return None
end

// Helper: verify a foldr argument atom resolves to a MakeClosure. Returns
// the closure expression on success; None if it is anything else (literal,
// param-only var, FuncRef-style atom, …) — fusion is conservative and
// only fires when both g and k are explicit MakeClosure values that
// effect_analysis can index.
let fus_require_closure = fn (atom: LirAtom, defs: [ FusionVarDef ]) -> Option<LirExpr> do
  match fus_resolve_closure(atom, defs) do
    | None -> return None
    | Some(val: e) ->
      if let LirExprMakeClosure(_) = e then return Some(val: e) end
      return None
  end
end

// FuseResult: outcome of trying to fuse a single foldr Let.
//   * stmt: the replacement statement (foldr → CallClosure form).
//   * orphan_xs_name: the build Let's bound name, now dead; the
//     surrounding pipeline must drop that statement to keep `g` from
//     being invoked twice (once by the orphan build, once by the
//     fused CallClosure). The pre-q0th implementation deferred the
//     drop to DCE, but DCE lacks the higher-order purity reasoning
//     required to prove `build(g)` discardable in general; carrying
//     the name out of fusion records the proof inline.
type FuseResult = FuseResult(stmt: LirStmt, orphan_xs_name: string)

// The core rewrite: given a foldr Let, decide whether it fuses with a
// preceding build, and produce the replacement statement plus the
// orphan build's let-name. Returns None when the local pattern does
// not match.
let fus_try_fuse_foldr = fn (
  let_name: string,
  let_typ: TypeExpr,
  args: [ LirCallArg ],
  ctx: FusionCtx,
  effects: &EffectMap
) -> Option<FuseResult> do
  let FusionCtx(defs, uses: _) = ctx
  match fus_find_arg(label: "xs", args) do
    | None -> return None
    | Some(val: xs_atom) ->
      match fus_find_arg(label: "init", args) do
        | None -> return None
        | Some(val: init_atom) ->
          match fus_find_arg(label: "f", args) do
            | None -> return None
            | Some(val: f_atom) ->
              match fus_unfold_build(xs_atom, ctx) do
                | None -> return None
                | Some(val: g_atom) ->
                  match fus_require_closure(atom: g_atom, defs) do
                    | None -> return None
                    | Some(_) ->
                      match fus_require_closure(atom: f_atom, defs) do
                        | None -> return None
                        | Some(val: k_expr) ->
                          if !fus_is_closure_pure(clos_expr: k_expr, effects) then
                            return None
                          end
                          // Synthesise the direct closure call:
                          //   CallClosure(g, [cons=k, nil=z])
                          let new_args = [
                            LirCallArg(label: "cons", value: f_atom),
                            LirCallArg(label: "nil", value: init_atom)
                          ]
                          let new_expr = LirExprCallClosure(
                            closure: g_atom,
                            args: new_args,
                            typ: let_typ
                          )
                          // xs_atom must be a LirAtomVar at this point
                          // (fus_unfold_build only returns Some when
                          // xs_atom is a Var resolving to a build call).
                          // Re-extract the name; on the unreachable
                          // None branch we abort the rewrite rather
                          // than fabricate a bogus orphan name.
                          match fus_xs_name_of(atom: xs_atom) do
                            | None -> return None
                            | Some(val: xs_name) ->
                              let new_let = LirStmtLet(name: let_name, typ: let_typ, expr: new_expr)
                              return Some(val: FuseResult(stmt: new_let, orphan_xs_name: xs_name))
                          end
                      end
                  end
              end
          end
      end
  end
end

// Helper: extract the variable name from a `LirAtomVar` xs-atom. The
// caller has already checked (via `fus_unfold_build`) that xs_atom is
// a Var; we still surface the option here rather than raising so the
// enclosing fusion logic remains pure (no `throws { Exn }` plumbing).
// Callers that observe `None` treat the rewrite as inapplicable.
let fus_xs_name_of = fn (atom: LirAtom) -> Option<string> do
  if let LirAtomVar(name: n, typ: _) = atom then return Some(val: n) end
  return None
end

// String-set helpers for the orphan-name pool. Orphan-name lists stay
// short (≤ # foldr fusions per scope) so a linear assoc-list fits the
// existing pass posture.
let fus_orphan_member = fn (name: string, xs: [ string ]) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == name then return true end
      return fus_orphan_member(name, xs: rest)
  end
end

// StmtRewrite: outcome of rewriting a single statement.
//   * stmt: the rewritten statement (or unchanged input).
//   * orphan: Some(name) if fusion fired and `name` is the build-Let
//     bound name that the surrounding scope must drop; None otherwise.
type StmtRewrite = StmtRewrite(stmt: LirStmt, orphan: Option<string>)

// Rewrite a single statement in-place if it is the foldr we want to
// fuse. The unchanged-stmt cases reconstruct the same shape rather
// than reusing the scrutinee variable; that keeps the pattern style
// consistent with the rest of this file.
let fus_rewrite_stmt = fn (stmt: LirStmt, ctx: FusionCtx, effects: &EffectMap) -> StmtRewrite do
  match stmt do
    | LirStmtLet(name: n, typ: t, expr: e) ->
      if let LirExprCall(func: fname, args: a, typ: _) = e then
        if fname == foldr_fn_name then
          match fus_try_fuse_foldr(let_name: n, let_typ: t, args: a, ctx, effects) do
            | Some(val: FuseResult(stmt: new_stmt, orphan_xs_name)) ->
              return StmtRewrite(stmt: new_stmt, orphan: Some(val: orphan_xs_name))
            | None ->
              return StmtRewrite(stmt: LirStmtLet(name: n, typ: t, expr: e), orphan: None)
          end
        end
      end
      return StmtRewrite(stmt: LirStmtLet(name: n, typ: t, expr: e), orphan: None)
    | LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let new_stmt = LirStmtIf(cond: c,
                       then_body: fus_rewrite_stmts_in(stmts: tb, effects),
                       else_body: fus_rewrite_stmts_in(stmts: eb, effects))
      return StmtRewrite(stmt: new_stmt, orphan: None)
    | LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr,
                      else_body: eb, else_ret: er, ret_type: rt) ->
      let new_stmt = LirStmtIfReturn(cond: c,
                             then_body: fus_rewrite_stmts_in(stmts: tb, effects),
                             then_ret: tr,
                             else_body: fus_rewrite_stmts_in(stmts: eb, effects),
                             else_ret: er, ret_type: rt)
      return StmtRewrite(stmt: new_stmt, orphan: None)
    | LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      let new_stmt = LirStmtLoop(cond_stmts: fus_rewrite_stmts_in(stmts: cs, effects),
                         cond: c,
                         body: fus_rewrite_stmts_in(stmts: b, effects))
      return StmtRewrite(stmt: new_stmt, orphan: None)
    | LirStmtTryCatch(body: b, body_ret: br, catch_param: cp,
                      catch_param_typ: cpt, catch_body: cb, catch_ret: cr) ->
      let new_stmt = LirStmtTryCatch(body: fus_rewrite_stmts_in(stmts: b, effects),
                             body_ret: br, catch_param: cp, catch_param_typ: cpt,
                             catch_body: fus_rewrite_stmts_in(stmts: cb, effects),
                             catch_ret: cr)
      return StmtRewrite(stmt: new_stmt, orphan: None)
  end
end

// Iterate over a stmt list with a freshly built ctx for that scope.
// Two-step: (1) rewrite each statement, recording orphan-build let-names
// from successful fusions; (2) filter the rewritten list, dropping the
// LirStmtLets whose name appears in the orphan set. Step (2) is the
// "stmt-list surgery" that the q0th issue requires — fusion has proven
// the build call's effects are subsumed by the rewritten CallClosure,
// so the orphan can be erased without leaning on a higher-order purity
// summary.
//
// One sweep collects orphans and drops them, but the act of dropping a
// `let xs = build(g)` removes uses of `g` and of every variable g
// captured. A previously multi-use variable can flip to single-use after
// that drop, unblocking another foldr/build pair in the same scope. The
// driver (`fus_rewrite_stmts_in`) therefore re-runs sweep+drop until the
// pass produces zero orphans (multi-stage fixed point, issue qzl0).
let fus_rewrite_stmts_one = fn (stmts: [ LirStmt ], effects: &EffectMap) -> RewriteOnce do
  let defs = fus_collect_defs_stmts(stmts, acc: [])
  let uses = fus_count_uses_stmts(stmts, uses: [])
  let ctx = FusionCtx(defs, uses)
  let rewritten = fus_rewrite_stmts_go(stmts, ctx, effects, acc: [], orphans: [])
  match rewritten do | RewriteResult(stmts: new_stmts, orphans) ->
    let dropped = fus_drop_orphans(stmts: new_stmts, orphans, acc: [])
    return RewriteOnce(stmts: dropped, orphan_count: fus_orphan_count(orphans))
  end
end

let fus_orphan_count = fn (orphans: [ string ]) -> i64 do
  match orphans do
    | [] -> return 0
    | _ :: rest -> return 1 + fus_orphan_count(orphans: rest)
  end
end

// One iteration's outcome: rewritten statement list plus how many distinct
// orphan build-Lets the sweep dropped. Zero means no fusion fired this
// round, which is the fixed-point signal.
type RewriteOnce = RewriteOnce(stmts: [ LirStmt ], orphan_count: i64)

// Multi-stage driver: keep sweeping until a pass produces zero orphans.
// Each successful sweep strictly decreases the number of foldr/build
// pairs in the scope (every orphan drop removes one build call), so the
// loop terminates in at most `original-build-count` rounds.
let fus_rewrite_stmts_in = fn (stmts: [ LirStmt ], effects: &EffectMap) -> [ LirStmt ] do
  return fus_rewrite_stmts_fixedpoint(stmts, effects, iterations: 0)
end

// Hard upper bound on iterations as a defence-in-depth: the strict
// decrease argument above already guarantees termination, but a runaway
// pass would be much harder to diagnose than a clean abort. The bound is
// generous; real chains observed in self-host bootstrap top out at 3-4
// stages per scope.
let fus_max_iterations = 32
let fus_rewrite_stmts_fixedpoint = fn (stmts: [ LirStmt ], effects: &EffectMap, iterations: i64) -> [ LirStmt ] do
  if iterations >= fus_max_iterations then return stmts end
  match fus_rewrite_stmts_one(stmts, effects) do
    | RewriteOnce(stmts: new_stmts, orphan_count: n) ->
      if n == 0 then return new_stmts end
      return fus_rewrite_stmts_fixedpoint(stmts: new_stmts, effects, iterations: iterations + 1)
  end
end

type RewriteResult = RewriteResult(stmts: [ LirStmt ], orphans: [ string ])

let fus_rewrite_stmts_go = fn (stmts: [ LirStmt ], ctx: FusionCtx, effects: &EffectMap, acc: [ LirStmt ], orphans: [ string ]) -> RewriteResult do
  match stmts do
    | [] -> return RewriteResult(stmts: list.reverse(xs: acc), orphans)
    | s :: rest ->
      match fus_rewrite_stmt(stmt: s, ctx, effects) do
        | StmtRewrite(stmt: new_s, orphan: o) ->
          let new_orphans = match o do
            | Some(val: name) ->
              if fus_orphan_member(name, xs: orphans) then orphans
              else name :: orphans
              end
            | None -> orphans
          end
          return fus_rewrite_stmts_go(stmts: rest, ctx, effects, acc: new_s :: acc, orphans: new_orphans)
      end
  end
end

let fus_drop_orphans = fn (stmts: [ LirStmt ], orphans: [ string ], acc: [ LirStmt ]) -> [ LirStmt ] do
  match stmts do
    | [] -> return list.reverse(xs: acc)
    | s :: rest ->
      match s do
        | LirStmtLet(name: n, typ: _, expr: _) ->
          if fus_orphan_member(name: n, xs: orphans) then
            return fus_drop_orphans(stmts: rest, orphans, acc)
          end
          return fus_drop_orphans(stmts: rest, orphans, acc: s :: acc)
        | _ ->
          return fus_drop_orphans(stmts: rest, orphans, acc: s :: acc)
      end
  end
end

let fus_rewrite_function = fn (func: LirFunction, effects: &EffectMap) -> LirFunction do
  let LirFunction(name: n, params: p, ret_type: rt, body: bd, ret: rv, span: sp) = func
  let new_body = fus_rewrite_stmts_in(stmts: bd, effects)
  return LirFunction(name: n, params: p, ret_type: rt, body: new_body, ret: rv, span: sp)
end

/** Public function fus_rewrite_functions. */
export let fus_rewrite_functions = fn (funcs: [ LirFunction ], effects: &EffectMap) -> [ LirFunction ] do
  return fus_rewrite_functions_go(funcs, effects, acc: [])
end

let fus_rewrite_functions_go = fn (funcs: [ LirFunction ], effects: &EffectMap, acc: [ LirFunction ]) -> [ LirFunction ] do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      return fus_rewrite_functions_go(funcs: rest, effects,
                                      acc: fus_rewrite_function(func: f, effects) :: acc)
  end
end
