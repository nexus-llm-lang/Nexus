/**
 * lower_helpers: pure utility functions for MIR→LIR lowering.
 *
 * All functions here are DAG-leaves relative to the main lowering SCC in
 * lir.nx: they call no functions defined in lir.nx, so they can be extracted
 * without introducing a mutual-recursion cycle.
 *
 * Owns:
 * - Atom/type inspection helpers (lir_get_fn_ret_type, lir_get_atom_sem_type,
 *   fallback_ret_from_last_stmt, fallback_ret_from_terminal)
 * - Match result-type inference (lir_infer_match_result_type, lir_last_mir_expr)
 * - Trivial-body predicate (is_trivially_unit_body)
 * - LirStmt list utilities (append_stmts, push_stmts_to_reverse, prepend_reversed)
 * - Array-element numbering (number_atoms, number_atoms_go)
 */
import { LitUnit } from "src/types/vocab.nx"
import { TypeExpr, TyUnit, TyI64, TyRecord, NamedType, VariantDef, VariantField } from "src/types/type_expr.nx"
import * as list from "std:list"
import { LirError } from "src/ir/lir/errors.nx"
import { Some, None } from "std:option"
import {
  MirExpr,
  MirVariable,
  MirStmt,
  MirMatchCase,
  MirPattern,
  MirPatConstructor,
  MirPatRecord,
  MirPatVariable,
  MirPatternField,
  MirRecordPatField
} from "src/ir/mir/types.nx"
import { LirAtom, LirStmt, LirNamedAtom } from "src/ir/lir/types.nx"
import { LowerCtx, lir_lookup_type, insert_type, atom_type } from "src/ir/lir/context.nx"
import { infer_semantic_type } from "src/ir/lir/semantic_types.nx"
import { VariantIndex } from "src/ir/support/variant_index.nx"
import * as vidx from "src/ir/support/variant_index.nx"
import * as str from "std:str"

// ---------------------------------------------------------------------------
// Array-element numbering
// ---------------------------------------------------------------------------

export let number_atoms = fn (
  atoms: [ LirAtom ],
  idx: i64
) -> [ LirNamedAtom ] throws { LirError } do
  return number_atoms_go(atoms, idx, acc: [])
end

let number_atoms_go = fn (
  atoms: [ LirAtom ],
  idx: i64,
  acc: [ LirNamedAtom ]
) -> [ LirNamedAtom ] throws { LirError } do
  match atoms do
    | [] -> return list.reverse(xs: acc)
    | a :: rest ->
      return number_atoms_go(
        atoms: rest,
        idx: idx + 1,
        acc: LirNamedAtom(name: str.from_i64(val: idx), value: a) :: acc
      )
  end
end

// ---------------------------------------------------------------------------
// LowerCtx / atom inspection helpers
// ---------------------------------------------------------------------------

// Look up the enclosing function's wasm return type. `lir_lower_function`
// stores it under the sentinel name "#FN_RET#" in semantic_vars at function
// entry — `#` is not a valid identifier character so there is no collision
// with user names.
export let lir_get_fn_ret_type = fn (ctx: LowerCtx) -> TypeExpr throws { LirError } do
  let LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) = ctx
  match lir_lookup_type(name: "#FN_RET#", entries: sv) do
      | Some(val: t) -> return t
      | None -> return TyUnit
    end
end

export let lir_get_atom_sem_type = fn (
  atom: LirAtom,
  ctx: LowerCtx
) -> TypeExpr throws { LirError } do
  if let LirAtomVar(name: n, typ: t) = atom then
    let LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) = ctx
    match lir_lookup_type(name: n, entries: sv) do
        | Some(val: st) -> return st
        | None -> return t
      end
  else
    return atom_type(atom)
  end
end

// Extract return atom from the last statement in a list (forward order).
export let fallback_ret_from_last_stmt = fn (stmts: [ LirStmt ]) -> Option<LirAtom> do
  match stmts do
    | [] -> return None
    | [ s ] ->
      match s do
        | LirStmtIfReturn(
          cond: _,
          then_body: _,
          then_ret: tr,
          else_body: _,
          else_ret: _,
          ret_type: _
        ) ->
          return Some(val: tr)
        | LirStmtTryCatch(
          body: _,
          body_ret: br,
          catch_param: _,
          catch_param_typ: _,
          catch_body: _,
          catch_ret: cr
        ) ->
          match cr do
            | Some(_) -> return cr
            | None -> return br
          end
        | _ -> return None
      end
    | _ :: rest -> return fallback_ret_from_last_stmt(stmts: rest)
  end
end

// Extract return atom from the last emitted LIR statement (IfReturn or TryCatch).
export let fallback_ret_from_terminal = fn (ctx: LowerCtx) -> Option<LirAtom> do
  let LowerCtx(vars: _, semantic_vars: _, stmts, temp_counter: _, enum_defs: _) = ctx
  match stmts do
      | LirStmtIfReturn(
        cond: _,
        then_body: _,
        then_ret: tr,
        else_body: _,
        else_ret: _,
        ret_type: _
      ) :: _ ->
        Some(val: tr)
      | LirStmtTryCatch(
        body: _,
        body_ret: br,
        catch_param: _,
        catch_param_typ: _,
        catch_body: _,
        catch_ret: cr
      ) :: _ ->
        match cr do
          | Some(_) -> cr
          | None -> br
        end
      | _ -> None
    end
end

// ---------------------------------------------------------------------------
// Match result-type inference
// ---------------------------------------------------------------------------

// Resolve the declared type of a variant field named `field_name` on
// constructor `ctor`. Mirrors match_tree/emit.nx::constructor_field_type (kept
// local to avoid a cross-module import of that private helper); record-alias
// expansion is not needed here because the result is only consumed as a wasm
// width hint for the match-result slot.
let binder_field_type_of_ctor = fn (
  ctor: string,
  field_name: string,
  enum_defs: VariantIndex
) -> Option<TypeExpr> throws { LirError } do
  match vidx.lookup_variant_def_in_index(idx: enum_defs, variant: ctor) do
    | None -> return None
    | Some(val: VariantDef(name: _, fields: fs)) ->
      return lookup_named_variant_field(fields: fs, name: field_name)
  end
end

let lookup_named_variant_field = fn (
  fields: [ VariantField ],
  name: string
) -> Option<TypeExpr> throws { LirError } do
  match fields do
    | [] -> return None
    | VariantField(name: Some(val: n), typ: t) :: rest ->
      if n == name then return Some(val: t)
      else return lookup_named_variant_field(fields: rest, name) end
    | VariantField(name: None, typ: _) :: rest ->
      return lookup_named_variant_field(fields: rest, name)
  end
end

// ---------------------------------------------------------------------------
// Pattern-binder semantic-type registration
// ---------------------------------------------------------------------------
//
// When a match arm's BODY references a pattern binder (`| Wrapped(h: hh) -> [{
// col: hh.c }]`), the body's semantic type must be inferred with that binder's
// type in `semantic_vars` — otherwise `infer_semantic_type` defaults `hh` to
// `TyI64`, `hh.c` erases to `TyI64`, and the resulting structural-compare helper
// is keyed on / built for the erased field type (`col=i64`) → identity-compare
// or a harvested-vs-call-site helper-name divergence (E3001). The real decision-
// tree emission registers these binders (lir_emit_bindings / lir_extract_fields_
// loop), but the result-type inference (`lir_infer_match_result_type`) and the
// struct-eq harvest run BEFORE / WITHOUT that emission, so they register the
// binders here.
//
// Returns a ctx whose `semantic_vars` is extended with each DIRECT
// constructor-payload / record-pattern binder of `pattern`, typed by the
// field's declared type resolved through any record alias (so a record-typed
// binder carries its `TyRecord` body and a subsequent `.field` on it resolves).
// Nested patterns recurse, using the resolved field type as the inner
// scrutinee. A binder whose field type can't be located (or whose field type is
// a still-polymorphic type parameter) is simply not registered — it then keeps
// the conservative `TyI64` default, unchanged from prior behavior.

/** Public function register_pattern_binders. */
export let register_pattern_binders = fn (
  pattern: MirPattern,
  scrutinee_sem: TypeExpr,
  ctx: LowerCtx
) -> LowerCtx throws { LirError } do
  let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed) = ctx
  match pattern do
    | MirPatConstructor(name: ctor, fields: fs) ->
      return register_ctor_field_binders(ctor, fields: fs, enum_defs: ed, ctx)
    | MirPatRecord(fields: rfs, is_partial: _) ->
      return register_record_field_binders(fields: rfs, rec_sem: vidx.resolve_record_alias(idx: ed, typ: scrutinee_sem), ctx)
    | _ -> return ctx
  end
end

let register_ctor_field_binders = fn (
  ctor: string,
  fields: [ MirPatternField ],
  enum_defs: VariantIndex,
  ctx: LowerCtx
) -> LowerCtx throws { LirError } do
  match fields do
    | [] -> return ctx
    | MirPatternField(name: Some(val: fname), pattern: fpat) :: rest ->
      let field_ty = match binder_field_type_of_ctor(ctor, field_name: fname, enum_defs) do
        | Some(val: ft) -> vidx.resolve_record_alias(idx: enum_defs, typ: ft)
        | None -> TyI64
      end
      let ctx1 = register_binder_or_recurse(pat: fpat, sem: field_ty, ctx)
      return register_ctor_field_binders(ctor, fields: rest, enum_defs, ctx: ctx1)
    | MirPatternField(name: None, pattern: _) :: rest ->
      return register_ctor_field_binders(ctor, fields: rest, enum_defs, ctx)
  end
end

let register_record_field_binders = fn (
  fields: [ MirRecordPatField ],
  rec_sem: TypeExpr,
  ctx: LowerCtx
) -> LowerCtx throws { LirError } do
  match fields do
    | [] -> return ctx
    | MirRecordPatField(name: fname, pattern: fpat) :: rest ->
      let field_ty = match rec_sem do
        | TyRecord(fields: rfs) ->
          match lookup_record_field_type(fields: rfs, name: fname) do
            | Some(val: ft) -> ft
            | None -> TyI64
          end
        | _ -> TyI64
      end
      let ctx1 = register_binder_or_recurse(pat: fpat, sem: field_ty, ctx)
      return register_record_field_binders(fields: rest, rec_sem, ctx: ctx1)
  end
end

// Register `pat` as a leaf binder of semantic type `sem`, or recurse into a
// nested ctor/record pattern with `sem` as the inner scrutinee. A polymorphic
// (`TyVar`-bearing) field type is not registered — a `.field` on it would not
// resolve anyway, and registering it could mis-route a downstream compare.
let register_binder_or_recurse = fn (
  pat: MirPattern,
  sem: TypeExpr,
  ctx: LowerCtx
) -> LowerCtx throws { LirError } do
  match pat do
    | MirPatVariable(name: bn, sigil: _) ->
      let LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) = ctx
      return LowerCtx(vars: v, semantic_vars: insert_type(name: bn, typ: sem, entries: sv), stmts: s, temp_counter: c, enum_defs: ed)
    | MirPatConstructor(name: _, fields: _) -> return register_pattern_binders(pattern: pat, scrutinee_sem: sem, ctx)
    | MirPatRecord(fields: _, is_partial: _) -> return register_pattern_binders(pattern: pat, scrutinee_sem: sem, ctx)
    | _ -> return ctx
  end
end

let lookup_record_field_type = fn (
  fields: [ NamedType ],
  name: string
) -> Option<TypeExpr> throws { LirError } do
  match fields do
    | [] -> return None
    | NamedType(name: n, typ: t) :: rest ->
      if n == name then return Some(val: t) else return lookup_record_field_type(fields: rest, name) end
  end
end

// Find which constructor/record field of `pattern` binds the variable `binder`
// and return that field's declared type. Used to recover the type of a match
// arm that yields a bare pattern binder (`| Ctor(f: x) -> x`) — at result-type
// inference time the binder is not yet in `semantic_vars`, so without this it
// defaults to `TyI64`. That default is wrong for an `f32`/`i32` binder: the
// result slot is then typed i64 and the binder is packed through the i64
// channel (f32→i32→i64 zero-extend), but a downstream float op unpacks the slot
// as f64 (`f64.reinterpret_i64`) → garbage. Typing the slot at the binder's
// real width keeps the value off the i64 channel entirely. Only direct
// `Ctor(f: x)` / `{f: x}` binders are resolved; nested patterns and other arm
// shapes fall back to `infer_semantic_type`.
let binder_type_in_pattern = fn (
  pattern: MirPattern,
  binder: string,
  enum_defs: VariantIndex
) -> Option<TypeExpr> throws { LirError } do
  match pattern do
    | MirPatConstructor(name: ctor, fields: fs) ->
      return binder_type_in_ctor_fields(ctor, fields: fs, binder, enum_defs)
    | MirPatRecord(fields: rfs, is_partial: _) ->
      return binder_type_in_record_fields(fields: rfs, binder, enum_defs)
    | _ -> return None
  end
end

let binder_type_in_ctor_fields = fn (
  ctor: string,
  fields: [ MirPatternField ],
  binder: string,
  enum_defs: VariantIndex
) -> Option<TypeExpr> throws { LirError } do
  match fields do
    | [] -> return None
    | MirPatternField(name: Some(val: fname), pattern: MirPatVariable(name: bn, sigil: _)) :: rest ->
      if bn == binder then return binder_field_type_of_ctor(ctor, field_name: fname, enum_defs)
      else return binder_type_in_ctor_fields(ctor, fields: rest, binder, enum_defs) end
    | _ :: rest -> return binder_type_in_ctor_fields(ctor, fields: rest, binder, enum_defs)
  end
end

let binder_type_in_record_fields = fn (
  fields: [ MirRecordPatField ],
  binder: string,
  enum_defs: VariantIndex
) -> Option<TypeExpr> throws { LirError } do
  match fields do
    | [] -> return None
    | MirRecordPatField(name: _, pattern: MirPatVariable(name: bn, sigil: _)) :: rest ->
      // A record pattern binder's declared field type is not carried on the MIR
      // record pattern; only ctor-payload binders are recovered here (the f32
      // sum-payload case). Record `.field`/let-destructure already type the
      // binder correctly off the record's TyRecord, so this path is a
      // conservative no-op that defers to `infer_semantic_type`.
      if bn == binder then return None
      else return binder_type_in_record_fields(fields: rest, binder, enum_defs) end
    | _ :: rest -> return binder_type_in_record_fields(fields: rest, binder, enum_defs)
  end
end

export let lir_infer_match_result_type = fn (
  cases: [ MirMatchCase ],
  scrutinee_sem: TypeExpr,
  ctx: LowerCtx
) -> TypeExpr throws { LirError } do
  match cases do
    | [] -> return TyUnit
    | MirMatchCase(pattern: pat, body) :: rest ->
      match body do
        | [] -> return lir_infer_match_result_type(cases: rest, scrutinee_sem, ctx)
        | _ ->
          let last = lir_last_mir_expr(body)
          // A bare pattern-binder arm (`-> x`) is not yet in `semantic_vars`, so
          // `infer_semantic_type` would default it to `TyI64`. Recover the
          // binder's real type from the arm's pattern first; this is load-bearing
          // for `f32`/`i32` payload binders (see `binder_type_in_pattern`).
          let from_binder = match last do
            | MirVariable(name: vn) ->
              let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed) = ctx
              binder_type_in_pattern(pattern: pat, binder: vn, enum_defs: ed)
            | _ -> None
          end
          // For a non-bare body, infer its type with the arm's pattern binders
          // registered in `semantic_vars`, so a binder reference deeper in the
          // body (`hh` in `[{ col: hh.c }]`) resolves to its real record/sum type
          // instead of the `TyI64` default — keeping the structural-compare helper
          // keyed on the binder's actual field type. Binders are scoped to THIS
          // arm only (the extended ctx is local; the recursion uses the original).
          let arm_ctx = register_pattern_binders(pattern: pat, scrutinee_sem, ctx)
          let t = match from_binder do
            | Some(val: bt) -> bt
            | None -> infer_semantic_type(expr: last, ctx: arm_ctx)
          end
          match t do
            | TyUnit -> return lir_infer_match_result_type(cases: rest, scrutinee_sem, ctx)
            | _ -> return t
          end
      end
  end
end

let lir_last_mir_expr = fn (body: [ MirStmt ]) -> MirExpr throws { LirError } do
  match body do
    | [] -> return MirLiteral(lit: LitUnit)
    | [ MirStmtExpr(expr: e) ] -> return e
    | [ MirStmtReturn(expr: _) ] -> return MirLiteral(lit: LitUnit)
    | _ :: rest -> return lir_last_mir_expr(body: rest)
  end
end

// ---------------------------------------------------------------------------
// Trivial-body predicate
// ---------------------------------------------------------------------------

// Check if a MIR statement list is trivially unit (empty or all unit literals).
// Such cases should fall through instead of returning from the function.
export let is_trivially_unit_body = fn (stmts: [ MirStmt ]) -> bool throws { LirError } do
  match stmts do
    | [] -> return true
    | MirStmtExpr(expr: MirLiteral(lit: LitUnit)) :: rest ->
      return is_trivially_unit_body(stmts: rest)
    | _ -> return false
  end
end

// ---------------------------------------------------------------------------
// LirStmt list utilities
// ---------------------------------------------------------------------------

// Add forward-order stmts to a reverse-order accumulator (preserves execution order)
export let push_stmts_to_reverse = fn (
  stmts: [ LirStmt ],
  acc: [ LirStmt ]
) -> [ LirStmt ] throws { LirError } do
  match stmts do
    | [] -> return acc
    | s :: rest ->
      return push_stmts_to_reverse(stmts: rest, acc: s :: acc)
  end
end

export let append_stmts = fn (
  stmts: [ LirStmt ],
  tail: [ LirStmt ]
) -> [ LirStmt ] throws { LirError } do
  // Iterative: reverse stmts, then prepend each to tail (avoids stack overflow on large lists)
  let rev = list.reverse(xs: stmts)
  return prepend_reversed(stmts: rev, tail)
end

let prepend_reversed = fn (
  stmts: [ LirStmt ],
  tail: [ LirStmt ]
) -> [ LirStmt ] throws { LirError } do
  match stmts do
    | [] -> return tail
    | s :: rest -> return prepend_reversed(stmts: rest, tail: s :: tail)
  end
end
