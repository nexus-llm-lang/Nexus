/**
 * match_tree: Maranget decision-tree construction + pure emission helpers.
 *
 * Owns:
 * - Decision tree types (PatRow, DecTree, CtorBranch, LitBranch, AtomEntry, DecTreeResult)
 * - Pattern matrix → DecTree algorithm (Maranget)
 * - Specialization / default matrix / record destructure builders
 * - Bridge: MirMatchCase list → PatRow list
 * - Pure emission helpers shared by lir.nx:
 *   · Field-extraction for constructor + record scrutinees
 *   · Constructor- and literal-condition builders
 *   · Pattern-binding emission (lir_emit_bindings)
 *   · Small utilities: lir_nth_case_body, lir_nth_string, lir_ctors_length,
 *     lir_reverse_atoms, lir_builtin_field_mem_idx
 *
 * Does not own:
 * - Recursive decision-tree emission and leaf emission (stay in lir.nx):
 *   those call body lowering, and the self-hosted nxc has no first-class
 *   function calls yet (blocker for callback injection — see nexus-o7l9).
 * - LowerCtx definition (see src/ir/lir/context.nx).
 */
import { BinaryOp, OpEq, Literal, TypeExpr, TyUnit, TyI64, TyBool, TyRecord, NamedType, VariantDef, VariantField, EnumDef } from "src/common/ast.nx"
import { MirStmt, MirPattern, MirPatOr, MirPatternField, MirRecordPatField, MirMatchCase } from "src/ir/mir_types.nx"
import { LirAtom, LirAtomUnit, LirAtomVar, LirAtomInt, LirAtomBool, LirExpr, LirExprAtom, LirExprBinary, LirExprObjectField, LirStmt, LirStmtLet } from "src/ir/lir_types.nx"
import { LowerCtx, BindResult, insert_type, atom_type, wasm_type, bind_expr_to_temp, bind_expr_to_temp_semantic, literal_to_atom } from "src/ir/lir/context.nx"
import * as str from "stdlib/string_ops.nx"
import * as list from "stdlib/list.nx"

// ─── Public Decision Tree Types ──────────────────────────────────────────────

export type PatBinding = PatBinding(name: string, scrutinee_id: i64)
export type PatRow = PatRow(pats: [MirPattern], case_idx: i64, bindings: [PatBinding])

export type DecTree =
  DecLeaf(case_idx: i64, bindings: [PatBinding])
  | DecCtorSwitch(scrutinee_id: i64, branches: [CtorBranch], fallback: Option<DecTree>)
  | DecLitSwitch(scrutinee_id: i64, branches: [LitBranch], fallback: DecTree)
  | DecRecordDestructure(scrutinee_id: i64, field_names: [string], field_ids: [i64], subtree: DecTree)
  | DecFail

export type CtorBranch = CtorBranch(ctor_name: string, ctor_tag: i64, arity: i64, field_ids: [i64], subtree: DecTree)
export type LitBranch = LitBranch(lit: Literal, subtree: DecTree)

export type AtomEntry = AtomEntry(id: i64, atom: LirAtom, sem_type: TypeExpr)

export type DecTreeResult = DecTreeResult(tree: DecTree, next_id: i64)

type CtorBranchesResult = CtorBranchesResult(branches: [CtorBranch], next_id: i64)
type LitBranchesResult = LitBranchesResult(branches: [LitBranch], next_id: i64)

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_mir_patterns = fn (lst: [MirPattern], out: [MirPattern]) -> [MirPattern] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_patterns(lst: rest, out: x :: out)
  end
end

let rev_i64s = fn (lst: [i64], out: [i64]) -> [i64] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_i64s(lst: rest, out: x :: out)
  end
end

let rev_literals = fn (lst: [Literal], out: [Literal]) -> [Literal] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_literals(lst: rest, out: x :: out)
  end
end

let rev_pat_rows = fn (lst: [PatRow], out: [PatRow]) -> [PatRow] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_pat_rows(lst: rest, out: x :: out)
  end
end

let rev_strings = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_strings(lst: rest, out: x :: out)
  end
end

export let lir_reverse_ctors = fn (lst: [CtorBranch], acc: [CtorBranch]) -> [CtorBranch] do
  match lst do
    | [] -> return acc
    | x :: rest -> return lir_reverse_ctors(lst: rest, acc: x :: acc)
  end
end

export let lir_reverse_lit_branches = fn (lst: [LitBranch], acc: [LitBranch]) -> [LitBranch] do
  match lst do
    | [] -> return acc
    | x :: rest -> return lir_reverse_lit_branches(lst: rest, acc: x :: acc)
  end
end

// ─── String Less-Than (lexicographic) ────────────────────────────────────────

let lir_str_less_than_loop = fn (a: string, b: string, idx: i64, la: i64, lb: i64) -> bool do
  if idx >= la then
    return idx < lb
  else
    if idx >= lb then
      return false
    else
      let ca = str.char_code(s: a, idx: idx)
      let cb = str.char_code(s: b, idx: idx)
      if ca < cb then
        return true
      else
        if ca > cb then
          return false
        else
          return lir_str_less_than_loop(a: a, b: b, idx: idx + 1, la: la, lb: lb)
        end
      end
    end
  end
end

let lir_str_less_than = fn (a: string, b: string) -> bool do
  return lir_str_less_than_loop(a: a, b: b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end

// ─── Constructor Tag (FNV-1a) ────────────────────────────────────────────────

let fnv_basis = -3750763034362895579
let fnv_prime = 1099511628211

let lir_fnv_hash_byte = fn (hash: i64, byte: i64) -> i64 do
  return (hash ^ byte) * fnv_prime
end

let fnv_hash_string_loop = fn (s: string, idx: i64, slen: i64, hash: i64) -> i64 do
  if idx >= slen then return hash
  else return fnv_hash_string_loop(s: s, idx: idx + 1, slen: slen,
                                    hash: lir_fnv_hash_byte(hash: hash, byte: str.char_code(s: s, idx: idx)))
  end
end

let lir_constructor_tag = fn (name: string, arity: i64) -> i64 do
  let hash = fnv_hash_string_loop(s: name, idx: 0, slen: str.length(s: name), hash: fnv_basis)
  return lir_fnv_hash_byte(hash: hash, byte: arity)
end

// ─── Enum Definition Lookup ──────────────────────────────────────────────────

let find_variant_in_list = fn (name: string, variants: [VariantDef]) -> Option<VariantDef> do
  match variants do
    | [] -> return None
    | vd :: rest ->
      match vd do | VariantDef(name: vn, fields: _) ->
        if vn == name then return Some(val: vd)
        else return find_variant_in_list(name: name, variants: rest)
        end
      end
  end
end

let lookup_variant_def = fn (name: string, enum_defs: [EnumDef]) -> Option<VariantDef> do
  match enum_defs do
    | [] -> return None
    | ed :: rest ->
      match ed do | EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs) ->
        match find_variant_in_list(name: name, variants: vs) do
          | Some(val: vd) -> return Some(val: vd)
          | None -> return lookup_variant_def(name: name, enum_defs: rest)
        end
      end
  end
end

let count_variant_fields = fn (fields: [VariantField]) -> i64 do
  match fields do
    | [] -> return 0
    | _ :: rest -> return 1 + count_variant_fields(fields: rest)
  end
end

let variant_field_count = fn (vd: VariantDef) -> i64 do
  match vd do | VariantDef(name: _, fields: fs) ->
    return count_variant_fields(fields: fs)
  end
end

let lookup_constructor_arity = fn (name: string, enum_defs: [EnumDef], fallback: i64) -> i64 do
  match lookup_variant_def(name: name, enum_defs: enum_defs) do
    | Some(val: vd) -> return variant_field_count(vd: vd)
    | None -> return fallback
  end
end

let extract_variant_field_names = fn (fields: [VariantField]) -> [string] do
  return extract_variant_field_names_go(fields: fields, acc: [])
end

let extract_variant_field_names_go = fn (fields: [VariantField], acc: [string]) -> [string] do
  match fields do
    | [] -> return rev_strings(lst: acc, out: [])
    | VariantField(name: n_opt, typ: _) :: rest ->
      let field_name = match n_opt do
        | Some(val: n) -> n
        | None -> str.from_i64(val: count_variant_fields(fields: rest))
      end
      return extract_variant_field_names_go(fields: rest, acc: field_name :: acc)
  end
end

let get_variant_field_names = fn (vd: VariantDef) -> [string] do
  match vd do | VariantDef(name: _, fields: fs) ->
    return extract_variant_field_names(fields: fs)
  end
end

// ─── List Helpers for Decision Trees ────────────────────────────────────────

let lir_list_take = fn (lst: [MirPattern], n: i64) -> [MirPattern] do
  return lir_list_take_go(lst: lst, n: n, acc: [])
end

let lir_list_take_go = fn (lst: [MirPattern], n: i64, acc: [MirPattern]) -> [MirPattern] do
  if n <= 0 then return rev_mir_patterns(lst: acc, out: []) end
  match lst do
    | [] -> return rev_mir_patterns(lst: acc, out: [])
    | x :: rest -> return lir_list_take_go(lst: rest, n: n - 1, acc: x :: acc)
  end
end

let lir_list_drop = fn (lst: [MirPattern], n: i64) -> [MirPattern] do
  match n <= 0 do
    | true -> return lst
    | false ->
      match lst do
        | [] -> return []
        | _ :: rest -> return lir_list_drop(lst: rest, n: n - 1)
      end
  end
end

let lir_list_nth_pat = fn (lst: [MirPattern], n: i64) -> MirPattern do
  match lst do
    | [] -> return MirPatWildcard
    | x :: rest ->
      match n == 0 do
        | true -> return x
        | false -> return lir_list_nth_pat(lst: rest, n: n - 1)
      end
  end
end

let lir_ids_take = fn (lst: [i64], n: i64) -> [i64] do
  return lir_ids_take_go(lst: lst, n: n, acc: [])
end

let lir_ids_take_go = fn (lst: [i64], n: i64, acc: [i64]) -> [i64] do
  if n <= 0 then return rev_i64s(lst: acc, out: []) end
  match lst do
    | [] -> return rev_i64s(lst: acc, out: [])
    | x :: rest -> return lir_ids_take_go(lst: rest, n: n - 1, acc: x :: acc)
  end
end

let lir_ids_drop = fn (lst: [i64], n: i64) -> [i64] do
  match n <= 0 do
    | true -> return lst
    | false ->
      match lst do
        | [] -> return []
        | _ :: rest -> return lir_ids_drop(lst: rest, n: n - 1)
      end
  end
end

export let lir_id_nth = fn (lst: [i64], n: i64) -> i64 do
  match lst do
    | [] -> return 0
    | x :: rest ->
      match n == 0 do
        | true -> return x
        | false -> return lir_id_nth(lst: rest, n: n - 1)
      end
  end
end

let lir_str_contains = fn (lst: [string], name: string) -> bool do
  match lst do
    | [] -> return false
    | x :: rest ->
      match x == name do
        | true -> return true
        | false -> return lir_str_contains(lst: rest, name: name)
      end
  end
end

export let lir_str_index = fn (lst: [string], name: string, idx: i64) -> i64 do
  match lst do
    | [] -> return 0 - 1
    | x :: rest ->
      match x == name do
        | true -> return idx
        | false -> return lir_str_index(lst: rest, name: name, idx: idx + 1)
      end
  end
end

let lir_repeat_wildcard = fn (n: i64) -> [MirPattern] do
  return lir_repeat_wildcard_go(n: n, acc: [])
end

let lir_repeat_wildcard_go = fn (n: i64, acc: [MirPattern]) -> [MirPattern] do
  if n <= 0 then return acc end
  return lir_repeat_wildcard_go(n: n - 1, acc: MirPatWildcard :: acc)
end

let lir_alloc_ids = fn (n: i64, next_id: i64) -> [i64] do
  return lir_alloc_ids_go(curr: next_id + n - 1, stop: next_id, acc: [])
end

let lir_alloc_ids_go = fn (curr: i64, stop: i64, acc: [i64]) -> [i64] do
  if curr < stop then return acc end
  return lir_alloc_ids_go(curr: curr - 1, stop: stop, acc: curr :: acc)
end

let lir_append_pats = fn (a: [MirPattern], b: [MirPattern]) -> [MirPattern] do
  return lir_append_pats_go(a: a, b: b, acc: [])
end

let lir_append_pats_go = fn (a: [MirPattern], b: [MirPattern], acc: [MirPattern]) -> [MirPattern] do
  match a do
    | [] -> return rev_mir_patterns(lst: acc, out: b)
    | x :: rest -> return lir_append_pats_go(a: rest, b: b, acc: x :: acc)
  end
end

let lir_append_ids = fn (a: [i64], b: [i64]) -> [i64] do
  return lir_append_ids_go(a: a, b: b, acc: [])
end

let lir_append_ids_go = fn (a: [i64], b: [i64], acc: [i64]) -> [i64] do
  match a do
    | [] -> return rev_i64s(lst: acc, out: b)
    | x :: rest -> return lir_append_ids_go(a: rest, b: b, acc: x :: acc)
  end
end

let lir_lit_eq = fn (a: Literal, b: Literal) -> bool do
  match a do
    | LitInt(val: ai) ->
      return if let LitInt(val: bi) = b then ai == bi else false end
    | LitBool(val: ab) ->
      return if let LitBool(val: bb) = b then ab == bb else false end
    | LitString(val: as_) ->
      return if let LitString(val: bs) = b then as_ == bs else false end
    | LitChar(val: ac) ->
      return if let LitChar(val: bc) = b then ac == bc else false end
    | LitUnit ->
      return if let LitUnit = b then true else false end
    | _ -> return false
  end
end

let lir_lit_in_list = fn (lit: Literal, lst: [Literal]) -> bool do
  match lst do
    | [] -> return false
    | x :: rest ->
      match lir_lit_eq(a: lit, b: x) do
        | true -> return true
        | false -> return lir_lit_in_list(lit: lit, lst: rest)
      end
  end
end

export let lookup_atom_entry = fn (id: i64, atoms: [AtomEntry]) -> AtomEntry do
  match atoms do
    | [] -> return AtomEntry(id: id, atom: LirAtomUnit, sem_type: TyUnit)
    | AtomEntry(id: eid, atom: a, sem_type: st) :: rest ->
      match eid == id do
        | true -> return AtomEntry(id: eid, atom: a, sem_type: st)
        | false -> return lookup_atom_entry(id: id, atoms: rest)
      end
  end
end

// ─── Decision Tree Construction (Maranget) ──────────────────────────────────

let lir_find_active_column = fn (rows: [PatRow], n_cols: i64) -> Option<i64> do
  return lir_scan_columns(rows: rows, n_cols: n_cols, col: 0)
end

let lir_scan_columns = fn (rows: [PatRow], n_cols: i64, col: i64) -> Option<i64> do
  match col >= n_cols do
    | true -> return None
    | false ->
      match lir_column_has_active(rows: rows, col: col) do
        | true -> return Some(val: col)
        | false -> return lir_scan_columns(rows: rows, n_cols: n_cols, col: col + 1)
      end
  end
end

let lir_column_has_active = fn (rows: [PatRow], col: i64) -> bool do
  match rows do
    | [] -> return false
    | PatRow(pats: pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatWildcard -> return lir_column_has_active(rows: rest, col: col)
        | MirPatVariable(_) -> return lir_column_has_active(rows: rest, col: col)
        | _ -> return true
      end
  end
end

export let lir_build_decision_tree = fn (rows: [PatRow], col_ids: [i64], next_id: i64, enum_defs: [EnumDef]) -> DecTreeResult do
  match rows do
    | [] -> return DecTreeResult(tree: DecFail, next_id: next_id)
    | _ ->
      let n_cols = lir_ids_length(lst: col_ids)
      match lir_find_active_column(rows: rows, n_cols: n_cols) do
        | None ->
          match rows do
            | [] -> return DecTreeResult(tree: DecFail, next_id: next_id)
            | PatRow(pats: pats, case_idx: ci, bindings: bs) :: _ ->
            let all_bs = lir_collect_var_bindings(pats: pats, col_ids: col_ids, idx: 0, acc: bs)
            return DecTreeResult(tree: DecLeaf(case_idx: ci, bindings: all_bs), next_id: next_id)
          end
        | Some(val: col) ->
          match lir_first_active_pat(rows: rows, col: col) do
            | MirPatConstructor(_) ->
              return lir_build_ctor_switch(rows: rows, col: col, col_ids: col_ids, next_id: next_id, enum_defs: enum_defs)
            | MirPatLiteral(_) ->
              return lir_build_lit_switch(rows: rows, col: col, col_ids: col_ids, next_id: next_id, enum_defs: enum_defs)
            | MirPatRecord(_) ->
              let fnames = lir_collect_record_fields(rows: rows, col: col)
              let sorted_fnames = lir_sort_strings(lst: fnames)
              return lir_build_record_destructure(rows: rows, col: col, col_ids: col_ids,
                field_names: sorted_fnames, next_id: next_id, enum_defs: enum_defs)
            | _ -> return DecTreeResult(tree: DecFail, next_id: next_id)
          end
      end
  end
end

let lir_ids_length = fn (lst: [i64]) -> i64 do
  match lst do
    | [] -> return 0
    | _ :: rest -> return 1 + lir_ids_length(lst: rest)
  end
end

let lir_collect_var_bindings = fn (pats: [MirPattern], col_ids: [i64], idx: i64, acc: [PatBinding]) -> [PatBinding] do
  match pats do
    | [] -> return acc
    | p :: rest ->
      let scr_id = lir_id_nth(lst: col_ids, n: idx)
      match p do
        | MirPatVariable(name: n, sigil: _) ->
          return lir_collect_var_bindings(pats: rest, col_ids: col_ids, idx: idx + 1,
            acc: PatBinding(name: n, scrutinee_id: scr_id) :: acc)
        | _ ->
          return lir_collect_var_bindings(pats: rest, col_ids: col_ids, idx: idx + 1, acc: acc)
      end
  end
end

let lir_first_active_pat = fn (rows: [PatRow], col: i64) -> MirPattern do
  match rows do
    | [] -> return MirPatWildcard
    | PatRow(pats: pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatWildcard -> return lir_first_active_pat(rows: rest, col: col)
        | MirPatVariable(_) -> return lir_first_active_pat(rows: rest, col: col)
        | p -> return p
      end
  end
end

let lir_collect_ctor_names = fn (rows: [PatRow], col: i64) -> [string] do
  return lir_collect_ctor_names_go(rows: rows, col: col, seen: [])
end

let lir_collect_ctor_names_go = fn (rows: [PatRow], col: i64, seen: [string]) -> [string] do
  match rows do
    | [] -> return seen
    | PatRow(pats: pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatConstructor(name: n, fields: _) ->
          match lir_str_contains(lst: seen, name: n) do
            | true -> return lir_collect_ctor_names_go(rows: rest, col: col, seen: seen)
            | false ->
              let new_seen = lir_append_strings(a: seen, b: [n])
              return lir_collect_ctor_names_go(rows: rest, col: col, seen: new_seen)
          end
        | _ -> return lir_collect_ctor_names_go(rows: rest, col: col, seen: seen)
      end
  end
end

let lir_append_strings = fn (a: [string], b: [string]) -> [string] do
  return lir_append_strings_go(a: a, b: b, acc: [])
end

let lir_append_strings_go = fn (a: [string], b: [string], acc: [string]) -> [string] do
  match a do
    | [] -> return rev_strings(lst: acc, out: b)
    | x :: rest -> return lir_append_strings_go(a: rest, b: b, acc: x :: acc)
  end
end

let lir_collect_lits = fn (rows: [PatRow], col: i64) -> [Literal] do
  return lir_collect_lits_go(rows: rows, col: col, seen: [])
end

let lir_collect_lits_go = fn (rows: [PatRow], col: i64, seen: [Literal]) -> [Literal] do
  match rows do
    | [] -> return seen
    | PatRow(pats: pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatLiteral(lit: l) ->
          match lir_lit_in_list(lit: l, lst: seen) do
            | true -> return lir_collect_lits_go(rows: rest, col: col, seen: seen)
            | false ->
              let new_seen = lir_append_lits(a: seen, b: [l])
              return lir_collect_lits_go(rows: rest, col: col, seen: new_seen)
          end
        | _ -> return lir_collect_lits_go(rows: rest, col: col, seen: seen)
      end
  end
end

let lir_append_lits = fn (a: [Literal], b: [Literal]) -> [Literal] do
  return lir_append_lits_go(a: a, b: b, acc: [])
end

let lir_append_lits_go = fn (a: [Literal], b: [Literal], acc: [Literal]) -> [Literal] do
  match a do
    | [] -> return rev_literals(lst: acc, out: b)
    | x :: rest -> return lir_append_lits_go(a: rest, b: b, acc: x :: acc)
  end
end

let lir_collect_record_fields = fn (rows: [PatRow], col: i64) -> [string] do
  return lir_collect_record_fields_go(rows: rows, col: col, seen: [])
end

let lir_collect_record_fields_go = fn (rows: [PatRow], col: i64, seen: [string]) -> [string] do
  match rows do
    | [] -> return seen
    | PatRow(pats: pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatRecord(fields: fields, is_partial: _) ->
          let new_seen = lir_add_record_field_names(fields: fields, seen: seen)
          return lir_collect_record_fields_go(rows: rest, col: col, seen: new_seen)
        | _ -> return lir_collect_record_fields_go(rows: rest, col: col, seen: seen)
      end
  end
end

let lir_add_record_field_names = fn (fields: [MirRecordPatField], seen: [string]) -> [string] do
  match fields do
    | [] -> return seen
    | MirRecordPatField(name: n, pattern: _) :: rest ->
      match lir_str_contains(lst: seen, name: n) do
        | true -> return lir_add_record_field_names(fields: rest, seen: seen)
        | false -> return lir_add_record_field_names(fields: rest, seen: lir_append_strings(a: seen, b: [n]))
      end
  end
end

export let lir_sort_strings = fn (lst: [string]) -> [string] do
  match lst do
    | [] -> return []
    | x :: rest -> return lir_insert_sorted(val: x, sorted: lir_sort_strings(lst: rest))
  end
end

let lir_insert_sorted = fn (val: string, sorted: [string]) -> [string] do
  return lir_insert_sorted_go(val: val, sorted: sorted, acc: [])
end

let lir_insert_sorted_go = fn (val: string, sorted: [string], acc: [string]) -> [string] do
  match sorted do
    | [] -> return rev_strings(lst: acc, out: [val])
    | x :: rest ->
      match lir_str_less_than(a: val, b: x) || val == x do
        | true -> return rev_strings(lst: acc, out: val :: sorted)
        | false -> return lir_insert_sorted_go(val: val, sorted: rest, acc: x :: acc)
      end
  end
end

// ─── Build CtorSwitch ───────────────────────────────────────────────────────

let lir_build_ctor_switch = fn (rows: [PatRow], col: i64, col_ids: [i64],
    next_id: i64, enum_defs: [EnumDef]) -> DecTreeResult do
  let scr_id = lir_id_nth(lst: col_ids, n: col)
  let ctor_names = lir_collect_ctor_names(rows: rows, col: col)
  match lir_build_ctor_branches(ctor_names: ctor_names, rows: rows, col: col, col_ids: col_ids,
      next_id: next_id, enum_defs: enum_defs) do | CtorBranchesResult(branches: branches, next_id: nid2) ->
    let default_rows = lir_default_matrix(rows: rows, col: col, col_ids: col_ids)
    let new_col_ids = lir_append_ids(a: lir_ids_take(lst: col_ids, n: col),
                                      b: lir_ids_drop(lst: col_ids, n: col + 1))
    match default_rows do
      | [] ->
        return DecTreeResult(tree: DecCtorSwitch(scrutinee_id: scr_id, branches: branches, fallback: None), next_id: nid2)
      | _ ->
        match lir_build_decision_tree(rows: default_rows, col_ids: new_col_ids, next_id: nid2, enum_defs: enum_defs) do | DecTreeResult(tree: fb, next_id: nid3) ->
          return DecTreeResult(tree: DecCtorSwitch(scrutinee_id: scr_id, branches: branches, fallback: Some(val: fb)), next_id: nid3)
        end
    end
  end
end

let lir_ctor_arity_from_rows = fn (rows: [PatRow], col: i64, ctor_name: string) -> i64 do
  match rows do
    | [] -> return 0
    | PatRow(pats: pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatConstructor(name: n, fields: fields) ->
          match n == ctor_name do
            | true -> return lir_pat_fields_length(lst: fields)
            | false -> return lir_ctor_arity_from_rows(rows: rest, col: col, ctor_name: ctor_name)
          end
        | _ -> return lir_ctor_arity_from_rows(rows: rest, col: col, ctor_name: ctor_name)
      end
  end
end

let lir_pat_fields_length = fn (lst: [MirPatternField]) -> i64 do
  match lst do
    | [] -> return 0
    | _ :: rest -> return 1 + lir_pat_fields_length(lst: rest)
  end
end

let lir_build_ctor_branches = fn (ctor_names: [string], rows: [PatRow], col: i64,
    col_ids: [i64], next_id: i64, enum_defs: [EnumDef]) -> CtorBranchesResult do
  return lir_build_ctor_branches_go(ctor_names: ctor_names, rows: rows, col: col,
    col_ids: col_ids, next_id: next_id, enum_defs: enum_defs, acc: [])
end

let lir_build_ctor_branches_go = fn (ctor_names: [string], rows: [PatRow], col: i64,
    col_ids: [i64], next_id: i64, enum_defs: [EnumDef], acc: [CtorBranch]) -> CtorBranchesResult do
  match ctor_names do
    | [] -> return CtorBranchesResult(branches: lir_reverse_ctors(lst: acc, acc: []), next_id: next_id)
    | cn :: rest_names ->
      let pat_arity = lir_ctor_arity_from_rows(rows: rows, col: col, ctor_name: cn)
      let arity = lookup_constructor_arity(name: cn, enum_defs: enum_defs, fallback: pat_arity)
      let field_ids = lir_alloc_ids(n: arity, next_id: next_id)
      let nid2 = next_id + arity
      let new_col_ids = lir_append_ids(a: lir_ids_take(lst: col_ids, n: col),
                          b: lir_append_ids(a: field_ids, b: lir_ids_drop(lst: col_ids, n: col + 1)))
      let spec_rows = lir_specialize_ctor(rows: rows, col: col, col_ids: col_ids, ctor_name: cn,
                                            arity: arity, enum_defs: enum_defs)
      match lir_build_decision_tree(rows: spec_rows, col_ids: new_col_ids, next_id: nid2, enum_defs: enum_defs) do | DecTreeResult(tree: subtree, next_id: nid3) ->
        let tag = lir_constructor_tag(name: cn, arity: arity)
        let branch = CtorBranch(ctor_name: cn, ctor_tag: tag, arity: arity, field_ids: field_ids, subtree: subtree)
        return lir_build_ctor_branches_go(ctor_names: rest_names, rows: rows, col: col, col_ids: col_ids,
          next_id: nid3, enum_defs: enum_defs, acc: branch :: acc)
      end
  end
end

let lir_specialize_ctor = fn (rows: [PatRow], col: i64, col_ids: [i64],
    ctor_name: string, arity: i64, enum_defs: [EnumDef]) -> [PatRow] do
  return lir_specialize_ctor_go(rows: rows, col: col, col_ids: col_ids,
    ctor_name: ctor_name, arity: arity, enum_defs: enum_defs, acc: [])
end

let lir_specialize_ctor_go = fn (rows: [PatRow], col: i64, col_ids: [i64],
    ctor_name: string, arity: i64, enum_defs: [EnumDef], acc: [PatRow]) -> [PatRow] do
  match rows do
    | [] -> return rev_pat_rows(lst: acc, out: [])
    | PatRow(pats: pats, case_idx: ci, bindings: bs) :: rest ->
      let pat = lir_list_nth_pat(lst: pats, n: col)
      match pat do
        | MirPatConstructor(name: n, fields: fields) ->
          match n == ctor_name do
            | true ->
              let sub_pats = lir_reorder_ctor_fields(fields: fields, ctor_name: ctor_name,
                                                       arity: arity, enum_defs: enum_defs)
              let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                              b: lir_append_pats(a: sub_pats, b: lir_list_drop(lst: pats, n: col + 1)))
              return lir_specialize_ctor_go(rows: rest, col: col, col_ids: col_ids,
                ctor_name: ctor_name, arity: arity, enum_defs: enum_defs,
                acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
            | false -> return lir_specialize_ctor_go(rows: rest, col: col, col_ids: col_ids,
              ctor_name: ctor_name, arity: arity, enum_defs: enum_defs, acc: acc)
          end
        | MirPatWildcard ->
          let wild_pats = lir_repeat_wildcard(n: arity)
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_append_pats(a: wild_pats, b: lir_list_drop(lst: pats, n: col + 1)))
          return lir_specialize_ctor_go(rows: rest, col: col, col_ids: col_ids,
            ctor_name: ctor_name, arity: arity, enum_defs: enum_defs,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
        | MirPatVariable(name: vn, sigil: _) ->
          let scr_id = lir_id_nth(lst: col_ids, n: col)
          let new_bs = PatBinding(name: vn, scrutinee_id: scr_id) :: bs
          let wild_pats = lir_repeat_wildcard(n: arity)
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_append_pats(a: wild_pats, b: lir_list_drop(lst: pats, n: col + 1)))
          return lir_specialize_ctor_go(rows: rest, col: col, col_ids: col_ids,
            ctor_name: ctor_name, arity: arity, enum_defs: enum_defs,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: new_bs) :: acc)
        | _ -> return lir_specialize_ctor_go(rows: rest, col: col, col_ids: col_ids,
          ctor_name: ctor_name, arity: arity, enum_defs: enum_defs, acc: acc)
      end
  end
end

let lir_reorder_ctor_fields = fn (fields: [MirPatternField], ctor_name: string,
    arity: i64, enum_defs: [EnumDef]) -> [MirPattern] do
  let base = lir_repeat_wildcard(n: arity)
  match lookup_variant_def(name: ctor_name, enum_defs: enum_defs) do
    | Some(val: vd) ->
      let def_names = get_variant_field_names(vd: vd)
      return lir_place_fields(fields: fields, base: base, def_names: def_names, pos: 0)
    | None ->
      return lir_extract_field_pats(fields: fields)
  end
end

let lir_place_fields = fn (fields: [MirPatternField], base: [MirPattern],
    def_names: [string], pos: i64) -> [MirPattern] do
  match fields do
    | [] -> return base
    | MirPatternField(name: name_opt, pattern: p) :: rest ->
      let def_idx = match name_opt do
        | Some(val: n) -> lir_str_index(lst: def_names, name: n, idx: 0)
        | None -> pos
      end
      let new_base = lir_set_nth_pat(lst: base, idx: def_idx, val: p)
      return lir_place_fields(fields: rest, base: new_base, def_names: def_names, pos: pos + 1)
  end
end

let lir_set_nth_pat = fn (lst: [MirPattern], idx: i64, val: MirPattern) -> [MirPattern] do
  return lir_set_nth_pat_go(lst: lst, idx: idx, val: val, acc: [])
end

let lir_set_nth_pat_go = fn (lst: [MirPattern], idx: i64, val: MirPattern, acc: [MirPattern]) -> [MirPattern] do
  match lst do
    | [] -> return rev_mir_patterns(lst: acc, out: [])
    | x :: rest ->
      if idx == 0 then return rev_mir_patterns(lst: acc, out: val :: rest)
      else return lir_set_nth_pat_go(lst: rest, idx: idx - 1, val: val, acc: x :: acc)
      end
  end
end

let lir_extract_field_pats = fn (fields: [MirPatternField]) -> [MirPattern] do
  return lir_extract_field_pats_go(fields: fields, acc: [])
end

let lir_extract_field_pats_go = fn (fields: [MirPatternField], acc: [MirPattern]) -> [MirPattern] do
  match fields do
    | [] -> return rev_mir_patterns(lst: acc, out: [])
    | MirPatternField(name: _, pattern: p) :: rest -> return lir_extract_field_pats_go(fields: rest, acc: p :: acc)
  end
end

// ─── Build LitSwitch ────────────────────────────────────────────────────────

let lir_build_lit_switch = fn (rows: [PatRow], col: i64, col_ids: [i64],
    next_id: i64, enum_defs: [EnumDef]) -> DecTreeResult do
  let scr_id = lir_id_nth(lst: col_ids, n: col)
  let lits = lir_collect_lits(rows: rows, col: col)
  let new_col_ids = lir_append_ids(a: lir_ids_take(lst: col_ids, n: col),
                                    b: lir_ids_drop(lst: col_ids, n: col + 1))
  match lir_build_lit_branches(lits: lits, rows: rows, col: col, col_ids: col_ids,
      new_col_ids: new_col_ids, next_id: next_id, enum_defs: enum_defs) do | LitBranchesResult(branches: branches, next_id: nid2) ->
    let default_rows = lir_default_matrix(rows: rows, col: col, col_ids: col_ids)
    match lir_build_decision_tree(rows: default_rows, col_ids: new_col_ids, next_id: nid2, enum_defs: enum_defs) do | DecTreeResult(tree: fb, next_id: nid3) ->
      return DecTreeResult(tree: DecLitSwitch(scrutinee_id: scr_id, branches: branches, fallback: fb), next_id: nid3)
    end
  end
end

let lir_build_lit_branches = fn (lits: [Literal], rows: [PatRow], col: i64,
    col_ids: [i64], new_col_ids: [i64], next_id: i64, enum_defs: [EnumDef]) -> LitBranchesResult do
  return lir_build_lit_branches_go(lits: lits, rows: rows, col: col,
    col_ids: col_ids, new_col_ids: new_col_ids, next_id: next_id, enum_defs: enum_defs, acc: [])
end

let lir_build_lit_branches_go = fn (lits: [Literal], rows: [PatRow], col: i64,
    col_ids: [i64], new_col_ids: [i64], next_id: i64, enum_defs: [EnumDef], acc: [LitBranch]) -> LitBranchesResult do
  match lits do
    | [] -> return LitBranchesResult(branches: lir_reverse_lit_branches(lst: acc, acc: []), next_id: next_id)
    | l :: rest_lits ->
      let spec_rows = lir_specialize_literal(rows: rows, col: col, col_ids: col_ids, lit: l)
      match lir_build_decision_tree(rows: spec_rows, col_ids: new_col_ids, next_id: next_id, enum_defs: enum_defs) do | DecTreeResult(tree: subtree, next_id: nid2) ->
        return lir_build_lit_branches_go(lits: rest_lits, rows: rows, col: col, col_ids: col_ids,
          new_col_ids: new_col_ids, next_id: nid2, enum_defs: enum_defs,
          acc: LitBranch(lit: l, subtree: subtree) :: acc)
      end
  end
end

let lir_specialize_literal = fn (rows: [PatRow], col: i64, col_ids: [i64], lit: Literal) -> [PatRow] do
  return lir_specialize_literal_go(rows: rows, col: col, col_ids: col_ids, lit: lit, acc: [])
end

let lir_specialize_literal_go = fn (rows: [PatRow], col: i64, col_ids: [i64], lit: Literal, acc: [PatRow]) -> [PatRow] do
  match rows do
    | [] -> return rev_pat_rows(lst: acc, out: [])
    | PatRow(pats: pats, case_idx: ci, bindings: bs) :: rest ->
      let pat = lir_list_nth_pat(lst: pats, n: col)
      match pat do
        | MirPatLiteral(lit: l) ->
          match lir_lit_eq(a: l, b: lit) do
            | true ->
              let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                              b: lir_list_drop(lst: pats, n: col + 1))
              return lir_specialize_literal_go(rows: rest, col: col, col_ids: col_ids, lit: lit,
                acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
            | false -> return lir_specialize_literal_go(rows: rest, col: col, col_ids: col_ids, lit: lit, acc: acc)
          end
        | MirPatWildcard ->
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_list_drop(lst: pats, n: col + 1))
          return lir_specialize_literal_go(rows: rest, col: col, col_ids: col_ids, lit: lit,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
        | MirPatVariable(name: vn, sigil: _) ->
          let scr_id = lir_id_nth(lst: col_ids, n: col)
          let new_bs = PatBinding(name: vn, scrutinee_id: scr_id) :: bs
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_list_drop(lst: pats, n: col + 1))
          return lir_specialize_literal_go(rows: rest, col: col, col_ids: col_ids, lit: lit,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: new_bs) :: acc)
        | _ -> return lir_specialize_literal_go(rows: rest, col: col, col_ids: col_ids, lit: lit, acc: acc)
      end
  end
end

// ─── Build RecordDestructure ────────────────────────────────────────────────

let lir_build_record_destructure = fn (rows: [PatRow], col: i64, col_ids: [i64],
    field_names: [string], next_id: i64, enum_defs: [EnumDef]) -> DecTreeResult do
  let scr_id = lir_id_nth(lst: col_ids, n: col)
  let k = lir_strings_length(lst: field_names)
  let field_ids = lir_alloc_ids(n: k, next_id: next_id)
  let nid2 = next_id + k
  let new_col_ids = lir_append_ids(a: lir_ids_take(lst: col_ids, n: col),
                      b: lir_append_ids(a: field_ids, b: lir_ids_drop(lst: col_ids, n: col + 1)))
  let spec_rows = lir_specialize_record(rows: rows, col: col, col_ids: col_ids,
                                          field_names: field_names, k: k)
  match lir_build_decision_tree(rows: spec_rows, col_ids: new_col_ids, next_id: nid2, enum_defs: enum_defs) do | DecTreeResult(tree: subtree, next_id: nid3) ->
    return DecTreeResult(tree: DecRecordDestructure(scrutinee_id: scr_id, field_names: field_names,
                                                      field_ids: field_ids, subtree: subtree), next_id: nid3)
  end
end

let lir_strings_length = fn (lst: [string]) -> i64 do
  match lst do
    | [] -> return 0
    | _ :: rest -> return 1 + lir_strings_length(lst: rest)
  end
end

let lir_specialize_record = fn (rows: [PatRow], col: i64, col_ids: [i64],
    field_names: [string], k: i64) -> [PatRow] do
  return lir_specialize_record_go(rows: rows, col: col, col_ids: col_ids,
    field_names: field_names, k: k, acc: [])
end

let lir_specialize_record_go = fn (rows: [PatRow], col: i64, col_ids: [i64],
    field_names: [string], k: i64, acc: [PatRow]) -> [PatRow] do
  match rows do
    | [] -> return rev_pat_rows(lst: acc, out: [])
    | PatRow(pats: pats, case_idx: ci, bindings: bs) :: rest ->
      let pat = lir_list_nth_pat(lst: pats, n: col)
      match pat do
        | MirPatRecord(fields: fields, is_partial: _) ->
          let sub_pats = lir_expand_record_fields(fields: fields, field_names: field_names, k: k)
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_append_pats(a: sub_pats, b: lir_list_drop(lst: pats, n: col + 1)))
          return lir_specialize_record_go(rows: rest, col: col, col_ids: col_ids,
            field_names: field_names, k: k,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
        | MirPatWildcard ->
          let wild_pats = lir_repeat_wildcard(n: k)
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_append_pats(a: wild_pats, b: lir_list_drop(lst: pats, n: col + 1)))
          return lir_specialize_record_go(rows: rest, col: col, col_ids: col_ids,
            field_names: field_names, k: k,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
        | MirPatVariable(name: vn, sigil: _) ->
          let scr_id = lir_id_nth(lst: col_ids, n: col)
          let new_bs = PatBinding(name: vn, scrutinee_id: scr_id) :: bs
          let wild_pats = lir_repeat_wildcard(n: k)
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_append_pats(a: wild_pats, b: lir_list_drop(lst: pats, n: col + 1)))
          return lir_specialize_record_go(rows: rest, col: col, col_ids: col_ids,
            field_names: field_names, k: k,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: new_bs) :: acc)
        | _ -> return lir_specialize_record_go(rows: rest, col: col, col_ids: col_ids,
          field_names: field_names, k: k, acc: acc)
      end
  end
end

let lir_expand_record_fields = fn (fields: [MirRecordPatField], field_names: [string], k: i64) -> [MirPattern] do
  let base = lir_repeat_wildcard(n: k)
  return lir_place_record_pats(fields: fields, base: base, field_names: field_names)
end

let lir_place_record_pats = fn (fields: [MirRecordPatField], base: [MirPattern], field_names: [string]) -> [MirPattern] do
  match fields do
    | [] -> return base
    | MirRecordPatField(name: n, pattern: p) :: rest ->
      let idx = lir_str_index(lst: field_names, name: n, idx: 0)
      let new_base = lir_set_nth_pat(lst: base, idx: idx, val: p)
      return lir_place_record_pats(fields: rest, base: new_base, field_names: field_names)
  end
end

// ─── Default Matrix ─────────────────────────────────────────────────────────

let lir_default_matrix = fn (rows: [PatRow], col: i64, col_ids: [i64]) -> [PatRow] do
  return lir_default_matrix_go(rows: rows, col: col, col_ids: col_ids, acc: [])
end

let lir_default_matrix_go = fn (rows: [PatRow], col: i64, col_ids: [i64], acc: [PatRow]) -> [PatRow] do
  match rows do
    | [] -> return rev_pat_rows(lst: acc, out: [])
    | PatRow(pats: pats, case_idx: ci, bindings: bs) :: rest ->
      let pat = lir_list_nth_pat(lst: pats, n: col)
      match pat do
        | MirPatWildcard ->
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_list_drop(lst: pats, n: col + 1))
          return lir_default_matrix_go(rows: rest, col: col, col_ids: col_ids,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
        | MirPatVariable(name: vn, sigil: _) ->
          let scr_id = lir_id_nth(lst: col_ids, n: col)
          let new_bs = PatBinding(name: vn, scrutinee_id: scr_id) :: bs
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_list_drop(lst: pats, n: col + 1))
          return lir_default_matrix_go(rows: rest, col: col, col_ids: col_ids,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: new_bs) :: acc)
        | _ -> return lir_default_matrix_go(rows: rest, col: col, col_ids: col_ids, acc: acc)
      end
  end
end

// ─── Cases → Rows Bridge ────────────────────────────────────────────────────

export let lir_cases_to_rows = fn (cases: [MirMatchCase], idx: i64) -> [PatRow] do
  return lir_cases_to_rows_go(cases: cases, idx: idx, acc: [])
end

let lir_cases_to_rows_go = fn (cases: [MirMatchCase], idx: i64, acc: [PatRow]) -> [PatRow] do
  match cases do
    | [] -> return rev_pat_rows(lst: acc, out: [])
    | MirMatchCase(pattern: p, body: _) :: rest ->
      // Expand top-level or-patterns: one match arm with `A | B` becomes
      // two PatRows (with patterns A and B) sharing the same case_idx,
      // mirroring Maranget's row-expansion treatment of or-patterns.
      // lir_or_expand_pattern returns rows in REVERSE declared order so they
      // can be prepended to acc directly — `acc` is itself in reverse order
      // until the final rev_pat_rows() flips it back.
      let new_rows_rev = lir_or_expand_pattern(pat: p, idx: idx)
      return lir_cases_to_rows_go(cases: rest, idx: idx + 1, acc: list.concat(xs: new_rows_rev, ys: acc))
  end
end

let lir_or_expand_pattern = fn (pat: MirPattern, idx: i64) -> [PatRow] do
  match pat do
    | MirPatOr(alts: alts) -> return lir_or_expand_alts(alts: alts, idx: idx, acc: [])
    | _ -> return [PatRow(pats: [pat], case_idx: idx, bindings: [])]
  end
end

let lir_or_expand_alts = fn (alts: [MirPattern], idx: i64, acc: [PatRow]) -> [PatRow] do
  match alts do
    | [] -> return acc
    | a :: rest ->
      // Recursively flatten nested ors (defensive — parser doesn't currently produce them).
      let nested = lir_or_expand_pattern(pat: a, idx: idx)
      return lir_or_expand_alts(alts: rest, idx: idx, acc: list.concat(xs: nested, ys: acc))
  end
end

// ═══════════════════════════════════════════════════════════════════════════
// Pure emission helpers (shared with lir.nx)
//
// These transform decision-tree metadata into LIR statements without ever
// calling back into lir.nx's body lowering, so they sit cleanly here without
// a module cycle.
// ═══════════════════════════════════════════════════════════════════════════

// ─── Emission result types (shared with lir.nx) ─────────────────────────────

export type CtorCondsResult = CtorCondsResult(ctx: LowerCtx, conds: [LirAtom])
export type LitCondsResult = LitCondsResult(ctx: LowerCtx, conds: [LirAtom])
export type FieldExtractResult = FieldExtractResult(ctx: LowerCtx, atoms: [AtomEntry], field_stmts: [LirStmt])
export type FieldLoopResult = FieldLoopResult(ctx: LowerCtx, atoms: [AtomEntry])

// ─── Small utility helpers ──────────────────────────────────────────────────

export let lir_reverse_atoms = fn (lst: [LirAtom], acc: [LirAtom]) -> [LirAtom] do
  match lst do
    | [] -> return acc
    | x :: rest -> return lir_reverse_atoms(lst: rest, acc: x :: acc)
  end
end

export let lir_ctors_length = fn (lst: [CtorBranch]) -> i64 do
  match lst do
    | [] -> return 0
    | _ :: rest -> return 1 + lir_ctors_length(lst: rest)
  end
end

export let lir_nth_case_body = fn (cases: [MirMatchCase], idx: i64) -> [MirStmt] do
  match cases do
    | [] -> return []
    | MirMatchCase(pattern: _, body: b) :: rest ->
      match idx == 0 do
        | true -> return b
        | false -> return lir_nth_case_body(cases: rest, idx: idx - 1)
      end
  end
end

let lir_nth_string = fn (lst: [string], n: i64) -> string do
  match lst do
    | [] -> return ""
    | x :: rest ->
      match n == 0 do
        | true -> return x
        | false -> return lir_nth_string(lst: rest, n: n - 1)
      end
  end
end

// Map definition-order field index to memory (sorted) index for built-in constructors.
// Cons(v, rest): sorted [rest(0), v(1)] → def 0(v)→mem 1, def 1(rest)→mem 0.
// Some(val): only 1 field, no reordering.
let lir_builtin_field_mem_idx = fn (ctor_name: string, def_idx: i64) -> i64 do
  if ctor_name == "Cons" then
    if def_idx == 0 then return 1 else return 0 end
  end
  return def_idx
end

// ─── Constructor / record field type + index lookups ────────────────────────

let sorted_field_index = fn (field_name: string, all_names: [string]) -> i64 do
  match all_names do
    | [] -> return 0
    | n :: rest ->
      if lir_str_less_than(a: n, b: field_name) then
        return 1 + sorted_field_index(field_name: field_name, all_names: rest)
      else
        return sorted_field_index(field_name: field_name, all_names: rest)
      end
  end
end

let find_variant_field_type = fn (fields: [VariantField], name: string) -> TypeExpr do
  match fields do
    | [] -> return TyI64
    | VariantField(name: Some(val: n), typ: t) :: rest ->
      if n == name then return t
      else return find_variant_field_type(fields: rest, name: name)
      end
    | VariantField(name: None, typ: _) :: rest ->
      return find_variant_field_type(fields: rest, name: name)
  end
end

let constructor_field_type = fn (field_name: string, ctor_name: string, enum_defs: [EnumDef]) -> TypeExpr do
  match lookup_variant_def(name: ctor_name, enum_defs: enum_defs) do
    | Some(val: VariantDef(name: _, fields: fs)) ->
      return find_variant_field_type(fields: fs, name: field_name)
    | None -> return TyI64
  end
end

let constructor_field_heap_index = fn (field_name: string, ctor_name: string, enum_defs: [EnumDef]) -> i64 do
  match lookup_variant_def(name: ctor_name, enum_defs: enum_defs) do
    | Some(val: vd) ->
      let all_names = get_variant_field_names(vd: vd)
      return sorted_field_index(field_name: field_name, all_names: all_names)
    | None -> return 0
  end
end

let lir_record_field_type = fn (sem: TypeExpr, name: string) -> TypeExpr do
  match sem do
    | TyRecord(fields: fields) ->
      return lir_find_named_type(fields: fields, name: name)
    | _ -> return TyI64
  end
end

let lir_find_named_type = fn (fields: [NamedType], name: string) -> TypeExpr do
  match fields do
    | [] -> return TyI64
    | NamedType(name: fn_, typ: ft) :: rest ->
      match fn_ == name do
        | true -> return ft
        | false -> return lir_find_named_type(fields: rest, name: name)
      end
  end
end

let lir_record_sorted_idx = fn (sem: TypeExpr, name: string) -> i64 do
  match sem do
    | TyRecord(fields: fields) ->
      let names = lir_extract_named_type_names(fields: fields)
      let sorted = lir_sort_strings(lst: names)
      return lir_str_index(lst: sorted, name: name, idx: 0)
    | _ -> return 0
  end
end

let lir_extract_named_type_names = fn (fields: [NamedType]) -> [string] do
  return lir_extract_named_type_names_go(fields: fields, acc: [])
end

let lir_extract_named_type_names_go = fn (fields: [NamedType], acc: [string]) -> [string] do
  match fields do
    | [] -> return rev_strings(lst: acc, out: [])
    | NamedType(name: n, typ: _) :: rest -> return lir_extract_named_type_names_go(fields: rest, acc: n :: acc)
  end
end

// ─── Pattern-binding emission ───────────────────────────────────────────────

export let lir_emit_bindings = fn (bindings: [PatBinding], atoms: [AtomEntry], ctx: LowerCtx) -> LowerCtx do
  match bindings do
    | [] -> return ctx
    | PatBinding(name: n, scrutinee_id: sid) :: rest ->
      match lookup_atom_entry(id: sid, atoms: atoms) do | AtomEntry(id: _, atom: a, sem_type: st) ->
        match ctx do | LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
          let typ = atom_type(atom: a)
          let ctx2 = LowerCtx(
            vars: insert_type(name: n, typ: typ, entries: v),
            semantic_vars: insert_type(name: n, typ: st, entries: sv),
            stmts: LirStmtLet(name: n, typ: typ, expr: LirExprAtom(atom: a)) :: s,
            temp_counter: c, enum_defs: ed
          )
          return lir_emit_bindings(bindings: rest, atoms: atoms, ctx: ctx2)
        end
      end
  end
end

// ─── Field-extraction helpers ───────────────────────────────────────────────

let reverse_stmts_local = fn (stmts: [LirStmt]) -> [LirStmt] do
  return reverse_stmts_local_go(stmts: stmts, acc: [])
end

let reverse_stmts_local_go = fn (stmts: [LirStmt], acc: [LirStmt]) -> [LirStmt] do
  match stmts do
    | [] -> return acc
    | s :: rest -> return reverse_stmts_local_go(stmts: rest, acc: s :: acc)
  end
end

export let lir_extract_ctor_fields = fn (scr_atom: LirAtom, scr_sem: TypeExpr, ctor_name: string,
    arity: i64, field_ids: [i64], atoms: [AtomEntry], ctx: LowerCtx) -> FieldExtractResult do
  match ctx do | LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let work_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lir_extract_fields_loop(scr_atom: scr_atom, scr_sem: scr_sem, ctor_name: ctor_name,
        field_ids: field_ids, idx: 0, arity: arity, atoms: atoms, ctx: work_ctx,
        enum_defs: ed) do | FieldLoopResult(ctx: ctx2, atoms: atoms2) ->
      match ctx2 do | LowerCtx(vars: _, semantic_vars: _, stmts: field_stmts, temp_counter: c2, enum_defs: _) ->
        let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
        return FieldExtractResult(ctx: restored, atoms: atoms2, field_stmts: reverse_stmts_local(stmts: field_stmts))
      end
    end
  end
end

let lir_extract_fields_loop = fn (scr_atom: LirAtom, scr_sem: TypeExpr, ctor_name: string,
    field_ids: [i64], idx: i64, arity: i64, atoms: [AtomEntry], ctx: LowerCtx,
    enum_defs: [EnumDef]) -> FieldLoopResult do
  match idx >= arity do
    | true -> return FieldLoopResult(ctx: ctx, atoms: atoms)
    | false ->
      let fid = lir_id_nth(lst: field_ids, n: idx)
      match lookup_variant_def(name: ctor_name, enum_defs: enum_defs) do
        | Some(val: vd) ->
          let names = get_variant_field_names(vd: vd)
          let field_name = lir_nth_string(lst: names, n: idx)
          let heap_idx = constructor_field_heap_index(field_name: field_name, ctor_name: ctor_name, enum_defs: enum_defs)
          let sem_ft = constructor_field_type(field_name: field_name, ctor_name: ctor_name, enum_defs: enum_defs)
          let wasm_ft = wasm_type(typ: sem_ft)
          match bind_expr_to_temp_semantic(ctx: ctx,
            expr: LirExprObjectField(value: scr_atom, index: heap_idx, typ: wasm_ft),
            typ: wasm_ft, semantic_type: sem_ft) do | BindResult(ctx: ctx2, atom: field_atom) ->
            let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: sem_ft) :: atoms
            return lir_extract_fields_loop(scr_atom: scr_atom, scr_sem: scr_sem, ctor_name: ctor_name,
              field_ids: field_ids, idx: idx + 1, arity: arity, atoms: new_atoms, ctx: ctx2,
              enum_defs: enum_defs)
          end
        | None ->
          // Built-in constructor — alphabetical field sort for memory layout.
          let mem_idx = lir_builtin_field_mem_idx(ctor_name: ctor_name, def_idx: idx)
          match bind_expr_to_temp(ctx: ctx,
            expr: LirExprObjectField(value: scr_atom, index: mem_idx, typ: TyI64),
            typ: TyI64) do | BindResult(ctx: ctx2, atom: field_atom) ->
            let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: TyI64) :: atoms
            return lir_extract_fields_loop(scr_atom: scr_atom, scr_sem: scr_sem, ctor_name: ctor_name,
              field_ids: field_ids, idx: idx + 1, arity: arity, atoms: new_atoms, ctx: ctx2,
              enum_defs: enum_defs)
          end
      end
  end
end

export let lir_extract_record_fields = fn (scr_atom: LirAtom, scr_sem: TypeExpr,
    field_names: [string], field_ids: [i64], atoms: [AtomEntry], ctx: LowerCtx) -> FieldExtractResult do
  match ctx do | LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let work_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lir_extract_record_loop(scr_atom: scr_atom, scr_sem: scr_sem,
        field_names: field_names, field_ids: field_ids, atoms: atoms, ctx: work_ctx) do | FieldLoopResult(ctx: ctx2, atoms: atoms2) ->
      match ctx2 do | LowerCtx(vars: _, semantic_vars: _, stmts: field_stmts, temp_counter: c2, enum_defs: _) ->
        let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
        return FieldExtractResult(ctx: restored, atoms: atoms2, field_stmts: reverse_stmts_local(stmts: field_stmts))
      end
    end
  end
end

let lir_extract_record_loop = fn (scr_atom: LirAtom, scr_sem: TypeExpr,
    field_names: [string], field_ids: [i64], atoms: [AtomEntry], ctx: LowerCtx) -> FieldLoopResult do
  match field_names do
    | [] -> return FieldLoopResult(ctx: ctx, atoms: atoms)
    | fn_ :: rest_names ->
      match field_ids do
        | [] -> return FieldLoopResult(ctx: ctx, atoms: atoms)
        | fid :: rest_ids ->
        let field_type = lir_record_field_type(sem: scr_sem, name: fn_)
        let sorted_idx = lir_record_sorted_idx(sem: scr_sem, name: fn_)
        let wasm_ft = wasm_type(typ: field_type)
        match bind_expr_to_temp_semantic(ctx: ctx,
          expr: LirExprObjectField(value: scr_atom, index: sorted_idx, typ: wasm_ft),
          typ: wasm_ft, semantic_type: field_type) do | BindResult(ctx: ctx2, atom: field_atom) ->
          let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: field_type) :: atoms
          return lir_extract_record_loop(scr_atom: scr_atom, scr_sem: scr_sem,
            field_names: rest_names, field_ids: rest_ids, atoms: new_atoms, ctx: ctx2)
        end
      end
  end
end

// ─── Condition builders (ctor tag / literal equality) ───────────────────────

export let lir_emit_ctor_conds = fn (branches: [CtorBranch], tag_atom: LirAtom, has_fb: bool, pos: i64, total: i64, ctx: LowerCtx) -> CtorCondsResult do
  return lir_emit_ctor_conds_go(branches: branches, tag_atom: tag_atom, has_fb: has_fb, pos: pos, total: total, ctx: ctx, acc: [])
end

let lir_emit_ctor_conds_go = fn (branches: [CtorBranch], tag_atom: LirAtom, has_fb: bool, pos: i64, total: i64, ctx: LowerCtx, acc: [LirAtom]) -> CtorCondsResult do
  match branches do
    | [] -> return CtorCondsResult(ctx: ctx, conds: lir_reverse_atoms(lst: acc, acc: []))
    | CtorBranch(ctor_name: _, ctor_tag: tag, arity: _, field_ids: _, subtree: _) :: rest ->
      let is_last_no_fb = (pos == total - 1) && (has_fb == false)
      match is_last_no_fb do
        | true ->
          return lir_emit_ctor_conds_go(branches: rest, tag_atom: tag_atom, has_fb: has_fb, pos: pos + 1, total: total, ctx: ctx, acc: LirAtomBool(val: true) :: acc)
        | false ->
          match bind_expr_to_temp(ctx: ctx,
            expr: LirExprBinary(op: OpEq, lhs: tag_atom, rhs: LirAtomInt(val: tag), typ: TyBool),
            typ: TyBool) do | BindResult(ctx: ctx2, atom: cond) ->
            return lir_emit_ctor_conds_go(branches: rest, tag_atom: tag_atom, has_fb: has_fb, pos: pos + 1, total: total, ctx: ctx2, acc: cond :: acc)
          end
      end
  end
end

export let lir_emit_lit_conds = fn (branches: [LitBranch], scr_atom: LirAtom, ctx: LowerCtx) -> LitCondsResult do
  return lir_emit_lit_conds_go(branches: branches, scr_atom: scr_atom, ctx: ctx, acc: [])
end

let lir_emit_lit_conds_go = fn (branches: [LitBranch], scr_atom: LirAtom, ctx: LowerCtx, acc: [LirAtom]) -> LitCondsResult do
  match branches do
    | [] -> return LitCondsResult(ctx: ctx, conds: lir_reverse_atoms(lst: acc, acc: []))
    | LitBranch(lit: l, subtree: _) :: rest ->
      let lit_atom = literal_to_atom(lit: l)
      match bind_expr_to_temp(ctx: ctx,
        expr: LirExprBinary(op: OpEq, lhs: scr_atom, rhs: lit_atom, typ: TyBool),
        typ: TyBool) do | BindResult(ctx: ctx2, atom: cond) ->
        return lir_emit_lit_conds_go(branches: rest, scr_atom: scr_atom, ctx: ctx2, acc: cond :: acc)
      end
  end
end
