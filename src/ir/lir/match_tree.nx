/**
 * match_tree: Maranget decision-tree construction + pure emission helpers.
 *
 * Owns:
 * - Decision tree types (PatRow, DecTree, CtorBranch, LitBranch, AtomEntry, DecTreeResult)
 * - Pattern matrix → DecTree algorithm (Maranget)
 * - Specialization / default matrix / record destructure builders
 * - Bridge: MirMatchCase list → PatRow list
 * - Pure emission helpers shared by lir.nx:
 *   · Field-extraction for constructor + record scrutinees
 *   · Constructor- and literal-condition builders
 *   · Pattern-binding emission (lir_emit_bindings)
 *   · Small utilities: lir_nth_case_body, lir_nth_string, lir_ctors_length,
 *     lir_reverse_atoms, lir_builtin_field_mem_idx
 *
 * Does not own:
 * - Recursive decision-tree emission and leaf emission (stay in lir.nx):
 *   those call body lowering, and the self-hosted compiler has no first-class
 * function calls yet (blocker for callback injection —).
 * - LowerCtx definition (see src/ir/lir/context.nx).
 *
 * Implementation is split across sub-files:
 *   match_tree/types.nx — public ADTs (PatBinding, DecTree, CtorBranch, etc.)
 *   match_tree/build.nx — pattern matrix → DecTree construction (Maranget)
 *   match_tree/emit.nx  — pure emission helpers shared with lir.nx
 * This file is the stable import surface for functions; types are in
 * match_tree/types.nx.
 */
import { LirError } from "src/ir/lir/errors.nx"
import { MirMatchCase } from "src/ir/mir/types.nx"
import { LirAtom, LirStmt } from "src/ir/lir/types.nx"
import { LowerCtx } from "src/ir/lir/context.nx"
import { TypeExpr } from "src/types/type_expr.nx"
import { VariantIndex } from "src/ir/support/variant_index.nx"
import {
  PatBinding,
  PatRow,
  DecTree,
  DecTreeResult,
  CtorBranch,
  LitBranch,
  AtomEntry,
  CtorCondsResult,
  LitCondsResult,
  FieldExtractResult
} from "src/ir/lir/match_tree/types.nx"
import { lir_build_decision_tree as _build_decision_tree } from "src/ir/lir/match_tree/build.nx"
import {
  lir_cases_to_rows as _cases_to_rows,
  lir_reverse_ctors as _reverse_ctors,
  lir_reverse_lit_branches as _reverse_lit_branches
} from "src/ir/lir/match_tree/build_utils.nx"
import {
  lookup_atom_entry as _lookup_atom_entry,
  lir_reverse_atoms as _reverse_atoms,
  lir_ctors_length as _ctors_length,
  lir_nth_case_body as _nth_case_body,
  lir_emit_bindings as _emit_bindings,
  lir_extract_ctor_fields as _extract_ctor_fields,
  lir_extract_record_fields as _extract_record_fields,
  lir_emit_ctor_conds as _emit_ctor_conds,
  lir_emit_lit_conds as _emit_lit_conds
} from "src/ir/lir/match_tree/emit.nx"
import { MirStmt } from "src/ir/mir/types.nx"

/** Public function lir_reverse_ctors. */
export let lir_reverse_ctors = fn (
  lst: [ CtorBranch ],
  acc: [ CtorBranch ]
) -> [ CtorBranch ] throws { LirError } do
  return _reverse_ctors(lst, acc)
end

/** Public function lir_reverse_lit_branches. */
export let lir_reverse_lit_branches = fn (
  lst: [ LitBranch ],
  acc: [ LitBranch ]
) -> [ LitBranch ] throws { LirError } do
  return _reverse_lit_branches(lst, acc)
end

/** Public function lookup_atom_entry. */
export let lookup_atom_entry = fn (
  id: i64,
  atoms: [ AtomEntry ]
) -> AtomEntry throws { LirError } do
  return _lookup_atom_entry(id, atoms)
end

/** Public function lir_build_decision_tree. */
export let lir_build_decision_tree = fn (
  rows: [ PatRow ],
  col_ids: [ i64 ],
  next_id: i64,
  enum_defs: VariantIndex
) -> DecTreeResult throws { LirError } do
  return _build_decision_tree(rows, col_ids, next_id, enum_defs)
end

/** Public function lir_cases_to_rows. */
export let lir_cases_to_rows = fn (
  cases: [ MirMatchCase ],
  idx: i64
) -> [ PatRow ] throws { LirError } do
  return _cases_to_rows(cases, idx)
end

/** Public function lir_reverse_atoms. */
export let lir_reverse_atoms = fn (
  lst: [ LirAtom ],
  acc: [ LirAtom ]
) -> [ LirAtom ] throws { LirError } do
  return _reverse_atoms(lst, acc)
end

/** Public function lir_ctors_length. */
export let lir_ctors_length = fn (lst: [ CtorBranch ]) -> i64 throws { LirError } do
  return _ctors_length(lst)
end

/** Public function lir_nth_case_body. */
export let lir_nth_case_body = fn (
  cases: [ MirMatchCase ],
  idx: i64
) -> [ MirStmt ] throws { LirError } do
  return _nth_case_body(cases, idx)
end

/** Public function lir_emit_bindings. */
export let lir_emit_bindings = fn (
  bindings: [ PatBinding ],
  atoms: [ AtomEntry ],
  ctx: LowerCtx
) -> LowerCtx throws { LirError } do
  return _emit_bindings(bindings, atoms, ctx)
end

/** Public function lir_extract_ctor_fields. */
export let lir_extract_ctor_fields = fn (scr_atom: LirAtom, scr_sem: TypeExpr, ctor_name: string,
    arity: i64, field_ids: [ i64 ], atoms: [ AtomEntry ], ctx: LowerCtx) -> FieldExtractResult throws { LirError } do
  return _extract_ctor_fields(scr_atom, scr_sem, ctor_name, arity, field_ids, atoms, ctx)
end

/** Public function lir_extract_record_fields. */
export let lir_extract_record_fields = fn (scr_atom: LirAtom, scr_sem: TypeExpr,
    field_names: [ string ], field_ids: [ i64 ], atoms: [ AtomEntry ], ctx: LowerCtx) -> FieldExtractResult throws { LirError } do
  return _extract_record_fields(scr_atom, scr_sem, field_names, field_ids, atoms, ctx)
end

/** Public function lir_emit_ctor_conds. */
export let lir_emit_ctor_conds = fn (
  branches: [ CtorBranch ],
  tag_atom: LirAtom,
  has_fb: bool,
  pos: i64,
  total: i64,
  ctx: LowerCtx
) -> CtorCondsResult throws { LirError } do
  return _emit_ctor_conds(branches, tag_atom, has_fb, pos, total, ctx)
end

/** Public function lir_emit_lit_conds. */
export let lir_emit_lit_conds = fn (
  branches: [ LitBranch ],
  scr_atom: LirAtom,
  ctx: LowerCtx
) -> LitCondsResult throws { LirError } do
  return _emit_lit_conds(branches, scr_atom, ctx)
end
