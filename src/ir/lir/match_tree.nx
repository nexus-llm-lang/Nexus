/**
 * match_tree: Maranget decision-tree construction + pure emission helpers.
 *
 * Owns:
 * - Decision tree types (PatRow, DecTree, CtorBranch, LitBranch, AtomEntry, DecTreeResult)
 * - Pattern matrix → DecTree algorithm (Maranget)
 * - Specialization / default matrix / record destructure builders
 * - Bridge: MirMatchCase list → PatRow list
 * - Pure emission helpers shared by lir.nx:
 *   · Field-extraction for constructor + record scrutinees
 *   · Constructor- and literal-condition builders
 *   · Pattern-binding emission (lir_emit_bindings)
 *   · Small utilities: lir_nth_case_body, lir_nth_string, lir_ctors_length,
 *     lir_reverse_atoms, lir_builtin_field_mem_idx
 *
 * Does not own:
 * - Recursive decision-tree emission and leaf emission (stay in lir.nx):
 *   those call body lowering, and the self-hosted compiler has no first-class
 * function calls yet (blocker for callback injection —).
 * - LowerCtx definition (see src/ir/lir/context.nx).
 */
import { OpEq, Literal, TypeExpr, TyI64, TyBool, TyRecord, NamedType, VariantDef, VariantField } from "src/common/ast.nx"
import { LirAtomEntryNotFound } from "src/ir/lir/errors.nx"
import { Some, None } from "std:option"
import { MirStmt, MirPattern, MirPatOr, MirPatternField, MirRecordPatField, MirMatchCase } from "src/ir/mir/types.nx"
import { LirAtom, LirAtomInt, LirAtomBool, LirExprAtom, LirExprBinary, LirExprObjectField, LirStmt, LirStmtLet } from "src/ir/lir/types.nx"
import { LowerCtx, BindResult, insert_type, atom_type, wasm_type, bind_expr_to_temp, bind_expr_to_temp_semantic, literal_to_atom } from "src/ir/lir/context.nx"
import { VariantIndex }, * as vidx from "src/common/variant_index.nx"
import * as str from "std:str"
import * as list from "std:list"
import { rev_strings } from "src/common/listrev.nx"


/** Public type PatBinding. */
export type PatBinding = PatBinding(name: string, scrutinee_id: i64)
/** Public type PatRow. */
export type PatRow = PatRow(pats: [MirPattern], case_idx: i64, bindings: [PatBinding])

/** Public type DecTree. */
export type DecTree =
  DecLeaf(case_idx: i64, bindings: [PatBinding])
  | DecCtorSwitch(scrutinee_id: i64, branches: [CtorBranch], fallback: Option<DecTree>)
  | DecLitSwitch(scrutinee_id: i64, branches: [LitBranch], fallback: DecTree)
  | DecRecordDestructure(scrutinee_id: i64, field_names: [string], field_ids: [i64], subtree: DecTree)
  | DecFail

/** Public type CtorBranch. */
export type CtorBranch = CtorBranch(ctor_name: string, ctor_tag: i64, arity: i64, field_ids: [i64], subtree: DecTree)
/** Public type LitBranch. */
export type LitBranch = LitBranch(lit: Literal, subtree: DecTree)

/** Public type AtomEntry. */
export type AtomEntry = AtomEntry(id: i64, atom: LirAtom, sem_type: TypeExpr)

/** Public type DecTreeResult. */
export type DecTreeResult = DecTreeResult(tree: DecTree, next_id: i64)

type CtorBranchesResult = CtorBranchesResult(branches: [CtorBranch], next_id: i64)
type LitBranchesResult = LitBranchesResult(branches: [LitBranch], next_id: i64)


let rev_mir_patterns = fn (lst: [MirPattern], out: [MirPattern]) -> [MirPattern] throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_patterns(lst: rest, out: x :: out)
  end
end

let rev_i64s = fn (lst: [i64], out: [i64]) -> [i64] throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_i64s(lst: rest, out: x :: out)
  end
end

let rev_literals = fn (lst: [Literal], out: [Literal]) -> [Literal] throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_literals(lst: rest, out: x :: out)
  end
end

/** Public function lir_reverse_ctors. */
export let lir_reverse_ctors = fn (lst: [CtorBranch], acc: [CtorBranch]) -> [CtorBranch] throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return acc
    | x :: rest -> return lir_reverse_ctors(lst: rest, acc: x :: acc)
  end
end

/** Public function lir_reverse_lit_branches. */
export let lir_reverse_lit_branches = fn (lst: [LitBranch], acc: [LitBranch]) -> [LitBranch] throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return acc
    | x :: rest -> return lir_reverse_lit_branches(lst: rest, acc: x :: acc)
  end
end


let lir_str_less_than_loop = fn (a: string, b: string, idx: i64, la: i64, lb: i64) -> bool throws { LirAtomEntryNotFound } do
  if idx >= la then
    return idx < lb
  else if idx >= lb then
    return false
  else
    let ca = str.char_code(s: a, idx)
    let cb = str.char_code(s: b, idx)
    if ca < cb then
      return true
    else if ca > cb then
      return false
    else
      return lir_str_less_than_loop(a, b, idx: idx + 1, la, lb)
    end
  end
end

let lir_str_less_than = fn (a: string, b: string) -> bool throws { LirAtomEntryNotFound } do
  return lir_str_less_than_loop(a, b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end


let fnv_basis = -3750763034362895579
let fnv_prime = 1099511628211

let lir_fnv_hash_byte = fn (hash: i64, byte: i64) -> i64 throws { LirAtomEntryNotFound } do
  return (hash ^ byte) * fnv_prime
end

let fnv_hash_string_loop = fn (s: string, idx: i64, slen: i64, hash: i64) -> i64 throws { LirAtomEntryNotFound } do
  if idx >= slen then return hash
  else return fnv_hash_string_loop(s, idx: idx + 1, slen,
                                    hash: lir_fnv_hash_byte(hash, byte: str.char_code(s, idx)))
  end
end

let lir_constructor_tag = fn (name: string, arity: i64) -> i64 throws { LirAtomEntryNotFound } do
  let hash = fnv_hash_string_loop(s: name, idx: 0, slen: str.length(s: name), hash: fnv_basis)
  return lir_fnv_hash_byte(hash, byte: arity)
end


let lookup_variant_def = fn (name: string, enum_defs: VariantIndex) -> Option<VariantDef> do
  return vidx.lookup_variant_def_in_index(idx: enum_defs, variant: name)
end

let count_variant_fields = fn (fields: [VariantField]) -> i64 throws { LirAtomEntryNotFound } do
  match fields do
    | [] -> return 0
    | _ :: rest -> return 1 + count_variant_fields(fields: rest)
  end
end

let variant_field_count = fn (vd: VariantDef) -> i64 throws { LirAtomEntryNotFound } do
  match vd do | VariantDef(name: _, fields: fs) ->
    return count_variant_fields(fields: fs)
  end
end

let lookup_constructor_arity = fn (name: string, enum_defs: VariantIndex, fallback: i64) -> i64 throws { LirAtomEntryNotFound } do
  match lookup_variant_def(name, enum_defs) do
    | Some(val: vd) -> return variant_field_count(vd)
    | None -> return fallback
  end
end

let extract_variant_field_names = fn (fields: [VariantField]) -> [string] throws { LirAtomEntryNotFound } do
  return extract_variant_field_names_go(fields, acc: [])
end

let extract_variant_field_names_go = fn (fields: [VariantField], acc: [string]) -> [string] throws { LirAtomEntryNotFound } do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | VariantField(name: n_opt, typ: _) :: rest ->
      let field_name = match n_opt do
        | Some(val: n) -> n
        | None -> str.from_i64(val: count_variant_fields(fields: rest))
      end
      return extract_variant_field_names_go(fields: rest, acc: field_name :: acc)
  end
end

let get_variant_field_names = fn (vd: VariantDef) -> [string] throws { LirAtomEntryNotFound } do
  match vd do | VariantDef(name: _, fields: fs) ->
    return extract_variant_field_names(fields: fs)
  end
end


let lir_list_take = fn (lst: [MirPattern], n: i64) -> [MirPattern] throws { LirAtomEntryNotFound } do
  return lir_list_take_go(lst, n, acc: [])
end

let lir_list_take_go = fn (lst: [MirPattern], n: i64, acc: [MirPattern]) -> [MirPattern] throws { LirAtomEntryNotFound } do
  if n <= 0 then return rev_mir_patterns(lst: acc, out: []) end
  match lst do
    | [] -> return rev_mir_patterns(lst: acc, out: [])
    | x :: rest -> return lir_list_take_go(lst: rest, n: n - 1, acc: x :: acc)
  end
end

let lir_list_drop = fn (lst: [MirPattern], n: i64) -> [MirPattern] throws { LirAtomEntryNotFound } do
  if n <= 0 then return lst end
  match lst do
    | [] -> return []
    | _ :: rest -> return lir_list_drop(lst: rest, n: n - 1)
  end
end

let lir_list_nth_pat = fn (lst: [MirPattern], n: i64) -> MirPattern throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> throw LirAtomEntryNotFound(id: n)
    | x :: rest ->
      if n == 0 then return x
      else return lir_list_nth_pat(lst: rest, n: n - 1)
      end
  end
end

let lir_ids_take = fn (lst: [i64], n: i64) -> [i64] throws { LirAtomEntryNotFound } do
  return lir_ids_take_go(lst, n, acc: [])
end

let lir_ids_take_go = fn (lst: [i64], n: i64, acc: [i64]) -> [i64] throws { LirAtomEntryNotFound } do
  if n <= 0 then return rev_i64s(lst: acc, out: []) end
  match lst do
    | [] -> return rev_i64s(lst: acc, out: [])
    | x :: rest -> return lir_ids_take_go(lst: rest, n: n - 1, acc: x :: acc)
  end
end

let lir_ids_drop = fn (lst: [i64], n: i64) -> [i64] throws { LirAtomEntryNotFound } do
  if n <= 0 then return lst end
  match lst do
    | [] -> return []
    | _ :: rest -> return lir_ids_drop(lst: rest, n: n - 1)
  end
end

let lir_id_nth = fn (lst: [i64], n: i64) -> i64 throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> throw LirAtomEntryNotFound(id: n)
    | x :: rest ->
      if n == 0 then return x
      else return lir_id_nth(lst: rest, n: n - 1)
      end
  end
end

let lir_str_contains = fn (lst: [string], name: string) -> bool throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return false
    | x :: rest ->
      if x == name then return true
      else return lir_str_contains(lst: rest, name)
      end
  end
end

let lir_str_index = fn (lst: [string], name: string, idx: i64) -> i64 throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return -1
    | x :: rest ->
      if x == name then return idx
      else return lir_str_index(lst: rest, name, idx: idx + 1)
      end
  end
end

let lir_repeat_wildcard = fn (n: i64) -> [MirPattern] throws { LirAtomEntryNotFound } do
  return lir_repeat_wildcard_go(n, acc: [])
end

let lir_repeat_wildcard_go = fn (n: i64, acc: [MirPattern]) -> [MirPattern] throws { LirAtomEntryNotFound } do
  if n <= 0 then return acc end
  return lir_repeat_wildcard_go(n: n - 1, acc: MirPatWildcard :: acc)
end

let lir_alloc_ids = fn (n: i64, next_id: i64) -> [i64] throws { LirAtomEntryNotFound } do
  return lir_alloc_ids_go(curr: next_id + n - 1, stop: next_id, acc: [])
end

let lir_alloc_ids_go = fn (curr: i64, stop: i64, acc: [i64]) -> [i64] throws { LirAtomEntryNotFound } do
  if curr < stop then return acc end
  return lir_alloc_ids_go(curr: curr - 1, stop, acc: curr :: acc)
end

let lir_append_pats = fn (a: [MirPattern], b: [MirPattern]) -> [MirPattern] throws { LirAtomEntryNotFound } do
  return lir_append_pats_go(a, b, acc: [])
end

let lir_append_pats_go = fn (a: [MirPattern], b: [MirPattern], acc: [MirPattern]) -> [MirPattern] throws { LirAtomEntryNotFound } do
  match a do
    | [] -> return rev_mir_patterns(lst: acc, out: b)
    | x :: rest -> return lir_append_pats_go(a: rest, b, acc: x :: acc)
  end
end

let lir_append_ids = fn (a: [i64], b: [i64]) -> [i64] throws { LirAtomEntryNotFound } do
  return lir_append_ids_go(a, b, acc: [])
end

let lir_append_ids_go = fn (a: [i64], b: [i64], acc: [i64]) -> [i64] throws { LirAtomEntryNotFound } do
  match a do
    | [] -> return rev_i64s(lst: acc, out: b)
    | x :: rest -> return lir_append_ids_go(a: rest, b, acc: x :: acc)
  end
end

let lir_lit_eq = fn (a: Literal, b: Literal) -> bool throws { LirAtomEntryNotFound } do
  match a do
    | LitInt(val: ai) ->
      return if let LitInt(val: bi) = b then ai == bi else false end
    | LitBool(val: ab) ->
      return if let LitBool(val: bb) = b then ab == bb else false end
    | LitString(val: as_) ->
      return if let LitString(val: bs) = b then as_ == bs else false end
    | LitChar(val: ac) ->
      return if let LitChar(val: bc) = b then ac == bc else false end
    | LitUnit ->
      return if let LitUnit = b then true else false end
    | _ -> return false
  end
end

let lir_lit_in_list = fn (lit: Literal, lst: [Literal]) -> bool throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return false
    | x :: rest ->
      if lir_lit_eq(a: lit, b: x) then return true
      else return lir_lit_in_list(lit, lst: rest)
      end
  end
end

/** Public function lookup_atom_entry. */
export let lookup_atom_entry = fn (id: i64, atoms: [AtomEntry]) -> AtomEntry throws { LirAtomEntryNotFound } do
  match atoms do
    | [] -> throw LirAtomEntryNotFound(id)
    | AtomEntry(id: eid, atom: a, sem_type: st) :: rest ->
      if eid == id then return AtomEntry(id: eid, atom: a, sem_type: st)
      else return lookup_atom_entry(id, atoms: rest)
      end
  end
end


/** Grand-fathered Option<T>-AND-throws: None is the normal
 *  "no active column" signal; the throws-row is an unrelated invariant-violation
 *  propagated from lir_list_nth_pat (out-of-bounds pattern index = malformed
 *  PatRow). The two signals are orthogonal — see src/common/error.nx header.
 */
let lir_find_active_column = fn (rows: [PatRow], n_cols: i64) -> Option<i64> throws { LirAtomEntryNotFound } do
  return lir_scan_columns(rows, n_cols, col: 0)
end

/** Grand-fathered Option<T>-AND-throws: same rationale as
 *  lir_find_active_column above; throws inherited via lir_column_has_active.
 */
let lir_scan_columns = fn (rows: [PatRow], n_cols: i64, col: i64) -> Option<i64> throws { LirAtomEntryNotFound } do
  if col >= n_cols then return None end
  if lir_column_has_active(rows, col) then return Some(val: col)
  else return lir_scan_columns(rows, n_cols, col: col + 1)
  end
end

let lir_column_has_active = fn (rows: [PatRow], col: i64) -> bool throws { LirAtomEntryNotFound } do
  match rows do
    | [] -> return false
    | PatRow(pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatWildcard | MirPatVariable(_) -> return lir_column_has_active(rows: rest, col)
        | _ -> return true
      end
  end
end

/** Public function lir_build_decision_tree. */
export let lir_build_decision_tree = fn (rows: [PatRow], col_ids: [i64], next_id: i64, enum_defs: VariantIndex) -> DecTreeResult throws { LirAtomEntryNotFound } do
  match rows do
    | [] -> return DecTreeResult(tree: DecFail, next_id)
    | _ ->
      let n_cols = lir_ids_length(lst: col_ids)
      match lir_find_active_column(rows, n_cols) do
        | None ->
          match rows do
            | [] -> return DecTreeResult(tree: DecFail, next_id)
            | PatRow(pats, case_idx: ci, bindings: bs) :: _ ->
            let all_bs = lir_collect_var_bindings(pats, col_ids, idx: 0, acc: bs)
            return DecTreeResult(tree: DecLeaf(case_idx: ci, bindings: all_bs), next_id)
          end
        | Some(val: col) ->
          match lir_first_active_pat(rows, col) do
            | MirPatConstructor(_) ->
              return lir_build_ctor_switch(rows, col, col_ids, next_id, enum_defs)
            | MirPatLiteral(_) ->
              return lir_build_lit_switch(rows, col, col_ids, next_id, enum_defs)
            | MirPatRecord(_) ->
              let fnames = lir_collect_record_fields(rows, col)
              let sorted_fnames = lir_sort_strings(lst: fnames)
              return lir_build_record_destructure(rows, col, col_ids,
                field_names: sorted_fnames, next_id, enum_defs)
            | _ -> return DecTreeResult(tree: DecFail, next_id)
          end
      end
  end
end

let lir_ids_length = fn (lst: [i64]) -> i64 throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return 0
    | _ :: rest -> return 1 + lir_ids_length(lst: rest)
  end
end

let lir_collect_var_bindings = fn (pats: [MirPattern], col_ids: [i64], idx: i64, acc: [PatBinding]) -> [PatBinding] throws { LirAtomEntryNotFound } do
  match pats do
    | [] -> return acc
    | p :: rest ->
      let scr_id = lir_id_nth(lst: col_ids, n: idx)
      match p do
        | MirPatVariable(name: n, sigil: _) ->
          return lir_collect_var_bindings(pats: rest, col_ids, idx: idx + 1,
            acc: PatBinding(name: n, scrutinee_id: scr_id) :: acc)
        | _ ->
          return lir_collect_var_bindings(pats: rest, col_ids, idx: idx + 1, acc)
      end
  end
end

let lir_first_active_pat = fn (rows: [PatRow], col: i64) -> MirPattern throws { LirAtomEntryNotFound } do
  match rows do
    | [] -> return MirPatWildcard
    | PatRow(pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatWildcard | MirPatVariable(_) -> return lir_first_active_pat(rows: rest, col)
        | p -> return p
      end
  end
end

let lir_collect_ctor_names = fn (rows: [PatRow], col: i64) -> [string] throws { LirAtomEntryNotFound } do
  return lir_collect_ctor_names_go(rows, col, seen: [])
end

let lir_collect_ctor_names_go = fn (rows: [PatRow], col: i64, seen: [string]) -> [string] throws { LirAtomEntryNotFound } do
  match rows do
    | [] -> return seen
    | PatRow(pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatConstructor(name: n, fields: _) ->
          if lir_str_contains(lst: seen, name: n) then
            return lir_collect_ctor_names_go(rows: rest, col, seen)
          else
            let new_seen = lir_append_strings(a: seen, b: [n])
            return lir_collect_ctor_names_go(rows: rest, col, seen: new_seen)
          end
        | _ -> return lir_collect_ctor_names_go(rows: rest, col, seen)
      end
  end
end

let lir_append_strings = fn (a: [string], b: [string]) -> [string] throws { LirAtomEntryNotFound } do
  return lir_append_strings_go(a, b, acc: [])
end

let lir_append_strings_go = fn (a: [string], b: [string], acc: [string]) -> [string] throws { LirAtomEntryNotFound } do
  match a do
    | [] -> return rev_strings(lst: acc, out: b)
    | x :: rest -> return lir_append_strings_go(a: rest, b, acc: x :: acc)
  end
end

let lir_collect_lits = fn (rows: [PatRow], col: i64) -> [Literal] throws { LirAtomEntryNotFound } do
  return lir_collect_lits_go(rows, col, seen: [])
end

let lir_collect_lits_go = fn (rows: [PatRow], col: i64, seen: [Literal]) -> [Literal] throws { LirAtomEntryNotFound } do
  match rows do
    | [] -> return seen
    | PatRow(pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatLiteral(lit: l) ->
          if lir_lit_in_list(lit: l, lst: seen) then
            return lir_collect_lits_go(rows: rest, col, seen)
          else
            let new_seen = lir_append_lits(a: seen, b: [l])
            return lir_collect_lits_go(rows: rest, col, seen: new_seen)
          end
        | _ -> return lir_collect_lits_go(rows: rest, col, seen)
      end
  end
end

let lir_append_lits = fn (a: [Literal], b: [Literal]) -> [Literal] throws { LirAtomEntryNotFound } do
  return lir_append_lits_go(a, b, acc: [])
end

let lir_append_lits_go = fn (a: [Literal], b: [Literal], acc: [Literal]) -> [Literal] throws { LirAtomEntryNotFound } do
  match a do
    | [] -> return rev_literals(lst: acc, out: b)
    | x :: rest -> return lir_append_lits_go(a: rest, b, acc: x :: acc)
  end
end

let lir_collect_record_fields = fn (rows: [PatRow], col: i64) -> [string] throws { LirAtomEntryNotFound } do
  return lir_collect_record_fields_go(rows, col, seen: [])
end

let lir_collect_record_fields_go = fn (rows: [PatRow], col: i64, seen: [string]) -> [string] throws { LirAtomEntryNotFound } do
  match rows do
    | [] -> return seen
    | PatRow(pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatRecord(fields, is_partial: _) ->
          let new_seen = lir_add_record_field_names(fields, seen)
          return lir_collect_record_fields_go(rows: rest, col, seen: new_seen)
        | _ -> return lir_collect_record_fields_go(rows: rest, col, seen)
      end
  end
end

let lir_add_record_field_names = fn (fields: [MirRecordPatField], seen: [string]) -> [string] throws { LirAtomEntryNotFound } do
  match fields do
    | [] -> return seen
    | MirRecordPatField(name: n, pattern: _) :: rest ->
      if lir_str_contains(lst: seen, name: n) then
        return lir_add_record_field_names(fields: rest, seen)
      else
        return lir_add_record_field_names(fields: rest, seen: lir_append_strings(a: seen, b: [n]))
      end
  end
end

let lir_sort_strings = fn (lst: [string]) -> [string] throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return []
    | x :: rest -> return lir_insert_sorted(val: x, sorted: lir_sort_strings(lst: rest))
  end
end

let lir_insert_sorted = fn (val: string, sorted: [string]) -> [string] throws { LirAtomEntryNotFound } do
  return lir_insert_sorted_go(val, sorted, acc: [])
end

let lir_insert_sorted_go = fn (val: string, sorted: [string], acc: [string]) -> [string] throws { LirAtomEntryNotFound } do
  match sorted do
    | [] -> return rev_strings(lst: acc, out: [val])
    | x :: rest ->
      if lir_str_less_than(a: val, b: x) || val == x then
        return rev_strings(lst: acc, out: val :: sorted)
      else
        return lir_insert_sorted_go(val, sorted: rest, acc: x :: acc)
      end
  end
end


let lir_build_ctor_switch = fn (rows: [PatRow], col: i64, col_ids: [i64],
    next_id: i64, enum_defs: VariantIndex) -> DecTreeResult throws { LirAtomEntryNotFound } do
  let scr_id = lir_id_nth(lst: col_ids, n: col)
  let ctor_names = lir_collect_ctor_names(rows, col)
  match lir_build_ctor_branches(ctor_names, rows, col, col_ids,
      next_id, enum_defs) do | CtorBranchesResult(branches, next_id: nid2) ->
    let default_rows = lir_default_matrix(rows, col, col_ids)
    let new_col_ids = lir_append_ids(a: lir_ids_take(lst: col_ids, n: col),
                                      b: lir_ids_drop(lst: col_ids, n: col + 1))
    match default_rows do
      | [] ->
        return DecTreeResult(tree: DecCtorSwitch(scrutinee_id: scr_id, branches, fallback: None), next_id: nid2)
      | _ ->
        match lir_build_decision_tree(rows: default_rows, col_ids: new_col_ids, next_id: nid2, enum_defs) do | DecTreeResult(tree: fb, next_id: nid3) ->
          return DecTreeResult(tree: DecCtorSwitch(scrutinee_id: scr_id, branches, fallback: Some(val: fb)), next_id: nid3)
        end
    end
  end
end

let lir_ctor_arity_from_rows = fn (rows: [PatRow], col: i64, ctor_name: string) -> i64 throws { LirAtomEntryNotFound } do
  match rows do
    | [] -> return 0
    | PatRow(pats, case_idx: _, bindings: _) :: rest ->
      match lir_list_nth_pat(lst: pats, n: col) do
        | MirPatConstructor(name: n, fields) ->
          if n == ctor_name then return lir_pat_fields_length(lst: fields)
          else return lir_ctor_arity_from_rows(rows: rest, col, ctor_name)
          end
        | _ -> return lir_ctor_arity_from_rows(rows: rest, col, ctor_name)
      end
  end
end

let lir_pat_fields_length = fn (lst: [MirPatternField]) -> i64 throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return 0
    | _ :: rest -> return 1 + lir_pat_fields_length(lst: rest)
  end
end

let lir_build_ctor_branches = fn (ctor_names: [string], rows: [PatRow], col: i64,
    col_ids: [i64], next_id: i64, enum_defs: VariantIndex) -> CtorBranchesResult throws { LirAtomEntryNotFound } do
  return lir_build_ctor_branches_go(ctor_names, rows, col,
    col_ids, next_id, enum_defs, acc: [])
end

let lir_build_ctor_branches_go = fn (ctor_names: [string], rows: [PatRow], col: i64,
    col_ids: [i64], next_id: i64, enum_defs: VariantIndex, acc: [CtorBranch]) -> CtorBranchesResult throws { LirAtomEntryNotFound } do
  match ctor_names do
    | [] -> return CtorBranchesResult(branches: lir_reverse_ctors(lst: acc, acc: []), next_id)
    | cn :: rest_names ->
      let pat_arity = lir_ctor_arity_from_rows(rows, col, ctor_name: cn)
      let arity = lookup_constructor_arity(name: cn, enum_defs, fallback: pat_arity)
      let field_ids = lir_alloc_ids(n: arity, next_id)
      let nid2 = next_id + arity
      let new_col_ids = lir_append_ids(a: lir_ids_take(lst: col_ids, n: col),
                          b: lir_append_ids(a: field_ids, b: lir_ids_drop(lst: col_ids, n: col + 1)))
      let spec_rows = lir_specialize_ctor(rows, col, col_ids, ctor_name: cn,
                                            arity, enum_defs)
      match lir_build_decision_tree(rows: spec_rows, col_ids: new_col_ids, next_id: nid2, enum_defs) do | DecTreeResult(tree: subtree, next_id: nid3) ->
        let tag = lir_constructor_tag(name: cn, arity)
        let branch = CtorBranch(ctor_name: cn, ctor_tag: tag, arity, field_ids, subtree)
        return lir_build_ctor_branches_go(ctor_names: rest_names, rows, col, col_ids,
          next_id: nid3, enum_defs, acc: branch :: acc)
      end
  end
end

let lir_specialize_ctor = fn (rows: [PatRow], col: i64, col_ids: [i64],
    ctor_name: string, arity: i64, enum_defs: VariantIndex) -> [PatRow] throws { LirAtomEntryNotFound } do
  return lir_specialize_ctor_go(rows, col, col_ids,
    ctor_name, arity, enum_defs, acc: [])
end

let lir_specialize_ctor_go = fn (rows: [PatRow], col: i64, col_ids: [i64],
    ctor_name: string, arity: i64, enum_defs: VariantIndex, acc: [PatRow]) -> [PatRow] throws { LirAtomEntryNotFound } do
  match rows do
    | [] -> return list.reverse(xs: acc)
    | PatRow(pats, case_idx: ci, bindings: bs) :: rest ->
      let pat = lir_list_nth_pat(lst: pats, n: col)
      match pat do
        | MirPatConstructor(name: n, fields) ->
          if n == ctor_name then
            let sub_pats = lir_reorder_ctor_fields(fields, ctor_name,
                                                     arity, enum_defs)
            let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                            b: lir_append_pats(a: sub_pats, b: lir_list_drop(lst: pats, n: col + 1)))
            return lir_specialize_ctor_go(rows: rest, col, col_ids,
              ctor_name, arity, enum_defs,
              acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
          else
            return lir_specialize_ctor_go(rows: rest, col, col_ids,
              ctor_name, arity, enum_defs, acc)
          end
        | MirPatWildcard ->
          let wild_pats = lir_repeat_wildcard(n: arity)
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_append_pats(a: wild_pats, b: lir_list_drop(lst: pats, n: col + 1)))
          return lir_specialize_ctor_go(rows: rest, col, col_ids,
            ctor_name, arity, enum_defs,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
        | MirPatVariable(name: vn, sigil: _) ->
          let scr_id = lir_id_nth(lst: col_ids, n: col)
          let new_bs = PatBinding(name: vn, scrutinee_id: scr_id) :: bs
          let wild_pats = lir_repeat_wildcard(n: arity)
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_append_pats(a: wild_pats, b: lir_list_drop(lst: pats, n: col + 1)))
          return lir_specialize_ctor_go(rows: rest, col, col_ids,
            ctor_name, arity, enum_defs,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: new_bs) :: acc)
        | _ -> return lir_specialize_ctor_go(rows: rest, col, col_ids,
          ctor_name, arity, enum_defs, acc)
      end
  end
end

let lir_reorder_ctor_fields = fn (fields: [MirPatternField], ctor_name: string,
    arity: i64, enum_defs: VariantIndex) -> [MirPattern] throws { LirAtomEntryNotFound } do
  let base = lir_repeat_wildcard(n: arity)
  match lookup_variant_def(name: ctor_name, enum_defs) do
    | Some(val: vd) ->
      let def_names = get_variant_field_names(vd)
      return lir_place_fields(fields, base, def_names, pos: 0)
    | None ->
      return lir_extract_field_pats(fields)
  end
end

let lir_place_fields = fn (fields: [MirPatternField], base: [MirPattern],
    def_names: [string], pos: i64) -> [MirPattern] throws { LirAtomEntryNotFound } do
  match fields do
    | [] -> return base
    | MirPatternField(name: name_opt, pattern: p) :: rest ->
      let def_idx = match name_opt do
        | Some(val: n) -> lir_str_index(lst: def_names, name: n, idx: 0)
        | None -> pos
      end
      let new_base = lir_set_nth_pat(lst: base, idx: def_idx, val: p)
      return lir_place_fields(fields: rest, base: new_base, def_names, pos: pos + 1)
  end
end

let lir_set_nth_pat = fn (lst: [MirPattern], idx: i64, val: MirPattern) -> [MirPattern] throws { LirAtomEntryNotFound } do
  return lir_set_nth_pat_go(lst, idx, val, acc: [])
end

let lir_set_nth_pat_go = fn (lst: [MirPattern], idx: i64, val: MirPattern, acc: [MirPattern]) -> [MirPattern] throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return rev_mir_patterns(lst: acc, out: [])
    | x :: rest ->
      if idx == 0 then return rev_mir_patterns(lst: acc, out: val :: rest)
      else return lir_set_nth_pat_go(lst: rest, idx: idx - 1, val, acc: x :: acc)
      end
  end
end

let lir_extract_field_pats = fn (fields: [MirPatternField]) -> [MirPattern] throws { LirAtomEntryNotFound } do
  return lir_extract_field_pats_go(fields, acc: [])
end

let lir_extract_field_pats_go = fn (fields: [MirPatternField], acc: [MirPattern]) -> [MirPattern] throws { LirAtomEntryNotFound } do
  match fields do
    | [] -> return rev_mir_patterns(lst: acc, out: [])
    | MirPatternField(name: _, pattern: p) :: rest -> return lir_extract_field_pats_go(fields: rest, acc: p :: acc)
  end
end


let lir_build_lit_switch = fn (rows: [PatRow], col: i64, col_ids: [i64],
    next_id: i64, enum_defs: VariantIndex) -> DecTreeResult throws { LirAtomEntryNotFound } do
  let scr_id = lir_id_nth(lst: col_ids, n: col)
  let lits = lir_collect_lits(rows, col)
  let new_col_ids = lir_append_ids(a: lir_ids_take(lst: col_ids, n: col),
                                    b: lir_ids_drop(lst: col_ids, n: col + 1))
  match lir_build_lit_branches(lits, rows, col, col_ids,
      new_col_ids, next_id, enum_defs) do | LitBranchesResult(branches, next_id: nid2) ->
    let default_rows = lir_default_matrix(rows, col, col_ids)
    match lir_build_decision_tree(rows: default_rows, col_ids: new_col_ids, next_id: nid2, enum_defs) do | DecTreeResult(tree: fb, next_id: nid3) ->
      return DecTreeResult(tree: DecLitSwitch(scrutinee_id: scr_id, branches, fallback: fb), next_id: nid3)
    end
  end
end

let lir_build_lit_branches = fn (lits: [Literal], rows: [PatRow], col: i64,
    col_ids: [i64], new_col_ids: [i64], next_id: i64, enum_defs: VariantIndex) -> LitBranchesResult throws { LirAtomEntryNotFound } do
  return lir_build_lit_branches_go(lits, rows, col,
    col_ids, new_col_ids, next_id, enum_defs, acc: [])
end

let lir_build_lit_branches_go = fn (lits: [Literal], rows: [PatRow], col: i64,
    col_ids: [i64], new_col_ids: [i64], next_id: i64, enum_defs: VariantIndex, acc: [LitBranch]) -> LitBranchesResult throws { LirAtomEntryNotFound } do
  match lits do
    | [] -> return LitBranchesResult(branches: lir_reverse_lit_branches(lst: acc, acc: []), next_id)
    | l :: rest_lits ->
      let spec_rows = lir_specialize_literal(rows, col, col_ids, lit: l)
      match lir_build_decision_tree(rows: spec_rows, col_ids: new_col_ids, next_id, enum_defs) do | DecTreeResult(tree: subtree, next_id: nid2) ->
        return lir_build_lit_branches_go(lits: rest_lits, rows, col, col_ids,
          new_col_ids, next_id: nid2, enum_defs,
          acc: LitBranch(lit: l, subtree) :: acc)
      end
  end
end

let lir_specialize_literal = fn (rows: [PatRow], col: i64, col_ids: [i64], lit: Literal) -> [PatRow] throws { LirAtomEntryNotFound } do
  return lir_specialize_literal_go(rows, col, col_ids, lit, acc: [])
end

let lir_specialize_literal_go = fn (rows: [PatRow], col: i64, col_ids: [i64], lit: Literal, acc: [PatRow]) -> [PatRow] throws { LirAtomEntryNotFound } do
  match rows do
    | [] -> return list.reverse(xs: acc)
    | PatRow(pats, case_idx: ci, bindings: bs) :: rest ->
      let pat = lir_list_nth_pat(lst: pats, n: col)
      match pat do
        | MirPatLiteral(lit: l) ->
          if lir_lit_eq(a: l, b: lit) then
            let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                            b: lir_list_drop(lst: pats, n: col + 1))
            return lir_specialize_literal_go(rows: rest, col, col_ids, lit,
              acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
          else
            return lir_specialize_literal_go(rows: rest, col, col_ids, lit, acc)
          end
        | MirPatWildcard ->
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_list_drop(lst: pats, n: col + 1))
          return lir_specialize_literal_go(rows: rest, col, col_ids, lit,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
        | MirPatVariable(name: vn, sigil: _) ->
          let scr_id = lir_id_nth(lst: col_ids, n: col)
          let new_bs = PatBinding(name: vn, scrutinee_id: scr_id) :: bs
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_list_drop(lst: pats, n: col + 1))
          return lir_specialize_literal_go(rows: rest, col, col_ids, lit,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: new_bs) :: acc)
        | _ -> return lir_specialize_literal_go(rows: rest, col, col_ids, lit, acc)
      end
  end
end


let lir_build_record_destructure = fn (rows: [PatRow], col: i64, col_ids: [i64],
    field_names: [string], next_id: i64, enum_defs: VariantIndex) -> DecTreeResult throws { LirAtomEntryNotFound } do
  let scr_id = lir_id_nth(lst: col_ids, n: col)
  let k = lir_strings_length(lst: field_names)
  let field_ids = lir_alloc_ids(n: k, next_id)
  let nid2 = next_id + k
  let new_col_ids = lir_append_ids(a: lir_ids_take(lst: col_ids, n: col),
                      b: lir_append_ids(a: field_ids, b: lir_ids_drop(lst: col_ids, n: col + 1)))
  let spec_rows = lir_specialize_record(rows, col, col_ids,
                                          field_names, k)
  match lir_build_decision_tree(rows: spec_rows, col_ids: new_col_ids, next_id: nid2, enum_defs) do | DecTreeResult(tree: subtree, next_id: nid3) ->
    return DecTreeResult(tree: DecRecordDestructure(scrutinee_id: scr_id, field_names,
                                                      field_ids, subtree), next_id: nid3)
  end
end

let lir_strings_length = fn (lst: [string]) -> i64 throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return 0
    | _ :: rest -> return 1 + lir_strings_length(lst: rest)
  end
end

let lir_specialize_record = fn (rows: [PatRow], col: i64, col_ids: [i64],
    field_names: [string], k: i64) -> [PatRow] throws { LirAtomEntryNotFound } do
  return lir_specialize_record_go(rows, col, col_ids,
    field_names, k, acc: [])
end

let lir_specialize_record_go = fn (rows: [PatRow], col: i64, col_ids: [i64],
    field_names: [string], k: i64, acc: [PatRow]) -> [PatRow] throws { LirAtomEntryNotFound } do
  match rows do
    | [] -> return list.reverse(xs: acc)
    | PatRow(pats, case_idx: ci, bindings: bs) :: rest ->
      let pat = lir_list_nth_pat(lst: pats, n: col)
      match pat do
        | MirPatRecord(fields, is_partial: _) ->
          let sub_pats = lir_expand_record_fields(fields, field_names, k)
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_append_pats(a: sub_pats, b: lir_list_drop(lst: pats, n: col + 1)))
          return lir_specialize_record_go(rows: rest, col, col_ids,
            field_names, k,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
        | MirPatWildcard ->
          let wild_pats = lir_repeat_wildcard(n: k)
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_append_pats(a: wild_pats, b: lir_list_drop(lst: pats, n: col + 1)))
          return lir_specialize_record_go(rows: rest, col, col_ids,
            field_names, k,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
        | MirPatVariable(name: vn, sigil: _) ->
          let scr_id = lir_id_nth(lst: col_ids, n: col)
          let new_bs = PatBinding(name: vn, scrutinee_id: scr_id) :: bs
          let wild_pats = lir_repeat_wildcard(n: k)
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_append_pats(a: wild_pats, b: lir_list_drop(lst: pats, n: col + 1)))
          return lir_specialize_record_go(rows: rest, col, col_ids,
            field_names, k,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: new_bs) :: acc)
        | _ -> return lir_specialize_record_go(rows: rest, col, col_ids,
          field_names, k, acc)
      end
  end
end

let lir_expand_record_fields = fn (fields: [MirRecordPatField], field_names: [string], k: i64) -> [MirPattern] throws { LirAtomEntryNotFound } do
  let base = lir_repeat_wildcard(n: k)
  return lir_place_record_pats(fields, base, field_names)
end

let lir_place_record_pats = fn (fields: [MirRecordPatField], base: [MirPattern], field_names: [string]) -> [MirPattern] throws { LirAtomEntryNotFound } do
  match fields do
    | [] -> return base
    | MirRecordPatField(name: n, pattern: p) :: rest ->
      let idx = lir_str_index(lst: field_names, name: n, idx: 0)
      let new_base = lir_set_nth_pat(lst: base, idx, val: p)
      return lir_place_record_pats(fields: rest, base: new_base, field_names)
  end
end


let lir_default_matrix = fn (rows: [PatRow], col: i64, col_ids: [i64]) -> [PatRow] throws { LirAtomEntryNotFound } do
  return lir_default_matrix_go(rows, col, col_ids, acc: [])
end

let lir_default_matrix_go = fn (rows: [PatRow], col: i64, col_ids: [i64], acc: [PatRow]) -> [PatRow] throws { LirAtomEntryNotFound } do
  match rows do
    | [] -> return list.reverse(xs: acc)
    | PatRow(pats, case_idx: ci, bindings: bs) :: rest ->
      let pat = lir_list_nth_pat(lst: pats, n: col)
      match pat do
        | MirPatWildcard ->
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_list_drop(lst: pats, n: col + 1))
          return lir_default_matrix_go(rows: rest, col, col_ids,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: bs) :: acc)
        | MirPatVariable(name: vn, sigil: _) ->
          let scr_id = lir_id_nth(lst: col_ids, n: col)
          let new_bs = PatBinding(name: vn, scrutinee_id: scr_id) :: bs
          let new_pats = lir_append_pats(a: lir_list_take(lst: pats, n: col),
                          b: lir_list_drop(lst: pats, n: col + 1))
          return lir_default_matrix_go(rows: rest, col, col_ids,
            acc: PatRow(pats: new_pats, case_idx: ci, bindings: new_bs) :: acc)
        | _ -> return lir_default_matrix_go(rows: rest, col, col_ids, acc)
      end
  end
end


/** Public function lir_cases_to_rows. */
export let lir_cases_to_rows = fn (cases: [MirMatchCase], idx: i64) -> [PatRow] throws { LirAtomEntryNotFound } do
  return lir_cases_to_rows_go(cases, idx, acc: [])
end

let lir_cases_to_rows_go = fn (cases: [MirMatchCase], idx: i64, acc: [PatRow]) -> [PatRow] throws { LirAtomEntryNotFound } do
  match cases do
    | [] -> return list.reverse(xs: acc)
    | MirMatchCase(pattern: p, body: _) :: rest ->
      // Expand top-level or-patterns: one match arm with `A | B` becomes
      // two PatRows (with patterns A and B) sharing the same case_idx,
      // mirroring Maranget's row-expansion treatment of or-patterns.
      // lir_or_expand_pattern returns rows in REVERSE declared order so they
      // can be prepended to acc directly — `acc` is itself in reverse order
      // until the final rev_pat_rows() flips it back.
      let new_rows_rev = lir_or_expand_pattern(pat: p, idx)
      return lir_cases_to_rows_go(cases: rest, idx: idx + 1, acc: list.concat(xs: new_rows_rev, ys: acc))
  end
end

let lir_or_expand_pattern = fn (pat: MirPattern, idx: i64) -> [PatRow] throws { LirAtomEntryNotFound } do
  if let MirPatOr(alts) = pat then
    return lir_or_expand_alts(alts, idx, acc: [])
  else
    return [PatRow(pats: [pat], case_idx: idx, bindings: [])]
  end
end

let lir_or_expand_alts = fn (alts: [MirPattern], idx: i64, acc: [PatRow]) -> [PatRow] throws { LirAtomEntryNotFound } do
  match alts do
    | [] -> return acc
    | a :: rest ->
      // Recursively flatten nested ors (defensive — parser doesn't currently produce them).
      let nested = lir_or_expand_pattern(pat: a, idx)
      return lir_or_expand_alts(alts: rest, idx, acc: list.concat(xs: nested, ys: acc))
  end
end

// ═══════════════════════════════════════════════════════════════════════════
// Pure emission helpers (shared with lir.nx)
//
// These transform decision-tree metadata into LIR statements without ever
// calling back into lir.nx's body lowering, so they sit cleanly here without
// a module cycle.
// ═══════════════════════════════════════════════════════════════════════════


/** Public type CtorCondsResult. */
export type CtorCondsResult = CtorCondsResult(ctx: LowerCtx, conds: [LirAtom])
/** Public type LitCondsResult. */
export type LitCondsResult = LitCondsResult(ctx: LowerCtx, conds: [LirAtom])
/** Public type FieldExtractResult. */
export type FieldExtractResult = FieldExtractResult(ctx: LowerCtx, atoms: [AtomEntry], field_stmts: [LirStmt])
/** Public type FieldLoopResult. */
export type FieldLoopResult = FieldLoopResult(ctx: LowerCtx, atoms: [AtomEntry])


/** Public function lir_reverse_atoms. */
export let lir_reverse_atoms = fn (lst: [LirAtom], acc: [LirAtom]) -> [LirAtom] throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return acc
    | x :: rest -> return lir_reverse_atoms(lst: rest, acc: x :: acc)
  end
end

/** Public function lir_ctors_length. */
export let lir_ctors_length = fn (lst: [CtorBranch]) -> i64 throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return 0
    | _ :: rest -> return 1 + lir_ctors_length(lst: rest)
  end
end

/** Public function lir_nth_case_body. */
export let lir_nth_case_body = fn (cases: [MirMatchCase], idx: i64) -> [MirStmt] throws { LirAtomEntryNotFound } do
  match cases do
    | [] -> return []
    | MirMatchCase(pattern: _, body: b) :: rest ->
      if idx == 0 then return b
      else return lir_nth_case_body(cases: rest, idx: idx - 1)
      end
  end
end

let lir_nth_string = fn (lst: [string], n: i64) -> string throws { LirAtomEntryNotFound } do
  match lst do
    | [] -> return ""
    | x :: rest ->
      if n == 0 then return x
      else return lir_nth_string(lst: rest, n: n - 1)
      end
  end
end

// Map definition-order field index to memory (sorted) index for built-in constructors.
// Cons(v, rest): sorted [rest(0), v(1)] → def 0(v)→mem 1, def 1(rest)→mem 0.
// Some(val): only 1 field, no reordering.
let lir_builtin_field_mem_idx = fn (ctor_name: string, def_idx: i64) -> i64 throws { LirAtomEntryNotFound } do
  if ctor_name == "Cons" then
    if def_idx == 0 then return 1 else return 0 end
  end
  return def_idx
end


let sorted_field_index = fn (field_name: string, all_names: [string]) -> i64 throws { LirAtomEntryNotFound } do
  match all_names do
    | [] -> return 0
    | n :: rest ->
      if lir_str_less_than(a: n, b: field_name) then
        return 1 + sorted_field_index(field_name, all_names: rest)
      else
        return sorted_field_index(field_name, all_names: rest)
      end
  end
end

let lookup_variant_field_type = fn (fields: [VariantField], name: string) -> TypeExpr throws { LirAtomEntryNotFound } do
  match fields do
    | [] -> return TyI64
    | VariantField(name: Some(val: n), typ: t) :: rest ->
      if n == name then return t
      else return lookup_variant_field_type(fields: rest, name)
      end
    | VariantField(name: None, typ: _) :: rest ->
      return lookup_variant_field_type(fields: rest, name)
  end
end

let constructor_field_type = fn (field_name: string, ctor_name: string, enum_defs: VariantIndex) -> TypeExpr throws { LirAtomEntryNotFound } do
  match lookup_variant_def(name: ctor_name, enum_defs) do
    | Some(val: VariantDef(name: _, fields: fs)) ->
      return lookup_variant_field_type(fields: fs, name: field_name)
    | None -> return TyI64
  end
end

let constructor_field_heap_index = fn (field_name: string, ctor_name: string, enum_defs: VariantIndex) -> i64 throws { LirAtomEntryNotFound } do
  match lookup_variant_def(name: ctor_name, enum_defs) do
    | Some(val: vd) ->
      let all_names = get_variant_field_names(vd)
      return sorted_field_index(field_name, all_names)
    | None -> return 0
  end
end

let lir_record_field_type = fn (sem: TypeExpr, name: string) -> TypeExpr throws { LirAtomEntryNotFound } do
  if let TyRecord(fields) = sem then
    return lir_find_named_type(fields, name)
  else
    return TyI64
  end
end

let lir_find_named_type = fn (fields: [NamedType], name: string) -> TypeExpr throws { LirAtomEntryNotFound } do
  match fields do
    | [] -> return TyI64
    | NamedType(name: fn_, typ: ft) :: rest ->
      if fn_ == name then return ft
      else return lir_find_named_type(fields: rest, name)
      end
  end
end

let lir_record_sorted_idx = fn (sem: TypeExpr, name: string) -> i64 throws { LirAtomEntryNotFound } do
  if let TyRecord(fields) = sem then
    let names = lir_extract_named_type_names(fields)
    let sorted = lir_sort_strings(lst: names)
    return lir_str_index(lst: sorted, name, idx: 0)
  else
    return 0
  end
end

let lir_extract_named_type_names = fn (fields: [NamedType]) -> [string] throws { LirAtomEntryNotFound } do
  return lir_extract_named_type_names_go(fields, acc: [])
end

let lir_extract_named_type_names_go = fn (fields: [NamedType], acc: [string]) -> [string] throws { LirAtomEntryNotFound } do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: n, typ: _) :: rest -> return lir_extract_named_type_names_go(fields: rest, acc: n :: acc)
  end
end


/** Public function lir_emit_bindings. */
export let lir_emit_bindings = fn (bindings: [PatBinding], atoms: [AtomEntry], ctx: LowerCtx) -> LowerCtx throws { LirAtomEntryNotFound } do
  match bindings do
    | [] -> return ctx
    | PatBinding(name: n, scrutinee_id: sid) :: rest ->
      match lookup_atom_entry(id: sid, atoms) do | AtomEntry(id: _, atom: a, sem_type: st) ->
        match ctx do | LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
          let typ = atom_type(atom: a)
          let ctx2 = LowerCtx(
            vars: insert_type(name: n, typ, entries: v),
            semantic_vars: insert_type(name: n, typ: st, entries: sv),
            stmts: LirStmtLet(name: n, typ, expr: LirExprAtom(atom: a)) :: s,
            temp_counter: c, enum_defs: ed
          )
          return lir_emit_bindings(bindings: rest, atoms, ctx: ctx2)
        end
      end
  end
end


/** Public function lir_extract_ctor_fields. */
export let lir_extract_ctor_fields = fn (scr_atom: LirAtom, scr_sem: TypeExpr, ctor_name: string,
    arity: i64, field_ids: [i64], atoms: [AtomEntry], ctx: LowerCtx) -> FieldExtractResult throws { LirAtomEntryNotFound } do
  match ctx do | LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let work_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lir_extract_fields_loop(scr_atom, scr_sem, ctor_name,
        field_ids, idx: 0, arity, atoms, ctx: work_ctx,
        enum_defs: ed) do | FieldLoopResult(ctx: ctx2, atoms: atoms2) ->
      match ctx2 do | LowerCtx(vars: _, semantic_vars: _, stmts: field_stmts, temp_counter: c2, enum_defs: _) ->
        let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
        return FieldExtractResult(ctx: restored, atoms: atoms2, field_stmts: list.reverse(xs: field_stmts))
      end
    end
  end
end

let lir_extract_fields_loop = fn (scr_atom: LirAtom, scr_sem: TypeExpr, ctor_name: string,
    field_ids: [i64], idx: i64, arity: i64, atoms: [AtomEntry], ctx: LowerCtx,
    enum_defs: VariantIndex) -> FieldLoopResult throws { LirAtomEntryNotFound } do
  if idx >= arity then return FieldLoopResult(ctx, atoms) end
  let fid = lir_id_nth(lst: field_ids, n: idx)
  match lookup_variant_def(name: ctor_name, enum_defs) do
    | Some(val: vd) ->
      let names = get_variant_field_names(vd)
      let field_name = lir_nth_string(lst: names, n: idx)
      let heap_idx = constructor_field_heap_index(field_name, ctor_name, enum_defs)
      let sem_ft = constructor_field_type(field_name, ctor_name, enum_defs)
      let wasm_ft = wasm_type(typ: sem_ft)
      match bind_expr_to_temp_semantic(ctx,
        expr: LirExprObjectField(value: scr_atom, index: heap_idx, typ: wasm_ft),
        typ: wasm_ft, semantic_type: sem_ft) do | BindResult(ctx: ctx2, atom: field_atom) ->
        let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: sem_ft) :: atoms
        return lir_extract_fields_loop(scr_atom, scr_sem, ctor_name,
          field_ids, idx: idx + 1, arity, atoms: new_atoms, ctx: ctx2,
          enum_defs)
      end
    | None ->
      // Built-in constructor — alphabetical field sort for memory layout.
      let mem_idx = lir_builtin_field_mem_idx(ctor_name, def_idx: idx)
      match bind_expr_to_temp(ctx,
        expr: LirExprObjectField(value: scr_atom, index: mem_idx, typ: TyI64),
        typ: TyI64) do | BindResult(ctx: ctx2, atom: field_atom) ->
        let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: TyI64) :: atoms
        return lir_extract_fields_loop(scr_atom, scr_sem, ctor_name,
          field_ids, idx: idx + 1, arity, atoms: new_atoms, ctx: ctx2,
          enum_defs)
      end
  end
end

/** Public function lir_extract_record_fields. */
export let lir_extract_record_fields = fn (scr_atom: LirAtom, scr_sem: TypeExpr,
    field_names: [string], field_ids: [i64], atoms: [AtomEntry], ctx: LowerCtx) -> FieldExtractResult throws { LirAtomEntryNotFound } do
  match ctx do | LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let work_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lir_extract_record_loop(scr_atom, scr_sem,
        field_names, field_ids, atoms, ctx: work_ctx) do | FieldLoopResult(ctx: ctx2, atoms: atoms2) ->
      match ctx2 do | LowerCtx(vars: _, semantic_vars: _, stmts: field_stmts, temp_counter: c2, enum_defs: _) ->
        let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
        return FieldExtractResult(ctx: restored, atoms: atoms2, field_stmts: list.reverse(xs: field_stmts))
      end
    end
  end
end

let lir_extract_record_loop = fn (scr_atom: LirAtom, scr_sem: TypeExpr,
    field_names: [string], field_ids: [i64], atoms: [AtomEntry], ctx: LowerCtx) -> FieldLoopResult throws { LirAtomEntryNotFound } do
  match field_names do
    | [] -> return FieldLoopResult(ctx, atoms)
    | fn_ :: rest_names ->
      match field_ids do
        | [] -> return FieldLoopResult(ctx, atoms)
        | fid :: rest_ids ->
        let field_type = lir_record_field_type(sem: scr_sem, name: fn_)
        let sorted_idx = lir_record_sorted_idx(sem: scr_sem, name: fn_)
        let wasm_ft = wasm_type(typ: field_type)
        match bind_expr_to_temp_semantic(ctx,
          expr: LirExprObjectField(value: scr_atom, index: sorted_idx, typ: wasm_ft),
          typ: wasm_ft, semantic_type: field_type) do | BindResult(ctx: ctx2, atom: field_atom) ->
          let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: field_type) :: atoms
          return lir_extract_record_loop(scr_atom, scr_sem,
            field_names: rest_names, field_ids: rest_ids, atoms: new_atoms, ctx: ctx2)
        end
      end
  end
end


/** Public function lir_emit_ctor_conds. */
export let lir_emit_ctor_conds = fn (branches: [CtorBranch], tag_atom: LirAtom, has_fb: bool, pos: i64, total: i64, ctx: LowerCtx) -> CtorCondsResult throws { LirAtomEntryNotFound } do
  return lir_emit_ctor_conds_go(branches, tag_atom, has_fb, pos, total, ctx, acc: [])
end

let lir_emit_ctor_conds_go = fn (branches: [CtorBranch], tag_atom: LirAtom, has_fb: bool, pos: i64, total: i64, ctx: LowerCtx, acc: [LirAtom]) -> CtorCondsResult throws { LirAtomEntryNotFound } do
  match branches do
    | [] -> return CtorCondsResult(ctx, conds: lir_reverse_atoms(lst: acc, acc: []))
    | CtorBranch(ctor_name: _, ctor_tag: tag, arity: _, field_ids: _, subtree: _) :: rest ->
      let is_last_no_fb = (pos == total - 1) && !has_fb
      if is_last_no_fb then
        return lir_emit_ctor_conds_go(branches: rest, tag_atom, has_fb, pos: pos + 1, total, ctx, acc: LirAtomBool(val: true) :: acc)
      else
        match bind_expr_to_temp(ctx,
          expr: LirExprBinary(op: OpEq, lhs: tag_atom, rhs: LirAtomInt(val: tag), typ: TyBool),
          typ: TyBool) do | BindResult(ctx: ctx2, atom: cond) ->
          return lir_emit_ctor_conds_go(branches: rest, tag_atom, has_fb, pos: pos + 1, total, ctx: ctx2, acc: cond :: acc)
        end
      end
  end
end

/** Public function lir_emit_lit_conds. */
export let lir_emit_lit_conds = fn (branches: [LitBranch], scr_atom: LirAtom, ctx: LowerCtx) -> LitCondsResult throws { LirAtomEntryNotFound } do
  return lir_emit_lit_conds_go(branches, scr_atom, ctx, acc: [])
end

let lir_emit_lit_conds_go = fn (branches: [LitBranch], scr_atom: LirAtom, ctx: LowerCtx, acc: [LirAtom]) -> LitCondsResult throws { LirAtomEntryNotFound } do
  match branches do
    | [] -> return LitCondsResult(ctx, conds: lir_reverse_atoms(lst: acc, acc: []))
    | LitBranch(lit: l, subtree: _) :: rest ->
      let lit_atom = literal_to_atom(lit: l)
      match bind_expr_to_temp(ctx,
        expr: LirExprBinary(op: OpEq, lhs: scr_atom, rhs: lit_atom, typ: TyBool),
        typ: TyBool) do | BindResult(ctx: ctx2, atom: cond) ->
        return lir_emit_lit_conds_go(branches: rest, scr_atom, ctx: ctx2, acc: cond :: acc)
      end
  end
end
