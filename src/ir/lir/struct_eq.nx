/**
 * struct_eq: structural equality lowering for `==` / `!=` on record and sum
 * (ADT) operands.
 *
 * Per spec § T-Cmp, `comparable'` admits records (all fields comparable) and
 * named sum types (unfold + all-variant-fields comparable), so `==` on them is
 * well-typed and MUST compute STRUCTURAL value equality — not the pointer
 * identity that a plain `LirExprBinary(OpEq)` on the i32 heap pointer produces.
 *
 * Strategy — GENERATED RUNTIME HELPERS. For every named aggregate type in the
 * program (each `EnumDef` and each record-alias `RecordDef`) a structural
 * compare helper `__streq_<TypeName>(l, r) -> bool` is synthesized as an extra
 * `LirFunction` and appended to the program (see `gen_struct_eq_helpers`,
 * called from `lower_mir_to_lir`). The helper recurses at RUN TIME:
 *   - Record  : equal iff ALL fields structurally equal (AND-fold; the record
 *               tag is fixed by construction so equal-typed records always share
 *               it — no runtime tag check needed).
 *   - Sum/ADT : equal iff same constructor tag AND all payload fields equal.
 *               Nullary constructors bottom out at tag equality; differing tags
 *               short-circuit to false. A tag check selects the per-variant
 *               payload compare via a chain of `LirStmtIf` on
 *               `tag == constructor_tag(V)`.
 *   - Aggregate (named record/sum) field : a CALL to that type's helper. A
 *               RECURSIVE field position (e.g. `Node.left: Tree`) is just a call
 *               to the SAME helper, which terminates on finite data; a sibling
 *               field of another aggregate type calls that type's helper. Because
 *               the recursion is in the emitted wasm — not in this static
 *               expansion — self- and mutually-recursive types (Tree, Even/Odd)
 *               compare structurally with no depth limit.
 *   - Primitive / string : a single value-compare binary (`LirExprBinary(OpEq)`;
 *               codegen routes TyString operands through `emit_string_compare`
 *               via `is_string_op`). A type-parameter field (`TyVar`, e.g. the
 *               element of a generic `List<T>`) is type-erased at this stage and
 *               also bottoms out at the i64 value compare — generic element
 *               recursion is out of scope of the monomorphic helper.
 * `!=` is the negation of `==`.
 *
 * The LIR `MirBinaryOp` dispatch (lir.nx) lowers `lhs op rhs` on a NAMED
 * aggregate to a single CALL of that type's helper. An ANONYMOUS record literal
 * type (`{a, b}` with no name — never recursive, since recursion needs a name to
 * close the loop) is expanded INLINE one level, its aggregate fields still
 * routed through the generated helpers.
 *
 * Owns:
 * - gen_struct_eq_helpers (synthesizes the per-type helper LirFunctions)
 * - lower_struct_eq (entry; called from lir.nx's MirBinaryOp OpEq/OpNe case)
 * - should_struct_eq (classifier: operand type is a record / known sum)
 * - struct_eq_helper_name (the canonical helper name for a named aggregate)
 *
 * Does not own:
 * - LowerCtx / temp + stmt helpers (see src/ir/lir/context.nx)
 * - Field/tag heap layout opcodes (see src/backend/codegen.nx, wasm/defs.nx)
 * - Function injection (see src/ir/lir/func_lower.nx — appends the helpers)
 */
import { TypeExpr, TyRecord, TyUserDefined, TyBool, TyI64, TyF64, TyChar,
         TyString, TyList, TyVar, NamedType,
         EnumDef, RecordDef, VariantDef, VariantField } from "src/types/type_expr.nx"
import { Span } from "src/types/span.nx"
import { BinaryOp, OpEq, OpNe, OpAnd } from "src/types/vocab.nx"
import {
  LirAtom,
  LirAtomVar,
  LirAtomBool,
  LirAtomInt,
  LirExpr,
  LirExprAtom,
  LirExprBinary,
  LirExprCall,
  LirExprObjectField,
  LirExprObjectTag,
  LirCallArg,
  LirParam,
  LirFunction,
  LirStmt,
  LirStmtLet,
  LirStmtIf
} from "src/ir/lir/types.nx"
import {
  LowerCtx,
  TypeEntry,
  BindResult,
  bind_expr_to_temp,
  insert_type
} from "src/ir/lir/context.nx"
import { infer_semantic_type } from "src/ir/lir/semantic_types.nx"
import { LirError } from "src/ir/lir/errors.nx"
import { Some, None, Option } from "std:option"
import * as list from "std:list"
import * as str from "std:str"
import { VariantIndex }, * as vidx from "src/ir/support/variant_index.nx"
import { constructor_tag } from "src/backend/wasm/defs.nx"
import {
  MirFunction,
  MirParam,
  MirExpr,
  MirBinaryOp,
  MirCall,
  MirConstructor,
  MirRecord,
  MirArray,
  MirIndex,
  MirFieldAccess,
  MirIf,
  MirMatch,
  MirWhile,
  MirRaise,
  MirForce,
  MirMakeClosure,
  MirCallClosure,
  MirSuspend,
  MirResume,
  MirBlock,
  MirInjectValue,
  MirNamedExpr,
  MirCallArg,
  MirStmt,
  MirStmtLet,
  MirStmtExpr,
  MirStmtReturn,
  MirStmtAssign,
  MirStmtTry,
  MirMatchCase
} from "src/ir/mir/types.nx"

// ─── Helper naming ──────────────────────────────────────────────────────────

/** Canonical synthesized helper name for a named aggregate type. One helper per
 *  distinct type name; recursive / mutually-recursive references reuse the same
 *  name so the emitted wasm calls itself / its sibling. */
export let struct_eq_helper_name = fn (type_name: string) -> string do
  return "__streq_" ++ type_name
end

// Canonical key string for a list ELEMENT type. Distinct element types map to
// distinct keys (so `[i64]` and `[string]` get separate helpers); the SAME
// element type always maps to the same key, so a recursive `rest: [elem]` field
// self-calls the right helper. A type-parameter / unknown element erases to the
// generic key, whose helper bottoms out at an i64 value compare on the element
// (acceptable per the monomorphic-helper precedent — generic `List<T>` recursion
// is type-erased). The synthetic helper-bearing type name for `[elem]` is
// `List$<key(elem)>`, never collidable with a user type (`$` is not a legal
// identifier char), and shared so the helper recurses on itself.
let list_elem_key = fn (elem: TypeExpr) -> string do
  match elem do
    | TyI64 -> return "i64"
    | TyBool -> return "bool"
    | TyF64 -> return "f64"
    | TyChar -> return "char"
    | TyString -> return "string"
    | TyUserDefined(name: n, args: _) -> return n
    | TyList(elem: inner) -> return "List$" ++ list_elem_key(elem: inner)
    // An ANONYMOUS record element (`[{a, b}]`) carries no type name, so derive a
    // stable structural key from its (alphabetically sorted) field names + field
    // types. Two anon records that differ in field names OR field types get
    // distinct keys (hence distinct helpers); the SAME shape always maps to the
    // same key so a `rest: [{...}]` recursion self-calls the right helper. The
    // `$` / `_` separators are not legal identifier chars, so the synthesized
    // `List$Rec$...` name can never collide with a user type or another key.
    | TyRecord(fields: fs) -> return "Rec$" ++ anon_record_key(fields: fs)
    | _ -> return "T"
  end
end

// Stable key fragment for an anonymous record's field set: alphabetically sorted
// `name=type` pairs joined by `~` (so field order at the literal can't change the
// key, matching the alphabetical heap layout). Field types recurse through
// list_elem_key, so a nested anon-record / list field contributes structurally.
let anon_record_key = fn (fields: [ NamedType ]) -> string do
  return anon_record_key_go(fields: sort_named_fields(fields), first: true, acc: "")
end

let anon_record_key_go = fn (fields: [ NamedType ], first: bool, acc: string) -> string do
  match fields do
    | [] -> return acc
    | NamedType(name: n, typ: t) :: rest ->
      let piece = n ++ "=" ++ list_elem_key(elem: t)
      let acc2 = if first then piece else acc ++ "~" ++ piece end
      return anon_record_key_go(fields: rest, first: false, acc: acc2)
  end
end

// Sort record fields alphabetically by name (mirrors the alphabetical heap
// layout used by record extraction and `heap_index_of`).
let sort_named_fields = fn (fields: [ NamedType ]) -> [ NamedType ] do
  match fields do
    | [] -> return []
    | x :: rest -> return list.insert_sorted_by(x, xs: sort_named_fields(fields: rest), lt: fn (a: NamedType, b: NamedType) -> bool do
        let NamedType(name: an, typ: _) = a
        let NamedType(name: bn, typ: _) = b
        return an < bn
      end)
  end
end

// Synthetic helper-bearing type name for the list type `[elem]`.
let list_type_name = fn (elem: TypeExpr) -> string do
  return "List$" ++ list_elem_key(elem)
end

// ─── Per-instantiation keying (generic-enum-at-concrete payload) ────────────
//
// `list_elem_key` ERASES a generic instantiation's type arguments
// (`TyUserDefined(n, _) -> n`), so `Option<Color>` and `Option<i64>` share the
// bare `__streq_Option` / `__streq_List$Option` helper (whose type-parameter
// payload is identity-compared). `inst_key` instead PRESERVES the arguments
// (`Option<Color>` → `Option$Color`), keying the per-instantiation structural
// helper whose payload recurses into the concrete type's own compare. Used only
// on the gen-inst routing path (a `==` site or another per-inst helper body); a
// BARE helper body keeps `list_elem_key`'s erasure so a never-`==`'d type's
// concrete generic field (`VariantIndex.by_variant: Map<string, VariantInfo>`)
// routes to the bare element helper — never dragging in a per-inst closure.
let inst_key = fn (t: TypeExpr) -> string do
  match t do
    | TyI64 -> return "i64"
    | TyBool -> return "bool"
    | TyF64 -> return "f64"
    | TyChar -> return "char"
    | TyString -> return "string"
    | TyUserDefined(name: n, args: []) -> return n
    | TyUserDefined(name: n, args: ats) -> return n ++ "$" ++ inst_key_args(ats, first: true, acc: "")
    | TyList(elem: inner) -> return "List$" ++ inst_key(t: inner)
    | TyRecord(fields: fs) -> return "Rec$" ++ anon_record_key(fields: fs)
    | _ -> return "T"
  end
end

let inst_key_args = fn (ats: [ TypeExpr ], first: bool, acc: string) -> string do
  match ats do
    | [] -> return acc
    | a :: rest ->
      let piece = inst_key(t: a)
      let acc2 = if first then piece else acc ++ "$" ++ piece end
      return inst_key_args(ats: rest, first: false, acc: acc2)
  end
end

// The per-instantiation enum helper's type-name for `Enum<args>` (e.g.
// `Option$Color`). Equal to `inst_key(TyUserDefined(enum, args))` so a nested
// `Option<Option<Color>>` field and the standalone `Option<Color>` `==` site key
// the SAME `__streq_Option$Color` helper.
let enum_inst_name = fn (enum: string, args: [ TypeExpr ]) -> string do
  return inst_key(t: TyUserDefined(name: enum, args))
end

// True iff `t` is a CONCRETE generic instantiation `K<args>` with at least one
// argument and no remaining type variable (`TyVar`) — i.e. one for which a
// per-instantiation helper can be keyed. A bare `K<>` (no args), a primitive, or
// a `TyVar`-bearing shape is NOT.
let is_concrete_generic_inst = fn (t: TypeExpr) -> bool do
  match t do
    | TyUserDefined(name: _, args: []) -> return false
    | TyUserDefined(name: _, args: ats) -> return !type_list_has_tyvar(ts: ats)
    | _ -> return false
  end
end

let type_has_tyvar_se = fn (t: TypeExpr) -> bool do
  match t do
    | TyVar(name: _) -> return true
    | TyList(elem: e) -> return type_has_tyvar_se(t: e)
    | TyUserDefined(name: _, args: ats) -> return type_list_has_tyvar(ts: ats)
    | TyRecord(fields: fs) -> return named_list_has_tyvar(nts: fs)
    | _ -> return false
  end
end

let type_list_has_tyvar = fn (ts: [ TypeExpr ]) -> bool do
  match ts do
    | [] -> return false
    | t :: rest -> if type_has_tyvar_se(t) then return true else return type_list_has_tyvar(ts: rest) end
  end
end

let named_list_has_tyvar = fn (nts: [ NamedType ]) -> bool do
  match nts do
    | [] -> return false
    | NamedType(name: _, typ: t) :: rest -> if type_has_tyvar_se(t) then return true else return named_list_has_tyvar(nts: rest) end
  end
end

// The monomorphized `Cons`/`Nil` variant defs for `[elem]`, matching the
// built-in `List` layout (`Cons(v: elem, rest: [elem])`, `Nil`). Drives the
// list helper body's structural compare: the `v` field recurses on `elem`
// (string→string compare, record→its helper, list→its helper); the `rest`
// field recurses on `[elem]` → a self-call of this list's helper.
let list_variant_defs = fn (elem: TypeExpr) -> [ VariantDef ] do
  return [
    VariantDef(name: "Nil", fields: []),
    VariantDef(name: "Cons", fields: [
      VariantField(name: Some(val: "v"), typ: elem),
      VariantField(name: Some(val: "rest"), typ: TyList(elem)) ]) ]
end

// ─── Operand-type classification ────────────────────────────────────────────

let resolve_operand_type = fn (t: TypeExpr, ctx: LowerCtx) -> TypeExpr do
  // A named type may be a record alias (resolve to its TyRecord body) or a sum
  // (kept as TyUserDefined so the sum path can enumerate variants). Records
  // already arrive as TyRecord.
  let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed) = ctx
  match t do
    | TyUserDefined(name: _, args: _) -> return vidx.resolve_record_alias(idx: ed, typ: t)
    | _ -> return t
  end
end

/** True iff `op` is an equality operator (`==` / `!=`) — the only ops with a
 *  structural variant. Ordering comparisons (`<`, `<=`, …) are out of scope. */
export let is_struct_eq_op = fn (op: BinaryOp) -> bool do
  match op do
    | OpEq | OpNe -> return true
    | _ -> return false
  end
end

/** Pick the better structural-compare type from a `==`/`!=` site's two operand
 *  semantic types. When BOTH name the same generic enum but only ONE carries the
 *  concrete instantiation (`a: Option<Color>` vs an erased `b: Option<>` coming
 *  from a bare `None` / a TyI64-defaulted value), prefer the CONCRETE side so the
 *  site routes to the per-instantiation structural helper rather than the
 *  type-erased bare one (which would identity-compare a sum/record payload).
 *  Otherwise keep the existing left-biased "first that needs a structural
 *  compare" choice. */
export let pick_struct_sem = fn (a: TypeExpr, b: TypeExpr, ctx: LowerCtx) -> TypeExpr do
  let a_ok = should_struct_eq(t: a, ctx)
  let b_ok = should_struct_eq(t: b, ctx)
  // If exactly one side is structural, that side is the only choice.
  if a_ok && !b_ok then return a end
  if b_ok && !a_ok then return b end
  // Both structural: prefer a concrete generic instantiation over an erased one.
  if is_concrete_generic_inst(t: a) && !is_concrete_generic_inst(t: b) then return a end
  if is_concrete_generic_inst(t: b) && !is_concrete_generic_inst(t: a) then return b end
  // Neither (or both) concrete: keep the prior left-biased choice.
  if a_ok then return a else return b end
end

/** True iff `==`/`!=` on an operand of semantic type `t` needs a structural
 *  compare: `t` resolves to a record, or to a named sum with known variants.
 *  Primitives / strings / unknown (TyI64-erased) types return false and keep
 *  the legacy value/identity binary path. */
export let should_struct_eq = fn (t: TypeExpr, ctx: LowerCtx) -> bool do
  match resolve_operand_type(t, ctx) do
    | TyRecord(fields: _) -> return true
    // A `[elem]` list compares structurally (same length AND element-wise equal)
    // via a generated runtime helper, NOT the heap-pointer identity the legacy
    // binary path produces. Element structurality is preserved through the
    // helper keyed on `elem` (strings/records/nested lists recurse correctly).
    | TyList(elem: _) -> return true
    | TyUserDefined(name: en, args: _) ->
      let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed) = ctx
      match vidx.variants_of_enum(idx: ed, enum_name: en) do
        | [] -> return false
        | _ -> return true
      end
    | _ -> return false
  end
end

// `named_aggregate_name`: the helper-bearing type name of `t`, if `t` is a named
// sum (TyUserDefined with known variants) or a named record alias (TyUserDefined
// resolving to a TyRecord body). Anonymous TyRecord carries no name → None.

// True iff `elem`'s specific list helper (`__streq_List$<key(elem)>`) is among
// the generated set, so `[elem]` can route to it (preserving element
// structurality). Mirrors gen_struct_eq_helpers' coverage: primitives, named
// aggregates with in-scope structure, and ONE level of list-of-those. Anything
// else (deeper bare nesting, type vars, opaque enums) is uncovered and routes to
// the generic `__streq_List$T` helper, whose element compare is the i64 value
// compare (type-erased precedent).
let list_elem_covered = fn (elem: TypeExpr, ctx: LowerCtx) -> bool do
  match elem do
    | TyI64 | TyString | TyBool | TyF64 | TyChar -> return true
    // An ANONYMOUS record element (`[{a, b}]`) gets a structural list helper
    // whose head compare expands the record inline (compare_record). Always
    // covered — the helper is synthesized from the anon-record element types
    // harvested out of the MIR (see harvest_mir_anon_record_lists).
    | TyRecord(fields: _) -> return true
    | TyUserDefined(name: _, args: _) ->
      match resolve_operand_type(t: elem, ctx) do
        | TyRecord(fields: _) -> return true
        | TyUserDefined(name: en, args: _) ->
          let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed) = ctx
          match vidx.variants_of_enum(idx: ed, enum_name: en) do
            | [] -> return false
            | _ -> return true
          end
        | _ -> return false
      end
    // One nesting level: `[[prim]]` / `[[aggregate]]` / `[[{...}]]` are
    // generated; deeper not.
    | TyList(elem: inner) ->
      match inner do
        | TyI64 | TyString | TyBool | TyF64 | TyChar -> return true
        | TyRecord(fields: _) -> return list_elem_covered(elem: inner, ctx)
        | TyUserDefined(name: _, args: _) -> return list_elem_covered(elem: inner, ctx)
        | _ -> return false
      end
    | _ -> return false
  end
end

// Helper-bearing type name for a `[elem]` compare site: the specific element
// helper when covered, else the generic `List$T` fallback. The recursive `rest`
// field inside a helper resolves through this same routing on the SAME element
// type, so it self-calls the right helper consistently.
//
// `gen_inst` selects the element KEY: on the gen-inst path (a `==` site / a
// per-instantiation helper body) a concrete generic element `Option<Color>` keys
// the per-instantiation list helper `List$Option$Color` (whose `v` recurses into
// `__streq_Option$Color`); a BARE helper body (`gen_inst = false`) erases the
// element's args so `[Option<i64>]` routes to the bare `List$Option` (today's
// type-erased behavior). The worklist guarantees every `gen_inst`-keyed list
// helper is actually synthesized.
let list_site_type_name = fn (elem: TypeExpr, gen_inst: bool, ctx: LowerCtx) -> string do
  if list_elem_covered(elem, ctx) then
    if gen_inst then return "List$" ++ inst_key(t: elem) else return list_type_name(elem) end
  else return list_type_name(elem: TyVar(name: "T"))
  end
end

// `named_aggregate_name`: the helper-bearing type name of `t`. On the `gen_inst`
// path a concrete generic-enum instantiation `Enum<args>` routes to its
// per-instantiation helper `Enum$args` (structural payload compare); off it
// (a bare helper body) the args are erased to the bare `Enum` so a never-`==`'d
// type's concrete generic field never requests an un-generated per-inst helper.
let named_aggregate_name = fn (t: TypeExpr, gen_inst: bool, ctx: LowerCtx) -> Option<string> do
  match t do
    // `[elem]` routes to the per-element-type generated list helper. Returning a
    // name here makes `compare_values` emit a CALL (not an inline expansion), so
    // the recursive `rest` field terminates at run time like recursive sums do.
    | TyList(elem: et) -> return Some(val: list_site_type_name(elem: et, gen_inst, ctx))
    | TyUserDefined(name: n, args: _) ->
      // Either a record alias or a sum with known variants gets a helper.
      match resolve_operand_type(t, ctx) do
        | TyRecord(fields: _) -> return Some(val: n)
        | TyUserDefined(name: en, args: _) ->
          let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed) = ctx
          match vidx.variants_of_enum(idx: ed, enum_name: en) do
            | [] -> return None
            | _ ->
              // Per-instantiation helper on the gen-inst path for a concrete
              // generic enum; bare helper otherwise.
              if gen_inst && is_concrete_generic_inst(t) then return Some(val: enum_inst_name(enum: en, args: inst_args_of(t)))
              else return Some(val: en) end
          end
        | _ -> return None
      end
    | _ -> return None
  end
end

let inst_args_of = fn (t: TypeExpr) -> [ TypeExpr ] do
  match t do
    | TyUserDefined(name: _, args: ats) -> return ats
    | _ -> return []
  end
end

// ─── Field-name layout (alphabetical, mirrors HIR sort_ctor_args / record sort)

let sort_names = fn (ns: [ string ]) -> [ string ] do
  match ns do
    | [] -> return []
    | x :: rest -> return list.insert_sorted_by(x, xs: sort_names(ns: rest), lt: fn (a: string, b: string) -> bool do return a < b end)
  end
end

// Alphabetical heap index of `name` among `all_names` (the field's position once
// the field-name set is sorted). Matches constructor_field_heap_index /
// sorted_named_type_index used everywhere else.
let heap_index_of = fn (name: string, all_names: [ string ]) -> i64 do
  return heap_index_go(name, sorted: sort_names(ns: all_names), idx: 0)
end

let heap_index_go = fn (name: string, sorted: [ string ], idx: i64) -> i64 do
  match sorted do
    | [] -> return idx
    | h :: rest ->
      if h == name then return idx
      else return heap_index_go(name, sorted: rest, idx: idx + 1)
      end
  end
end

// ─── Per-field load + recursive compare ─────────────────────────────────────

type CmpResult = CmpResult(ctx: LowerCtx, atom: LirAtom)

// Load `parent.field[heap_idx]` (object field at alphabetical index) for both
// operands and compare them structurally. `gen_inst` is forwarded so a concrete
// generic-enum field routes to its per-instantiation helper on the gen-inst path
// (a `==` site / per-inst helper body) and to the bare/erased helper otherwise.
let compare_field = fn (
  lhs_parent: LirAtom,
  rhs_parent: LirAtom,
  heap_idx: i64,
  field_type: TypeExpr,
  gen_inst: bool,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  // wasm slot type for the field load: strings flow as i64 packed handles but
  // must be TYPED TyString so the recursive compare routes through the string
  // path (codegen is_string_op trusts atom_type == TyString). Aggregates and
  // primitives load as i64.
  let load_wt = match resolve_operand_type(t: field_type, ctx) do
    | TyString -> TyString
    | _ -> TyI64
  end
  let BindResult(ctx: ctx1, atom: l_field) = bind_expr_to_temp(
    ctx,
    expr: LirExprObjectField(value: lhs_parent, index: heap_idx, typ: load_wt),
    typ: load_wt
  )
  let BindResult(ctx: ctx2, atom: r_field) = bind_expr_to_temp(
    ctx: ctx1,
    expr: LirExprObjectField(value: rhs_parent, index: heap_idx, typ: load_wt),
    typ: load_wt
  )
  return compare_values(l: l_field, r: r_field, sem_type: field_type, gen_inst, ctx: ctx2)
end

// Compare two already-loaded operand atoms of semantic type `sem_type`,
// emitting whatever statements the comparison needs and yielding a bool atom.
//
// A NAMED aggregate (sum / record alias) routes to a CALL of that type's
// generated helper — including recursive positions, which terminate at run time.
// An ANONYMOUS record is expanded inline one level (its aggregate fields recurse
// through their helpers). Everything else is a single value compare. `gen_inst`
// selects per-instantiation vs bare/erased routing for a concrete generic enum
// (see `named_aggregate_name`).
let compare_values = fn (
  l: LirAtom,
  r: LirAtom,
  sem_type: TypeExpr,
  gen_inst: bool,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  match named_aggregate_name(t: sem_type, gen_inst, ctx) do
    | Some(val: nm) -> return call_helper(l, r, type_name: nm, ctx)
    | None ->
      match resolve_operand_type(t: sem_type, ctx) do
        | TyRecord(fields: fs) -> return compare_record(l, r, fields: fs, gen_inst, ctx)
        | _ -> return compare_primitive(l, r, ctx)
      end
  end
end

// Emit `__streq_<type_name>(l, r)` and bind the bool result. The args are
// emitted in sorted-param order (labels "l" < "r") so the positional
// internal-call ABI lines up with the helper's sorted params.
let call_helper = fn (
  l: LirAtom,
  r: LirAtom,
  type_name: string,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  let BindResult(ctx: ctx1, atom) = bind_expr_to_temp(
    ctx,
    expr: LirExprCall(
      func: struct_eq_helper_name(type_name),
      args: [ LirCallArg(label: "l", value: l), LirCallArg(label: "r", value: r) ],
      typ: TyBool
    ),
    typ: TyBool
  )
  return CmpResult(ctx: ctx1, atom)
end

// Primitive / string / type-param / opaque: a single value-compare binary.
// TyString operands route to emit_string_compare in codegen; everything else to
// i32/i64 eq.
let compare_primitive = fn (
  l: LirAtom,
  r: LirAtom,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  let BindResult(ctx: ctx1, atom) = bind_expr_to_temp(
    ctx,
    expr: LirExprBinary(op: OpEq, lhs: l, rhs: r, typ: TyBool),
    typ: TyBool
  )
  return CmpResult(ctx: ctx1, atom)
end

// ─── Record compare: AND-fold field comparisons ────────────────────────────

let record_field_names = fn (fields: [ NamedType ], acc: [ string ]) -> [ string ] do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: n, typ: _) :: rest -> return record_field_names(fields: rest, acc: n :: acc)
  end
end

let compare_record = fn (
  l: LirAtom,
  r: LirAtom,
  fields: [ NamedType ],
  gen_inst: bool,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  let all_names = record_field_names(fields, acc: [])
  return compare_record_go(l, r, fields, all_names, acc: None, gen_inst, ctx)
end

let compare_record_go = fn (
  l: LirAtom,
  r: LirAtom,
  fields: [ NamedType ],
  all_names: [ string ],
  acc: Option<LirAtom>,
  gen_inst: bool,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  match fields do
    | [] ->
      match acc do
        | Some(val: a) -> return CmpResult(ctx, atom: a)
        // Empty record: structurally equal unconditionally.
        | None -> return CmpResult(ctx, atom: LirAtomBool(val: true))
      end
    | NamedType(name: fname, typ: ftyp) :: rest ->
      let heap_idx = heap_index_of(name: fname, all_names)
      let CmpResult(ctx: ctx1, atom: feq) = compare_field(
        lhs_parent: l, rhs_parent: r, heap_idx, field_type: ftyp, gen_inst, ctx
      )
      let next_acc = match acc do
        | None -> CmpResult(ctx: ctx1, atom: feq)
        | Some(val: prev) ->
          let BindResult(ctx: ctx2, atom: anded) = bind_expr_to_temp(
            ctx: ctx1,
            expr: LirExprBinary(op: OpAnd, lhs: prev, rhs: feq, typ: TyBool),
            typ: TyBool
          )
          CmpResult(ctx: ctx2, atom: anded)
      end
      let CmpResult(ctx: ctx3, atom: acc_atom) = next_acc
      return compare_record_go(l, r, fields: rest, all_names, acc: Some(val: acc_atom), gen_inst, ctx: ctx3)
  end
end

// ─── Sum compare: tag check then per-variant payload dispatch ───────────────

let variant_field_name = fn (vf: VariantField, pos_from_end: i64) -> string do
  let VariantField(name: n_opt, typ: _) = vf
  match n_opt do
    | Some(val: n) -> return n
    | None -> return str.from_i64(val: pos_from_end)
  end
end

let count_fields = fn (fs: [ VariantField ]) -> i64 do
  match fs do
    | [] -> return 0
    | _ :: rest -> return 1 + count_fields(fs: rest)
  end
end

// Build the (alphabetical) field-name list for a variant, matching
// get_variant_field_names in match_tree/emit.nx (positional fields named by
// their position-from-end).
let variant_field_names = fn (fs: [ VariantField ], acc: [ string ]) -> [ string ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | vf :: rest ->
      let nm = variant_field_name(vf, pos_from_end: count_fields(fs: rest))
      return variant_field_names(fs: rest, acc: nm :: acc)
  end
end

let arity_of = fn (vd: VariantDef) -> i64 do
  let VariantDef(name: _, fields: fs) = vd
  return count_fields(fs)
end

// Compare the payload fields of ONE variant (both operands already known to
// carry this variant's tag). AND-folds per-field comparisons; nullary → true.
let compare_variant_payload = fn (
  l: LirAtom,
  r: LirAtom,
  vd: VariantDef,
  gen_inst: bool,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  let VariantDef(name: _, fields: fs) = vd
  let all_names = variant_field_names(fs, acc: [])
  return compare_variant_fields_go(l, r, fields: fs, all_names, acc: None, gen_inst, ctx)
end

let compare_variant_fields_go = fn (
  l: LirAtom,
  r: LirAtom,
  fields: [ VariantField ],
  all_names: [ string ],
  acc: Option<LirAtom>,
  gen_inst: bool,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  match fields do
    | [] ->
      match acc do
        | Some(val: a) -> return CmpResult(ctx, atom: a)
        | None -> return CmpResult(ctx, atom: LirAtomBool(val: true))
      end
    | VariantField(name: n_opt, typ: ftyp) :: rest ->
      let fname = match n_opt do
        | Some(val: n) -> n
        | None -> str.from_i64(val: count_fields(fs: rest))
      end
      let heap_idx = heap_index_of(name: fname, all_names)
      let CmpResult(ctx: ctx1, atom: feq) = compare_field(
        lhs_parent: l, rhs_parent: r, heap_idx, field_type: ftyp, gen_inst, ctx
      )
      let next_acc = match acc do
        | None -> CmpResult(ctx: ctx1, atom: feq)
        | Some(val: prev) ->
          let BindResult(ctx: ctx2, atom: anded) = bind_expr_to_temp(
            ctx: ctx1,
            expr: LirExprBinary(op: OpAnd, lhs: prev, rhs: feq, typ: TyBool),
            typ: TyBool
          )
          CmpResult(ctx: ctx2, atom: anded)
      end
      let CmpResult(ctx: ctx3, atom: acc_atom) = next_acc
      return compare_variant_fields_go(l, r, fields: rest, all_names,
                                       acc: Some(val: acc_atom), gen_inst, ctx: ctx3)
  end
end

// Sum equality: load both tags, require tag equality, then dispatch on the
// (shared) tag to the matching variant's payload compare. Variants are
// processed as a chain of `if tag_l == constructor_tag(V) then <payload eq>`;
// the trailing default yields `true` (tags already equal ⇒ same nullary /
// already-handled variant). The whole thing is AND'd with the tag-equality
// flag so a tag mismatch is `false` regardless of payload reads.
let compare_sum = fn (
  l: LirAtom,
  r: LirAtom,
  variants: [ VariantDef ],
  gen_inst: bool,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  // tag_l / tag_r
  let BindResult(ctx: c1, atom: tag_l) = bind_expr_to_temp(
    ctx, expr: LirExprObjectTag(value: l, typ: TyI64), typ: TyI64
  )
  let BindResult(ctx: c2, atom: tag_r) = bind_expr_to_temp(
    ctx: c1, expr: LirExprObjectTag(value: r, typ: TyI64), typ: TyI64
  )
  let BindResult(ctx: c3, atom: tags_eq) = bind_expr_to_temp(
    ctx: c2, expr: LirExprBinary(op: OpEq, lhs: tag_l, rhs: tag_r, typ: TyBool), typ: TyBool
  )
  // Pre-declare the payload-result temp; the guarded dispatch assigns it.
  let BindResult(ctx: c4, atom: payload_eq) = bind_expr_to_temp(
    ctx: c3, expr: LirExprBinary(op: OpEq, lhs: tag_l, rhs: tag_l, typ: TyBool), typ: TyBool
  )
  let payload_name = match payload_eq do
    | LirAtomVar(name: pn, typ: _) -> pn
    | _ -> ""
  end
  // Guard the per-variant payload compare behind tag equality. When the tags
  // DIFFER the payloads must NOT be read: with structural recursion a field of
  // the wrong-shaped operand would be loaded as a heap pointer and recursed
  // into, faulting on garbage. So: `if tags_eq then <dispatch> else payload=false`.
  let LowerCtx(vars: gv, semantic_vars: gsv, stmts: g_saved, temp_counter: gc, enum_defs: ged) = c4
  let then_ctx0 = LowerCtx(vars: gv, semantic_vars: gsv, stmts: [], temp_counter: gc, enum_defs: ged)
  let then_done = emit_variant_dispatch(l, r, tag_l, variants, payload_name, gen_inst, ctx: then_ctx0)
  let LowerCtx(vars: tv, semantic_vars: tsv, stmts: then_rev, temp_counter: tc, enum_defs: ted) = then_done
  let then_stmts = list.reverse(xs: then_rev)
  let else_stmts = [ LirStmtLet(name: payload_name, typ: TyBool, expr: LirExprAtom(atom: LirAtomBool(val: false))) ]
  let c5 = LowerCtx(
    vars: tv, semantic_vars: tsv,
    stmts: LirStmtIf(cond: tags_eq, then_body: then_stmts, else_body: else_stmts) :: g_saved,
    temp_counter: tc, enum_defs: ted
  )
  // result = tags_eq && payload_eq (payload_eq already false on tag mismatch).
  let BindResult(ctx: c6, atom: result) = bind_expr_to_temp(
    ctx: c5,
    expr: LirExprBinary(op: OpAnd, lhs: tags_eq, rhs: payload_eq, typ: TyBool),
    typ: TyBool
  )
  return CmpResult(ctx: c6, atom: result)
end

// Emit `if tag_l == ctor_tag(V) then payload_name = <V payload eq> else <rest>`
// chained over all variants. Each branch is lowered in an ISOLATED stmt list
// (saved/restored ctx.stmts) so the nested compares land inside the branch.
let emit_variant_dispatch = fn (
  l: LirAtom,
  r: LirAtom,
  tag_l: LirAtom,
  variants: [ VariantDef ],
  payload_name: string,
  gen_inst: bool,
  ctx: LowerCtx
) -> LowerCtx throws { LirError } do
  match variants do
    | [] -> return ctx
    | vd :: rest ->
      let VariantDef(name: vname, fields: _) = vd
      let tag_val = constructor_tag(name: vname, arity: arity_of(vd))
      // cond = (tag_l == tag_val)
      let BindResult(ctx: c1, atom: cond) = bind_expr_to_temp(
        ctx,
        expr: LirExprBinary(op: OpEq, lhs: tag_l, rhs: LirAtomInt(val: tag_val), typ: TyBool),
        typ: TyBool
      )
      // THEN branch: compute this variant's payload eq into payload_name.
      let then_stmts = build_branch_stmts(
        l, r, vd, payload_name, gen_inst, ctx: c1
      )
      // ELSE branch: recurse over the remaining variants, again isolated.
      let LowerCtx(vars: ev, semantic_vars: esv, stmts: saved, temp_counter: ec, enum_defs: eed) = c1
      let else_ctx0 = LowerCtx(vars: ev, semantic_vars: esv, stmts: [],
                               temp_counter: ec, enum_defs: eed)
      let else_done = emit_variant_dispatch(l, r, tag_l, variants: rest,
                                            payload_name, gen_inst, ctx: else_ctx0)
      let LowerCtx(vars: ev2, semantic_vars: esv2, stmts: else_rev,
                   temp_counter: ec2, enum_defs: eed2) = else_done
      let else_stmts = list.reverse(xs: else_rev)
      // Re-emit the if into the ORIGINAL (restored) stmt stream.
      let c_final = LowerCtx(
        vars: ev2, semantic_vars: esv2,
        stmts: LirStmtIf(cond, then_body: then_stmts, else_body: else_stmts) :: saved,
        temp_counter: ec2, enum_defs: eed2
      )
      return c_final
  end
end

// Lower one variant's payload comparison in an isolated stmt list, with a
// trailing assignment of the result into `payload_name`. Returns the branch
// statement list (forward order).
let build_branch_stmts = fn (
  l: LirAtom,
  r: LirAtom,
  vd: VariantDef,
  payload_name: string,
  gen_inst: bool,
  ctx: LowerCtx
) -> [ LirStmt ] throws { LirError } do
  let LowerCtx(vars: v, semantic_vars: sv, stmts: _, temp_counter: c, enum_defs: ed) = ctx
  let iso = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
  let CmpResult(ctx: iso2, atom: peq) = compare_variant_payload(l, r, vd, gen_inst, ctx: iso)
  let LowerCtx(vars: _, semantic_vars: _, stmts: body_rev, temp_counter: _, enum_defs: _) = iso2
  let assign = LirStmtLet(name: payload_name, typ: TyBool, expr: LirExprAtom(atom: peq))
  return list.reverse(xs: assign :: body_rev)
end

// ─── Generated runtime helpers ──────────────────────────────────────────────

let zero_span = Span(offset: 0, line: 0, col: 0)

// Build the body of a structural-compare helper for `sem_type` with the two
// operands bound to params `l` / `r`. Returns the helper's statement list
// (forward order) and the final bool result atom. The body compares ONE LEVEL
// of `sem_type`'s structure inline; aggregate field positions emit a CALL to the
// relevant helper (self-call for recursive positions), so recursion is at run
// time and always terminates on finite values.
let build_helper_body = fn (
  sem_type: TypeExpr,
  gen_inst: bool,
  enum_defs: VariantIndex
) -> BindResult throws { LirError } do
  let l = LirAtomVar(name: "l", typ: TyI64)
  let r = LirAtomVar(name: "r", typ: TyI64)
  let ctx0 = LowerCtx(vars: [], semantic_vars: [], stmts: [], temp_counter: 0, enum_defs)
  // Dispatch on the type's own shape (NOT named_aggregate_name — that would emit
  // a self-call and never bottom out).
  let CmpResult(ctx: ctx1, atom: result) = match vidx.resolve_record_alias(idx: enum_defs, typ: sem_type) do
    | TyRecord(fields: fs) -> compare_record(l, r, fields: fs, gen_inst, ctx: ctx0)
    | TyUserDefined(name: en, args: _) ->
      match vidx.variants_of_enum(idx: enum_defs, enum_name: en) do
        | [] -> compare_primitive(l, r, ctx: ctx0)
        | vs -> compare_sum(l, r, variants: vs, gen_inst, ctx: ctx0)
      end
    | _ -> compare_primitive(l, r, ctx: ctx0)
  end
  let LowerCtx(vars: _, semantic_vars: _, stmts: body_rev, temp_counter: _, enum_defs: _) = ctx1
  return BindResult(ctx: ctx1, atom: result)
end

// Synthesize one `__streq_<Name>(l, r) -> bool` helper for a named aggregate. The
// BARE per-named-type helper is built with `gen_inst = false` so a generic field
// erases to identity (today's behavior); a per-INSTANTIATION helper passes
// `gen_inst = true` so its (substituted) generic-payload fields recurse.
let make_helper = fn (
  type_name: string,
  sem_type: TypeExpr,
  gen_inst: bool,
  enum_defs: VariantIndex
) -> LirFunction throws { LirError } do
  let BindResult(ctx: ctx1, atom: result) = build_helper_body(sem_type, gen_inst, enum_defs)
  let LowerCtx(vars: _, semantic_vars: _, stmts: body_rev, temp_counter: _, enum_defs: _) = ctx1
  // Params labelled "l" < "r" so sort_lir_params keeps [l, r]; call sites emit
  // args in that same order (positional internal-call ABI).
  return LirFunction(
    name: struct_eq_helper_name(type_name),
    params: [ LirParam(label: "l", name: "l", typ: TyI64),
              LirParam(label: "r", name: "r", typ: TyI64) ],
    ret_type: TyBool,
    body: list.reverse(xs: body_rev),
    ret: result,
    span: zero_span
  )
end

// Synthesize the `__streq_List$<key>(l, r) -> bool` helper for the list type
// `[elem]`. Body = a sum compare over the monomorphized `Nil`/`Cons` variants:
// equal iff same tag (both Nil, or both Cons) AND, for Cons, the head `v`
// (type `elem`) and tail `rest` (type `[elem]`) are both structurally equal.
// The `rest` recursion self-calls this same helper (terminates on finite data);
// the `v` recursion routes through `elem`'s own compare path so strings, records
// and nested lists compare structurally rather than by i64 identity.
// `gen_inst` + `type_name` let a per-INSTANTIATION list helper
// (`__streq_List$Option$Color`, built with `gen_inst = true`) recurse its head
// `v: Option<Color>` into the per-inst element helper; the BARE list helper
// (`__streq_List$Option`, `gen_inst = false`) erases the element's generic args.
let make_list_helper = fn (
  type_name: string,
  elem: TypeExpr,
  gen_inst: bool,
  enum_defs: VariantIndex
) -> LirFunction throws { LirError } do
  let l = LirAtomVar(name: "l", typ: TyI64)
  let r = LirAtomVar(name: "r", typ: TyI64)
  let ctx0 = LowerCtx(vars: [], semantic_vars: [], stmts: [], temp_counter: 0, enum_defs)
  let CmpResult(ctx: ctx1, atom: result) = compare_sum(l, r, variants: list_variant_defs(elem: elem), gen_inst, ctx: ctx0)
  let LowerCtx(vars: _, semantic_vars: _, stmts: body_rev, temp_counter: _, enum_defs: _) = ctx1
  return LirFunction(
    name: struct_eq_helper_name(type_name),
    params: [ LirParam(label: "l", name: "l", typ: TyI64),
              LirParam(label: "r", name: "r", typ: TyI64) ],
    ret_type: TyBool,
    body: list.reverse(xs: body_rev),
    ret: result,
    span: zero_span
  )
end

let make_enum_helpers = fn (
  defs: [ EnumDef ],
  enum_defs: VariantIndex,
  acc: [ LirFunction ]
) -> [ LirFunction ] throws { LirError } do
  match defs do
    | [] -> return list.reverse(xs: acc)
    | EnumDef(name: en, is_public: _, is_opaque: _, type_params: _, variants: vs, layout_variants: _) :: rest ->
      // Skip enums with no in-scope variants (opaque imported) — no structure to
      // compare; a compare on such a value keeps the legacy i64 path.
      let acc2 = match vs do
        | [] -> acc
        | _ -> make_helper(type_name: en, sem_type: TyUserDefined(name: en, args: []), gen_inst: false, enum_defs) :: acc
      end
      return make_enum_helpers(defs: rest, enum_defs, acc: acc2)
  end
end

let make_record_helpers = fn (
  defs: [ RecordDef ],
  enum_defs: VariantIndex,
  acc: [ LirFunction ]
) -> [ LirFunction ] throws { LirError } do
  match defs do
    | [] -> return list.reverse(xs: acc)
    | RecordDef(name: rn, is_public: _, type_params: _, fields: fs) :: rest ->
      let helper = make_helper(type_name: rn, sem_type: TyRecord(fields: fs), gen_inst: false, enum_defs)
      return make_record_helpers(defs: rest, enum_defs, acc: helper :: acc)
  end
end

// ─── List-helper element-type collection ────────────────────────────────────
//
// `[elem] == [elem]` lowers to a CALL of `__streq_List$<key(elem)>`. One such
// helper must be synthesized per distinct element type that any list `==`/`!=`
// compares. The element type lives at the `==` site (in the MIR/semantic type)
// and is NOT recovered here, so the set is over-approximated from the program's
// declared shapes plus the primitive base set: every concrete element type a
// list literal/value can carry is covered (primitives, every named aggregate,
// one level of list-of-list per the spec's nested-list requirement). Unused
// helpers are harmless — they reference only themselves and `elem`'s helper,
// both of which are generated. An element type outside this set (e.g. an
// uncommon deeper nesting) falls back to the generic `T`-keyed helper, whose
// element compare is the i64 value compare (the type-erased precedent).

// Add `e` to `acc` keyed by `list_type_name` (dedup by helper name).
let push_elem = fn (e: TypeExpr, acc: [ TypeExpr ]) -> [ TypeExpr ] do
  return push_elem_go(e, key: list_type_name(elem: e), rest: acc, full: acc)
end

let push_elem_go = fn (e: TypeExpr, key: string, rest: [ TypeExpr ], full: [ TypeExpr ]) -> [ TypeExpr ] do
  match rest do
    | [] -> return e :: full
    | h :: tl ->
      if list_type_name(elem: h) == key then return full
      else return push_elem_go(e, key, rest: tl, full)
      end
  end
end

// Harvest the list element types reachable from a field type: a `[e]` field
// contributes `[e]`, and the recursion into `e` contributes any nested `[[..]]`.
let harvest_type = fn (t: TypeExpr, acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match t do
    | TyList(elem: e) ->
      // record `[e]` itself as a needed helper; recurse into `e` (covers `[[x]]`).
      let acc1 = push_elem(e, acc)
      return harvest_type(t: e, acc: acc1)
    | _ -> return acc
  end
end

let enum_field_types = fn (defs: [ EnumDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs, layout_variants: _) :: rest ->
      return enum_field_types(defs: rest, acc: variant_list_field_types(vs, acc))
  end
end

let variant_list_field_types = fn (vs: [ VariantDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match vs do
    | [] -> return acc
    | VariantDef(name: _, fields: fs) :: rest ->
      return variant_list_field_types(vs: rest, acc: variant_field_types_go(fs, acc))
  end
end

let variant_field_types_go = fn (fs: [ VariantField ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match fs do
    | [] -> return acc
    | VariantField(name: _, typ: t) :: rest -> return variant_field_types_go(fs: rest, acc: harvest_type(t, acc))
  end
end

let record_field_types = fn (defs: [ RecordDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | RecordDef(name: _, is_public: _, type_params: _, fields: fs) :: rest ->
      return record_field_types(defs: rest, acc: record_field_types_go(fs, acc))
  end
end

let record_field_types_go = fn (fs: [ NamedType ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match fs do
    | [] -> return acc
    | NamedType(name: _, typ: t) :: rest -> return record_field_types_go(fs: rest, acc: harvest_type(t, acc))
  end
end

// Element types whose `[elem]` list helper is always synthesized: the primitive
// base set, every named aggregate (record/enum), and one nested level of
// list-of-each so a bare `[[1], [2]]` (`[[i64]]`) compare resolves its helper.
let enum_name_elems = fn (defs: [ EnumDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | EnumDef(name: en, is_public: _, is_opaque: _, type_params: _, variants: vs, layout_variants: _) :: rest ->
      let acc2 = match vs do
        | [] -> acc
        | _ -> push_elem(e: TyUserDefined(name: en, args: []), acc)
      end
      return enum_name_elems(defs: rest, acc: acc2)
  end
end

let record_name_elems = fn (defs: [ RecordDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | RecordDef(name: rn, is_public: _, type_params: _, fields: _) :: rest ->
      return record_name_elems(defs: rest, acc: push_elem(e: TyUserDefined(name: rn, args: []), acc))
  end
end

let primitive_elems = fn () -> [ TypeExpr ] do
  return [ TyI64, TyString, TyBool, TyF64, TyChar ]
end

let seed_elems_into = fn (xs: [ TypeExpr ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match xs do
    | [] -> return acc
    | x :: rest -> return seed_elems_into(xs: rest, acc: push_elem(e: x, acc))
  end
end

// Add `[base]` as a new element for every base element, so a bare list-of-list
// (`[[i64]]`) compare has its helper. One nesting level covers the spec's
// nested-list requirement; deeper nesting falls back to the generic helper.
let nest_one_level = fn (bases: [ TypeExpr ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match bases do
    | [] -> return acc
    | b :: rest -> return nest_one_level(bases: rest, acc: push_elem(e: TyList(elem: b), acc))
  end
end

let make_list_helpers = fn (
  elems: [ TypeExpr ],
  enum_defs: VariantIndex,
  acc: [ LirFunction ]
) -> [ LirFunction ] throws { LirError } do
  match elems do
    | [] -> return list.reverse(xs: acc)
    | e :: rest -> return make_list_helpers(elems: rest, enum_defs, acc: make_list_helper(type_name: list_type_name(elem: e), elem: e, gen_inst: false, enum_defs) :: acc)
  end
end

// ─── ANONYMOUS-record list-element harvesting (from MIR, with a semantic env) ─
//
// A list whose element is an ANONYMOUS record (`[{a, b}]` / `[{ col: mk(7) }]`)
// has no declared type name, so its `__streq_List$Rec$...` helper cannot be seeded
// from the EnumDef / RecordDef tables — the element shape lives only in the MIR.
// A list literal desugars to `Cons(rest, v)` / `Nil`, so for every `Cons` we
// recover the list ELEMENT type from the head value `v` and, when it (or a nesting
// of it) carries an anonymous record, push that element type so the matching helper
// is synthesized.
//
// KEY (nexus-h69yj): the element type MUST be recovered with the SAME
// `infer_semantic_type` the `==` CALL SITE uses, because an anon-record FIELD value
// may be a call / variable / match / field-access (`{ col: mk(7) }`) whose type is
// semantic, not a syntactic literal. The previous `mir_field_type` walk had a
// catch-all that erased those to `TyI64`, so the harvested helper name
// (`…col=i64…`) diverged from the call site's (`…col=Color…`) → the helper was
// never generated → E3001 codegen abort. We therefore thread the SAME running
// semantic-variable env the real LIR lowering builds (function params + each `let`
// binding's recovered type) and type each `Cons` head with `infer_semantic_type`.
//
// The recursive walk threads a SINGLE flat `[TypeExpr]` accumulator of the raw
// recovered list types (NOT yet filtered) — mirroring the known-good single-
// accumulator shape; the anon-record FILTER runs in a SEPARATE, non-recursive pass
// (harvested_anon_record_elems). This deliberately avoids threading a richer record
// through the deep mutual recursion, which the self-host seed miscompiles.

// Walk an expr, pushing the RAW recovered semantic type of every `MirConstructor`
// (a `Cons` yields `TyList(elem)`), and always recursing into sub-exprs so nested
// list literals (`[[{...}]]`, `f([{...}])`) are caught.
let harvest_expr = fn (e: MirExpr, ctx: LowerCtx, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match e do
    | MirConstructor(name: _, args: cargs) ->
      let acc1 = infer_semantic_type(expr: e, ctx) :: acc
      return harvest_exprs(es: cargs, ctx, acc: acc1)
    | MirRecord(fields: fs) -> return harvest_named_exprs(fs, ctx, acc)
    | MirArray(elems: es) -> return harvest_exprs(es, ctx, acc)
    | MirBinaryOp(left: l, op, right: r) ->
      // At a `==` / `!=` SITE, record both operands' recovered semantic types
      // (wrapped in the `#EQSITE#` marker) so the per-instantiation worklist is
      // seeded STRICTLY from comparison sites — never from an incidental
      // `Some(...)` construction elsewhere (worklist rule 1). The marker name
      // carries `#`, so it can never collide with a real type; the worklist
      // post-pass (`harvested_eq_site_insts`) unwraps it.
      let acc_eq = if is_struct_eq_op(op) then eq_site_marker(t: infer_semantic_type(expr: r, ctx)) :: (eq_site_marker(t: infer_semantic_type(expr: l, ctx)) :: acc) else acc end
      return harvest_expr(e: r, ctx, acc: harvest_expr(e: l, ctx, acc: acc_eq))
    | MirCall(func: _, args: cas, ret_type: _) -> return harvest_call_args(cas, ctx, acc)
    | MirCallClosure(closure: c, args: cas, ret_type: _) -> return harvest_call_args(cas, ctx, acc: harvest_expr(e: c, ctx, acc))
    | MirIndex(target: t, index: i) -> return harvest_expr(e: i, ctx, acc: harvest_expr(e: t, ctx, acc))
    | MirFieldAccess(target: t, field: _) -> return harvest_expr(e: t, ctx, acc)
    | MirIf(cond: c, then_body: tb, else_body: eb) ->
      let acc1 = harvest_expr(e: c, ctx, acc)
      let acc2 = harvest_stmts(stmts: tb, ctx, acc: acc1)
      match eb do
        | Some(val: ebs) -> return harvest_stmts(stmts: ebs, ctx, acc: acc2)
        | None -> return acc2
      end
    | MirMatch(target: t, cases: cs) -> return harvest_cases(cs, ctx, acc: harvest_expr(e: t, ctx, acc))
    | MirWhile(cond: c, body: b) -> return harvest_stmts(stmts: b, ctx, acc: harvest_expr(e: c, ctx, acc))
    | MirRaise(expr: x) -> return harvest_expr(e: x, ctx, acc)
    | MirForce(expr: x) -> return harvest_expr(e: x, ctx, acc)
    | MirMakeClosure(func_name: _, captures: cs) -> return harvest_exprs(es: cs, ctx, acc)
    | MirSuspend(tag_name: _, payload: p, ret_type: _) -> return harvest_expr(e: p, ctx, acc)
    | MirResume(cont_var: _, value: v, ret_type: _) -> return harvest_expr(e: v, ctx, acc)
    | MirBlock(stmts: ss) -> return harvest_stmts(stmts: ss, ctx, acc)
    | MirInjectValue(stmts: ss, ret_type: _) -> return harvest_stmts(stmts: ss, ctx, acc)
    | _ -> return acc
  end
end

let harvest_exprs = fn (es: [ MirExpr ], ctx: LowerCtx, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match es do
    | [] -> return acc
    | x :: rest -> return harvest_exprs(es: rest, ctx, acc: harvest_expr(e: x, ctx, acc))
  end
end

let harvest_named_exprs = fn (fs: [ MirNamedExpr ], ctx: LowerCtx, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match fs do
    | [] -> return acc
    | MirNamedExpr(name: _, value: v) :: rest -> return harvest_named_exprs(fs: rest, ctx, acc: harvest_expr(e: v, ctx, acc))
  end
end

let harvest_call_args = fn (cas: [ MirCallArg ], ctx: LowerCtx, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match cas do
    | [] -> return acc
    | MirCallArg(label: _, value: v) :: rest -> return harvest_call_args(cas: rest, ctx, acc: harvest_expr(e: v, ctx, acc))
  end
end

let harvest_cases = fn (cs: [ MirMatchCase ], ctx: LowerCtx, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match cs do
    | [] -> return acc
    // Match-arm bodies run in a nested scope; the env only grows, a sound
    // over-approximation — pattern-bound names resolve to TyI64 (their
    // constructors are still walked).
    | MirMatchCase(pattern: _, body: b) :: rest -> return harvest_cases(cs: rest, ctx, acc: harvest_stmts(stmts: b, ctx, acc))
  end
end

// Walk statements threading the running env: a `let` extends the env with the
// binding's recovered semantic type so a LATER list literal that references the
// variable recovers the same element type the real lowering does.
let harvest_stmts = fn (stmts: [ MirStmt ], ctx: LowerCtx, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match stmts do
    | [] -> return acc
    | s :: rest ->
      let HarvestStmtResult(ctx: ctx1, acc: acc1) = harvest_stmt(s, ctx, acc)
      return harvest_stmts(stmts: rest, ctx: ctx1, acc: acc1)
  end
end

type HarvestStmtResult = HarvestStmtResult(ctx: LowerCtx, acc: [ TypeExpr ])

let harvest_stmt = fn (s: MirStmt, ctx: LowerCtx, acc: [ TypeExpr ]) -> HarvestStmtResult throws { LirError } do
  match s do
    | MirStmtLet(name: n, typ: _, expr: e) ->
      let acc1 = harvest_expr(e, ctx, acc)
      let inst = infer_semantic_type(expr: e, ctx)
      let LowerCtx(vars: v, semantic_vars: sv, stmts: st, temp_counter: tc, enum_defs: ed) = ctx
      return HarvestStmtResult(ctx: LowerCtx(vars: v, semantic_vars: insert_type(name: n, typ: inst, entries: sv), stmts: st, temp_counter: tc, enum_defs: ed), acc: acc1)
    | MirStmtExpr(expr: e) -> return HarvestStmtResult(ctx, acc: harvest_expr(e, ctx, acc))
    | MirStmtReturn(expr: e) -> return HarvestStmtResult(ctx, acc: harvest_expr(e, ctx, acc))
    | MirStmtAssign(target: t, value: vv) -> return HarvestStmtResult(ctx, acc: harvest_expr(e: vv, ctx, acc: harvest_expr(e: t, ctx, acc)))
    | MirStmtTry(body: b, catch_param: _, catch_body: cb) ->
      let acc1 = harvest_stmts(stmts: b, ctx, acc)
      return HarvestStmtResult(ctx, acc: harvest_stmts(stmts: cb, ctx, acc: acc1))
    | _ -> return HarvestStmtResult(ctx, acc)
  end
end

let seed_param_env = fn (params: [ MirParam ], acc: [ TypeEntry ]) -> [ TypeEntry ] do
  match params do
    | [] -> return acc
    | MirParam(label: _, name: n, typ: t) :: rest -> return seed_param_env(params: rest, acc: TypeEntry(name: n, typ: t) :: acc)
  end
end

let harvest_func = fn (f: MirFunction, enum_defs: VariantIndex, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  let MirFunction(name: _, params: ps, ret_type: _, body: b, span: _) = f
  let ctx0 = LowerCtx(vars: [], semantic_vars: seed_param_env(params: ps, acc: []), stmts: [], temp_counter: 0, enum_defs)
  return harvest_stmts(stmts: b, ctx: ctx0, acc)
end

let harvest_mir_funcs = fn (funcs: [ MirFunction ], enum_defs: VariantIndex, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match funcs do
    | [] -> return acc
    | f :: rest -> return harvest_mir_funcs(funcs: rest, enum_defs, acc: harvest_func(f, enum_defs, acc))
  end
end

// Does a list-element type carry an anonymous record anywhere a generated helper
// would need it (the element itself, or under one or more `[..]` nestings)?
let elem_carries_anon_record = fn (t: TypeExpr) -> bool do
  match t do
    | TyRecord(fields: _) -> return true
    | TyList(elem: inner) -> return elem_carries_anon_record(t: inner)
    | _ -> return false
  end
end

// Non-recursive post-pass: from the flat raw list of recovered constructor types,
// push the ELEMENT type of every `TyList(elem)` whose element carries an anonymous
// record (dedup by helper name via push_elem).
let harvested_anon_record_elems = fn (raw: [ TypeExpr ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match raw do
    | [] -> return acc
    | TyList(elem: el) :: rest ->
      let acc1 = if elem_carries_anon_record(t: el) then push_elem(e: el, acc) else acc end
      return harvested_anon_record_elems(raw: rest, acc: acc1)
    | _ :: rest -> return harvested_anon_record_elems(raw: rest, acc)
  end
end

// ─── Per-instantiation helper worklist (generic-enum-at-concrete payload) ────
//
// `==`/`!=` on a generic enum at a concrete structural instantiation
// (`Some(Red(7)) == Some(Red(7))`, operand type `Option<Color>`) must compare the
// type-parameter payload STRUCTURALLY (spec § T-Cmp), not by the heap-pointer
// identity the type-erased bare `__streq_Option` emits. We synthesize a
// per-instantiation helper `__streq_Option$Color` whose `Some` arm — built from
// the variant defs with the type params substituted (`T := Color`) — recurses
// into `__streq_Color`.
//
// SCALING (the load-bearing design). The per-instantiation set is seeded STRICTLY
// from `==`/`!=` SITES (the `#EQSITE#`-marked operand types harvested above),
// then transitively closed over the generic instantiations those helpers recurse
// into. It is NOT seeded from arbitrary declared type fields: a never-`==`'d infra
// type (`VariantIndex { by_variant: Map<string, VariantInfo> }`) would otherwise
// drag the whole `Map → Node → … → TypeExpr` closure into existence. The matching
// guarantee is in the ROUTING: a BARE helper body (`gen_inst = false`) erases a
// concrete generic field to the bare helper, so `__streq_VariantIndex` calls bare
// `__streq_Map` (never `__streq_Map$string$VariantInfo`) — no per-inst request,
// no closure. Only a `gen_inst = true` body (a per-inst helper, reached from a
// `==` site) recurses structurally, and every instantiation it reaches is in the
// worklist by construction.
//
// All shapes are seed-safe: flat `[TypeExpr]` / `[string]` accumulators threaded
// as separate params (never a rich record through deep recursion), with a
// fuel-bounded worklist loop mirroring the reachability `collect_calls_*` shape.

// Marker wrapping a `==`-site operand type in the flat harvest accumulator. The
// `#` in the name guarantees no collision with a real `TyUserDefined` type.
let eq_site_marker = fn (t: TypeExpr) -> TypeExpr do
  return TyUserDefined(name: "#EQSITE#", args: [ t ])
end

// Non-recursive post-pass: unwrap every `#EQSITE#` marker and keep the operand
// types that name a per-instantiation COMPARE TARGET — a concrete generic-enum
// instantiation (`Option<Color>`) or a list whose element carries one
// (`[Option<Color>]`). Everything else (primitives, bare enums, anon records,
// `==` on non-generic types) contributes no per-inst helper.
let harvested_eq_site_insts = fn (raw: [ TypeExpr ], enum_defs: VariantIndex, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match raw do
    | [] -> return acc
    | TyUserDefined(name: "#EQSITE#", args: [ operand ]) :: rest ->
      return harvested_eq_site_insts(raw: rest, enum_defs, acc: targets_in_type(t: operand, enum_defs, acc))
    | _ :: rest -> return harvested_eq_site_insts(raw: rest, enum_defs, acc)
  end
end

// Collect, from a single type, every per-instantiation compare TARGET it
// contains: a concrete generic-enum instantiation `Enum<concrete>` (one for which
// a `__streq_Enum$args` helper is keyed) and, for a `[elem]`, the list itself when
// its element carries a target plus the element's own targets. Walks the finite
// TypeExpr structure, threading a single flat accumulator (dedup by helper name
// via `push_inst`).
let targets_in_type = fn (t: TypeExpr, enum_defs: VariantIndex, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match t do
    | TyUserDefined(name: en, args: ats) ->
      if is_concrete_generic_inst(t) then
        match vidx.variants_of_enum(idx: enum_defs, enum_name: en) do
          // Only a generic ENUM (known in-scope variants) gets a per-inst helper;
          // a generic RECORD/struct instantiation (e.g. `Map<…>`) is left to its
          // bare helper (its declared fields are not `==`-seeded).
          | [] -> return targets_in_type_list(ts: ats, enum_defs, acc)
          | _ -> return targets_in_type_list(ts: ats, enum_defs, acc: push_inst(e: t, acc))
        end
      else
        return targets_in_type_list(ts: ats, enum_defs, acc)
      end
    | TyList(elem: el) ->
      // A list whose element carries a target needs its OWN per-inst list helper
      // (`__streq_List$Option$Color`); recurse into the element for nested targets.
      let acc1 = if type_carries_inst_target(t: el, enum_defs) then push_inst(e: t, acc) else acc end
      return targets_in_type(t: el, enum_defs, acc: acc1)
    | _ -> return acc
  end
end

let targets_in_type_list = fn (ts: [ TypeExpr ], enum_defs: VariantIndex, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match ts do
    | [] -> return acc
    | x :: rest -> return targets_in_type_list(ts: rest, enum_defs, acc: targets_in_type(t: x, enum_defs, acc))
  end
end

// True iff `t` (a list element) contains a per-instantiation target anywhere, so
// the enclosing `[t]` warrants a per-inst list helper rather than the bare one.
let type_carries_inst_target = fn (t: TypeExpr, enum_defs: VariantIndex) -> bool throws { LirError } do
  match targets_in_type(t, enum_defs, acc: []) do
    | [] -> return false
    | _ -> return true
  end
end

// Dedup-push a target by its per-instantiation helper-bearing name (`inst_key`).
let push_inst = fn (e: TypeExpr, acc: [ TypeExpr ]) -> [ TypeExpr ] do
  return push_inst_go(e, key: inst_key(t: e), rest: acc, full: acc)
end

let push_inst_go = fn (e: TypeExpr, key: string, rest: [ TypeExpr ], full: [ TypeExpr ]) -> [ TypeExpr ] do
  match rest do
    | [] -> return e :: full
    | h :: tl -> if inst_key(t: h) == key then return full else return push_inst_go(e, key, rest: tl, full) end
  end
end

// ─── Worklist transitive closure ────────────────────────────────────────────

let lookup_enum_def = fn (defs: [ EnumDef ], name: string) -> Option<EnumDef> do
  match defs do
    | [] -> return None
    | EnumDef(name: n, is_public: p, is_opaque: o, type_params: tps, variants: vs, layout_variants: lvs) :: rest ->
      if n == name then return Some(val: EnumDef(name: n, is_public: p, is_opaque: o, type_params: tps, variants: vs, layout_variants: lvs))
      else return lookup_enum_def(defs: rest, name) end
  end
end

// Build a param-name → concrete-arg map (positional) for an enum instantiation.
let zip_params_args = fn (params: [ string ], args: [ TypeExpr ], acc: [ NamedType ]) -> [ NamedType ] do
  match params do
    | [] -> return acc
    | p :: prest ->
      match args do
        | [] -> return acc
        | a :: arest -> return zip_params_args(params: prest, args: arest, acc: NamedType(name: p, typ: a) :: acc)
      end
  end
end

// Substitute a declared variant-field type's type parameters with the
// instantiation's concrete args. A type parameter `p` arrives EITHER as
// `TyVar("p")` (the builtin enums List / Option / Result declare their params as
// `TyVar`) OR as `TyUserDefined("p", [])` (a USER generic enum's params are
// shape-identical to a named type at MIR) — both are substituted. Recurses
// through `[T]` / `K<…>` / records.
let subst_param_type = fn (t: TypeExpr, subst: [ NamedType ]) -> TypeExpr do
  match t do
    | TyVar(name: n) ->
      match lookup_nt(target: n, fields: subst) do
        | Some(val: bound) -> return bound
        | None -> return t
      end
    | TyUserDefined(name: n, args: []) ->
      match lookup_nt(target: n, fields: subst) do
        | Some(val: bound) -> return bound
        | None -> return t
      end
    | TyUserDefined(name: n, args: ats) -> return TyUserDefined(name: n, args: subst_param_type_list(ts: ats, subst))
    | TyList(elem: e) -> return TyList(elem: subst_param_type(t: e, subst))
    | TyRecord(fields: fs) -> return TyRecord(fields: subst_param_named(nts: fs, subst))
    | _ -> return t
  end
end

let subst_param_type_list = fn (ts: [ TypeExpr ], subst: [ NamedType ]) -> [ TypeExpr ] do
  match ts do
    | [] -> return []
    | x :: rest -> return subst_param_type(t: x, subst) :: subst_param_type_list(ts: rest, subst)
  end
end

let subst_param_named = fn (nts: [ NamedType ], subst: [ NamedType ]) -> [ NamedType ] do
  match nts do
    | [] -> return []
    | NamedType(name: n, typ: t) :: rest -> return NamedType(name: n, typ: subst_param_type(t, subst)) :: subst_param_named(nts: rest, subst)
  end
end

let lookup_nt = fn (target: string, fields: [ NamedType ]) -> Option<TypeExpr> do
  match fields do
    | [] -> return None
    | NamedType(name: n, typ: t) :: rest -> if n == target then return Some(val: t) else return lookup_nt(target, fields: rest) end
  end
end

// The CHILD instantiation targets a per-inst helper for `t` recurses into: the
// generic instantiations appearing in its (substituted) variant-field /
// list-element types. A named non-generic payload (`Color`) uses its bare helper
// and contributes no child.
let inst_children = fn (t: TypeExpr, enum_def_list: [ EnumDef ], enum_defs: VariantIndex) -> [ TypeExpr ] throws { LirError } do
  match t do
    | TyList(elem: el) -> return targets_in_type(t: el, enum_defs, acc: [])
    | TyUserDefined(name: en, args: ats) ->
      match lookup_enum_def(defs: enum_def_list, name: en) do
        | None -> return []
        | Some(val: EnumDef(name: _, is_public: _, is_opaque: _, type_params: tps, variants: vs, layout_variants: _)) ->
          let subst = zip_params_args(params: tps, args: ats, acc: [])
          return variant_targets(vs, subst, enum_defs, acc: [])
      end
    | _ -> return []
  end
end

let variant_targets = fn (vs: [ VariantDef ], subst: [ NamedType ], enum_defs: VariantIndex, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match vs do
    | [] -> return acc
    | VariantDef(name: _, fields: fs) :: rest -> return variant_targets(vs: rest, subst, enum_defs, acc: variant_field_targets(fs, subst, enum_defs, acc))
  end
end

let variant_field_targets = fn (fs: [ VariantField ], subst: [ NamedType ], enum_defs: VariantIndex, acc: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match fs do
    | [] -> return acc
    | VariantField(name: _, typ: t) :: rest ->
      let acc1 = targets_in_type(t: subst_param_type(t, subst), enum_defs, acc)
      return variant_field_targets(fs: rest, subst, enum_defs, acc: acc1)
  end
end

// Fuel-bounded worklist closure: process each pending target once (dedup by
// `inst_key` via the `seen` name list), append its child targets, accumulate the
// full target list. Separate flat `pending` / `seen` / `result` params (no rich
// record threaded) mirror the seed-safe reachability shape. The `seen` set makes
// this terminate on finite distinct instantiations; `fuel` is a hard safety bound.
let close_worklist = fn (
  pending: [ TypeExpr ],
  seen: [ string ],
  result: [ TypeExpr ],
  fuel: i64,
  enum_def_list: [ EnumDef ],
  enum_defs: VariantIndex
) -> [ TypeExpr ] throws { LirError } do
  if fuel <= 0 then return result end
  match pending do
    | [] -> return result
    | t :: rest ->
      let key = inst_key(t)
      if str_list_contains_se(xs: seen, s: key) then
        return close_worklist(pending: rest, seen, result, fuel: fuel - 1, enum_def_list, enum_defs)
      else
        let children = inst_children(t, enum_def_list, enum_defs)
        return close_worklist(
          pending: list.concat(xs: children, ys: rest),
          seen: key :: seen,
          result: t :: result,
          fuel: fuel - 1,
          enum_def_list, enum_defs
        )
      end
  end
end

let str_list_contains_se = fn (xs: [ string ], s: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest -> if x == s then return true else return str_list_contains_se(xs: rest, s) end
  end
end

// ─── Per-instantiation helper synthesis ─────────────────────────────────────

// Build one per-instantiation helper for a target. An enum instantiation
// `Option<Color>` yields `__streq_Option$Color` whose variant defs are the enum's
// with type params substituted (so the `Some` payload field is `Color`, routed
// `gen_inst = true` into `__streq_Color`). A list-of-generic `[Option<Color>]`
// yields `__streq_List$Option$Color` whose `Cons.v` is `Option<Color>` (routed
// into `__streq_Option$Color`).
let make_inst_helper = fn (t: TypeExpr, enum_def_list: [ EnumDef ], enum_defs: VariantIndex) -> Option<LirFunction> throws { LirError } do
  match t do
    | TyList(elem: el) ->
      return Some(val: make_list_helper(type_name: "List$" ++ inst_key(t: el), elem: el, gen_inst: true, enum_defs))
    | TyUserDefined(name: en, args: ats) ->
      match lookup_enum_def(defs: enum_def_list, name: en) do
        | None -> return None
        | Some(val: EnumDef(name: _, is_public: _, is_opaque: _, type_params: tps, variants: vs, layout_variants: _)) ->
          let subst = zip_params_args(params: tps, args: ats, acc: [])
          let inst_variants = subst_variant_defs(vs, subst)
          return Some(val: make_inst_enum_helper(type_name: enum_inst_name(enum: en, args: ats), variants: inst_variants, enum_defs))
      end
    | _ -> return None
  end
end

let subst_variant_defs = fn (vs: [ VariantDef ], subst: [ NamedType ]) -> [ VariantDef ] do
  match vs do
    | [] -> return []
    | VariantDef(name: vn, fields: fs) :: rest -> return VariantDef(name: vn, fields: subst_variant_fields(fs, subst)) :: subst_variant_defs(vs: rest, subst)
  end
end

let subst_variant_fields = fn (fs: [ VariantField ], subst: [ NamedType ]) -> [ VariantField ] do
  match fs do
    | [] -> return []
    | VariantField(name: n, typ: t) :: rest -> return VariantField(name: n, typ: subst_param_type(t, subst)) :: subst_variant_fields(fs: rest, subst)
  end
end

// Synthesize `__streq_<type_name>(l, r) -> bool` for an enum instantiation from
// its SUBSTITUTED variant defs (a sum compare, `gen_inst = true`).
let make_inst_enum_helper = fn (type_name: string, variants: [ VariantDef ], enum_defs: VariantIndex) -> LirFunction throws { LirError } do
  let l = LirAtomVar(name: "l", typ: TyI64)
  let r = LirAtomVar(name: "r", typ: TyI64)
  let ctx0 = LowerCtx(vars: [], semantic_vars: [], stmts: [], temp_counter: 0, enum_defs)
  let CmpResult(ctx: ctx1, atom: result) = compare_sum(l, r, variants, gen_inst: true, ctx: ctx0)
  let LowerCtx(vars: _, semantic_vars: _, stmts: body_rev, temp_counter: _, enum_defs: _) = ctx1
  return LirFunction(
    name: struct_eq_helper_name(type_name),
    params: [ LirParam(label: "l", name: "l", typ: TyI64),
              LirParam(label: "r", name: "r", typ: TyI64) ],
    ret_type: TyBool,
    body: list.reverse(xs: body_rev),
    ret: result,
    span: zero_span
  )
end

let make_inst_helpers = fn (targets: [ TypeExpr ], enum_def_list: [ EnumDef ], enum_defs: VariantIndex, acc: [ LirFunction ]) -> [ LirFunction ] throws { LirError } do
  match targets do
    | [] -> return list.reverse(xs: acc)
    | t :: rest ->
      let acc2 = match make_inst_helper(t, enum_def_list, enum_defs) do
        | Some(val: f) -> f :: acc
        | None -> acc
      end
      return make_inst_helpers(targets: rest, enum_def_list, enum_defs, acc: acc2)
  end
end

/** Synthesize the structural-compare helper functions for every named aggregate
 *  type in the program — one per `EnumDef` (with in-scope variants) and one per
 *  record-alias `RecordDef` — plus one per distinct list element type
 *  (`__streq_List$<key>`). Appended to the LirProgram by `lower_mir_to_lir`.
 *  Recursive and mutually-recursive references resolve to the same helper names,
 *  so the emitted wasm recurses at run time and terminates on finite data.
 *  `mir_funcs` supplies the MIR functions so anonymous-record list element types
 *  (`[{...}]`, which have no declared type name to seed from) can be harvested
 *  structurally and get their own list helpers. */
export let gen_struct_eq_helpers = fn (
  enum_def_list: [ EnumDef ],
  record_defs: [ RecordDef ],
  enum_defs: VariantIndex,
  mir_funcs: [ MirFunction ]
) -> [ LirFunction ] throws { LirError } do
  let enum_helpers = make_enum_helpers(defs: enum_def_list, enum_defs, acc: [])
  let record_helpers = make_record_helpers(defs: record_defs, enum_defs, acc: [])
  // Collect the list element types needing a helper: primitives + named
  // aggregates + one nested level, plus every list element harvested from the
  // program's declared record/variant field shapes (any depth). A generic
  // `T`-keyed helper is always present as the fallback for unrecovered/erased
  // element types.
  let base = seed_elems_into(xs: primitive_elems(), acc: [])
  let base1 = enum_name_elems(defs: enum_def_list, acc: base)
  let base2 = record_name_elems(defs: record_defs, acc: base1)
  // Anonymous-record list element types harvested from the MIR (`[{...}]` has no
  // declared type name to seed from). The walk recovers each list element with
  // `infer_semantic_type` (a semantic-env walk over params + lets), so a field
  // VALUE that is a call/variable/match/field-access (`[{ col: mk(7) }]`) keys the
  // SAME element type the `==` call site does — nexus-h69yj. Filtered to anon-record
  // elements (post-pass) and recorded BEFORE nest_one_level so a bare `[[{...}]]`
  // also gets its helper.
  let raw_harvest = harvest_mir_funcs(funcs: mir_funcs, enum_defs, acc: [])
  let base3 = harvested_anon_record_elems(raw: raw_harvest, acc: base2)
  let nested = nest_one_level(bases: base3, acc: base3)
  let with_enum_fields = enum_field_types(defs: enum_def_list, acc: nested)
  let with_rec_fields = record_field_types(defs: record_defs, acc: with_enum_fields)
  // Generic erased-element fallback helper (`__streq_List$T`).
  let all_elems = push_elem(e: TyVar(name: "T"), acc: with_rec_fields)
  let list_helpers = make_list_helpers(elems: all_elems, enum_defs, acc: [])
  // Per-INSTANTIATION structural helpers for generic enums at concrete payloads
  // (`Option<Color>`, user `Box<Color>`, `[Option<Color>]`, …) — see worklist note.
  // Seeded STRICTLY from the `#EQSITE#`-marked `==`/`!=` operand types, then
  // transitively closed over the generic instantiations those helpers recurse
  // into. The bare helpers above are UNCHANGED (their generic fields erase via
  // `gen_inst = false`); only these gen-inst helpers compare a type-parameter
  // payload structurally. The closure stays tiny for a normal program because it
  // never grows from arbitrary declared type fields.
  let eq_seeds = harvested_eq_site_insts(raw: raw_harvest, enum_defs, acc: [])
  let inst_targets = close_worklist(pending: eq_seeds, seen: [], result: [], fuel: 4096, enum_def_list, enum_defs)
  let inst_helpers = make_inst_helpers(targets: inst_targets, enum_def_list, enum_defs, acc: [])
  return list.concat(xs: list.concat(xs: list.concat(xs: enum_helpers, ys: record_helpers), ys: list_helpers), ys: inst_helpers)
end

// ─── Entry point ────────────────────────────────────────────────────────────

/** Lower `lhs op rhs` (op ∈ {OpEq, OpNe}) on a record / sum operand to a
 *  structural compare, returning the result atom. A NAMED aggregate routes to a
 *  CALL of its generated helper (`__streq_<Name>`); an ANONYMOUS record is
 *  expanded inline. `op == OpNe` negates the structural-equal result. Callers
 *  must guard with `should_struct_eq` first. */
export let lower_struct_eq = fn (
  op: BinaryOp,
  lhs: LirAtom,
  rhs: LirAtom,
  sem_type: TypeExpr,
  ctx: LowerCtx
) -> BindResult throws { LirError } do
  // A `==`/`!=` SITE is the gen-inst entry: a concrete generic-enum operand
  // (`Option<Color>`) routes to its per-instantiation structural helper
  // (`__streq_Option$Color`), which the worklist guarantees was synthesized.
  let CmpResult(ctx: ctx1, atom: eq_atom) = compare_values(l: lhs, r: rhs, sem_type: sem_type, gen_inst: true, ctx)
  match op do
    | OpNe ->
      // != is `eq == false`.
      let BindResult(ctx: ctx2, atom: neq) = bind_expr_to_temp(
        ctx: ctx1,
        expr: LirExprBinary(op: OpEq, lhs: eq_atom, rhs: LirAtomBool(val: false), typ: TyBool),
        typ: TyBool
      )
      return BindResult(ctx: ctx2, atom: neq)
    | _ -> return BindResult(ctx: ctx1, atom: eq_atom)
  end
end
