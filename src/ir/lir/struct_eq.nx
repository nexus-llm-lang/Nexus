/**
 * struct_eq: structural equality lowering for `==` / `!=` on record and sum
 * (ADT) operands.
 *
 * Per spec § T-Cmp, `comparable'` admits records (all fields comparable) and
 * named sum types (unfold + all-variant-fields comparable), so `==` on them is
 * well-typed and MUST compute STRUCTURAL value equality — not the pointer
 * identity that a plain `LirExprBinary(OpEq)` on the i32 heap pointer produces.
 *
 * Strategy — GENERATED RUNTIME HELPERS. For every named aggregate type in the
 * program (each `EnumDef` and each record-alias `RecordDef`) a structural
 * compare helper `__streq_<TypeName>(l, r) -> bool` is synthesized as an extra
 * `LirFunction` and appended to the program (see `gen_struct_eq_helpers`,
 * called from `lower_mir_to_lir`). The helper recurses at RUN TIME:
 *   - Record  : equal iff ALL fields structurally equal (AND-fold; the record
 *               tag is fixed by construction so equal-typed records always share
 *               it — no runtime tag check needed).
 *   - Sum/ADT : equal iff same constructor tag AND all payload fields equal.
 *               Nullary constructors bottom out at tag equality; differing tags
 *               short-circuit to false. A tag check selects the per-variant
 *               payload compare via a chain of `LirStmtIf` on
 *               `tag == constructor_tag(V)`.
 *   - Aggregate (named record/sum) field : a CALL to that type's helper. A
 *               RECURSIVE field position (e.g. `Node.left: Tree`) is just a call
 *               to the SAME helper, which terminates on finite data; a sibling
 *               field of another aggregate type calls that type's helper. Because
 *               the recursion is in the emitted wasm — not in this static
 *               expansion — self- and mutually-recursive types (Tree, Even/Odd)
 *               compare structurally with no depth limit.
 *   - Primitive / string : a single value-compare binary (`LirExprBinary(OpEq)`;
 *               codegen routes TyString operands through `emit_string_compare`
 *               via `is_string_op`). A type-parameter field (`TyVar`, e.g. the
 *               element of a generic `List<T>`) is type-erased at this stage and
 *               also bottoms out at the i64 value compare — generic element
 *               recursion is out of scope of the monomorphic helper.
 * `!=` is the negation of `==`.
 *
 * The LIR `MirBinaryOp` dispatch (lir.nx) lowers `lhs op rhs` on a NAMED
 * aggregate to a single CALL of that type's helper. An ANONYMOUS record literal
 * type (`{a, b}` with no name — never recursive, since recursion needs a name to
 * close the loop) is expanded INLINE one level, its aggregate fields still
 * routed through the generated helpers.
 *
 * Owns:
 * - gen_struct_eq_helpers (synthesizes the per-type helper LirFunctions)
 * - lower_struct_eq (entry; called from lir.nx's MirBinaryOp OpEq/OpNe case)
 * - should_struct_eq (classifier: operand type is a record / known sum)
 * - struct_eq_helper_name (the canonical helper name for a named aggregate)
 *
 * Does not own:
 * - LowerCtx / temp + stmt helpers (see src/ir/lir/context.nx)
 * - Field/tag heap layout opcodes (see src/backend/codegen.nx, wasm/defs.nx)
 * - Function injection (see src/ir/lir/func_lower.nx — appends the helpers)
 */
import { TypeExpr, TyRecord, TyUserDefined, TyBool, TyI64, TyF64, TyChar,
         TyString, TyList, TyVar, NamedType,
         EnumDef, RecordDef, VariantDef, VariantField } from "src/types/type_expr.nx"
import { Span } from "src/types/span.nx"
import { BinaryOp, OpEq, OpNe, OpAnd,
         Literal, LitInt, LitFloat, LitBool, LitChar, LitString, LitUnit } from "src/types/vocab.nx"
import {
  LirAtom,
  LirAtomVar,
  LirAtomBool,
  LirAtomInt,
  LirExpr,
  LirExprAtom,
  LirExprBinary,
  LirExprCall,
  LirExprObjectField,
  LirExprObjectTag,
  LirCallArg,
  LirParam,
  LirFunction,
  LirStmt,
  LirStmtLet,
  LirStmtIf
} from "src/ir/lir/types.nx"
import {
  LowerCtx,
  BindResult,
  bind_expr_to_temp
} from "src/ir/lir/context.nx"
import { LirError } from "src/ir/lir/errors.nx"
import { Some, None, Option } from "std:option"
import * as list from "std:list"
import * as str from "std:str"
import { VariantIndex }, * as vidx from "src/ir/support/variant_index.nx"
import { constructor_tag } from "src/backend/wasm/defs.nx"
import {
  MirFunction,
  MirExpr,
  MirLiteral,
  MirBinaryOp,
  MirCall,
  MirConstructor,
  MirRecord,
  MirArray,
  MirIndex,
  MirFieldAccess,
  MirIf,
  MirMatch,
  MirWhile,
  MirRaise,
  MirForce,
  MirMakeClosure,
  MirCallClosure,
  MirSuspend,
  MirResume,
  MirBlock,
  MirNamedExpr,
  MirCallArg,
  MirStmt,
  MirStmtLet,
  MirStmtExpr,
  MirStmtReturn,
  MirStmtAssign,
  MirStmtTry,
  MirMatchCase
} from "src/ir/mir/types.nx"

// ─── Helper naming ──────────────────────────────────────────────────────────

/** Canonical synthesized helper name for a named aggregate type. One helper per
 *  distinct type name; recursive / mutually-recursive references reuse the same
 *  name so the emitted wasm calls itself / its sibling. */
export let struct_eq_helper_name = fn (type_name: string) -> string do
  return "__streq_" ++ type_name
end

// Canonical key string for a list ELEMENT type. Distinct element types map to
// distinct keys (so `[i64]` and `[string]` get separate helpers); the SAME
// element type always maps to the same key, so a recursive `rest: [elem]` field
// self-calls the right helper. A type-parameter / unknown element erases to the
// generic key, whose helper bottoms out at an i64 value compare on the element
// (acceptable per the monomorphic-helper precedent — generic `List<T>` recursion
// is type-erased). The synthetic helper-bearing type name for `[elem]` is
// `List$<key(elem)>`, never collidable with a user type (`$` is not a legal
// identifier char), and shared so the helper recurses on itself.
let list_elem_key = fn (elem: TypeExpr) -> string do
  match elem do
    | TyI64 -> return "i64"
    | TyBool -> return "bool"
    | TyF64 -> return "f64"
    | TyChar -> return "char"
    | TyString -> return "string"
    | TyUserDefined(name: n, args: _) -> return n
    | TyList(elem: inner) -> return "List$" ++ list_elem_key(elem: inner)
    // An ANONYMOUS record element (`[{a, b}]`) carries no type name, so derive a
    // stable structural key from its (alphabetically sorted) field names + field
    // types. Two anon records that differ in field names OR field types get
    // distinct keys (hence distinct helpers); the SAME shape always maps to the
    // same key so a `rest: [{...}]` recursion self-calls the right helper. The
    // `$` / `_` separators are not legal identifier chars, so the synthesized
    // `List$Rec$...` name can never collide with a user type or another key.
    | TyRecord(fields: fs) -> return "Rec$" ++ anon_record_key(fields: fs)
    | _ -> return "T"
  end
end

// Stable key fragment for an anonymous record's field set: alphabetically sorted
// `name=type` pairs joined by `~` (so field order at the literal can't change the
// key, matching the alphabetical heap layout). Field types recurse through
// list_elem_key, so a nested anon-record / list field contributes structurally.
let anon_record_key = fn (fields: [ NamedType ]) -> string do
  return anon_record_key_go(fields: sort_named_fields(fields), first: true, acc: "")
end

let anon_record_key_go = fn (fields: [ NamedType ], first: bool, acc: string) -> string do
  match fields do
    | [] -> return acc
    | NamedType(name: n, typ: t) :: rest ->
      let piece = n ++ "=" ++ list_elem_key(elem: t)
      let acc2 = if first then piece else acc ++ "~" ++ piece end
      return anon_record_key_go(fields: rest, first: false, acc: acc2)
  end
end

// Sort record fields alphabetically by name (mirrors the alphabetical heap
// layout used by record extraction and `heap_index_of`).
let sort_named_fields = fn (fields: [ NamedType ]) -> [ NamedType ] do
  match fields do
    | [] -> return []
    | x :: rest -> return insert_sorted_field(f: x, sorted: sort_named_fields(fields: rest), acc: [])
  end
end

let insert_sorted_field = fn (f: NamedType, sorted: [ NamedType ], acc: [ NamedType ]) -> [ NamedType ] do
  let NamedType(name: fn_name, typ: _) = f
  match sorted do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: [ f ])
    | h :: rest ->
      let NamedType(name: hn, typ: _) = h
      if fn_name < hn then
        return list.concat(xs: list.reverse(xs: acc), ys: f :: sorted)
      else
        return insert_sorted_field(f, sorted: rest, acc: h :: acc)
      end
  end
end

// Synthetic helper-bearing type name for the list type `[elem]`.
let list_type_name = fn (elem: TypeExpr) -> string do
  return "List$" ++ list_elem_key(elem)
end

// The monomorphized `Cons`/`Nil` variant defs for `[elem]`, matching the
// built-in `List` layout (`Cons(v: elem, rest: [elem])`, `Nil`). Drives the
// list helper body's structural compare: the `v` field recurses on `elem`
// (string→string compare, record→its helper, list→its helper); the `rest`
// field recurses on `[elem]` → a self-call of this list's helper.
let list_variant_defs = fn (elem: TypeExpr) -> [ VariantDef ] do
  return [
    VariantDef(name: "Nil", fields: []),
    VariantDef(name: "Cons", fields: [
      VariantField(name: Some(val: "v"), typ: elem),
      VariantField(name: Some(val: "rest"), typ: TyList(elem)) ]) ]
end

// ─── Operand-type classification ────────────────────────────────────────────

let resolve_operand_type = fn (t: TypeExpr, ctx: LowerCtx) -> TypeExpr do
  // A named type may be a record alias (resolve to its TyRecord body) or a sum
  // (kept as TyUserDefined so the sum path can enumerate variants). Records
  // already arrive as TyRecord.
  let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed) = ctx
  match t do
    | TyUserDefined(name: _, args: _) -> return vidx.resolve_record_alias(idx: ed, typ: t)
    | _ -> return t
  end
end

/** True iff `op` is an equality operator (`==` / `!=`) — the only ops with a
 *  structural variant. Ordering comparisons (`<`, `<=`, …) are out of scope. */
export let is_struct_eq_op = fn (op: BinaryOp) -> bool do
  match op do
    | OpEq | OpNe -> return true
    | _ -> return false
  end
end

/** True iff `==`/`!=` on an operand of semantic type `t` needs a structural
 *  compare: `t` resolves to a record, or to a named sum with known variants.
 *  Primitives / strings / unknown (TyI64-erased) types return false and keep
 *  the legacy value/identity binary path. */
export let should_struct_eq = fn (t: TypeExpr, ctx: LowerCtx) -> bool do
  match resolve_operand_type(t, ctx) do
    | TyRecord(fields: _) -> return true
    // A `[elem]` list compares structurally (same length AND element-wise equal)
    // via a generated runtime helper, NOT the heap-pointer identity the legacy
    // binary path produces. Element structurality is preserved through the
    // helper keyed on `elem` (strings/records/nested lists recurse correctly).
    | TyList(elem: _) -> return true
    | TyUserDefined(name: en, args: _) ->
      let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed) = ctx
      match vidx.variants_of_enum(idx: ed, enum_name: en) do
        | [] -> return false
        | _ -> return true
      end
    | _ -> return false
  end
end

// `named_aggregate_name`: the helper-bearing type name of `t`, if `t` is a named
// sum (TyUserDefined with known variants) or a named record alias (TyUserDefined
// resolving to a TyRecord body). Anonymous TyRecord carries no name → None.

// True iff `elem`'s specific list helper (`__streq_List$<key(elem)>`) is among
// the generated set, so `[elem]` can route to it (preserving element
// structurality). Mirrors gen_struct_eq_helpers' coverage: primitives, named
// aggregates with in-scope structure, and ONE level of list-of-those. Anything
// else (deeper bare nesting, type vars, opaque enums) is uncovered and routes to
// the generic `__streq_List$T` helper, whose element compare is the i64 value
// compare (type-erased precedent).
let list_elem_covered = fn (elem: TypeExpr, ctx: LowerCtx) -> bool do
  match elem do
    | TyI64 | TyString | TyBool | TyF64 | TyChar -> return true
    // An ANONYMOUS record element (`[{a, b}]`) gets a structural list helper
    // whose head compare expands the record inline (compare_record). Always
    // covered — the helper is synthesized from the anon-record element types
    // harvested out of the MIR (see harvest_mir_anon_record_lists).
    | TyRecord(fields: _) -> return true
    | TyUserDefined(name: _, args: _) ->
      match resolve_operand_type(t: elem, ctx) do
        | TyRecord(fields: _) -> return true
        | TyUserDefined(name: en, args: _) ->
          let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed) = ctx
          match vidx.variants_of_enum(idx: ed, enum_name: en) do
            | [] -> return false
            | _ -> return true
          end
        | _ -> return false
      end
    // One nesting level: `[[prim]]` / `[[aggregate]]` / `[[{...}]]` are
    // generated; deeper not.
    | TyList(elem: inner) ->
      match inner do
        | TyI64 | TyString | TyBool | TyF64 | TyChar -> return true
        | TyRecord(fields: _) -> return list_elem_covered(elem: inner, ctx)
        | TyUserDefined(name: _, args: _) -> return list_elem_covered(elem: inner, ctx)
        | _ -> return false
      end
    | _ -> return false
  end
end

// Helper-bearing type name for a `[elem]` compare site: the specific element
// helper when covered, else the generic `List$T` fallback. The recursive `rest`
// field inside a helper resolves through this same routing on the SAME element
// type, so it self-calls the right helper consistently.
let list_site_type_name = fn (elem: TypeExpr, ctx: LowerCtx) -> string do
  if list_elem_covered(elem, ctx) then return list_type_name(elem)
  else return list_type_name(elem: TyVar(name: "T"))
  end
end

let named_aggregate_name = fn (t: TypeExpr, ctx: LowerCtx) -> Option<string> do
  match t do
    // `[elem]` routes to the per-element-type generated list helper. Returning a
    // name here makes `compare_values` emit a CALL (not an inline expansion), so
    // the recursive `rest` field terminates at run time like recursive sums do.
    | TyList(elem: et) -> return Some(val: list_site_type_name(elem: et, ctx))
    | TyUserDefined(name: n, args: _) ->
      // Either a record alias or a sum with known variants gets a helper.
      match resolve_operand_type(t, ctx) do
        | TyRecord(fields: _) -> return Some(val: n)
        | TyUserDefined(name: en, args: _) ->
          let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed) = ctx
          match vidx.variants_of_enum(idx: ed, enum_name: en) do
            | [] -> return None
            | _ -> return Some(val: en)
          end
        | _ -> return None
      end
    | _ -> return None
  end
end

// ─── Field-name layout (alphabetical, mirrors HIR sort_ctor_args / record sort)

let insert_sorted_name = fn (n: string, sorted: [ string ], acc: [ string ]) -> [ string ] do
  match sorted do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: [ n ])
    | h :: rest ->
      if n < h then
        return list.concat(xs: list.reverse(xs: acc), ys: n :: sorted)
      else
        return insert_sorted_name(n, sorted: rest, acc: h :: acc)
      end
  end
end

let sort_names = fn (ns: [ string ]) -> [ string ] do
  match ns do
    | [] -> return []
    | x :: rest -> return insert_sorted_name(n: x, sorted: sort_names(ns: rest), acc: [])
  end
end

// Alphabetical heap index of `name` among `all_names` (the field's position once
// the field-name set is sorted). Matches constructor_field_heap_index /
// sorted_named_type_index used everywhere else.
let heap_index_of = fn (name: string, all_names: [ string ]) -> i64 do
  return heap_index_go(name, sorted: sort_names(ns: all_names), idx: 0)
end

let heap_index_go = fn (name: string, sorted: [ string ], idx: i64) -> i64 do
  match sorted do
    | [] -> return idx
    | h :: rest ->
      if h == name then return idx
      else return heap_index_go(name, sorted: rest, idx: idx + 1)
      end
  end
end

// ─── Per-field load + recursive compare ─────────────────────────────────────

type CmpResult = CmpResult(ctx: LowerCtx, atom: LirAtom)

// Load `parent.field[heap_idx]` (object field at alphabetical index) for both
// operands and compare them structurally.
let compare_field = fn (
  lhs_parent: LirAtom,
  rhs_parent: LirAtom,
  heap_idx: i64,
  field_type: TypeExpr,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  // wasm slot type for the field load: strings flow as i64 packed handles but
  // must be TYPED TyString so the recursive compare routes through the string
  // path (codegen is_string_op trusts atom_type == TyString). Aggregates and
  // primitives load as i64.
  let load_wt = match resolve_operand_type(t: field_type, ctx) do
    | TyString -> TyString
    | _ -> TyI64
  end
  let BindResult(ctx: ctx1, atom: l_field) = bind_expr_to_temp(
    ctx,
    expr: LirExprObjectField(value: lhs_parent, index: heap_idx, typ: load_wt),
    typ: load_wt
  )
  let BindResult(ctx: ctx2, atom: r_field) = bind_expr_to_temp(
    ctx: ctx1,
    expr: LirExprObjectField(value: rhs_parent, index: heap_idx, typ: load_wt),
    typ: load_wt
  )
  return compare_values(l: l_field, r: r_field, sem_type: field_type, ctx: ctx2)
end

// Compare two already-loaded operand atoms of semantic type `sem_type`,
// emitting whatever statements the comparison needs and yielding a bool atom.
//
// A NAMED aggregate (sum / record alias) routes to a CALL of that type's
// generated helper — including recursive positions, which terminate at run time.
// An ANONYMOUS record is expanded inline one level (its aggregate fields recurse
// through their helpers). Everything else is a single value compare.
let compare_values = fn (
  l: LirAtom,
  r: LirAtom,
  sem_type: TypeExpr,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  match named_aggregate_name(t: sem_type, ctx) do
    | Some(val: nm) -> return call_helper(l, r, type_name: nm, ctx)
    | None ->
      match resolve_operand_type(t: sem_type, ctx) do
        | TyRecord(fields: fs) -> return compare_record(l, r, fields: fs, ctx)
        | _ -> return compare_primitive(l, r, ctx)
      end
  end
end

// Emit `__streq_<type_name>(l, r)` and bind the bool result. The args are
// emitted in sorted-param order (labels "l" < "r") so the positional
// internal-call ABI lines up with the helper's sorted params.
let call_helper = fn (
  l: LirAtom,
  r: LirAtom,
  type_name: string,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  let BindResult(ctx: ctx1, atom) = bind_expr_to_temp(
    ctx,
    expr: LirExprCall(
      func: struct_eq_helper_name(type_name),
      args: [ LirCallArg(label: "l", value: l), LirCallArg(label: "r", value: r) ],
      typ: TyBool
    ),
    typ: TyBool
  )
  return CmpResult(ctx: ctx1, atom)
end

// Primitive / string / type-param / opaque: a single value-compare binary.
// TyString operands route to emit_string_compare in codegen; everything else to
// i32/i64 eq.
let compare_primitive = fn (
  l: LirAtom,
  r: LirAtom,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  let BindResult(ctx: ctx1, atom) = bind_expr_to_temp(
    ctx,
    expr: LirExprBinary(op: OpEq, lhs: l, rhs: r, typ: TyBool),
    typ: TyBool
  )
  return CmpResult(ctx: ctx1, atom)
end

// ─── Record compare: AND-fold field comparisons ────────────────────────────

let record_field_names = fn (fields: [ NamedType ], acc: [ string ]) -> [ string ] do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: n, typ: _) :: rest -> return record_field_names(fields: rest, acc: n :: acc)
  end
end

let compare_record = fn (
  l: LirAtom,
  r: LirAtom,
  fields: [ NamedType ],
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  let all_names = record_field_names(fields, acc: [])
  return compare_record_go(l, r, fields, all_names, acc: None, ctx)
end

let compare_record_go = fn (
  l: LirAtom,
  r: LirAtom,
  fields: [ NamedType ],
  all_names: [ string ],
  acc: Option<LirAtom>,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  match fields do
    | [] ->
      match acc do
        | Some(val: a) -> return CmpResult(ctx, atom: a)
        // Empty record: structurally equal unconditionally.
        | None -> return CmpResult(ctx, atom: LirAtomBool(val: true))
      end
    | NamedType(name: fname, typ: ftyp) :: rest ->
      let heap_idx = heap_index_of(name: fname, all_names)
      let CmpResult(ctx: ctx1, atom: feq) = compare_field(
        lhs_parent: l, rhs_parent: r, heap_idx, field_type: ftyp, ctx
      )
      let next_acc = match acc do
        | None -> CmpResult(ctx: ctx1, atom: feq)
        | Some(val: prev) ->
          let BindResult(ctx: ctx2, atom: anded) = bind_expr_to_temp(
            ctx: ctx1,
            expr: LirExprBinary(op: OpAnd, lhs: prev, rhs: feq, typ: TyBool),
            typ: TyBool
          )
          CmpResult(ctx: ctx2, atom: anded)
      end
      let CmpResult(ctx: ctx3, atom: acc_atom) = next_acc
      return compare_record_go(l, r, fields: rest, all_names, acc: Some(val: acc_atom), ctx: ctx3)
  end
end

// ─── Sum compare: tag check then per-variant payload dispatch ───────────────

let variant_field_name = fn (vf: VariantField, pos_from_end: i64) -> string do
  let VariantField(name: n_opt, typ: _) = vf
  match n_opt do
    | Some(val: n) -> return n
    | None -> return str.from_i64(val: pos_from_end)
  end
end

let count_fields = fn (fs: [ VariantField ]) -> i64 do
  match fs do
    | [] -> return 0
    | _ :: rest -> return 1 + count_fields(fs: rest)
  end
end

// Build the (alphabetical) field-name list for a variant, matching
// get_variant_field_names in match_tree/emit.nx (positional fields named by
// their position-from-end).
let variant_field_names = fn (fs: [ VariantField ], acc: [ string ]) -> [ string ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | vf :: rest ->
      let nm = variant_field_name(vf, pos_from_end: count_fields(fs: rest))
      return variant_field_names(fs: rest, acc: nm :: acc)
  end
end

let arity_of = fn (vd: VariantDef) -> i64 do
  let VariantDef(name: _, fields: fs) = vd
  return count_fields(fs)
end

// Compare the payload fields of ONE variant (both operands already known to
// carry this variant's tag). AND-folds per-field comparisons; nullary → true.
let compare_variant_payload = fn (
  l: LirAtom,
  r: LirAtom,
  vd: VariantDef,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  let VariantDef(name: _, fields: fs) = vd
  let all_names = variant_field_names(fs, acc: [])
  return compare_variant_fields_go(l, r, fields: fs, all_names, acc: None, ctx)
end

let compare_variant_fields_go = fn (
  l: LirAtom,
  r: LirAtom,
  fields: [ VariantField ],
  all_names: [ string ],
  acc: Option<LirAtom>,
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  match fields do
    | [] ->
      match acc do
        | Some(val: a) -> return CmpResult(ctx, atom: a)
        | None -> return CmpResult(ctx, atom: LirAtomBool(val: true))
      end
    | VariantField(name: n_opt, typ: ftyp) :: rest ->
      let fname = match n_opt do
        | Some(val: n) -> n
        | None -> str.from_i64(val: count_fields(fs: rest))
      end
      let heap_idx = heap_index_of(name: fname, all_names)
      let CmpResult(ctx: ctx1, atom: feq) = compare_field(
        lhs_parent: l, rhs_parent: r, heap_idx, field_type: ftyp, ctx
      )
      let next_acc = match acc do
        | None -> CmpResult(ctx: ctx1, atom: feq)
        | Some(val: prev) ->
          let BindResult(ctx: ctx2, atom: anded) = bind_expr_to_temp(
            ctx: ctx1,
            expr: LirExprBinary(op: OpAnd, lhs: prev, rhs: feq, typ: TyBool),
            typ: TyBool
          )
          CmpResult(ctx: ctx2, atom: anded)
      end
      let CmpResult(ctx: ctx3, atom: acc_atom) = next_acc
      return compare_variant_fields_go(l, r, fields: rest, all_names,
                                       acc: Some(val: acc_atom), ctx: ctx3)
  end
end

// Sum equality: load both tags, require tag equality, then dispatch on the
// (shared) tag to the matching variant's payload compare. Variants are
// processed as a chain of `if tag_l == constructor_tag(V) then <payload eq>`;
// the trailing default yields `true` (tags already equal ⇒ same nullary /
// already-handled variant). The whole thing is AND'd with the tag-equality
// flag so a tag mismatch is `false` regardless of payload reads.
let compare_sum = fn (
  l: LirAtom,
  r: LirAtom,
  variants: [ VariantDef ],
  ctx: LowerCtx
) -> CmpResult throws { LirError } do
  // tag_l / tag_r
  let BindResult(ctx: c1, atom: tag_l) = bind_expr_to_temp(
    ctx, expr: LirExprObjectTag(value: l, typ: TyI64), typ: TyI64
  )
  let BindResult(ctx: c2, atom: tag_r) = bind_expr_to_temp(
    ctx: c1, expr: LirExprObjectTag(value: r, typ: TyI64), typ: TyI64
  )
  let BindResult(ctx: c3, atom: tags_eq) = bind_expr_to_temp(
    ctx: c2, expr: LirExprBinary(op: OpEq, lhs: tag_l, rhs: tag_r, typ: TyBool), typ: TyBool
  )
  // Pre-declare the payload-result temp; the guarded dispatch assigns it.
  let BindResult(ctx: c4, atom: payload_eq) = bind_expr_to_temp(
    ctx: c3, expr: LirExprBinary(op: OpEq, lhs: tag_l, rhs: tag_l, typ: TyBool), typ: TyBool
  )
  let payload_name = match payload_eq do
    | LirAtomVar(name: pn, typ: _) -> pn
    | _ -> ""
  end
  // Guard the per-variant payload compare behind tag equality. When the tags
  // DIFFER the payloads must NOT be read: with structural recursion a field of
  // the wrong-shaped operand would be loaded as a heap pointer and recursed
  // into, faulting on garbage. So: `if tags_eq then <dispatch> else payload=false`.
  let LowerCtx(vars: gv, semantic_vars: gsv, stmts: g_saved, temp_counter: gc, enum_defs: ged) = c4
  let then_ctx0 = LowerCtx(vars: gv, semantic_vars: gsv, stmts: [], temp_counter: gc, enum_defs: ged)
  let then_done = emit_variant_dispatch(l, r, tag_l, variants, payload_name, ctx: then_ctx0)
  let LowerCtx(vars: tv, semantic_vars: tsv, stmts: then_rev, temp_counter: tc, enum_defs: ted) = then_done
  let then_stmts = list.reverse(xs: then_rev)
  let else_stmts = [ LirStmtLet(name: payload_name, typ: TyBool, expr: LirExprAtom(atom: LirAtomBool(val: false))) ]
  let c5 = LowerCtx(
    vars: tv, semantic_vars: tsv,
    stmts: LirStmtIf(cond: tags_eq, then_body: then_stmts, else_body: else_stmts) :: g_saved,
    temp_counter: tc, enum_defs: ted
  )
  // result = tags_eq && payload_eq (payload_eq already false on tag mismatch).
  let BindResult(ctx: c6, atom: result) = bind_expr_to_temp(
    ctx: c5,
    expr: LirExprBinary(op: OpAnd, lhs: tags_eq, rhs: payload_eq, typ: TyBool),
    typ: TyBool
  )
  return CmpResult(ctx: c6, atom: result)
end

// Emit `if tag_l == ctor_tag(V) then payload_name = <V payload eq> else <rest>`
// chained over all variants. Each branch is lowered in an ISOLATED stmt list
// (saved/restored ctx.stmts) so the nested compares land inside the branch.
let emit_variant_dispatch = fn (
  l: LirAtom,
  r: LirAtom,
  tag_l: LirAtom,
  variants: [ VariantDef ],
  payload_name: string,
  ctx: LowerCtx
) -> LowerCtx throws { LirError } do
  match variants do
    | [] -> return ctx
    | vd :: rest ->
      let VariantDef(name: vname, fields: _) = vd
      let tag_val = constructor_tag(name: vname, arity: arity_of(vd))
      // cond = (tag_l == tag_val)
      let BindResult(ctx: c1, atom: cond) = bind_expr_to_temp(
        ctx,
        expr: LirExprBinary(op: OpEq, lhs: tag_l, rhs: LirAtomInt(val: tag_val), typ: TyBool),
        typ: TyBool
      )
      // THEN branch: compute this variant's payload eq into payload_name.
      let then_stmts = build_branch_stmts(
        l, r, vd, payload_name, ctx: c1
      )
      // ELSE branch: recurse over the remaining variants, again isolated.
      let LowerCtx(vars: ev, semantic_vars: esv, stmts: saved, temp_counter: ec, enum_defs: eed) = c1
      let else_ctx0 = LowerCtx(vars: ev, semantic_vars: esv, stmts: [],
                               temp_counter: ec, enum_defs: eed)
      let else_done = emit_variant_dispatch(l, r, tag_l, variants: rest,
                                            payload_name, ctx: else_ctx0)
      let LowerCtx(vars: ev2, semantic_vars: esv2, stmts: else_rev,
                   temp_counter: ec2, enum_defs: eed2) = else_done
      let else_stmts = list.reverse(xs: else_rev)
      // Re-emit the if into the ORIGINAL (restored) stmt stream.
      let c_final = LowerCtx(
        vars: ev2, semantic_vars: esv2,
        stmts: LirStmtIf(cond, then_body: then_stmts, else_body: else_stmts) :: saved,
        temp_counter: ec2, enum_defs: eed2
      )
      return c_final
  end
end

// Lower one variant's payload comparison in an isolated stmt list, with a
// trailing assignment of the result into `payload_name`. Returns the branch
// statement list (forward order).
let build_branch_stmts = fn (
  l: LirAtom,
  r: LirAtom,
  vd: VariantDef,
  payload_name: string,
  ctx: LowerCtx
) -> [ LirStmt ] throws { LirError } do
  let LowerCtx(vars: v, semantic_vars: sv, stmts: _, temp_counter: c, enum_defs: ed) = ctx
  let iso = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
  let CmpResult(ctx: iso2, atom: peq) = compare_variant_payload(l, r, vd, ctx: iso)
  let LowerCtx(vars: _, semantic_vars: _, stmts: body_rev, temp_counter: _, enum_defs: _) = iso2
  let assign = LirStmtLet(name: payload_name, typ: TyBool, expr: LirExprAtom(atom: peq))
  return list.reverse(xs: assign :: body_rev)
end

// ─── Generated runtime helpers ──────────────────────────────────────────────

let zero_span = Span(offset: 0, line: 0, col: 0)

// Build the body of a structural-compare helper for `sem_type` with the two
// operands bound to params `l` / `r`. Returns the helper's statement list
// (forward order) and the final bool result atom. The body compares ONE LEVEL
// of `sem_type`'s structure inline; aggregate field positions emit a CALL to the
// relevant helper (self-call for recursive positions), so recursion is at run
// time and always terminates on finite values.
let build_helper_body = fn (
  sem_type: TypeExpr,
  enum_defs: VariantIndex
) -> BindResult throws { LirError } do
  let l = LirAtomVar(name: "l", typ: TyI64)
  let r = LirAtomVar(name: "r", typ: TyI64)
  let ctx0 = LowerCtx(vars: [], semantic_vars: [], stmts: [], temp_counter: 0, enum_defs)
  // Dispatch on the type's own shape (NOT named_aggregate_name — that would emit
  // a self-call and never bottom out).
  let CmpResult(ctx: ctx1, atom: result) = match vidx.resolve_record_alias(idx: enum_defs, typ: sem_type) do
    | TyRecord(fields: fs) -> compare_record(l, r, fields: fs, ctx: ctx0)
    | TyUserDefined(name: en, args: _) ->
      match vidx.variants_of_enum(idx: enum_defs, enum_name: en) do
        | [] -> compare_primitive(l, r, ctx: ctx0)
        | vs -> compare_sum(l, r, variants: vs, ctx: ctx0)
      end
    | _ -> compare_primitive(l, r, ctx: ctx0)
  end
  let LowerCtx(vars: _, semantic_vars: _, stmts: body_rev, temp_counter: _, enum_defs: _) = ctx1
  return BindResult(ctx: ctx1, atom: result)
end

// Synthesize one `__streq_<Name>(l, r) -> bool` helper for a named aggregate.
let make_helper = fn (
  type_name: string,
  sem_type: TypeExpr,
  enum_defs: VariantIndex
) -> LirFunction throws { LirError } do
  let BindResult(ctx: ctx1, atom: result) = build_helper_body(sem_type, enum_defs)
  let LowerCtx(vars: _, semantic_vars: _, stmts: body_rev, temp_counter: _, enum_defs: _) = ctx1
  // Params labelled "l" < "r" so sort_lir_params keeps [l, r]; call sites emit
  // args in that same order (positional internal-call ABI).
  return LirFunction(
    name: struct_eq_helper_name(type_name),
    params: [ LirParam(label: "l", name: "l", typ: TyI64),
              LirParam(label: "r", name: "r", typ: TyI64) ],
    ret_type: TyBool,
    body: list.reverse(xs: body_rev),
    ret: result,
    span: zero_span
  )
end

// Synthesize the `__streq_List$<key>(l, r) -> bool` helper for the list type
// `[elem]`. Body = a sum compare over the monomorphized `Nil`/`Cons` variants:
// equal iff same tag (both Nil, or both Cons) AND, for Cons, the head `v`
// (type `elem`) and tail `rest` (type `[elem]`) are both structurally equal.
// The `rest` recursion self-calls this same helper (terminates on finite data);
// the `v` recursion routes through `elem`'s own compare path so strings, records
// and nested lists compare structurally rather than by i64 identity.
let make_list_helper = fn (
  elem: TypeExpr,
  enum_defs: VariantIndex
) -> LirFunction throws { LirError } do
  let l = LirAtomVar(name: "l", typ: TyI64)
  let r = LirAtomVar(name: "r", typ: TyI64)
  let ctx0 = LowerCtx(vars: [], semantic_vars: [], stmts: [], temp_counter: 0, enum_defs)
  let CmpResult(ctx: ctx1, atom: result) = compare_sum(l, r, variants: list_variant_defs(elem: elem), ctx: ctx0)
  let LowerCtx(vars: _, semantic_vars: _, stmts: body_rev, temp_counter: _, enum_defs: _) = ctx1
  return LirFunction(
    name: struct_eq_helper_name(type_name: list_type_name(elem: elem)),
    params: [ LirParam(label: "l", name: "l", typ: TyI64),
              LirParam(label: "r", name: "r", typ: TyI64) ],
    ret_type: TyBool,
    body: list.reverse(xs: body_rev),
    ret: result,
    span: zero_span
  )
end

let make_enum_helpers = fn (
  defs: [ EnumDef ],
  enum_defs: VariantIndex,
  acc: [ LirFunction ]
) -> [ LirFunction ] throws { LirError } do
  match defs do
    | [] -> return list.reverse(xs: acc)
    | EnumDef(name: en, is_public: _, is_opaque: _, type_params: _, variants: vs, layout_variants: _) :: rest ->
      // Skip enums with no in-scope variants (opaque imported) — no structure to
      // compare; a compare on such a value keeps the legacy i64 path.
      let acc2 = match vs do
        | [] -> acc
        | _ -> make_helper(type_name: en, sem_type: TyUserDefined(name: en, args: []), enum_defs) :: acc
      end
      return make_enum_helpers(defs: rest, enum_defs, acc: acc2)
  end
end

let make_record_helpers = fn (
  defs: [ RecordDef ],
  enum_defs: VariantIndex,
  acc: [ LirFunction ]
) -> [ LirFunction ] throws { LirError } do
  match defs do
    | [] -> return list.reverse(xs: acc)
    | RecordDef(name: rn, is_public: _, type_params: _, fields: fs) :: rest ->
      let helper = make_helper(type_name: rn, sem_type: TyRecord(fields: fs), enum_defs)
      return make_record_helpers(defs: rest, enum_defs, acc: helper :: acc)
  end
end

// ─── List-helper element-type collection ────────────────────────────────────
//
// `[elem] == [elem]` lowers to a CALL of `__streq_List$<key(elem)>`. One such
// helper must be synthesized per distinct element type that any list `==`/`!=`
// compares. The element type lives at the `==` site (in the MIR/semantic type)
// and is NOT recovered here, so the set is over-approximated from the program's
// declared shapes plus the primitive base set: every concrete element type a
// list literal/value can carry is covered (primitives, every named aggregate,
// one level of list-of-list per the spec's nested-list requirement). Unused
// helpers are harmless — they reference only themselves and `elem`'s helper,
// both of which are generated. An element type outside this set (e.g. an
// uncommon deeper nesting) falls back to the generic `T`-keyed helper, whose
// element compare is the i64 value compare (the type-erased precedent).

// Add `e` to `acc` keyed by `list_type_name` (dedup by helper name).
let push_elem = fn (e: TypeExpr, acc: [ TypeExpr ]) -> [ TypeExpr ] do
  return push_elem_go(e, key: list_type_name(elem: e), rest: acc, full: acc)
end

let push_elem_go = fn (e: TypeExpr, key: string, rest: [ TypeExpr ], full: [ TypeExpr ]) -> [ TypeExpr ] do
  match rest do
    | [] -> return e :: full
    | h :: tl ->
      if list_type_name(elem: h) == key then return full
      else return push_elem_go(e, key, rest: tl, full)
      end
  end
end

// Harvest the list element types reachable from a field type: a `[e]` field
// contributes `[e]`, and the recursion into `e` contributes any nested `[[..]]`.
let harvest_type = fn (t: TypeExpr, acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match t do
    | TyList(elem: e) ->
      // record `[e]` itself as a needed helper; recurse into `e` (covers `[[x]]`).
      let acc1 = push_elem(e, acc)
      return harvest_type(t: e, acc: acc1)
    | _ -> return acc
  end
end

let enum_field_types = fn (defs: [ EnumDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs, layout_variants: _) :: rest ->
      return enum_field_types(defs: rest, acc: variant_list_field_types(vs, acc))
  end
end

let variant_list_field_types = fn (vs: [ VariantDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match vs do
    | [] -> return acc
    | VariantDef(name: _, fields: fs) :: rest ->
      return variant_list_field_types(vs: rest, acc: variant_field_types_go(fs, acc))
  end
end

let variant_field_types_go = fn (fs: [ VariantField ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match fs do
    | [] -> return acc
    | VariantField(name: _, typ: t) :: rest -> return variant_field_types_go(fs: rest, acc: harvest_type(t, acc))
  end
end

let record_field_types = fn (defs: [ RecordDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | RecordDef(name: _, is_public: _, type_params: _, fields: fs) :: rest ->
      return record_field_types(defs: rest, acc: record_field_types_go(fs, acc))
  end
end

let record_field_types_go = fn (fs: [ NamedType ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match fs do
    | [] -> return acc
    | NamedType(name: _, typ: t) :: rest -> return record_field_types_go(fs: rest, acc: harvest_type(t, acc))
  end
end

// Element types whose `[elem]` list helper is always synthesized: the primitive
// base set, every named aggregate (record/enum), and one nested level of
// list-of-each so a bare `[[1], [2]]` (`[[i64]]`) compare resolves its helper.
let enum_name_elems = fn (defs: [ EnumDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | EnumDef(name: en, is_public: _, is_opaque: _, type_params: _, variants: vs, layout_variants: _) :: rest ->
      let acc2 = match vs do
        | [] -> acc
        | _ -> push_elem(e: TyUserDefined(name: en, args: []), acc)
      end
      return enum_name_elems(defs: rest, acc: acc2)
  end
end

let record_name_elems = fn (defs: [ RecordDef ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match defs do
    | [] -> return acc
    | RecordDef(name: rn, is_public: _, type_params: _, fields: _) :: rest ->
      return record_name_elems(defs: rest, acc: push_elem(e: TyUserDefined(name: rn, args: []), acc))
  end
end

let primitive_elems = fn () -> [ TypeExpr ] do
  return [ TyI64, TyString, TyBool, TyF64, TyChar ]
end

let seed_elems_into = fn (xs: [ TypeExpr ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match xs do
    | [] -> return acc
    | x :: rest -> return seed_elems_into(xs: rest, acc: push_elem(e: x, acc))
  end
end

// Add `[base]` as a new element for every base element, so a bare list-of-list
// (`[[i64]]`) compare has its helper. One nesting level covers the spec's
// nested-list requirement; deeper nesting falls back to the generic helper.
let nest_one_level = fn (bases: [ TypeExpr ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match bases do
    | [] -> return acc
    | b :: rest -> return nest_one_level(bases: rest, acc: push_elem(e: TyList(elem: b), acc))
  end
end

let make_list_helpers = fn (
  elems: [ TypeExpr ],
  enum_defs: VariantIndex,
  acc: [ LirFunction ]
) -> [ LirFunction ] throws { LirError } do
  match elems do
    | [] -> return list.reverse(xs: acc)
    | e :: rest -> return make_list_helpers(elems: rest, enum_defs, acc: make_list_helper(elem: e, enum_defs) :: acc)
  end
end

// ─── ANONYMOUS-record list-element harvesting (from MIR) ────────────────────
//
// A list whose element is an ANONYMOUS record (`[{a, b}]`) has no declared type
// name, so its `__streq_List$Rec$...` helper cannot be seeded from the program's
// EnumDef / RecordDef tables (the named-aggregate path). The element shape is
// only visible in the MIR. A list LITERAL `[{...}]` (and `::`) desugars to the
// built-in list constructors `Cons(rest, v)` / `Nil` — alphabetical ctor args
// `[rest, v]`, so the head record value `v` sits at index 1. We therefore walk
// the MIR and, for every record-head `Cons`, push the list ELEMENT type
// (`TyRecord(field-types)`, or `TyList(TyRecord(...))` for `[[{...}]]`) so the
// matching helper is synthesized. Field types are recovered structurally from the
// head record's field values (literals, nested records, nested lists); a field
// whose value is not statically classifiable falls back to TyI64 (the same
// type-erased value compare the generic helper uses), which still compares the
// field by value. The collected set is over-approximate and dedup'd by helper
// name (push_elem); unused helpers are harmless.

// Best-effort structural type of a MIR expression WITHOUT a LowerCtx: only the
// shapes needed to key an anonymous-record list element (literals, anon records,
// list constructors). Everything else erases to TyI64 (value compare).
let mir_field_type = fn (e: MirExpr) -> TypeExpr do
  match e do
    | MirLiteral(lit: l) ->
      match l do
        | LitInt(_) -> return TyI64
        | LitFloat(_) -> return TyF64
        | LitBool(_) -> return TyBool
        | LitChar(_) -> return TyChar
        | LitString(_) -> return TyString
        | LitUnit -> return TyUnit
      end
    | MirRecord(fields: fs) -> return TyRecord(fields: mir_record_field_types(fields: fs))
    | MirConstructor(name: cn, args: cargs) ->
      // List literals desugar to `Cons(rest, v)` / `Nil`; recover `[elem]` from
      // the head value `v` (alphabetical args put `rest` at 0, `v` at 1).
      if cn == "Cons" then
        match cargs do
          | _ :: v :: _ -> return TyList(elem: mir_field_type(e: v))
          | _ -> return TyI64
        end
      else if cn == "Nil" then return TyI64
      else return TyI64
      end
    | MirArray(elems: es) ->
      match es do
        | x :: _ -> return TyList(elem: mir_field_type(e: x))
        | [] -> return TyI64
      end
    | _ -> return TyI64
  end
end

let mir_record_field_types = fn (fields: [ MirNamedExpr ]) -> [ NamedType ] do
  match fields do
    | [] -> return []
    | MirNamedExpr(name: n, value: v) :: rest ->
      return NamedType(name: n, typ: mir_field_type(e: v)) :: mir_record_field_types(fields: rest)
  end
end

// Does a list-element type carry an anonymous record anywhere a generated helper
// would need (the element itself, or under one or more `[..]` nestings)? Only
// such elements need MIR-harvested helpers — primitive / named-aggregate element
// helpers are already seeded from the type tables. (TyVar / opaque erase to a
// value compare and don't need a structural helper.)
let elem_carries_anon_record = fn (t: TypeExpr) -> bool do
  match t do
    | TyRecord(fields: _) -> return true
    | TyList(elem: inner) -> return elem_carries_anon_record(t: inner)
    | _ -> return false
  end
end

// Given the HEAD value of a list `Cons(rest, v)` (the head element `v`), push the
// list ELEMENT type when that head is (or nests) an anonymous record, so the
// corresponding `__streq_List$Rec$...` / `__streq_List$List$Rec$...` helper is
// synthesized. `mir_field_type` recovers the head's structural shape: a
// `MirRecord` head → `TyRecord` (element of `[{...}]`); a `Cons` head whose own
// head is a record → `TyList(TyRecord)` (element of `[[{...}]]`). Heads with no
// anon record push nothing (their list helpers, if any, are seeded elsewhere).
// Dedup'd by helper name via push_elem.
let push_anon_record_elem = fn (head: MirExpr, acc: [ TypeExpr ]) -> [ TypeExpr ] do
  let elem = mir_field_type(e: head)
  if elem_carries_anon_record(t: elem) then return push_elem(e: elem, acc)
  else return acc
  end
end

// Walk a MIR expression, pushing the anonymous-record list-element type for every
// list `Cons` (a list literal `[{...}]` / `::` desugars to `Cons`) whose head is
// (or nests) an anonymous record. Recurses through every sub-expression /
// statement so nested occurrences are caught.
let harvest_expr = fn (e: MirExpr, acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match e do
    | MirConstructor(name: cn, args: cargs) ->
      // A list literal `[{...}]` (and `::`) desugars to `Cons(rest, v)` — the
      // load-bearing case. Alphabetical ctor args `[rest, v]` put the head value
      // `v` at index 1; a record head means this is a list-of-anonymous-records,
      // so push its element type and the `__streq_List$Rec$...` helper is built.
      let acc1 = if cn == "Cons" then
        match cargs do
          | _ :: head :: _ -> push_anon_record_elem(head, acc)
          | _ -> acc
        end
      else acc end
      return harvest_exprs(es: cargs, acc: acc1)
    | MirRecord(fields: fs) -> return harvest_named_exprs(fs, acc)
    // A `MirArray` is the fixed-ARRAY form (`[T]` array). List literals desugar to
    // `Cons`, not this, and arrays never reach the list `==` helper path
    // (should_struct_eq / named_aggregate_name have no TyArray arm), so no element
    // helper is harvested here — just recurse for any nested record literals.
    | MirArray(elems: es) -> return harvest_exprs(es, acc)
    | MirBinaryOp(left: l, op: _, right: r) -> return harvest_expr(e: r, acc: harvest_expr(e: l, acc))
    | MirCall(func: _, args: cas, ret_type: _) -> return harvest_call_args(cas, acc)
    | MirCallClosure(closure: c, args: cas, ret_type: _) -> return harvest_call_args(cas, acc: harvest_expr(e: c, acc))
    | MirIndex(target: t, index: i) -> return harvest_expr(e: i, acc: harvest_expr(e: t, acc))
    | MirFieldAccess(target: t, field: _) -> return harvest_expr(e: t, acc)
    | MirIf(cond: c, then_body: tb, else_body: eb) ->
      let acc1 = harvest_expr(e: c, acc)
      let acc2 = harvest_stmts(stmts: tb, acc: acc1)
      match eb do
        | Some(val: ebs) -> return harvest_stmts(stmts: ebs, acc: acc2)
        | None -> return acc2
      end
    | MirMatch(target: t, cases: cs) -> return harvest_cases(cs, acc: harvest_expr(e: t, acc))
    | MirWhile(cond: c, body: b) -> return harvest_stmts(stmts: b, acc: harvest_expr(e: c, acc))
    | MirRaise(expr: x) -> return harvest_expr(e: x, acc)
    | MirForce(expr: x) -> return harvest_expr(e: x, acc)
    | MirMakeClosure(func_name: _, captures: cs) -> return harvest_exprs(es: cs, acc)
    | MirSuspend(tag_name: _, payload: p, ret_type: _) -> return harvest_expr(e: p, acc)
    | MirResume(cont_var: _, value: v, ret_type: _) -> return harvest_expr(e: v, acc)
    | MirBlock(stmts: ss) -> return harvest_stmts(stmts: ss, acc)
    | _ -> return acc
  end
end

let harvest_exprs = fn (es: [ MirExpr ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match es do
    | [] -> return acc
    | x :: rest -> return harvest_exprs(es: rest, acc: harvest_expr(e: x, acc))
  end
end

let harvest_named_exprs = fn (fs: [ MirNamedExpr ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match fs do
    | [] -> return acc
    | MirNamedExpr(name: _, value: v) :: rest -> return harvest_named_exprs(fs: rest, acc: harvest_expr(e: v, acc))
  end
end

let harvest_call_args = fn (cas: [ MirCallArg ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match cas do
    | [] -> return acc
    | MirCallArg(label: _, value: v) :: rest -> return harvest_call_args(cas: rest, acc: harvest_expr(e: v, acc))
  end
end

let harvest_cases = fn (cs: [ MirMatchCase ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match cs do
    | [] -> return acc
    | MirMatchCase(pattern: _, body: b) :: rest -> return harvest_cases(cs: rest, acc: harvest_stmts(stmts: b, acc))
  end
end

let harvest_stmts = fn (stmts: [ MirStmt ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match stmts do
    | [] -> return acc
    | s :: rest -> return harvest_stmts(stmts: rest, acc: harvest_stmt(s, acc))
  end
end

let harvest_stmt = fn (s: MirStmt, acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match s do
    | MirStmtLet(name: _, typ: _, expr: e) -> return harvest_expr(e, acc)
    | MirStmtExpr(expr: e) -> return harvest_expr(e, acc)
    | MirStmtReturn(expr: e) -> return harvest_expr(e, acc)
    | MirStmtAssign(target: t, value: v) -> return harvest_expr(e: v, acc: harvest_expr(e: t, acc))
    | MirStmtTry(body: b, catch_param: _, catch_body: cb) ->
      return harvest_stmts(stmts: cb, acc: harvest_stmts(stmts: b, acc))
    | _ -> return acc
  end
end

let harvest_mir_funcs = fn (funcs: [ MirFunction ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match funcs do
    | [] -> return acc
    | MirFunction(name: _, params: _, ret_type: _, body: b, span: _) :: rest ->
      return harvest_mir_funcs(funcs: rest, acc: harvest_stmts(stmts: b, acc))
  end
end

/** Synthesize the structural-compare helper functions for every named aggregate
 *  type in the program — one per `EnumDef` (with in-scope variants) and one per
 *  record-alias `RecordDef` — plus one per distinct list element type
 *  (`__streq_List$<key>`). Appended to the LirProgram by `lower_mir_to_lir`.
 *  Recursive and mutually-recursive references resolve to the same helper names,
 *  so the emitted wasm recurses at run time and terminates on finite data.
 *  `mir_funcs` supplies the MIR functions so anonymous-record list element types
 *  (`[{...}]`, which have no declared type name to seed from) can be harvested
 *  structurally and get their own list helpers. */
export let gen_struct_eq_helpers = fn (
  enum_def_list: [ EnumDef ],
  record_defs: [ RecordDef ],
  enum_defs: VariantIndex,
  mir_funcs: [ MirFunction ]
) -> [ LirFunction ] throws { LirError } do
  let enum_helpers = make_enum_helpers(defs: enum_def_list, enum_defs, acc: [])
  let record_helpers = make_record_helpers(defs: record_defs, enum_defs, acc: [])
  // Collect the list element types needing a helper: primitives + named
  // aggregates + one nested level, plus every list element harvested from the
  // program's declared record/variant field shapes (any depth). A generic
  // `T`-keyed helper is always present as the fallback for unrecovered/erased
  // element types.
  let base = seed_elems_into(xs: primitive_elems(), acc: [])
  let base1 = enum_name_elems(defs: enum_def_list, acc: base)
  let base2 = record_name_elems(defs: record_defs, acc: base1)
  // Anonymous-record list element types harvested from the MIR (`[{...}]` has no
  // declared type name to seed from). Recorded BEFORE nest_one_level so a bare
  // `[[{...}]]` (list-of-list-of-anon-record) also gets its helper.
  let base3 = harvest_mir_funcs(funcs: mir_funcs, acc: base2)
  let nested = nest_one_level(bases: base3, acc: base3)
  let with_enum_fields = enum_field_types(defs: enum_def_list, acc: nested)
  let with_rec_fields = record_field_types(defs: record_defs, acc: with_enum_fields)
  // Generic erased-element fallback helper (`__streq_List$T`).
  let all_elems = push_elem(e: TyVar(name: "T"), acc: with_rec_fields)
  let list_helpers = make_list_helpers(elems: all_elems, enum_defs, acc: [])
  return list.concat(xs: list.concat(xs: enum_helpers, ys: record_helpers), ys: list_helpers)
end

// ─── Entry point ────────────────────────────────────────────────────────────

/** Lower `lhs op rhs` (op ∈ {OpEq, OpNe}) on a record / sum operand to a
 *  structural compare, returning the result atom. A NAMED aggregate routes to a
 *  CALL of its generated helper (`__streq_<Name>`); an ANONYMOUS record is
 *  expanded inline. `op == OpNe` negates the structural-equal result. Callers
 *  must guard with `should_struct_eq` first. */
export let lower_struct_eq = fn (
  op: BinaryOp,
  lhs: LirAtom,
  rhs: LirAtom,
  sem_type: TypeExpr,
  ctx: LowerCtx
) -> BindResult throws { LirError } do
  let CmpResult(ctx: ctx1, atom: eq_atom) = compare_values(l: lhs, r: rhs, sem_type: sem_type, ctx)
  match op do
    | OpNe ->
      // != is `eq == false`.
      let BindResult(ctx: ctx2, atom: neq) = bind_expr_to_temp(
        ctx: ctx1,
        expr: LirExprBinary(op: OpEq, lhs: eq_atom, rhs: LirAtomBool(val: false), typ: TyBool),
        typ: TyBool
      )
      return BindResult(ctx: ctx2, atom: neq)
    | _ -> return BindResult(ctx: ctx1, atom: eq_atom)
  end
end
