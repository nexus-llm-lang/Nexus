/**
 * match_tree/emit: Pure emission helpers shared by lir.nx.
 *
 * Owns:
 * - Field-extraction for constructor + record scrutinees
 * - Constructor- and literal-condition builders
 * - Pattern-binding emission (lir_emit_bindings)
 * - Small utilities: lir_nth_case_body, lir_nth_string, lir_ctors_length,
 *   lir_reverse_atoms, lir_builtin_field_mem_idx
 */
import { OpEq, OpFEq, Literal, LitFloat } from "src/types/vocab.nx"
import {
  TypeExpr,
  TyI64,
  TyBool,
  TyRecord,
  NamedType,
  VariantDef,
  VariantField
} from "src/types/type_expr.nx"
import { LirError, LirAtomEntryNotFound } from "src/ir/lir/errors.nx"
import { Some, None } from "std:option"
import { MirStmt, MirMatchCase } from "src/ir/mir/types.nx"
import {
  LirAtom,
  LirAtomInt,
  LirAtomBool,
  LirExprAtom,
  LirExprBinary,
  LirExprObjectField,
  LirStmt,
  LirStmtLet
} from "src/ir/lir/types.nx"
import {
  LowerCtx,
  BindResult,
  insert_type,
  atom_type,
  wasm_type,
  bind_expr_to_temp,
  bind_expr_to_temp_semantic,
  literal_to_atom
} from "src/ir/lir/context.nx"
import {
  PatBinding,
  AtomEntry,
  CtorBranch,
  LitBranch,
  CtorCondsResult,
  LitCondsResult,
  FieldExtractResult,
  FieldLoopResult
} from "src/ir/lir/match_tree/types.nx"
import { VariantIndex }, * as vidx from "src/ir/support/variant_index.nx"
import * as str from "std:str"
import * as list from "std:list"

/** Public function lookup_atom_entry. */
export let lookup_atom_entry = fn (
  id: i64,
  atoms: [ AtomEntry ]
) -> AtomEntry throws { LirError } do
  match atoms do
    | [] -> throw LirAtomEntryNotFound(id)
    | AtomEntry(id: eid, atom: a, sem_type: st) :: rest ->
      if eid == id then return AtomEntry(id: eid, atom: a, sem_type: st)
      else return lookup_atom_entry(id, atoms: rest)
      end
  end
end

/** Public function lir_reverse_atoms. */
export let lir_reverse_atoms = fn (
  lst: [ LirAtom ],
  acc: [ LirAtom ]
) -> [ LirAtom ] throws { LirError } do
  match lst do
    | [] -> return acc
    | x :: rest -> return lir_reverse_atoms(lst: rest, acc: x :: acc)
  end
end

/** Public function lir_ctors_length. */
export let lir_ctors_length = fn (lst: [ CtorBranch ]) -> i64 throws { LirError } do
  match lst do
    | [] -> return 0
    | _ :: rest -> return 1 + lir_ctors_length(lst: rest)
  end
end

/** Public function lir_nth_case_body. */
export let lir_nth_case_body = fn (
  cases: [ MirMatchCase ],
  idx: i64
) -> [ MirStmt ] throws { LirError } do
  match cases do
    | [] -> return []
    | MirMatchCase(pattern: _, body: b) :: rest ->
      if idx == 0 then return b
      else return lir_nth_case_body(cases: rest, idx: idx - 1)
      end
  end
end

let lir_nth_string = fn (lst: [ string ], n: i64) -> string throws { LirError } do
  match lst do
    | [] -> return ""
    | x :: rest ->
      if n == 0 then return x
      else return lir_nth_string(lst: rest, n: n - 1)
      end
  end
end

// Map definition-order field index to memory (sorted) index for built-in constructors.
// Cons(v, rest): sorted [rest(0), v(1)] → def 0(v)→mem 1, def 1(rest)→mem 0.
// Some(val): only 1 field, no reordering.
let lir_builtin_field_mem_idx = fn (ctor_name: string, def_idx: i64) -> i64 throws { LirError } do
  if ctor_name == "Cons" then
    if def_idx == 0 then return 1 else return 0 end
  end
  return def_idx
end

// Concrete type arguments carried by a scrutinee's semantic type, in the order
// of the owning enum's `type_params`. A `match` over a generic container binds
// constructor fields whose DECLARED type is a bare type-param (`Cons.v : T`,
// `MkPair.fst : X`); substituting these args lets the field's real type reach
// the bound variable so `.field` doesn't abort LIR with E6002 (nexus-n5gub).
//   TyList(e)            → [e]            (built-in List<T>)
//   TyUserDefined(_, as) → as            (user generic enum / record alias)
// Other shapes carry no args; substitution then leaves type-params untouched.
let scrutinee_type_args = fn (scr_sem: TypeExpr) -> [ TypeExpr ] do
  match scr_sem do
    | TyList(elem: e) -> return [ e ]
    | TyUserDefined(name: _, args: a) -> return a
    | _ -> return []
  end
end

// Substitute bare type-param occurrences (`TyVar(p_i)`) in `typ` with the
// corresponding concrete arg, pairing `params[i]` with `args[i]` positionally.
// One level deep is enough for variant fields (`T`, `[T]`, `Foo<T>`); recursive
// record bodies stay unexpanded so cyclic types never loop.
let subst_type_params = fn (typ: TypeExpr, params: [ string ], args: [ TypeExpr ]) -> TypeExpr throws { LirError } do
  match typ do
    | TyVar(name: n) -> return lookup_type_param(name: n, params, args)
    | TyList(elem: e) -> return TyList(elem: subst_type_params(typ: e, params, args))
    | TyArray(elem: e) -> return TyArray(elem: subst_type_params(typ: e, params, args))
    | TyUserDefined(name: n, args: a) ->
      // Bare type-param references reach LIR as `TyUserDefined(n, [])` (the
      // frontend has not run convert_ud_to_var on these enum_defs), so an
      // arg-less user type whose name is a declared type-param IS a type-param
      // occurrence — substitute it. Named types keep their (recursed) args.
      if string_in(name: n, names: params) && is_empty_args(a) then
        return lookup_type_param(name: n, params, args)
      else
        return TyUserDefined(name: n, args: subst_type_params_list(types: a, params, args))
      end
    | _ -> return typ
  end
end

let is_empty_args = fn (a: [ TypeExpr ]) -> bool do
  match a do
    | [] -> return true
    | _ -> return false
  end
end

let string_in = fn (name: string, names: [ string ]) -> bool do
  match names do
    | [] -> return false
    | n :: rest -> if n == name then return true else return string_in(name, names: rest) end
  end
end

let subst_type_params_list = fn (types: [ TypeExpr ], params: [ string ], args: [ TypeExpr ]) -> [ TypeExpr ] throws { LirError } do
  match types do
    | [] -> return []
    | t :: rest -> return subst_type_params(typ: t, params, args) :: subst_type_params_list(types: rest, params, args)
  end
end

// The owning enum's type-param names for a constructor (`List` → ["T"],
// `Pair` → ["X","Y"]). Empty when the ctor is unknown or monomorphic.
let variant_type_params = fn (idx: VariantIndex, ctor_name: string) -> [ string ] throws { LirError } do
  match vidx.lookup_variant_info(idx, variant: ctor_name) do
    | Some(val: vidx.VariantInfo(enum_name: _, type_params: tps, def: _)) -> return tps
    | None -> return []
  end
end

let lookup_type_param = fn (name: string, params: [ string ], args: [ TypeExpr ]) -> TypeExpr throws { LirError } do
  match params do
    | [] -> return TyVar(name)
    | p :: rest_p ->
      match args do
        | [] -> return TyVar(name)
        | a :: rest_a ->
          if p == name then return a
          else return lookup_type_param(name, params: rest_p, args: rest_a)
          end
      end
  end
end

let lir_str_less_than_loop = fn (
  a: string,
  b: string,
  idx: i64,
  la: i64,
  lb: i64
) -> bool throws { LirError } do
  if idx >= la then
    return idx < lb
  else if idx >= lb then
    return false
  else
    let ca = str.char_code(s: a, idx)
    let cb = str.char_code(s: b, idx)
    if ca < cb then
      return true
    else if ca > cb then
      return false
    else
      return lir_str_less_than_loop(a, b, idx: idx + 1, la, lb)
    end
  end
end

let lir_str_less_than = fn (a: string, b: string) -> bool throws { LirError } do
  return lir_str_less_than_loop(a, b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end

let sorted_field_index = fn (
  field_name: string,
  all_names: [ string ]
) -> i64 throws { LirError } do
  match all_names do
    | [] -> return 0
    | n :: rest ->
      if lir_str_less_than(a: n, b: field_name) then
        return 1 + sorted_field_index(field_name, all_names: rest)
      else
        return sorted_field_index(field_name, all_names: rest)
      end
  end
end

let lookup_variant_def = fn (name: string, enum_defs: VariantIndex) -> Option<VariantDef> do
  return vidx.lookup_variant_def_in_index(idx: enum_defs, variant: name)
end

let count_variant_fields = fn (fields: [ VariantField ]) -> i64 throws { LirError } do
  match fields do
    | [] -> return 0
    | _ :: rest -> return 1 + count_variant_fields(fields: rest)
  end
end

let extract_variant_field_names_go = fn (
  fields: [ VariantField ],
  acc: [ string ]
) -> [ string ] throws { LirError } do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | VariantField(name: n_opt, typ: _) :: rest ->
      let field_name = match n_opt do
        | Some(val: n) -> n
        | None -> str.from_i64(val: count_variant_fields(fields: rest))
      end
      return extract_variant_field_names_go(fields: rest, acc: field_name :: acc)
  end
end

let get_variant_field_names = fn (vd: VariantDef) -> [ string ] throws { LirError } do
  let VariantDef(name: _, fields: fs) = vd
  return extract_variant_field_names_go(fields: fs, acc: [])
end

let lookup_variant_field_type = fn (
  fields: [ VariantField ],
  name: string
) -> TypeExpr throws { LirError } do
  match fields do
    | [] -> return TyI64
    | VariantField(name: Some(val: n), typ: t) :: rest ->
      if n == name then return t
      else return lookup_variant_field_type(fields: rest, name)
      end
    | VariantField(name: None, typ: _) :: rest ->
      return lookup_variant_field_type(fields: rest, name)
  end
end

let constructor_field_type = fn (
  field_name: string,
  ctor_name: string,
  enum_defs: VariantIndex
) -> TypeExpr throws { LirError } do
  match lookup_variant_def(name: ctor_name, enum_defs) do
    | Some(val: VariantDef(name: _, fields: fs)) ->
      let raw = lookup_variant_field_type(fields: fs, name: field_name)
      // A field whose declared type is a NAMED record alias (`inner: Inner`)
      // arrives here as `TyUserDefined("Inner", …)`. Expand it to its
      // `TyRecord` body so the bound variable's semantic type carries the
      // field shape, otherwise `.field` access on that binding aborts LIR
      // with E6002 (nexus-xs3dl). Non-record / unknown types pass through.
      return vidx.resolve_record_alias(idx: enum_defs, typ: raw)
    | None -> return TyI64
  end
end

let constructor_field_heap_index = fn (
  field_name: string,
  ctor_name: string,
  enum_defs: VariantIndex
) -> i64 throws { LirError } do
  match lookup_variant_def(name: ctor_name, enum_defs) do
    | Some(val: vd) ->
      let all_names = get_variant_field_names(vd)
      return sorted_field_index(field_name, all_names)
    | None -> return 0
  end
end

let lir_record_field_type = fn (sem: TypeExpr, name: string) -> TypeExpr throws { LirError } do
  if let TyRecord(fields) = sem then
    return lir_find_named_type(fields, name)
  else
    return TyI64
  end
end

let lir_find_named_type = fn (
  fields: [ NamedType ],
  name: string
) -> TypeExpr throws { LirError } do
  match fields do
    | [] -> return TyI64
    | NamedType(name: fn_, typ: ft) :: rest ->
      if fn_ == name then return ft
      else return lir_find_named_type(fields: rest, name)
      end
  end
end

let lir_sort_strings = fn (lst: [ string ]) -> [ string ] throws { LirError } do
  match lst do
    | [] -> return []
    | x :: rest -> return lir_insert_sorted(val: x, sorted: lir_sort_strings(lst: rest))
  end
end

let lir_insert_sorted_go = fn (
  val: string,
  sorted: [ string ],
  acc: [ string ]
) -> [ string ] throws { LirError } do
  match sorted do
    | [] ->
      let rev_acc = list.concat(xs: list.reverse(xs: acc), ys: [ val ])
      return rev_acc
    | x :: rest ->
      if lir_str_less_than(a: val, b: x) || val == x then
        return list.concat(xs: list.reverse(xs: acc), ys: val :: sorted)
      else
        return lir_insert_sorted_go(val, sorted: rest, acc: x :: acc)
      end
  end
end

let lir_insert_sorted = fn (val: string, sorted: [ string ]) -> [ string ] throws { LirError } do
  return lir_insert_sorted_go(val, sorted, acc: [])
end

let lir_record_sorted_idx = fn (sem: TypeExpr, name: string) -> i64 throws { LirError } do
  if let TyRecord(fields) = sem then
    let names = lir_extract_named_type_names(fields)
    let sorted = lir_sort_strings(lst: names)
    return lir_str_index(lst: sorted, name, idx: 0)
  else
    return 0
  end
end

let lir_extract_named_type_names = fn (fields: [ NamedType ]) -> [ string ] throws { LirError } do
  return lir_extract_named_type_names_go(fields, acc: [])
end

let lir_extract_named_type_names_go = fn (
  fields: [ NamedType ],
  acc: [ string ]
) -> [ string ] throws { LirError } do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | NamedType(
      name: n,
      typ: _
    ) :: rest -> return lir_extract_named_type_names_go(fields: rest, acc: n :: acc)
  end
end

let lir_str_index = fn (lst: [ string ], name: string, idx: i64) -> i64 throws { LirError } do
  match lst do
    | [] -> return -1
    | x :: rest ->
      if x == name then return idx
      else return lir_str_index(lst: rest, name, idx: idx + 1)
      end
  end
end

/** Public function lir_emit_bindings. */
export let lir_emit_bindings = fn (
  bindings: [ PatBinding ],
  atoms: [ AtomEntry ],
  ctx: LowerCtx
) -> LowerCtx throws { LirError } do
  match bindings do
    | [] -> return ctx
    | PatBinding(name: n, scrutinee_id: sid) :: rest ->
      let AtomEntry(id: _, atom: a, sem_type: st) = lookup_atom_entry(id: sid, atoms)
      let LowerCtx(
          vars: v,
          semantic_vars: sv,
          stmts: s,
          temp_counter: c,
          enum_defs: ed
        ) = ctx
      let typ = atom_type(atom: a)
          let ctx2 = LowerCtx(
            vars: insert_type(name: n, typ, entries: v),
            semantic_vars: insert_type(name: n, typ: st, entries: sv),
            stmts: LirStmtLet(name: n, typ, expr: LirExprAtom(atom: a)) :: s,
            temp_counter: c, enum_defs: ed
          )
          return lir_emit_bindings(bindings: rest, atoms, ctx: ctx2)
  end
end

/** Public function lir_extract_ctor_fields. */
export let lir_extract_ctor_fields = fn (scr_atom: LirAtom, scr_sem: TypeExpr, ctor_name: string,
    arity: i64, field_ids: [ i64 ], atoms: [ AtomEntry ], ctx: LowerCtx) -> FieldExtractResult throws { LirError } do
  let LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) = ctx
  let work_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    let FieldLoopResult(
      ctx: ctx2,
      atoms: atoms2
    ) = lir_extract_fields_loop(scr_atom, scr_sem, ctor_name,
        field_ids, idx: 0, arity, atoms, ctx: work_ctx,
        enum_defs: ed)
    let LowerCtx(
        vars: _,
        semantic_vars: _,
        stmts: field_stmts,
        temp_counter: c2,
        enum_defs: _
      ) = ctx2
    let restored = LowerCtx(
          vars: v,
          semantic_vars: sv,
          stmts: saved,
          temp_counter: c2,
          enum_defs: ed
        )
        return FieldExtractResult(
          ctx: restored,
          atoms: atoms2,
          field_stmts: list.reverse(xs: field_stmts)
        )
end

let lir_extract_fields_loop = fn (scr_atom: LirAtom, scr_sem: TypeExpr, ctor_name: string,
    field_ids: [ i64 ], idx: i64, arity: i64, atoms: [ AtomEntry ], ctx: LowerCtx,
    enum_defs: VariantIndex) -> FieldLoopResult throws { LirError } do
  if idx >= arity then return FieldLoopResult(ctx, atoms) end
  let fid = lir_id_nth(lst: field_ids, n: idx)
  match lookup_variant_def(name: ctor_name, enum_defs) do
    | Some(val: vd) ->
      let names = get_variant_field_names(vd)
      let field_name = lir_nth_string(lst: names, n: idx)
      let heap_idx = constructor_field_heap_index(field_name, ctor_name, enum_defs)
      let raw_ft = constructor_field_type(field_name, ctor_name, enum_defs)
      // A generic-container field is declared with a bare type-param
      // (`Cons.v : T`, `MkPair.fst : X`). Substitute the scrutinee's concrete
      // type args (`[Inner]` → T=Inner; `Pair<Inner,i64>` → X=Inner, Y=i64)
      // before resolving the alias so the bound variable carries the field's
      // real semantic type instead of an unresolved `TyVar`, otherwise
      // `.field` on it aborts LIR with E6002 (nexus-n5gub #1 cons-elem / #3
      // generic-field). One level on demand → recursive types never loop.
      let tps = variant_type_params(idx: enum_defs, ctor_name)
      let substituted = subst_type_params(typ: raw_ft, params: tps,
        args: scrutinee_type_args(scr_sem))
      let sem_ft = vidx.resolve_record_alias(idx: enum_defs, typ: substituted)
      let wasm_ft = wasm_type(typ: sem_ft)
      let BindResult(ctx: ctx2, atom: field_atom) = bind_expr_to_temp_semantic(ctx,
        expr: LirExprObjectField(value: scr_atom, index: heap_idx, typ: wasm_ft),
        typ: wasm_ft, semantic_type: sem_ft)
      let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: sem_ft) :: atoms
        return lir_extract_fields_loop(scr_atom, scr_sem, ctor_name,
          field_ids, idx: idx + 1, arity, atoms: new_atoms, ctx: ctx2,
          enum_defs)
    | None ->
      // Built-in constructor — alphabetical field sort for memory layout.
      let mem_idx = lir_builtin_field_mem_idx(ctor_name, def_idx: idx)
      let BindResult(ctx: ctx2, atom: field_atom) = bind_expr_to_temp(ctx,
        expr: LirExprObjectField(value: scr_atom, index: mem_idx, typ: TyI64),
        typ: TyI64)
      let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: TyI64) :: atoms
        return lir_extract_fields_loop(scr_atom, scr_sem, ctor_name,
          field_ids, idx: idx + 1, arity, atoms: new_atoms, ctx: ctx2,
          enum_defs)
  end
end

let lir_id_nth = fn (lst: [ i64 ], n: i64) -> i64 throws { LirError } do
  match lst do
    | [] -> throw LirAtomEntryNotFound(id: n)
    | x :: rest ->
      if n == 0 then return x
      else return lir_id_nth(lst: rest, n: n - 1)
      end
  end
end

/** Public function lir_extract_record_fields. */
export let lir_extract_record_fields = fn (scr_atom: LirAtom, scr_sem: TypeExpr,
    field_names: [ string ], field_ids: [ i64 ], atoms: [ AtomEntry ], ctx: LowerCtx) -> FieldExtractResult throws { LirError } do
  let LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) = ctx
  let work_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    let FieldLoopResult(
          ctx: ctx2,
          atoms: atoms2
        ) = lir_extract_record_loop(scr_atom, scr_sem,
        field_names, field_ids, atoms, ctx: work_ctx)
    let LowerCtx(
        vars: _,
        semantic_vars: _,
        stmts: field_stmts,
        temp_counter: c2,
        enum_defs: _
      ) = ctx2
    let restored = LowerCtx(
          vars: v,
          semantic_vars: sv,
          stmts: saved,
          temp_counter: c2,
          enum_defs: ed
        )
        return FieldExtractResult(
          ctx: restored,
          atoms: atoms2,
          field_stmts: list.reverse(xs: field_stmts)
        )
end

let lir_extract_record_loop = fn (scr_atom: LirAtom, scr_sem: TypeExpr,
    field_names: [ string ], field_ids: [ i64 ], atoms: [ AtomEntry ], ctx: LowerCtx) -> FieldLoopResult throws { LirError } do
  match field_names do
    | [] -> return FieldLoopResult(ctx, atoms)
    | fn_ :: rest_names ->
      match field_ids do
        | [] -> return FieldLoopResult(ctx, atoms)
        | fid :: rest_ids ->
        let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: ed_loop) = ctx
        // A nested record field declared as a named alias (`inner: Inner`)
        // arrives as `TyUserDefined("Inner", …)`. Resolve it to its `TyRecord`
        // body so a deeper destructure (or `.field` access) sees the field
        // shape instead of collapsing all offsets to 0 (nexus-9kkrc, the
        // nested sibling of xs3dl). Resolution is one-level-on-demand here, so
        // recursive record types never expand infinitely.
        let field_type = vidx.resolve_record_alias(idx: ed_loop,
          typ: lir_record_field_type(sem: scr_sem, name: fn_))
        let sorted_idx = lir_record_sorted_idx(sem: scr_sem, name: fn_)
        let wasm_ft = wasm_type(typ: field_type)
        let BindResult(ctx: ctx2, atom: field_atom) = bind_expr_to_temp_semantic(ctx,
          expr: LirExprObjectField(value: scr_atom, index: sorted_idx, typ: wasm_ft),
          typ: wasm_ft, semantic_type: field_type)
        let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: field_type) :: atoms
          return lir_extract_record_loop(scr_atom, scr_sem,
            field_names: rest_names, field_ids: rest_ids, atoms: new_atoms, ctx: ctx2)
      end
  end
end

/** Public function lir_emit_ctor_conds. */
export let lir_emit_ctor_conds = fn (
  branches: [ CtorBranch ],
  tag_atom: LirAtom,
  has_fb: bool,
  pos: i64,
  total: i64,
  ctx: LowerCtx
) -> CtorCondsResult throws { LirError } do
  return lir_emit_ctor_conds_go(branches, tag_atom, has_fb, pos, total, ctx, acc: [])
end

let lir_emit_ctor_conds_go = fn (
  branches: [ CtorBranch ],
  tag_atom: LirAtom,
  has_fb: bool,
  pos: i64,
  total: i64,
  ctx: LowerCtx,
  acc: [ LirAtom ]
) -> CtorCondsResult throws { LirError } do
  match branches do
    | [] -> return CtorCondsResult(ctx, conds: lir_reverse_atoms(lst: acc, acc: []))
    | CtorBranch(ctor_name: _, ctor_tag: tag, arity: _, field_ids: _, subtree: _) :: rest ->
      let is_last_no_fb = (pos == total - 1) && !has_fb
      if is_last_no_fb then
        return lir_emit_ctor_conds_go(
          branches: rest,
          tag_atom,
          has_fb,
          pos: pos + 1,
          total,
          ctx,
          acc: LirAtomBool(val: true) :: acc
        )
      else
        let BindResult(ctx: ctx2, atom: cond) = bind_expr_to_temp(ctx,
          expr: LirExprBinary(op: OpEq, lhs: tag_atom, rhs: LirAtomInt(val: tag), typ: TyBool),
          typ: TyBool)
        return lir_emit_ctor_conds_go(
            branches: rest,
            tag_atom,
            has_fb,
            pos: pos + 1,
            total,
            ctx: ctx2,
            acc: cond :: acc
          )
      end
  end
end

/** Public function lir_emit_lit_conds. */
export let lir_emit_lit_conds = fn (
  branches: [ LitBranch ],
  scr_atom: LirAtom,
  ctx: LowerCtx
) -> LitCondsResult throws { LirError } do
  return lir_emit_lit_conds_go(branches, scr_atom, ctx, acc: [])
end

let lir_emit_lit_conds_go = fn (
  branches: [ LitBranch ],
  scr_atom: LirAtom,
  ctx: LowerCtx,
  acc: [ LirAtom ]
) -> LitCondsResult throws { LirError } do
  match branches do
    | [] -> return LitCondsResult(ctx, conds: lir_reverse_atoms(lst: acc, acc: []))
    | LitBranch(lit: l, subtree: _) :: rest ->
      let lit_atom = literal_to_atom(lit: l)
      // Float literals require f64.eq (OpFEq); all other literals use i64.eq (OpEq).
      let cmp_op = match l do | LitFloat(_) -> OpFEq | _ -> OpEq end
      let BindResult(ctx: ctx2, atom: cond) = bind_expr_to_temp(ctx,
        expr: LirExprBinary(op: cmp_op, lhs: scr_atom, rhs: lit_atom, typ: TyBool),
        typ: TyBool)
      return lir_emit_lit_conds_go(branches: rest, scr_atom, ctx: ctx2, acc: cond :: acc)
  end
end
