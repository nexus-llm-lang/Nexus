/**
 * emit_tree: decision-tree emission for LIR lowering.
 *
 * Owns:
 * - Expr-mode emission (EmitExprResult, lir_emit_decision_tree_expr and helpers)
 * - Stmt-mode emission (EmitStmtResult, lir_emit_decision_tree_stmt and helpers)
 *
 * Both entry points receive the two hub callbacks that emit leaf bodies:
 *   lower_branch_body_fn  — used by lir_emit_leaf_expr (expr-mode leaf)
 *   lower_case_body_fn    — used by lir_emit_leaf_stmt  (stmt-mode leaf)
 *
 * This avoids a cyclic import: the emit cluster recurses through the
 * decision tree (self-contained) and only calls back into lir.nx at leaf
 * boundaries where it needs to lower MIR statement bodies.
 *
 * Extracted from src/ir/lir/lir.nx (nexus-lxf00).
 */
import { TypeExpr, TyI64 } from "src/syntax/ast.nx"
import * as list from "std:list"
import { LirError } from "src/ir/lir/errors.nx"
import { MirStmt, MirMatchCase } from "src/ir/mir/types.nx"
import { LirAtom, LirStmt, LirAtomBool } from "src/ir/lir/types.nx"
import {
  LowerCtx,
  BindResult,
  BranchBodyResult,
  BlockResult,
  bind_expr_to_temp
} from "src/ir/lir/context.nx"
import {
  PatBinding,
  CtorBranch,
  LitBranch,
  AtomEntry,
  DecTree,
  FieldExtractResult,
  CtorCondsResult,
  LitCondsResult
} from "src/ir/lir/match_tree/types.nx"
import {
  lookup_atom_entry,
  lir_reverse_ctors,
  lir_reverse_lit_branches,
  lir_reverse_atoms,
  lir_ctors_length,
  lir_nth_case_body,
  lir_emit_bindings,
  lir_emit_ctor_conds,
  lir_emit_lit_conds,
  lir_extract_ctor_fields,
  lir_extract_record_fields
} from "src/ir/lir/match_tree.nx"
import {
  fallback_ret_from_last_stmt,
  is_trivially_unit_body,
  append_stmts
} from "src/ir/lir/lower_helpers.nx"

// ---------------------------------------------------------------------------
// Expr-mode types
// ---------------------------------------------------------------------------

export type EmitExprResult = EmitExprResult(ctx: LowerCtx, chain_stmts: [ LirStmt ])

// ---------------------------------------------------------------------------
// Expr-mode emit
// ---------------------------------------------------------------------------

export let lir_emit_decision_tree_expr = fn (
  tree: DecTree,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  result_name: string,
  result_type: TypeExpr,
  ctx: LowerCtx,
  lower_branch_body_fn: (
    body: [ MirStmt ],
    result_name: string,
    result_type: TypeExpr,
    ctx: LowerCtx
  ) -> BranchBodyResult throws { LirError }
) -> EmitExprResult throws { LirError } do
  match tree do
    | DecFail -> return EmitExprResult(ctx, chain_stmts: [])
    | DecLeaf(case_idx: ci, bindings: bs) ->
      return lir_emit_leaf_expr(case_idx: ci, bindings: bs, atoms, cases,
                                  result_name, result_type, ctx,
                                  lower_branch_body_fn)
    | DecCtorSwitch(scrutinee_id: sid, branches, fallback: fb) ->
      return lir_emit_ctor_switch_expr(scrutinee_id: sid, branches, fallback: fb,
        atoms, cases, result_name, result_type, ctx, lower_branch_body_fn)
    | DecLitSwitch(scrutinee_id: sid, branches, fallback: fb) ->
      return lir_emit_lit_switch_expr(scrutinee_id: sid, branches, fallback: fb,
        atoms, cases, result_name, result_type, ctx, lower_branch_body_fn)
    | DecRecordDestructure(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st) ->
      return lir_emit_record_expr(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st,
        atoms, cases, result_name, result_type, ctx, lower_branch_body_fn)
  end
end

let lir_emit_leaf_expr = fn (
  case_idx: i64,
  bindings: [ PatBinding ],
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  result_name: string,
  result_type: TypeExpr,
  ctx: LowerCtx,
  lower_branch_body_fn: (
    body: [ MirStmt ],
    result_name: string,
    result_type: TypeExpr,
    ctx: LowerCtx
  ) -> BranchBodyResult throws { LirError }
) -> EmitExprResult throws { LirError } do
  let case_body = lir_nth_case_body(cases, idx: case_idx)
  // Emit bindings in isolation (matching lir_emit_leaf_stmt) to prevent
  // accumulated stmts from ctx leaking into branch chain_stmts.
  match ctx do | LowerCtx(
    vars: v0,
    semantic_vars: sv0,
    stmts: s0,
    temp_counter: c0,
    enum_defs: ed0
  ) ->
    let bind_ctx = LowerCtx(
      vars: v0,
      semantic_vars: sv0,
      stmts: [],
      temp_counter: c0,
      enum_defs: ed0
    )
    match lir_emit_bindings(bindings, atoms, ctx: bind_ctx) do | LowerCtx(
      vars: v2,
      semantic_vars: sv2,
      stmts: bind_stmts,
      temp_counter: c2,
      enum_defs: _
    ) ->
      let body_ctx = LowerCtx(
        vars: v2,
        semantic_vars: sv2,
        stmts: [],
        temp_counter: c2,
        enum_defs: ed0
      )
      match lower_branch_body_fn(
        body: case_body,
        result_name,
        result_type,
        ctx: body_ctx
      ) do | BranchBodyResult(ctx: ctx3, value_opt: val_opt) ->
        match ctx3 do | LowerCtx(
          vars: _,
          semantic_vars: _,
          stmts: raw_body_stmts,
          temp_counter: c3,
          enum_defs: _
        ) ->
          let restored_ctx = LowerCtx(
            vars: v0,
            semantic_vars: sv0,
            stmts: s0,
            temp_counter: c3,
            enum_defs: ed0
          )
          let leaf_stmts = append_stmts(
            stmts: list.reverse(xs: bind_stmts),
            tail: list.reverse(xs: raw_body_stmts)
          )
          let final_stmts = match val_opt do
            | Some(val: va) ->
              append_stmts(
                stmts: leaf_stmts,
                tail: [ LirStmtLet(name: result_name, typ: result_type, expr: LirExprAtom(atom: va)) ]
              )
            | None -> leaf_stmts
          end
          return EmitExprResult(ctx: restored_ctx, chain_stmts: final_stmts)
        end
      end
    end
  end
end

let lir_emit_ctor_switch_expr = fn (
  scrutinee_id: i64,
  branches: [ CtorBranch ],
  fallback: Option<DecTree>,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  result_name: string,
  result_type: TypeExpr,
  ctx: LowerCtx,
  lower_branch_body_fn: (
    body: [ MirStmt ],
    result_name: string,
    result_type: TypeExpr,
    ctx: LowerCtx
  ) -> BranchBodyResult throws { LirError }
) -> EmitExprResult throws { LirError } do
  match lookup_atom_entry(
    id: scrutinee_id,
    atoms
  ) do | AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    // Extract tag + conditions in isolation to avoid duplicating existing stmts.
    match ctx do | LowerCtx(
      vars: v0,
      semantic_vars: sv0,
      stmts: s0,
      temp_counter: c0,
      enum_defs: ed0
    ) ->
      let iso_ctx = LowerCtx(
        vars: v0,
        semantic_vars: sv0,
        stmts: [],
        temp_counter: c0,
        enum_defs: ed0
      )
      match bind_expr_to_temp(
        ctx: iso_ctx,
        expr: LirExprObjectTag(value: scr_atom, typ: TyI64),
        typ: TyI64
      ) do | BindResult(ctx: ctx2, atom: tag_atom) ->
      let has_fb = if let Some(_) = fallback then true else false end
      match lir_emit_ctor_conds(
        branches,
        tag_atom,
        has_fb,
        pos: 0,
        total: lir_ctors_length(lst: branches),
        ctx: ctx2
      ) do | CtorCondsResult(ctx: ctx3, conds) ->
        match ctx3 do | LowerCtx(
          vars: _,
          semantic_vars: _,
          stmts: cond_stmts,
          temp_counter: c3,
          enum_defs: _
        ) ->
            let base_ctx = LowerCtx(
              vars: v0,
              semantic_vars: sv0,
              stmts: s0,
              temp_counter: c3,
              enum_defs: ed0
            )
            // Build chain: start with fallback
            match lir_emit_fb_expr(fallback, atoms, cases,
                result_name, result_type, ctx: base_ctx,
                lower_branch_body_fn) do | EmitExprResult(ctx: ctx4, chain_stmts: chain_else) ->
              // Process branches in reverse
              let rev_branches = lir_reverse_ctors(lst: branches, acc: [])
              let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
              match lir_build_expr_chain(branches: rev_branches, conds: rev_conds, scr_atom,
                  scr_sem, atoms, cases, result_name,
                  result_type, chain_else, ctx: ctx4,
                  lower_branch_body_fn) do | EmitExprResult(ctx: ctx5, chain_stmts: final_chain) ->
                // Prepend cond stmts
                let all_stmts = append_stmts(stmts: list.reverse(xs: cond_stmts), tail: final_chain)
                return EmitExprResult(ctx: ctx5, chain_stmts: all_stmts)
              end
            end
          end
        end
      end
    end
  end
end

let lir_emit_fb_expr = fn (
  fallback: Option<DecTree>,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  result_name: string,
  result_type: TypeExpr,
  ctx: LowerCtx,
  lower_branch_body_fn: (
    body: [ MirStmt ],
    result_name: string,
    result_type: TypeExpr,
    ctx: LowerCtx
  ) -> BranchBodyResult throws { LirError }
) -> EmitExprResult throws { LirError } do
  match fallback do
    | None -> return EmitExprResult(ctx, chain_stmts: [])
    | Some(val: fb) ->
      return lir_emit_decision_tree_expr(tree: fb, atoms, cases,
        result_name, result_type, ctx, lower_branch_body_fn)
  end
end

let lir_build_expr_chain = fn (
  branches: [ CtorBranch ],
  conds: [ LirAtom ],
  scr_atom: LirAtom,
  scr_sem: TypeExpr,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  result_name: string,
  result_type: TypeExpr,
  chain_else: [ LirStmt ],
  ctx: LowerCtx,
  lower_branch_body_fn: (
    body: [ MirStmt ],
    result_name: string,
    result_type: TypeExpr,
    ctx: LowerCtx
  ) -> BranchBodyResult throws { LirError }
) -> EmitExprResult throws { LirError } do
  match branches do
    | [] -> return EmitExprResult(ctx, chain_stmts: chain_else)
    | CtorBranch(ctor_name: cn, ctor_tag: _, arity: ar, field_ids: fids, subtree: st) :: rest_b ->
      match conds do
        | [] -> return EmitExprResult(ctx, chain_stmts: chain_else)
        | cond :: rest_c ->
        match lir_extract_ctor_fields(scr_atom, scr_sem, ctor_name: cn,
            arity: ar, field_ids: fids, atoms, ctx) do | FieldExtractResult(
              ctx: ctx2,
              atoms: atoms2,
              field_stmts: fstmts
            ) ->
          match lir_emit_decision_tree_expr(tree: st, atoms: atoms2, cases,
              result_name, result_type, ctx: ctx2,
              lower_branch_body_fn) do | EmitExprResult(ctx: ctx3, chain_stmts: sub_stmts) ->
            let then_body = append_stmts(stmts: fstmts, tail: sub_stmts)
            let if_stmt = LirStmtIf(cond, then_body, else_body: chain_else)
            return lir_build_expr_chain(branches: rest_b, conds: rest_c, scr_atom,
              scr_sem, atoms, cases, result_name,
              result_type, chain_else: [ if_stmt ], ctx: ctx3,
              lower_branch_body_fn)
          end
        end
      end
  end
end

let lir_emit_lit_switch_expr = fn (
  scrutinee_id: i64,
  branches: [ LitBranch ],
  fallback: DecTree,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  result_name: string,
  result_type: TypeExpr,
  ctx: LowerCtx,
  lower_branch_body_fn: (
    body: [ MirStmt ],
    result_name: string,
    result_type: TypeExpr,
    ctx: LowerCtx
  ) -> BranchBodyResult throws { LirError }
) -> EmitExprResult throws { LirError } do
  match lookup_atom_entry(
    id: scrutinee_id,
    atoms
  ) do | AtomEntry(id: _, atom: scr_atom, sem_type: _) ->
    // Pre-compute conditions in isolation to avoid duplicating existing stmts.
    match ctx do | LowerCtx(
      vars: v0,
      semantic_vars: sv0,
      stmts: s0,
      temp_counter: c0,
      enum_defs: ed0
    ) ->
      let iso_ctx = LowerCtx(
        vars: v0,
        semantic_vars: sv0,
        stmts: [],
        temp_counter: c0,
        enum_defs: ed0
      )
      match lir_emit_lit_conds(
        branches,
        scr_atom,
        ctx: iso_ctx
      ) do | LitCondsResult(ctx: ctx2, conds) ->
      match ctx2 do | LowerCtx(
        vars: _,
        semantic_vars: _,
        stmts: cond_stmts,
        temp_counter: c2,
        enum_defs: _
      ) ->
          let base_ctx = LowerCtx(
            vars: v0,
            semantic_vars: sv0,
            stmts: s0,
            temp_counter: c2,
            enum_defs: ed0
          )
          // Start with fallback
          match lir_emit_decision_tree_expr(tree: fallback, atoms, cases,
              result_name, result_type, ctx: base_ctx,
              lower_branch_body_fn) do | EmitExprResult(ctx: ctx3, chain_stmts: chain_else) ->
            let rev_branches = lir_reverse_lit_branches(lst: branches, acc: [])
            let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
            match lir_build_lit_expr_chain(branches: rev_branches, conds: rev_conds, atoms,
                cases, result_name, result_type,
                chain_else, ctx: ctx3,
                lower_branch_body_fn) do | EmitExprResult(ctx: ctx4, chain_stmts: final_chain) ->
              let all_stmts = append_stmts(stmts: list.reverse(xs: cond_stmts), tail: final_chain)
              return EmitExprResult(ctx: ctx4, chain_stmts: all_stmts)
            end
          end
        end
      end
    end
  end
end

let lir_build_lit_expr_chain = fn (
  branches: [ LitBranch ],
  conds: [ LirAtom ],
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  result_name: string,
  result_type: TypeExpr,
  chain_else: [ LirStmt ],
  ctx: LowerCtx,
  lower_branch_body_fn: (
    body: [ MirStmt ],
    result_name: string,
    result_type: TypeExpr,
    ctx: LowerCtx
  ) -> BranchBodyResult throws { LirError }
) -> EmitExprResult throws { LirError } do
  match branches do
    | [] -> return EmitExprResult(ctx, chain_stmts: chain_else)
    | LitBranch(lit: _, subtree: st) :: rest_b ->
      match conds do
        | [] -> return EmitExprResult(ctx, chain_stmts: chain_else)
        | cond :: rest_c ->
        match lir_emit_decision_tree_expr(tree: st, atoms, cases,
            result_name, result_type, ctx,
            lower_branch_body_fn) do | EmitExprResult(ctx: ctx2, chain_stmts: sub_stmts) ->
          let if_stmt = LirStmtIf(cond, then_body: sub_stmts, else_body: chain_else)
          return lir_build_lit_expr_chain(branches: rest_b, conds: rest_c, atoms,
            cases, result_name, result_type,
            chain_else: [ if_stmt ], ctx: ctx2,
            lower_branch_body_fn)
        end
      end
  end
end

let lir_emit_record_expr = fn (
  scrutinee_id: i64,
  field_names: [ string ],
  field_ids: [ i64 ],
  subtree: DecTree,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  result_name: string,
  result_type: TypeExpr,
  ctx: LowerCtx,
  lower_branch_body_fn: (
    body: [ MirStmt ],
    result_name: string,
    result_type: TypeExpr,
    ctx: LowerCtx
  ) -> BranchBodyResult throws { LirError }
) -> EmitExprResult throws { LirError } do
  match lookup_atom_entry(
    id: scrutinee_id,
    atoms
  ) do | AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    match lir_extract_record_fields(scr_atom, scr_sem,
        field_names, field_ids, atoms, ctx) do | FieldExtractResult(
          ctx: ctx2,
          atoms: atoms2,
          field_stmts: fstmts
        ) ->
      match lir_emit_decision_tree_expr(tree: subtree, atoms: atoms2, cases,
          result_name, result_type, ctx: ctx2,
          lower_branch_body_fn) do | EmitExprResult(ctx: ctx3, chain_stmts: sub_stmts) ->
        return EmitExprResult(ctx: ctx3, chain_stmts: append_stmts(stmts: fstmts, tail: sub_stmts))
      end
    end
  end
end

// ---------------------------------------------------------------------------
// Stmt-mode types
// ---------------------------------------------------------------------------

export type EmitStmtResult = EmitStmtResult(ctx: LowerCtx, chain_stmts: [ LirStmt ])

// ---------------------------------------------------------------------------
// Stmt-mode emit
// ---------------------------------------------------------------------------

export let lir_emit_decision_tree_stmt = fn (
  tree: DecTree,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  ret_type: TypeExpr,
  ctx: LowerCtx,
  lower_case_body_fn: (
    stmts: [ MirStmt ],
    ret_type: TypeExpr,
    ctx: LowerCtx
  ) -> BlockResult throws { LirError }
) -> EmitStmtResult throws { LirError } do
  match tree do
    | DecFail -> return EmitStmtResult(ctx, chain_stmts: [])
    | DecLeaf(case_idx: ci, bindings: bs) ->
      return lir_emit_leaf_stmt(case_idx: ci, bindings: bs, atoms, cases,
                                  ret_type, ctx, lower_case_body_fn)
    | DecCtorSwitch(scrutinee_id: sid, branches, fallback: fb) ->
      return lir_emit_ctor_switch_stmt(scrutinee_id: sid, branches, fallback: fb,
        atoms, cases, ret_type, ctx, lower_case_body_fn)
    | DecLitSwitch(scrutinee_id: sid, branches, fallback: fb) ->
      return lir_emit_lit_switch_stmt(scrutinee_id: sid, branches, fallback: fb,
        atoms, cases, ret_type, ctx, lower_case_body_fn)
    | DecRecordDestructure(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st) ->
      return lir_emit_record_stmt(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st,
        atoms, cases, ret_type, ctx, lower_case_body_fn)
  end
end

let lir_emit_leaf_stmt = fn (
  case_idx: i64,
  bindings: [ PatBinding ],
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  ret_type: TypeExpr,
  ctx: LowerCtx,
  lower_case_body_fn: (
    stmts: [ MirStmt ],
    ret_type: TypeExpr,
    ctx: LowerCtx
  ) -> BlockResult throws { LirError }
) -> EmitStmtResult throws { LirError } do
  let case_body = lir_nth_case_body(cases, idx: case_idx)
  // Emit bindings in isolation so they go into chain_stmts (inside the branch),
  // not ctx.stmts (outside the branch). Otherwise, bindings like
  // "Let result = _field_atom" leak before the if-chain, reading uninitialized locals.
  match ctx do | LowerCtx(
    vars: v0,
    semantic_vars: sv0,
    stmts: s0,
    temp_counter: c0,
    enum_defs: ed0
  ) ->
    let bind_ctx = LowerCtx(
      vars: v0,
      semantic_vars: sv0,
      stmts: [],
      temp_counter: c0,
      enum_defs: ed0
    )
    match lir_emit_bindings(bindings, atoms, ctx: bind_ctx) do | LowerCtx(
      vars: v2,
      semantic_vars: sv2,
      stmts: bind_stmts,
      temp_counter: c2,
      enum_defs: _
    ) ->
      let block_ctx = LowerCtx(
        vars: v2,
        semantic_vars: sv2,
        stmts: s0,
        temp_counter: c2,
        enum_defs: ed0
      )
      match lower_case_body_fn(
        stmts: case_body,
        ret_type,
        ctx: block_ctx
      ) do | BlockResult(ctx: ctx3, stmts: body_stmts, ret: case_ret) ->
        let full_body = append_stmts(stmts: list.reverse(xs: bind_stmts), tail: body_stmts)
        let is_trivial = is_trivially_unit_body(stmts: case_body)
        let genuine_ret = match case_ret do
          | Some(_) -> case_ret
          | None -> fallback_ret_from_last_stmt(stmts: full_body)
        end
        match genuine_ret do
          | Some(val: a) ->
            let stmt = LirStmtIfReturn(cond: LirAtomBool(val: true), then_body: full_body,
              then_ret: a, else_body: [], else_ret: None, ret_type)
            return EmitStmtResult(ctx: ctx3, chain_stmts: [ stmt ])
          | None ->
            return EmitStmtResult(ctx: ctx3, chain_stmts: full_body)
        end
      end
    end
  end
end

let lir_emit_ctor_switch_stmt = fn (
  scrutinee_id: i64,
  branches: [ CtorBranch ],
  fallback: Option<DecTree>,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  ret_type: TypeExpr,
  ctx: LowerCtx,
  lower_case_body_fn: (
    stmts: [ MirStmt ],
    ret_type: TypeExpr,
    ctx: LowerCtx
  ) -> BlockResult throws { LirError }
) -> EmitStmtResult throws { LirError } do
  match lookup_atom_entry(
    id: scrutinee_id,
    atoms
  ) do | AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    // Extract tag + conditions in isolation (empty stmts) to avoid duplicating
    // the target call stmts that are already in ctx.stmts.
    match ctx do | LowerCtx(
      vars: v0,
      semantic_vars: sv0,
      stmts: s0,
      temp_counter: c0,
      enum_defs: ed0
    ) ->
      let iso_ctx = LowerCtx(
        vars: v0,
        semantic_vars: sv0,
        stmts: [],
        temp_counter: c0,
        enum_defs: ed0
      )
      match bind_expr_to_temp(
        ctx: iso_ctx,
        expr: LirExprObjectTag(value: scr_atom, typ: TyI64),
        typ: TyI64
      ) do | BindResult(ctx: ctx2, atom: tag_atom) ->
      let has_fb = if let Some(_) = fallback then true else false end
      match lir_emit_ctor_conds(
        branches,
        tag_atom,
        has_fb,
        pos: 0,
        total: lir_ctors_length(lst: branches),
        ctx: ctx2
      ) do | CtorCondsResult(ctx: ctx3, conds) ->
        match ctx3 do | LowerCtx(
          vars: _,
          semantic_vars: _,
          stmts: cond_stmts,
          temp_counter: c3,
          enum_defs: _
        ) ->
            let base_ctx = LowerCtx(
              vars: v0,
              semantic_vars: sv0,
              stmts: s0,
              temp_counter: c3,
              enum_defs: ed0
            )
            match lir_emit_fb_stmt(fallback, atoms, cases,
                ret_type, ctx: base_ctx,
                lower_case_body_fn) do | EmitStmtResult(ctx: ctx4, chain_stmts: chain_else) ->
              let rev_branches = lir_reverse_ctors(lst: branches, acc: [])
              let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
              match lir_build_stmt_chain(branches: rev_branches, conds: rev_conds, scr_atom,
                  scr_sem, atoms, cases, ret_type,
                  chain_else, ctx: ctx4,
                  lower_case_body_fn) do | EmitStmtResult(ctx: ctx5, chain_stmts: final_chain) ->
                let all_stmts = append_stmts(stmts: list.reverse(xs: cond_stmts), tail: final_chain)
                return EmitStmtResult(ctx: ctx5, chain_stmts: all_stmts)
              end
            end
          end
        end
      end
    end
  end
end

let lir_emit_fb_stmt = fn (
  fallback: Option<DecTree>,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  ret_type: TypeExpr,
  ctx: LowerCtx,
  lower_case_body_fn: (
    stmts: [ MirStmt ],
    ret_type: TypeExpr,
    ctx: LowerCtx
  ) -> BlockResult throws { LirError }
) -> EmitStmtResult throws { LirError } do
  match fallback do
    | None -> return EmitStmtResult(ctx, chain_stmts: [])
    | Some(val: fb) ->
      return lir_emit_decision_tree_stmt(tree: fb, atoms, cases, ret_type, ctx,
        lower_case_body_fn)
  end
end

let lir_build_stmt_chain = fn (
  branches: [ CtorBranch ],
  conds: [ LirAtom ],
  scr_atom: LirAtom,
  scr_sem: TypeExpr,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  ret_type: TypeExpr,
  chain_else: [ LirStmt ],
  ctx: LowerCtx,
  lower_case_body_fn: (
    stmts: [ MirStmt ],
    ret_type: TypeExpr,
    ctx: LowerCtx
  ) -> BlockResult throws { LirError }
) -> EmitStmtResult throws { LirError } do
  match branches do
    | [] -> return EmitStmtResult(ctx, chain_stmts: chain_else)
    | CtorBranch(ctor_name: cn, ctor_tag: _, arity: ar, field_ids: fids, subtree: st) :: rest_b ->
      match conds do
        | [] -> return EmitStmtResult(ctx, chain_stmts: chain_else)
        | cond :: rest_c ->
        match lir_extract_ctor_fields(scr_atom, scr_sem, ctor_name: cn,
            arity: ar, field_ids: fids, atoms, ctx) do | FieldExtractResult(
              ctx: ctx2,
              atoms: atoms2,
              field_stmts: fstmts
            ) ->
          match lir_emit_decision_tree_stmt(tree: st, atoms: atoms2, cases,
              ret_type, ctx: ctx2,
              lower_case_body_fn) do | EmitStmtResult(ctx: ctx3, chain_stmts: sub_stmts) ->
            let then_body = append_stmts(stmts: fstmts, tail: sub_stmts)
            let then_ret_opt = fallback_ret_from_last_stmt(stmts: then_body)
            match then_ret_opt do
              | Some(val: then_ret) ->
                let stmt = LirStmtIfReturn(cond, then_body, then_ret,
                  else_body: chain_else, else_ret: None, ret_type)
                return lir_build_stmt_chain(branches: rest_b, conds: rest_c, scr_atom,
                  scr_sem, atoms, cases, ret_type,
                  chain_else: [ stmt ], ctx: ctx3,
                  lower_case_body_fn)
              | None ->
                let stmt = LirStmtIf(cond, then_body, else_body: chain_else)
                return lir_build_stmt_chain(branches: rest_b, conds: rest_c, scr_atom,
                  scr_sem, atoms, cases, ret_type,
                  chain_else: [ stmt ], ctx: ctx3,
                  lower_case_body_fn)
            end
          end
        end
      end
  end
end

let lir_emit_lit_switch_stmt = fn (
  scrutinee_id: i64,
  branches: [ LitBranch ],
  fallback: DecTree,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  ret_type: TypeExpr,
  ctx: LowerCtx,
  lower_case_body_fn: (
    stmts: [ MirStmt ],
    ret_type: TypeExpr,
    ctx: LowerCtx
  ) -> BlockResult throws { LirError }
) -> EmitStmtResult throws { LirError } do
  match lookup_atom_entry(
    id: scrutinee_id,
    atoms
  ) do | AtomEntry(id: _, atom: scr_atom, sem_type: _) ->
    match ctx do | LowerCtx(
      vars: v0,
      semantic_vars: sv0,
      stmts: s0,
      temp_counter: c0,
      enum_defs: ed0
    ) ->
      let iso_ctx = LowerCtx(
        vars: v0,
        semantic_vars: sv0,
        stmts: [],
        temp_counter: c0,
        enum_defs: ed0
      )
      match lir_emit_lit_conds(
        branches,
        scr_atom,
        ctx: iso_ctx
      ) do | LitCondsResult(ctx: ctx2, conds) ->
      match ctx2 do | LowerCtx(
        vars: _,
        semantic_vars: _,
        stmts: cond_stmts,
        temp_counter: c2,
        enum_defs: _
      ) ->
          let base_ctx = LowerCtx(
            vars: v0,
            semantic_vars: sv0,
            stmts: s0,
            temp_counter: c2,
            enum_defs: ed0
          )
          match lir_emit_decision_tree_stmt(tree: fallback, atoms, cases,
              ret_type, ctx: base_ctx,
              lower_case_body_fn) do | EmitStmtResult(ctx: ctx3, chain_stmts: chain_else) ->
            let rev_branches = lir_reverse_lit_branches(lst: branches, acc: [])
            let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
            match lir_build_lit_stmt_chain(branches: rev_branches, conds: rev_conds, atoms,
                cases, ret_type, chain_else, ctx: ctx3,
                lower_case_body_fn) do | EmitStmtResult(ctx: ctx4, chain_stmts: final_chain) ->
              let all_stmts = append_stmts(stmts: list.reverse(xs: cond_stmts), tail: final_chain)
              return EmitStmtResult(ctx: ctx4, chain_stmts: all_stmts)
            end
          end
        end
      end
    end
  end
end

let lir_build_lit_stmt_chain = fn (
  branches: [ LitBranch ],
  conds: [ LirAtom ],
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  ret_type: TypeExpr,
  chain_else: [ LirStmt ],
  ctx: LowerCtx,
  lower_case_body_fn: (
    stmts: [ MirStmt ],
    ret_type: TypeExpr,
    ctx: LowerCtx
  ) -> BlockResult throws { LirError }
) -> EmitStmtResult throws { LirError } do
  match branches do
    | [] -> return EmitStmtResult(ctx, chain_stmts: chain_else)
    | LitBranch(lit: _, subtree: st) :: rest_b ->
      match conds do
        | [] -> return EmitStmtResult(ctx, chain_stmts: chain_else)
        | cond :: rest_c ->
        match lir_emit_decision_tree_stmt(tree: st, atoms, cases,
            ret_type, ctx,
            lower_case_body_fn) do | EmitStmtResult(ctx: ctx2, chain_stmts: sub_stmts) ->
          let then_ret_opt = fallback_ret_from_last_stmt(stmts: sub_stmts)
          match then_ret_opt do
            | Some(val: then_ret) ->
              let stmt = LirStmtIfReturn(cond, then_body: sub_stmts, then_ret,
                else_body: chain_else, else_ret: None, ret_type)
              return lir_build_lit_stmt_chain(branches: rest_b, conds: rest_c, atoms,
                cases, ret_type, chain_else: [ stmt ], ctx: ctx2,
                lower_case_body_fn)
            | None ->
              let stmt = LirStmtIf(cond, then_body: sub_stmts, else_body: chain_else)
              return lir_build_lit_stmt_chain(branches: rest_b, conds: rest_c, atoms,
                cases, ret_type, chain_else: [ stmt ], ctx: ctx2,
                lower_case_body_fn)
          end
        end
      end
  end
end

let lir_emit_record_stmt = fn (
  scrutinee_id: i64,
  field_names: [ string ],
  field_ids: [ i64 ],
  subtree: DecTree,
  atoms: [ AtomEntry ],
  cases: [ MirMatchCase ],
  ret_type: TypeExpr,
  ctx: LowerCtx,
  lower_case_body_fn: (
    stmts: [ MirStmt ],
    ret_type: TypeExpr,
    ctx: LowerCtx
  ) -> BlockResult throws { LirError }
) -> EmitStmtResult throws { LirError } do
  match lookup_atom_entry(
    id: scrutinee_id,
    atoms
  ) do | AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    match lir_extract_record_fields(scr_atom, scr_sem,
        field_names, field_ids, atoms, ctx) do | FieldExtractResult(
          ctx: ctx2,
          atoms: atoms2,
          field_stmts: fstmts
        ) ->
      match lir_emit_decision_tree_stmt(tree: subtree, atoms: atoms2, cases,
          ret_type, ctx: ctx2,
          lower_case_body_fn) do | EmitStmtResult(ctx: ctx3, chain_stmts: sub_stmts) ->
        return EmitStmtResult(ctx: ctx3, chain_stmts: append_stmts(stmts: fstmts, tail: sub_stmts))
      end
    end
  end
end
