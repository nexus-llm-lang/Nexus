/**
 * func_lower: function/external lowering — DAG leaf over lir.nx.
 *
 * This module is a strict DAG leaf: it calls into lir.nx (lir_lower_stmts)
 * but lir.nx never calls back. The split is safe because function lowering
 * is purely a driver over the expr/stmt SCC — it sets up LowerCtx, calls
 * lir_lower_stmts once per function body, then wraps the result into
 * LirFunction. The expr/stmt/match SCC in lir.nx has no upward dependency
 * on anything in this file.
 *
 * Owns:
 * - param sorting and conversion (MirParam → LirParam)
 * - per-function context construction (build_param_vars, build_param_semantic_vars)
 * - external conversion (convert_external)
 * - builtin enum defs injection (List, Option, Result)
 * - lower_mir_to_lir entry point
 *
 * Does not own:
 * - ANF expression/statement lowering (see src/ir/lir/lir.nx)
 * - LIR type definitions (see src/ir/lir/types.nx)
 * - LowerCtx and atom helpers (see src/ir/lir/context.nx)
 * - Maranget pattern-matrix → DecTree (see src/ir/lir/match_tree.nx)
 */
import {
  TypeExpr,
  TyUserDefined,
  TyRecord,
  TyArrow,
  NamedType,
  EnumDef,
  VariantDef,
  VariantField,
  RecordDef,
  TyVar,
  TyList,
  TyI64,
  TyF64,
  TyString,
  TyBool,
  TyChar,
  TyUnit
} from "src/types/type_expr.nx"
import {
  Literal,
  LitInt,
  LitFloat,
  LitBool,
  LitChar,
  LitString,
  LitUnit
} from "src/types/vocab.nx"
import * as list from "std:list"
import { from_i64 }, * as str from "std:str"
import { LirError } from "src/ir/lir/errors.nx"
import { Some, None } from "std:option"
import {
  MirProgram,
  MirFunction,
  MirParam,
  MirExternal,
  MirExpr,
  MirVariable,
  MirRecord,
  MirLiteral,
  MirNamedExpr,
  MirStmt,
  MirStmtLet,
  MirStmtExpr,
  MirStmtReturn,
  MirStmtAssign,
  MirStmtTry,
  MirMakeClosure,
  MirEnvLoad,
  MirIf,
  MirMatch,
  MirWhile,
  MirBlock,
  MirMatchCase
} from "src/ir/mir/types.nx"
import { LirProgram, LirFunction, LirExternal, LirParam } from "src/ir/lir/types.nx"
import { LowerCtx, TypeEntry, wasm_type, insert_type, default_atom } from "src/ir/lir/context.nx"
import { VariantIndex }, * as vidx from "src/ir/support/variant_index.nx"
import { lir_lower_stmts, LowerStmtsResult } from "src/ir/lir/lir.nx"
import {
  lir_str_less_than,
  sort_mir_params,
  env_slot_sentinel,
  fnsig_sentinel
} from "src/ir/lir/semantic_types.nx"
import { gen_struct_eq_helpers } from "src/ir/lir/struct_eq.nx"

let lir_lower_function = fn (
  f: MirFunction,
  enum_defs: VariantIndex,
  type_defs: [ RecordDef ],
  func_types: [ TypeEntry ],
  sem_func_types: [ TypeEntry ],
  env_type_entries: [ TypeEntry ]
) -> LirFunction throws { LirError } do
  let MirFunction(name: fname, params: raw_params, ret_type: rt, body, span: sp) = f
  let params = sort_mir_params(params: raw_params)
    let wasm_ret = wasm_type(typ: rt)
    // Prepend param_vars before func_types so params shadow any same-named functions.
    // Store wasm_ret under the sentinel name "#FN_RET#" so nested lowering paths
    // (match-as-expression branches with `return`) can recover the function's
    // return type for emitting LirStmtIfReturn without threading ret_type
    // through ~25 call sites of lower_expr_to_atom.
    let param_vars = build_param_vars(params)
    // semantic_vars stores types as observed by match-pattern lowering. We
    // resolve TyUserDefined → TyRecord eagerly here so that
    // `match (r: Recd) do | { a, b } ...` looks up field indices on the
    // expanded record shape rather than reading offset 0 for every field.
    let param_sem_vars = build_param_semantic_vars(params, type_defs)
    // Prepend param_sem_vars before sem_func_types so parameters shadow
    // any same-named function. sem_func_types maps function names to their
    // resolved semantic return type (TyRecord for structural record returns)
    // so that lower_expr_to_atom can recover the correct semantic type for
    // MirCall results without threading type_defs through LowerCtx.
    let all_sem_vars = prepend_type_entries(xs: param_sem_vars, ys: sem_func_types)
    let sem_vars_with_fn_ret = insert_type(name: "#FN_RET#", typ: wasm_ret, entries: all_sem_vars)
    // Captured-record env types: the registry (a SEPARATE, small
    // list holding only closure-capture entries) keys entries by the LIFTED
    // closure fn name (`#ENVTYPE#<lifted_fn>#<slot>`). Re-key the entries
    // belonging to THIS function down to the slot-only key (`#ENVTYPE#<slot>`)
    // and prepend them, so the MirEnvLoad lowering inside this body can look
    // them up without threading the current fn name. Kept out of
    // `sem_func_types` so it does not bloat every function's semantic_vars.
    let local_env_types = rekey_env_types_for_fn(fname, entries: env_type_entries, acc: [])
    let ctx = LowerCtx(
      vars: prepend_type_entries(xs: param_vars, ys: func_types),
      semantic_vars: prepend_type_entries(xs: local_env_types, ys: sem_vars_with_fn_ret),
      stmts: [],
      temp_counter: 0,
      enum_defs
    )
    let LowerStmtsResult(
      ctx: LowerCtx(vars: _, semantic_vars: _, stmts, temp_counter: _, enum_defs: _),
      ret: ret_val
    ) = lir_lower_stmts(stmts: body, ret_type: wasm_ret, ctx)
    let ret_atom = match ret_val do
        | Some(val: a) -> a
        | None -> default_atom(typ: wasm_ret)
      end
      let lir_params = lir_convert_params(params)
      return LirFunction(
        name: fname,
        params: lir_params,
        ret_type: wasm_ret,
        body: list.reverse(xs: stmts),
        ret: ret_atom,
        span: sp
      )
end

let build_param_vars = fn (params: [ MirParam ]) -> [ TypeEntry ] throws { LirError } do
  return build_param_vars_go(params, acc: [])
end

let build_param_vars_go = fn (
  params: [ MirParam ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | MirParam(label: _, name: n, typ: t) :: rest ->
      return build_param_vars_go(
        params: rest,
        acc: TypeEntry(name: n, typ: wasm_type(typ: t)) :: acc
      )
  end
end

let build_param_semantic_vars = fn (
  params: [ MirParam ],
  type_defs: [ RecordDef ]
) -> [ TypeEntry ] throws { LirError } do
  return build_param_semantic_vars_go(params, type_defs, acc: [])
end

let build_param_semantic_vars_go = fn (
  params: [ MirParam ],
  type_defs: [ RecordDef ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | MirParam(label: _, name: n, typ: t) :: rest ->
      let resolved = resolve_typedef(typ: t, type_defs)
      return build_param_semantic_vars_go(
        params: rest,
        type_defs,
        acc: TypeEntry(name: n, typ: resolved) :: acc
      )
  end
end

/**
Rewrite TyUserDefined → TyRecord whenever the named type def is a record
alias. Necessary at param-binding time so match-pattern lowering can read
sorted field indices instead of falling back to offset 0.
*/
let resolve_typedef = fn (
  typ: TypeExpr,
  type_defs: [ RecordDef ]
) -> TypeExpr throws { LirError } do
  if let TyUserDefined(name: n, args: _) = typ then
    match lookup_record_def(name: n, defs: type_defs) do
      | Some(val: RecordDef(name: _, is_public: _, type_params: _, fields)) ->
        return TyRecord(fields)
      | None -> return typ
    end
  else
    return typ
  end
end

// Normalize a SIGNATURE type for generic-return recovery: resolve named
// records to `TyRecord` (so layout is visible), and rewrite every remaining
// `TyUserDefined(name, …)` whose `name` is NOT a known concrete type (record
// or enum) into `TyVar(name)` — i.e. a type PARAMETER. At MIR a generic `T`
// is carried as `TyUserDefined("T", [])`, indistinguishable by shape from a
// real named type; the known-names set is what disambiguates it. Recurses
// through `[T]`, `K<…>` args, and record fields so `Option<T>` / `[T]` get
// their inner type parameters marked too. `recover_generic_call_type` then
// treats the marked `TyVar`s uniformly (guard / unify / substitute).
let normalize_type_params = fn (
  typ: TypeExpr,
  type_defs: [ RecordDef ],
  known_names: [ string ]
) -> TypeExpr throws { LirError } do
  match typ do
    | TyUserDefined(name: n, args: ats) ->
      match lookup_record_def(name: n, defs: type_defs) do
        | Some(val: RecordDef(name: _, is_public: _, type_params: _, fields)) -> return TyRecord(fields)
        | None ->
          if str_list_contains(xs: known_names, s: n) then
            return TyUserDefined(name: n, args: normalize_type_params_list(ts: ats, type_defs, known_names))
          else
            // Not a record, not a known enum ⇒ a type parameter.
            return TyVar(name: n)
          end
      end
    | TyList(elem: e) -> return TyList(elem: normalize_type_params(typ: e, type_defs, known_names))
    | TyRecord(fields: fs) -> return TyRecord(fields: normalize_named_type_params(nts: fs, type_defs, known_names))
    | _ -> return typ
  end
end

let normalize_type_params_list = fn (
  ts: [ TypeExpr ],
  type_defs: [ RecordDef ],
  known_names: [ string ]
) -> [ TypeExpr ] throws { LirError } do
  match ts do
    | [] -> return []
    | t :: rest ->
      return normalize_type_params(typ: t, type_defs, known_names) :: normalize_type_params_list(ts: rest, type_defs, known_names)
  end
end

let normalize_named_type_params = fn (
  nts: [ NamedType ],
  type_defs: [ RecordDef ],
  known_names: [ string ]
) -> [ NamedType ] throws { LirError } do
  match nts do
    | [] -> return []
    | NamedType(name: n, typ: t) :: rest ->
      return NamedType(name: n, typ: normalize_type_params(typ: t, type_defs, known_names)) :: normalize_named_type_params(nts: rest, type_defs, known_names)
  end
end

let str_list_contains = fn (xs: [ string ], s: string) -> bool throws { LirError } do
  match xs do
    | [] -> return false
    | x :: rest -> if x == s then return true else return str_list_contains(xs: rest, s) end
  end
end

// Known concrete type names = every enum name (incl. builtins) ∪ every record
// name. Used by `normalize_type_params` to tell a type parameter apart from a
// real named type.
let collect_type_names = fn (
  enum_defs: [ EnumDef ],
  type_defs: [ RecordDef ]
) -> [ string ] throws { LirError } do
  return collect_enum_names(enum_defs, acc: collect_record_names(type_defs, acc: []))
end

let collect_enum_names = fn (enum_defs: [ EnumDef ], acc: [ string ]) -> [ string ] throws { LirError } do
  match enum_defs do
    | [] -> return acc
    | EnumDef(name: n, is_public: _, is_opaque: _, type_params: _, variants: _, layout_variants: _) :: rest ->
      return collect_enum_names(enum_defs: rest, acc: n :: acc)
  end
end

let collect_record_names = fn (type_defs: [ RecordDef ], acc: [ string ]) -> [ string ] throws { LirError } do
  match type_defs do
    | [] -> return acc
    | RecordDef(name: n, is_public: _, type_params: _, fields: _) :: rest ->
      return collect_record_names(type_defs: rest, acc: n :: acc)
  end
end

let lookup_record_def = fn (name: string, defs: [ RecordDef ]) -> Option<RecordDef> do
  match defs do
    | [] -> return None
    | RecordDef(name: n, is_public: p, type_params: tps, fields: fs) :: rest ->
      if n == name then
        return Some(val: RecordDef(name: n, is_public: p, type_params: tps, fields: fs))
      end
      return lookup_record_def(name, defs: rest)
  end
end

let lir_convert_params = fn (params: [ MirParam ]) -> [ LirParam ] throws { LirError } do
  let converted = lir_convert_params_go(params, acc: [])
  return sort_lir_params(params: converted)
end

let lir_convert_params_go = fn (
  params: [ MirParam ],
  acc: [ LirParam ]
) -> [ LirParam ] throws { LirError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | MirParam(label: l, name: n, typ: t) :: rest ->
      return lir_convert_params_go(
        params: rest,
        acc: LirParam(label: l, name: n, typ: wasm_type(typ: t)) :: acc
      )
  end
end

let sort_lir_params = fn (params: [ LirParam ]) -> [ LirParam ] throws { LirError } do
  match params do
    | [] -> return []
    | p :: rest -> return insert_lir_param(p, sorted: sort_lir_params(params: rest))
  end
end

let insert_lir_param = fn (p: LirParam, sorted: [ LirParam ]) -> [ LirParam ] throws { LirError } do
  return insert_lir_param_go(p, sorted, acc: [])
end

let insert_lir_param_go = fn (
  p: LirParam,
  sorted: [ LirParam ],
  acc: [ LirParam ]
) -> [ LirParam ] throws { LirError } do
  match sorted do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: [ p ])
    | head :: rest ->
      let LirParam(label: la, name: _, typ: _) = p
      let LirParam(label: lb, name: _, typ: _) = head
      if lir_str_less_than(a: la, b: lb) then
            return list.concat(xs: list.reverse(xs: acc), ys: p :: sorted)
          else
            return insert_lir_param_go(p, sorted: rest, acc: head :: acc)
          end
  end
end

let convert_external = fn (ext: MirExternal) -> LirExternal throws { LirError } do
  let MirExternal(
    name: n,
    wasm_module: wm,
    wasm_name: wn,
    params: ps,
    ret_type: rt,
    throw_row: tr
  ) = ext
  return LirExternal(
      name: n, wasm_module: wm, wasm_name: wn,
      params: convert_ext_params(params: ps),
      ret_type: wasm_type(typ: rt),
      throw_row: tr
    )
end

let convert_ext_params = fn (params: [ MirParam ]) -> [ LirParam ] throws { LirError } do
  return convert_ext_params_go(params, acc: [])
end

let convert_ext_params_go = fn (
  params: [ MirParam ],
  acc: [ LirParam ]
) -> [ LirParam ] throws { LirError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | MirParam(label: l, name: n, typ: t) :: rest ->
      // Preserve semantic type for externals (emit_external_arg needs TyString/TyArray)
      return convert_ext_params_go(params: rest, acc: LirParam(label: l, name: n, typ: t) :: acc)
  end
end

let builtin_enum_defs = fn () -> [ EnumDef ] throws { LirError } do
  return [
    EnumDef(name: "List", is_public: true, is_opaque: false,
      type_params: [ "T"],
      variants: [
        VariantDef(name: "Nil", fields: []),
        VariantDef(name: "Cons", fields: [
          VariantField(name: Some(val: "v"), typ: TyVar(name: "T")),
          VariantField(name: Some(val: "rest"), typ: TyList(elem: TyVar(name: "T"))) ]) ],
      layout_variants: [], module: ""),
    EnumDef(name: "Option", is_public: true, is_opaque: false,
      type_params: [ "T"],
      variants: [
        VariantDef(name: "None", fields: []),
        VariantDef(name: "Some", fields: [
          VariantField(name: Some(val: "val"), typ: TyVar(name: "T")) ]) ],
      layout_variants: [], module: ""),
    EnumDef(name: "Result", is_public: true, is_opaque: false,
      type_params: [ "T", "E" ],
      variants: [
        VariantDef(name: "Ok", fields: [
          VariantField(name: Some(val: "val"), typ: TyVar(name: "T")) ]),
        VariantDef(name: "Err", fields: [
          VariantField(name: Some(val: "err"), typ: TyVar(name: "E")) ]) ],
      layout_variants: [], module: "") ]
end

let prepend_defs = fn (xs: [ EnumDef ], ys: [ EnumDef ]) -> [ EnumDef ] throws { LirError } do
  return prepend_defs_go(xs, ys, acc: [])
end

let prepend_defs_go = fn (
  xs: [ EnumDef ],
  ys: [ EnumDef ],
  acc: [ EnumDef ]
) -> [ EnumDef ] throws { LirError } do
  match xs do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: ys)
    | x :: rest -> return prepend_defs_go(xs: rest, ys, acc: x :: acc)
  end
end

// Build type entries for all function return types so that MirVariable references
// to top-level constants (zero-arg functions) resolve to the correct WASM type
// instead of defaulting to TyI64.
let build_func_type_entries = fn (funcs: [ MirFunction ]) -> [ TypeEntry ] throws { LirError } do
  return build_func_type_entries_go(funcs, acc: [])
end

let build_func_type_entries_go = fn (
  funcs: [ MirFunction ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | MirFunction(name: n, params: _, ret_type: rt, body: _, span: _) :: rest ->
      return build_func_type_entries_go(
        funcs: rest,
        acc: TypeEntry(name: n, typ: wasm_type(typ: rt)) :: acc
      )
  end
end

// Build semantic type entries for all function return types, resolving
// TyUserDefined → TyRecord for structural record return types. These entries
// are stored in semantic_vars so that lower_expr_to_atom can recover the
// correct TyRecord semantic type when a call returns a named record type
// (e.g. `type Trip = { a, b, c }`) instead of the raw TyUserDefined.
let build_func_semantic_type_entries = fn (
  funcs: [ MirFunction ],
  type_defs: [ RecordDef ],
  known_names: [ string ]
) -> [ TypeEntry ] throws { LirError } do
  return build_func_semantic_type_entries_go(funcs, type_defs, known_names, acc: [])
end

let build_func_semantic_type_entries_go = fn (
  funcs: [ MirFunction ],
  type_defs: [ RecordDef ],
  known_names: [ string ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | MirFunction(name: n, params: _, ret_type: rt, body: _, span: _) :: rest ->
      // Mark a generic return's type parameter (`TyUserDefined("T",[])`) as a
      // `TyVar` so the MirCall recovery's guard fires; concrete record/sum
      // returns are resolved/kept unchanged.
      let sem_rt = normalize_type_params(typ: rt, type_defs, known_names)
      return build_func_semantic_type_entries_go(
        funcs: rest,
        type_defs,
        known_names,
        acc: TypeEntry(name: n, typ: sem_rt) :: acc
      )
  end
end

// Build full SEMANTIC signature entries for every function, keyed
// `#FNSIG#<name>` → `TyArrow(params, ret)`. Parameter and return types are
// resolved (`TyUserDefined` record → `TyRecord`) but type VARIABLES are
// preserved, so a generic callee's `(x: T) -> T` / `(xs: [T]) -> T` keeps the
// `TyVar`s that `recover_generic_call_type` unifies against the call's
// argument types to instantiate the result's record/sum layout. The
// `requires`/`throw_row` slots carry `TyUnit` placeholders — the consumer
// reads only `params` and (indirectly) the return type. Kept under a sentinel
// key so it does not shadow the plain `<name>` return-type entry that
// `MirVariable`/`MirCall` lookups depend on.
let build_func_sig_entries = fn (
  funcs: [ MirFunction ],
  type_defs: [ RecordDef ],
  known_names: [ string ]
) -> [ TypeEntry ] throws { LirError } do
  return build_func_sig_entries_go(funcs, type_defs, known_names, acc: [])
end

let build_func_sig_entries_go = fn (
  funcs: [ MirFunction ],
  type_defs: [ RecordDef ],
  known_names: [ string ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | MirFunction(name: n, params: ps, ret_type: rt, body: _, span: _) :: rest ->
      let sig = TyArrow(
          params: build_sig_param_types(params: ps, type_defs, known_names, acc: []),
          ret: normalize_type_params(typ: rt, type_defs, known_names),
          requires: TyUnit,
          throw_row: TyUnit
        )
      return build_func_sig_entries_go(
        funcs: rest,
        type_defs,
        known_names,
        acc: TypeEntry(name: fnsig_sentinel(name: n), typ: sig) :: acc
      )
  end
end

let build_sig_param_types = fn (
  params: [ MirParam ],
  type_defs: [ RecordDef ],
  known_names: [ string ],
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | MirParam(label: l, name: _, typ: t) :: rest ->
      return build_sig_param_types(
        params: rest,
        type_defs,
        known_names,
        acc: NamedType(name: l, typ: normalize_type_params(typ: t, type_defs, known_names)) :: acc
      )
  end
end

let prepend_type_entries = fn (
  xs: [ TypeEntry ],
  ys: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  return prepend_type_entries_go(xs, ys, acc: [])
end

let prepend_type_entries_go = fn (
  xs: [ TypeEntry ],
  ys: [ TypeEntry ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match xs do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: ys)
    | x :: rest -> return prepend_type_entries_go(xs: rest, ys, acc: x :: acc)
  end
end

// --- Captured-record env-type registry ---
//
// A record value captured into a closure loses its semantic type at MIR:
// `MirEnvLoad` carries no type and the env-load preamble binds it as TyI64,
// so a `.field` inside the lifted closure body aborts LIR lowering with
// E6002. We recover the type with a forward registry: for each enclosing
// function, walk its body for `MirMakeClosure(lifted_fn, captures)`; for
// each capture that names a local of record shape, emit a sentinel entry
// `#ENVTYPE#<lifted_fn>#<slot>` → its resolved TyRecord. These entries are
// prepended into the program-wide `sem_func_types` (already threaded into
// every function's `semantic_vars`), and the `MirEnvLoad` lowering looks
// them up via the function's own `#FN_NAME#` sentinel. Lifted closures are
// emitted after their enclosing function, but the registry is built from the
// WHOLE program up front, so ordering does not matter.

let env_type_sentinel = fn (lifted_fn: string, slot: i64) -> string throws { LirError } do
  return "#ENVTYPE#" ++ lifted_fn ++ "#" ++ from_i64(val: slot)
end

// Keep only the registry entries belonging to `fname` (keyed
// `#ENVTYPE#<fname>#<slot>`) and re-key them to the slot-only form so a
// MirEnvLoad inside this function's body can look them up.
let rekey_env_types_for_fn = fn (
  fname: string,
  entries: [ TypeEntry ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match entries do
    | [] -> return list.reverse(xs: acc)
    | TypeEntry(name: n, typ: t) :: rest ->
      let prefix = "#ENVTYPE#" ++ fname ++ "#"
      let plen = str.length(s: prefix)
      let acc2 = if str.starts_with(s: n, prefix) then
          // Drop the `<fname>#` middle, keeping the `#ENVTYPE#` head and the
          // trailing `<slot>` → slot-only key consumed inside this body.
          let slot_str = str.substring(s: n, start: plen, len: str.length(s: n) - plen)
          TypeEntry(name: "#ENVTYPE#" ++ slot_str, typ: t) :: acc
        else acc end
      return rekey_env_types_for_fn(fname, entries: rest, acc: acc2)
  end
end

// Best-effort semantic type of a record-literal field expression, used only
// when the captured local was an unannotated `let capv = { ... }` (MIR let
// type is TyUnit). Only record shapes matter for later `.field` resolution;
// scalars resolve to their wasm-comparable semantic type and anything else
// falls back to TyI64.
let mir_record_field_type = fn (
  e: MirExpr,
  locals: [ TypeEntry ],
  type_defs: [ RecordDef ]
) -> TypeExpr throws { LirError } do
  match e do
    | MirLiteral(lit: l) ->
      match l do
        | LitInt(_) -> return TyI64
        | LitFloat(_) -> return TyF64
        | LitBool(_) -> return TyBool
        | LitChar(_) -> return TyChar
        | LitString(_) -> return TyString
        | LitUnit -> return TyUnit
      end
    | MirRecord(fields: fs) -> return TyRecord(fields: mir_record_named_types(fields: fs, locals, type_defs, acc: []))
    | MirVariable(name: n) ->
      match lookup_type_entry(name: n, entries: locals) do
        | Some(val: t) -> return t
        | None -> return TyI64
      end
    | _ -> return TyI64
  end
end

let mir_record_named_types = fn (
  fields: [ MirNamedExpr ],
  locals: [ TypeEntry ],
  type_defs: [ RecordDef ],
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | MirNamedExpr(name: n, value: v) :: rest ->
      let ft = mir_record_field_type(e: v, locals, type_defs)
      return mir_record_named_types(fields: rest, locals, type_defs, acc: NamedType(name: n, typ: ft) :: acc)
  end
end

let lookup_type_entry = fn (name: string, entries: [ TypeEntry ]) -> Option<TypeExpr> throws { LirError } do
  match entries do
    | [] -> return None
    | TypeEntry(name: n, typ: t) :: rest ->
      if n == name then return Some(val: t) else return lookup_type_entry(name, entries: rest) end
  end
end

// Resolve a captured local's RECORD semantic type, or None when the binding
// is not record-shaped (scalars / closures need no env-type recovery — the
// existing TyI64 default is correct for them).
let resolve_record_local = fn (
  declared: TypeExpr,
  rhs: Option<MirExpr>,
  locals: [ TypeEntry ],
  type_defs: [ RecordDef ]
) -> Option<TypeExpr> throws { LirError } do
  // Prefer the declared type (annotated `let capv: Inner` / params) resolved
  // through the record-alias table.
  let resolved = resolve_typedef(typ: declared, type_defs)
  if let TyRecord(_) = resolved then
    return Some(val: resolved)
  end
  // Unannotated `let capv = { ... }` → declared is TyUnit; recover from RHS.
  match rhs do
    | Some(val: r) ->
      let from_rhs = mir_record_field_type(e: r, locals, type_defs)
      if let TyRecord(_) = from_rhs then return Some(val: from_rhs) else return None end
    | None -> return None
  end
end

// Collect the record-shaped local bindings of a single function (params +
// MirStmtLet, recursively through nested stmt-bearing exprs). The resulting
// name→TypeExpr table is then consulted when a MakeClosure captures one of
// these names. `env_for_fn` is the slot-keyed (`#ENVTYPE#<slot>`) env-type
// registry already accumulated for THIS function — used to recognize an
// env-load-preamble let (`let capv = MirEnvLoad(__env, idx)`) inside a lifted
// closure as a record, so a NESTED closure capturing that re-bound name is
// itself typed.
let collect_func_record_locals = fn (
  func: MirFunction,
  type_defs: [ RecordDef ],
  env_for_fn: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  let MirFunction(name: _, params: ps, ret_type: _, body, span: _) = func
  let with_params = collect_param_record_locals(params: ps, type_defs, acc: [])
  return collect_stmts_record_locals(stmts: body, type_defs, env_for_fn, acc: with_params)
end

let collect_param_record_locals = fn (
  params: [ MirParam ],
  type_defs: [ RecordDef ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match params do
    | [] -> return acc
    | MirParam(label: _, name: n, typ: t) :: rest ->
      let resolved = resolve_typedef(typ: t, type_defs)
      let acc2 = if let TyRecord(_) = resolved then TypeEntry(name: n, typ: resolved) :: acc else acc end
      return collect_param_record_locals(params: rest, type_defs, acc: acc2)
  end
end

let collect_stmts_record_locals = fn (
  stmts: [ MirStmt ],
  type_defs: [ RecordDef ],
  env_for_fn: [ TypeEntry ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match stmts do
    | [] -> return acc
    | s :: rest ->
      let acc2 = collect_stmt_record_locals(stmt: s, type_defs, env_for_fn, acc)
      return collect_stmts_record_locals(stmts: rest, type_defs, env_for_fn, acc: acc2)
  end
end

let collect_stmt_record_locals = fn (
  stmt: MirStmt,
  type_defs: [ RecordDef ],
  env_for_fn: [ TypeEntry ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match stmt do
    | MirStmtLet(name: n, typ: t, expr: e) ->
      // An env-load-preamble let inside a lifted closure: recover its record
      // type from this function's slot-keyed env registry.
      match env_load_record_type(expr: e, env_for_fn) do
        | Some(val: ert) -> return TypeEntry(name: n, typ: ert) :: acc
        | None ->
          match resolve_record_local(declared: t, rhs: Some(val: e), locals: acc, type_defs) do
            | Some(val: rt) -> return TypeEntry(name: n, typ: rt) :: acc
            | None -> return collect_expr_record_locals(expr: e, type_defs, env_for_fn, acc)
          end
      end
    | MirStmtExpr(expr: e) | MirStmtReturn(expr: e) -> return collect_expr_record_locals(expr: e, type_defs, env_for_fn, acc)
    | MirStmtAssign(target: _, value: v) -> return collect_expr_record_locals(expr: v, type_defs, env_for_fn, acc)
    | MirStmtTry(body: b, catch_param: _, catch_body: cb) ->
      let a1 = collect_stmts_record_locals(stmts: b, type_defs, env_for_fn, acc)
      return collect_stmts_record_locals(stmts: cb, type_defs, env_for_fn, acc: a1)
    | _ -> return acc
  end
end

// If `e` is `MirEnvLoad(_, idx)` and the slot-keyed registry holds a TyRecord
// for slot idx, return it. Used to type env-load-preamble lets.
let env_load_record_type = fn (
  expr: MirExpr,
  env_for_fn: [ TypeEntry ]
) -> Option<TypeExpr> throws { LirError } do
  if let MirEnvLoad(env_var: _, index: idx) = expr then
    match lookup_type_entry(name: env_slot_sentinel(slot: idx), entries: env_for_fn) do
      | Some(val: TyRecord(fields: fs)) -> return Some(val: TyRecord(fields: fs))
      | _ -> return None
    end
  else
    return None
  end
end

let collect_expr_record_locals = fn (
  expr: MirExpr,
  type_defs: [ RecordDef ],
  env_for_fn: [ TypeEntry ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match expr do
    | MirIf(cond: _, then_body: tb, else_body: eb) ->
      let a1 = collect_stmts_record_locals(stmts: tb, type_defs, env_for_fn, acc)
      match eb do
        | Some(val: e2) -> return collect_stmts_record_locals(stmts: e2, type_defs, env_for_fn, acc: a1)
        | None -> return a1
      end
    | MirWhile(cond: _, body: b) -> return collect_stmts_record_locals(stmts: b, type_defs, env_for_fn, acc)
    | MirBlock(stmts: b) -> return collect_stmts_record_locals(stmts: b, type_defs, env_for_fn, acc)
    | MirInjectValue(stmts: b, ret_type: _) -> return collect_stmts_record_locals(stmts: b, type_defs, env_for_fn, acc)
    | MirMatch(target: _, cases: cs) -> return collect_match_cases_record_locals(cases: cs, type_defs, env_for_fn, acc)
    | _ -> return acc
  end
end

let collect_match_cases_record_locals = fn (
  cases: [ MirMatchCase ],
  type_defs: [ RecordDef ],
  env_for_fn: [ TypeEntry ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match cases do
    | [] -> return acc
    | MirMatchCase(pattern: _, body: b) :: rest ->
      let a1 = collect_stmts_record_locals(stmts: b, type_defs, env_for_fn, acc)
      return collect_match_cases_record_locals(cases: rest, type_defs, env_for_fn, acc: a1)
  end
end

// Walk a function body for MakeClosure sites and emit env-type sentinel
// entries for any capture that resolves to a record local of THIS function.
// `registry_so_far` is the program-wide env-type registry accumulated for
// already-processed functions; its entries for THIS function (re-keyed to the
// slot-only form) let env-load-preamble lets in a lifted closure be typed as
// records, so a nested closure capturing them is itself typed (pin4).
let collect_env_type_entries_for_func = fn (
  func: MirFunction,
  type_defs: [ RecordDef ],
  registry_so_far: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  let MirFunction(name: fname, params: _, ret_type: _, body, span: _) = func
  let env_for_fn = rekey_env_types_for_fn(fname, entries: registry_so_far, acc: [])
  let locals = collect_func_record_locals(func, type_defs, env_for_fn)
  return env_entries_from_stmts(stmts: body, locals, acc: [])
end

let env_entries_from_stmts = fn (
  stmts: [ MirStmt ],
  locals: [ TypeEntry ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match stmts do
    | [] -> return acc
    | s :: rest ->
      let acc2 = env_entries_from_stmt(stmt: s, locals, acc)
      return env_entries_from_stmts(stmts: rest, locals, acc: acc2)
  end
end

let env_entries_from_stmt = fn (
  stmt: MirStmt,
  locals: [ TypeEntry ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match stmt do
    | MirStmtLet(name: _, typ: _, expr: e) -> return env_entries_from_expr(expr: e, locals, acc)
    | MirStmtExpr(expr: e) | MirStmtReturn(expr: e) -> return env_entries_from_expr(expr: e, locals, acc)
    | MirStmtAssign(target: _, value: v) -> return env_entries_from_expr(expr: v, locals, acc)
    | MirStmtTry(body: b, catch_param: _, catch_body: cb) ->
      let a1 = env_entries_from_stmts(stmts: b, locals, acc)
      return env_entries_from_stmts(stmts: cb, locals, acc: a1)
    | _ -> return acc
  end
end

let env_entries_from_expr = fn (
  expr: MirExpr,
  locals: [ TypeEntry ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match expr do
    | MirMakeClosure(func_name: fn_name, captures: caps) ->
      return env_entries_from_captures(lifted_fn: fn_name, captures: caps, slot: 0, locals, acc)
    | MirIf(cond: _, then_body: tb, else_body: eb) ->
      let a1 = env_entries_from_stmts(stmts: tb, locals, acc)
      match eb do
        | Some(val: e2) -> return env_entries_from_stmts(stmts: e2, locals, acc: a1)
        | None -> return a1
      end
    | MirWhile(cond: _, body: b) -> return env_entries_from_stmts(stmts: b, locals, acc)
    | MirBlock(stmts: b) -> return env_entries_from_stmts(stmts: b, locals, acc)
    | MirInjectValue(stmts: b, ret_type: _) -> return env_entries_from_stmts(stmts: b, locals, acc)
    | MirMatch(target: _, cases: cs) -> return env_entries_from_match_cases(cases: cs, locals, acc)
    | _ -> return acc
  end
end

let env_entries_from_match_cases = fn (
  cases: [ MirMatchCase ],
  locals: [ TypeEntry ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match cases do
    | [] -> return acc
    | MirMatchCase(pattern: _, body: b) :: rest ->
      let a1 = env_entries_from_stmts(stmts: b, locals, acc)
      return env_entries_from_match_cases(cases: rest, locals, acc: a1)
  end
end

let env_entries_from_captures = fn (
  lifted_fn: string,
  captures: [ MirExpr ],
  slot: i64,
  locals: [ TypeEntry ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match captures do
    | [] -> return acc
    | cap_expr :: rest ->
      let acc2 = match cap_expr do
        | MirVariable(name: vn) ->
          match lookup_type_entry(name: vn, entries: locals) do
            | Some(val: rt) -> TypeEntry(name: env_type_sentinel(lifted_fn, slot), typ: rt) :: acc
            | None -> acc
          end
        | _ -> acc
      end
      return env_entries_from_captures(lifted_fn, captures: rest, slot: slot + 1, locals, acc: acc2)
  end
end

let collect_all_env_type_entries = fn (
  funcs: [ MirFunction ],
  type_defs: [ RecordDef ]
) -> [ TypeEntry ] throws { LirError } do
  return collect_all_env_type_entries_go(funcs, type_defs, acc: [])
end

let collect_all_env_type_entries_go = fn (
  funcs: [ MirFunction ],
  type_defs: [ RecordDef ],
  acc: [ TypeEntry ]
) -> [ TypeEntry ] throws { LirError } do
  match funcs do
    | [] -> return acc
    | f :: rest ->
      // Forward accumulation: pass the registry built so far so a lifted
      // closure (which appears after its enclosing fn in program order) can
      // see its own env-load preamble lets typed as records (pin4).
      let entries = collect_env_type_entries_for_func(func: f, type_defs, registry_so_far: acc)
      return collect_all_env_type_entries_go(funcs: rest, type_defs, acc: prepend_type_entries(xs: entries, ys: acc))
  end
end

/** Entry point: lower a MirProgram to a LirProgram. */
export let lower_mir_to_lir = fn (
  mir: MirProgram,
  enum_defs: [ EnumDef ],
  type_defs: [ RecordDef ]
) -> LirProgram throws { LirError } do
  let all_defs = prepend_defs(xs: builtin_enum_defs(), ys: enum_defs)
  // Carry the record-alias table on the index so match-tree lowering can
  // expand a constructor field's declared `TyUserDefined` type to its
  // `TyRecord` body when binding the field to a variable.
  let variant_idx = vidx.with_record_defs(idx: vidx.build_variant_index(defs: all_defs), record_defs: type_defs)
  let MirProgram(functions: fs, externals: exts) = mir
  let func_types = build_func_type_entries(funcs: fs)
  // Names of all concrete types (every enum incl. builtins ∪ every record).
  // Lets `normalize_type_params` tell a generic type PARAMETER
  // (`TyUserDefined("T",[])`, no matching def) from a real named type.
  let known_names = collect_type_names(enum_defs: all_defs, type_defs)
  // sem_func_types maps each function's bare name → resolved return type (with
  // generic type params marked `TyVar`). We also register its FULL signature
  // under the `#FNSIG#<name>` sentinel key (distinct namespace, no shadowing)
  // so `recover_generic_call_type` can instantiate a generic callee's
  // `TyVar`-bearing return type from the call's argument semantic types.
  let sem_func_types = prepend_type_entries(
      xs: build_func_sig_entries(funcs: fs, type_defs, known_names),
      ys: build_func_semantic_type_entries(funcs: fs, type_defs, known_names)
    )
  // Captured-record env types: a SEPARATE, small registry (only
  // closures that capture a record contribute) — kept out of sem_func_types so
  // it does not bloat every function's semantic_vars. Threaded alongside.
  let env_type_entries = collect_all_env_type_entries(funcs: fs, type_defs)
  let lowered = lir_lower_functions(functions: fs, enum_defs: variant_idx, type_defs, func_types, sem_func_types, env_type_entries)
  // Synthesize structural-compare helpers (`__streq_<Name>`) for every named
  // aggregate type and append them to the program. They recurse at run time, so
  // `==` / `!=` on a self- or mutually-recursive type compares structurally with
  // no static-expansion depth limit. The MirBinaryOp dispatch in lir.nx emits a
  // CALL to these helpers; appending them as ordinary LirFunctions makes them
  // collectable / index-assignable / callable through the normal machinery.
  let struct_eq_helpers = gen_struct_eq_helpers(enum_def_list: all_defs, record_defs: type_defs, enum_defs: variant_idx, mir_funcs: fs)
    return LirProgram(
      functions: list.concat(xs: lowered, ys: struct_eq_helpers),
      externals: convert_externals(externals: exts)
    )
end

let lir_lower_functions = fn (
  functions: [ MirFunction ],
  enum_defs: VariantIndex,
  type_defs: [ RecordDef ],
  func_types: [ TypeEntry ],
  sem_func_types: [ TypeEntry ],
  env_type_entries: [ TypeEntry ]
) -> [ LirFunction ] throws { LirError } do
  return lir_lower_functions_go(functions, enum_defs, type_defs, func_types, sem_func_types, env_type_entries, acc: [])
end

let lir_lower_functions_go = fn (
  functions: [ MirFunction ],
  enum_defs: VariantIndex,
  type_defs: [ RecordDef ],
  func_types: [ TypeEntry ],
  sem_func_types: [ TypeEntry ],
  env_type_entries: [ TypeEntry ],
  acc: [ LirFunction ]
) -> [ LirFunction ] throws { LirError } do
  match functions do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      return lir_lower_functions_go(functions: rest, enum_defs, type_defs, func_types, sem_func_types, env_type_entries,
        acc: lir_lower_function(f, enum_defs, type_defs, func_types, sem_func_types, env_type_entries) :: acc)
  end
end

let convert_externals = fn (externals: [ MirExternal ]) -> [ LirExternal ] throws { LirError } do
  return convert_externals_go(externals, acc: [])
end

let convert_externals_go = fn (
  externals: [ MirExternal ],
  acc: [ LirExternal ]
) -> [ LirExternal ] throws { LirError } do
  match externals do
    | [] -> return list.reverse(xs: acc)
    | e :: rest ->
      return convert_externals_go(externals: rest, acc: convert_external(ext: e) :: acc)
  end
end
