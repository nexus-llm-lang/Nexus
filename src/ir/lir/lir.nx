/**
 * lir: MIR → LIR lowering (A-Normal Form with semantic-type tracking).
 *
 * Owns:
 * - ANF-lowering of sub-expressions to atomic values
 * - match / if conversion to conditional assignment chains
 * - Statement lowering (lir_lower_stmts, lower_stmt_inner and helpers)
 *
 * Does not own:
 * - Decision-tree emission (Expr Mode + Stmt Mode) — see src/ir/lir/emit_tree.nx
 *   (extracted via callback injection: lower_branch_body / lower_case_body)
 * - Function/external lowering, entry point lower_mir_to_lir
 *   (see src/ir/lir/func_lower.nx — DAG leaf over this file)
 * - LowerCtx and the atom / type / temp-var helpers (see src/ir/lir/context.nx)
 * - LIR type definitions (see src/ir/lir/types.nx)
 * - Maranget pattern-matrix → DecTree construction (see src/ir/lir/match_tree.nx)
 * - Semantic-type inference, record-field resolution, canonical label sorting
 *   (see src/ir/lir/semantic_types.nx)
 * - Pure DAG-leaf utilities (atom inspection, stmt-list ops, match result inference)
 *   (see src/ir/lir/lower_helpers.nx)
 * - LIR-level optimization passes (see src/ir/lir/opt.nx)
 */
import { TypeExpr, TyUserDefined, TyLazy, TyArrow, TyRecord, TyList, TyArray } from "src/types/type_expr.nx"
import * as list from "std:list"
import { LirError } from "src/ir/lir/errors.nx"
import { Some, None } from "std:option"
import { MirExpr, MirStmt, MirCallArg, MirMatchCase, MirNamedExpr } from "src/ir/mir/types.nx"
import { LirAtom, LirStmt, LirCallArg, LirNamedAtom } from "src/ir/lir/types.nx"
import {
  LowerCtx,
  TempResult,
  BindResult,
  BranchBodyResult,
  BlockResult,
  lir_lookup_type,
  insert_type,
  wasm_type,
  atom_type,
  default_atom,
  new_temp,
  bind_expr_to_temp,
  bind_expr_to_temp_semantic,
  literal_to_atom
} from "src/ir/lir/context.nx"
import {
  PatBinding,
  DecTree,
  CtorBranch,
  LitBranch,
  AtomEntry,
  DecTreeResult,
  FieldExtractResult,
  CtorCondsResult,
  LitCondsResult
} from "src/ir/lir/match_tree/types.nx"
import {
  lir_build_decision_tree,
  lir_cases_to_rows,
  lir_reverse_ctors,
  lir_reverse_lit_branches,
  lookup_atom_entry,
  lir_reverse_atoms,
  lir_ctors_length,
  lir_emit_bindings,
  lir_emit_ctor_conds,
  lir_emit_lit_conds,
  lir_extract_ctor_fields,
  lir_extract_record_fields,
  lir_nth_case_body
} from "src/ir/lir/match_tree.nx"
import {
  FieldResolution,
  infer_semantic_type,
  resolve_closure_ret_type,
  infer_stmts_type,
  is_semantic_string,
  infer_binary_type,
  sort_lir_call_args,
  sort_lir_named_atoms,
  build_record_semantic_type,
  resolve_record_field,
  env_slot_sentinel
} from "src/ir/lir/semantic_types.nx"
import {
  number_atoms,
  lir_get_fn_ret_type,
  lir_get_atom_sem_type,
  lir_infer_match_result_type,
  is_trivially_unit_body,
  fallback_ret_from_last_stmt,
  fallback_ret_from_terminal,
  push_stmts_to_reverse,
  append_stmts
} from "src/ir/lir/lower_helpers.nx"
import {
  EmitExprResult,
  EmitStmtResult,
  lir_emit_decision_tree_expr,
  lir_emit_decision_tree_stmt
} from "src/ir/lir/emit_tree.nx"
import {
  is_struct_eq_op,
  should_struct_eq,
  lower_struct_eq
} from "src/ir/lir/struct_eq.nx"

let lower_expr_to_atom = fn (expr: MirExpr, ctx: LowerCtx) -> BindResult throws { LirError } do
  match expr do
    | MirLiteral(lit: l) -> return BindResult(ctx, atom: literal_to_atom(lit: l))

    | MirVariable(name: n) ->
      let LowerCtx(vars: v, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) = ctx
      let typ = match lir_lookup_type(name: n, entries: sv) do
          // Preserve TyString for string vars (enables is_string_op detection)
          | Some(val: TyString) -> TyString
          | Some(val: t) -> wasm_type(typ: t)
          | None ->
            match lir_lookup_type(name: n, entries: v) do
              | Some(val: t) -> t
              | None -> TyI64
            end
        end
        return BindResult(ctx, atom: LirAtomVar(name: n, typ))

    | MirBinaryOp(left: lhs, op, right: rhs) ->
      let BindResult(ctx: ctx2, atom: la) = lower_expr_to_atom(expr: lhs, ctx)
      let BindResult(ctx: ctx3, atom: ra) = lower_expr_to_atom(expr: rhs, ctx: ctx2)
      let sem_lhs = infer_semantic_type(expr: lhs, ctx)
          let sem_rhs = infer_semantic_type(expr: rhs, ctx)
          // `==` / `!=` on a record or sum operand demands STRUCTURAL equality
          // (spec § T-Cmp), not the pointer-identity a plain LirExprBinary on the
          // i32 heap pointer would emit. Recover the operand's structural type
          // from either side's semantic type (one side may be TyI64-erased) and
          // emit a recursive value compare. Primitives / strings / unknown types
          // fall through to the legacy binary path unchanged.
          if is_struct_eq_op(op) && (should_struct_eq(t: sem_lhs, ctx: ctx3) || should_struct_eq(t: sem_rhs, ctx: ctx3)) then
            let struct_sem = if should_struct_eq(t: sem_lhs, ctx: ctx3) then sem_lhs else sem_rhs end
            return lower_struct_eq(op, lhs: la, rhs: ra, sem_type: struct_sem, ctx: ctx3)
          end
          let lhs_for_infer = if is_semantic_string(t: sem_lhs) then TyString else atom_type(atom: la) end
          let rhs_for_infer = if is_semantic_string(t: sem_rhs) then TyString else atom_type(atom: ra) end
          let result_type = infer_binary_type(op, lhs_type: lhs_for_infer, rhs_type: rhs_for_infer)
          return bind_expr_to_temp(ctx: ctx3,
            expr: LirExprBinary(op, lhs: la, rhs: ra, typ: result_type),
            typ: result_type)

    | MirCall(func: f, args, ret_type: rt) ->
      let LowerCallArgsResult(ctx: ctx2, lir_args: la) = lir_lower_call_args(args, ctx)
      let LowerCtx(vars: _, semantic_vars: sv2, stmts: _, temp_counter: _, enum_defs: _) = ctx2
      // Look up f in semantic_vars: sem_func_types (populated at function entry)
      // maps function names to their resolved return type, converting
      // TyUserDefined("Trip",[]) → TyRecord([...]) for structural record returns.
      // This preserves the semantic layout across the call-return boundary so
      // that subsequent field access and record destructure resolve correctly.
      let sem_rt = match lir_lookup_type(name: f, entries: sv2) do
        | Some(val: t) -> t
        | None -> rt
      end
      let wt = wasm_type(typ: rt)
        return bind_expr_to_temp_semantic(ctx: ctx2,
          expr: LirExprCall(func: f, args: la, typ: wt),
          typ: wt, semantic_type: sem_rt)

    | MirConstructor(name: n, args) ->
      let LowerExprsResult(ctx: ctx2, atoms) = lower_exprs_to_atoms(exprs: args, ctx)
      return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprConstructor(name: n, args: atoms, typ: TyI64),
          typ: TyI64)

    | MirRecord(fields) ->
      let LowerNamedExprsResult(ctx: ctx2, atoms: named_atoms) = lir_lower_named_exprs(fields, ctx)
      let sorted_atoms = sort_lir_named_atoms(atoms: named_atoms)
        let sem_type = build_record_semantic_type(atoms: sorted_atoms, ctx: ctx2)
        return bind_expr_to_temp_semantic(ctx: ctx2,
          expr: LirExprRecord(fields: sorted_atoms, typ: TyI64),
          typ: TyI64, semantic_type: sem_type)

    | MirFieldAccess(target: recv, field) ->
      let BindResult(ctx: ctx2, atom: obj_atom) = lower_expr_to_atom(expr: recv, ctx)
      let FieldResolution(
          index: idx,
          typ: ft
        ) = resolve_record_field(atom: obj_atom, field, ctx: ctx2)
        let wt = wasm_type(typ: ft)
        return bind_expr_to_temp_semantic(ctx: ctx2,
          expr: LirExprObjectField(value: obj_atom, index: idx, typ: wt),
          typ: wt, semantic_type: ft)

    | MirBorrow(name: n) ->
      let LowerCtx(vars: v, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: _) = ctx
      let typ = match lir_lookup_type(name: n, entries: v) do
          | Some(val: t) -> t
          | None -> TyI64
        end
        return BindResult(ctx, atom: LirAtomVar(name: n, typ))

    | MirRaise(expr: e) ->
      let BindResult(ctx: ctx2, atom: a) = lower_expr_to_atom(expr: e, ctx)
      return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprRaise(value: a, typ: TyUnit),
          typ: TyUnit)

    | MirForce(expr: e) ->
      let BindResult(ctx: ctx2, atom: a) = lower_expr_to_atom(expr: e, ctx)
      let inner_typ = match atom_type(atom: a) do
          // Rows are erased at runtime; only the inner result type matters.
          | TyLazy(inner: t, require_row: _, throw_row: _) -> t
          | other -> other
        end
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprForce(value: a, typ: inner_typ),
          typ: inner_typ)

    | MirIf(cond, then_body: tb, else_body: eb) ->
      return lower_if_expr(cond, then_body: tb, else_body: eb, ctx)

    | MirMatch(target: tgt, cases: cs) ->
      return lower_match_expr(target: tgt, cases: cs, ctx)

    | MirWhile(cond, body) ->
      // While in expression position: run the loop for side effects, yield unit.
      let LowerStmtResult(ctx: ctx2, ret: _) = lower_while_stmt(cond, body, ctx)
      return BindResult(ctx: ctx2, atom: LirAtomUnit)

    | MirBlock(stmts: block_stmts) ->
      // Block in expression position: lower all statements inline (same scope,
      // so mutable-ref mutations remain visible to the caller), yield unit.
      // Used for For-in-expr desugaring.
      let LowerStmtsResult(ctx: ctx2, ret: _) = lir_lower_stmts(
        stmts: block_stmts,
        ret_type: TyUnit,
        ctx
      )
      return BindResult(ctx: ctx2, atom: LirAtomUnit)

    | MirArray(elems) ->
      let LowerExprsResult(ctx: ctx2, atoms) = lower_exprs_to_atoms(exprs: elems, ctx)
      let named = number_atoms(atoms, idx: 0)
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprRecord(fields: named, typ: TyI64),
          typ: TyI64)

    | MirIndex(target: arr, index: idx) ->
      let BindResult(ctx: ctx2, atom: arr_atom) = lower_expr_to_atom(expr: arr, ctx)
      let BindResult(ctx: ctx3, atom: idx_atom) = lower_expr_to_atom(expr: idx, ctx: ctx2)
      return bind_expr_to_temp(ctx: ctx3,
            expr: LirExprCall(func: "__array_get",
              args: [
                LirCallArg(label: "arr", value: arr_atom),
                LirCallArg(label: "idx", value: idx_atom)
              ],
              typ: TyI64),
            typ: TyI64)

    | MirMakeClosure(func_name: name, captures: caps) ->
      let LowerExprsResult(ctx: ctx2, atoms: cap_atoms) = lower_exprs_to_atoms(exprs: caps, ctx)
      return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprMakeClosure(func_name: name, captures: cap_atoms, typ: TyI64),
          typ: TyI64)

    | MirCallClosure(closure: clos, args: cargs, ret_type: rt) ->
      let BindResult(ctx: ctx2, atom: clos_atom) = lower_expr_to_atom(expr: clos, ctx)
      let LowerCallArgsResult(ctx: ctx3, lir_args) = lir_lower_call_args(
          args: cargs,
          ctx: ctx2
        )
      let actual_rt = resolve_closure_ret_type(clos, fallback: rt, ctx: ctx3)
          let wt = wasm_type(typ: actual_rt)
          return bind_expr_to_temp_semantic(ctx: ctx3,
            expr: LirExprCallClosure(closure: clos_atom, args: lir_args, typ: wt),
            typ: wt, semantic_type: actual_rt)

    | MirEnvLoad(env_var: env, index: idx) ->
      // Recover a captured record's semantic type: the env-load
      // value is a raw i64 object pointer, but if the registry recorded a
      // TyRecord for this slot, bind the temp with that semantic type so a
      // subsequent `.field` resolves instead of aborting E6002.
      let LowerCtx(vars: _, semantic_vars: sv_env, stmts: _, temp_counter: _, enum_defs: _) = ctx
      let env_expr = LirExprObjectField(value: LirAtomVar(name: env, typ: TyI64), index: idx, typ: TyI64)
      match lir_lookup_type(name: env_slot_sentinel(slot: idx), entries: sv_env) do
        | Some(val: TyRecord(fields: fs)) ->
          return bind_expr_to_temp_semantic(ctx,
            expr: env_expr, typ: TyI64, semantic_type: TyRecord(fields: fs))
        | _ ->
          return bind_expr_to_temp(ctx, expr: env_expr, typ: TyI64)
      end

    | MirSuspend(tag_name: tn, payload: p, ret_type: rt) ->
      let BindResult(ctx: ctx2, atom: pa) = lower_expr_to_atom(expr: p, ctx)
      let wt = wasm_type(typ: rt)
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprSuspend(tag_name: tn, payload: pa, typ: wt),
          typ: wt)

    | MirResume(cont_var: cv, value: v, ret_type: rt) ->
      let BindResult(ctx: ctx2, atom: va) = lower_expr_to_atom(expr: v, ctx)
      let wt = wasm_type(typ: rt)
        let cont_atom = LirAtomVar(name: cv, typ: TyI64)
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprResume(cont: cont_atom, value: va, typ: wt),
          typ: wt)
  end
end

type LowerCallArgsResult = LowerCallArgsResult(ctx: LowerCtx, lir_args: [ LirCallArg ])

let lir_lower_call_args_inner = fn (
  args: [ MirCallArg ],
  ctx: LowerCtx
) -> LowerCallArgsResult throws { LirError } do
  return lir_lower_call_args_inner_go(args, ctx, acc: [])
end

let lir_lower_call_args_inner_go = fn (
  args: [ MirCallArg ],
  ctx: LowerCtx,
  acc: [ LirCallArg ]
) -> LowerCallArgsResult throws { LirError } do
  match args do
    | [] -> return LowerCallArgsResult(ctx, lir_args: list.reverse(xs: acc))
    | MirCallArg(label: l, value: e) :: rest ->
      let BindResult(ctx: ctx2, atom: a) = lower_expr_to_atom(expr: e, ctx)
      return lir_lower_call_args_inner_go(
          args: rest,
          ctx: ctx2,
          acc: LirCallArg(label: l, value: a) :: acc
        )
  end
end

let lir_lower_call_args = fn (
  args: [ MirCallArg ],
  ctx: LowerCtx
) -> LowerCallArgsResult throws { LirError } do
  // Lower args in source order (preserving side-effect evaluation), then sort by label
  let LowerCallArgsResult(ctx: c, lir_args: la) = lir_lower_call_args_inner(args, ctx)
  return LowerCallArgsResult(ctx: c, lir_args: sort_lir_call_args(args: la))
end

type LowerExprsResult = LowerExprsResult(ctx: LowerCtx, atoms: [ LirAtom ])

let lower_exprs_to_atoms = fn (
  exprs: [ MirExpr ],
  ctx: LowerCtx
) -> LowerExprsResult throws { LirError } do
  return lower_exprs_to_atoms_go(exprs, ctx, acc: [])
end

let lower_exprs_to_atoms_go = fn (
  exprs: [ MirExpr ],
  ctx: LowerCtx,
  acc: [ LirAtom ]
) -> LowerExprsResult throws { LirError } do
  match exprs do
    | [] -> return LowerExprsResult(ctx, atoms: lir_reverse_atoms(lst: acc, acc: []))
    | e :: rest ->
      let BindResult(ctx: ctx2, atom: a) = lower_expr_to_atom(expr: e, ctx)
      return lower_exprs_to_atoms_go(exprs: rest, ctx: ctx2, acc: a :: acc)
  end
end

type LowerNamedExprsResult = LowerNamedExprsResult(ctx: LowerCtx, atoms: [ LirNamedAtom ])

let lir_lower_named_exprs = fn (
  fields: [ MirNamedExpr ],
  ctx: LowerCtx
) -> LowerNamedExprsResult throws { LirError } do
  return lir_lower_named_exprs_go(fields, ctx, acc: [])
end

let lir_lower_named_exprs_go = fn (
  fields: [ MirNamedExpr ],
  ctx: LowerCtx,
  acc: [ LirNamedAtom ]
) -> LowerNamedExprsResult throws { LirError } do
  match fields do
    | [] -> return LowerNamedExprsResult(ctx, atoms: list.reverse(xs: acc))
    | MirNamedExpr(name: n, value: e) :: rest ->
      let BindResult(ctx: ctx2, atom: a) = lower_expr_to_atom(expr: e, ctx)
      return lir_lower_named_exprs_go(
          fields: rest,
          ctx: ctx2,
          acc: LirNamedAtom(name: n, value: a) :: acc
        )
  end
end

let lower_if_expr = fn (
  cond: MirExpr,
  then_body: [ MirStmt ],
  else_body: Option<[ MirStmt ]>,
  ctx: LowerCtx
) -> BindResult throws { LirError } do
  let BindResult(ctx: ctx2, atom: cond_atom) = lower_expr_to_atom(expr: cond, ctx)
  let sem_type = infer_stmts_type(stmts: then_body, ctx: ctx2)
    let result_type = wasm_type(typ: sem_type)
    let TempResult(
      ctx: LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed),
      name: result_name
    ) = new_temp(ctx: ctx2)
    let ctx4 = LowerCtx(
        vars: insert_type(name: result_name, typ: result_type, entries: v),
        semantic_vars: insert_type(name: result_name, typ: sem_type, entries: sv),
        stmts: LirStmtLet(name: result_name, typ: result_type,
                       expr: LirExprAtom(atom: default_atom(typ: result_type))) :: s,
        temp_counter: c,
        enum_defs: ed
      )
      let BranchResult(
                                      ctx: ctx5,
                                      stmts: then_stmts
                                    ) = lower_branch_for_value(body: then_body, result_name,
                                    result_type, ctx: ctx4)
      let else_r = match else_body do
          | Some(val: eb) -> lower_branch_for_value(body: eb, result_name,
                                                        result_type, ctx: ctx5)
          | None -> BranchResult(ctx: ctx5, stmts: [])
        end
        let BranchResult(
          ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: s2, temp_counter: c2, enum_defs: ed2),
          stmts: else_stmts
        ) = else_r
        let ctx7 = LowerCtx(
            vars: v2, semantic_vars: sv2,
            stmts: LirStmtIf(cond: cond_atom, then_body: then_stmts, else_body: else_stmts) :: s2,
            temp_counter: c2, enum_defs: ed2
          )
          return BindResult(ctx: ctx7, atom: LirAtomVar(name: result_name, typ: result_type))
end

type BranchResult = BranchResult(ctx: LowerCtx, stmts: [ LirStmt ])

let lower_branch_for_value = fn (
  body: [ MirStmt ],
  result_name: string,
  result_type: TypeExpr,
  ctx: LowerCtx
) -> BranchResult throws { LirError } do
  // Save current statements, lower branch in isolation
  let LowerCtx(vars: v, semantic_vars: sv, stmts: saved_stmts, temp_counter: c, enum_defs: ed) = ctx
  let branch_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    let BranchBodyResult(
      ctx: LowerCtx(
        vars: v2,
        semantic_vars: sv2,
        stmts: branch_stmts,
        temp_counter: c2,
        enum_defs: _
      ),
      value_opt: val_opt
    ) = lower_branch_body(body, result_name, result_type, ctx: branch_ctx)
    let final_stmts = match val_opt do
        | Some(val: atom) ->
          LirStmtLet(name: result_name, typ: result_type,
                             expr: LirExprAtom(atom)) :: branch_stmts
        | None -> branch_stmts
      end
      let restored = LowerCtx(
        vars: v,
        semantic_vars: sv,
        stmts: saved_stmts,
        temp_counter: c2,
        enum_defs: ed
      )
      return BranchResult(ctx: restored, stmts: list.reverse(xs: final_stmts))
end

// Emit a function-level return for `return e` inside a match-as-expression
// branch. Per spec (semantics.md §diverging-match-arms): arms containing `return` diverge and
// do not contribute to the unified match result — so value_opt is None.
//
// For `return f(args)`, produce a LirExprTailCall whose codegen emits
// `return_call` (self-terminating). For any other expression, emit the atom
// and wrap in LirStmtIfReturn(cond: true, ...) which codegens as an
// unconditional op_return.
let emit_diverging_return = fn (
  expr: MirExpr,
  ctx: LowerCtx
) -> BranchBodyResult throws { LirError } do
  let ret_type = lir_get_fn_ret_type(ctx)
  if let MirCall(func: f, args, ret_type: rt) = expr then
    let LowerCallArgsResult(ctx: ctx2, lir_args: la) = lir_lower_call_args(args, ctx)
    let wt = wasm_type(typ: rt)
      let BindResult(ctx: ctx3, atom: _) = bind_expr_to_temp(
        ctx: ctx2,
        expr: LirExprTailCall(func: f, args: la, typ: wt),
        typ: wt
      )
      return BranchBodyResult(ctx: ctx3, value_opt: None)
  else
    let BindResult(ctx: ctx2, atom: a) = lower_expr_to_atom(expr, ctx)
    let LowerCtx(
        vars: v,
        semantic_vars: sv,
        stmts: s,
        temp_counter: c,
        enum_defs: ed
      ) = ctx2
    let ret_stmt = LirStmtIfReturn(
          cond: LirAtomBool(val: true),
          then_body: [], then_ret: a,
          else_body: [], else_ret: None,
          ret_type
        )
        let ctx3 = LowerCtx(
          vars: v,
          semantic_vars: sv,
          stmts: ret_stmt :: s,
          temp_counter: c,
          enum_defs: ed
        )
        return BranchBodyResult(ctx: ctx3, value_opt: None)
  end
end

let lower_branch_body = fn (
  body: [ MirStmt ],
  result_name: string,
  result_type: TypeExpr,
  ctx: LowerCtx
) -> BranchBodyResult throws { LirError } do
  match body do
    | [] -> return BranchBodyResult(ctx, value_opt: None)
    | [ last ] ->
      match last do
        | MirStmtExpr(expr: e) ->
          let BindResult(ctx: ctx2, atom: a) = lower_expr_to_atom(expr: e, ctx)
          return BranchBodyResult(ctx: ctx2, value_opt: Some(val: a))
        | MirStmtReturn(expr: e) ->
          return emit_diverging_return(expr: e, ctx)
        | _ ->
          let LowerStmtResult(ctx: ctx2, ret: _) = lower_stmt_inner(
            stmt: last,
            ret_type: TyUnit,
            ctx
          )
          return BranchBodyResult(ctx: ctx2, value_opt: None)
      end
    | s :: rest ->
      match s do
        | MirStmtReturn(expr: e) ->
          return emit_diverging_return(expr: e, ctx)
        | _ ->
          let LowerStmtResult(ctx: ctx2, ret: _) = lower_stmt_inner(stmt: s, ret_type: TyUnit, ctx)
          return lower_branch_body(body: rest, result_name, result_type, ctx: ctx2)
      end
  end
end

// Lower match expression using Maranget decision tree.
let lower_match_expr = fn (
  target: MirExpr,
  cases: [ MirMatchCase ],
  ctx: LowerCtx
) -> BindResult throws { LirError } do
  let BindResult(ctx: ctx2, atom: target_atom) = lower_expr_to_atom(expr: target, ctx)
  match cases do
      | [] -> return BindResult(ctx: ctx2, atom: LirAtomUnit)
      | _ ->
        let target_sem = lir_get_atom_sem_type(atom: target_atom, ctx: ctx2)
        // Infer result type from case bodies
        let sem_type = lir_infer_match_result_type(cases, ctx: ctx2)
        let result_type = wasm_type(typ: sem_type)
        let TempResult(ctx: ctx3, name: result_name) = new_temp(ctx: ctx2)
        let LowerCtx(
            vars: v,
            semantic_vars: sv,
            stmts: s,
            temp_counter: c,
            enum_defs: ed
          ) = ctx3
        let ctx4 = LowerCtx(
              vars: insert_type(name: result_name, typ: result_type, entries: v),
              semantic_vars: insert_type(name: result_name, typ: sem_type, entries: sv),
              stmts: LirStmtLet(name: result_name, typ: result_type,
                             expr: LirExprAtom(atom: default_atom(typ: result_type))) :: s,
              temp_counter: c, enum_defs: ed
            )
            // Build pattern matrix and decision tree
            let rows = lir_cases_to_rows(cases, idx: 0)
            let DecTreeResult(tree, next_id: _) = lir_build_decision_tree(
              rows,
              col_ids: [ 0 ],
              next_id: 1,
              enum_defs: ed
            )
            let atoms = [ AtomEntry(id: 0, atom: target_atom, sem_type: target_sem) ]
              let EmitExprResult(
                    ctx: ctx5,
                    chain_stmts: chain
                  ) = lir_emit_decision_tree_expr(tree, atoms, cases,
                  result_name, result_type, ctx: ctx4,
                  lower_branch_body_fn: lower_branch_body)
              let LowerCtx(
                  vars: v5,
                  semantic_vars: sv5,
                  stmts: s5,
                  temp_counter: c5,
                  enum_defs: ed5
                ) = ctx5
              let s6 = push_stmts_to_reverse(stmts: chain, acc: s5)
                  let ctx6 = LowerCtx(
                    vars: v5,
                    semantic_vars: sv5,
                    stmts: s6,
                    temp_counter: c5,
                    enum_defs: ed5
                  )
                  return BindResult(
                    ctx: ctx6,
                    atom: LirAtomVar(name: result_name, typ: result_type)
                  )
    end
end

type LowerStmtResult = LowerStmtResult(ctx: LowerCtx, ret: Option<LirAtom>)

/** True for a collection type that carries an element type (`[R]`). Used to
 *  decide when a `let`-annotation should override an RHS-inferred semantic type
 *  that collapsed to a non-list shape — recovering the element type for a
 *  locally-bound empty list `[]` (`Nil`, no head to infer from) so the
 *  cons-pattern binder's `.field` resolves instead of aborting LIR with E6002
 *Scoped to list/array so a record-typed annotation never
 *  shadows the structurally-inferred `TyRecord` used for field resolution. */
let is_list_or_array_ty = fn (t: TypeExpr) -> bool do
  match t do
    | TyList(elem: _) -> return true
    | TyArray(elem: _) -> return true
    | _ -> return false
  end
end

let prefer_annotation_sem = fn (annot: TypeExpr, atom_sem: TypeExpr) -> bool do
  if is_list_or_array_ty(t: annot) then
    if is_list_or_array_ty(t: atom_sem) then return false else return true end
  else
    return false
  end
end

let lower_stmt_inner = fn (
  stmt: MirStmt,
  ret_type: TypeExpr,
  ctx: LowerCtx
) -> LowerStmtResult throws { LirError } do
  match stmt do
    | MirStmtLet(name: n, typ: t, expr: e) ->
      let sem_type = infer_semantic_type(expr: e, ctx)
      let BindResult(ctx: ctx2, atom: a) = lower_expr_to_atom(expr: e, ctx)
      let inferred = atom_type(atom: a)
        // Prefer semantic type from lowered atom if available
        let atom_sem = match a do
          | LirAtomVar(name: vn, typ: _) ->
            let LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) = ctx2
            match lir_lookup_type(name: vn, entries: sv) do
                | Some(val: st) -> st
                | None -> sem_type
              end
          | _ -> sem_type
        end
        // A list literal / empty list / `::` desugars to `Cons`/`Nil`; the
        // inferred semantic type recovers the element from a non-empty `Cons`
        // head, but `[]` (`Nil`) and shapes where inference falls back to the
        // catch-all `TyI64` lose the element type. When the user supplied a
        // collection annotation (`let xs: [R] = ...`), prefer it so the bound
        // list carries `TyList(R)` — without this the cons-pattern binder's
        // `.field` aborts LIR with E6002 for the empty-tail case.
        let actual_sem = if prefer_annotation_sem(annot: t, atom_sem) then
          t
        else
          atom_sem
        end
        let LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) = ctx2
        let ctx3 = LowerCtx(
            vars: insert_type(name: n, typ: inferred, entries: v),
            semantic_vars: insert_type(name: n, typ: actual_sem, entries: sv),
            stmts: LirStmtLet(name: n, typ: inferred, expr: LirExprAtom(atom: a)) :: s,
            temp_counter: c, enum_defs: ed
          )
          return LowerStmtResult(ctx: ctx3, ret: None)

    | MirStmtExpr(expr: e) ->
      match e do
        | MirIf(cond, then_body: tb, else_body: eb) ->
          return lower_if_stmt(cond, then_body: tb, else_body: eb, ret_type, ctx)
        | MirMatch(target: tgt, cases: cs) ->
          return lower_match_stmt(target: tgt, cases: cs, ret_type, ctx)
        | MirWhile(cond, body) ->
          return lower_while_stmt(cond, body, ctx)
        | _ ->
          let BindResult(ctx: ctx2, atom: _) = lower_expr_to_atom(expr: e, ctx)
          return LowerStmtResult(ctx: ctx2, ret: None)
      end

    | MirStmtReturn(expr: e) ->
      match e do
        | MirCall(func: f, args, ret_type: rt) ->
          let LowerCallArgsResult(ctx: ctx2, lir_args: la) = lir_lower_call_args(args, ctx)
          let wt = wasm_type(typ: rt)
            let BindResult(ctx: ctx3, atom: a) = bind_expr_to_temp(ctx: ctx2,
              expr: LirExprTailCall(func: f, args: la, typ: wt), typ: wt)
            return LowerStmtResult(ctx: ctx3, ret: Some(val: a))
        | _ ->
          let BindResult(ctx: ctx2, atom: a) = lower_expr_to_atom(expr: e, ctx)
          return LowerStmtResult(ctx: ctx2, ret: Some(val: a))
      end

    | MirStmtAssign(target: tgt, value: val) ->
      // ANF has no mutation — emit as Let re-binding for variable targets,
      // or as a __array_set intrinsic call for indexed targets.
      match tgt do
        | MirVariable(name: n) ->
          let BindResult(ctx: ctx2, atom: a) = lower_expr_to_atom(expr: val, ctx)
          let LowerCtx(
              vars: vs,
              semantic_vars: sv,
              stmts: s,
              temp_counter: c,
              enum_defs: ed
            ) = ctx2
          let ctx3 = LowerCtx(
                vars: insert_type(name: n, typ: atom_type(atom: a), entries: vs),
                semantic_vars: sv,
                stmts: LirStmtLet(
                  name: n,
                  typ: atom_type(atom: a),
                  expr: LirExprAtom(atom: a)
                ) :: s,
                temp_counter: c, enum_defs: ed
              )
              return LowerStmtResult(ctx: ctx3, ret: None)
        | MirIndex(target: arr, index: idx) ->
          // `arr[idx] <- val` lowers to a call to __array_set, paralleling
          // MirIndex's lowering to __array_get. The intrinsic is dispatched
          // by emit_call in src/backend/codegen.nx (emit_array_set) and
          // never registered as a real wasm import.
          let BindResult(ctx: ctx2, atom: arr_atom) = lower_expr_to_atom(expr: arr, ctx)
          let BindResult(ctx: ctx3, atom: idx_atom) = lower_expr_to_atom(
              expr: idx,
              ctx: ctx2
            )
          let BindResult(ctx: ctx4, atom: val_atom) = lower_expr_to_atom(
                expr: val,
                ctx: ctx3
              )
          let BindResult(ctx: ctx5, atom: _) = bind_expr_to_temp(ctx: ctx4,
                  expr: LirExprCall(func: "__array_set",
                    args: [ LirCallArg(label: "arr", value: arr_atom),
                           LirCallArg(label: "idx", value: idx_atom),
                           LirCallArg(label: "val", value: val_atom) ],
                    typ: TyUnit),
                  typ: TyUnit)
          return LowerStmtResult(ctx: ctx5, ret: None)
        | _ ->
          // Non-variable, non-index assign — just lower both sides
          let BindResult(ctx: ctx2, atom: _) = lower_expr_to_atom(expr: val, ctx)
          return LowerStmtResult(ctx: ctx2, ret: None)
      end

    | MirStmtTry(body, catch_param: cp, catch_body: cb) ->
      return lower_try_stmt(body, catch_param: cp, catch_body: cb, ret_type, ctx)

    | MirStmtInjectResume(body_fn: bfn, handler_arm_fns: arms, handler_arm_tags: arm_tags, ret_type: inj_rt) ->
      // Lower the inject resume to a let-bound LirExprInjectResume so the
      // existing LirStmtLet → emit_stmt pipeline picks it up. The body's
      // trailing value (when the inject is value-producing, inj_rt non-unit)
      // is delivered to this site out-of-band via the ss_inject_value global;
      // codegen leaves it on the stack so the temp binds the real value and a
      // trailing inject can become the enclosing function's return value
      //For unit bodies codegen drops, as before.
      let BindResult(ctx: ctx2, atom: _) = bind_expr_to_temp(ctx,
        expr: LirExprInjectResume(body_fn: bfn, arm_fns: arms, arm_tags, typ: inj_rt),
        typ: inj_rt)
      // Statement-position lowering never surfaces the value (it would
      // short-circuit and drop following statements). When the inject is the
      // enclosing function's trailing statement, lir_lower_stmts re-lowers it
      // through the dedicated last-statement case below so the value is
      // captured as the function's return. Mid-function injects discard the
      // value (unit context), matching the pre-h4v70 behaviour.
      return LowerStmtResult(ctx: ctx2, ret: None)
  end
end

let lower_if_stmt = fn (
  cond: MirExpr,
  then_body: [ MirStmt ],
  else_body: Option<[ MirStmt ]>,
  ret_type: TypeExpr,
  ctx: LowerCtx
) -> LowerStmtResult throws { LirError } do
  let BindResult(ctx: ctx2, atom: cond_atom) = lower_expr_to_atom(expr: cond, ctx)
  let BlockResult(ctx: ctx3, stmts: then_stmts, ret: then_ret) = lower_block(
      stmts: then_body,
      ret_type,
      ctx: ctx2
    )
  match else_body do
        | Some(val: eb) ->
          let BlockResult(ctx: ctx4, stmts: else_stmts, ret: else_ret) = lower_block(
            stmts: eb,
            ret_type,
            ctx: ctx3
          )
          match then_ret do
              | Some(_) ->
                let LowerCtx(
                  vars: v,
                  semantic_vars: sv,
                  stmts: s,
                  temp_counter: c,
                  enum_defs: ed
                ) = ctx4
                let then_ret_val = match then_ret do
                    | Some(val: a) -> a
                    | None -> default_atom(typ: ret_type)
                  end
                  let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                    stmts: LirStmtIfReturn(cond: cond_atom,
                      then_body: then_stmts, then_ret: then_ret_val,
                      else_body: else_stmts, else_ret,
                      ret_type) :: s,
                    temp_counter: c, enum_defs: ed)
                  return LowerStmtResult(ctx: ctx5, ret: None)
              | None ->
                match else_ret do
                  | Some(_) ->
                    let LowerCtx(
                      vars: v,
                      semantic_vars: sv,
                      stmts: s,
                      temp_counter: c,
                      enum_defs: ed
                    ) = ctx4
                    let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                        stmts: LirStmtIfReturn(cond: cond_atom,
                          then_body: then_stmts, then_ret: default_atom(typ: ret_type),
                          else_body: else_stmts, else_ret,
                          ret_type) :: s,
                        temp_counter: c, enum_defs: ed)
                      return LowerStmtResult(ctx: ctx5, ret: None)
                  | None ->
                    let LowerCtx(
                      vars: v,
                      semantic_vars: sv,
                      stmts: s,
                      temp_counter: c,
                      enum_defs: ed
                    ) = ctx4
                    let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                        stmts: LirStmtIf(
                          cond: cond_atom,
                          then_body: then_stmts,
                          else_body: else_stmts
                        ) :: s,
                        temp_counter: c, enum_defs: ed)
                      return LowerStmtResult(ctx: ctx5, ret: None)
                end
            end
        | None ->
          let LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) = ctx3
          match then_ret do
              | Some(val: tr) ->
                let ctx4 = LowerCtx(vars: v, semantic_vars: sv,
                  stmts: LirStmtIfReturn(cond: cond_atom,
                    then_body: then_stmts, then_ret: tr,
                    else_body: [], else_ret: None,
                    ret_type) :: s,
                  temp_counter: c, enum_defs: ed)
                return LowerStmtResult(ctx: ctx4, ret: None)
              | None ->
                let ctx4 = LowerCtx(vars: v, semantic_vars: sv,
                  stmts: LirStmtIf(cond: cond_atom, then_body: then_stmts, else_body: []) :: s,
                  temp_counter: c, enum_defs: ed)
                return LowerStmtResult(ctx: ctx4, ret: None)
            end
      end
end

// Lower match statement using Maranget decision tree.
let lower_match_stmt = fn (
  target: MirExpr,
  cases: [ MirMatchCase ],
  ret_type: TypeExpr,
  ctx: LowerCtx
) -> LowerStmtResult throws { LirError } do
  let BindResult(ctx: ctx2, atom: target_atom) = lower_expr_to_atom(expr: target, ctx)
  match cases do
      | [] -> return LowerStmtResult(ctx: ctx2, ret: None)
      | _ ->
        let target_sem = lir_get_atom_sem_type(atom: target_atom, ctx: ctx2)
        let LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) = ctx2
        let rows = lir_cases_to_rows(cases, idx: 0)
          let DecTreeResult(tree, next_id: _) = lir_build_decision_tree(
            rows,
            col_ids: [ 0 ],
            next_id: 1,
            enum_defs: ed
          )
          let atoms = [ AtomEntry(id: 0, atom: target_atom, sem_type: target_sem) ]
            let EmitStmtResult(
                  ctx: ctx3,
                  chain_stmts: chain
                ) = lir_emit_decision_tree_stmt(tree, atoms, cases,
                ret_type, ctx: ctx2,
                lower_case_body_fn: lower_case_body)
            let LowerCtx(
                vars: v3,
                semantic_vars: sv3,
                stmts: s3,
                temp_counter: c3,
                enum_defs: ed3
              ) = ctx3
            let s4 = push_stmts_to_reverse(stmts: chain, acc: s3)
                let ctx4 = LowerCtx(
                  vars: v3,
                  semantic_vars: sv3,
                  stmts: s4,
                  temp_counter: c3,
                  enum_defs: ed3
                )
                return LowerStmtResult(ctx: ctx4, ret: None)
    end
end

let lower_while_stmt = fn (
  cond: MirExpr,
  body: [ MirStmt ],
  ctx: LowerCtx
) -> LowerStmtResult throws { LirError } do
  let LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) = ctx
  let cond_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    let BindResult(ctx: ctx2, atom: cond_atom) = lower_expr_to_atom(expr: cond, ctx: cond_ctx)
    let BindResult(
          ctx: LowerCtx(
            vars: v2,
            semantic_vars: sv2,
            stmts: cond_stmts,
            temp_counter: c2,
            enum_defs: _
          ),
          atom: neg_cond
        ) = bind_expr_to_temp(ctx: ctx2,
        expr: LirExprBinary(op: OpEq, lhs: cond_atom, rhs: LirAtomBool(val: false), typ: TyBool),
        typ: TyBool)
    let body_ctx = LowerCtx(
          vars: v2,
          semantic_vars: sv2,
          stmts: [],
          temp_counter: c2,
          enum_defs: ed
        )
        let LowerStmtsResult(
          ctx: LowerCtx(
            vars: _,
            semantic_vars: _,
            stmts: body_stmts,
            temp_counter: c3,
            enum_defs: _
          ),
          ret: _
        ) = lir_lower_stmts(stmts: body, ret_type: TyUnit, ctx: body_ctx)
        let final_ctx = LowerCtx(vars: v, semantic_vars: sv,
            stmts: LirStmtLoop(
              cond_stmts: list.reverse(xs: cond_stmts),
              cond: neg_cond,
              body: list.reverse(xs: body_stmts)
            ) :: saved,
            temp_counter: c3, enum_defs: ed)
          return LowerStmtResult(ctx: final_ctx, ret: None)
end

let lower_try_stmt = fn (
  body: [ MirStmt ],
  catch_param: string,
  catch_body: [ MirStmt ],
  ret_type: TypeExpr,
  ctx: LowerCtx
) -> LowerStmtResult throws { LirError } do
  let BlockResult(ctx: ctx2, stmts: body_stmts, ret: body_ret) = lower_block(
    stmts: body,
    ret_type,
    ctx
  )
  let LowerCtx(
      vars: v,
      semantic_vars: sv,
      stmts: s,
      temp_counter: c,
      enum_defs: ed
    ) = ctx2
  let exn_type = TyUserDefined(name: "Exn", args: [])
      let catch_ctx = LowerCtx(
        vars: insert_type(name: catch_param, typ: exn_type, entries: v),
        semantic_vars: insert_type(name: catch_param, typ: exn_type, entries: sv),
        stmts: s, temp_counter: c, enum_defs: ed
      )
      let BlockResult(ctx: ctx3, stmts: catch_stmts, ret: catch_ret) = lower_block(
        stmts: catch_body,
        ret_type,
        ctx: catch_ctx
      )
      let LowerCtx(
          vars: v2,
          semantic_vars: sv2,
          stmts: s2,
          temp_counter: c2,
          enum_defs: ed2
        ) = ctx3
      let ctx4 = LowerCtx(vars: v2, semantic_vars: sv2,
            stmts: LirStmtTryCatch(
              body: body_stmts, body_ret,
              catch_param, catch_param_typ: exn_type,
              catch_body: catch_stmts, catch_ret
            ) :: s2,
            temp_counter: c2, enum_defs: ed2)
          return LowerStmtResult(ctx: ctx4, ret: None)
end

// Save/separate/restore the stmt accumulator, run lower_stmts_fn over the given
// stmts, then reverse the accumulated output and return a fresh BlockResult.
let lower_isolated_stmts = fn (
  stmts: [ MirStmt ],
  ret_type: TypeExpr,
  ctx: LowerCtx,
  lower_stmts_fn: (
    stmts: [ MirStmt ],
    ret_type: TypeExpr,
    ctx: LowerCtx
  ) -> LowerStmtsResult throws { LirError }
) -> BlockResult throws { LirError } do
  let LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) = ctx
  let block_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
  let LowerStmtsResult(
    ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: block_stmts, temp_counter: c2, enum_defs: _),
    ret: ret_val
  ) = lower_stmts_fn(stmts, ret_type, ctx: block_ctx)
  let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
  return BlockResult(ctx: restored, stmts: list.reverse(xs: block_stmts), ret: ret_val)
end

// Block context (if/while/try bodies): trailing bare expressions are evaluated
// for side effect only, NOT captured as an implicit return.
let lower_block = fn (
  stmts: [ MirStmt ],
  ret_type: TypeExpr,
  ctx: LowerCtx
) -> BlockResult throws { LirError } do
  return lower_isolated_stmts(stmts, ret_type, ctx, lower_stmts_fn: lir_lower_block_stmts)
end

// Case-body context (match arms): trailing bare expression IS captured as the
// produced value of the case.
let lower_case_body = fn (
  stmts: [ MirStmt ],
  ret_type: TypeExpr,
  ctx: LowerCtx
) -> BlockResult throws { LirError } do
  return lower_isolated_stmts(stmts, ret_type, ctx, lower_stmts_fn: lir_lower_stmts)
end

// Lower a stmt list, returning Some(atom) only when a MirStmtReturn is found.
// Never extracts a trailing bare expression (cf. lir_lower_stmts which does).
let lir_lower_block_stmts = fn (
  stmts: [ MirStmt ],
  ret_type: TypeExpr,
  ctx: LowerCtx
) -> LowerStmtsResult throws { LirError } do
  match stmts do
    | [] -> return LowerStmtsResult(ctx, ret: None)
    | s :: rest ->
      let LowerStmtResult(ctx: ctx2, ret: ret_val) = lower_stmt_inner(stmt: s, ret_type, ctx)
      match ret_val do
          | Some(_) -> return LowerStmtsResult(ctx: ctx2, ret: ret_val)
          | None -> return lir_lower_block_stmts(stmts: rest, ret_type, ctx: ctx2)
        end
  end
end

export type LowerStmtsResult = LowerStmtsResult(ctx: LowerCtx, ret: Option<LirAtom>)

export let lir_lower_stmts = fn (
  stmts: [ MirStmt ],
  ret_type: TypeExpr,
  ctx: LowerCtx
) -> LowerStmtsResult throws { LirError } do
  match stmts do
    | [] -> return LowerStmtsResult(ctx, ret: None)
    | [ s ] ->
      // Last statement — capture implicit return value
      match s do
        | MirStmtInjectResume(body_fn: bfn, handler_arm_fns: arms, handler_arm_tags: arm_tags, ret_type: inj_rt) ->
          // Trailing inject: bind the resume value to a temp and surface it as
          // the function's return value when the body is value-producing. The
          // value arrives on the wasm stack from the dispatcher (codegen reads
          // ss_inject_value out-of-band). Unit bodies yield no value, as before
          let BindResult(ctx: ctx2, atom: a) = bind_expr_to_temp(ctx,
            expr: LirExprInjectResume(body_fn: bfn, arm_fns: arms, arm_tags, typ: inj_rt),
            typ: inj_rt)
          match inj_rt do
            | TyUnit -> return LowerStmtsResult(ctx: ctx2, ret: None)
            | _ -> return LowerStmtsResult(ctx: ctx2, ret: Some(val: a))
          end
        | MirStmtExpr(expr: e) ->
          match e do
            | MirIf(_) | MirMatch(_) ->
              let LowerStmtResult(ctx: ctx2, ret: _) = lower_stmt_inner(stmt: s, ret_type, ctx)
              return LowerStmtsResult(ctx: ctx2, ret: fallback_ret_from_terminal(ctx: ctx2))
            | MirWhile(_) ->
              let LowerStmtResult(ctx: ctx2, ret: _) = lower_stmt_inner(stmt: s, ret_type, ctx)
              return LowerStmtsResult(ctx: ctx2, ret: None)
            | _ ->
              // Bare expression (call, constructor, variable) — capture value
              let BindResult(ctx: ctx2, atom: a) = lower_expr_to_atom(expr: e, ctx)
              match atom_type(atom: a) do
                  | TyUnit -> return LowerStmtsResult(ctx: ctx2, ret: None)
                  | _ -> return LowerStmtsResult(ctx: ctx2, ret: Some(val: a))
                end
          end
        | _ ->
          let LowerStmtResult(ctx: ctx2, ret: ret_val) = lower_stmt_inner(stmt: s, ret_type, ctx)
          match ret_val do
              | Some(_) -> return LowerStmtsResult(ctx: ctx2, ret: ret_val)
              | None -> return LowerStmtsResult(
                ctx: ctx2,
                ret: fallback_ret_from_terminal(ctx: ctx2)
              )
            end
      end
    | s :: rest ->
      let LowerStmtResult(ctx: ctx2, ret: ret_val) = lower_stmt_inner(stmt: s, ret_type, ctx)
      match ret_val do
          | Some(_) -> return LowerStmtsResult(ctx: ctx2, ret: ret_val)
          | None -> return lir_lower_stmts(stmts: rest, ret_type, ctx: ctx2)
        end
  end
end
