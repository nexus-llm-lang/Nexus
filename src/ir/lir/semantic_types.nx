/**
 * semantic_types: MIR-side semantic type inference & layout helpers for LIR
 * lowering.
 *
 * Owns:
 * - Semantic type inference (per MirExpr) and binary-op result typing
 * - Record builder: atoms → semantic record type
 * - Record field resolution (sorted-name index + type lookup)
 * - Canonical alphabetical sorting for MirParam / LirCallArg / LirNamedAtom
 * - Monomorphic reverse helpers for NamedType / MirParam / LirCallArg /
 *   LirNamedAtom (re-exported for lir.nx)
 *
 * Does not own:
 * - LowerCtx & atom helpers (see src/ir/lir/context.nx)
 * - Match-tree construction (see src/ir/lir/match_tree.nx)
 * - Body / statement / function lowering (see src/ir/lir/lir.nx)
 */
import { BinaryOp } from "src/types/vocab.nx"
import { TypeExpr, TyRecord, NamedType, TyArrow, TyList, TyArray, TyUserDefined, TyVar,
         TyF32, TyF64, TyI32, TyI64,
         VariantDef, VariantField } from "src/types/type_expr.nx"
import { VariantInfo, VariantIndex } from "src/ir/support/variant_index.nx"
import * as list from "std:list"
import {
  LirError,
  LirFieldOnNonVariable,
  LirFieldOnNonRecord,
  LirFieldNotInRecord
} from "src/ir/lir/errors.nx"
import { Some, None } from "std:option"
import {
  MirExpr,
  MirStmt,
  MirParam,
  MirCallArg,
  MirFieldAccess,
  MirMatchCase,
  MirNamedExpr
} from "src/ir/mir/types.nx"
import { LirAtom, LirCallArg, LirNamedAtom } from "src/ir/lir/types.nx"
import { LowerCtx, lir_lookup_type, atom_type } from "src/ir/lir/context.nx"
import * as vidx from "src/ir/support/variant_index.nx"
import * as str from "std:str"

/** Slot-only env-type sentinel key. A captured record's
 *  recovered TyRecord is registered in a lifted closure's `semantic_vars`
 *  under this key (`#ENVTYPE#<slot>`); the `MirEnvLoad(_, idx)` lowering looks
 *  it up so a subsequent `.field` resolves instead of aborting E6002. The
 *  per-function registry filtering happens in func_lower.nx — here the fn name
 *  is implicit. */
export let env_slot_sentinel = fn (slot: i64) -> string throws { LirError } do
  return "#ENVTYPE#" ++ str.from_i64(val: slot)
end

/** Public function infer_semantic_type. */
export let infer_semantic_type = fn (
  expr: MirExpr,
  ctx: LowerCtx
) -> TypeExpr throws { LirError } do
  let LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: edx) = ctx
  match expr do
      | MirVariable(name: n) ->
        match lir_lookup_type(name: n, entries: sv) do
          | Some(val: t) -> return t
          | None -> return TyI64
        end
      | MirCall(func: f, args: cargs, ret_type: rt) ->
        // A generic callee returns a bare type variable (or a `TyVar`-bearing
        // shape); recover the concrete instantiation from the argument types so
        // the result binding carries the real record/sum layout (else a
        // downstream destructure / `.field` reads offset 0 / aborts E6002).
        // No-op for non-generic returns.
        return recover_generic_call_type(callee: f, args: cargs, sem_rt: rt, ctx)
      | MirLiteral(lit: l) ->
        match l do
          | LitInt(_) -> return TyI64
          | LitFloat(_) -> return TyF64
          | LitBool(_) -> return TyBool
          | LitChar(_) -> return TyChar
          | LitString(_) -> return TyString
          | LitUnit -> return TyUnit
        end
      // List literals (`[a, b]`) and `::` both desugar to the built-in list
      // constructors `Cons(v, rest)` / `Nil`. Recover the element type from a
      // `Cons` head so a locally-bound list carries `TyList(elem)` as its
      // semantic type (NOT the catch-all `TyI64`). This lets the cons-pattern
      // binder's `scrutinee_type_args` resolve the element record type so
      // `.field` on the bound head/tail does not abort LIR with E6002 — the
      // fn-PARAMETER scrutinee already got `TyList(_)` at function entry; this
      // closes the same gap for local lets / cons exprs.
      // An empty `Nil` carries no element; the `MirStmtLet`
      // annotation fallback (see lower_stmt_inner) supplies the type there.
      // `Cons` args are stored in alphabetical field order `[rest, v]` (the
      // tail list at index 0, the head element at index 1; see desugar_list /
      // sort_ctor_args). Recover the element type from `v` so the list carries
      // `TyList(elem)`.
      | MirConstructor(name: cn, args: cargs) ->
        if cn == "Cons" then
          match cargs do
            | _ :: v :: _ -> return TyList(elem: infer_semantic_type(expr: v, ctx))
            | _ -> return TyI64
          end
        else
          // Recover the sum value's named type from its constructor so a
          // `let a = Red`-bound variable carries `TyUserDefined("Color")` in
          // semantic_vars. The LIR `==`/`!=` lowering needs this to emit a
          // structural (per-field/per-tag) compare instead of pointer identity
          // (spec § T-Cmp). Unknown / opaque constructors fall back to TyI64,
          // which routes `==` to the legacy identity compare unchanged.
          //
          // For a GENERIC enum (`Option<T>`, user `Box<T>`) also recover the
          // CONCRETE type arguments from the constructor's payload (`Some(Red(7))`
          // ⇒ `Option<Color>`). Those args let `==` route to the
          // per-instantiation structural-compare helper for the type-parameter
          // payload; they are erased to `[]` (today's behavior) for
          // a non-generic enum or when the instantiation can't be fully recovered.
          match vidx.enum_name_of_variant(idx: edx, variant: cn) do
            | Some(val: en) -> return TyUserDefined(name: en, args: recover_ctor_instantiation(ctor: cn, args: cargs, ctx))
            | None -> return TyI64
          end
        end
      // `target.field`: recover the field's declared semantic type from the
      // target's (recovered) record type, so a record/sum-typed `.field` value
      // is NOT erased to the catch-all TyI64. This mirrors the real LIR
      // `MirFieldAccess` lowering (resolve_record_field). Without it an anonymous
      // record literal whose field VALUE is a `.field` access (`{ col: h.c }`)
      // would key its structural-compare helper on the erased field type
      // (`col=i64`) and identity-compare the field — or, when the access is
      // let-bound first, diverge the harvested helper name from the `==` call
      // site (E3001 at codegen). Falls back to TyI64 when the target's type is
      // not a resolvable record (the field can't be located), keeping prior
      // behavior. The field's own declared type is resolved through any
      // named-record alias so a chained `a.inner.x` recovers the inner record.
      | MirFieldAccess(target: recv, field: fname) ->
        match vidx.resolve_record_alias(idx: edx, typ: infer_semantic_type(expr: recv, ctx)) do
          | TyRecord(fields: fs) ->
            match lookup_named_type_opt(target: fname, fields: fs) do
              | Some(val: ft) -> return vidx.resolve_record_alias(idx: edx, typ: ft)
              | None -> return TyI64
            end
          | _ -> return TyI64
        end
      | MirBinaryOp(left: _, op, right: _) ->
        match op do
          | OpConcat -> return TyString
          | OpEq | OpNe | OpLt | OpLe | OpGt | OpGe
          | OpFEq | OpFNe | OpFLt | OpFLe | OpFGt | OpFGe
          | OpAnd | OpOr -> return TyBool
          | OpFAdd | OpFSub | OpFMul | OpFDiv -> return TyF64
          | _ -> return TyI64
        end
      | MirIf(cond: _, then_body: tb, else_body: eb) ->
        return infer_branches_type(arms: if_arms(then_body: tb, else_body: eb), ctx)
      | MirMatch(target: _, cases: cs) ->
        return infer_branches_type(arms: match_case_bodies(cases: cs), ctx)
      | MirRecord(fields: fs) ->
        return TyRecord(fields: infer_record_field_types(fields: fs, ctx))
      | MirMakeClosure(_) -> return TyI64
      | MirCallClosure(closure: clos, args: _, ret_type: rt) ->
        return resolve_closure_ret_type(clos, fallback: rt, ctx)
      | MirBlock(_) -> return TyUnit
      | MirInjectValue(stmts: _, ret_type: rt) -> return rt
      | MirEnvLoad(_) | _ -> return TyI64
    end
end

/** Resolve the real return type of a closure-call site. The MIR side stores a
 *  TyI64 placeholder when lowering a variable-call; the actual TyArrow lives
 *  in semantic_vars (populated at function entry from the param's declared
 *  type). Falls back to the MIR-supplied type for non-variable callees.
 */
export let resolve_closure_ret_type = fn (
  clos: MirExpr,
  fallback: TypeExpr,
  ctx: LowerCtx
) -> TypeExpr throws { LirError } do
  if let MirVariable(name: n) = clos then
    let LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) = ctx
    if let Some(val: TyArrow(params: _, ret: r, requires: _, throw_row: _)) = lir_lookup_type(
        name: n,
        entries: sv
      ) then
        return r
      else
        return fallback
      end
  else
    return fallback
  end
end

/** Recover the `TyArrow` signature of a closure built by `MirMakeClosure`.
 *  The lifted closure body is a top-level function (`func_name`) whose full
 *  semantic signature is registered under `#FNSIG#<func_name>`; the `let` that
 *  binds the closure value can adopt that arrow as its semantic type so a later
 *  `resolve_closure_ret_type` on a call of the binding recovers the real
 *  (record/sum) return type instead of the `TyI64` placeholder. Falls back to
 *  `TyI64` when no signature is registered. */
export let closure_arrow_type = fn (
  func_name: string,
  ctx: LowerCtx
) -> TypeExpr throws { LirError } do
  let LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) = ctx
  match lir_lookup_type(name: fnsig_sentinel(name: func_name), entries: sv) do
    | Some(val: TyArrow(params: ps, ret: r, requires: rq, throw_row: tr)) ->
      return TyArrow(params: ps, ret: r, requires: rq, throw_row: tr)
    | _ -> return TyI64
  end
end

/** Sentinel key under which a function's full SEMANTIC signature
 *  (`TyArrow(params, ret, …)`, with named-record params/ret resolved to
 *  `TyRecord`) is registered in every function's `semantic_vars`. Kept
 *  distinct from the plain `<name>` return-type entry (used by
 *  `MirVariable`/`MirCall` lookups) so overloading the bare name does not turn
 *  a zero-arg constant reference into a `TyArrow`. Consumed by
 *  `recover_generic_call_type` to instantiate a generic callee's bare-`TyVar`
 *  return type from the call's argument semantic types. */
export let fnsig_sentinel = fn (name: string) -> string throws { LirError } do
  return "#FNSIG#" ++ name
end

/** True iff `t` is — or structurally contains — a bare type variable
 *  (`TyVar`). Used to gate the (otherwise no-op) generic-return recovery so it
 *  only fires for a callee whose resolved return type is still polymorphic. */
let type_has_tyvar = fn (t: TypeExpr) -> bool throws { LirError } do
  match t do
    | TyVar(name: _) -> return true
    | TyList(elem: e) -> return type_has_tyvar(t: e)
    | TyUserDefined(name: _, args: ats) -> return type_args_have_tyvar(ts: ats)
    | TyRecord(fields: fs) -> return named_types_have_tyvar(nts: fs)
    | _ -> return false
  end
end

let type_args_have_tyvar = fn (ts: [ TypeExpr ]) -> bool throws { LirError } do
  match ts do
    | [] -> return false
    | t :: rest -> if type_has_tyvar(t) then return true else return type_args_have_tyvar(ts: rest) end
  end
end

let named_types_have_tyvar = fn (nts: [ NamedType ]) -> bool throws { LirError } do
  match nts do
    | [] -> return false
    | NamedType(name: _, typ: t) :: rest ->
      if type_has_tyvar(t) then return true else return named_types_have_tyvar(nts: rest) end
  end
end

/** Structurally match a callee PARAMETER type (which may mention type
 *  variables) against the corresponding ARGUMENT's inferred semantic type,
 *  binding each `TyVar(name)` it encounters to the concrete sub-type at the
 *  same position. Bindings accumulate as `NamedType(name → concrete)` entries
 *  (later read by `subst_type_vars`). Mirrors a one-shot, structural
 *  unification — only the shapes that carry record/sum layout matter
 *  (`T`, `[T]`, `K<…,T,…>`), so anything else simply contributes no binding. */
let collect_tyvar_bindings = fn (
  param_ty: TypeExpr,
  arg_ty: TypeExpr,
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match param_ty do
    | TyVar(name: pv) -> return NamedType(name: pv, typ: arg_ty) :: acc
    | TyList(elem: pe) ->
      // `[T]` arg ⇒ recover `T` from the argument's element type. A
      // `Cons`-headed local already carries `TyList(elem)` (see the
      // `MirConstructor("Cons", …)` arm), so this threads `list.head(xs:[R])`'s
      // `T := R` through.
      match arg_ty do
        | TyList(elem: ae) -> return collect_tyvar_bindings(param_ty: pe, arg_ty: ae, acc)
        | _ -> return acc
      end
    | TyUserDefined(name: pn, args: pas) ->
      // `K<…>` arg (`Option<T>`, `Result<T,E>`, …) ⇒ recover each type
      // argument positionally from a same-head user-defined arg type.
      match arg_ty do
        | TyUserDefined(name: an, args: aargs) ->
          if pn == an then return collect_tyvar_bindings_list(ps: pas, ats: aargs, acc) else return acc end
        | _ -> return acc
      end
    | _ -> return acc
  end
end

let collect_tyvar_bindings_list = fn (
  ps: [ TypeExpr ],
  ats: [ TypeExpr ],
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match ps do
    | [] -> return acc
    | p :: prest ->
      match ats do
        | [] -> return acc
        | a :: arest ->
          let acc2 = collect_tyvar_bindings(param_ty: p, arg_ty: a, acc)
          return collect_tyvar_bindings_list(ps: prest, ats: arest, acc: acc2)
      end
  end
end

/** Substitute every `TyVar(name)` in `t` with its binding from `subst`
 *  (recovered by `collect_tyvar_bindings`). Unbound type variables are left
 *  intact (the recovery then declines, see `recover_generic_call_type`).
 *  Recurses through `[T]` / `K<…>` / record fields so a return type like
 *  `[R]` or `Option<R>` is instantiated, not only a bare `T`. */
let subst_type_vars = fn (t: TypeExpr, subst: [ NamedType ]) -> TypeExpr throws { LirError } do
  match t do
    | TyVar(name: n) ->
      match lookup_named_type_opt(target: n, fields: subst) do
        | Some(val: bound) -> return bound
        | None -> return t
      end
    | TyList(elem: e) -> return TyList(elem: subst_type_vars(t: e, subst))
    | TyUserDefined(name: n, args: ats) ->
      return TyUserDefined(name: n, args: subst_type_vars_list(ts: ats, subst))
    | TyRecord(fields: fs) -> return TyRecord(fields: subst_named_types(nts: fs, subst))
    | _ -> return t
  end
end

let subst_type_vars_list = fn (ts: [ TypeExpr ], subst: [ NamedType ]) -> [ TypeExpr ] throws { LirError } do
  match ts do
    | [] -> return []
    | t :: rest -> return subst_type_vars(t, subst) :: subst_type_vars_list(ts: rest, subst)
  end
end

let subst_named_types = fn (nts: [ NamedType ], subst: [ NamedType ]) -> [ NamedType ] throws { LirError } do
  match nts do
    | [] -> return []
    | NamedType(name: n, typ: t) :: rest ->
      return NamedType(name: n, typ: subst_type_vars(t, subst)) :: subst_named_types(nts: rest, subst)
  end
end

let lookup_named_type_opt = fn (
  target: string,
  fields: [ NamedType ]
) -> Option<TypeExpr> throws { LirError } do
  match fields do
    | [] -> return None
    | NamedType(name: n, typ: t) :: rest ->
      if n == target then return Some(val: t) else return lookup_named_type_opt(target, fields: rest) end
  end
end

/** Recover a generic callee's CONCRETE return type at a call site.
 *
 *  `sem_rt` is the callee's resolved semantic return type (from
 *  `sem_func_types`); for a generic fn it is still a bare `TyVar` (or a
 *  `TyVar`-bearing shape like `[T]`). This looks up the callee's full
 *  signature under `#FNSIG#<callee>`, unifies each parameter type against the
 *  matching call argument's inferred semantic type to bind the type
 *  variables, then substitutes them into `sem_rt`. So `idg<T>(x:T)->T` called
 *  with a record arg returns that record's `TyRecord`; `list.head(xs:[T])->T`
 *  on a `[R]` arg returns `R`. This is what lets a downstream
 *  record-destructure / `.field` on the result resolve field offsets instead
 *  of defaulting every projection to offset 0 (or aborting E6002).
 *
 *  Returns `sem_rt` UNCHANGED when: the return type carries no `TyVar` (not
 *  generic), no signature is registered, or the recovered type still carries
 *  an unbound `TyVar` (couldn't instantiate) — never widening or corrupting a
 *  type it can't confidently recover. */
export let recover_generic_call_type = fn (
  callee: string,
  args: [ MirCallArg ],
  sem_rt: TypeExpr,
  ctx: LowerCtx
) -> TypeExpr throws { LirError } do
  let LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) = ctx
  match lir_lookup_type(name: fnsig_sentinel(name: callee), entries: sv) do
    | Some(val: TyArrow(params: ps, ret: sig_ret, requires: _, throw_row: _)) ->
      // Use the signature's NORMALIZED return type (generic params marked
      // `TyVar`) — uniform across both call sites regardless of the passed
      // `sem_rt`'s normalization state. Non-generic returns carry no `TyVar`,
      // so this is a no-op (returns `sig_ret`, equal to `sem_rt` in shape).
      if !type_has_tyvar(t: sig_ret) then return sem_rt end
      let subst = collect_call_bindings(params: ps, args, ctx, acc: [])
      let recovered = subst_type_vars(t: sig_ret, subst)
      // Decline if anything remained polymorphic — a partially-substituted
      // type would mis-resolve worse than the conservative bare-`TyVar`
      // default; falling back to `sem_rt` keeps prior (offset-0) behavior.
      if type_has_tyvar(t: recovered) then return sem_rt else return recovered end
    | _ -> return sem_rt
  end
end

/** Labels of the call's arguments whose DECLARED parameter type is a bare type
 *  variable (erased to the `i64` value channel) but whose INSTANTIATION at this
 *  call site is `f32`. A float LITERAL argument carries the width-less `TyF64`
 *  atom type, so the i64-channel pack at the call site would box its un-rounded
 *  f64 bits; the callee — and any `f32`-typed binding the result flows into —
 *  must instead observe the value at `f32` width. The lowering binds such a
 *  literal to an `f32` temp first (a runtime `f32.demote_f64`), then packs the
 *  rounded value. Concrete `f32` parameters are excluded: they are not erased,
 *  so the existing `emit_coercion(TyF64 → TyF32)` already demotes the literal. */
export let instantiated_f32_arg_labels = fn (
  callee: string,
  args: [ MirCallArg ],
  ret_hint: Option<TypeExpr>,
  ctx: LowerCtx
) -> [ string ] throws { LirError } do
  let LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) = ctx
  match lir_lookup_type(name: fnsig_sentinel(name: callee), entries: sv) do
    | Some(val: TyArrow(params: ps, ret: sig_ret, requires: _, throw_row: _)) ->
      let arg_subst = collect_call_bindings(params: ps, args, ctx, acc: [])
      // A width-less float-literal argument infers as `TyF64`, so it cannot, on
      // its own, bind a type variable to `f32`. The `f32` width is instead
      // determined by the call result's declared `let` annotation flowing back
      // through the shared return type variable: `let r: f32 = id(x: <lit>)`
      // binds `T := f32` from the return position, demoting the argument too.
      let subst = bind_return_tyvar(sig_ret, ret_hint, acc: arg_subst)
      return f32_tyvar_param_labels(params: ps, subst, acc: [])
    | _ -> return []
  end
end

let bind_return_tyvar = fn (
  sig_ret: TypeExpr,
  ret_hint: Option<TypeExpr>,
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match sig_ret do
    | TyVar(name: rv) ->
      match ret_hint do
        | Some(val: ht) -> return NamedType(name: rv, typ: ht) :: acc
        | None -> return acc
      end
    | _ -> return acc
  end
end

let f32_tyvar_param_labels = fn (
  params: [ NamedType ],
  subst: [ NamedType ],
  acc: [ string ]
) -> [ string ] throws { LirError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: plabel, typ: pty) :: rest ->
      let acc2 = match pty do
          | TyVar(name: _) ->
            if let TyF32 = subst_type_vars(t: pty, subst) then plabel :: acc else acc end
          | _ -> acc
        end
      return f32_tyvar_param_labels(params: rest, subst, acc: acc2)
  end
end

/** Recover the CONCRETE type-argument instantiation of a generic-enum value from
 *  one of its constructor applications. `Some(val: Red(7))` (constructor `Some`
 *  of `Option<T>`) yields `Option<Color>`; `Wrap(v: x)` of `Box<T>` with `x:
 *  Color` yields `Box<Color>`. The recovered arg list lets the LIR `==`/`!=`
 *  lowering route to a per-instantiation structural-compare helper instead of
 *  the type-erased identity compare (spec § T-Cmp), and seeds the per-inst
 *  helper worklist (see struct_eq.nx).
 *
 *  How: the constructor's owning enum carries `type_params` (e.g. `["T"]`) and
 *  the variant's DECLARED field types (which mention those params as
 *  `TyUserDefined("T", [])` — at MIR a type parameter is shape-identical to a
 *  named type, disambiguated here by membership in `type_params`). Aligning the
 *  variant's fields (alphabetically, matching the MIR's sorted constructor-arg
 *  order) with the args' inferred semantic types binds each param to a concrete
 *  type; the enum's `type_params` are then mapped through those bindings.
 *
 *  Returns `args: []` (today's erased behavior) when: the constructor is
 *  unknown/opaque, the enum is non-generic (no params), or any param is left
 *  unbound or still polymorphic — never a partial/`TyVar`-bearing instantiation,
 *  which would mis-key the helper. */
export let recover_ctor_instantiation = fn (
  ctor: string,
  args: [ MirExpr ],
  ctx: LowerCtx
) -> [ TypeExpr ] throws { LirError } do
  let LowerCtx(vars: _, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: edx) = ctx
  match vidx.lookup_variant_info(idx: edx, variant: ctor) do
    | None -> return []
    | Some(val: VariantInfo(enum_name: _, type_params: tps, def: vd)) ->
      match tps do
        // Non-generic enum: no instantiation to recover.
        | [] -> return []
        | _ ->
          let VariantDef(name: _, fields: fs) = vd
          // Align declared fields with the MIR's alphabetical constructor-arg
          // order, then unify field-type-vs-arg-type to bind the params.
          let subst = unify_ctor_fields(fields: sort_variant_fields(fs), args, params: tps, ctx, acc: [])
          let recovered = inst_args_from_params(params: tps, subst)
          // Accept only a fully-concrete instantiation; any remaining `TyVar`
          // means a param stayed unbound (e.g. a phantom param) → erase.
          if type_args_have_tyvar(ts: recovered) then return [] else return recovered end
      end
  end
end

// Sort a variant's fields alphabetically by name, matching the MIR's
// `sort_ctor_args` constructor-arg ordering so a positional zip with the args
// lines field `i` up with arg `i`. Positional (nameless) fields keep their order.
let sort_variant_fields = fn (fs: [ VariantField ]) -> [ VariantField ] throws { LirError } do
  match fs do
    | [] -> return []
    | f :: rest -> return insert_variant_field(f, sorted: sort_variant_fields(fs: rest))
  end
end

let insert_variant_field = fn (
  f: VariantField,
  sorted: [ VariantField ]
) -> [ VariantField ] throws { LirError } do
  return insert_variant_field_go(f, sorted, acc: [])
end

let insert_variant_field_go = fn (
  f: VariantField,
  sorted: [ VariantField ],
  acc: [ VariantField ]
) -> [ VariantField ] throws { LirError } do
  match sorted do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: [ f ])
    | head :: rest ->
      if lir_str_less_than(a: variant_field_label(vf: f), b: variant_field_label(vf: head)) then
        return list.concat(xs: list.reverse(xs: acc), ys: f :: sorted)
      else
        return insert_variant_field_go(f, sorted: rest, acc: head :: acc)
      end
  end
end

let variant_field_label = fn (vf: VariantField) -> string throws { LirError } do
  let VariantField(name: n_opt, typ: _) = vf
  match n_opt do
    | Some(val: n) -> return n
    | None -> return ""
  end
end

// Walk the (sorted) variant fields alongside the (alphabetically-ordered) MIR
// args, unifying each declared field type against the arg's inferred semantic
// type to bind the enum's type params. Threads a single flat `[NamedType]`
// binding accumulator (param-name → concrete type).
let unify_ctor_fields = fn (
  fields: [ VariantField ],
  args: [ MirExpr ],
  params: [ string ],
  ctx: LowerCtx,
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match fields do
    | [] -> return acc
    | VariantField(name: _, typ: ftyp) :: frest ->
      match args do
        | [] -> return acc
        | a :: arest ->
          let acc2 = unify_param_type(decl: ftyp, arg_ty: infer_semantic_type(expr: a, ctx), params, acc)
          return unify_ctor_fields(fields: frest, args: arest, params, ctx, acc: acc2)
      end
  end
end

// Structurally match a DECLARED field type (which may mention the enum's type
// params as `TyUserDefined(p, [])`) against an arg's concrete type, binding each
// param it reaches. A field-name in `params` is the variable; anything else is a
// concrete shape recursed positionally (`[T]`, `K<…,T,…>`). Mirrors
// `collect_tyvar_bindings` but treats param-named `TyUserDefined` as the var
// (the MIR representation of a type parameter), not `TyVar`.
let unify_param_type = fn (
  decl: TypeExpr,
  arg_ty: TypeExpr,
  params: [ string ],
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match decl do
    | TyUserDefined(name: dn, args: dargs) ->
      if str_list_has(xs: params, s: dn) then
        // `dn` is a type parameter → bind it to the whole arg type.
        return NamedType(name: dn, typ: arg_ty) :: acc
      else
        // Concrete same-head constructor (`Option<T>` field at `Option<Color>`
        // arg): recurse positionally into the type args.
        match arg_ty do
          | TyUserDefined(name: an, args: aargs) ->
            if dn == an then return unify_param_type_list(ds: dargs, ats: aargs, params, acc) else return acc end
          | _ -> return acc
        end
      end
    | TyList(elem: de) ->
      match arg_ty do
        | TyList(elem: ae) -> return unify_param_type(decl: de, arg_ty: ae, params, acc)
        | _ -> return acc
      end
    | TyVar(name: vn) ->
      // Defensive: a param already normalized to `TyVar` also binds.
      if str_list_has(xs: params, s: vn) then return NamedType(name: vn, typ: arg_ty) :: acc else return acc end
    | _ -> return acc
  end
end

let unify_param_type_list = fn (
  ds: [ TypeExpr ],
  ats: [ TypeExpr ],
  params: [ string ],
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match ds do
    | [] -> return acc
    | d :: drest ->
      match ats do
        | [] -> return acc
        | a :: arest ->
          let acc2 = unify_param_type(decl: d, arg_ty: a, params, acc)
          return unify_param_type_list(ds: drest, ats: arest, params, acc: acc2)
      end
  end
end

// Build the enum's instantiation arg list by mapping each `type_param` through
// the recovered bindings (an unbound param stays `TyVar(param)`, which the caller
// rejects as not-fully-concrete).
let inst_args_from_params = fn (
  params: [ string ],
  subst: [ NamedType ]
) -> [ TypeExpr ] throws { LirError } do
  match params do
    | [] -> return []
    | p :: rest ->
      let bound = match lookup_named_type_opt(target: p, fields: subst) do
        | Some(val: t) -> t
        | None -> TyVar(name: p)
      end
      return bound :: inst_args_from_params(params: rest, subst)
  end
end

let str_list_has = fn (xs: [ string ], s: string) -> bool throws { LirError } do
  match xs do
    | [] -> return false
    | x :: rest -> if x == s then return true else return str_list_has(xs: rest, s) end
  end
end

/** Walk the callee's (labeled) parameter types alongside the call's arguments,
 *  matched BY LABEL (both are labeled; MIR arg order need not equal the
 *  declared param order), accumulating type-variable bindings. */
let collect_call_bindings = fn (
  params: [ NamedType ],
  args: [ MirCallArg ],
  ctx: LowerCtx,
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match params do
    | [] -> return acc
    | NamedType(name: plabel, typ: pty) :: prest ->
      let acc2 = match find_arg_by_label(label: plabel, args) do
          | Some(val: aexpr) ->
            collect_tyvar_bindings(param_ty: pty, arg_ty: infer_semantic_type(expr: aexpr, ctx), acc)
          | None -> acc
        end
      return collect_call_bindings(params: prest, args, ctx, acc: acc2)
  end
end

let find_arg_by_label = fn (
  label: string,
  args: [ MirCallArg ]
) -> Option<MirExpr> throws { LirError } do
  match args do
    | [] -> return None
    | MirCallArg(label: l, value: v) :: rest ->
      if l == label then return Some(val: v) else return find_arg_by_label(label, args: rest) end
  end
end

/** Public function infer_record_field_types. */
export let infer_record_field_types = fn (
  fields: [ MirNamedExpr ],
  ctx: LowerCtx
) -> [ NamedType ] throws { LirError } do
  return infer_record_field_types_go(fields, ctx, acc: [])
end

let infer_record_field_types_go = fn (
  fields: [ MirNamedExpr ],
  ctx: LowerCtx,
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | MirNamedExpr(name: n, value: e) :: rest ->
      let ft = infer_semantic_type(expr: e, ctx)
      return infer_record_field_types_go(fields: rest, ctx, acc: NamedType(name: n, typ: ft) :: acc)
  end
end

/** Prefer the annotation's narrow numeric WIDTH (`f32`/`i32`) over the
 *  structurally-inferred wide default (`f64`/`i64`), leaf-only. A literal carries
 *  no width on its atom (`LirAtomFloat`/`LirAtomInt` lower to `f64`/`i64`), so a
 *  declared-narrow leaf must take its width from the annotation. Non-narrow
 *  annotations leave the inferred type untouched. */
let prefer_narrow_width = fn (declared: TypeExpr, inferred: TypeExpr) -> TypeExpr do
  match declared do
    | TyF32 -> match inferred do | TyF64 -> return TyF32 | _ -> return inferred end
    | TyI32 -> match inferred do | TyI64 -> return TyI32 | _ -> return inferred end
    | _ -> return inferred
  end
end

let reconcile_record_field_widths = fn (
  annot_fields: [ NamedType ],
  inferred_fields: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  return reconcile_record_field_widths_go(annot_fields, inferred_fields, acc: [])
end

let reconcile_record_field_widths_go = fn (
  annot_fields: [ NamedType ],
  inferred_fields: [ NamedType ],
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match inferred_fields do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: n, typ: it) :: rest ->
      let merged = match lookup_named_type_opt(target: n, fields: annot_fields) do
        | Some(val: at) -> prefer_narrow_width(declared: at, inferred: it)
        | None -> it
      end
      return reconcile_record_field_widths_go(annot_fields, inferred_fields: rest,
        acc: NamedType(name: n, typ: merged) :: acc)
  end
end

/** Carry the `let`-annotation's narrow numeric leaf WIDTH (`f32`/`i32`) onto the
 *  structurally-inferred semantic type of a record / list / array literal,
 *  field-by-field (record) or on the element (list/array).
 *
 *  A literal initializer infers its leaf type from the literal atom, which is
 *  always the wide default (`atom_type` is width-less on float/int literals). So
 *  `{ zed: <flit> }` infers `zed: f64` and `[ <flit> ]` infers element `f64`,
 *  dropping a declared `f32`. The field/element LOAD then takes the wide arm of
 *  `emit_typed_field_load` (`f64.load`, no demote), and an `f32` literal keeps
 *  its full f64 precision instead of rounding. Reconciling the narrow width onto
 *  the field/element routes the load through the `TyF32` demote arm — symmetric
 *  with the sum-payload path, which already recovers `f32` from the variant def.
 *
 *  Only the leaf WIDTH is taken from the annotation; the inferred structure
 *  (field names/order, nested record bodies, element record types) is preserved,
 *  so a structurally-richer inferred element is never shadowed. The annotation is
 *  resolved through any record alias so a named record type (`FieldRec`) exposes
 *  its declared fields. */
export let reconcile_annotation_widths = fn (
  annot: TypeExpr,
  inferred: TypeExpr,
  enum_defs: VariantIndex
) -> TypeExpr throws { LirError } do
  match annot do
    | TyList(elem: ae) ->
      match inferred do
        | TyList(elem: ie) -> return TyList(elem: prefer_narrow_width(declared: ae, inferred: ie))
        | _ -> return inferred
      end
    | TyArray(elem: ae) ->
      match inferred do
        | TyArray(elem: ie) -> return TyArray(elem: prefer_narrow_width(declared: ae, inferred: ie))
        | _ -> return inferred
      end
    | _ ->
      match vidx.resolve_record_alias(idx: enum_defs, typ: annot) do
        | TyRecord(fields: af) ->
          match inferred do
            | TyRecord(fields: inf) ->
              return TyRecord(fields: reconcile_record_field_widths(annot_fields: af, inferred_fields: inf))
            | _ -> return inferred
          end
        | _ -> return inferred
      end
  end
end

/** Public function infer_stmts_type. */
export let infer_stmts_type = fn (
  stmts: [ MirStmt ],
  ctx: LowerCtx
) -> TypeExpr throws { LirError } do
  match stmts do
    | [] -> return TyUnit
    | [ s ] ->
      match s do
        | MirStmtExpr(expr: e) | MirStmtReturn(expr: e) -> return infer_semantic_type(expr: e, ctx)
        | _ -> return TyUnit
      end
    | _ :: rest -> return infer_stmts_type(stmts: rest, ctx)
  end
end

/** Collect an `if`'s arm bodies (then, then else when present) as a flat list
 *  of statement sequences, so the value-position type inference can skip
 *  diverging arms and read the type from a value-producing one. */
export let if_arms = fn (
  then_body: [ MirStmt ],
  else_body: Option<[ MirStmt ]>
) -> [ [ MirStmt ] ] throws { LirError } do
  match else_body do
    | Some(val: eb) -> return [ then_body, eb ]
    | None -> return [ then_body ]
  end
end

let match_case_bodies = fn (
  cases: [ MirMatchCase ]
) -> [ [ MirStmt ] ] throws { LirError } do
  match cases do
    | [] -> return []
    | MirMatchCase(pattern: _, body: b) :: rest -> return b :: match_case_bodies(cases: rest)
  end
end

/** True iff a statement sequence cannot produce a value because its last
 *  statement transfers control away (a `return` or a `throw`). The value-typed
 *  `if`/`match` inference must skip such arms — their last statement carries no
 *  binding-typed value, so reading their type yields the catch-all `TyI64` and
 *  a later `.field` projection on the bound result aborts LIR with E6002. This
 *  mirrors the typechecker's diverging-branch carve-out: the binding's type is
 *  taken from a value-producing arm.
 *
 *  Divergence also propagates through a trailing nested `if`/`match`: such a
 *  statement transfers control away when every one of its branch bodies
 *  diverges (and, for an `if`, only when an `else` branch is present, since a
 *  missing `else` lets control fall through to the unit value). */
export let stmts_diverge = fn (stmts: [ MirStmt ]) -> bool throws { LirError } do
  match last_stmt_opt(stmts) do
    | Some(val: MirStmtReturn(expr: _)) -> return true
    | Some(val: MirStmtExpr(expr: MirRaise(expr: _))) -> return true
    | Some(val: MirStmtExpr(expr: MirIf(cond: _, then_body: tb, else_body: eb))) ->
      match eb do
        | Some(val: _) -> return all_arms_diverge(arms: if_arms(then_body: tb, else_body: eb))
        | None -> return false
      end
    | Some(val: MirStmtExpr(expr: MirMatch(target: _, cases: cs))) ->
      match cs do
        | [] -> return false
        | _ -> return all_arms_diverge(arms: match_case_bodies(cases: cs))
      end
    | _ -> return false
  end
end

/** True iff every branch body in `arms` diverges. An empty arm list is treated
 *  as non-diverging so a branchless construct never masks a value-producing
 *  sibling arm. */
let all_arms_diverge = fn (arms: [ [ MirStmt ] ]) -> bool throws { LirError } do
  match arms do
    | [] -> return true
    | arm :: rest ->
      if stmts_diverge(stmts: arm) then
        return all_arms_diverge(arms: rest)
      else
        return false
      end
  end
end

let last_stmt_opt = fn (stmts: [ MirStmt ]) -> Option<MirStmt> throws { LirError } do
  match stmts do
    | [] -> return None
    | [ s ] -> return Some(val: s)
    | _ :: rest -> return last_stmt_opt(stmts: rest)
  end
end

/** Infer the value type shared by a set of branch bodies (`if`/`match` arms),
 *  preferring the first value-producing (non-diverging) arm. Falls back to the
 *  first arm's type when every arm diverges (the binding is then dead, so the
 *  resulting `TyI64` is never projected). */
export let infer_branches_type = fn (
  arms: [ [ MirStmt ] ],
  ctx: LowerCtx
) -> TypeExpr throws { LirError } do
  match arms do
    | [] -> return TyUnit
    | arm :: rest ->
      if stmts_diverge(stmts: arm) then
        match infer_first_value_arm(arms: rest, ctx) do
          | Some(val: t) -> return t
          | None -> return infer_stmts_type(stmts: arm, ctx)
        end
      else
        return infer_stmts_type(stmts: arm, ctx)
      end
  end
end

let infer_first_value_arm = fn (
  arms: [ [ MirStmt ] ],
  ctx: LowerCtx
) -> Option<TypeExpr> throws { LirError } do
  match arms do
    | [] -> return None
    | arm :: rest ->
      if stmts_diverge(stmts: arm) then
        return infer_first_value_arm(arms: rest, ctx)
      else
        return Some(val: infer_stmts_type(stmts: arm, ctx))
      end
  end
end

/** Public function is_semantic_string. */
export let is_semantic_string = fn (t: TypeExpr) -> bool throws { LirError } do
  return if let TyString = t then true else false end
end

/** True iff `t` is the narrow 32-bit int slot `TyI32`. */
let is_i32 = fn (t: TypeExpr) -> bool do
  match t do | TyI32 -> return true | _ -> return false end
end

/** True iff `t` is the narrow 32-bit float slot `TyF32`. */
let is_f32 = fn (t: TypeExpr) -> bool do
  match t do | TyF32 -> return true | _ -> return false end
end

/** Result type of a float-arith op (`+. -. *. /.`). The codegen opcode is f32
 *  whenever EITHER operand is f32 (a literal `1.0` on the other side stays f64
 *  but is demoted before the op); the typechecker rejects genuine f32/f64
 *  variable mixing, so an f32 next to an f64 means that f64 is a float literal
 *  that adopts the f32 width. Recording TyF32 here keeps the result temp's
 *  declared type in sync with the f32 value the opcode produces (an f64 temp
 *  would reject the f32 `local.set`). Otherwise f64. */
let float_arith_result = fn (lhs_type: TypeExpr, rhs_type: TypeExpr) -> TypeExpr do
  if is_f32(t: lhs_type) || is_f32(t: rhs_type) then return TyF32 end
  return TyF64
end

/** Result type of an int-arith op. f64-on-either-side wins (polymorphic `+`
 *  can land on floats as OpAdd); else i32 whenever EITHER operand is i32 (the
 *  other side is then an i64 literal narrowed to i32 — typecheck forbids
 *  genuine i32/i64 variable mixing); else i64. Keeps the result temp's type in
 *  sync with the i32 opcode + literal-narrowing emit_binary / binary_operand_type
 *  emit, so the value matches the slot it flows into. */
let int_arith_result = fn (lhs_type: TypeExpr, rhs_type: TypeExpr) -> TypeExpr do
  match lhs_type do | TyF64 -> return TyF64 | _ -> () end
  match rhs_type do | TyF64 -> return TyF64 | _ -> () end
  if is_i32(t: lhs_type) || is_i32(t: rhs_type) then return TyI32 end
  return TyI64
end

/** Public function infer_binary_type. */
export let infer_binary_type = fn (
  op: BinaryOp,
  lhs_type: TypeExpr,
  rhs_type: TypeExpr
) -> TypeExpr throws { LirError } do
  match op do
    | OpEq | OpNe | OpLt | OpLe | OpGt | OpGe
    | OpFEq | OpFNe | OpFLt | OpFLe | OpFGt | OpFGe
    | OpAnd | OpOr -> return TyBool
    | OpConcat -> return TyString
    | OpFAdd | OpFSub | OpFMul | OpFDiv -> return float_arith_result(lhs_type, rhs_type)
    | OpAdd ->
      match lhs_type do
        | TyString -> return TyString
        | _ -> return int_arith_result(lhs_type, rhs_type)
      end
    | OpSub | OpMul | OpDiv -> return int_arith_result(lhs_type, rhs_type)
    | OpMod -> return int_arith_result(lhs_type, rhs_type)
    | _ -> return lhs_type
  end
end

// Character-by-character string comparison (lexicographic less-than)
let lir_str_less_than_loop = fn (
  a: string,
  b: string,
  idx: i64,
  la: i64,
  lb: i64
) -> bool throws { LirError } do
  if idx >= la then
    return idx < lb
  else if idx >= lb then
    return false
  else
    let ca = str.char_code(s: a, idx)
    let cb = str.char_code(s: b, idx)
    if ca < cb then
      return true
    else if ca > cb then
      return false
    else
      return lir_str_less_than_loop(a, b, idx: idx + 1, la, lb)
    end
  end
end

/** Public function lir_str_less_than. */
export let lir_str_less_than = fn (a: string, b: string) -> bool throws { LirError } do
  return lir_str_less_than_loop(a, b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end

let insert_mir_param = fn (p: MirParam, sorted: [ MirParam ]) -> [ MirParam ] throws { LirError } do
  return insert_mir_param_go(p, sorted, acc: [])
end

let insert_mir_param_go = fn (
  p: MirParam,
  sorted: [ MirParam ],
  acc: [ MirParam ]
) -> [ MirParam ] throws { LirError } do
  match sorted do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: [ p ])
    | head :: rest ->
      let MirParam(label: la, name: _, typ: _) = p
      let MirParam(label: lb, name: _, typ: _) = head
      if lir_str_less_than(a: la, b: lb) then
            return list.concat(xs: list.reverse(xs: acc), ys: p :: sorted)
          else
            return insert_mir_param_go(p, sorted: rest, acc: head :: acc)
          end
  end
end

/** Public function sort_mir_params. */
export let sort_mir_params = fn (params: [ MirParam ]) -> [ MirParam ] throws { LirError } do
  match params do
    | [] -> return []
    | p :: rest -> return insert_mir_param(p, sorted: sort_mir_params(params: rest))
  end
end

let insert_lir_call_arg = fn (
  a: LirCallArg,
  sorted: [ LirCallArg ]
) -> [ LirCallArg ] throws { LirError } do
  return insert_lir_call_arg_go(a, sorted, acc: [])
end

let insert_lir_call_arg_go = fn (
  a: LirCallArg,
  sorted: [ LirCallArg ],
  acc: [ LirCallArg ]
) -> [ LirCallArg ] throws { LirError } do
  match sorted do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: [ a ])
    | head :: rest ->
      let LirCallArg(label: la, value: _) = a
      let LirCallArg(label: lb, value: _) = head
      if lir_str_less_than(a: la, b: lb) then
            return list.concat(xs: list.reverse(xs: acc), ys: a :: sorted)
          else
            return insert_lir_call_arg_go(a, sorted: rest, acc: head :: acc)
          end
  end
end

/** Public function sort_lir_call_args. */
export let sort_lir_call_args = fn (args: [ LirCallArg ]) -> [ LirCallArg ] throws { LirError } do
  match args do
    | [] -> return []
    | a :: rest -> return insert_lir_call_arg(a, sorted: sort_lir_call_args(args: rest))
  end
end

let insert_lir_named_atom = fn (
  a: LirNamedAtom,
  sorted: [ LirNamedAtom ]
) -> [ LirNamedAtom ] throws { LirError } do
  return insert_lir_named_atom_go(a, sorted, acc: [])
end

let insert_lir_named_atom_go = fn (
  a: LirNamedAtom,
  sorted: [ LirNamedAtom ],
  acc: [ LirNamedAtom ]
) -> [ LirNamedAtom ] throws { LirError } do
  match sorted do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: [ a ])
    | head :: rest ->
      let LirNamedAtom(name: na, value: _) = a
      let LirNamedAtom(name: nb, value: _) = head
      if lir_str_less_than(a: na, b: nb) then
            return list.concat(xs: list.reverse(xs: acc), ys: a :: sorted)
          else
            return insert_lir_named_atom_go(a, sorted: rest, acc: head :: acc)
          end
  end
end

/** Public function sort_lir_named_atoms. */
export let sort_lir_named_atoms = fn (atoms: [ LirNamedAtom ]) -> [ LirNamedAtom ] throws { LirError } do
  match atoms do
    | [] -> return []
    | a :: rest -> return insert_lir_named_atom(a, sorted: sort_lir_named_atoms(atoms: rest))
  end
end

/** Public function build_record_semantic_type. */
export let build_record_semantic_type = fn (
  atoms: [ LirNamedAtom ],
  ctx: LowerCtx
) -> TypeExpr throws { LirError } do
  return TyRecord(fields: build_named_types_from_atoms(atoms, ctx))
end

let build_named_types_from_atoms = fn (
  atoms: [ LirNamedAtom ],
  ctx: LowerCtx
) -> [ NamedType ] throws { LirError } do
  return build_named_types_from_atoms_go(atoms, ctx, acc: [])
end

let build_named_types_from_atoms_go = fn (
  atoms: [ LirNamedAtom ],
  ctx: LowerCtx,
  acc: [ NamedType ]
) -> [ NamedType ] throws { LirError } do
  match atoms do
    | [] -> return list.reverse(xs: acc)
    | LirNamedAtom(name: n, value: v) :: rest ->
      let sem = match v do
        | LirAtomVar(name: vn, typ: _) ->
          let LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) = ctx
          match lir_lookup_type(name: vn, entries: sv) do
              | Some(val: t) -> t
              | None -> wasm_to_semantic(typ: atom_type(atom: v))
            end
        | _ -> wasm_to_semantic(typ: atom_type(atom: v))
      end
      return build_named_types_from_atoms_go(
        atoms: rest,
        ctx,
        acc: NamedType(name: n, typ: sem) :: acc
      )
  end
end

let wasm_to_semantic = fn (typ: TypeExpr) -> TypeExpr throws { LirError } do
  // Best-effort reverse mapping from WASM type to semantic type
  match typ do
    | TyI32 | TyI64 -> return TyI64
    | TyF64 -> return TyF64
    | _ -> return typ
  end
end

/** Public type FieldResolution. */
export type FieldResolution = FieldResolution(index: i64, typ: TypeExpr)

let sorted_named_type_index = fn (
  target: string,
  fields: [ NamedType ]
) -> i64 throws { LirError } do
  match fields do
    | [] -> return 0
    | NamedType(name: n, typ: _) :: rest ->
      if lir_str_less_than(a: n, b: target) then
        return 1 + sorted_named_type_index(target, fields: rest)
      else
        return sorted_named_type_index(target, fields: rest)
      end
  end
end

let lookup_named_type = fn (
  target: string,
  fields: [ NamedType ]
) -> TypeExpr throws { LirError } do
  match fields do
    | [] -> throw LirFieldNotInRecord(field: target)
    | NamedType(name: n, typ: t) :: rest ->
      if n == target then return t
      else return lookup_named_type(target, fields: rest)
      end
  end
end

/** Public function resolve_record_field. */
export let resolve_record_field = fn (
  atom: LirAtom,
  field: string,
  ctx: LowerCtx
) -> FieldResolution throws { LirError } do
  if let LirAtomVar(name: n, typ: _) = atom then
    let LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: ed) = ctx
    match lir_lookup_type(name: n, entries: sv) do
        | Some(val: TyRecord(fields: fs)) ->
          let idx = sorted_named_type_index(target: field, fields: fs)
          // The field's declared type may be a named record alias
          // (`inner: Inner` → `TyUserDefined("Inner", …)`). Resolve it to its
          // `TyRecord` body so the bound result temp carries a record semantic
          // type and a chained `.field` (`oo.inner.a`) doesn't abort with E6002
          //One-level-on-demand → safe on recursive records.
          let ft = vidx.resolve_record_alias(idx: ed,
            typ: lookup_named_type(target: field, fields: fs))
          return FieldResolution(index: idx, typ: ft)
        | _ -> throw LirFieldOnNonRecord(field, variable: n)
      end
  else
    throw LirFieldOnNonVariable(field)
  end
end
