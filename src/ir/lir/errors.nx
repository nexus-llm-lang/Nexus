/**
 * lir/errors: LIR-phase exception types.
 *
 * These are internal compiler errors (ICEs) raised when LIR construction or
 * analysis encounters a structurally invalid atom table or record type.
 * All are E6xxx codes in `format_error`.
 */

/** Public exception LirFieldOnNonVariable. */
export exception LirFieldOnNonVariable(field: string)
/** Public exception LirFieldOnNonRecord. */
export exception LirFieldOnNonRecord(field: string, variable: string)
/** Public exception LirFieldNotInRecord. */
export exception LirFieldNotInRecord(field: string)
/** Public exception LirAtomEntryNotFound. */
export exception LirAtomEntryNotFound(id: i64)

/** Public exception group LirError. */
export exception group LirError =
    LirFieldOnNonVariable | LirFieldOnNonRecord | LirFieldNotInRecord | LirAtomEntryNotFound
