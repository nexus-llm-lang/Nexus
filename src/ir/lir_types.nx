/**
 * lir_types: LIR type definitions for the Nexus self-hosting compiler.
 *
 * Pure data types extracted from lir.nx. No logic, no helpers.
 */

import { Span } from "src/common/token.nx"
import { BinaryOp, TypeExpr } from "src/common/ast.nx"

// ─── LIR Types ───────────────────────────────────────────────────────────────

export type LirParam = LirParam(label: string, name: string, typ: TypeExpr)

export type LirExternal = LirExternal(
  name: string,
  wasm_module: string,
  wasm_name: string,
  params: [LirParam],
  ret_type: TypeExpr,
  throw_row: TypeExpr
)

export type LirAtom =
  LirAtomVar(name: string, typ: TypeExpr)
  | LirAtomInt(val: i64)
  | LirAtomFloat(val: string)
  | LirAtomBool(val: bool)
  | LirAtomChar(val: i64)
  | LirAtomString(val: string)
  | LirAtomUnit

export type LirExpr =
  LirExprAtom(atom: LirAtom)
  | LirExprBinary(op: BinaryOp, lhs: LirAtom, rhs: LirAtom, typ: TypeExpr)
  | LirExprCall(func: string, args: [LirCallArg], typ: TypeExpr)
  | LirExprTailCall(func: string, args: [LirCallArg], typ: TypeExpr)
  | LirExprConstructor(name: string, args: [LirAtom], typ: TypeExpr)
  | LirExprRecord(fields: [LirNamedAtom], typ: TypeExpr)
  | LirExprObjectTag(value: LirAtom, typ: TypeExpr)
  | LirExprObjectField(value: LirAtom, index: i64, typ: TypeExpr)
  | LirExprRaise(value: LirAtom, typ: TypeExpr)
  | LirExprForce(value: LirAtom, typ: TypeExpr)
  | LirExprMakeClosure(func_name: string, captures: [LirAtom], typ: TypeExpr)
  | LirExprCallClosure(closure: LirAtom, args: [LirCallArg], typ: TypeExpr)
  // wasm stack-switching primitives: `suspend $tag` (yield to handler arm),
  // `resume $cont` (resume captured cont), `cont.new $func` (allocate cont
  // from a function reference).
  | LirExprSuspend(tag_name: string, payload: LirAtom, typ: TypeExpr)
  | LirExprResume(cont: LirAtom, value: LirAtom, typ: TypeExpr)
  | LirExprContNew(func_ref: string, typ: TypeExpr)
  // Inject body invoked as a stack-switching continuation. `body_fn` names a
  // top-level lifted MirFunction (`__inject_N`); `arm_fns` is the dispatch
  // table for on-clauses, one entry per `(port, op)` with cont_binder.
  | LirExprInjectResume(body_fn: string, arm_fns: [string], arm_tags: [string], typ: TypeExpr)

export type LirCallArg = LirCallArg(label: string, value: LirAtom)

export type LirNamedAtom = LirNamedAtom(name: string, value: LirAtom)

export type LirStmt =
  LirStmtLet(name: string, typ: TypeExpr, expr: LirExpr)
  | LirStmtIf(cond: LirAtom, then_body: [LirStmt], else_body: [LirStmt])
  | LirStmtIfReturn(cond: LirAtom, then_body: [LirStmt], then_ret: LirAtom,
                     else_body: [LirStmt], else_ret: Option<LirAtom>, ret_type: TypeExpr)
  | LirStmtLoop(cond_stmts: [LirStmt], cond: LirAtom, body: [LirStmt])
  | LirStmtTryCatch(body: [LirStmt], body_ret: Option<LirAtom>,
                     catch_param: string, catch_param_typ: TypeExpr,
                     catch_body: [LirStmt], catch_ret: Option<LirAtom>)

export type LirFunction = LirFunction(
  name: string,
  params: [LirParam],
  ret_type: TypeExpr,
  body: [LirStmt],
  ret: LirAtom,
  span: Span
)

export type LirProgram = LirProgram(functions: [LirFunction], externals: [LirExternal])
