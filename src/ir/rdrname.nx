/**
 * rdrname: RdrName → canonical wasm-safe string conversion.
 *
 * Owns:
 * - Path sanitization (/, . → _) so source paths are safe as wasm identifier segments
 * - RdrName (Unqual / Qual) to flat-string conversion for use in rename maps / func tables
 *
 * Does not own:
 * - The symtab / scope lookup itself — see src/ir/symtab.nx
 * - Handler-function mangling — see src/common/naming.nx
 */
import { RdrName, Unqual, Qual } from "src/common/ast.nx"
import * as str from "std:str"

/** Replace / and . with _ so source paths are safe as wasm identifier segments.
 *
 * Both `/` (0x2F) and `.` (0x2E) are ASCII single-byte chars that cannot appear
 * as UTF-8 continuation bytes, so two passes of byte-level `str.replace` give
 * the same output as the previous char-by-char loop, in O(N) instead of O(N^2).
 */
let sanitize_path = fn (path: string) -> string do
  let no_slash = str.replace(s: path, from_str: "/", to_str: "_")
  return str.replace(s: no_slash, from_str: ".", to_str: "_")
end

/** Canonical global name: "sanitized_source_path#name". */
export let canonical_name = fn (source_path: string, name: string) -> string do
  return sanitize_path(path: source_path) ++ "#" ++ name
end

export let rdr_from_dotted = fn (s: string) -> RdrName do
  let dot_pos = str.index_of(s, sub: ".")
  if dot_pos < 0 then return Unqual(name: s) end
  let alias_part = str.substring(s, start: 0, len: dot_pos)
  let name_part = str.substring(s, start: dot_pos + 1, len: str.length(s) - dot_pos - 1)
  return Qual(alias: alias_part, name: name_part)
end

export let rdr_to_string = fn (r: RdrName) -> string do
  match r do
    | Unqual(name: n) -> return n
    | Qual(alias: a, name: n) -> return a ++ "." ++ n
  end
end

export let rdr_occ = fn (r: RdrName) -> string do
  match r do
    | Unqual(name: n) | Qual(alias: _, name: n) -> return n
  end
end
