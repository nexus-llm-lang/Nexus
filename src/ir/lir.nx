/**
 * lir: MIR → LIR lowering (A-Normal Form with semantic-type tracking).
 *
 * Owns:
 * - ANF-lowering of sub-expressions to atomic values
 * - Semantic-type tracking for field access resolution
 * - match / if conversion to conditional assignment chains
 * - Decision-tree emission (Expr Mode + Stmt Mode). Pure emission helpers
 *   (field extraction, condition builders, binding emission) live in
 *   src/ir/lir/match_tree.nx. The emission entry / leaf / recursive
 *   dispatch stays here because leaves call body lowering and the
 *   self-hosted nxc does not yet support first-class function calls —
 *   callback injection would be the natural split (see nexus-o7l9).
 * - Statement lowering, function lowering, external conversion, entry point
 *
 * Does not own:
 * - LowerCtx and the atom / type / temp-var helpers (see src/ir/lir/context.nx)
 * - LIR type definitions (see src/ir/lir_types.nx)
 * - Maranget pattern-matrix → DecTree construction (see src/ir/lir/match_tree.nx)
 * - LIR-level optimization passes (see src/ir/lir_opt.nx)
 */
import { BinaryOp, Literal, TypeExpr, TyUserDefined, NamedType, EnumDef, VariantDef, VariantField, TyVar, TyList, TyLazy, TyArrow } from "src/common/ast.nx"
import { LirFieldOnNonVariable, LirFieldOnNonRecord, LirFieldNotInRecord } from "src/common/error.nx"
import { Some, None } from "std:option"
import { MirProgram, MirFunction, MirExpr, MirStmt, MirParam, MirExternal, MirCallArg, MirMatchCase, MirPattern, MirPatternField, MirRecordPatField, MirNamedExpr } from "src/ir/mir_types.nx"
import { LirProgram, LirFunction, LirExternal, LirParam, LirAtom, LirExpr, LirStmt, LirCallArg, LirNamedAtom } from "src/ir/lir_types.nx"
import { LowerCtx, TypeEntry, TempResult, BindResult, BranchBodyResult, BlockResult, lir_lookup_type, insert_type, wasm_type, atom_type, default_atom, new_temp, bind_expr_to_temp, bind_expr_to_temp_semantic, literal_to_atom } from "src/ir/lir/context.nx"
import { PatBinding, PatRow, DecTree, CtorBranch, LitBranch, AtomEntry, DecTreeResult, FieldExtractResult, FieldLoopResult, CtorCondsResult, LitCondsResult, lir_build_decision_tree, lir_cases_to_rows, lir_reverse_ctors, lir_reverse_lit_branches, lookup_atom_entry, lir_id_nth, lir_str_index, lir_sort_strings, lir_reverse_atoms, lir_ctors_length, lir_emit_bindings, lir_emit_ctor_conds, lir_emit_lit_conds, lir_extract_ctor_fields, lir_extract_record_fields, lir_nth_case_body } from "src/ir/lir/match_tree.nx"
import * as str from "std:string_ops"

// ─── Semantic Type Inference ─────────────────────────────────────────────────

let infer_semantic_type = fn (expr: MirExpr, ctx: LowerCtx) -> TypeExpr throws { Exn } do
  match ctx do | LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
    match expr do
      | MirVariable(name: n) ->
        match lir_lookup_type(name: n, entries: sv) do
          | Some(val: t) -> return t
          | None -> return TyI64
        end
      | MirCall(func: _, args: _, ret_type: rt) -> return rt
      | MirLiteral(lit: l) ->
        match l do
          | LitInt(_) -> return TyI64
          | LitFloat(_) -> return TyF64
          | LitBool(_) -> return TyBool
          | LitChar(_) -> return TyChar
          | LitString(_) -> return TyString
          | LitUnit -> return TyUnit
        end
      | MirConstructor(_) -> return TyI64
      | MirBinaryOp(left: _, op, right: _) ->
        match op do
          | OpConcat -> return TyString
          | OpEq -> return TyBool
          | OpNe -> return TyBool
          | OpLt -> return TyBool
          | OpLe -> return TyBool
          | OpGt -> return TyBool
          | OpGe -> return TyBool
          | OpAnd -> return TyBool
          | OpOr -> return TyBool
          | _ -> return TyI64
        end
      | MirIf(cond: _, then_body: tb, else_body: _) ->
        return infer_stmts_type(stmts: tb, ctx)
      | MirMatch(target: _, cases: cs) ->
        match cs do
          | MirMatchCase(pattern: _, body: b) :: _ ->
            return infer_stmts_type(stmts: b, ctx)
          | [] -> return TyUnit
        end
      | MirRecord(fields: fs) ->
        return TyRecord(fields: infer_record_field_types(fields: fs, ctx))
      | MirMakeClosure(_) -> return TyI64
      | MirCallClosure(closure: _, args: _, ret_type: rt) -> return rt
      | MirEnvLoad(_) -> return TyI64
      | _ -> return TyI64
    end
  end
end

/// Resolve the real return type of a closure-call site. The MIR side stores a
/// TyI64 placeholder when lowering a variable-call; the actual TyArrow lives
/// in semantic_vars (populated at function entry from the param's declared
/// type). Falls back to the MIR-supplied type for non-variable callees.
let resolve_closure_ret_type = fn (clos: MirExpr, fallback: TypeExpr, ctx: LowerCtx) -> TypeExpr throws { Exn } do
  if let MirVariable(name: n) = clos then
    match ctx do | LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
      if let Some(val: TyArrow(params: _, ret: r, requires: _, throw_row: _)) = lir_lookup_type(name: n, entries: sv) then
        return r
      else
        return fallback
      end
    end
  else
    return fallback
  end
end

let infer_record_field_types = fn (fields: [MirNamedExpr], ctx: LowerCtx) -> [NamedType] throws { Exn } do
  return infer_record_field_types_go(fields, ctx, acc: [])
end

let infer_record_field_types_go = fn (fields: [MirNamedExpr], ctx: LowerCtx, acc: [NamedType]) -> [NamedType] throws { Exn } do
  match fields do
    | [] -> return rev_named_types(lst: acc, out: [])
    | MirNamedExpr(name: n, value: e) :: rest ->
      let ft = infer_semantic_type(expr: e, ctx)
      return infer_record_field_types_go(fields: rest, ctx, acc: NamedType(name: n, typ: ft) :: acc)
  end
end

let infer_stmts_type = fn (stmts: [MirStmt], ctx: LowerCtx) -> TypeExpr throws { Exn } do
  match stmts do
    | [] -> return TyUnit
    | [s] ->
      // Last statement determines the type
      match s do
        | MirStmtExpr(expr: e) -> return infer_semantic_type(expr: e, ctx)
        | MirStmtReturn(expr: e) -> return infer_semantic_type(expr: e, ctx)
        | _ -> return TyUnit
      end
    | _ :: rest -> return infer_stmts_type(stmts: rest, ctx)
  end
end

let is_semantic_string = fn (t: TypeExpr) -> bool throws { Exn } do
  return if let TyString = t then true else false end
end

// ─── Binary Type Inference ───────────────────────────────────────────────────

let infer_binary_type = fn (op: BinaryOp, lhs_type: TypeExpr, rhs_type: TypeExpr) -> TypeExpr throws { Exn } do
  match op do
    | OpEq -> return TyBool
    | OpNe -> return TyBool
    | OpLt -> return TyBool
    | OpLe -> return TyBool
    | OpGt -> return TyBool
    | OpGe -> return TyBool
    | OpAnd -> return TyBool
    | OpOr -> return TyBool
    | OpConcat -> return TyString
    | OpAdd ->
      match lhs_type do
        | TyString -> return TyString
        | TyF64 -> return TyF64
        | _ -> return TyI64
      end
    | OpSub ->
      match lhs_type do
        | TyF64 -> return TyF64
        | _ -> return TyI64
      end
    | OpMul ->
      match lhs_type do
        | TyF64 -> return TyF64
        | _ -> return TyI64
      end
    | OpDiv ->
      match lhs_type do
        | TyF64 -> return TyF64
        | _ -> return TyI64
      end
    | OpMod -> return TyI64
    | _ -> return lhs_type
  end
end

// Character-by-character string comparison (lexicographic less-than)
let lir_str_less_than_loop = fn (a: string, b: string, idx: i64, la: i64, lb: i64) -> bool throws { Exn } do
  if idx >= la then
    return idx < lb
  else if idx >= lb then
    return false
  else
    let ca = str.char_code(s: a, idx)
    let cb = str.char_code(s: b, idx)
    if ca < cb then
      return true
    else if ca > cb then
      return false
    else
      return lir_str_less_than_loop(a, b, idx: idx + 1, la, lb)
    end
  end
end

let lir_str_less_than = fn (a: string, b: string) -> bool throws { Exn } do
  return lir_str_less_than_loop(a, b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end

// ─── Sorting helpers (alphabetical by label, matching Rust compiler) ────────

let insert_mir_param = fn (p: MirParam, sorted: [MirParam]) -> [MirParam] throws { Exn } do
  return insert_mir_param_go(p, sorted, acc: [])
end

let insert_mir_param_go = fn (p: MirParam, sorted: [MirParam], acc: [MirParam]) -> [MirParam] throws { Exn } do
  match sorted do
    | [] -> return rev_mir_params(lst: acc, out: [p])
    | head :: rest ->
      match p do | MirParam(label: la, name: _, typ: _) ->
        match head do | MirParam(label: lb, name: _, typ: _) ->
          if lir_str_less_than(a: la, b: lb) then
            return rev_mir_params(lst: acc, out: p :: sorted)
          else
            return insert_mir_param_go(p, sorted: rest, acc: head :: acc)
          end
        end
      end
  end
end

let sort_mir_params = fn (params: [MirParam]) -> [MirParam] throws { Exn } do
  match params do
    | [] -> return []
    | p :: rest -> return insert_mir_param(p, sorted: sort_mir_params(params: rest))
  end
end

let insert_lir_call_arg = fn (a: LirCallArg, sorted: [LirCallArg]) -> [LirCallArg] throws { Exn } do
  return insert_lir_call_arg_go(a, sorted, acc: [])
end

let insert_lir_call_arg_go = fn (a: LirCallArg, sorted: [LirCallArg], acc: [LirCallArg]) -> [LirCallArg] throws { Exn } do
  match sorted do
    | [] -> return rev_lir_call_args(lst: acc, out: [a])
    | head :: rest ->
      match a do | LirCallArg(label: la, value: _) ->
        match head do | LirCallArg(label: lb, value: _) ->
          if lir_str_less_than(a: la, b: lb) then
            return rev_lir_call_args(lst: acc, out: a :: sorted)
          else
            return insert_lir_call_arg_go(a, sorted: rest, acc: head :: acc)
          end
        end
      end
  end
end

let sort_lir_call_args = fn (args: [LirCallArg]) -> [LirCallArg] throws { Exn } do
  match args do
    | [] -> return []
    | a :: rest -> return insert_lir_call_arg(a, sorted: sort_lir_call_args(args: rest))
  end
end

let insert_lir_named_atom = fn (a: LirNamedAtom, sorted: [LirNamedAtom]) -> [LirNamedAtom] throws { Exn } do
  return insert_lir_named_atom_go(a, sorted, acc: [])
end

let insert_lir_named_atom_go = fn (a: LirNamedAtom, sorted: [LirNamedAtom], acc: [LirNamedAtom]) -> [LirNamedAtom] throws { Exn } do
  match sorted do
    | [] -> return rev_lir_named_atoms(lst: acc, out: [a])
    | head :: rest ->
      match a do | LirNamedAtom(name: na, value: _) ->
        match head do | LirNamedAtom(name: nb, value: _) ->
          if lir_str_less_than(a: na, b: nb) then
            return rev_lir_named_atoms(lst: acc, out: a :: sorted)
          else
            return insert_lir_named_atom_go(a, sorted: rest, acc: head :: acc)
          end
        end
      end
  end
end

let sort_lir_named_atoms = fn (atoms: [LirNamedAtom]) -> [LirNamedAtom] throws { Exn } do
  match atoms do
    | [] -> return []
    | a :: rest -> return insert_lir_named_atom(a, sorted: sort_lir_named_atoms(atoms: rest))
  end
end

// ─── Record Semantic Type Builder ────────────────────────────────────────────

let build_record_semantic_type = fn (atoms: [LirNamedAtom], ctx: LowerCtx) -> TypeExpr throws { Exn } do
  return TyRecord(fields: build_named_types_from_atoms(atoms, ctx))
end

let build_named_types_from_atoms = fn (atoms: [LirNamedAtom], ctx: LowerCtx) -> [NamedType] throws { Exn } do
  return build_named_types_from_atoms_go(atoms, ctx, acc: [])
end

let build_named_types_from_atoms_go = fn (atoms: [LirNamedAtom], ctx: LowerCtx, acc: [NamedType]) -> [NamedType] throws { Exn } do
  match atoms do
    | [] -> return rev_named_types(lst: acc, out: [])
    | LirNamedAtom(name: n, value: v) :: rest ->
      let sem = match v do
        | LirAtomVar(name: vn, typ: _) ->
          match ctx do | LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
            match lir_lookup_type(name: vn, entries: sv) do
              | Some(val: t) -> t
              | None -> wasm_to_semantic(typ: atom_type(atom: v))
            end
          end
        | _ -> wasm_to_semantic(typ: atom_type(atom: v))
      end
      return build_named_types_from_atoms_go(atoms: rest, ctx, acc: NamedType(name: n, typ: sem) :: acc)
  end
end

let wasm_to_semantic = fn (typ: TypeExpr) -> TypeExpr throws { Exn } do
  // Best-effort reverse mapping from WASM type to semantic type
  match typ do
    | TyI32 -> return TyI64
    | TyF64 -> return TyF64
    | TyI64 -> return TyI64
    | _ -> return typ
  end
end

// ─── Record Field Resolution ────────────────────────────────────────────────

type FieldResolution = FieldResolution(index: i64, typ: TypeExpr)

let sorted_named_type_index = fn (target: string, fields: [NamedType]) -> i64 throws { Exn } do
  match fields do
    | [] -> return 0
    | NamedType(name: n, typ: _) :: rest ->
      if lir_str_less_than(a: n, b: target) then
        return 1 + sorted_named_type_index(target, fields: rest)
      else
        return sorted_named_type_index(target, fields: rest)
      end
  end
end

let find_named_type = fn (target: string, fields: [NamedType]) -> TypeExpr throws { Exn } do
  match fields do
    | [] -> raise LirFieldNotInRecord(field: target, span: None)
    | NamedType(name: n, typ: t) :: rest ->
      if n == target then return t
      else return find_named_type(target, fields: rest)
      end
  end
end

let resolve_record_field = fn (atom: LirAtom, field: string, ctx: LowerCtx) -> FieldResolution throws { Exn } do
  if let LirAtomVar(name: n, typ: _) = atom then
    match ctx do | LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
      match lir_lookup_type(name: n, entries: sv) do
        | Some(val: TyRecord(fields: fs)) ->
          let idx = sorted_named_type_index(target: field, fields: fs)
          let ft = find_named_type(target: field, fields: fs)
          return FieldResolution(index: idx, typ: ft)
        | _ -> raise LirFieldOnNonRecord(field, variable: n, span: None)
      end
    end
  else
    raise LirFieldOnNonVariable(field, span: None)
  end
end

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_named_types = fn (lst: [NamedType], out: [NamedType]) -> [NamedType] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_named_types(lst: rest, out: x :: out)
  end
end

let rev_strings = fn (lst: [string], out: [string]) -> [string] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_strings(lst: rest, out: x :: out)
  end
end

let rev_mir_params = fn (lst: [MirParam], out: [MirParam]) -> [MirParam] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_mir_params(lst: rest, out: x :: out)
  end
end

let rev_lir_call_args = fn (lst: [LirCallArg], out: [LirCallArg]) -> [LirCallArg] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_lir_call_args(lst: rest, out: x :: out)
  end
end

let rev_lir_named_atoms = fn (lst: [LirNamedAtom], out: [LirNamedAtom]) -> [LirNamedAtom] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_lir_named_atoms(lst: rest, out: x :: out)
  end
end

let rev_type_entries = fn (lst: [TypeEntry], out: [TypeEntry]) -> [TypeEntry] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_type_entries(lst: rest, out: x :: out)
  end
end

let rev_lir_params = fn (lst: [LirParam], out: [LirParam]) -> [LirParam] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_lir_params(lst: rest, out: x :: out)
  end
end

let rev_enum_defs = fn (lst: [EnumDef], out: [EnumDef]) -> [EnumDef] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_enum_defs(lst: rest, out: x :: out)
  end
end

// ─── Expression Lowering ─────────────────────────────────────────────────────

let lower_expr_to_atom = fn (expr: MirExpr, ctx: LowerCtx) -> BindResult throws { Exn } do
  match expr do
    | MirLiteral(lit: l) -> return BindResult(ctx, atom: literal_to_atom(lit: l))

    | MirVariable(name: n) ->
      match ctx do | LowerCtx(vars: v, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
        let typ = match lir_lookup_type(name: n, entries: sv) do
          // Preserve TyString for string vars (enables is_string_op detection)
          | Some(val: TyString) -> TyString
          | Some(val: t) -> wasm_type(typ: t)
          | None ->
            match lir_lookup_type(name: n, entries: v) do
              | Some(val: t) -> t
              | None -> TyI64
            end
        end
        return BindResult(ctx, atom: LirAtomVar(name: n, typ))
      end

    | MirBinaryOp(left: lhs, op, right: rhs) ->
      match lower_expr_to_atom(expr: lhs, ctx) do | BindResult(ctx: ctx2, atom: la) ->
        match lower_expr_to_atom(expr: rhs, ctx: ctx2) do | BindResult(ctx: ctx3, atom: ra) ->
          // Use semantic types for binary type inference when WASM types lose
          // string info (pattern-extracted string vars have TyI64 WASM type)
          let sem_lhs = infer_semantic_type(expr: lhs, ctx)
          let sem_rhs = infer_semantic_type(expr: rhs, ctx)
          let lhs_for_infer = if is_semantic_string(t: sem_lhs) then TyString else atom_type(atom: la) end
          let rhs_for_infer = if is_semantic_string(t: sem_rhs) then TyString else atom_type(atom: ra) end
          let result_type = infer_binary_type(op, lhs_type: lhs_for_infer, rhs_type: rhs_for_infer)
          return bind_expr_to_temp(ctx: ctx3,
            expr: LirExprBinary(op, lhs: la, rhs: ra, typ: result_type),
            typ: result_type)
        end
      end

    | MirCall(func: f, args, ret_type: rt) ->
      match lir_lower_call_args(args, ctx) do | LowerCallArgsResult(ctx: ctx2, lir_args: la) ->
        let wt = wasm_type(typ: rt)
        return bind_expr_to_temp_semantic(ctx: ctx2,
          expr: LirExprCall(func: f, args: la, typ: wt),
          typ: wt, semantic_type: rt)
      end

    | MirConstructor(name: n, args) ->
      match lower_exprs_to_atoms(exprs: args, ctx) do | LowerExprsResult(ctx: ctx2, atoms) ->
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprConstructor(name: n, args: atoms, typ: TyI64),
          typ: TyI64)
      end

    | MirRecord(fields) ->
      match lir_lower_named_exprs(fields, ctx) do | LowerNamedExprsResult(ctx: ctx2, atoms: named_atoms) ->
        // Sort fields alphabetically by name (matching Rust compiler layout)
        let sorted_atoms = sort_lir_named_atoms(atoms: named_atoms)
        let sem_type = build_record_semantic_type(atoms: sorted_atoms, ctx: ctx2)
        return bind_expr_to_temp_semantic(ctx: ctx2,
          expr: LirExprRecord(fields: sorted_atoms, typ: TyI64),
          typ: TyI64, semantic_type: sem_type)
      end

    | MirFieldAccess(target: recv, field) ->
      match lower_expr_to_atom(expr: recv, ctx) do | BindResult(ctx: ctx2, atom: obj_atom) ->
        let FieldResolution(index: idx, typ: ft) = resolve_record_field(atom: obj_atom, field, ctx: ctx2)
        let wt = wasm_type(typ: ft)
        return bind_expr_to_temp_semantic(ctx: ctx2,
          expr: LirExprObjectField(value: obj_atom, index: idx, typ: wt),
          typ: wt, semantic_type: ft)
      end

    | MirBorrow(name: n) ->
      match ctx do | LowerCtx(vars: v, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: _) ->
        let typ = match lir_lookup_type(name: n, entries: v) do
          | Some(val: t) -> t
          | None -> TyI64
        end
        return BindResult(ctx, atom: LirAtomVar(name: n, typ))
      end

    | MirRaise(expr: e) ->
      match lower_expr_to_atom(expr: e, ctx) do | BindResult(ctx: ctx2, atom: a) ->
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprRaise(value: a, typ: TyUnit),
          typ: TyUnit)
      end

    | MirForce(expr: e) ->
      match lower_expr_to_atom(expr: e, ctx) do | BindResult(ctx: ctx2, atom: a) ->
        let inner_typ = match atom_type(atom: a) do
          | TyLazy(inner: t) -> t
          | other -> other
        end
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprForce(value: a, typ: inner_typ),
          typ: inner_typ)
      end

    | MirIf(cond, then_body: tb, else_body: eb) ->
      return lower_if_expr(cond, then_body: tb, else_body: eb, ctx)

    | MirMatch(target: tgt, cases: cs) ->
      return lower_match_expr(target: tgt, cases: cs, ctx)

    | MirWhile(_) ->
      // While loops not valid in expression position
      return BindResult(ctx, atom: LirAtomUnit)

    | MirArray(elems) ->
      match lower_exprs_to_atoms(exprs: elems, ctx) do | LowerExprsResult(ctx: ctx2, atoms) ->
        // Encode array as record with numeric indices
        let named = number_atoms(atoms, idx: 0)
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprRecord(fields: named, typ: TyI64),
          typ: TyI64)
      end

    | MirIndex(target: arr, index: idx) ->
      match lower_expr_to_atom(expr: arr, ctx) do | BindResult(ctx: ctx2, atom: arr_atom) ->
        match lower_expr_to_atom(expr: idx, ctx: ctx2) do | BindResult(ctx: ctx3, atom: idx_atom) ->
          return bind_expr_to_temp(ctx: ctx3,
            expr: LirExprCall(func: "__array_get",
              args: [LirCallArg(label: "arr", value: arr_atom), LirCallArg(label: "idx", value: idx_atom)],
              typ: TyI64),
            typ: TyI64)
        end
      end

    | MirMakeClosure(func_name: name, captures: caps) ->
      match lower_exprs_to_atoms(exprs: caps, ctx) do | LowerExprsResult(ctx: ctx2, atoms: cap_atoms) ->
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprMakeClosure(func_name: name, captures: cap_atoms, typ: TyI64),
          typ: TyI64)
      end

    | MirCallClosure(closure: clos, args: cargs, ret_type: rt) ->
      match lower_expr_to_atom(expr: clos, ctx) do | BindResult(ctx: ctx2, atom: clos_atom) ->
        match lir_lower_call_args(args: cargs, ctx: ctx2) do | LowerCallArgsResult(ctx: ctx3, lir_args) ->
          // HIR→MIR sets ret_type to a TyI64 placeholder for variable-call sites.
          // Recover the real return type from the callee variable's TyArrow in
          // semantic_vars (populated per-function from each param's declared type).
          let actual_rt = resolve_closure_ret_type(clos, fallback: rt, ctx: ctx3)
          let wt = wasm_type(typ: actual_rt)
          return bind_expr_to_temp_semantic(ctx: ctx3,
            expr: LirExprCallClosure(closure: clos_atom, args: lir_args, typ: wt),
            typ: wt, semantic_type: actual_rt)
        end
      end

    | MirEnvLoad(env_var: env, index: idx) ->
      return bind_expr_to_temp(ctx,
        expr: LirExprObjectField(value: LirAtomVar(name: env, typ: TyI64), index: idx, typ: TyI64),
        typ: TyI64)

    | MirSuspend(tag_name: tn, payload: p, ret_type: rt) ->
      match lower_expr_to_atom(expr: p, ctx) do | BindResult(ctx: ctx2, atom: pa) ->
        let wt = wasm_type(typ: rt)
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprSuspend(tag_name: tn, payload: pa, typ: wt),
          typ: wt)
      end

    | MirResume(cont_var: cv, value: v, ret_type: rt) ->
      match lower_expr_to_atom(expr: v, ctx) do | BindResult(ctx: ctx2, atom: va) ->
        let wt = wasm_type(typ: rt)
        let cont_atom = LirAtomVar(name: cv, typ: TyI64)
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprResume(cont: cont_atom, value: va, typ: wt),
          typ: wt)
      end
  end
end

// ─── Helper: Number atoms for array encoding ─────────────────────────────────

let number_atoms = fn (atoms: [LirAtom], idx: i64) -> [LirNamedAtom] throws { Exn } do
  return number_atoms_go(atoms, idx, acc: [])
end

let number_atoms_go = fn (atoms: [LirAtom], idx: i64, acc: [LirNamedAtom]) -> [LirNamedAtom] throws { Exn } do
  match atoms do
    | [] -> return rev_lir_named_atoms(lst: acc, out: [])
    | a :: rest ->
      return number_atoms_go(atoms: rest, idx: idx + 1, acc: LirNamedAtom(name: str.from_i64(val: idx), value: a) :: acc)
  end
end

// ─── Helper: Lower Call Args ─────────────────────────────────────────────────

type LowerCallArgsResult = LowerCallArgsResult(ctx: LowerCtx, lir_args: [LirCallArg])

let lir_lower_call_args_inner = fn (args: [MirCallArg], ctx: LowerCtx) -> LowerCallArgsResult throws { Exn } do
  return lir_lower_call_args_inner_go(args, ctx, acc: [])
end

let lir_lower_call_args_inner_go = fn (args: [MirCallArg], ctx: LowerCtx, acc: [LirCallArg]) -> LowerCallArgsResult throws { Exn } do
  match args do
    | [] -> return LowerCallArgsResult(ctx, lir_args: rev_lir_call_args(lst: acc, out: []))
    | MirCallArg(label: l, value: e) :: rest ->
      match lower_expr_to_atom(expr: e, ctx) do | BindResult(ctx: ctx2, atom: a) ->
        return lir_lower_call_args_inner_go(args: rest, ctx: ctx2, acc: LirCallArg(label: l, value: a) :: acc)
      end
  end
end

let lir_lower_call_args = fn (args: [MirCallArg], ctx: LowerCtx) -> LowerCallArgsResult throws { Exn } do
  // Lower args in source order (preserving side-effect evaluation), then sort by label
  match lir_lower_call_args_inner(args, ctx) do
    | LowerCallArgsResult(ctx: c, lir_args: la) ->
      return LowerCallArgsResult(ctx: c, lir_args: sort_lir_call_args(args: la))
  end
end

// ─── Helper: Lower Multiple Exprs ────────────────────────────────────────────

type LowerExprsResult = LowerExprsResult(ctx: LowerCtx, atoms: [LirAtom])

let lower_exprs_to_atoms = fn (exprs: [MirExpr], ctx: LowerCtx) -> LowerExprsResult throws { Exn } do
  return lower_exprs_to_atoms_go(exprs, ctx, acc: [])
end

let lower_exprs_to_atoms_go = fn (exprs: [MirExpr], ctx: LowerCtx, acc: [LirAtom]) -> LowerExprsResult throws { Exn } do
  match exprs do
    | [] -> return LowerExprsResult(ctx, atoms: lir_reverse_atoms(lst: acc, acc: []))
    | e :: rest ->
      match lower_expr_to_atom(expr: e, ctx) do | BindResult(ctx: ctx2, atom: a) ->
        return lower_exprs_to_atoms_go(exprs: rest, ctx: ctx2, acc: a :: acc)
      end
  end
end

// ─── Helper: Lower Named Exprs ───────────────────────────────────────────────

type LowerNamedExprsResult = LowerNamedExprsResult(ctx: LowerCtx, atoms: [LirNamedAtom])

let lir_lower_named_exprs = fn (fields: [MirNamedExpr], ctx: LowerCtx) -> LowerNamedExprsResult throws { Exn } do
  return lir_lower_named_exprs_go(fields, ctx, acc: [])
end

let lir_lower_named_exprs_go = fn (fields: [MirNamedExpr], ctx: LowerCtx, acc: [LirNamedAtom]) -> LowerNamedExprsResult throws { Exn } do
  match fields do
    | [] -> return LowerNamedExprsResult(ctx, atoms: rev_lir_named_atoms(lst: acc, out: []))
    | MirNamedExpr(name: n, value: e) :: rest ->
      match lower_expr_to_atom(expr: e, ctx) do | BindResult(ctx: ctx2, atom: a) ->
        return lir_lower_named_exprs_go(fields: rest, ctx: ctx2, acc: LirNamedAtom(name: n, value: a) :: acc)
      end
  end
end

// ─── If Expression Lowering ──────────────────────────────────────────────────

let lower_if_expr = fn (cond: MirExpr, then_body: [MirStmt], else_body: Option<[MirStmt]>, ctx: LowerCtx) -> BindResult throws { Exn } do
  match lower_expr_to_atom(expr: cond, ctx) do | BindResult(ctx: ctx2, atom: cond_atom) ->
    let sem_type = infer_stmts_type(stmts: then_body, ctx: ctx2)
    let result_type = wasm_type(typ: sem_type)
    match new_temp(ctx: ctx2) do | TempResult(ctx: LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed), name: result_name) ->
      // Register result variable
      let ctx4 = LowerCtx(
        vars: insert_type(name: result_name, typ: result_type, entries: v),
        semantic_vars: insert_type(name: result_name, typ: sem_type, entries: sv),
        stmts: LirStmtLet(name: result_name, typ: result_type,
                       expr: LirExprAtom(atom: default_atom(typ: result_type))) :: s,
        temp_counter: c,
        enum_defs: ed
      )
      // Lower then branch
      match lower_branch_for_value(body: then_body, result_name,
                                    result_type, ctx: ctx4) do | BranchResult(ctx: ctx5, stmts: then_stmts) ->
        // Lower else branch
        let else_r = match else_body do
          | Some(val: eb) -> lower_branch_for_value(body: eb, result_name,
                                                        result_type, ctx: ctx5)
          | None -> BranchResult(ctx: ctx5, stmts: [])
        end
        match else_r do | BranchResult(ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: s2, temp_counter: c2, enum_defs: ed2), stmts: else_stmts) ->
          // Add the if statement
          let ctx7 = LowerCtx(
            vars: v2, semantic_vars: sv2,
            stmts: LirStmtIf(cond: cond_atom, then_body: then_stmts, else_body: else_stmts) :: s2,
            temp_counter: c2, enum_defs: ed2
          )
          return BindResult(ctx: ctx7, atom: LirAtomVar(name: result_name, typ: result_type))
        end
      end
    end
  end
end

// ─── Branch Value Extraction ─────────────────────────────────────────────────

type BranchResult = BranchResult(ctx: LowerCtx, stmts: [LirStmt])

let lower_branch_for_value = fn (body: [MirStmt], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> BranchResult throws { Exn } do
  // Save current statements, lower branch in isolation
  match ctx do | LowerCtx(vars: v, semantic_vars: sv, stmts: saved_stmts, temp_counter: c, enum_defs: ed) ->
    let branch_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lower_branch_body(body, result_name, result_type, ctx: branch_ctx) do | BranchBodyResult(ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: branch_stmts, temp_counter: c2, enum_defs: _), value_opt: val_opt) ->
      // Assign value if present
      let final_stmts = match val_opt do
        | Some(val: atom) ->
          LirStmtLet(name: result_name, typ: result_type,
                             expr: LirExprAtom(atom)) :: branch_stmts
        | None -> branch_stmts
      end
      // Restore outer context with updated temp counter
      let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved_stmts, temp_counter: c2, enum_defs: ed)
      return BranchResult(ctx: restored, stmts: reverse_stmts(stmts: final_stmts))
    end
  end
end

type BranchBodyResult = BranchBodyResult(ctx: LowerCtx, value_opt: Option<LirAtom>)

// Look up the enclosing function's wasm return type. `lir_lower_function`
// stores it under the sentinel name "#FN_RET#" in semantic_vars at function
// entry — `#` is not a valid identifier character so there is no collision
// with user names.
let lir_get_fn_ret_type = fn (ctx: LowerCtx) -> TypeExpr throws { Exn } do
  match ctx do | LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
    match lir_lookup_type(name: "#FN_RET#", entries: sv) do
      | Some(val: t) -> return t
      | None -> return TyUnit
    end
  end
end

// Emit a function-level return for `return e` inside a match-as-expression
// branch. Per spec (semantics.md:126): arms containing `return` diverge and
// do not contribute to the unified match result — so value_opt is None.
//
// For `return f(args)`, produce a LirExprTailCall whose codegen emits
// `return_call` (self-terminating). For any other expression, emit the atom
// and wrap in LirStmtIfReturn(cond: true, ...) which codegens as an
// unconditional op_return.
let emit_diverging_return = fn (expr: MirExpr, ctx: LowerCtx) -> BranchBodyResult throws { Exn } do
  let ret_type = lir_get_fn_ret_type(ctx)
  if let MirCall(func: f, args, ret_type: rt) = expr then
    match lir_lower_call_args(args, ctx) do | LowerCallArgsResult(ctx: ctx2, lir_args: la) ->
      let wt = wasm_type(typ: rt)
      match bind_expr_to_temp(ctx: ctx2, expr: LirExprTailCall(func: f, args: la, typ: wt), typ: wt) do | BindResult(ctx: ctx3, atom: _) ->
        return BranchBodyResult(ctx: ctx3, value_opt: None)
      end
    end
  else
    match lower_expr_to_atom(expr, ctx) do | BindResult(ctx: ctx2, atom: a) ->
      match ctx2 do | LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
        let ret_stmt = LirStmtIfReturn(
          cond: LirAtomBool(val: true),
          then_body: [], then_ret: a,
          else_body: [], else_ret: None,
          ret_type: ret_type
        )
        let ctx3 = LowerCtx(vars: v, semantic_vars: sv, stmts: ret_stmt :: s, temp_counter: c, enum_defs: ed)
        return BranchBodyResult(ctx: ctx3, value_opt: None)
      end
    end
  end
end

let lower_branch_body = fn (body: [MirStmt], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> BranchBodyResult throws { Exn } do
  match body do
    | [] -> return BranchBodyResult(ctx, value_opt: None)
    | [last] ->
      match last do
        | MirStmtExpr(expr: e) ->
          match lower_expr_to_atom(expr: e, ctx) do | BindResult(ctx: ctx2, atom: a) ->
            return BranchBodyResult(ctx: ctx2, value_opt: Some(val: a))
          end
        | MirStmtReturn(expr: e) ->
          return emit_diverging_return(expr: e, ctx)
        | _ ->
          match lower_stmt_inner(stmt: last, ret_type: TyUnit, ctx) do | LowerStmtResult(ctx: ctx2, ret: _) ->
            return BranchBodyResult(ctx: ctx2, value_opt: None)
          end
      end
    | s :: rest ->
      match s do
        | MirStmtReturn(expr: e) ->
          return emit_diverging_return(expr: e, ctx)
        | _ ->
          match lower_stmt_inner(stmt: s, ret_type: TyUnit, ctx) do | LowerStmtResult(ctx: ctx2, ret: _) ->
            return lower_branch_body(body: rest, result_name, result_type, ctx: ctx2)
          end
      end
  end
end

// ─── Decision Tree Match Lowering ────────────────────────────────────────────

// Lower match expression using Maranget decision tree.
let lower_match_expr = fn (target: MirExpr, cases: [MirMatchCase], ctx: LowerCtx) -> BindResult throws { Exn } do
  match lower_expr_to_atom(expr: target, ctx) do | BindResult(ctx: ctx2, atom: target_atom) ->
    match cases do
      | [] -> return BindResult(ctx: ctx2, atom: LirAtomUnit)
      | _ ->
        let target_sem = lir_get_atom_sem_type(atom: target_atom, ctx: ctx2)
        // Infer result type from case bodies
        let sem_type = lir_infer_match_result_type(cases, ctx: ctx2)
        let result_type = wasm_type(typ: sem_type)
        match new_temp(ctx: ctx2) do | TempResult(ctx: ctx3, name: result_name) ->
          match ctx3 do | LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
            let ctx4 = LowerCtx(
              vars: insert_type(name: result_name, typ: result_type, entries: v),
              semantic_vars: insert_type(name: result_name, typ: sem_type, entries: sv),
              stmts: LirStmtLet(name: result_name, typ: result_type,
                             expr: LirExprAtom(atom: default_atom(typ: result_type))) :: s,
              temp_counter: c, enum_defs: ed
            )
            // Build pattern matrix and decision tree
            let rows = lir_cases_to_rows(cases, idx: 0)
            match lir_build_decision_tree(rows, col_ids: [0], next_id: 1, enum_defs: ed) do | DecTreeResult(tree, next_id: _) ->
              let atoms = [AtomEntry(id: 0, atom: target_atom, sem_type: target_sem)]
              match lir_emit_decision_tree_expr(tree, atoms, cases,
                  result_name, result_type, ctx: ctx4) do | EmitExprResult(ctx: ctx5, chain_stmts: chain) ->
                match ctx5 do | LowerCtx(vars: v5, semantic_vars: sv5, stmts: s5, temp_counter: c5, enum_defs: ed5) ->
                  let s6 = push_stmts_to_reverse(stmts: chain, acc: s5)
                  let ctx6 = LowerCtx(vars: v5, semantic_vars: sv5, stmts: s6, temp_counter: c5, enum_defs: ed5)
                  return BindResult(ctx: ctx6, atom: LirAtomVar(name: result_name, typ: result_type))
                end
              end
            end
          end
        end
    end
  end
end

let lir_get_atom_sem_type = fn (atom: LirAtom, ctx: LowerCtx) -> TypeExpr throws { Exn } do
  if let LirAtomVar(name: n, typ: t) = atom then
    match ctx do | LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
      match lir_lookup_type(name: n, entries: sv) do
        | Some(val: st) -> return st
        | None -> return t
      end
    end
  else
    return atom_type(atom)
  end
end

let lir_infer_match_result_type = fn (cases: [MirMatchCase], ctx: LowerCtx) -> TypeExpr throws { Exn } do
  match cases do
    | [] -> return TyUnit
    | MirMatchCase(pattern: _, body) :: rest ->
      match body do
        | [] -> return lir_infer_match_result_type(cases: rest, ctx)
        | _ ->
          let t = infer_semantic_type(expr: lir_last_mir_expr(body), ctx)
          match t do
            | TyUnit -> return lir_infer_match_result_type(cases: rest, ctx)
            | _ -> return t
          end
      end
  end
end

let lir_last_mir_expr = fn (body: [MirStmt]) -> MirExpr throws { Exn } do
  match body do
    | [] -> return MirLiteral(lit: LitUnit)
    | [MirStmtExpr(expr: e)] -> return e
    | [MirStmtReturn(expr: e)] -> return e
    | _ :: rest -> return lir_last_mir_expr(body: rest)
  end
end

// ─── Decision Tree Emission (Expr Mode) ─────────────────────────────────────

type EmitExprResult = EmitExprResult(ctx: LowerCtx, chain_stmts: [LirStmt])

let lir_emit_decision_tree_expr = fn (tree: DecTree, atoms: [AtomEntry], cases: [MirMatchCase],
    result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult throws { Exn } do
  match tree do
    | DecFail -> return EmitExprResult(ctx, chain_stmts: [])
    | DecLeaf(case_idx: ci, bindings: bs) ->
      return lir_emit_leaf_expr(case_idx: ci, bindings: bs, atoms, cases,
                                  result_name, result_type, ctx)
    | DecCtorSwitch(scrutinee_id: sid, branches, fallback: fb) ->
      return lir_emit_ctor_switch_expr(scrutinee_id: sid, branches, fallback: fb,
        atoms, cases, result_name, result_type, ctx)
    | DecLitSwitch(scrutinee_id: sid, branches, fallback: fb) ->
      return lir_emit_lit_switch_expr(scrutinee_id: sid, branches, fallback: fb,
        atoms, cases, result_name, result_type, ctx)
    | DecRecordDestructure(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st) ->
      return lir_emit_record_expr(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st,
        atoms, cases, result_name, result_type, ctx)
  end
end

let lir_emit_leaf_expr = fn (case_idx: i64, bindings: [PatBinding], atoms: [AtomEntry],
    cases: [MirMatchCase], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult throws { Exn } do
  let case_body = lir_nth_case_body(cases, idx: case_idx)
  // Emit bindings in isolation (matching lir_emit_leaf_stmt) to prevent
  // accumulated stmts from ctx leaking into branch chain_stmts.
  match ctx do | LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
    let bind_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
    match lir_emit_bindings(bindings, atoms, ctx: bind_ctx) do | LowerCtx(vars: v2, semantic_vars: sv2, stmts: bind_stmts, temp_counter: c2, enum_defs: _) ->
      let body_ctx = LowerCtx(vars: v2, semantic_vars: sv2, stmts: [], temp_counter: c2, enum_defs: ed0)
      match lower_branch_body(body: case_body, result_name, result_type, ctx: body_ctx) do | BranchBodyResult(ctx: ctx3, value_opt: val_opt) ->
        match ctx3 do | LowerCtx(vars: _, semantic_vars: _, stmts: raw_body_stmts, temp_counter: c3, enum_defs: _) ->
          let restored_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c3, enum_defs: ed0)
          let leaf_stmts = append_stmts(stmts: reverse_stmts(stmts: bind_stmts), tail: reverse_stmts(stmts: raw_body_stmts))
          let final_stmts = match val_opt do
            | Some(val: va) ->
              append_stmts(stmts: leaf_stmts, tail: [LirStmtLet(name: result_name, typ: result_type, expr: LirExprAtom(atom: va))])
            | None -> leaf_stmts
          end
          return EmitExprResult(ctx: restored_ctx, chain_stmts: final_stmts)
        end
      end
    end
  end
end

let lir_emit_ctor_switch_expr = fn (scrutinee_id: i64, branches: [CtorBranch], fallback: Option<DecTree>,
    atoms: [AtomEntry], cases: [MirMatchCase], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult throws { Exn } do
  match lookup_atom_entry(id: scrutinee_id, atoms) do | AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    // Extract tag + conditions in isolation to avoid duplicating existing stmts.
    match ctx do | LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
      let iso_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
      match bind_expr_to_temp(ctx: iso_ctx, expr: LirExprObjectTag(value: scr_atom, typ: TyI64), typ: TyI64) do | BindResult(ctx: ctx2, atom: tag_atom) ->
      let has_fb = if let Some(_) = fallback then true else false end
      match lir_emit_ctor_conds(branches, tag_atom, has_fb, pos: 0, total: lir_ctors_length(lst: branches), ctx: ctx2) do | CtorCondsResult(ctx: ctx3, conds) ->
        match ctx3 do | LowerCtx(vars: _, semantic_vars: _, stmts: cond_stmts, temp_counter: c3, enum_defs: _) ->
            let base_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c3, enum_defs: ed0)
            // Build chain: start with fallback
            match lir_emit_fb_expr(fallback, atoms, cases,
                result_name, result_type, ctx: base_ctx) do | EmitExprResult(ctx: ctx4, chain_stmts: chain_else) ->
              // Process branches in reverse
              let rev_branches = lir_reverse_ctors(lst: branches, acc: [])
              let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
              match lir_build_expr_chain(branches: rev_branches, conds: rev_conds, scr_atom,
                  scr_sem, atoms, cases, result_name,
                  result_type, chain_else, ctx: ctx4) do | EmitExprResult(ctx: ctx5, chain_stmts: final_chain) ->
                // Prepend cond stmts
                let all_stmts = append_stmts(stmts: reverse_stmts(stmts: cond_stmts), tail: final_chain)
                return EmitExprResult(ctx: ctx5, chain_stmts: all_stmts)
              end
            end
          end
        end
      end
    end
  end
end


let lir_emit_fb_expr = fn (fallback: Option<DecTree>, atoms: [AtomEntry], cases: [MirMatchCase],
    result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult throws { Exn } do
  match fallback do
    | None -> return EmitExprResult(ctx, chain_stmts: [])
    | Some(val: fb) ->
      return lir_emit_decision_tree_expr(tree: fb, atoms, cases,
        result_name, result_type, ctx)
  end
end

let lir_build_expr_chain = fn (branches: [CtorBranch], conds: [LirAtom], scr_atom: LirAtom,
    scr_sem: TypeExpr, atoms: [AtomEntry], cases: [MirMatchCase], result_name: string,
    result_type: TypeExpr, chain_else: [LirStmt], ctx: LowerCtx) -> EmitExprResult throws { Exn } do
  match branches do
    | [] -> return EmitExprResult(ctx, chain_stmts: chain_else)
    | CtorBranch(ctor_name: cn, ctor_tag: _, arity: ar, field_ids: fids, subtree: st) :: rest_b ->
      match conds do
        | [] -> return EmitExprResult(ctx, chain_stmts: chain_else)
        | cond :: rest_c ->
        // Extract fields and emit subtree
        match lir_extract_ctor_fields(scr_atom, scr_sem, ctor_name: cn,
            arity: ar, field_ids: fids, atoms, ctx) do | FieldExtractResult(ctx: ctx2, atoms: atoms2, field_stmts: fstmts) ->
          match lir_emit_decision_tree_expr(tree: st, atoms: atoms2, cases,
              result_name, result_type, ctx: ctx2) do | EmitExprResult(ctx: ctx3, chain_stmts: sub_stmts) ->
            let then_body = append_stmts(stmts: fstmts, tail: sub_stmts)
            let if_stmt = LirStmtIf(cond, then_body, else_body: chain_else)
            return lir_build_expr_chain(branches: rest_b, conds: rest_c, scr_atom,
              scr_sem, atoms, cases, result_name,
              result_type, chain_else: [if_stmt], ctx: ctx3)
          end
        end
      end
  end
end



let lir_emit_lit_switch_expr = fn (scrutinee_id: i64, branches: [LitBranch], fallback: DecTree,
    atoms: [AtomEntry], cases: [MirMatchCase], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult throws { Exn } do
  match lookup_atom_entry(id: scrutinee_id, atoms) do | AtomEntry(id: _, atom: scr_atom, sem_type: _) ->
    // Pre-compute conditions in isolation to avoid duplicating existing stmts.
    match ctx do | LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
      let iso_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
      match lir_emit_lit_conds(branches, scr_atom, ctx: iso_ctx) do | LitCondsResult(ctx: ctx2, conds) ->
      match ctx2 do | LowerCtx(vars: _, semantic_vars: _, stmts: cond_stmts, temp_counter: c2, enum_defs: _) ->
          let base_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c2, enum_defs: ed0)
          // Start with fallback
          match lir_emit_decision_tree_expr(tree: fallback, atoms, cases,
              result_name, result_type, ctx: base_ctx) do | EmitExprResult(ctx: ctx3, chain_stmts: chain_else) ->
            let rev_branches = lir_reverse_lit_branches(lst: branches, acc: [])
            let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
            match lir_build_lit_expr_chain(branches: rev_branches, conds: rev_conds, atoms,
                cases, result_name, result_type,
                chain_else, ctx: ctx3) do | EmitExprResult(ctx: ctx4, chain_stmts: final_chain) ->
              let all_stmts = append_stmts(stmts: reverse_stmts(stmts: cond_stmts), tail: final_chain)
              return EmitExprResult(ctx: ctx4, chain_stmts: all_stmts)
            end
          end
        end
      end
    end
  end
end


let lir_build_lit_expr_chain = fn (branches: [LitBranch], conds: [LirAtom], atoms: [AtomEntry],
    cases: [MirMatchCase], result_name: string, result_type: TypeExpr,
    chain_else: [LirStmt], ctx: LowerCtx) -> EmitExprResult throws { Exn } do
  match branches do
    | [] -> return EmitExprResult(ctx, chain_stmts: chain_else)
    | LitBranch(lit: _, subtree: st) :: rest_b ->
      match conds do
        | [] -> return EmitExprResult(ctx, chain_stmts: chain_else)
        | cond :: rest_c ->
        match lir_emit_decision_tree_expr(tree: st, atoms, cases,
            result_name, result_type, ctx) do | EmitExprResult(ctx: ctx2, chain_stmts: sub_stmts) ->
          let if_stmt = LirStmtIf(cond, then_body: sub_stmts, else_body: chain_else)
          return lir_build_lit_expr_chain(branches: rest_b, conds: rest_c, atoms,
            cases, result_name, result_type,
            chain_else: [if_stmt], ctx: ctx2)
        end
      end
  end
end

let lir_emit_record_expr = fn (scrutinee_id: i64, field_names: [string], field_ids: [i64],
    subtree: DecTree, atoms: [AtomEntry], cases: [MirMatchCase],
    result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult throws { Exn } do
  match lookup_atom_entry(id: scrutinee_id, atoms) do | AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    match lir_extract_record_fields(scr_atom, scr_sem,
        field_names, field_ids, atoms, ctx) do | FieldExtractResult(ctx: ctx2, atoms: atoms2, field_stmts: fstmts) ->
      match lir_emit_decision_tree_expr(tree: subtree, atoms: atoms2, cases,
          result_name, result_type, ctx: ctx2) do | EmitExprResult(ctx: ctx3, chain_stmts: sub_stmts) ->
        return EmitExprResult(ctx: ctx3, chain_stmts: append_stmts(stmts: fstmts, tail: sub_stmts))
      end
    end
  end
end





// ─── Decision Tree Emission (Stmt Mode) ─────────────────────────────────────

type EmitStmtResult = EmitStmtResult(ctx: LowerCtx, chain_stmts: [LirStmt])

let lir_emit_decision_tree_stmt = fn (tree: DecTree, atoms: [AtomEntry], cases: [MirMatchCase],
    ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult throws { Exn } do
  match tree do
    | DecFail -> return EmitStmtResult(ctx, chain_stmts: [])
    | DecLeaf(case_idx: ci, bindings: bs) ->
      return lir_emit_leaf_stmt(case_idx: ci, bindings: bs, atoms, cases,
                                  ret_type, ctx)
    | DecCtorSwitch(scrutinee_id: sid, branches, fallback: fb) ->
      return lir_emit_ctor_switch_stmt(scrutinee_id: sid, branches, fallback: fb,
        atoms, cases, ret_type, ctx)
    | DecLitSwitch(scrutinee_id: sid, branches, fallback: fb) ->
      return lir_emit_lit_switch_stmt(scrutinee_id: sid, branches, fallback: fb,
        atoms, cases, ret_type, ctx)
    | DecRecordDestructure(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st) ->
      return lir_emit_record_stmt(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st,
        atoms, cases, ret_type, ctx)
  end
end

let lir_emit_leaf_stmt = fn (case_idx: i64, bindings: [PatBinding], atoms: [AtomEntry],
    cases: [MirMatchCase], ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult throws { Exn } do
  let case_body = lir_nth_case_body(cases, idx: case_idx)
  // Emit bindings in isolation so they go into chain_stmts (inside the branch),
  // not ctx.stmts (outside the branch). Otherwise, bindings like
  // "Let result = _field_atom" leak before the if-chain, reading uninitialized locals.
  match ctx do | LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
    let bind_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
    match lir_emit_bindings(bindings, atoms, ctx: bind_ctx) do | LowerCtx(vars: v2, semantic_vars: sv2, stmts: bind_stmts, temp_counter: c2, enum_defs: _) ->
      let block_ctx = LowerCtx(vars: v2, semantic_vars: sv2, stmts: s0, temp_counter: c2, enum_defs: ed0)
      match lower_case_body(stmts: case_body, ret_type, ctx: block_ctx) do | BlockResult(ctx: ctx3, stmts: body_stmts, ret: case_ret) ->
        let full_body = append_stmts(stmts: reverse_stmts(stmts: bind_stmts), tail: body_stmts)
        let is_trivial = is_trivially_unit_body(stmts: case_body)
        let genuine_ret = match case_ret do
          | Some(_) -> case_ret
          | None -> fallback_ret_from_last_stmt(stmts: full_body)
        end
        match genuine_ret do
          | Some(val: a) ->
            let stmt = LirStmtIfReturn(cond: LirAtomBool(val: true), then_body: full_body,
              then_ret: a, else_body: [], else_ret: None, ret_type)
            return EmitStmtResult(ctx: ctx3, chain_stmts: [stmt])
          | None ->
            return EmitStmtResult(ctx: ctx3, chain_stmts: full_body)
        end
      end
    end
  end
end

let lir_emit_ctor_switch_stmt = fn (scrutinee_id: i64, branches: [CtorBranch], fallback: Option<DecTree>,
    atoms: [AtomEntry], cases: [MirMatchCase], ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult throws { Exn } do
  match lookup_atom_entry(id: scrutinee_id, atoms) do | AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    // Extract tag + conditions in isolation (empty stmts) to avoid duplicating
    // the target call stmts that are already in ctx.stmts.
    match ctx do | LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
      let iso_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
      match bind_expr_to_temp(ctx: iso_ctx, expr: LirExprObjectTag(value: scr_atom, typ: TyI64), typ: TyI64) do | BindResult(ctx: ctx2, atom: tag_atom) ->
      let has_fb = if let Some(_) = fallback then true else false end
      match lir_emit_ctor_conds(branches, tag_atom, has_fb, pos: 0, total: lir_ctors_length(lst: branches), ctx: ctx2) do | CtorCondsResult(ctx: ctx3, conds) ->
        match ctx3 do | LowerCtx(vars: _, semantic_vars: _, stmts: cond_stmts, temp_counter: c3, enum_defs: _) ->
            let base_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c3, enum_defs: ed0)
            match lir_emit_fb_stmt(fallback, atoms, cases,
                ret_type, ctx: base_ctx) do | EmitStmtResult(ctx: ctx4, chain_stmts: chain_else) ->
              let rev_branches = lir_reverse_ctors(lst: branches, acc: [])
              let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
              match lir_build_stmt_chain(branches: rev_branches, conds: rev_conds, scr_atom,
                  scr_sem, atoms, cases, ret_type,
                  chain_else, ctx: ctx4) do | EmitStmtResult(ctx: ctx5, chain_stmts: final_chain) ->
                let all_stmts = append_stmts(stmts: reverse_stmts(stmts: cond_stmts), tail: final_chain)
                return EmitStmtResult(ctx: ctx5, chain_stmts: all_stmts)
              end
            end
          end
        end
      end
    end
  end
end

let lir_emit_fb_stmt = fn (fallback: Option<DecTree>, atoms: [AtomEntry], cases: [MirMatchCase],
    ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult throws { Exn } do
  match fallback do
    | None -> return EmitStmtResult(ctx, chain_stmts: [])
    | Some(val: fb) ->
      return lir_emit_decision_tree_stmt(tree: fb, atoms, cases, ret_type, ctx)
  end
end

let lir_build_stmt_chain = fn (branches: [CtorBranch], conds: [LirAtom], scr_atom: LirAtom,
    scr_sem: TypeExpr, atoms: [AtomEntry], cases: [MirMatchCase], ret_type: TypeExpr,
    chain_else: [LirStmt], ctx: LowerCtx) -> EmitStmtResult throws { Exn } do
  match branches do
    | [] -> return EmitStmtResult(ctx, chain_stmts: chain_else)
    | CtorBranch(ctor_name: cn, ctor_tag: _, arity: ar, field_ids: fids, subtree: st) :: rest_b ->
      match conds do
        | [] -> return EmitStmtResult(ctx, chain_stmts: chain_else)
        | cond :: rest_c ->
        match lir_extract_ctor_fields(scr_atom, scr_sem, ctor_name: cn,
            arity: ar, field_ids: fids, atoms, ctx) do | FieldExtractResult(ctx: ctx2, atoms: atoms2, field_stmts: fstmts) ->
          match lir_emit_decision_tree_stmt(tree: st, atoms: atoms2, cases,
              ret_type, ctx: ctx2) do | EmitStmtResult(ctx: ctx3, chain_stmts: sub_stmts) ->
            let then_body = append_stmts(stmts: fstmts, tail: sub_stmts)
            let then_ret_opt = fallback_ret_from_last_stmt(stmts: then_body)
            match then_ret_opt do
              | Some(val: then_ret) ->
                let stmt = LirStmtIfReturn(cond, then_body, then_ret,
                  else_body: chain_else, else_ret: None, ret_type)
                return lir_build_stmt_chain(branches: rest_b, conds: rest_c, scr_atom,
                  scr_sem, atoms, cases, ret_type,
                  chain_else: [stmt], ctx: ctx3)
              | None ->
                let stmt = LirStmtIf(cond, then_body, else_body: chain_else)
                return lir_build_stmt_chain(branches: rest_b, conds: rest_c, scr_atom,
                  scr_sem, atoms, cases, ret_type,
                  chain_else: [stmt], ctx: ctx3)
            end
          end
        end
      end
  end
end

let lir_emit_lit_switch_stmt = fn (scrutinee_id: i64, branches: [LitBranch], fallback: DecTree,
    atoms: [AtomEntry], cases: [MirMatchCase], ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult throws { Exn } do
  match lookup_atom_entry(id: scrutinee_id, atoms) do | AtomEntry(id: _, atom: scr_atom, sem_type: _) ->
    match ctx do | LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
      let iso_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
      match lir_emit_lit_conds(branches, scr_atom, ctx: iso_ctx) do | LitCondsResult(ctx: ctx2, conds) ->
      match ctx2 do | LowerCtx(vars: _, semantic_vars: _, stmts: cond_stmts, temp_counter: c2, enum_defs: _) ->
          let base_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c2, enum_defs: ed0)
          match lir_emit_decision_tree_stmt(tree: fallback, atoms, cases,
              ret_type, ctx: base_ctx) do | EmitStmtResult(ctx: ctx3, chain_stmts: chain_else) ->
            let rev_branches = lir_reverse_lit_branches(lst: branches, acc: [])
            let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
            match lir_build_lit_stmt_chain(branches: rev_branches, conds: rev_conds, atoms,
                cases, ret_type, chain_else, ctx: ctx3) do | EmitStmtResult(ctx: ctx4, chain_stmts: final_chain) ->
              let all_stmts = append_stmts(stmts: reverse_stmts(stmts: cond_stmts), tail: final_chain)
              return EmitStmtResult(ctx: ctx4, chain_stmts: all_stmts)
            end
          end
        end
      end
    end
  end
end

let lir_build_lit_stmt_chain = fn (branches: [LitBranch], conds: [LirAtom], atoms: [AtomEntry],
    cases: [MirMatchCase], ret_type: TypeExpr, chain_else: [LirStmt], ctx: LowerCtx) -> EmitStmtResult throws { Exn } do
  match branches do
    | [] -> return EmitStmtResult(ctx, chain_stmts: chain_else)
    | LitBranch(lit: _, subtree: st) :: rest_b ->
      match conds do
        | [] -> return EmitStmtResult(ctx, chain_stmts: chain_else)
        | cond :: rest_c ->
        match lir_emit_decision_tree_stmt(tree: st, atoms, cases,
            ret_type, ctx) do | EmitStmtResult(ctx: ctx2, chain_stmts: sub_stmts) ->
          let then_ret_opt = fallback_ret_from_last_stmt(stmts: sub_stmts)
          match then_ret_opt do
            | Some(val: then_ret) ->
              let stmt = LirStmtIfReturn(cond, then_body: sub_stmts, then_ret,
                else_body: chain_else, else_ret: None, ret_type)
              return lir_build_lit_stmt_chain(branches: rest_b, conds: rest_c, atoms,
                cases, ret_type, chain_else: [stmt], ctx: ctx2)
            | None ->
              let stmt = LirStmtIf(cond, then_body: sub_stmts, else_body: chain_else)
              return lir_build_lit_stmt_chain(branches: rest_b, conds: rest_c, atoms,
                cases, ret_type, chain_else: [stmt], ctx: ctx2)
          end
        end
      end
  end
end

let lir_emit_record_stmt = fn (scrutinee_id: i64, field_names: [string], field_ids: [i64],
    subtree: DecTree, atoms: [AtomEntry], cases: [MirMatchCase],
    ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult throws { Exn } do
  match lookup_atom_entry(id: scrutinee_id, atoms) do | AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    match lir_extract_record_fields(scr_atom, scr_sem,
        field_names, field_ids, atoms, ctx) do | FieldExtractResult(ctx: ctx2, atoms: atoms2, field_stmts: fstmts) ->
      match lir_emit_decision_tree_stmt(tree: subtree, atoms: atoms2, cases,
          ret_type, ctx: ctx2) do | EmitStmtResult(ctx: ctx3, chain_stmts: sub_stmts) ->
        return EmitStmtResult(ctx: ctx3, chain_stmts: append_stmts(stmts: fstmts, tail: sub_stmts))
      end
    end
  end
end

// ─── Statement Lowering ──────────────────────────────────────────────────────

type LowerStmtResult = LowerStmtResult(ctx: LowerCtx, ret: Option<LirAtom>)

let lower_stmt_inner = fn (stmt: MirStmt, ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult throws { Exn } do
  match stmt do
    | MirStmtLet(name: n, typ: t, expr: e) ->
      let sem_type = infer_semantic_type(expr: e, ctx)
      match lower_expr_to_atom(expr: e, ctx) do | BindResult(ctx: ctx2, atom: a) ->
        let inferred = atom_type(atom: a)
        // Prefer semantic type from lowered atom if available
        let actual_sem = match a do
          | LirAtomVar(name: vn, typ: _) ->
            match ctx2 do | LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
              match lir_lookup_type(name: vn, entries: sv) do
                | Some(val: st) -> st
                | None -> sem_type
              end
            end
          | _ -> sem_type
        end
        match ctx2 do | LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
          let ctx3 = LowerCtx(
            vars: insert_type(name: n, typ: inferred, entries: v),
            semantic_vars: insert_type(name: n, typ: actual_sem, entries: sv),
            stmts: LirStmtLet(name: n, typ: inferred, expr: LirExprAtom(atom: a)) :: s,
            temp_counter: c, enum_defs: ed
          )
          return LowerStmtResult(ctx: ctx3, ret: None)
        end
      end

    | MirStmtExpr(expr: e) ->
      // Check for if/match/while at statement level
      match e do
        | MirIf(cond, then_body: tb, else_body: eb) ->
          return lower_if_stmt(cond, then_body: tb, else_body: eb, ret_type, ctx)
        | MirMatch(target: tgt, cases: cs) ->
          return lower_match_stmt(target: tgt, cases: cs, ret_type, ctx)
        | MirWhile(cond, body) ->
          return lower_while_stmt(cond, body, ctx)
        | _ ->
          match lower_expr_to_atom(expr: e, ctx) do | BindResult(ctx: ctx2, atom: _) ->
            return LowerStmtResult(ctx: ctx2, ret: None)
          end
      end

    | MirStmtReturn(expr: e) ->
      // Check for tail call optimization
      match e do
        | MirCall(func: f, args, ret_type: rt) ->
          match lir_lower_call_args(args, ctx) do | LowerCallArgsResult(ctx: ctx2, lir_args: la) ->
            let wt = wasm_type(typ: rt)
            match bind_expr_to_temp(ctx: ctx2,
              expr: LirExprTailCall(func: f, args: la, typ: wt), typ: wt) do | BindResult(ctx: ctx3, atom: a) ->
              return LowerStmtResult(ctx: ctx3, ret: Some(val: a))
            end
          end
        | _ ->
          match lower_expr_to_atom(expr: e, ctx) do | BindResult(ctx: ctx2, atom: a) ->
            return LowerStmtResult(ctx: ctx2, ret: Some(val: a))
          end
      end

    | MirStmtAssign(target: tgt, value: val) ->
      // ANF has no mutation — emit as Let re-binding
      match tgt do
        | MirVariable(name: n) ->
          match lower_expr_to_atom(expr: val, ctx) do | BindResult(ctx: ctx2, atom: a) ->
            match ctx2 do | LowerCtx(vars: vs, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
              let ctx3 = LowerCtx(
                vars: insert_type(name: n, typ: atom_type(atom: a), entries: vs),
                semantic_vars: sv,
                stmts: LirStmtLet(name: n, typ: atom_type(atom: a), expr: LirExprAtom(atom: a)) :: s,
                temp_counter: c, enum_defs: ed
              )
              return LowerStmtResult(ctx: ctx3, ret: None)
            end
          end
        | _ ->
          // Non-variable assign — just lower both sides
          match lower_expr_to_atom(expr: val, ctx) do | BindResult(ctx: ctx2, atom: _) ->
            return LowerStmtResult(ctx: ctx2, ret: None)
          end
      end

    | MirStmtTry(body, catch_param: cp, catch_body: cb) ->
      return lower_try_stmt(body, catch_param: cp, catch_body: cb, ret_type, ctx)

    | MirStmtInjectResume(body_fn: bfn, handler_arm_fns: arms, handler_arm_tags: arm_tags) ->
      // Lower the inject resume to a let-bound LirExprInjectResume so the
      // existing LirStmtLet → emit_stmt pipeline picks it up. Result type is
      // unit — codegen handles drop accordingly.
      match bind_expr_to_temp(ctx,
        expr: LirExprInjectResume(body_fn: bfn, arm_fns: arms, arm_tags, typ: TyUnit),
        typ: TyUnit) do | BindResult(ctx: ctx2, atom: _) ->
        return LowerStmtResult(ctx: ctx2, ret: None)
      end
  end
end

// ─── If Statement Lowering ───────────────────────────────────────────────────

let lower_if_stmt = fn (cond: MirExpr, then_body: [MirStmt], else_body: Option<[MirStmt]>, ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult throws { Exn } do
  match lower_expr_to_atom(expr: cond, ctx) do | BindResult(ctx: ctx2, atom: cond_atom) ->
    match lower_block(stmts: then_body, ret_type, ctx: ctx2) do | BlockResult(ctx: ctx3, stmts: then_stmts, ret: then_ret) ->
      match else_body do
        | Some(val: eb) ->
          match lower_block(stmts: eb, ret_type, ctx: ctx3) do | BlockResult(ctx: ctx4, stmts: else_stmts, ret: else_ret) ->
            match then_ret do
              | Some(_) ->
                match ctx4 do | LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
                  let then_ret_val = match then_ret do
                    | Some(val: a) -> a
                    | None -> default_atom(typ: ret_type)
                  end
                  let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                    stmts: LirStmtIfReturn(cond: cond_atom,
                      then_body: then_stmts, then_ret: then_ret_val,
                      else_body: else_stmts, else_ret,
                      ret_type) :: s,
                    temp_counter: c, enum_defs: ed)
                  return LowerStmtResult(ctx: ctx5, ret: None)
                end
              | None ->
                match else_ret do
                  | Some(_) ->
                    match ctx4 do | LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
                      let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                        stmts: LirStmtIfReturn(cond: cond_atom,
                          then_body: then_stmts, then_ret: default_atom(typ: ret_type),
                          else_body: else_stmts, else_ret,
                          ret_type) :: s,
                        temp_counter: c, enum_defs: ed)
                      return LowerStmtResult(ctx: ctx5, ret: None)
                    end
                  | None ->
                    match ctx4 do | LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
                      let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                        stmts: LirStmtIf(cond: cond_atom, then_body: then_stmts, else_body: else_stmts) :: s,
                        temp_counter: c, enum_defs: ed)
                      return LowerStmtResult(ctx: ctx5, ret: None)
                    end
                end
            end
          end
        | None ->
          match ctx3 do | LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
            match then_ret do
              | Some(val: tr) ->
                let ctx4 = LowerCtx(vars: v, semantic_vars: sv,
                  stmts: LirStmtIfReturn(cond: cond_atom,
                    then_body: then_stmts, then_ret: tr,
                    else_body: [], else_ret: None,
                    ret_type) :: s,
                  temp_counter: c, enum_defs: ed)
                return LowerStmtResult(ctx: ctx4, ret: None)
              | None ->
                let ctx4 = LowerCtx(vars: v, semantic_vars: sv,
                  stmts: LirStmtIf(cond: cond_atom, then_body: then_stmts, else_body: []) :: s,
                  temp_counter: c, enum_defs: ed)
                return LowerStmtResult(ctx: ctx4, ret: None)
            end
          end
      end
    end
  end
end

// ─── Match Statement Lowering ────────────────────────────────────────────────

// Check if a MIR statement list is trivially unit (empty or all unit literals).
// Such cases should fall through instead of returning from the function.
let is_trivially_unit_body = fn (stmts: [MirStmt]) -> bool throws { Exn } do
  match stmts do
    | [] -> return true
    | MirStmtExpr(expr: MirLiteral(lit: LitUnit)) :: rest ->
      return is_trivially_unit_body(stmts: rest)
    | _ -> return false
  end
end

// Lower match statement using Maranget decision tree.
let lower_match_stmt = fn (target: MirExpr, cases: [MirMatchCase], ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult throws { Exn } do
  match lower_expr_to_atom(expr: target, ctx) do | BindResult(ctx: ctx2, atom: target_atom) ->
    match cases do
      | [] -> return LowerStmtResult(ctx: ctx2, ret: None)
      | _ ->
        let target_sem = lir_get_atom_sem_type(atom: target_atom, ctx: ctx2)
        match ctx2 do | LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
          let rows = lir_cases_to_rows(cases, idx: 0)
          match lir_build_decision_tree(rows, col_ids: [0], next_id: 1, enum_defs: ed) do | DecTreeResult(tree, next_id: _) ->
            let atoms = [AtomEntry(id: 0, atom: target_atom, sem_type: target_sem)]
            match lir_emit_decision_tree_stmt(tree, atoms, cases,
                ret_type, ctx: ctx2) do | EmitStmtResult(ctx: ctx3, chain_stmts: chain) ->
              match ctx3 do | LowerCtx(vars: v3, semantic_vars: sv3, stmts: s3, temp_counter: c3, enum_defs: ed3) ->
                let s4 = push_stmts_to_reverse(stmts: chain, acc: s3)
                let ctx4 = LowerCtx(vars: v3, semantic_vars: sv3, stmts: s4, temp_counter: c3, enum_defs: ed3)
                return LowerStmtResult(ctx: ctx4, ret: None)
              end
            end
          end
        end
    end
  end
end

// ─── While Statement Lowering ────────────────────────────────────────────────

let lower_while_stmt = fn (cond: MirExpr, body: [MirStmt], ctx: LowerCtx) -> LowerStmtResult throws { Exn } do
  // Lower condition in isolation
  match ctx do | LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let cond_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lower_expr_to_atom(expr: cond, ctx: cond_ctx) do | BindResult(ctx: ctx2, atom: cond_atom) ->
      // Negate the condition (loop breaks when true)
      match bind_expr_to_temp(ctx: ctx2,
        expr: LirExprBinary(op: OpEq, lhs: cond_atom, rhs: LirAtomBool(val: false), typ: TyBool),
        typ: TyBool) do | BindResult(ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: cond_stmts, temp_counter: c2, enum_defs: _), atom: neg_cond) ->
        // Lower body
        let body_ctx = LowerCtx(vars: v2, semantic_vars: sv2, stmts: [], temp_counter: c2, enum_defs: ed)
        match lir_lower_stmts(stmts: body, ret_type: TyUnit, ctx: body_ctx) do | LowerStmtsResult(ctx: LowerCtx(vars: _, semantic_vars: _, stmts: body_stmts, temp_counter: c3, enum_defs: _), ret: _) ->
          let final_ctx = LowerCtx(vars: v, semantic_vars: sv,
            stmts: LirStmtLoop(
              cond_stmts: reverse_stmts(stmts: cond_stmts),
              cond: neg_cond,
              body: reverse_stmts(stmts: body_stmts)
            ) :: saved,
            temp_counter: c3, enum_defs: ed)
          return LowerStmtResult(ctx: final_ctx, ret: None)
        end
      end
    end
  end
end

// ─── Try-Catch Lowering ──────────────────────────────────────────────────────

let lower_try_stmt = fn (body: [MirStmt], catch_param: string, catch_body: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult throws { Exn } do
  match lower_block(stmts: body, ret_type, ctx) do | BlockResult(ctx: ctx2, stmts: body_stmts, ret: body_ret) ->
    // Add catch parameter to scope
    match ctx2 do | LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
      let exn_type = TyUserDefined(name: "Exn", args: [])
      let catch_ctx = LowerCtx(
        vars: insert_type(name: catch_param, typ: exn_type, entries: v),
        semantic_vars: insert_type(name: catch_param, typ: exn_type, entries: sv),
        stmts: s, temp_counter: c, enum_defs: ed
      )
      match lower_block(stmts: catch_body, ret_type, ctx: catch_ctx) do | BlockResult(ctx: ctx3, stmts: catch_stmts, ret: catch_ret) ->
        match ctx3 do | LowerCtx(vars: v2, semantic_vars: sv2, stmts: s2, temp_counter: c2, enum_defs: ed2) ->
          let ctx4 = LowerCtx(vars: v2, semantic_vars: sv2,
            stmts: LirStmtTryCatch(
              body: body_stmts, body_ret,
              catch_param, catch_param_typ: TyString,
              catch_body: catch_stmts, catch_ret: catch_ret
            ) :: s2,
            temp_counter: c2, enum_defs: ed2)
          return LowerStmtResult(ctx: ctx4, ret: None)
        end
      end
    end
  end
end

// ─── Block Lowering ──────────────────────────────────────────────────────────

type BlockResult = BlockResult(ctx: LowerCtx, stmts: [LirStmt], ret: Option<LirAtom>)

// Block context (if/while/try bodies): trailing bare expressions are evaluated
// for side effect only, NOT captured as an implicit return.
let lower_block = fn (stmts: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> BlockResult throws { Exn } do
  match ctx do | LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let block_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lir_lower_block_stmts(stmts, ret_type, ctx: block_ctx) do | LowerStmtsResult(ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: block_stmts, temp_counter: c2, enum_defs: _), ret: ret_val) ->
      let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
      return BlockResult(ctx: restored, stmts: reverse_stmts(stmts: block_stmts), ret: ret_val)
    end
  end
end

// Case-body context (match arms): trailing bare expression IS captured as the
// produced value of the case.
let lower_case_body = fn (stmts: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> BlockResult throws { Exn } do
  match ctx do | LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let block_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lir_lower_stmts(stmts, ret_type, ctx: block_ctx) do | LowerStmtsResult(ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: block_stmts, temp_counter: c2, enum_defs: _), ret: ret_val) ->
      let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
      return BlockResult(ctx: restored, stmts: reverse_stmts(stmts: block_stmts), ret: ret_val)
    end
  end
end

// Lower a stmt list, returning Some(atom) only when a MirStmtReturn is found.
// Never extracts a trailing bare expression (cf. lir_lower_stmts which does).
let lir_lower_block_stmts = fn (stmts: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtsResult throws { Exn } do
  match stmts do
    | [] -> return LowerStmtsResult(ctx, ret: None)
    | s :: rest ->
      match lower_stmt_inner(stmt: s, ret_type, ctx) do | LowerStmtResult(ctx: ctx2, ret: ret_val) ->
        match ret_val do
          | Some(_) -> return LowerStmtsResult(ctx: ctx2, ret: ret_val)
          | None -> return lir_lower_block_stmts(stmts: rest, ret_type, ctx: ctx2)
        end
      end
  end
end

type LowerStmtsResult = LowerStmtsResult(ctx: LowerCtx, ret: Option<LirAtom>)

// Extract return atom from the last statement in a list (forward order).
let fallback_ret_from_last_stmt = fn (stmts: [LirStmt]) -> Option<LirAtom> throws { Exn } do
  match stmts do
    | [] -> return None
    | [s] ->
      match s do
        | LirStmtIfReturn(cond: _, then_body: _, then_ret: tr, else_body: _, else_ret: _, ret_type: _) ->
          return Some(val: tr)
        | LirStmtTryCatch(body: _, body_ret: br, catch_param: _, catch_param_typ: _, catch_body: _, catch_ret: cr) ->
          match cr do
            | Some(_) -> return cr
            | None -> return br
          end
        | _ -> return None
      end
    | _ :: rest -> return fallback_ret_from_last_stmt(stmts: rest)
  end
end

// Extract return atom from the last emitted LIR statement (IfReturn or TryCatch).
// Mirrors the Rust compiler's fallback_return_atom_from_terminal_stmt.
let fallback_ret_from_terminal = fn (ctx: LowerCtx) -> Option<LirAtom> throws { Exn } do
  match ctx do | LowerCtx(vars: _, semantic_vars: _, stmts, temp_counter: _, enum_defs: _) ->
    match stmts do
      | LirStmtIfReturn(cond: _, then_body: _, then_ret: tr, else_body: _, else_ret: _, ret_type: _) :: _ ->
        Some(val: tr)
      | LirStmtTryCatch(body: _, body_ret: br, catch_param: _, catch_param_typ: _, catch_body: _, catch_ret: cr) :: _ ->
        match cr do
          | Some(_) -> cr
          | None -> br
        end
      | _ -> None
    end
  end
end

let lir_lower_stmts = fn (stmts: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtsResult throws { Exn } do
  match stmts do
    | [] -> return LowerStmtsResult(ctx, ret: None)
    | [s] ->
      // Last statement — capture implicit return value
      match s do
        | MirStmtExpr(expr: e) ->
          match e do
            | MirIf(_) ->
              match lower_stmt_inner(stmt: s, ret_type, ctx) do | LowerStmtResult(ctx: ctx2, ret: _) ->
                return LowerStmtsResult(ctx: ctx2, ret: fallback_ret_from_terminal(ctx: ctx2))
              end
            | MirMatch(_) ->
              match lower_stmt_inner(stmt: s, ret_type, ctx) do | LowerStmtResult(ctx: ctx2, ret: _) ->
                return LowerStmtsResult(ctx: ctx2, ret: fallback_ret_from_terminal(ctx: ctx2))
              end
            | MirWhile(_) ->
              match lower_stmt_inner(stmt: s, ret_type, ctx) do | LowerStmtResult(ctx: ctx2, ret: _) ->
                return LowerStmtsResult(ctx: ctx2, ret: None)
              end
            | _ ->
              // Bare expression (call, constructor, variable) — capture value
              match lower_expr_to_atom(expr: e, ctx) do | BindResult(ctx: ctx2, atom: a) ->
                match atom_type(atom: a) do
                  | TyUnit -> return LowerStmtsResult(ctx: ctx2, ret: None)
                  | _ -> return LowerStmtsResult(ctx: ctx2, ret: Some(val: a))
                end
              end
          end
        | _ ->
          match lower_stmt_inner(stmt: s, ret_type, ctx) do | LowerStmtResult(ctx: ctx2, ret: ret_val) ->
            match ret_val do
              | Some(_) -> return LowerStmtsResult(ctx: ctx2, ret: ret_val)
              | None -> return LowerStmtsResult(ctx: ctx2, ret: fallback_ret_from_terminal(ctx: ctx2))
            end
          end
      end
    | s :: rest ->
      match lower_stmt_inner(stmt: s, ret_type, ctx) do | LowerStmtResult(ctx: ctx2, ret: ret_val) ->
        match ret_val do
          | Some(_) -> return LowerStmtsResult(ctx: ctx2, ret: ret_val)
          | None -> return lir_lower_stmts(stmts: rest, ret_type, ctx: ctx2)
        end
      end
  end
end

// ─── Function Lowering ──────────────────────────────────────────────────────

let lir_lower_function = fn (f: MirFunction, enum_defs: [EnumDef], func_types: [TypeEntry]) -> LirFunction throws { Exn } do
  match f do | MirFunction(name: fname, params: raw_params, ret_type: rt, body, span: sp) ->
    // Sort params alphabetically by label (matching Rust compiler layout)
    let params = sort_mir_params(params: raw_params)
    let wasm_ret = wasm_type(typ: rt)
    // Build initial context with params
    // Prepend param_vars before func_types so params shadow any same-named functions.
    // Store wasm_ret under the sentinel name "#FN_RET#" so nested lowering paths
    // (match-as-expression branches with `return`) can recover the function's
    // return type for emitting LirStmtIfReturn without threading ret_type
    // through ~25 call sites of lower_expr_to_atom.
    let param_vars = build_param_vars(params)
    let param_sem_vars = build_param_semantic_vars(params)
    let sem_vars_with_fn_ret = insert_type(name: "#FN_RET#", typ: wasm_ret, entries: param_sem_vars)
    let ctx = LowerCtx(
      vars: prepend_type_entries(xs: param_vars, ys: func_types),
      semantic_vars: sem_vars_with_fn_ret,
      stmts: [],
      temp_counter: 0,
      enum_defs: enum_defs
    )
    // Lower body
    match lir_lower_stmts(stmts: body, ret_type: wasm_ret, ctx) do | LowerStmtsResult(ctx: LowerCtx(vars: _, semantic_vars: _, stmts, temp_counter: _, enum_defs: _), ret: ret_val) ->
      let ret_atom = match ret_val do
        | Some(val: a) -> a
        | None -> default_atom(typ: wasm_ret)
      end
      let lir_params = lir_convert_params(params)
      return LirFunction(
        name: fname,
        params: lir_params,
        ret_type: wasm_ret,
        body: reverse_stmts(stmts),
        ret: ret_atom,
        span: sp
      )
    end
  end
end

let build_param_vars = fn (params: [MirParam]) -> [TypeEntry] throws { Exn } do
  return build_param_vars_go(params, acc: [])
end

let build_param_vars_go = fn (params: [MirParam], acc: [TypeEntry]) -> [TypeEntry] throws { Exn } do
  match params do
    | [] -> return rev_type_entries(lst: acc, out: [])
    | MirParam(label: _, name: n, typ: t) :: rest ->
      return build_param_vars_go(params: rest, acc: TypeEntry(name: n, typ: wasm_type(typ: t)) :: acc)
  end
end

let build_param_semantic_vars = fn (params: [MirParam]) -> [TypeEntry] throws { Exn } do
  return build_param_semantic_vars_go(params, acc: [])
end

let build_param_semantic_vars_go = fn (params: [MirParam], acc: [TypeEntry]) -> [TypeEntry] throws { Exn } do
  match params do
    | [] -> return rev_type_entries(lst: acc, out: [])
    | MirParam(label: _, name: n, typ: t) :: rest ->
      return build_param_semantic_vars_go(params: rest, acc: TypeEntry(name: n, typ: t) :: acc)
  end
end

let lir_convert_params = fn (params: [MirParam]) -> [LirParam] throws { Exn } do
  let converted = lir_convert_params_go(params, acc: [])
  return sort_lir_params(params: converted)
end

let lir_convert_params_go = fn (params: [MirParam], acc: [LirParam]) -> [LirParam] throws { Exn } do
  match params do
    | [] -> return rev_lir_params(lst: acc, out: [])
    | MirParam(label: l, name: n, typ: t) :: rest ->
      return lir_convert_params_go(params: rest, acc: LirParam(label: l, name: n, typ: wasm_type(typ: t)) :: acc)
  end
end

let sort_lir_params = fn (params: [LirParam]) -> [LirParam] throws { Exn } do
  match params do
    | [] -> return []
    | p :: rest -> return insert_lir_param(p, sorted: sort_lir_params(params: rest))
  end
end

let insert_lir_param = fn (p: LirParam, sorted: [LirParam]) -> [LirParam] throws { Exn } do
  return insert_lir_param_go(p, sorted, acc: [])
end

let insert_lir_param_go = fn (p: LirParam, sorted: [LirParam], acc: [LirParam]) -> [LirParam] throws { Exn } do
  match sorted do
    | [] -> return rev_lir_params(lst: acc, out: [p])
    | head :: rest ->
      match p do | LirParam(label: la, name: _, typ: _) ->
        match head do | LirParam(label: lb, name: _, typ: _) ->
          if lir_str_less_than(a: la, b: lb) then
            return rev_lir_params(lst: acc, out: p :: sorted)
          else
            return insert_lir_param_go(p, sorted: rest, acc: head :: acc)
          end
        end
      end
  end
end

// ─── External Conversion ─────────────────────────────────────────────────────

let convert_external = fn (ext: MirExternal) -> LirExternal throws { Exn } do
  match ext do | MirExternal(name: n, wasm_module: wm, wasm_name: wn, params: ps, ret_type: rt, throw_row: tr) ->
    // External params stay in source order (must match stdlib WASM ABI)
    return LirExternal(
      name: n, wasm_module: wm, wasm_name: wn,
      params: convert_ext_params(params: ps),
      ret_type: wasm_type(typ: rt),
      throw_row: tr
    )
  end
end

let convert_ext_params = fn (params: [MirParam]) -> [LirParam] throws { Exn } do
  return convert_ext_params_go(params, acc: [])
end

let convert_ext_params_go = fn (params: [MirParam], acc: [LirParam]) -> [LirParam] throws { Exn } do
  match params do
    | [] -> return rev_lir_params(lst: acc, out: [])
    | MirParam(label: l, name: n, typ: t) :: rest ->
      // Preserve semantic type for externals (emit_external_arg needs TyString/TyArray)
      return convert_ext_params_go(params: rest, acc: LirParam(label: l, name: n, typ: t) :: acc)
  end
end

// ─── Entry Point ─────────────────────────────────────────────────────────────

let builtin_enum_defs = fn () -> [EnumDef] throws { Exn } do
  return [
    EnumDef(name: "List", is_public: true, is_opaque: false,
      type_params: ["T"],
      variants: [
        VariantDef(name: "Nil", fields: []),
        VariantDef(name: "Cons", fields: [
          VariantField(name: Some(val: "v"), typ: TyVar(name: "T")),
          VariantField(name: Some(val: "rest"), typ: TyList(elem: TyVar(name: "T")))])]),
    EnumDef(name: "Option", is_public: true, is_opaque: false,
      type_params: ["T"],
      variants: [
        VariantDef(name: "None", fields: []),
        VariantDef(name: "Some", fields: [
          VariantField(name: Some(val: "val"), typ: TyVar(name: "T"))])])]
end

let prepend_defs = fn (xs: [EnumDef], ys: [EnumDef]) -> [EnumDef] throws { Exn } do
  return prepend_defs_go(xs, ys, acc: [])
end

let prepend_defs_go = fn (xs: [EnumDef], ys: [EnumDef], acc: [EnumDef]) -> [EnumDef] throws { Exn } do
  match xs do
    | [] -> return rev_enum_defs(lst: acc, out: ys)
    | x :: rest -> return prepend_defs_go(xs: rest, ys, acc: x :: acc)
  end
end

// Build type entries for all function return types so that MirVariable references
// to top-level constants (zero-arg functions) resolve to the correct WASM type
// instead of defaulting to TyI64.
let build_func_type_entries = fn (funcs: [MirFunction]) -> [TypeEntry] throws { Exn } do
  return build_func_type_entries_go(funcs, acc: [])
end

let build_func_type_entries_go = fn (funcs: [MirFunction], acc: [TypeEntry]) -> [TypeEntry] throws { Exn } do
  match funcs do
    | [] -> return rev_type_entries(lst: acc, out: [])
    | MirFunction(name: n, params: _, ret_type: rt, body: _, span: _) :: rest ->
      return build_func_type_entries_go(funcs: rest, acc: TypeEntry(name: n, typ: wasm_type(typ: rt)) :: acc)
  end
end

let prepend_type_entries = fn (xs: [TypeEntry], ys: [TypeEntry]) -> [TypeEntry] throws { Exn } do
  return prepend_type_entries_go(xs, ys, acc: [])
end

let prepend_type_entries_go = fn (xs: [TypeEntry], ys: [TypeEntry], acc: [TypeEntry]) -> [TypeEntry] throws { Exn } do
  match xs do
    | [] -> return rev_type_entries(lst: acc, out: ys)
    | x :: rest -> return prepend_type_entries_go(xs: rest, ys, acc: x :: acc)
  end
end

export let lower_mir_to_lir = fn (mir: MirProgram, enum_defs: [EnumDef]) -> LirProgram throws { Exn } do
  let all_defs = prepend_defs(xs: builtin_enum_defs(), ys: enum_defs)
  match mir do | MirProgram(functions: fs, externals: exts) ->
    let func_types = build_func_type_entries(funcs: fs)
    return LirProgram(
      functions: lir_lower_functions(functions: fs, enum_defs: all_defs, func_types),
      externals: convert_externals(externals: exts)
    )
  end
end

let lir_lower_functions = fn (functions: [MirFunction], enum_defs: [EnumDef], func_types: [TypeEntry]) -> [LirFunction] throws { Exn } do
  return lir_lower_functions_go(functions, enum_defs, func_types, acc: [])
end

let lir_lower_functions_go = fn (functions: [MirFunction], enum_defs: [EnumDef], func_types: [TypeEntry], acc: [LirFunction]) -> [LirFunction] throws { Exn } do
  match functions do
    | [] -> return reverse_lir_funcs(lst: acc, out: [])
    | f :: rest ->
      return lir_lower_functions_go(functions: rest, enum_defs, func_types,
        acc: lir_lower_function(f, enum_defs, func_types) :: acc)
  end
end

let reverse_lir_funcs = fn (lst: [LirFunction], out: [LirFunction]) -> [LirFunction] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_lir_funcs(lst: rest, out: x :: out)
  end
end

let convert_externals = fn (externals: [MirExternal]) -> [LirExternal] throws { Exn } do
  return convert_externals_go(externals, acc: [])
end

let convert_externals_go = fn (externals: [MirExternal], acc: [LirExternal]) -> [LirExternal] throws { Exn } do
  match externals do
    | [] -> return reverse_lir_exts(lst: acc, out: [])
    | e :: rest ->
      return convert_externals_go(externals: rest, acc: convert_external(ext: e) :: acc)
  end
end

let reverse_lir_exts = fn (lst: [LirExternal], out: [LirExternal]) -> [LirExternal] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_lir_exts(lst: rest, out: x :: out)
  end
end

// ─── List Utility Helpers ────────────────────────────────────────────────────

let list_length = fn (lst: [MirPatternField]) -> i64 throws { Exn } do
  match lst do
    | [] -> return 0
    | _ :: rest -> return 1 + list_length(lst: rest)
  end
end

let reverse_stmts = fn (stmts: [LirStmt]) -> [LirStmt] throws { Exn } do
  return reverse_stmts_go(stmts, acc: [])
end

let reverse_stmts_go = fn (stmts: [LirStmt], acc: [LirStmt]) -> [LirStmt] throws { Exn } do
  match stmts do
    | [] -> return acc
    | s :: rest -> return reverse_stmts_go(stmts: rest, acc: s :: acc)
  end
end

// Add forward-order stmts to a reverse-order accumulator (preserves execution order)
let push_stmts_to_reverse = fn (stmts: [LirStmt], acc: [LirStmt]) -> [LirStmt] throws { Exn } do
  match stmts do
    | [] -> return acc
    | s :: rest ->
      return push_stmts_to_reverse(stmts: rest, acc: s :: acc)
  end
end

let append_stmts = fn (stmts: [LirStmt], tail: [LirStmt]) -> [LirStmt] throws { Exn } do
  // Iterative: reverse stmts, then prepend each to tail (avoids stack overflow on large lists)
  let rev = reverse_stmts_go(stmts, acc: [])
  return prepend_reversed(stmts: rev, tail)
end

let prepend_reversed = fn (stmts: [LirStmt], tail: [LirStmt]) -> [LirStmt] throws { Exn } do
  match stmts do
    | [] -> return tail
    | s :: rest -> return prepend_reversed(stmts: rest, tail: s :: tail)
  end
end

