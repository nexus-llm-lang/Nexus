/**
 * lir: MIR → LIR lowering (A-Normal Form with semantic-type tracking).
 *
 * Owns:
 * - ANF-lowering of sub-expressions to atomic values
 * - Semantic-type tracking for field access resolution
 * - match / if conversion to conditional assignment chains
 * - Decision-tree emission (Expr Mode + Stmt Mode) — see nexus-o7l9 for the
 *   pending extract to src/ir/lir/match_tree.nx
 * - Statement lowering, function lowering, external conversion, entry point
 * - LowerCtx threading and the atom / type / temp-var helpers
 *
 * Does not own:
 * - LIR type definitions (see src/ir/lir_types.nx)
 * - Maranget pattern-matrix → DecTree construction (see src/ir/lir/match_tree.nx)
 * - LIR-level optimization passes (see src/ir/lir_opt.nx)
 */
import { BinaryOp, Literal, TypeExpr, NamedType, EnumDef, VariantDef, VariantField, TyVar, TyList, TyLazy } from "src/common/ast.nx"
import { MirProgram, MirFunction, MirExpr, MirStmt, MirParam, MirExternal, MirCallArg, MirMatchCase, MirPattern, MirPatternField, MirRecordPatField, MirNamedExpr } from "src/ir/mir_types.nx"
import { LirProgram, LirFunction, LirExternal, LirParam, LirAtom, LirExpr, LirStmt, LirCallArg, LirNamedAtom } from "src/ir/lir_types.nx"
import { PatBinding, PatRow, DecTree, CtorBranch, LitBranch, AtomEntry, DecTreeResult, lir_build_decision_tree, lir_cases_to_rows, lir_reverse_ctors, lir_reverse_lit_branches, lookup_atom_entry, lir_id_nth, lir_str_index, lir_sort_strings } from "src/ir/lir/match_tree.nx"
import * as str from "stdlib/string.nx"

// ─── Lowering Context ────────────────────────────────────────────────────────

type TypeEntry = TypeEntry(name: string, typ: TypeExpr)

type LowerCtx = LowerCtx(
  vars: [TypeEntry],
  semantic_vars: [TypeEntry],
  stmts: [LirStmt],
  temp_counter: i64,
  enum_defs: [EnumDef]
)

// ─── Type Lookup Helpers ─────────────────────────────────────────────────────

let lir_lookup_type = fn (name: string, entries: [TypeEntry]) -> Option<TypeExpr> do
  match entries do
    case [] -> return None
    case TypeEntry(name: n, typ: t) :: rest ->
      if n == name then return Some(val: t)
      else return lir_lookup_type(name: name, entries: rest)
      end
  end
end

let insert_type = fn (name: string, typ: TypeExpr, entries: [TypeEntry]) -> [TypeEntry] do
  return TypeEntry(name: name, typ: typ) :: entries
end

// ─── WASM Type Mapping ──────────────────────────────────────────────────────

let wasm_type = fn (typ: TypeExpr) -> TypeExpr do
  match typ do
    case TyI32 -> return TyI32
    case TyI64 -> return TyI64
    case TyF32 -> return TyF32
    case TyF64 -> return TyF64
    case TyBool -> return TyBool
    case TyChar -> return TyChar
    case TyString -> return TyString
    case TyUnit -> return TyUnit
    case TyIntLit -> return TyI64
    case TyFloatLit -> return TyF64
    // Heap-allocated compound types → I64 (object pointer)
    case TyList(_) -> return TyI64
    case TyUserDefined(_) -> return TyI64
    case TyHandler(_) -> return TyI64
    case TyLinear(inner: t) -> return wasm_type(typ: t)
    case TyLazy(inner: t) -> return wasm_type(typ: t)
    case TyBorrow(inner: t) -> return wasm_type(typ: t)
    case TyRow(_) -> return TyUnit
    // All remaining compound/heap types → I64 (object pointer)
    case _ -> return TyI64
  end
end

// ─── Atom Type Accessor ──────────────────────────────────────────────────────

export let atom_type = fn (atom: LirAtom) -> TypeExpr do
  match atom do
    case LirAtomVar(name: _, typ: t) -> return t
    case LirAtomInt(_) -> return TyI64
    case LirAtomFloat(_) -> return TyF64
    case LirAtomBool(_) -> return TyBool
    case LirAtomChar(_) -> return TyChar
    case LirAtomString(_) -> return TyString
    case LirAtomUnit -> return TyUnit
  end
end

// ─── Default Atom for Type ───────────────────────────────────────────────────

let default_atom = fn (typ: TypeExpr) -> LirAtom do
  match typ do
    case TyI64 -> return LirAtomInt(val: 0)
    case TyF64 -> return LirAtomFloat(val: "0.0")
    case TyBool -> return LirAtomBool(val: false)
    case TyChar -> return LirAtomChar(val: 0)
    case TyString -> return LirAtomString(val: "")
    case TyUnit -> return LirAtomUnit
    case _ -> return LirAtomInt(val: 0)
  end
end

// ─── Temp Variable Generation ────────────────────────────────────────────────

type TempResult = TempResult(ctx: LowerCtx, name: string)

let new_temp = fn (ctx: LowerCtx) -> TempResult do
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
    let name = "__t" ++ str.from_i64(val: c)
    return TempResult(
      ctx: LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c + 1, enum_defs: ed),
      name: name
    )
  end
end

// ─── Bind Expression to Temp ─────────────────────────────────────────────────

type BindResult = BindResult(ctx: LowerCtx, atom: LirAtom)

let bind_expr_to_temp = fn (ctx: LowerCtx, expr: LirExpr, typ: TypeExpr) -> BindResult do
  match new_temp(ctx: ctx) do case TempResult(ctx: LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed), name: name) ->
    let new_vars = insert_type(name: name, typ: typ, entries: v)
    let new_stmts = LirStmtLet(name: name, typ: typ, expr: expr) :: s
    return BindResult(
      ctx: LowerCtx(vars: new_vars, semantic_vars: sv, stmts: new_stmts, temp_counter: c, enum_defs: ed),
      atom: LirAtomVar(name: name, typ: typ)
    )
  end
end

let bind_expr_to_temp_semantic = fn (ctx: LowerCtx, expr: LirExpr, typ: TypeExpr, semantic_type: TypeExpr) -> BindResult do
  match new_temp(ctx: ctx) do case TempResult(ctx: LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed), name: name) ->
    // For string-typed vars, use TyString as the atom type (not TyI64).
    // type_to_valtype(TyString) = vt_i64, so WASM codegen is unaffected,
    // but atom_type returns TyString enabling is_string_op detection.
    let atom_typ = match semantic_type do
      case TyString -> TyString
      case _ -> typ
    end
    let new_vars = insert_type(name: name, typ: atom_typ, entries: v)
    let new_sv = insert_type(name: name, typ: semantic_type, entries: sv)
    let new_stmts = LirStmtLet(name: name, typ: atom_typ, expr: expr) :: s
    return BindResult(
      ctx: LowerCtx(vars: new_vars, semantic_vars: new_sv, stmts: new_stmts, temp_counter: c, enum_defs: ed),
      atom: LirAtomVar(name: name, typ: atom_typ)
    )
  end
end

// ─── Literal to Atom ─────────────────────────────────────────────────────────

let literal_to_atom = fn (lit: Literal) -> LirAtom do
  match lit do
    case LitInt(val: vi) -> return LirAtomInt(val: vi)
    case LitFloat(val: vf) -> return LirAtomFloat(val: vf)
    case LitBool(val: vb) -> return LirAtomBool(val: vb)
    case LitChar(val: vc) -> return LirAtomChar(val: vc)
    case LitString(val: vs) -> return LirAtomString(val: vs)
    case LitUnit -> return LirAtomUnit
  end
end

// ─── Semantic Type Inference ─────────────────────────────────────────────────

let infer_semantic_type = fn (expr: MirExpr, ctx: LowerCtx) -> TypeExpr do
  match ctx do case LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
    match expr do
      case MirVariable(name: n) ->
        match lir_lookup_type(name: n, entries: sv) do
          case Some(val: t) -> return t
          case None -> return TyI64
        end
      case MirCall(func: _, args: _, ret_type: rt) -> return rt
      case MirLiteral(lit: l) ->
        match l do
          case LitInt(_) -> return TyI64
          case LitFloat(_) -> return TyF64
          case LitBool(_) -> return TyBool
          case LitChar(_) -> return TyChar
          case LitString(_) -> return TyString
          case LitUnit -> return TyUnit
        end
      case MirConstructor(_) -> return TyI64
      case MirBinaryOp(left: _, op: op, right: _) ->
        match op do
          case OpConcat -> return TyString
          case OpEq -> return TyBool
          case OpNe -> return TyBool
          case OpLt -> return TyBool
          case OpLe -> return TyBool
          case OpGt -> return TyBool
          case OpGe -> return TyBool
          case OpAnd -> return TyBool
          case OpOr -> return TyBool
          case _ -> return TyI64
        end
      case MirIf(cond: _, then_body: tb, else_body: _) ->
        return infer_stmts_type(stmts: tb, ctx: ctx)
      case MirMatch(target: _, cases: cs) ->
        match cs do
          case MirMatchCase(pattern: _, body: b) :: _ ->
            return infer_stmts_type(stmts: b, ctx: ctx)
          case [] -> return TyUnit
        end
      case MirRecord(fields: fs) ->
        return TyRecord(fields: infer_record_field_types(fields: fs, ctx: ctx))
      case MirMakeClosure(_) -> return TyI64
      case MirCallClosure(closure: _, args: _, ret_type: rt) -> return rt
      case MirEnvLoad(_) -> return TyI64
      case _ -> return TyI64
    end
  end
end

let infer_record_field_types = fn (fields: [MirNamedExpr], ctx: LowerCtx) -> [NamedType] do
  return infer_record_field_types_go(fields: fields, ctx: ctx, acc: [])
end

let infer_record_field_types_go = fn (fields: [MirNamedExpr], ctx: LowerCtx, acc: [NamedType]) -> [NamedType] do
  match fields do
    case [] -> return rev_named_types(lst: acc, out: [])
    case MirNamedExpr(name: n, value: e) :: rest ->
      let ft = infer_semantic_type(expr: e, ctx: ctx)
      return infer_record_field_types_go(fields: rest, ctx: ctx, acc: NamedType(name: n, typ: ft) :: acc)
  end
end

let infer_stmts_type = fn (stmts: [MirStmt], ctx: LowerCtx) -> TypeExpr do
  match stmts do
    case [] -> return TyUnit
    case [s] ->
      // Last statement determines the type
      match s do
        case MirStmtExpr(expr: e) -> return infer_semantic_type(expr: e, ctx: ctx)
        case MirStmtReturn(expr: e) -> return infer_semantic_type(expr: e, ctx: ctx)
        case _ -> return TyUnit
      end
    case _ :: rest -> return infer_stmts_type(stmts: rest, ctx: ctx)
  end
end

let is_semantic_string = fn (t: TypeExpr) -> bool do
  return if let TyString = t then true else false end
end

// ─── Binary Type Inference ───────────────────────────────────────────────────

let infer_binary_type = fn (op: BinaryOp, lhs_type: TypeExpr, rhs_type: TypeExpr) -> TypeExpr do
  match op do
    case OpEq -> return TyBool
    case OpNe -> return TyBool
    case OpLt -> return TyBool
    case OpLe -> return TyBool
    case OpGt -> return TyBool
    case OpGe -> return TyBool
    case OpAnd -> return TyBool
    case OpOr -> return TyBool
    case OpConcat -> return TyString
    case OpAdd ->
      match lhs_type do
        case TyString -> return TyString
        case TyF64 -> return TyF64
        case _ -> return TyI64
      end
    case OpSub ->
      match lhs_type do
        case TyF64 -> return TyF64
        case _ -> return TyI64
      end
    case OpMul ->
      match lhs_type do
        case TyF64 -> return TyF64
        case _ -> return TyI64
      end
    case OpDiv ->
      match lhs_type do
        case TyF64 -> return TyF64
        case _ -> return TyI64
      end
    case OpMod -> return TyI64
    case _ -> return lhs_type
  end
end

// ─── Enum Definition Lookup ──────────────────────────────────────────────────

let find_variant_in_list = fn (name: string, variants: [VariantDef]) -> Option<VariantDef> do
  match variants do
    case [] -> return None
    case vd :: rest ->
      match vd do case VariantDef(name: vn, fields: _) ->
        if vn == name then return Some(val: vd)
        else return find_variant_in_list(name: name, variants: rest)
        end
      end
  end
end

let lookup_variant_def = fn (name: string, enum_defs: [EnumDef]) -> Option<VariantDef> do
  match enum_defs do
    case [] -> return None
    case ed :: rest ->
      match ed do case EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs) ->
        match find_variant_in_list(name: name, variants: vs) do
          case Some(val: vd) -> return Some(val: vd)
          case None -> return lookup_variant_def(name: name, enum_defs: rest)
        end
      end
  end
end

let count_variant_fields = fn (fields: [VariantField]) -> i64 do
  match fields do
    case [] -> return 0
    case _ :: rest -> return 1 + count_variant_fields(fields: rest)
  end
end

let extract_variant_field_names = fn (fields: [VariantField]) -> [string] do
  return extract_variant_field_names_go(fields: fields, acc: [])
end

let extract_variant_field_names_go = fn (fields: [VariantField], acc: [string]) -> [string] do
  match fields do
    case [] -> return rev_strings(lst: acc, out: [])
    case VariantField(name: n_opt, typ: _) :: rest ->
      let field_name = match n_opt do
        case Some(val: n) -> n
        case None -> str.from_i64(val: count_variant_fields(fields: rest))
      end
      return extract_variant_field_names_go(fields: rest, acc: field_name :: acc)
  end
end

let get_variant_field_names = fn (vd: VariantDef) -> [string] do
  match vd do case VariantDef(name: _, fields: fs) ->
    return extract_variant_field_names(fields: fs)
  end
end

// Character-by-character string comparison (lexicographic less-than)
let lir_str_less_than_loop = fn (a: string, b: string, idx: i64, la: i64, lb: i64) -> bool do
  if idx >= la then
    return idx < lb
  else
    if idx >= lb then
      return false
    else
      let ca = str.char_code(s: a, idx: idx)
      let cb = str.char_code(s: b, idx: idx)
      if ca < cb then
        return true
      else
        if ca > cb then
          return false
        else
          return lir_str_less_than_loop(a: a, b: b, idx: idx + 1, la: la, lb: lb)
        end
      end
    end
  end
end

let lir_str_less_than = fn (a: string, b: string) -> bool do
  return lir_str_less_than_loop(a: a, b: b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end

// ─── Sorting helpers (alphabetical by label, matching Rust compiler) ────────

let insert_mir_param = fn (p: MirParam, sorted: [MirParam]) -> [MirParam] do
  return insert_mir_param_go(p: p, sorted: sorted, acc: [])
end

let insert_mir_param_go = fn (p: MirParam, sorted: [MirParam], acc: [MirParam]) -> [MirParam] do
  match sorted do
    case [] -> return rev_mir_params(lst: acc, out: [p])
    case head :: rest ->
      match p do case MirParam(label: la, name: _, typ: _) ->
        match head do case MirParam(label: lb, name: _, typ: _) ->
          if lir_str_less_than(a: la, b: lb) then
            return rev_mir_params(lst: acc, out: p :: sorted)
          else
            return insert_mir_param_go(p: p, sorted: rest, acc: head :: acc)
          end
        end
      end
  end
end

let sort_mir_params = fn (params: [MirParam]) -> [MirParam] do
  match params do
    case [] -> return []
    case p :: rest -> return insert_mir_param(p: p, sorted: sort_mir_params(params: rest))
  end
end

let insert_lir_call_arg = fn (a: LirCallArg, sorted: [LirCallArg]) -> [LirCallArg] do
  return insert_lir_call_arg_go(a: a, sorted: sorted, acc: [])
end

let insert_lir_call_arg_go = fn (a: LirCallArg, sorted: [LirCallArg], acc: [LirCallArg]) -> [LirCallArg] do
  match sorted do
    case [] -> return rev_lir_call_args(lst: acc, out: [a])
    case head :: rest ->
      match a do case LirCallArg(label: la, value: _) ->
        match head do case LirCallArg(label: lb, value: _) ->
          if lir_str_less_than(a: la, b: lb) then
            return rev_lir_call_args(lst: acc, out: a :: sorted)
          else
            return insert_lir_call_arg_go(a: a, sorted: rest, acc: head :: acc)
          end
        end
      end
  end
end

let sort_lir_call_args = fn (args: [LirCallArg]) -> [LirCallArg] do
  match args do
    case [] -> return []
    case a :: rest -> return insert_lir_call_arg(a: a, sorted: sort_lir_call_args(args: rest))
  end
end

let insert_lir_named_atom = fn (a: LirNamedAtom, sorted: [LirNamedAtom]) -> [LirNamedAtom] do
  return insert_lir_named_atom_go(a: a, sorted: sorted, acc: [])
end

let insert_lir_named_atom_go = fn (a: LirNamedAtom, sorted: [LirNamedAtom], acc: [LirNamedAtom]) -> [LirNamedAtom] do
  match sorted do
    case [] -> return rev_lir_named_atoms(lst: acc, out: [a])
    case head :: rest ->
      match a do case LirNamedAtom(name: na, value: _) ->
        match head do case LirNamedAtom(name: nb, value: _) ->
          if lir_str_less_than(a: na, b: nb) then
            return rev_lir_named_atoms(lst: acc, out: a :: sorted)
          else
            return insert_lir_named_atom_go(a: a, sorted: rest, acc: head :: acc)
          end
        end
      end
  end
end

let sort_lir_named_atoms = fn (atoms: [LirNamedAtom]) -> [LirNamedAtom] do
  match atoms do
    case [] -> return []
    case a :: rest -> return insert_lir_named_atom(a: a, sorted: sort_lir_named_atoms(atoms: rest))
  end
end

// Count field names that sort before target (gives sorted position)
let sorted_field_index = fn (field_name: string, all_names: [string]) -> i64 do
  match all_names do
    case [] -> return 0
    case n :: rest ->
      if lir_str_less_than(a: n, b: field_name) then
        return 1 + sorted_field_index(field_name: field_name, all_names: rest)
      else
        return sorted_field_index(field_name: field_name, all_names: rest)
      end
  end
end

let find_variant_field_type = fn (fields: [VariantField], name: string) -> TypeExpr do
  match fields do
    case [] -> return TyI64
    case VariantField(name: Some(val: n), typ: t) :: rest ->
      if n == name then return t
      else return find_variant_field_type(fields: rest, name: name)
      end
    case VariantField(name: None, typ: _) :: rest ->
      return find_variant_field_type(fields: rest, name: name)
  end
end

let constructor_field_type = fn (field_name: string, ctor_name: string, enum_defs: [EnumDef]) -> TypeExpr do
  match lookup_variant_def(name: ctor_name, enum_defs: enum_defs) do
    case Some(val: VariantDef(name: _, fields: fs)) ->
      return find_variant_field_type(fields: fs, name: field_name)
    case None -> return TyI64
  end
end

let constructor_field_heap_index = fn (field_name: string, ctor_name: string, enum_defs: [EnumDef]) -> i64 do
  match lookup_variant_def(name: ctor_name, enum_defs: enum_defs) do
    case Some(val: vd) ->
      let all_names = get_variant_field_names(vd: vd)
      return sorted_field_index(field_name: field_name, all_names: all_names)
    case None -> return 0
  end
end

// ─── Record Semantic Type Builder ────────────────────────────────────────────

let build_record_semantic_type = fn (atoms: [LirNamedAtom], ctx: LowerCtx) -> TypeExpr do
  return TyRecord(fields: build_named_types_from_atoms(atoms: atoms, ctx: ctx))
end

let build_named_types_from_atoms = fn (atoms: [LirNamedAtom], ctx: LowerCtx) -> [NamedType] do
  return build_named_types_from_atoms_go(atoms: atoms, ctx: ctx, acc: [])
end

let build_named_types_from_atoms_go = fn (atoms: [LirNamedAtom], ctx: LowerCtx, acc: [NamedType]) -> [NamedType] do
  match atoms do
    case [] -> return rev_named_types(lst: acc, out: [])
    case LirNamedAtom(name: n, value: v) :: rest ->
      let sem = match v do
        case LirAtomVar(name: vn, typ: _) ->
          match ctx do case LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
            match lir_lookup_type(name: vn, entries: sv) do
              case Some(val: t) -> t
              case None -> wasm_to_semantic(typ: atom_type(atom: v))
            end
          end
        case _ -> wasm_to_semantic(typ: atom_type(atom: v))
      end
      return build_named_types_from_atoms_go(atoms: rest, ctx: ctx, acc: NamedType(name: n, typ: sem) :: acc)
  end
end

let wasm_to_semantic = fn (typ: TypeExpr) -> TypeExpr do
  // Best-effort reverse mapping from WASM type to semantic type
  match typ do
    case TyI32 -> return TyI64
    case TyF64 -> return TyF64
    case TyI64 -> return TyI64
    case _ -> return typ
  end
end

// ─── Record Field Resolution ────────────────────────────────────────────────

type FieldResolution = FieldResolution(index: i64, typ: TypeExpr)

let sorted_named_type_index = fn (target: string, fields: [NamedType]) -> i64 do
  match fields do
    case [] -> return 0
    case NamedType(name: n, typ: _) :: rest ->
      if lir_str_less_than(a: n, b: target) then
        return 1 + sorted_named_type_index(target: target, fields: rest)
      else
        return sorted_named_type_index(target: target, fields: rest)
      end
  end
end

let find_named_type = fn (target: string, fields: [NamedType]) -> TypeExpr do
  match fields do
    case [] -> return TyI64
    case NamedType(name: n, typ: t) :: rest ->
      if n == target then return t
      else return find_named_type(target: target, fields: rest)
      end
  end
end

let resolve_record_field = fn (atom: LirAtom, field: string, ctx: LowerCtx) -> FieldResolution do
  match atom do
    case LirAtomVar(name: n, typ: _) ->
      match ctx do case LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
        match lir_lookup_type(name: n, entries: sv) do
          case Some(val: TyRecord(fields: fs)) ->
            let idx = sorted_named_type_index(target: field, fields: fs)
            let ft = find_named_type(target: field, fields: fs)
            return FieldResolution(index: idx, typ: ft)
          case _ -> return FieldResolution(index: 0, typ: TyI64)
        end
      end
    case _ -> return FieldResolution(index: 0, typ: TyI64)
  end
end

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_named_types = fn (lst: [NamedType], out: [NamedType]) -> [NamedType] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_named_types(lst: rest, out: x :: out)
  end
end

let rev_strings = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_strings(lst: rest, out: x :: out)
  end
end

let rev_mir_params = fn (lst: [MirParam], out: [MirParam]) -> [MirParam] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_mir_params(lst: rest, out: x :: out)
  end
end

let rev_lir_call_args = fn (lst: [LirCallArg], out: [LirCallArg]) -> [LirCallArg] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_lir_call_args(lst: rest, out: x :: out)
  end
end

let rev_lir_named_atoms = fn (lst: [LirNamedAtom], out: [LirNamedAtom]) -> [LirNamedAtom] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_lir_named_atoms(lst: rest, out: x :: out)
  end
end

let rev_type_entries = fn (lst: [TypeEntry], out: [TypeEntry]) -> [TypeEntry] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_type_entries(lst: rest, out: x :: out)
  end
end

let rev_lir_params = fn (lst: [LirParam], out: [LirParam]) -> [LirParam] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_lir_params(lst: rest, out: x :: out)
  end
end

let rev_enum_defs = fn (lst: [EnumDef], out: [EnumDef]) -> [EnumDef] do
  match lst do
    case [] -> return out
    case x :: rest -> return rev_enum_defs(lst: rest, out: x :: out)
  end
end

// ─── Expression Lowering ─────────────────────────────────────────────────────

let lower_expr_to_atom = fn (expr: MirExpr, ctx: LowerCtx) -> BindResult do
  match expr do
    case MirLiteral(lit: l) -> return BindResult(ctx: ctx, atom: literal_to_atom(lit: l))

    case MirVariable(name: n) ->
      match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
        let typ = match lir_lookup_type(name: n, entries: sv) do
          // Preserve TyString for string vars (enables is_string_op detection)
          case Some(val: TyString) -> TyString
          case Some(val: t) -> wasm_type(typ: t)
          case None ->
            match lir_lookup_type(name: n, entries: v) do
              case Some(val: t) -> t
              case None -> TyI64
            end
        end
        return BindResult(ctx: ctx, atom: LirAtomVar(name: n, typ: typ))
      end

    case MirBinaryOp(left: lhs, op: op, right: rhs) ->
      match lower_expr_to_atom(expr: lhs, ctx: ctx) do case BindResult(ctx: ctx2, atom: la) ->
        match lower_expr_to_atom(expr: rhs, ctx: ctx2) do case BindResult(ctx: ctx3, atom: ra) ->
          // Use semantic types for binary type inference when WASM types lose
          // string info (pattern-extracted string vars have TyI64 WASM type)
          let sem_lhs = infer_semantic_type(expr: lhs, ctx: ctx)
          let sem_rhs = infer_semantic_type(expr: rhs, ctx: ctx)
          let lhs_for_infer = match is_semantic_string(t: sem_lhs) do
            case true -> TyString
            case false -> atom_type(atom: la)
          end
          let rhs_for_infer = match is_semantic_string(t: sem_rhs) do
            case true -> TyString
            case false -> atom_type(atom: ra)
          end
          let result_type = infer_binary_type(op: op, lhs_type: lhs_for_infer, rhs_type: rhs_for_infer)
          return bind_expr_to_temp(ctx: ctx3,
            expr: LirExprBinary(op: op, lhs: la, rhs: ra, typ: result_type),
            typ: result_type)
        end
      end

    case MirCall(func: f, args: args, ret_type: rt) ->
      match lir_lower_call_args(args: args, ctx: ctx) do case LowerCallArgsResult(ctx: ctx2, lir_args: la) ->
        let wt = wasm_type(typ: rt)
        return bind_expr_to_temp_semantic(ctx: ctx2,
          expr: LirExprCall(func: f, args: la, typ: wt),
          typ: wt, semantic_type: rt)
      end

    case MirConstructor(name: n, args: args) ->
      match lower_exprs_to_atoms(exprs: args, ctx: ctx) do case LowerExprsResult(ctx: ctx2, atoms: atoms) ->
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprConstructor(name: n, args: atoms, typ: TyI64),
          typ: TyI64)
      end

    case MirRecord(fields: fields) ->
      match lir_lower_named_exprs(fields: fields, ctx: ctx) do case LowerNamedExprsResult(ctx: ctx2, atoms: named_atoms) ->
        // Sort fields alphabetically by name (matching Rust compiler layout)
        let sorted_atoms = sort_lir_named_atoms(atoms: named_atoms)
        let sem_type = build_record_semantic_type(atoms: sorted_atoms, ctx: ctx2)
        return bind_expr_to_temp_semantic(ctx: ctx2,
          expr: LirExprRecord(fields: sorted_atoms, typ: TyI64),
          typ: TyI64, semantic_type: sem_type)
      end

    case MirFieldAccess(target: recv, field: field) ->
      match lower_expr_to_atom(expr: recv, ctx: ctx) do case BindResult(ctx: ctx2, atom: obj_atom) ->
        let FieldResolution(index: idx, typ: ft) = resolve_record_field(atom: obj_atom, field: field, ctx: ctx2)
        let wt = wasm_type(typ: ft)
        return bind_expr_to_temp_semantic(ctx: ctx2,
          expr: LirExprObjectField(value: obj_atom, index: idx, typ: wt),
          typ: wt, semantic_type: ft)
      end

    case MirBorrow(name: n) ->
      match ctx do case LowerCtx(vars: v, semantic_vars: _, stmts: _, temp_counter: _, enum_defs: _) ->
        let typ = match lir_lookup_type(name: n, entries: v) do
          case Some(val: t) -> t
          case None -> TyI64
        end
        return BindResult(ctx: ctx, atom: LirAtomVar(name: n, typ: typ))
      end

    case MirRaise(expr: e) ->
      match lower_expr_to_atom(expr: e, ctx: ctx) do case BindResult(ctx: ctx2, atom: a) ->
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprRaise(value: a, typ: TyUnit),
          typ: TyUnit)
      end

    case MirForce(expr: e) ->
      // Force: in nxc, @ thunks compile eagerly, so Force is identity.
      // For Expr::Force(@expr) syntax, just evaluate the inner expression.
      match lower_expr_to_atom(expr: e, ctx: ctx) do case BindResult(ctx: ctx2, atom: a) ->
        let inner_typ = match atom_type(atom: a) do
          case TyLazy(inner: t) -> t
          case other -> other
        end
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprForce(value: a, typ: inner_typ),
          typ: inner_typ)
      end

    case MirIf(cond: cond, then_body: tb, else_body: eb) ->
      return lower_if_expr(cond: cond, then_body: tb, else_body: eb, ctx: ctx)

    case MirMatch(target: tgt, cases: cs) ->
      return lower_match_expr(target: tgt, cases: cs, ctx: ctx)

    case MirWhile(_) ->
      // While loops not valid in expression position
      return BindResult(ctx: ctx, atom: LirAtomUnit)

    case MirArray(elems: elems) ->
      match lower_exprs_to_atoms(exprs: elems, ctx: ctx) do case LowerExprsResult(ctx: ctx2, atoms: atoms) ->
        // Encode array as record with numeric indices
        let named = number_atoms(atoms: atoms, idx: 0)
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprRecord(fields: named, typ: TyI64),
          typ: TyI64)
      end

    case MirIndex(target: arr, index: idx) ->
      match lower_expr_to_atom(expr: arr, ctx: ctx) do case BindResult(ctx: ctx2, atom: arr_atom) ->
        match lower_expr_to_atom(expr: idx, ctx: ctx2) do case BindResult(ctx: ctx3, atom: idx_atom) ->
          return bind_expr_to_temp(ctx: ctx3,
            expr: LirExprCall(func: "__array_get",
              args: [LirCallArg(label: "arr", value: arr_atom), LirCallArg(label: "idx", value: idx_atom)],
              typ: TyI64),
            typ: TyI64)
        end
      end

    case MirMakeClosure(func_name: name, captures: caps) ->
      match lower_exprs_to_atoms(exprs: caps, ctx: ctx) do case LowerExprsResult(ctx: ctx2, atoms: cap_atoms) ->
        return bind_expr_to_temp(ctx: ctx2,
          expr: LirExprMakeClosure(func_name: name, captures: cap_atoms, typ: TyI64),
          typ: TyI64)
      end

    case MirCallClosure(closure: clos, args: cargs, ret_type: rt) ->
      match lower_expr_to_atom(expr: clos, ctx: ctx) do case BindResult(ctx: ctx2, atom: clos_atom) ->
        match lir_lower_call_args(args: cargs, ctx: ctx2) do case LowerCallArgsResult(ctx: ctx3, lir_args: lir_args) ->
          let wt = wasm_type(typ: rt)
          return bind_expr_to_temp_semantic(ctx: ctx3,
            expr: LirExprCallClosure(closure: clos_atom, args: lir_args, typ: wt),
            typ: wt, semantic_type: rt)
        end
      end

    case MirEnvLoad(env_var: env, index: idx) ->
      return bind_expr_to_temp(ctx: ctx,
        expr: LirExprObjectField(value: LirAtomVar(name: env, typ: TyI64), index: idx, typ: TyI64),
        typ: TyI64)
  end
end

// ─── Helper: Number atoms for array encoding ─────────────────────────────────

let number_atoms = fn (atoms: [LirAtom], idx: i64) -> [LirNamedAtom] do
  return number_atoms_go(atoms: atoms, idx: idx, acc: [])
end

let number_atoms_go = fn (atoms: [LirAtom], idx: i64, acc: [LirNamedAtom]) -> [LirNamedAtom] do
  match atoms do
    case [] -> return rev_lir_named_atoms(lst: acc, out: [])
    case a :: rest ->
      return number_atoms_go(atoms: rest, idx: idx + 1, acc: LirNamedAtom(name: str.from_i64(val: idx), value: a) :: acc)
  end
end

// ─── Helper: Lower Call Args ─────────────────────────────────────────────────

type LowerCallArgsResult = LowerCallArgsResult(ctx: LowerCtx, lir_args: [LirCallArg])

let lir_lower_call_args_inner = fn (args: [MirCallArg], ctx: LowerCtx) -> LowerCallArgsResult do
  return lir_lower_call_args_inner_go(args: args, ctx: ctx, acc: [])
end

let lir_lower_call_args_inner_go = fn (args: [MirCallArg], ctx: LowerCtx, acc: [LirCallArg]) -> LowerCallArgsResult do
  match args do
    case [] -> return LowerCallArgsResult(ctx: ctx, lir_args: rev_lir_call_args(lst: acc, out: []))
    case MirCallArg(label: l, value: e) :: rest ->
      match lower_expr_to_atom(expr: e, ctx: ctx) do case BindResult(ctx: ctx2, atom: a) ->
        return lir_lower_call_args_inner_go(args: rest, ctx: ctx2, acc: LirCallArg(label: l, value: a) :: acc)
      end
  end
end

let lir_lower_call_args = fn (args: [MirCallArg], ctx: LowerCtx) -> LowerCallArgsResult do
  // Lower args in source order (preserving side-effect evaluation), then sort by label
  match lir_lower_call_args_inner(args: args, ctx: ctx) do
    case LowerCallArgsResult(ctx: c, lir_args: la) ->
      return LowerCallArgsResult(ctx: c, lir_args: sort_lir_call_args(args: la))
  end
end

// ─── Helper: Lower Multiple Exprs ────────────────────────────────────────────

type LowerExprsResult = LowerExprsResult(ctx: LowerCtx, atoms: [LirAtom])

let lower_exprs_to_atoms = fn (exprs: [MirExpr], ctx: LowerCtx) -> LowerExprsResult do
  return lower_exprs_to_atoms_go(exprs: exprs, ctx: ctx, acc: [])
end

let lower_exprs_to_atoms_go = fn (exprs: [MirExpr], ctx: LowerCtx, acc: [LirAtom]) -> LowerExprsResult do
  match exprs do
    case [] -> return LowerExprsResult(ctx: ctx, atoms: lir_reverse_atoms(lst: acc, acc: []))
    case e :: rest ->
      match lower_expr_to_atom(expr: e, ctx: ctx) do case BindResult(ctx: ctx2, atom: a) ->
        return lower_exprs_to_atoms_go(exprs: rest, ctx: ctx2, acc: a :: acc)
      end
  end
end

// ─── Helper: Lower Named Exprs ───────────────────────────────────────────────

type LowerNamedExprsResult = LowerNamedExprsResult(ctx: LowerCtx, atoms: [LirNamedAtom])

let lir_lower_named_exprs = fn (fields: [MirNamedExpr], ctx: LowerCtx) -> LowerNamedExprsResult do
  return lir_lower_named_exprs_go(fields: fields, ctx: ctx, acc: [])
end

let lir_lower_named_exprs_go = fn (fields: [MirNamedExpr], ctx: LowerCtx, acc: [LirNamedAtom]) -> LowerNamedExprsResult do
  match fields do
    case [] -> return LowerNamedExprsResult(ctx: ctx, atoms: rev_lir_named_atoms(lst: acc, out: []))
    case MirNamedExpr(name: n, value: e) :: rest ->
      match lower_expr_to_atom(expr: e, ctx: ctx) do case BindResult(ctx: ctx2, atom: a) ->
        return lir_lower_named_exprs_go(fields: rest, ctx: ctx2, acc: LirNamedAtom(name: n, value: a) :: acc)
      end
  end
end

// ─── If Expression Lowering ──────────────────────────────────────────────────

let lower_if_expr = fn (cond: MirExpr, then_body: [MirStmt], else_body: Option<[MirStmt]>, ctx: LowerCtx) -> BindResult do
  match lower_expr_to_atom(expr: cond, ctx: ctx) do case BindResult(ctx: ctx2, atom: cond_atom) ->
    let sem_type = infer_stmts_type(stmts: then_body, ctx: ctx2)
    let result_type = wasm_type(typ: sem_type)
    match new_temp(ctx: ctx2) do case TempResult(ctx: LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed), name: result_name) ->
      // Register result variable
      let ctx4 = LowerCtx(
        vars: insert_type(name: result_name, typ: result_type, entries: v),
        semantic_vars: insert_type(name: result_name, typ: sem_type, entries: sv),
        stmts: LirStmtLet(name: result_name, typ: result_type,
                       expr: LirExprAtom(atom: default_atom(typ: result_type))) :: s,
        temp_counter: c,
        enum_defs: ed
      )
      // Lower then branch
      match lower_branch_for_value(body: then_body, result_name: result_name,
                                    result_type: result_type, ctx: ctx4) do case BranchResult(ctx: ctx5, stmts: then_stmts) ->
        // Lower else branch
        let else_r = match else_body do
          case Some(val: eb) -> lower_branch_for_value(body: eb, result_name: result_name,
                                                        result_type: result_type, ctx: ctx5)
          case None -> BranchResult(ctx: ctx5, stmts: [])
        end
        match else_r do case BranchResult(ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: s2, temp_counter: c2, enum_defs: ed2), stmts: else_stmts) ->
          // Add the if statement
          let ctx7 = LowerCtx(
            vars: v2, semantic_vars: sv2,
            stmts: LirStmtIf(cond: cond_atom, then_body: then_stmts, else_body: else_stmts) :: s2,
            temp_counter: c2, enum_defs: ed2
          )
          return BindResult(ctx: ctx7, atom: LirAtomVar(name: result_name, typ: result_type))
        end
      end
    end
  end
end

// ─── Branch Value Extraction ─────────────────────────────────────────────────

type BranchResult = BranchResult(ctx: LowerCtx, stmts: [LirStmt])

let lower_branch_for_value = fn (body: [MirStmt], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> BranchResult do
  // Save current statements, lower branch in isolation
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: saved_stmts, temp_counter: c, enum_defs: ed) ->
    let branch_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lower_branch_body(body: body, result_name: result_name, result_type: result_type, ctx: branch_ctx) do case BranchBodyResult(ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: branch_stmts, temp_counter: c2, enum_defs: _), value_opt: val_opt) ->
      // Assign value if present
      let final_stmts = match val_opt do
        case Some(val: atom) ->
          LirStmtLet(name: result_name, typ: result_type,
                             expr: LirExprAtom(atom: atom)) :: branch_stmts
        case None -> branch_stmts
      end
      // Restore outer context with updated temp counter
      let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved_stmts, temp_counter: c2, enum_defs: ed)
      return BranchResult(ctx: restored, stmts: reverse_stmts(stmts: final_stmts))
    end
  end
end

type BranchBodyResult = BranchBodyResult(ctx: LowerCtx, value_opt: Option<LirAtom>)

let lower_branch_body = fn (body: [MirStmt], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> BranchBodyResult do
  match body do
    case [] -> return BranchBodyResult(ctx: ctx, value_opt: None)
    case [last] ->
      // Last statement — extract value
      match last do
        case MirStmtExpr(expr: e) ->
          match lower_expr_to_atom(expr: e, ctx: ctx) do case BindResult(ctx: ctx2, atom: a) ->
            return BranchBodyResult(ctx: ctx2, value_opt: Some(val: a))
          end
        case MirStmtReturn(expr: e) ->
          match lower_expr_to_atom(expr: e, ctx: ctx) do case BindResult(ctx: ctx2, atom: a) ->
            return BranchBodyResult(ctx: ctx2, value_opt: Some(val: a))
          end
        case _ ->
          match lower_stmt_inner(stmt: last, ret_type: TyUnit, ctx: ctx) do case LowerStmtResult(ctx: ctx2, ret: _) ->
            return BranchBodyResult(ctx: ctx2, value_opt: None)
          end
      end
    case s :: rest ->
      match lower_stmt_inner(stmt: s, ret_type: TyUnit, ctx: ctx) do case LowerStmtResult(ctx: ctx2, ret: _) ->
        return lower_branch_body(body: rest, result_name: result_name, result_type: result_type, ctx: ctx2)
      end
  end
end

// ─── Decision Tree Match Lowering ────────────────────────────────────────────

// Lower match expression using Maranget decision tree.
let lower_match_expr = fn (target: MirExpr, cases: [MirMatchCase], ctx: LowerCtx) -> BindResult do
  match lower_expr_to_atom(expr: target, ctx: ctx) do case BindResult(ctx: ctx2, atom: target_atom) ->
    match cases do
      case [] -> return BindResult(ctx: ctx2, atom: LirAtomUnit)
      case _ ->
        let target_sem = lir_get_atom_sem_type(atom: target_atom, ctx: ctx2)
        // Infer result type from case bodies
        let sem_type = lir_infer_match_result_type(cases: cases, ctx: ctx2)
        let result_type = wasm_type(typ: sem_type)
        match new_temp(ctx: ctx2) do case TempResult(ctx: ctx3, name: result_name) ->
          match ctx3 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
            let ctx4 = LowerCtx(
              vars: insert_type(name: result_name, typ: result_type, entries: v),
              semantic_vars: insert_type(name: result_name, typ: sem_type, entries: sv),
              stmts: LirStmtLet(name: result_name, typ: result_type,
                             expr: LirExprAtom(atom: default_atom(typ: result_type))) :: s,
              temp_counter: c, enum_defs: ed
            )
            // Build pattern matrix and decision tree
            let rows = lir_cases_to_rows(cases: cases, idx: 0)
            match lir_build_decision_tree(rows: rows, col_ids: [0], next_id: 1, enum_defs: ed) do case DecTreeResult(tree: tree, next_id: _) ->
              let atoms = [AtomEntry(id: 0, atom: target_atom, sem_type: target_sem)]
              match lir_emit_decision_tree_expr(tree: tree, atoms: atoms, cases: cases,
                  result_name: result_name, result_type: result_type, ctx: ctx4) do case EmitExprResult(ctx: ctx5, chain_stmts: chain) ->
                match ctx5 do case LowerCtx(vars: v5, semantic_vars: sv5, stmts: s5, temp_counter: c5, enum_defs: ed5) ->
                  let s6 = push_stmts_to_reverse(stmts: chain, acc: s5)
                  let ctx6 = LowerCtx(vars: v5, semantic_vars: sv5, stmts: s6, temp_counter: c5, enum_defs: ed5)
                  return BindResult(ctx: ctx6, atom: LirAtomVar(name: result_name, typ: result_type))
                end
              end
            end
          end
        end
    end
  end
end

let lir_get_atom_sem_type = fn (atom: LirAtom, ctx: LowerCtx) -> TypeExpr do
  match atom do
    case LirAtomVar(name: n, typ: t) ->
      match ctx do case LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
        match lir_lookup_type(name: n, entries: sv) do
          case Some(val: st) -> return st
          case None -> return t
        end
      end
    case _ -> return atom_type(atom: atom)
  end
end

let lir_infer_match_result_type = fn (cases: [MirMatchCase], ctx: LowerCtx) -> TypeExpr do
  match cases do
    case [] -> return TyUnit
    case MirMatchCase(pattern: _, body: body) :: rest ->
      match body do
        case [] -> return lir_infer_match_result_type(cases: rest, ctx: ctx)
        case _ ->
          let t = infer_semantic_type(expr: lir_last_mir_expr(body: body), ctx: ctx)
          match t do
            case TyUnit -> return lir_infer_match_result_type(cases: rest, ctx: ctx)
            case _ -> return t
          end
      end
  end
end

let lir_last_mir_expr = fn (body: [MirStmt]) -> MirExpr do
  match body do
    case [] -> return MirLiteral(lit: LitUnit)
    case [MirStmtExpr(expr: e)] -> return e
    case [MirStmtReturn(expr: e)] -> return e
    case _ :: rest -> return lir_last_mir_expr(body: rest)
  end
end

// ─── Decision Tree Emission (Expr Mode) ─────────────────────────────────────

type EmitExprResult = EmitExprResult(ctx: LowerCtx, chain_stmts: [LirStmt])

let lir_emit_decision_tree_expr = fn (tree: DecTree, atoms: [AtomEntry], cases: [MirMatchCase],
    result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult do
  match tree do
    case DecFail -> return EmitExprResult(ctx: ctx, chain_stmts: [])
    case DecLeaf(case_idx: ci, bindings: bs) ->
      return lir_emit_leaf_expr(case_idx: ci, bindings: bs, atoms: atoms, cases: cases,
                                  result_name: result_name, result_type: result_type, ctx: ctx)
    case DecCtorSwitch(scrutinee_id: sid, branches: branches, fallback: fb) ->
      return lir_emit_ctor_switch_expr(scrutinee_id: sid, branches: branches, fallback: fb,
        atoms: atoms, cases: cases, result_name: result_name, result_type: result_type, ctx: ctx)
    case DecLitSwitch(scrutinee_id: sid, branches: branches, fallback: fb) ->
      return lir_emit_lit_switch_expr(scrutinee_id: sid, branches: branches, fallback: fb,
        atoms: atoms, cases: cases, result_name: result_name, result_type: result_type, ctx: ctx)
    case DecRecordDestructure(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st) ->
      return lir_emit_record_expr(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st,
        atoms: atoms, cases: cases, result_name: result_name, result_type: result_type, ctx: ctx)
  end
end

let lir_emit_leaf_expr = fn (case_idx: i64, bindings: [PatBinding], atoms: [AtomEntry],
    cases: [MirMatchCase], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult do
  let case_body = lir_nth_case_body(cases: cases, idx: case_idx)
  // Emit bindings in isolation (matching lir_emit_leaf_stmt) to prevent
  // accumulated stmts from ctx leaking into branch chain_stmts.
  match ctx do case LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
    let bind_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
    match lir_emit_bindings(bindings: bindings, atoms: atoms, ctx: bind_ctx) do case LowerCtx(vars: v2, semantic_vars: sv2, stmts: bind_stmts, temp_counter: c2, enum_defs: _) ->
      let body_ctx = LowerCtx(vars: v2, semantic_vars: sv2, stmts: [], temp_counter: c2, enum_defs: ed0)
      match lower_branch_body(body: case_body, result_name: result_name, result_type: result_type, ctx: body_ctx) do case BranchBodyResult(ctx: ctx3, value_opt: val_opt) ->
        match ctx3 do case LowerCtx(vars: _, semantic_vars: _, stmts: raw_body_stmts, temp_counter: c3, enum_defs: _) ->
          let restored_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c3, enum_defs: ed0)
          let leaf_stmts = append_stmts(stmts: reverse_stmts(stmts: bind_stmts), tail: reverse_stmts(stmts: raw_body_stmts))
          let final_stmts = match val_opt do
            case Some(val: va) ->
              append_stmts(stmts: leaf_stmts, tail: [LirStmtLet(name: result_name, typ: result_type, expr: LirExprAtom(atom: va))])
            case None -> leaf_stmts
          end
          return EmitExprResult(ctx: restored_ctx, chain_stmts: final_stmts)
        end
      end
    end
  end
end

let lir_emit_ctor_switch_expr = fn (scrutinee_id: i64, branches: [CtorBranch], fallback: Option<DecTree>,
    atoms: [AtomEntry], cases: [MirMatchCase], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult do
  match lookup_atom_entry(id: scrutinee_id, atoms: atoms) do case AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    // Extract tag + conditions in isolation to avoid duplicating existing stmts.
    match ctx do case LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
      let iso_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
      match bind_expr_to_temp(ctx: iso_ctx, expr: LirExprObjectTag(value: scr_atom, typ: TyI64), typ: TyI64) do case BindResult(ctx: ctx2, atom: tag_atom) ->
      let has_fb = if let Some(_) = fallback then true else false end
      match lir_emit_ctor_conds(branches: branches, tag_atom: tag_atom, has_fb: has_fb, pos: 0, total: lir_ctors_length(lst: branches), ctx: ctx2) do case CtorCondsResult(ctx: ctx3, conds: conds) ->
        match ctx3 do case LowerCtx(vars: _, semantic_vars: _, stmts: cond_stmts, temp_counter: c3, enum_defs: _) ->
            let base_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c3, enum_defs: ed0)
            // Build chain: start with fallback
            match lir_emit_fb_expr(fallback: fallback, atoms: atoms, cases: cases,
                result_name: result_name, result_type: result_type, ctx: base_ctx) do case EmitExprResult(ctx: ctx4, chain_stmts: chain_else) ->
              // Process branches in reverse
              let rev_branches = lir_reverse_ctors(lst: branches, acc: [])
              let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
              match lir_build_expr_chain(branches: rev_branches, conds: rev_conds, scr_atom: scr_atom,
                  scr_sem: scr_sem, atoms: atoms, cases: cases, result_name: result_name,
                  result_type: result_type, chain_else: chain_else, ctx: ctx4) do case EmitExprResult(ctx: ctx5, chain_stmts: final_chain) ->
                // Prepend cond stmts
                let all_stmts = append_stmts(stmts: reverse_stmts(stmts: cond_stmts), tail: final_chain)
                return EmitExprResult(ctx: ctx5, chain_stmts: all_stmts)
              end
            end
          end
        end
      end
    end
  end
end

type CtorCondsResult = CtorCondsResult(ctx: LowerCtx, conds: [LirAtom])

let lir_emit_ctor_conds = fn (branches: [CtorBranch], tag_atom: LirAtom, has_fb: bool, pos: i64, total: i64, ctx: LowerCtx) -> CtorCondsResult do
  return lir_emit_ctor_conds_go(branches: branches, tag_atom: tag_atom, has_fb: has_fb, pos: pos, total: total, ctx: ctx, acc: [])
end

let lir_emit_ctor_conds_go = fn (branches: [CtorBranch], tag_atom: LirAtom, has_fb: bool, pos: i64, total: i64, ctx: LowerCtx, acc: [LirAtom]) -> CtorCondsResult do
  match branches do
    case [] -> return CtorCondsResult(ctx: ctx, conds: lir_reverse_atoms(lst: acc, acc: []))
    case CtorBranch(ctor_name: _, ctor_tag: tag, arity: _, field_ids: _, subtree: _) :: rest ->
      let is_last_no_fb = (pos == total - 1) && (has_fb == false)
      match is_last_no_fb do
        case true ->
          return lir_emit_ctor_conds_go(branches: rest, tag_atom: tag_atom, has_fb: has_fb, pos: pos + 1, total: total, ctx: ctx, acc: LirAtomBool(val: true) :: acc)
        case false ->
          match bind_expr_to_temp(ctx: ctx,
            expr: LirExprBinary(op: OpEq, lhs: tag_atom, rhs: LirAtomInt(val: tag), typ: TyBool),
            typ: TyBool) do case BindResult(ctx: ctx2, atom: cond) ->
            return lir_emit_ctor_conds_go(branches: rest, tag_atom: tag_atom, has_fb: has_fb, pos: pos + 1, total: total, ctx: ctx2, acc: cond :: acc)
          end
      end
  end
end

let lir_ctors_length = fn (lst: [CtorBranch]) -> i64 do
  match lst do
    case [] -> return 0
    case _ :: rest -> return 1 + lir_ctors_length(lst: rest)
  end
end

let lir_emit_fb_expr = fn (fallback: Option<DecTree>, atoms: [AtomEntry], cases: [MirMatchCase],
    result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult do
  match fallback do
    case None -> return EmitExprResult(ctx: ctx, chain_stmts: [])
    case Some(val: fb) ->
      return lir_emit_decision_tree_expr(tree: fb, atoms: atoms, cases: cases,
        result_name: result_name, result_type: result_type, ctx: ctx)
  end
end

let lir_build_expr_chain = fn (branches: [CtorBranch], conds: [LirAtom], scr_atom: LirAtom,
    scr_sem: TypeExpr, atoms: [AtomEntry], cases: [MirMatchCase], result_name: string,
    result_type: TypeExpr, chain_else: [LirStmt], ctx: LowerCtx) -> EmitExprResult do
  match branches do
    case [] -> return EmitExprResult(ctx: ctx, chain_stmts: chain_else)
    case CtorBranch(ctor_name: cn, ctor_tag: _, arity: ar, field_ids: fids, subtree: st) :: rest_b ->
      match conds do
        case [] -> return EmitExprResult(ctx: ctx, chain_stmts: chain_else)
        case cond :: rest_c ->
        // Extract fields and emit subtree
        match lir_extract_ctor_fields(scr_atom: scr_atom, scr_sem: scr_sem, ctor_name: cn,
            arity: ar, field_ids: fids, atoms: atoms, ctx: ctx) do case FieldExtractResult(ctx: ctx2, atoms: atoms2, field_stmts: fstmts) ->
          match lir_emit_decision_tree_expr(tree: st, atoms: atoms2, cases: cases,
              result_name: result_name, result_type: result_type, ctx: ctx2) do case EmitExprResult(ctx: ctx3, chain_stmts: sub_stmts) ->
            let then_body = append_stmts(stmts: fstmts, tail: sub_stmts)
            let if_stmt = LirStmtIf(cond: cond, then_body: then_body, else_body: chain_else)
            return lir_build_expr_chain(branches: rest_b, conds: rest_c, scr_atom: scr_atom,
              scr_sem: scr_sem, atoms: atoms, cases: cases, result_name: result_name,
              result_type: result_type, chain_else: [if_stmt], ctx: ctx3)
          end
        end
      end
  end
end

type FieldExtractResult = FieldExtractResult(ctx: LowerCtx, atoms: [AtomEntry], field_stmts: [LirStmt])

let lir_extract_ctor_fields = fn (scr_atom: LirAtom, scr_sem: TypeExpr, ctor_name: string,
    arity: i64, field_ids: [i64], atoms: [AtomEntry], ctx: LowerCtx) -> FieldExtractResult do
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let work_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lir_extract_fields_loop(scr_atom: scr_atom, scr_sem: scr_sem, ctor_name: ctor_name,
        field_ids: field_ids, idx: 0, arity: arity, atoms: atoms, ctx: work_ctx,
        enum_defs: ed) do case FieldLoopResult(ctx: ctx2, atoms: atoms2) ->
      match ctx2 do case LowerCtx(vars: _, semantic_vars: _, stmts: field_stmts, temp_counter: c2, enum_defs: _) ->
        let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
        return FieldExtractResult(ctx: restored, atoms: atoms2, field_stmts: reverse_stmts(stmts: field_stmts))
      end
    end
  end
end

type FieldLoopResult = FieldLoopResult(ctx: LowerCtx, atoms: [AtomEntry])

let lir_extract_fields_loop = fn (scr_atom: LirAtom, scr_sem: TypeExpr, ctor_name: string,
    field_ids: [i64], idx: i64, arity: i64, atoms: [AtomEntry], ctx: LowerCtx,
    enum_defs: [EnumDef]) -> FieldLoopResult do
  match idx >= arity do
    case true -> return FieldLoopResult(ctx: ctx, atoms: atoms)
    case false ->
      let fid = lir_id_nth(lst: field_ids, n: idx)
      // Resolve field heap index and type: from enum def if available, else positional
      match lookup_variant_def(name: ctor_name, enum_defs: enum_defs) do
        case Some(val: vd) ->
          let names = get_variant_field_names(vd: vd)
          let field_name = lir_nth_string(lst: names, n: idx)
          let heap_idx = constructor_field_heap_index(field_name: field_name, ctor_name: ctor_name, enum_defs: enum_defs)
          let sem_ft = constructor_field_type(field_name: field_name, ctor_name: ctor_name, enum_defs: enum_defs)
          let wasm_ft = wasm_type(typ: sem_ft)
          match bind_expr_to_temp_semantic(ctx: ctx,
            expr: LirExprObjectField(value: scr_atom, index: heap_idx, typ: wasm_ft),
            typ: wasm_ft, semantic_type: sem_ft) do case BindResult(ctx: ctx2, atom: field_atom) ->
            let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: sem_ft) :: atoms
            return lir_extract_fields_loop(scr_atom: scr_atom, scr_sem: scr_sem, ctor_name: ctor_name,
              field_ids: field_ids, idx: idx + 1, arity: arity, atoms: new_atoms, ctx: ctx2,
              enum_defs: enum_defs)
          end
        case None ->
          // Built-in constructor — apply alphabetical field sort for memory layout.
          // Cons(v, rest): definition order [v(0), rest(1)], sorted [rest(0), v(1)]
          //   def_idx 0 (v) → mem_idx 1, def_idx 1 (rest) → mem_idx 0
          // Some(val): only 1 field, no reordering needed
          let mem_idx = lir_builtin_field_mem_idx(ctor_name: ctor_name, def_idx: idx)
          match bind_expr_to_temp(ctx: ctx,
            expr: LirExprObjectField(value: scr_atom, index: mem_idx, typ: TyI64),
            typ: TyI64) do case BindResult(ctx: ctx2, atom: field_atom) ->
            let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: TyI64) :: atoms
            return lir_extract_fields_loop(scr_atom: scr_atom, scr_sem: scr_sem, ctor_name: ctor_name,
              field_ids: field_ids, idx: idx + 1, arity: arity, atoms: new_atoms, ctx: ctx2,
              enum_defs: enum_defs)
          end
      end
  end
end

/// Map definition-order field index to memory (sorted) index for built-in constructors.
/// Cons(v, rest): sorted [rest(0), v(1)] → def 0(v)→mem 1, def 1(rest)→mem 0
let lir_builtin_field_mem_idx = fn (ctor_name: string, def_idx: i64) -> i64 do
  if ctor_name == "Cons" then
    // Cons fields: v(def 0)→sorted 1, rest(def 1)→sorted 0
    if def_idx == 0 then return 1 else return 0 end
  end
  return def_idx
end

let lir_nth_string = fn (lst: [string], n: i64) -> string do
  match lst do
    case [] -> return ""
    case x :: rest ->
      match n == 0 do
        case true -> return x
        case false -> return lir_nth_string(lst: rest, n: n - 1)
      end
  end
end

let lir_emit_lit_switch_expr = fn (scrutinee_id: i64, branches: [LitBranch], fallback: DecTree,
    atoms: [AtomEntry], cases: [MirMatchCase], result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult do
  match lookup_atom_entry(id: scrutinee_id, atoms: atoms) do case AtomEntry(id: _, atom: scr_atom, sem_type: _) ->
    // Pre-compute conditions in isolation to avoid duplicating existing stmts.
    match ctx do case LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
      let iso_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
      match lir_emit_lit_conds(branches: branches, scr_atom: scr_atom, ctx: iso_ctx) do case LitCondsResult(ctx: ctx2, conds: conds) ->
      match ctx2 do case LowerCtx(vars: _, semantic_vars: _, stmts: cond_stmts, temp_counter: c2, enum_defs: _) ->
          let base_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c2, enum_defs: ed0)
          // Start with fallback
          match lir_emit_decision_tree_expr(tree: fallback, atoms: atoms, cases: cases,
              result_name: result_name, result_type: result_type, ctx: base_ctx) do case EmitExprResult(ctx: ctx3, chain_stmts: chain_else) ->
            let rev_branches = lir_reverse_lit_branches(lst: branches, acc: [])
            let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
            match lir_build_lit_expr_chain(branches: rev_branches, conds: rev_conds, atoms: atoms,
                cases: cases, result_name: result_name, result_type: result_type,
                chain_else: chain_else, ctx: ctx3) do case EmitExprResult(ctx: ctx4, chain_stmts: final_chain) ->
              let all_stmts = append_stmts(stmts: reverse_stmts(stmts: cond_stmts), tail: final_chain)
              return EmitExprResult(ctx: ctx4, chain_stmts: all_stmts)
            end
          end
        end
      end
    end
  end
end

type LitCondsResult = LitCondsResult(ctx: LowerCtx, conds: [LirAtom])

let lir_emit_lit_conds = fn (branches: [LitBranch], scr_atom: LirAtom, ctx: LowerCtx) -> LitCondsResult do
  return lir_emit_lit_conds_go(branches: branches, scr_atom: scr_atom, ctx: ctx, acc: [])
end

let lir_emit_lit_conds_go = fn (branches: [LitBranch], scr_atom: LirAtom, ctx: LowerCtx, acc: [LirAtom]) -> LitCondsResult do
  match branches do
    case [] -> return LitCondsResult(ctx: ctx, conds: lir_reverse_atoms(lst: acc, acc: []))
    case LitBranch(lit: l, subtree: _) :: rest ->
      let lit_atom = literal_to_atom(lit: l)
      match bind_expr_to_temp(ctx: ctx,
        expr: LirExprBinary(op: OpEq, lhs: scr_atom, rhs: lit_atom, typ: TyBool),
        typ: TyBool) do case BindResult(ctx: ctx2, atom: cond) ->
        return lir_emit_lit_conds_go(branches: rest, scr_atom: scr_atom, ctx: ctx2, acc: cond :: acc)
      end
  end
end

let lir_build_lit_expr_chain = fn (branches: [LitBranch], conds: [LirAtom], atoms: [AtomEntry],
    cases: [MirMatchCase], result_name: string, result_type: TypeExpr,
    chain_else: [LirStmt], ctx: LowerCtx) -> EmitExprResult do
  match branches do
    case [] -> return EmitExprResult(ctx: ctx, chain_stmts: chain_else)
    case LitBranch(lit: _, subtree: st) :: rest_b ->
      match conds do
        case [] -> return EmitExprResult(ctx: ctx, chain_stmts: chain_else)
        case cond :: rest_c ->
        match lir_emit_decision_tree_expr(tree: st, atoms: atoms, cases: cases,
            result_name: result_name, result_type: result_type, ctx: ctx) do case EmitExprResult(ctx: ctx2, chain_stmts: sub_stmts) ->
          let if_stmt = LirStmtIf(cond: cond, then_body: sub_stmts, else_body: chain_else)
          return lir_build_lit_expr_chain(branches: rest_b, conds: rest_c, atoms: atoms,
            cases: cases, result_name: result_name, result_type: result_type,
            chain_else: [if_stmt], ctx: ctx2)
        end
      end
  end
end

let lir_emit_record_expr = fn (scrutinee_id: i64, field_names: [string], field_ids: [i64],
    subtree: DecTree, atoms: [AtomEntry], cases: [MirMatchCase],
    result_name: string, result_type: TypeExpr, ctx: LowerCtx) -> EmitExprResult do
  match lookup_atom_entry(id: scrutinee_id, atoms: atoms) do case AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    match lir_extract_record_fields(scr_atom: scr_atom, scr_sem: scr_sem,
        field_names: field_names, field_ids: field_ids, atoms: atoms, ctx: ctx) do case FieldExtractResult(ctx: ctx2, atoms: atoms2, field_stmts: fstmts) ->
      match lir_emit_decision_tree_expr(tree: subtree, atoms: atoms2, cases: cases,
          result_name: result_name, result_type: result_type, ctx: ctx2) do case EmitExprResult(ctx: ctx3, chain_stmts: sub_stmts) ->
        return EmitExprResult(ctx: ctx3, chain_stmts: append_stmts(stmts: fstmts, tail: sub_stmts))
      end
    end
  end
end

let lir_extract_record_fields = fn (scr_atom: LirAtom, scr_sem: TypeExpr,
    field_names: [string], field_ids: [i64], atoms: [AtomEntry], ctx: LowerCtx) -> FieldExtractResult do
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let work_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lir_extract_record_loop(scr_atom: scr_atom, scr_sem: scr_sem,
        field_names: field_names, field_ids: field_ids, atoms: atoms, ctx: work_ctx) do case FieldLoopResult(ctx: ctx2, atoms: atoms2) ->
      match ctx2 do case LowerCtx(vars: _, semantic_vars: _, stmts: field_stmts, temp_counter: c2, enum_defs: _) ->
        let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
        return FieldExtractResult(ctx: restored, atoms: atoms2, field_stmts: reverse_stmts(stmts: field_stmts))
      end
    end
  end
end

let lir_extract_record_loop = fn (scr_atom: LirAtom, scr_sem: TypeExpr,
    field_names: [string], field_ids: [i64], atoms: [AtomEntry], ctx: LowerCtx) -> FieldLoopResult do
  match field_names do
    case [] -> return FieldLoopResult(ctx: ctx, atoms: atoms)
    case fn_ :: rest_names ->
      match field_ids do
        case [] -> return FieldLoopResult(ctx: ctx, atoms: atoms)
        case fid :: rest_ids ->
        // Look up field type from record semantic type
        let field_type = lir_record_field_type(sem: scr_sem, name: fn_)
        let sorted_idx = lir_record_sorted_idx(sem: scr_sem, name: fn_)
        let wasm_ft = wasm_type(typ: field_type)
        match bind_expr_to_temp_semantic(ctx: ctx,
          expr: LirExprObjectField(value: scr_atom, index: sorted_idx, typ: wasm_ft),
          typ: wasm_ft, semantic_type: field_type) do case BindResult(ctx: ctx2, atom: field_atom) ->
          let new_atoms = AtomEntry(id: fid, atom: field_atom, sem_type: field_type) :: atoms
          return lir_extract_record_loop(scr_atom: scr_atom, scr_sem: scr_sem,
            field_names: rest_names, field_ids: rest_ids, atoms: new_atoms, ctx: ctx2)
        end
      end
  end
end

let lir_record_field_type = fn (sem: TypeExpr, name: string) -> TypeExpr do
  match sem do
    case TyRecord(fields: fields) ->
      return lir_find_named_type(fields: fields, name: name)
    case _ -> return TyI64
  end
end

let lir_find_named_type = fn (fields: [NamedType], name: string) -> TypeExpr do
  match fields do
    case [] -> return TyI64
    case NamedType(name: fn_, typ: ft) :: rest ->
      match fn_ == name do
        case true -> return ft
        case false -> return lir_find_named_type(fields: rest, name: name)
      end
  end
end

let lir_record_sorted_idx = fn (sem: TypeExpr, name: string) -> i64 do
  match sem do
    case TyRecord(fields: fields) ->
      let names = lir_extract_named_type_names(fields: fields)
      let sorted = lir_sort_strings(lst: names)
      return lir_str_index(lst: sorted, name: name, idx: 0)
    case _ -> return 0
  end
end

let lir_extract_named_type_names = fn (fields: [NamedType]) -> [string] do
  return lir_extract_named_type_names_go(fields: fields, acc: [])
end

let lir_extract_named_type_names_go = fn (fields: [NamedType], acc: [string]) -> [string] do
  match fields do
    case [] -> return rev_strings(lst: acc, out: [])
    case NamedType(name: n, typ: _) :: rest -> return lir_extract_named_type_names_go(fields: rest, acc: n :: acc)
  end
end

let lir_reverse_atoms = fn (lst: [LirAtom], acc: [LirAtom]) -> [LirAtom] do
  match lst do
    case [] -> return acc
    case x :: rest -> return lir_reverse_atoms(lst: rest, acc: x :: acc)
  end
end

let lir_emit_bindings = fn (bindings: [PatBinding], atoms: [AtomEntry], ctx: LowerCtx) -> LowerCtx do
  match bindings do
    case [] -> return ctx
    case PatBinding(name: n, scrutinee_id: sid) :: rest ->
      match lookup_atom_entry(id: sid, atoms: atoms) do case AtomEntry(id: _, atom: a, sem_type: st) ->
        match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
          let typ = atom_type(atom: a)
          let ctx2 = LowerCtx(
            vars: insert_type(name: n, typ: typ, entries: v),
            semantic_vars: insert_type(name: n, typ: st, entries: sv),
            stmts: LirStmtLet(name: n, typ: typ, expr: LirExprAtom(atom: a)) :: s,
            temp_counter: c, enum_defs: ed
          )
          return lir_emit_bindings(bindings: rest, atoms: atoms, ctx: ctx2)
        end
      end
  end
end

let lir_nth_case_body = fn (cases: [MirMatchCase], idx: i64) -> [MirStmt] do
  match cases do
    case [] -> return []
    case MirMatchCase(pattern: _, body: b) :: rest ->
      match idx == 0 do
        case true -> return b
        case false -> return lir_nth_case_body(cases: rest, idx: idx - 1)
      end
  end
end

// ─── Decision Tree Emission (Stmt Mode) ─────────────────────────────────────

type EmitStmtResult = EmitStmtResult(ctx: LowerCtx, chain_stmts: [LirStmt])

let lir_emit_decision_tree_stmt = fn (tree: DecTree, atoms: [AtomEntry], cases: [MirMatchCase],
    ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult do
  match tree do
    case DecFail -> return EmitStmtResult(ctx: ctx, chain_stmts: [])
    case DecLeaf(case_idx: ci, bindings: bs) ->
      return lir_emit_leaf_stmt(case_idx: ci, bindings: bs, atoms: atoms, cases: cases,
                                  ret_type: ret_type, ctx: ctx)
    case DecCtorSwitch(scrutinee_id: sid, branches: branches, fallback: fb) ->
      return lir_emit_ctor_switch_stmt(scrutinee_id: sid, branches: branches, fallback: fb,
        atoms: atoms, cases: cases, ret_type: ret_type, ctx: ctx)
    case DecLitSwitch(scrutinee_id: sid, branches: branches, fallback: fb) ->
      return lir_emit_lit_switch_stmt(scrutinee_id: sid, branches: branches, fallback: fb,
        atoms: atoms, cases: cases, ret_type: ret_type, ctx: ctx)
    case DecRecordDestructure(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st) ->
      return lir_emit_record_stmt(scrutinee_id: sid, field_names: fns, field_ids: fids, subtree: st,
        atoms: atoms, cases: cases, ret_type: ret_type, ctx: ctx)
  end
end

let lir_emit_leaf_stmt = fn (case_idx: i64, bindings: [PatBinding], atoms: [AtomEntry],
    cases: [MirMatchCase], ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult do
  let case_body = lir_nth_case_body(cases: cases, idx: case_idx)
  // Emit bindings in isolation so they go into chain_stmts (inside the branch),
  // not ctx.stmts (outside the branch). Otherwise, bindings like
  // "Let result = _field_atom" leak before the if-chain, reading uninitialized locals.
  match ctx do case LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
    let bind_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
    match lir_emit_bindings(bindings: bindings, atoms: atoms, ctx: bind_ctx) do case LowerCtx(vars: v2, semantic_vars: sv2, stmts: bind_stmts, temp_counter: c2, enum_defs: _) ->
      let block_ctx = LowerCtx(vars: v2, semantic_vars: sv2, stmts: s0, temp_counter: c2, enum_defs: ed0)
      match lower_case_body(stmts: case_body, ret_type: ret_type, ctx: block_ctx) do case BlockResult(ctx: ctx3, stmts: body_stmts, ret: case_ret) ->
        let full_body = append_stmts(stmts: reverse_stmts(stmts: bind_stmts), tail: body_stmts)
        let is_trivial = is_trivially_unit_body(stmts: case_body)
        let genuine_ret = match case_ret do
          case Some(_) -> case_ret
          case None -> fallback_ret_from_last_stmt(stmts: full_body)
        end
        match genuine_ret do
          case Some(val: a) ->
            let stmt = LirStmtIfReturn(cond: LirAtomBool(val: true), then_body: full_body,
              then_ret: a, else_body: [], else_ret: None, ret_type: ret_type)
            return EmitStmtResult(ctx: ctx3, chain_stmts: [stmt])
          case None ->
            return EmitStmtResult(ctx: ctx3, chain_stmts: full_body)
        end
      end
    end
  end
end

let lir_emit_ctor_switch_stmt = fn (scrutinee_id: i64, branches: [CtorBranch], fallback: Option<DecTree>,
    atoms: [AtomEntry], cases: [MirMatchCase], ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult do
  match lookup_atom_entry(id: scrutinee_id, atoms: atoms) do case AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    // Extract tag + conditions in isolation (empty stmts) to avoid duplicating
    // the target call stmts that are already in ctx.stmts.
    match ctx do case LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
      let iso_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
      match bind_expr_to_temp(ctx: iso_ctx, expr: LirExprObjectTag(value: scr_atom, typ: TyI64), typ: TyI64) do case BindResult(ctx: ctx2, atom: tag_atom) ->
      let has_fb = if let Some(_) = fallback then true else false end
      match lir_emit_ctor_conds(branches: branches, tag_atom: tag_atom, has_fb: has_fb, pos: 0, total: lir_ctors_length(lst: branches), ctx: ctx2) do case CtorCondsResult(ctx: ctx3, conds: conds) ->
        match ctx3 do case LowerCtx(vars: _, semantic_vars: _, stmts: cond_stmts, temp_counter: c3, enum_defs: _) ->
            let base_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c3, enum_defs: ed0)
            match lir_emit_fb_stmt(fallback: fallback, atoms: atoms, cases: cases,
                ret_type: ret_type, ctx: base_ctx) do case EmitStmtResult(ctx: ctx4, chain_stmts: chain_else) ->
              let rev_branches = lir_reverse_ctors(lst: branches, acc: [])
              let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
              match lir_build_stmt_chain(branches: rev_branches, conds: rev_conds, scr_atom: scr_atom,
                  scr_sem: scr_sem, atoms: atoms, cases: cases, ret_type: ret_type,
                  chain_else: chain_else, ctx: ctx4) do case EmitStmtResult(ctx: ctx5, chain_stmts: final_chain) ->
                let all_stmts = append_stmts(stmts: reverse_stmts(stmts: cond_stmts), tail: final_chain)
                return EmitStmtResult(ctx: ctx5, chain_stmts: all_stmts)
              end
            end
          end
        end
      end
    end
  end
end

let lir_emit_fb_stmt = fn (fallback: Option<DecTree>, atoms: [AtomEntry], cases: [MirMatchCase],
    ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult do
  match fallback do
    case None -> return EmitStmtResult(ctx: ctx, chain_stmts: [])
    case Some(val: fb) ->
      return lir_emit_decision_tree_stmt(tree: fb, atoms: atoms, cases: cases, ret_type: ret_type, ctx: ctx)
  end
end

let lir_build_stmt_chain = fn (branches: [CtorBranch], conds: [LirAtom], scr_atom: LirAtom,
    scr_sem: TypeExpr, atoms: [AtomEntry], cases: [MirMatchCase], ret_type: TypeExpr,
    chain_else: [LirStmt], ctx: LowerCtx) -> EmitStmtResult do
  match branches do
    case [] -> return EmitStmtResult(ctx: ctx, chain_stmts: chain_else)
    case CtorBranch(ctor_name: cn, ctor_tag: _, arity: ar, field_ids: fids, subtree: st) :: rest_b ->
      match conds do
        case [] -> return EmitStmtResult(ctx: ctx, chain_stmts: chain_else)
        case cond :: rest_c ->
        match lir_extract_ctor_fields(scr_atom: scr_atom, scr_sem: scr_sem, ctor_name: cn,
            arity: ar, field_ids: fids, atoms: atoms, ctx: ctx) do case FieldExtractResult(ctx: ctx2, atoms: atoms2, field_stmts: fstmts) ->
          match lir_emit_decision_tree_stmt(tree: st, atoms: atoms2, cases: cases,
              ret_type: ret_type, ctx: ctx2) do case EmitStmtResult(ctx: ctx3, chain_stmts: sub_stmts) ->
            let then_body = append_stmts(stmts: fstmts, tail: sub_stmts)
            let then_ret_opt = fallback_ret_from_last_stmt(stmts: then_body)
            match then_ret_opt do
              case Some(val: then_ret) ->
                let stmt = LirStmtIfReturn(cond: cond, then_body: then_body, then_ret: then_ret,
                  else_body: chain_else, else_ret: None, ret_type: ret_type)
                return lir_build_stmt_chain(branches: rest_b, conds: rest_c, scr_atom: scr_atom,
                  scr_sem: scr_sem, atoms: atoms, cases: cases, ret_type: ret_type,
                  chain_else: [stmt], ctx: ctx3)
              case None ->
                let stmt = LirStmtIf(cond: cond, then_body: then_body, else_body: chain_else)
                return lir_build_stmt_chain(branches: rest_b, conds: rest_c, scr_atom: scr_atom,
                  scr_sem: scr_sem, atoms: atoms, cases: cases, ret_type: ret_type,
                  chain_else: [stmt], ctx: ctx3)
            end
          end
        end
      end
  end
end

let lir_emit_lit_switch_stmt = fn (scrutinee_id: i64, branches: [LitBranch], fallback: DecTree,
    atoms: [AtomEntry], cases: [MirMatchCase], ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult do
  match lookup_atom_entry(id: scrutinee_id, atoms: atoms) do case AtomEntry(id: _, atom: scr_atom, sem_type: _) ->
    match ctx do case LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c0, enum_defs: ed0) ->
      let iso_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: [], temp_counter: c0, enum_defs: ed0)
      match lir_emit_lit_conds(branches: branches, scr_atom: scr_atom, ctx: iso_ctx) do case LitCondsResult(ctx: ctx2, conds: conds) ->
      match ctx2 do case LowerCtx(vars: _, semantic_vars: _, stmts: cond_stmts, temp_counter: c2, enum_defs: _) ->
          let base_ctx = LowerCtx(vars: v0, semantic_vars: sv0, stmts: s0, temp_counter: c2, enum_defs: ed0)
          match lir_emit_decision_tree_stmt(tree: fallback, atoms: atoms, cases: cases,
              ret_type: ret_type, ctx: base_ctx) do case EmitStmtResult(ctx: ctx3, chain_stmts: chain_else) ->
            let rev_branches = lir_reverse_lit_branches(lst: branches, acc: [])
            let rev_conds = lir_reverse_atoms(lst: conds, acc: [])
            match lir_build_lit_stmt_chain(branches: rev_branches, conds: rev_conds, atoms: atoms,
                cases: cases, ret_type: ret_type, chain_else: chain_else, ctx: ctx3) do case EmitStmtResult(ctx: ctx4, chain_stmts: final_chain) ->
              let all_stmts = append_stmts(stmts: reverse_stmts(stmts: cond_stmts), tail: final_chain)
              return EmitStmtResult(ctx: ctx4, chain_stmts: all_stmts)
            end
          end
        end
      end
    end
  end
end

let lir_build_lit_stmt_chain = fn (branches: [LitBranch], conds: [LirAtom], atoms: [AtomEntry],
    cases: [MirMatchCase], ret_type: TypeExpr, chain_else: [LirStmt], ctx: LowerCtx) -> EmitStmtResult do
  match branches do
    case [] -> return EmitStmtResult(ctx: ctx, chain_stmts: chain_else)
    case LitBranch(lit: _, subtree: st) :: rest_b ->
      match conds do
        case [] -> return EmitStmtResult(ctx: ctx, chain_stmts: chain_else)
        case cond :: rest_c ->
        match lir_emit_decision_tree_stmt(tree: st, atoms: atoms, cases: cases,
            ret_type: ret_type, ctx: ctx) do case EmitStmtResult(ctx: ctx2, chain_stmts: sub_stmts) ->
          let then_ret_opt = fallback_ret_from_last_stmt(stmts: sub_stmts)
          match then_ret_opt do
            case Some(val: then_ret) ->
              let stmt = LirStmtIfReturn(cond: cond, then_body: sub_stmts, then_ret: then_ret,
                else_body: chain_else, else_ret: None, ret_type: ret_type)
              return lir_build_lit_stmt_chain(branches: rest_b, conds: rest_c, atoms: atoms,
                cases: cases, ret_type: ret_type, chain_else: [stmt], ctx: ctx2)
            case None ->
              let stmt = LirStmtIf(cond: cond, then_body: sub_stmts, else_body: chain_else)
              return lir_build_lit_stmt_chain(branches: rest_b, conds: rest_c, atoms: atoms,
                cases: cases, ret_type: ret_type, chain_else: [stmt], ctx: ctx2)
          end
        end
      end
  end
end

let lir_emit_record_stmt = fn (scrutinee_id: i64, field_names: [string], field_ids: [i64],
    subtree: DecTree, atoms: [AtomEntry], cases: [MirMatchCase],
    ret_type: TypeExpr, ctx: LowerCtx) -> EmitStmtResult do
  match lookup_atom_entry(id: scrutinee_id, atoms: atoms) do case AtomEntry(id: _, atom: scr_atom, sem_type: scr_sem) ->
    match lir_extract_record_fields(scr_atom: scr_atom, scr_sem: scr_sem,
        field_names: field_names, field_ids: field_ids, atoms: atoms, ctx: ctx) do case FieldExtractResult(ctx: ctx2, atoms: atoms2, field_stmts: fstmts) ->
      match lir_emit_decision_tree_stmt(tree: subtree, atoms: atoms2, cases: cases,
          ret_type: ret_type, ctx: ctx2) do case EmitStmtResult(ctx: ctx3, chain_stmts: sub_stmts) ->
        return EmitStmtResult(ctx: ctx3, chain_stmts: append_stmts(stmts: fstmts, tail: sub_stmts))
      end
    end
  end
end

// ─── Statement Lowering ──────────────────────────────────────────────────────

type LowerStmtResult = LowerStmtResult(ctx: LowerCtx, ret: Option<LirAtom>)

let lower_stmt_inner = fn (stmt: MirStmt, ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult do
  match stmt do
    case MirStmtLet(name: n, typ: t, expr: e) ->
      let sem_type = infer_semantic_type(expr: e, ctx: ctx)
      match lower_expr_to_atom(expr: e, ctx: ctx) do case BindResult(ctx: ctx2, atom: a) ->
        let inferred = atom_type(atom: a)
        // Prefer semantic type from lowered atom if available
        let actual_sem = match a do
          case LirAtomVar(name: vn, typ: _) ->
            match ctx2 do case LowerCtx(vars: _, semantic_vars: sv, stmts: _, temp_counter: _, enum_defs: _) ->
              match lir_lookup_type(name: vn, entries: sv) do
                case Some(val: st) -> st
                case None -> sem_type
              end
            end
          case _ -> sem_type
        end
        match ctx2 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
          let ctx3 = LowerCtx(
            vars: insert_type(name: n, typ: inferred, entries: v),
            semantic_vars: insert_type(name: n, typ: actual_sem, entries: sv),
            stmts: LirStmtLet(name: n, typ: inferred, expr: LirExprAtom(atom: a)) :: s,
            temp_counter: c, enum_defs: ed
          )
          return LowerStmtResult(ctx: ctx3, ret: None)
        end
      end

    case MirStmtExpr(expr: e) ->
      // Check for if/match/while at statement level
      match e do
        case MirIf(cond: cond, then_body: tb, else_body: eb) ->
          return lower_if_stmt(cond: cond, then_body: tb, else_body: eb, ret_type: ret_type, ctx: ctx)
        case MirMatch(target: tgt, cases: cs) ->
          return lower_match_stmt(target: tgt, cases: cs, ret_type: ret_type, ctx: ctx)
        case MirWhile(cond: cond, body: body) ->
          return lower_while_stmt(cond: cond, body: body, ctx: ctx)
        case _ ->
          match lower_expr_to_atom(expr: e, ctx: ctx) do case BindResult(ctx: ctx2, atom: _) ->
            return LowerStmtResult(ctx: ctx2, ret: None)
          end
      end

    case MirStmtReturn(expr: e) ->
      // Check for tail call optimization
      match e do
        case MirCall(func: f, args: args, ret_type: rt) ->
          match lir_lower_call_args(args: args, ctx: ctx) do case LowerCallArgsResult(ctx: ctx2, lir_args: la) ->
            let wt = wasm_type(typ: rt)
            match bind_expr_to_temp(ctx: ctx2,
              expr: LirExprTailCall(func: f, args: la, typ: wt), typ: wt) do case BindResult(ctx: ctx3, atom: a) ->
              return LowerStmtResult(ctx: ctx3, ret: Some(val: a))
            end
          end
        case _ ->
          match lower_expr_to_atom(expr: e, ctx: ctx) do case BindResult(ctx: ctx2, atom: a) ->
            return LowerStmtResult(ctx: ctx2, ret: Some(val: a))
          end
      end

    case MirStmtAssign(target: tgt, value: val) ->
      // ANF has no mutation — emit as Let re-binding
      match tgt do
        case MirVariable(name: n) ->
          match lower_expr_to_atom(expr: val, ctx: ctx) do case BindResult(ctx: ctx2, atom: a) ->
            match ctx2 do case LowerCtx(vars: vs, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
              let ctx3 = LowerCtx(
                vars: insert_type(name: n, typ: atom_type(atom: a), entries: vs),
                semantic_vars: sv,
                stmts: LirStmtLet(name: n, typ: atom_type(atom: a), expr: LirExprAtom(atom: a)) :: s,
                temp_counter: c, enum_defs: ed
              )
              return LowerStmtResult(ctx: ctx3, ret: None)
            end
          end
        case _ ->
          // Non-variable assign — just lower both sides
          match lower_expr_to_atom(expr: val, ctx: ctx) do case BindResult(ctx: ctx2, atom: _) ->
            return LowerStmtResult(ctx: ctx2, ret: None)
          end
      end

    case MirStmtTry(body: body, catch_param: cp, catch_body: cb) ->
      return lower_try_stmt(body: body, catch_param: cp, catch_body: cb, ret_type: ret_type, ctx: ctx)
  end
end

// ─── If Statement Lowering ───────────────────────────────────────────────────

let lower_if_stmt = fn (cond: MirExpr, then_body: [MirStmt], else_body: Option<[MirStmt]>, ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult do
  match lower_expr_to_atom(expr: cond, ctx: ctx) do case BindResult(ctx: ctx2, atom: cond_atom) ->
    match lower_block(stmts: then_body, ret_type: ret_type, ctx: ctx2) do case BlockResult(ctx: ctx3, stmts: then_stmts, ret: then_ret) ->
      match else_body do
        case Some(val: eb) ->
          match lower_block(stmts: eb, ret_type: ret_type, ctx: ctx3) do case BlockResult(ctx: ctx4, stmts: else_stmts, ret: else_ret) ->
            match then_ret do
              case Some(_) ->
                match ctx4 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
                  let then_ret_val = match then_ret do
                    case Some(val: a) -> a
                    case None -> default_atom(typ: ret_type)
                  end
                  let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                    stmts: LirStmtIfReturn(cond: cond_atom,
                      then_body: then_stmts, then_ret: then_ret_val,
                      else_body: else_stmts, else_ret: else_ret,
                      ret_type: ret_type) :: s,
                    temp_counter: c, enum_defs: ed)
                  return LowerStmtResult(ctx: ctx5, ret: None)
                end
              case None ->
                match else_ret do
                  case Some(_) ->
                    match ctx4 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
                      let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                        stmts: LirStmtIfReturn(cond: cond_atom,
                          then_body: then_stmts, then_ret: default_atom(typ: ret_type),
                          else_body: else_stmts, else_ret: else_ret,
                          ret_type: ret_type) :: s,
                        temp_counter: c, enum_defs: ed)
                      return LowerStmtResult(ctx: ctx5, ret: None)
                    end
                  case None ->
                    match ctx4 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
                      let ctx5 = LowerCtx(vars: v, semantic_vars: sv,
                        stmts: LirStmtIf(cond: cond_atom, then_body: then_stmts, else_body: else_stmts) :: s,
                        temp_counter: c, enum_defs: ed)
                      return LowerStmtResult(ctx: ctx5, ret: None)
                    end
                end
            end
          end
        case None ->
          match ctx3 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
            match then_ret do
              case Some(val: tr) ->
                let ctx4 = LowerCtx(vars: v, semantic_vars: sv,
                  stmts: LirStmtIfReturn(cond: cond_atom,
                    then_body: then_stmts, then_ret: tr,
                    else_body: [], else_ret: None,
                    ret_type: ret_type) :: s,
                  temp_counter: c, enum_defs: ed)
                return LowerStmtResult(ctx: ctx4, ret: None)
              case None ->
                let ctx4 = LowerCtx(vars: v, semantic_vars: sv,
                  stmts: LirStmtIf(cond: cond_atom, then_body: then_stmts, else_body: []) :: s,
                  temp_counter: c, enum_defs: ed)
                return LowerStmtResult(ctx: ctx4, ret: None)
            end
          end
      end
    end
  end
end

// ─── Match Statement Lowering ────────────────────────────────────────────────

// Check if a MIR statement list is trivially unit (empty or all unit literals).
// Such cases should fall through instead of returning from the function.
let is_trivially_unit_body = fn (stmts: [MirStmt]) -> bool do
  match stmts do
    case [] -> return true
    case MirStmtExpr(expr: MirLiteral(lit: LitUnit)) :: rest ->
      return is_trivially_unit_body(stmts: rest)
    case _ -> return false
  end
end

// Lower match statement using Maranget decision tree.
let lower_match_stmt = fn (target: MirExpr, cases: [MirMatchCase], ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult do
  match lower_expr_to_atom(expr: target, ctx: ctx) do case BindResult(ctx: ctx2, atom: target_atom) ->
    match cases do
      case [] -> return LowerStmtResult(ctx: ctx2, ret: None)
      case _ ->
        let target_sem = lir_get_atom_sem_type(atom: target_atom, ctx: ctx2)
        match ctx2 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
          let rows = lir_cases_to_rows(cases: cases, idx: 0)
          match lir_build_decision_tree(rows: rows, col_ids: [0], next_id: 1, enum_defs: ed) do case DecTreeResult(tree: tree, next_id: _) ->
            let atoms = [AtomEntry(id: 0, atom: target_atom, sem_type: target_sem)]
            match lir_emit_decision_tree_stmt(tree: tree, atoms: atoms, cases: cases,
                ret_type: ret_type, ctx: ctx2) do case EmitStmtResult(ctx: ctx3, chain_stmts: chain) ->
              match ctx3 do case LowerCtx(vars: v3, semantic_vars: sv3, stmts: s3, temp_counter: c3, enum_defs: ed3) ->
                let s4 = push_stmts_to_reverse(stmts: chain, acc: s3)
                let ctx4 = LowerCtx(vars: v3, semantic_vars: sv3, stmts: s4, temp_counter: c3, enum_defs: ed3)
                return LowerStmtResult(ctx: ctx4, ret: None)
              end
            end
          end
        end
    end
  end
end

// ─── While Statement Lowering ────────────────────────────────────────────────

let lower_while_stmt = fn (cond: MirExpr, body: [MirStmt], ctx: LowerCtx) -> LowerStmtResult do
  // Lower condition in isolation
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let cond_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lower_expr_to_atom(expr: cond, ctx: cond_ctx) do case BindResult(ctx: ctx2, atom: cond_atom) ->
      // Negate the condition (loop breaks when true)
      match bind_expr_to_temp(ctx: ctx2,
        expr: LirExprBinary(op: OpEq, lhs: cond_atom, rhs: LirAtomBool(val: false), typ: TyBool),
        typ: TyBool) do case BindResult(ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: cond_stmts, temp_counter: c2, enum_defs: _), atom: neg_cond) ->
        // Lower body
        let body_ctx = LowerCtx(vars: v2, semantic_vars: sv2, stmts: [], temp_counter: c2, enum_defs: ed)
        match lir_lower_stmts(stmts: body, ret_type: TyUnit, ctx: body_ctx) do case LowerStmtsResult(ctx: LowerCtx(vars: _, semantic_vars: _, stmts: body_stmts, temp_counter: c3, enum_defs: _), ret: _) ->
          let final_ctx = LowerCtx(vars: v, semantic_vars: sv,
            stmts: LirStmtLoop(
              cond_stmts: reverse_stmts(stmts: cond_stmts),
              cond: neg_cond,
              body: reverse_stmts(stmts: body_stmts)
            ) :: saved,
            temp_counter: c3, enum_defs: ed)
          return LowerStmtResult(ctx: final_ctx, ret: None)
        end
      end
    end
  end
end

// ─── Try-Catch Lowering ──────────────────────────────────────────────────────

let lower_try_stmt = fn (body: [MirStmt], catch_param: string, catch_body: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtResult do
  match lower_block(stmts: body, ret_type: ret_type, ctx: ctx) do case BlockResult(ctx: ctx2, stmts: body_stmts, ret: body_ret) ->
    // Add catch parameter to scope
    match ctx2 do case LowerCtx(vars: v, semantic_vars: sv, stmts: s, temp_counter: c, enum_defs: ed) ->
      let catch_ctx = LowerCtx(
        vars: insert_type(name: catch_param, typ: TyString, entries: v),
        semantic_vars: insert_type(name: catch_param, typ: TyString, entries: sv),
        stmts: s, temp_counter: c, enum_defs: ed
      )
      match lower_block(stmts: catch_body, ret_type: ret_type, ctx: catch_ctx) do case BlockResult(ctx: ctx3, stmts: catch_stmts, ret: catch_ret) ->
        match ctx3 do case LowerCtx(vars: v2, semantic_vars: sv2, stmts: s2, temp_counter: c2, enum_defs: ed2) ->
          let ctx4 = LowerCtx(vars: v2, semantic_vars: sv2,
            stmts: LirStmtTryCatch(
              body: body_stmts, body_ret: body_ret,
              catch_param: catch_param, catch_param_typ: TyString,
              catch_body: catch_stmts, catch_ret: catch_ret
            ) :: s2,
            temp_counter: c2, enum_defs: ed2)
          return LowerStmtResult(ctx: ctx4, ret: None)
        end
      end
    end
  end
end

// ─── Block Lowering ──────────────────────────────────────────────────────────

type BlockResult = BlockResult(ctx: LowerCtx, stmts: [LirStmt], ret: Option<LirAtom>)

// Block context (if/while/try bodies): trailing bare expressions are evaluated
// for side effect only, NOT captured as an implicit return.
let lower_block = fn (stmts: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> BlockResult do
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let block_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lir_lower_block_stmts(stmts: stmts, ret_type: ret_type, ctx: block_ctx) do case LowerStmtsResult(ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: block_stmts, temp_counter: c2, enum_defs: _), ret: ret_val) ->
      let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
      return BlockResult(ctx: restored, stmts: reverse_stmts(stmts: block_stmts), ret: ret_val)
    end
  end
end

// Case-body context (match arms): trailing bare expression IS captured as the
// produced value of the case.
let lower_case_body = fn (stmts: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> BlockResult do
  match ctx do case LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c, enum_defs: ed) ->
    let block_ctx = LowerCtx(vars: v, semantic_vars: sv, stmts: [], temp_counter: c, enum_defs: ed)
    match lir_lower_stmts(stmts: stmts, ret_type: ret_type, ctx: block_ctx) do case LowerStmtsResult(ctx: LowerCtx(vars: v2, semantic_vars: sv2, stmts: block_stmts, temp_counter: c2, enum_defs: _), ret: ret_val) ->
      let restored = LowerCtx(vars: v, semantic_vars: sv, stmts: saved, temp_counter: c2, enum_defs: ed)
      return BlockResult(ctx: restored, stmts: reverse_stmts(stmts: block_stmts), ret: ret_val)
    end
  end
end

// Lower a stmt list, returning Some(atom) only when a MirStmtReturn is found.
// Never extracts a trailing bare expression (cf. lir_lower_stmts which does).
let lir_lower_block_stmts = fn (stmts: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtsResult do
  match stmts do
    case [] -> return LowerStmtsResult(ctx: ctx, ret: None)
    case s :: rest ->
      match lower_stmt_inner(stmt: s, ret_type: ret_type, ctx: ctx) do case LowerStmtResult(ctx: ctx2, ret: ret_val) ->
        match ret_val do
          case Some(_) -> return LowerStmtsResult(ctx: ctx2, ret: ret_val)
          case None -> return lir_lower_block_stmts(stmts: rest, ret_type: ret_type, ctx: ctx2)
        end
      end
  end
end

type LowerStmtsResult = LowerStmtsResult(ctx: LowerCtx, ret: Option<LirAtom>)

// Extract return atom from the last statement in a list (forward order).
let fallback_ret_from_last_stmt = fn (stmts: [LirStmt]) -> Option<LirAtom> do
  match stmts do
    case [] -> return None
    case [s] ->
      match s do
        case LirStmtIfReturn(cond: _, then_body: _, then_ret: tr, else_body: _, else_ret: _, ret_type: _) ->
          return Some(val: tr)
        case LirStmtTryCatch(body: _, body_ret: br, catch_param: _, catch_param_typ: _, catch_body: _, catch_ret: cr) ->
          match cr do
            case Some(_) -> return cr
            case None -> return br
          end
        case _ -> return None
      end
    case _ :: rest -> return fallback_ret_from_last_stmt(stmts: rest)
  end
end

// Extract return atom from the last emitted LIR statement (IfReturn or TryCatch).
// Mirrors the Rust compiler's fallback_return_atom_from_terminal_stmt.
let fallback_ret_from_terminal = fn (ctx: LowerCtx) -> Option<LirAtom> do
  match ctx do case LowerCtx(vars: _, semantic_vars: _, stmts: stmts, temp_counter: _, enum_defs: _) ->
    match stmts do
      case LirStmtIfReturn(cond: _, then_body: _, then_ret: tr, else_body: _, else_ret: _, ret_type: _) :: _ ->
        Some(val: tr)
      case LirStmtTryCatch(body: _, body_ret: br, catch_param: _, catch_param_typ: _, catch_body: _, catch_ret: cr) :: _ ->
        match cr do
          case Some(_) -> cr
          case None -> br
        end
      case _ -> None
    end
  end
end

let lir_lower_stmts = fn (stmts: [MirStmt], ret_type: TypeExpr, ctx: LowerCtx) -> LowerStmtsResult do
  match stmts do
    case [] -> return LowerStmtsResult(ctx: ctx, ret: None)
    case [s] ->
      // Last statement — capture implicit return value
      match s do
        case MirStmtExpr(expr: e) ->
          match e do
            case MirIf(_) ->
              match lower_stmt_inner(stmt: s, ret_type: ret_type, ctx: ctx) do case LowerStmtResult(ctx: ctx2, ret: _) ->
                return LowerStmtsResult(ctx: ctx2, ret: fallback_ret_from_terminal(ctx: ctx2))
              end
            case MirMatch(_) ->
              match lower_stmt_inner(stmt: s, ret_type: ret_type, ctx: ctx) do case LowerStmtResult(ctx: ctx2, ret: _) ->
                return LowerStmtsResult(ctx: ctx2, ret: fallback_ret_from_terminal(ctx: ctx2))
              end
            case MirWhile(_) ->
              match lower_stmt_inner(stmt: s, ret_type: ret_type, ctx: ctx) do case LowerStmtResult(ctx: ctx2, ret: _) ->
                return LowerStmtsResult(ctx: ctx2, ret: None)
              end
            case _ ->
              // Bare expression (call, constructor, variable) — capture value
              match lower_expr_to_atom(expr: e, ctx: ctx) do case BindResult(ctx: ctx2, atom: a) ->
                match atom_type(atom: a) do
                  case TyUnit -> return LowerStmtsResult(ctx: ctx2, ret: None)
                  case _ -> return LowerStmtsResult(ctx: ctx2, ret: Some(val: a))
                end
              end
          end
        case _ ->
          match lower_stmt_inner(stmt: s, ret_type: ret_type, ctx: ctx) do case LowerStmtResult(ctx: ctx2, ret: ret_val) ->
            match ret_val do
              case Some(_) -> return LowerStmtsResult(ctx: ctx2, ret: ret_val)
              case None -> return LowerStmtsResult(ctx: ctx2, ret: fallback_ret_from_terminal(ctx: ctx2))
            end
          end
      end
    case s :: rest ->
      match lower_stmt_inner(stmt: s, ret_type: ret_type, ctx: ctx) do case LowerStmtResult(ctx: ctx2, ret: ret_val) ->
        match ret_val do
          case Some(_) -> return LowerStmtsResult(ctx: ctx2, ret: ret_val)
          case None -> return lir_lower_stmts(stmts: rest, ret_type: ret_type, ctx: ctx2)
        end
      end
  end
end

// ─── Function Lowering ──────────────────────────────────────────────────────

let lir_lower_function = fn (f: MirFunction, enum_defs: [EnumDef], func_types: [TypeEntry]) -> LirFunction do
  match f do case MirFunction(name: fname, params: raw_params, ret_type: rt, body: body, span: sp) ->
    // Sort params alphabetically by label (matching Rust compiler layout)
    let params = sort_mir_params(params: raw_params)
    let wasm_ret = wasm_type(typ: rt)
    // Build initial context with params
    // Prepend param_vars before func_types so params shadow any same-named functions
    let param_vars = build_param_vars(params: params)
    let param_sem_vars = build_param_semantic_vars(params: params)
    let ctx = LowerCtx(
      vars: prepend_type_entries(xs: param_vars, ys: func_types),
      semantic_vars: param_sem_vars,
      stmts: [],
      temp_counter: 0,
      enum_defs: enum_defs
    )
    // Lower body
    match lir_lower_stmts(stmts: body, ret_type: wasm_ret, ctx: ctx) do case LowerStmtsResult(ctx: LowerCtx(vars: _, semantic_vars: _, stmts: stmts, temp_counter: _, enum_defs: _), ret: ret_val) ->
      let ret_atom = match ret_val do
        case Some(val: a) -> a
        case None -> default_atom(typ: wasm_ret)
      end
      let lir_params = lir_convert_params(params: params)
      return LirFunction(
        name: fname,
        params: lir_params,
        ret_type: wasm_ret,
        body: reverse_stmts(stmts: stmts),
        ret: ret_atom,
        span: sp
      )
    end
  end
end

let build_param_vars = fn (params: [MirParam]) -> [TypeEntry] do
  return build_param_vars_go(params: params, acc: [])
end

let build_param_vars_go = fn (params: [MirParam], acc: [TypeEntry]) -> [TypeEntry] do
  match params do
    case [] -> return rev_type_entries(lst: acc, out: [])
    case MirParam(label: _, name: n, typ: t) :: rest ->
      return build_param_vars_go(params: rest, acc: TypeEntry(name: n, typ: wasm_type(typ: t)) :: acc)
  end
end

let build_param_semantic_vars = fn (params: [MirParam]) -> [TypeEntry] do
  return build_param_semantic_vars_go(params: params, acc: [])
end

let build_param_semantic_vars_go = fn (params: [MirParam], acc: [TypeEntry]) -> [TypeEntry] do
  match params do
    case [] -> return rev_type_entries(lst: acc, out: [])
    case MirParam(label: _, name: n, typ: t) :: rest ->
      return build_param_semantic_vars_go(params: rest, acc: TypeEntry(name: n, typ: t) :: acc)
  end
end

let lir_convert_params = fn (params: [MirParam]) -> [LirParam] do
  let converted = lir_convert_params_go(params: params, acc: [])
  return sort_lir_params(params: converted)
end

let lir_convert_params_go = fn (params: [MirParam], acc: [LirParam]) -> [LirParam] do
  match params do
    case [] -> return rev_lir_params(lst: acc, out: [])
    case MirParam(label: l, name: n, typ: t) :: rest ->
      return lir_convert_params_go(params: rest, acc: LirParam(label: l, name: n, typ: wasm_type(typ: t)) :: acc)
  end
end

let sort_lir_params = fn (params: [LirParam]) -> [LirParam] do
  match params do
    case [] -> return []
    case p :: rest -> return insert_lir_param(p: p, sorted: sort_lir_params(params: rest))
  end
end

let insert_lir_param = fn (p: LirParam, sorted: [LirParam]) -> [LirParam] do
  return insert_lir_param_go(p: p, sorted: sorted, acc: [])
end

let insert_lir_param_go = fn (p: LirParam, sorted: [LirParam], acc: [LirParam]) -> [LirParam] do
  match sorted do
    case [] -> return rev_lir_params(lst: acc, out: [p])
    case head :: rest ->
      match p do case LirParam(label: la, name: _, typ: _) ->
        match head do case LirParam(label: lb, name: _, typ: _) ->
          if lir_str_less_than(a: la, b: lb) then
            return rev_lir_params(lst: acc, out: p :: sorted)
          else
            return insert_lir_param_go(p: p, sorted: rest, acc: head :: acc)
          end
        end
      end
  end
end

// ─── External Conversion ─────────────────────────────────────────────────────

let convert_external = fn (ext: MirExternal) -> LirExternal do
  match ext do case MirExternal(name: n, wasm_module: wm, wasm_name: wn, params: ps, ret_type: rt, throw_row: tr) ->
    // External params stay in source order (must match stdlib WASM ABI)
    return LirExternal(
      name: n, wasm_module: wm, wasm_name: wn,
      params: convert_ext_params(params: ps),
      ret_type: wasm_type(typ: rt),
      throw_row: tr
    )
  end
end

let convert_ext_params = fn (params: [MirParam]) -> [LirParam] do
  return convert_ext_params_go(params: params, acc: [])
end

let convert_ext_params_go = fn (params: [MirParam], acc: [LirParam]) -> [LirParam] do
  match params do
    case [] -> return rev_lir_params(lst: acc, out: [])
    case MirParam(label: l, name: n, typ: t) :: rest ->
      // Preserve semantic type for externals (emit_external_arg needs TyString/TyArray)
      return convert_ext_params_go(params: rest, acc: LirParam(label: l, name: n, typ: t) :: acc)
  end
end

// ─── Entry Point ─────────────────────────────────────────────────────────────

let builtin_enum_defs = fn () -> [EnumDef] do
  return [
    EnumDef(name: "List", is_public: true, is_opaque: false,
      type_params: ["T"],
      variants: [
        VariantDef(name: "Nil", fields: []),
        VariantDef(name: "Cons", fields: [
          VariantField(name: Some(val: "v"), typ: TyVar(name: "T")),
          VariantField(name: Some(val: "rest"), typ: TyList(elem: TyVar(name: "T")))])]),
    EnumDef(name: "Option", is_public: true, is_opaque: false,
      type_params: ["T"],
      variants: [
        VariantDef(name: "None", fields: []),
        VariantDef(name: "Some", fields: [
          VariantField(name: Some(val: "val"), typ: TyVar(name: "T"))])])]
end

let prepend_defs = fn (xs: [EnumDef], ys: [EnumDef]) -> [EnumDef] do
  return prepend_defs_go(xs: xs, ys: ys, acc: [])
end

let prepend_defs_go = fn (xs: [EnumDef], ys: [EnumDef], acc: [EnumDef]) -> [EnumDef] do
  match xs do
    case [] -> return rev_enum_defs(lst: acc, out: ys)
    case x :: rest -> return prepend_defs_go(xs: rest, ys: ys, acc: x :: acc)
  end
end

// Build type entries for all function return types so that MirVariable references
// to top-level constants (zero-arg functions) resolve to the correct WASM type
// instead of defaulting to TyI64.
let build_func_type_entries = fn (funcs: [MirFunction]) -> [TypeEntry] do
  return build_func_type_entries_go(funcs: funcs, acc: [])
end

let build_func_type_entries_go = fn (funcs: [MirFunction], acc: [TypeEntry]) -> [TypeEntry] do
  match funcs do
    case [] -> return rev_type_entries(lst: acc, out: [])
    case MirFunction(name: n, params: _, ret_type: rt, body: _, span: _) :: rest ->
      return build_func_type_entries_go(funcs: rest, acc: TypeEntry(name: n, typ: wasm_type(typ: rt)) :: acc)
  end
end

let prepend_type_entries = fn (xs: [TypeEntry], ys: [TypeEntry]) -> [TypeEntry] do
  return prepend_type_entries_go(xs: xs, ys: ys, acc: [])
end

let prepend_type_entries_go = fn (xs: [TypeEntry], ys: [TypeEntry], acc: [TypeEntry]) -> [TypeEntry] do
  match xs do
    case [] -> return rev_type_entries(lst: acc, out: ys)
    case x :: rest -> return prepend_type_entries_go(xs: rest, ys: ys, acc: x :: acc)
  end
end

export let lower_mir_to_lir = fn (mir: MirProgram, enum_defs: [EnumDef]) -> LirProgram do
  let all_defs = prepend_defs(xs: builtin_enum_defs(), ys: enum_defs)
  match mir do case MirProgram(functions: fs, externals: exts) ->
    let func_types = build_func_type_entries(funcs: fs)
    return LirProgram(
      functions: lir_lower_functions(functions: fs, enum_defs: all_defs, func_types: func_types),
      externals: convert_externals(externals: exts)
    )
  end
end

let lir_lower_functions = fn (functions: [MirFunction], enum_defs: [EnumDef], func_types: [TypeEntry]) -> [LirFunction] do
  return lir_lower_functions_go(functions: functions, enum_defs: enum_defs, func_types: func_types, acc: [])
end

let lir_lower_functions_go = fn (functions: [MirFunction], enum_defs: [EnumDef], func_types: [TypeEntry], acc: [LirFunction]) -> [LirFunction] do
  match functions do
    case [] -> return reverse_lir_funcs(lst: acc, out: [])
    case f :: rest ->
      return lir_lower_functions_go(functions: rest, enum_defs: enum_defs, func_types: func_types,
        acc: lir_lower_function(f: f, enum_defs: enum_defs, func_types: func_types) :: acc)
  end
end

let reverse_lir_funcs = fn (lst: [LirFunction], out: [LirFunction]) -> [LirFunction] do
  match lst do
    case [] -> return out
    case x :: rest -> return reverse_lir_funcs(lst: rest, out: x :: out)
  end
end

let convert_externals = fn (externals: [MirExternal]) -> [LirExternal] do
  return convert_externals_go(externals: externals, acc: [])
end

let convert_externals_go = fn (externals: [MirExternal], acc: [LirExternal]) -> [LirExternal] do
  match externals do
    case [] -> return reverse_lir_exts(lst: acc, out: [])
    case e :: rest ->
      return convert_externals_go(externals: rest, acc: convert_external(ext: e) :: acc)
  end
end

let reverse_lir_exts = fn (lst: [LirExternal], out: [LirExternal]) -> [LirExternal] do
  match lst do
    case [] -> return out
    case x :: rest -> return reverse_lir_exts(lst: rest, out: x :: out)
  end
end

// ─── List Utility Helpers ────────────────────────────────────────────────────

let list_length = fn (lst: [MirPatternField]) -> i64 do
  match lst do
    case [] -> return 0
    case _ :: rest -> return 1 + list_length(lst: rest)
  end
end

let reverse_stmts = fn (stmts: [LirStmt]) -> [LirStmt] do
  return reverse_stmts_go(stmts: stmts, acc: [])
end

let reverse_stmts_go = fn (stmts: [LirStmt], acc: [LirStmt]) -> [LirStmt] do
  match stmts do
    case [] -> return acc
    case s :: rest -> return reverse_stmts_go(stmts: rest, acc: s :: acc)
  end
end

// Add forward-order stmts to a reverse-order accumulator (preserves execution order)
let push_stmts_to_reverse = fn (stmts: [LirStmt], acc: [LirStmt]) -> [LirStmt] do
  match stmts do
    case [] -> return acc
    case s :: rest ->
      return push_stmts_to_reverse(stmts: rest, acc: s :: acc)
  end
end

let append_stmts = fn (stmts: [LirStmt], tail: [LirStmt]) -> [LirStmt] do
  // Iterative: reverse stmts, then prepend each to tail (avoids stack overflow on large lists)
  let rev = reverse_stmts_go(stmts: stmts, acc: [])
  return prepend_reversed(stmts: rev, tail: tail)
end

let prepend_reversed = fn (stmts: [LirStmt], tail: [LirStmt]) -> [LirStmt] do
  match stmts do
    case [] -> return tail
    case s :: rest -> return prepend_reversed(stmts: rest, tail: s :: tail)
  end
end

