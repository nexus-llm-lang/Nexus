/**
 * lir_opt/folding: constant folding and identity/absorbing-element
 * simplification on binary LirExpr nodes.
 *
 * Extracted from src/ir/lir_opt.nx (nexus-95iz.2). Pure rewrites — no
 * statement-list surgery, no atom substitution. The propagate pass
 * (lir_opt/propagate.nx) chains this with substitution so that the
 * combined forward walk does both copy/constant propagation and
 * arithmetic folding in one go.
 *
 * Preserves the backtrace-stability contract trivially: only LirExprBinary
 * nodes are rewritten and the rewrite always yields another expression
 * (LirExprAtom or the original binary), never a statement-level edit.
 */

import { BinaryOp } from "src/common/ast.nx"
import { LirExpr, LirAtom } from "src/ir/lir_types.nx"

// ─── Constant Folding ───────────────────────────────────────────────────────

let opt_fold_int_binary = fn (op: BinaryOp, a: i64, b: i64) -> Option<LirAtom> do
  match op do
    | OpAdd -> return Some(val: LirAtomInt(val: a + b))
    | OpSub -> return Some(val: LirAtomInt(val: a - b))
    | OpMul -> return Some(val: LirAtomInt(val: a * b))
    | OpDiv ->
      if b == 0 then return None end
      return Some(val: LirAtomInt(val: a / b))
    | OpMod ->
      if b == 0 then return None end
      return Some(val: LirAtomInt(val: a - (a / b) * b))
    | OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    | OpLt ->
      if a < b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpLe ->
      if a <= b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpGt ->
      if a > b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpGe ->
      if a >= b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | _ -> return None
  end
end

let opt_fold_bool_binary = fn (op: BinaryOp, a: bool, b: bool) -> Option<LirAtom> do
  match op do
    | OpAnd -> return Some(val: LirAtomBool(val: a && b))
    | OpOr -> return Some(val: LirAtomBool(val: a || b))
    | OpEq -> return Some(val: LirAtomBool(val: a == b))
    | OpNe -> return Some(val: LirAtomBool(val: a != b))
    | _ -> return None
  end
end

let opt_fold_str_binary = fn (op: BinaryOp, a: string, b: string) -> Option<LirAtom> do
  match op do
    | OpConcat -> return Some(val: LirAtomString(val: a ++ b))
    | OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    | _ -> return None
  end
end

let opt_fold_char_binary = fn (op: BinaryOp, a: i64, b: i64) -> Option<LirAtom> do
  match op do
    | OpEq ->
      if a == b then return Some(val: LirAtomBool(val: true)) end
      return Some(val: LirAtomBool(val: false))
    | OpNe ->
      if a == b then return Some(val: LirAtomBool(val: false)) end
      return Some(val: LirAtomBool(val: true))
    | _ -> return None
  end
end

let opt_try_fold_binary = fn (op: BinaryOp, lhs: LirAtom, rhs: LirAtom) -> Option<LirAtom> do
  match lhs do
    | LirAtomInt(val: ia) ->
      if let LirAtomInt(val: ib) = rhs then
        return opt_fold_int_binary(op, a: ia, b: ib)
      else
        return None
      end
    | LirAtomBool(val: ba) ->
      if let LirAtomBool(val: bb) = rhs then
        return opt_fold_bool_binary(op, a: ba, b: bb)
      else
        return None
      end
    | LirAtomString(val: sa) ->
      if let LirAtomString(val: sb) = rhs then
        return opt_fold_str_binary(op, a: sa, b: sb)
      else
        return None
      end
    | LirAtomChar(val: ca) ->
      if let LirAtomChar(val: cb) = rhs then
        return opt_fold_char_binary(op, a: ca, b: cb)
      else
        return None
      end
    | _ -> return None
  end
end

// ─── Identity / Absorbing Element Simplification ────────────────────────────

let opt_simplify_binary = fn (op: BinaryOp, lhs: LirAtom, rhs: LirAtom) -> Option<LirAtom> do
  match op do
    | OpAdd ->
      match lhs do
        | LirAtomInt(val: 0) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomInt(val: 0) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | OpSub ->
      match rhs do
        | LirAtomInt(val: 0) -> return Some(val: lhs)
        | _ -> return None
      end
    | OpMul ->
      match lhs do
        | LirAtomInt(val: 0) -> return Some(val: LirAtomInt(val: 0))
        | LirAtomInt(val: 1) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomInt(val: 0) -> return Some(val: LirAtomInt(val: 0))
            | LirAtomInt(val: 1) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | OpDiv ->
      match rhs do
        | LirAtomInt(val: 1) -> return Some(val: lhs)
        | _ -> return None
      end
    | OpAnd ->
      match lhs do
        | LirAtomBool(val: false) -> return Some(val: LirAtomBool(val: false))
        | LirAtomBool(val: true) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomBool(val: false) -> return Some(val: LirAtomBool(val: false))
            | LirAtomBool(val: true) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | OpOr ->
      match lhs do
        | LirAtomBool(val: true) -> return Some(val: LirAtomBool(val: true))
        | LirAtomBool(val: false) -> return Some(val: rhs)
        | _ ->
          match rhs do
            | LirAtomBool(val: true) -> return Some(val: LirAtomBool(val: true))
            | LirAtomBool(val: false) -> return Some(val: lhs)
            | _ -> return None
          end
      end
    | _ -> return None
  end
end

export let opt_fold_expr = fn (expr: LirExpr) -> LirExpr do
  if let LirExprBinary(op, lhs: l, rhs: r, typ: _) = expr then
    match opt_try_fold_binary(op, lhs: l, rhs: r) do
      | Some(val: result) -> return LirExprAtom(atom: result)
      | None ->
        match opt_simplify_binary(op, lhs: l, rhs: r) do
          | Some(val: result) -> return LirExprAtom(atom: result)
          | None -> return expr
        end
    end
  end
  return expr
end
