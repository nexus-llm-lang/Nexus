/**
 * package: package-based module resolver (parallels bootstrap/src/lang/package.rs).
 *
 * Maps `pkg:path` import strings to physical files and to WASM
 * component-model WIT interface names.
 *
 * Example: `std:stdio` resolves to `nxlib/stdlib/stdio.nx` and to the
 * WIT name `nexus:std/stdio`.
 *
 * Bare paths (no `:`) flow through unchanged so legacy file-relative
 * imports continue to work during migration.
 */

import * as str from "std:str"

// Fixed namespace for all Nexus packages in the WIT component-model.
let wit_namespace = "nexus"

// Default name of the standard-library package.
let std_package = "std"

// Default root directory for the `std` package (relative to cwd).
let std_package_root = "nxlib/stdlib"

let nx_ext = "nx"

/// Result of splitting a `pkg:path` import. Empty `pkg` indicates the input
/// had no `:` separator (or one side was empty).
export type Split = Split(pkg: string, rest: string)

/// Split a `pkg:path` import into its components.
export let split_qualified = fn (path: string) -> Split throws { Exn } do
  let colon_pos = str.index_of(s: path, sub: ":")
  if colon_pos < 0 then return Split(pkg: "", rest: "") end
  let pkg = str.substring(s: path, start: 0, len: colon_pos)
  let rest_start = colon_pos + 1
  let rest = str.substring(s: path, start: rest_start, len: str.byte_length(s: path) - rest_start)
  if str.length(s: pkg) == 0 then return Split(pkg: "", rest: "") end
  if str.length(s: rest) == 0 then return Split(pkg: "", rest: "") end
  return Split(pkg, rest)
end

/// Returns the physical root directory for a registered package, or "" when unknown.
export let package_root = fn (pkg: string) -> string throws { Exn } do
  if pkg == std_package then return std_package_root end
  return ""
end

/// True when `pkg` is a registered package.
export let is_known_package = fn (pkg: string) -> bool throws { Exn } do
  return str.length(s: package_root(pkg)) > 0
end

/// Strip a trailing `.nx` extension if present.
let strip_nx_ext = fn (s: string) -> string throws { Exn } do
  let suffix = "." ++ nx_ext
  if str.ends_with(s, suffix) then
    let n = str.byte_length(s) - str.byte_length(s: suffix)
    return str.substring(s, start: 0, len: n)
  end
  return s
end

/// Resolve a `pkg:path` import to its physical `.nx` filesystem path. Returns
/// the empty string for unqualified or unknown-package paths.
export let resolve_qualified_to_file = fn (path: string) -> string throws { Exn } do
  let Split(pkg, rest) = split_qualified(path)
  if str.length(s: pkg) == 0 then return "" end
  let root = package_root(pkg)
  if str.length(s: root) == 0 then return "" end
  let stripped = strip_nx_ext(s: rest)
  return root ++ "/" ++ stripped ++ "." ++ nx_ext
end

/// Resolve a `pkg:path` import to its WIT module name (`nexus:pkg/path`).
/// Returns the empty string for unqualified paths.
export let resolve_qualified_to_wit = fn (path: string) -> string throws { Exn } do
  let Split(pkg, rest) = split_qualified(path)
  if str.length(s: pkg) == 0 then return "" end
  let stripped = strip_nx_ext(s: rest)
  // Already a `namespace:pkg/iface` WIT name — leave it alone.
  if str.contains(s: stripped, sub: "/") then return path end
  return wit_namespace ++ ":" ++ pkg ++ "/" ++ stripped
end

/// Resolve any import path. Qualified paths flow through the package resolver;
/// bare paths are returned unchanged so legacy file-relative imports continue
/// to work during migration.
export let resolve_import_path = fn (path: string) -> string throws { Exn } do
  let physical = resolve_qualified_to_file(path)
  if str.length(s: physical) > 0 then return physical end
  return path
end

/// Path to a package's bundled WASM artifact (used by the WASM merger to
/// resolve `nexus:<pkg>/...` imports against `<root>/stdlib.wasm`).
export let package_wasm_path = fn (pkg: string) -> string throws { Exn } do
  let root = package_root(pkg)
  if str.length(s: root) == 0 then return "" end
  return root ++ "/stdlib.wasm"
end
