/**
 * mir_types: MIR type definitions for the Nexus self-hosting compiler.
 *
 * Pure data types extracted from mir.nx. No logic, no helpers.
 *
 * Also hosts the port-call resolution side-records (NamePair, PortEntry,
 * PortCallResult) and the MIR lowering context (MirCtx) so that the
 * mir/port.nx submodule can reference them without a circular import back
 * into mir.nx.
 */

import { Span } from "src/common/token.nx"
import { Sigil, BinaryOp, Literal, TypeExpr } from "src/common/ast.nx"
import { HirFunction, HirHandlerBindingEntry, HirExternal } from "src/ir/hir_types.nx"

// ─── MIR Types ───────────────────────────────────────────────────────────────

export type MirParam = MirParam(label: string, name: string, typ: TypeExpr)

export type MirExternal = MirExternal(
  name: string,
  wasm_module: string,
  wasm_name: string,
  params: [MirParam],
  ret_type: TypeExpr,
  throw_row: TypeExpr
)

export type MirFunction = MirFunction(
  name: string,
  params: [MirParam],
  ret_type: TypeExpr,
  body: [MirStmt],
  span: Span
)

export type MirCallArg = MirCallArg(label: string, value: MirExpr)

export type MirExpr =
  MirLiteral(lit: Literal)
  | MirVariable(name: string)
  | MirBinaryOp(left: MirExpr, op: BinaryOp, right: MirExpr)
  | MirCall(func: string, args: [MirCallArg], ret_type: TypeExpr)
  | MirConstructor(name: string, args: [MirExpr])
  | MirRecord(fields: [MirNamedExpr])
  | MirArray(elems: [MirExpr])
  | MirIndex(target: MirExpr, index: MirExpr)
  | MirFieldAccess(target: MirExpr, field: string)
  | MirIf(cond: MirExpr, then_body: [MirStmt], else_body: Option<[MirStmt]>)
  | MirMatch(target: MirExpr, cases: [MirMatchCase])
  | MirWhile(cond: MirExpr, body: [MirStmt])
  | MirBorrow(name: string)
  | MirRaise(expr: MirExpr)
  | MirForce(expr: MirExpr)
  | MirMakeClosure(func_name: string, captures: [MirExpr])
  | MirCallClosure(closure: MirExpr, args: [MirCallArg], ret_type: TypeExpr)
  | MirEnvLoad(env_var: string, index: i64)

export type MirNamedExpr = MirNamedExpr(name: string, value: MirExpr)

export type MirStmt =
  MirStmtLet(name: string, typ: TypeExpr, expr: MirExpr)
  | MirStmtExpr(expr: MirExpr)
  | MirStmtReturn(expr: MirExpr)
  | MirStmtAssign(target: MirExpr, value: MirExpr)
  | MirStmtTry(body: [MirStmt], catch_param: string, catch_body: [MirStmt])

export type MirMatchCase = MirMatchCase(pattern: MirPattern, body: [MirStmt])

export type MirPattern =
  MirPatLiteral(lit: Literal)
  | MirPatVariable(name: string, sigil: Sigil)
  | MirPatConstructor(name: string, fields: [MirPatternField])
  | MirPatRecord(fields: [MirRecordPatField], is_partial: bool)
  | MirPatWildcard
  // Or-pattern: matches if any alternative matches. Expanded into multiple
  // pattern-matrix rows during decision-tree construction.
  | MirPatOr(alts: [MirPattern])

export type MirPatternField = MirPatternField(name: Option<string>, pattern: MirPattern)

export type MirRecordPatField = MirRecordPatField(name: string, pattern: MirPattern)

export type MirProgram = MirProgram(functions: [MirFunction], externals: [MirExternal])

// ─── Port-Call Resolution Side-Records ──────────────────────────────────────

export type NamePair = NamePair(key: string, value: string)

export type PortEntry = PortEntry(name: string, prefix: string, methods: [string])

export type PortCallResult = PortCallFound(port_name: string, method_name: string) | PortCallNotFound

// ─── MIR Lowering Context ───────────────────────────────────────────────────

/// Bundles the 8 threading parameters into a single context record.
/// `closure_counter` + `lifted_funcs` are mutated during lambda lifting:
/// each inline `fn (...)` expression bumps the counter and appends a new
/// top-level MirFunction named `__closure_<N>` to lifted_funcs.
export type MirCtx = MirCtx(
  scope: [NamePair],
  port_layouts: [PortEntry],
  handler_port_names: [NamePair],
  all_funcs: [HirFunction],
  all_handlers: [HirHandlerBindingEntry],
  all_exts: [HirExternal],
  closure_counter: i64,
  lifted_funcs: [MirFunction]
)

// ─── Lambda-lifting result types (ctx-threaded lowering) ─────────────────────

/// Result of lowering a HIR expression; carries an updated ctx so that
/// Lambda lifting can accumulate new lifted functions and bump the counter.
export type MirExprResult = MirExprResult(ctx: MirCtx, expr: MirExpr)

/// Result of lowering a list of HIR statements.
export type MirStmtsResult = MirStmtsResult(ctx: MirCtx, stmts: [MirStmt])

/// Result of lowering a list of HIR call args.
export type MirCallArgsResult = MirCallArgsResult(ctx: MirCtx, args: [MirCallArg])

/// Result of lowering a list of HIR expressions (e.g. ctor args / array elems).
export type MirExprListResult = MirExprListResult(ctx: MirCtx, exprs: [MirExpr])

/// Result of lowering a list of HIR named expressions (record fields).
export type MirNamedExprsResult = MirNamedExprsResult(ctx: MirCtx, exprs: [MirNamedExpr])

/// Result of lowering a list of HIR match cases.
export type MirMatchCasesResult = MirMatchCasesResult(ctx: MirCtx, cases: [MirMatchCase])

/// Result of lowering a list of HIR top-level functions (ctx carries any
/// lifted `__closure_*` funcs accumulated while lowering their bodies).
export type LowerFunctionsResult = LowerFunctionsResult(ctx: MirCtx, funcs: [MirFunction])

/// Result of lowering a single HIR function body.
export type LowerFunctionResult = LowerFunctionResult(ctx: MirCtx, func: MirFunction)
