/**
 * variant_index: pre-built O(1) lookup from variant-constructor name to its
 * defining enum + field shape.
 *
 * Replaces the recursive list scan that was duplicated in
 * `typecheck/types.nx::find_variant_in_list` and
 * `ir/lir/match_tree.nx::lookup_variant_def`. The original scans were called
 * per pattern node during type checking and decision-tree construction;
 * cost was O(N_enums * variants_per_enum) per pattern.
 *
 * Build the index once per program (where the `enums` table becomes
 * available) and re-use across all callers. The shape carries both
 * `VariantDef` (for the LIR path which only needs name + fields) and
 * the owning enum's name + type parameters (for the typecheck path which
 * produces `EnumVariantInfo`).
 *
 * Disambiguation: variant names are globally unique across enums in
 * surface Nexus, so a flat `variant_name -> VariantInfo` map suffices.
 * On collision the first-defined variant wins (mirrors the previous
 * list-scan first-match semantics).
 */

import { EnumDef, VariantDef, RecordDef, TypeExpr, TyUserDefined, TyRecord } from "src/types/type_expr.nx"
import { Map }, * as map from "std:collection/map"
import { Pair } from "std:tuple"
import { Option, Some, None } from "std:option"
import * as list from "std:list"

// `enum_name` / `type_params` mirror the owning EnumDef. `def` is the
// raw VariantDef (with its field list) so callers that only need
// arity / fields don't have to re-scan.
/** Public type VariantInfo. */
export type VariantInfo = VariantInfo(enum_name: string, type_params: [ string ], def: VariantDef)

// `record_defs` is the program's record-type-alias table, carried alongside
// the variant map so the LIR match-tree path can resolve a constructor
// field's declared `TyUserDefined("R", …)` to its `TyRecord` body when binding
// the field to a variable. The typecheck builders leave this
// empty — they never resolve record aliases through this index — so existing
// callers are unaffected.
//
// `opaque_layouts` is a LAYOUT-ONLY fallback map (variant name → VariantInfo)
// populated from each `EnumDef.layout_variants`. For an opaque
// imported enum the `variants` were stripped to `[]` (D-Type-Sum-Opaque), so
// `by_variant` has no entry; the field DECLARATION order it needs for the
// alphabetical heap layout survives only here. `lookup_variant_def_in_index`
// (LIR field-extraction only) consults this when `by_variant` misses, so the
// layout never reaches typecheck's `lookup_variant_info` (visibility /
// exhaustiveness / constructor-registration stay opaque). Empty for every enum
// whose constructors are NOT withheld, since `by_variant` already covers them.
/** Public type VariantIndex. */
export type VariantIndex = VariantIndex(
  by_variant: Map<string, VariantInfo>,
  record_defs: [ RecordDef ],
  opaque_layouts: Map<string, VariantInfo>
)

let insert_variants = fn (
  acc: Map<string, VariantInfo>,
  enum_name: string,
  type_params: [ string ],
  variants: [ VariantDef ]
) -> Map<string, VariantInfo> do
  match variants do
    | [] -> return acc
    | vd :: rest ->
      let VariantDef(name: vn, fields: _) = vd
      let next = match map.get(m: acc, k: vn) do
          | Some(_) -> acc
          | None -> map.insert(m: acc, k: vn, v: VariantInfo(enum_name, type_params, def: vd))
        end
        return insert_variants(acc: next, enum_name, type_params, variants: rest)
  end
end

// Insert each enum's `variants` into the public `by_variant` map (unchanged
// shape — a bare-map accumulator, never a record holding the map, so the
// dictionary-passing fn fields the Map carries stay intact through codegen).
let build_go = fn (defs: [ EnumDef ], acc: Map<string, VariantInfo>) -> Map<string, VariantInfo> do
  match defs do
    | [] -> return acc
    | ed :: rest ->
      let EnumDef(name: ename, is_public: _, is_opaque: _, type_params: tps, variants: vs, layout_variants: _) = ed
      let acc2 = insert_variants(acc, enum_name: ename, type_params: tps, variants: vs)
        return build_go(defs: rest, acc: acc2)
  end
end

// Independent pass that fills the LAYOUT-ONLY fallback from each enum's
// `layout_variants` (non-empty only for an opaque imported enum whose
// `variants` were stripped). Kept SEPARATE from `build_go` so neither map is
// ever stored in a record field.
let build_layouts_go = fn (defs: [ EnumDef ], acc: Map<string, VariantInfo>) -> Map<string, VariantInfo> do
  match defs do
    | [] -> return acc
    | ed :: rest ->
      let EnumDef(name: ename, is_public: _, is_opaque: _, type_params: tps, variants: _, layout_variants: lvs) = ed
      let acc2 = insert_variants(acc, enum_name: ename, type_params: tps, variants: lvs)
        return build_layouts_go(defs: rest, acc: acc2)
  end
end

/** Public function build_variant_index. */
export let build_variant_index = fn (defs: [ EnumDef ]) -> VariantIndex do
  return VariantIndex(
    by_variant: build_go(defs, acc: map.string_map()),
    record_defs: [],
    opaque_layouts: build_layouts_go(defs, acc: map.string_map())
  )
end

/** Direct path that consumes an `EnumDef` stream lazily without first
 *  materialising it; mirrors `build_variant_index` but threads a starting
 *  map so the typecheck builder can pre-seed with built-ins via a single
 *  chained call from the unwrapped `[EnumEntry]`.
 */
export let extend_variant_index = fn (idx: VariantIndex, defs: [ EnumDef ]) -> VariantIndex do
  let VariantIndex(by_variant: m, record_defs: rds, opaque_layouts: ol) = idx
  return VariantIndex(
    by_variant: build_go(defs, acc: m),
    record_defs: rds,
    opaque_layouts: build_layouts_go(defs, acc: ol)
  )
end

/** Public function empty_variant_index. */
export let empty_variant_index = fn () -> VariantIndex do
  return VariantIndex(by_variant: map.string_map(), record_defs: [], opaque_layouts: map.string_map())
end

/** Attach the program's record-type-alias table to an existing index so the
 *  LIR path can expand `TyUserDefined` field types to their `TyRecord` body
 **/
export let with_record_defs = fn (idx: VariantIndex, record_defs: [ RecordDef ]) -> VariantIndex do
  let VariantIndex(by_variant: m, record_defs: _, opaque_layouts: ol) = idx
  return VariantIndex(by_variant: m, record_defs, opaque_layouts: ol)
end

let lookup_record_def_in_index = fn (defs: [ RecordDef ], name: string) -> Option<RecordDef> do
  match defs do
    | [] -> return None
    | RecordDef(name: n, is_public: p, type_params: tps, fields: fs) :: rest ->
      if n == name then
        return Some(val: RecordDef(name: n, is_public: p, type_params: tps, fields: fs))
      end
      return lookup_record_def_in_index(defs: rest, name)
  end
end

/** Resolve a named record-alias type (`TyUserDefined("R", …)`) to its
 *  `TyRecord` body using the index's record-def table. Resolves transitively
 *  (alias-of-alias) and leaves non-record / unknown types unchanged. */
export let resolve_record_alias = fn (idx: VariantIndex, typ: TypeExpr) -> TypeExpr do
  if let TyUserDefined(name: n, args: _) = typ then
    let VariantIndex(by_variant: _, record_defs: rds, opaque_layouts: _) = idx
    match lookup_record_def_in_index(defs: rds, name: n) do
      | Some(val: RecordDef(name: _, is_public: _, type_params: _, fields)) ->
        return TyRecord(fields)
      | None -> return typ
    end
  else
    return typ
  end
end

/** Public function lookup_variant_info.
 *  Consults ONLY `by_variant` — opaque imported constructors are intentionally
 *  absent here so typecheck visibility / exhaustiveness stay opaque. */
export let lookup_variant_info = fn (idx: VariantIndex, variant: string) -> Option<VariantInfo> do
  let VariantIndex(by_variant: m, record_defs: _, opaque_layouts: _) = idx
  return map.get(m, k: variant)
end

/** Return the owning enum name for a constructor, or `None` when the
 *  constructor is unknown / opaque. Used by the LIR structural-equality
 *  lowering to recover a sum value's type from its constructor application. */
export let enum_name_of_variant = fn (idx: VariantIndex, variant: string) -> Option<string> do
  match lookup_variant_info(idx, variant) do
    | Some(val: VariantInfo(enum_name: en, type_params: _, def: _)) -> return Some(val: en)
    | None -> return None
  end
end

let filter_variants_by_enum = fn (
  pairs: [ Pair<string, VariantInfo> ],
  enum_name: string,
  acc: [ VariantDef ]
) -> [ VariantDef ] do
  match pairs do
    | [] -> return list.reverse(xs: acc)
    | Pair(left: _, right: VariantInfo(enum_name: en, type_params: _, def: vd)) :: rest ->
      if en == enum_name then
        return filter_variants_by_enum(pairs: rest, enum_name, acc: vd :: acc)
      else
        return filter_variants_by_enum(pairs: rest, enum_name, acc)
      end
  end
end

/** All constructor `VariantDef`s belonging to `enum_name`, drawn from the
 *  public `by_variant` map. Order is unspecified (map-iteration order); callers
 *  that branch on a runtime tag do not depend on order. Empty for an opaque
 *  imported enum whose constructors were stripped (the LIR structural-eq path
 *  treats an empty variant list as "no structural compare available" and falls
 *  back to identity comparison, matching the typecheck-opaque contract). */
export let variants_of_enum = fn (idx: VariantIndex, enum_name: string) -> [ VariantDef ] do
  let VariantIndex(by_variant: m, record_defs: _, opaque_layouts: _) = idx
  return filter_variants_by_enum(pairs: map.iterate(m), enum_name, acc: [])
end

/** Public function lookup_variant_def_in_index.
 *  LIR field-extraction path: falls back to the LAYOUT-ONLY `opaque_layouts`
 *  map when `by_variant` misses, so an opaque imported constructor's field
 *  DECLARATION order is recoverable for the alphabetical heap layout
 *This is the only lookup that sees the stripped layout. */
export let lookup_variant_def_in_index = fn (
  idx: VariantIndex,
  variant: string
) -> Option<VariantDef> do
  match lookup_variant_info(idx, variant) do
    | Some(val: VariantInfo(enum_name: _, type_params: _, def: vd)) -> return Some(val: vd)
    | None ->
      let VariantIndex(by_variant: _, record_defs: _, opaque_layouts: ol) = idx
      match map.get(m: ol, k: variant) do
        | None -> return None
        | Some(val: VariantInfo(enum_name: _, type_params: _, def: vd)) -> return Some(val: vd)
      end
  end
end
