/**
 * naming: conventional-name mangling for handler functions.
 *
 * Owns:
 * - The `__handler_<binding>_<method>` mangling used by cap-call lowering
 *   (src/ir/mir/cap.nx) and by reachability filtering (src/ir/hir/reachability.nx).
 *
 * Does not own:
 * - Any other name conventions (top-level qualification, module-path sanitizing,
 *   etc. — see src/ir/rdrname.nx for those).
 */
import * as bb from "std:bytebuffer"
import * as str from "std:str"

/** Public function handler_func_name. */
export let handler_func_name = fn (handler_name: string, method_name: string) -> string do
  return bb.concat(parts: [ "__handler_", handler_name, "_", method_name ])
end

/** Public function handler_prefix_len. */
export let handler_prefix_len = fn (handler_name: string) -> i64 do
  return str.length(s: bb.concat(parts: [ "__handler_", handler_name, "_" ]))
end

/** Mangled name of the runtime dispatcher generated for `cap_name.method_name`
 *  when the cap has two or more handler bindings. The dispatcher reads the cap's
 *  handler-register slot and forwards to the active `__handler_*` method. */
export let cap_dispatch_func_name = fn (cap_name: string, method_name: string) -> string do
  return bb.concat(parts: [ "__dispatch_", cap_name, "_", method_name ])
end
