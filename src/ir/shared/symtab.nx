/**
 * symtab: Rename-table machinery used during import resolution.
 *
 * Despite the historical name, this module no longer provides a scoped
 * symbol table — only the RenameEntry list and helpers that the resolver
 * uses to rewrite RdrNames into their canonical (qualified) form.
 */

import * as str from "std:str"

/** Public type RenameEntry. */
export type RenameEntry = RenameEntry(original: string, qualified: string)

/** Looks up `name` in the rename table (produced at import time) and returns
 *  the qualified form. If no entry matches, returns `name` unchanged.
 *
 *  Passthrough is load-bearing: local identifiers, primitive keywords
 *  (`if`/`then`), and builtin types (`i64`/`string`/`unit`/`Exn`) never appear
 *  in the rename table and must remain literal. Name-resolution failures for
 *  misspelled or truly undefined identifiers surface later during typecheck
 *  (env_lookup returns None → "unbound function" / TypeMismatch), which has
 *  access to the HIR span for a meaningful diagnostic. Raising here would be
 *  premature — this pass doesn't know the difference between "builtin" and
 *  "typo" — so the invariant is: every definitely-unknown name is caught by
 *  typecheck before it reaches codegen.
 */
export let rename = fn (name: string, entries: [ RenameEntry ]) -> string do
  match rename_direct(name, entries) do
    | Some(val: q) -> return q
    | None -> return rename_prefix(name, entries, best_idx: -1)
  end
end

let rename_direct = fn (name: string, entries: [ RenameEntry ]) -> Option<string> do
  match entries do
    | [] -> return None
    | RenameEntry(original: orig, qualified: qual) :: rest ->
      if orig == name then return Some(val: qual)
      else return rename_direct(name, entries: rest)
      end
  end
end

/** Longest-prefix rename on '.': if name has form "X.Y" and "X" is in
 *  entries, return "qualified(X).Y". Scans for the longest matching X.
 */
let rename_prefix = fn (name: string, entries: [ RenameEntry ], best_idx: i64) -> string do
  let len = str.length(s: name)
  let idx = find_best_dot(name, entries, i: 0, len, best: -1)
  if idx < 0 then return name end
  let prefix = str.substring(s: name, start: 0, len: idx)
  let suffix = str.substring(s: name, start: idx + 1, len: len - idx - 1)
  match rename_direct(name: prefix, entries) do
    | Some(val: q) -> return q ++ "." ++ suffix
    | None -> return name
  end
end

let find_best_dot = fn (
  name: string,
  entries: [ RenameEntry ],
  i: i64,
  len: i64,
  best: i64
) -> i64 do
  if i >= len then return best end
  if str.char_code(s: name, idx: i) == 46 then
    let prefix = str.substring(s: name, start: 0, len: i)
    match rename_direct(name: prefix, entries) do
      | Some(_) -> return find_best_dot(name, entries, i: i + 1, len, best: i)
      | None -> return find_best_dot(name, entries, i: i + 1, len, best)
    end
  end
  return find_best_dot(name, entries, i: i + 1, len, best)
end

/** Public function rename_add. */
export let rename_add = fn (
  entries: [ RenameEntry ],
  original: string,
  qualified: string
) -> [ RenameEntry ] do
  return RenameEntry(original, qualified) :: entries
end

/** Public function rename_has. */
export let rename_has = fn (name: string, entries: [ RenameEntry ]) -> bool do
  match entries do
    | [] -> return false
    | RenameEntry(original: orig, qualified: _) :: rest ->
      if orig == name then return true
      else return rename_has(name, entries: rest)
      end
  end
end

let rename_drop_go = fn (
  name: string,
  entries: [ RenameEntry ],
  acc: [ RenameEntry ]
) -> [ RenameEntry ] do
  match entries do
    | [] -> return acc
    | RenameEntry(original: orig, qualified: q) :: rest ->
      if orig == name then return rename_drop_go(name, entries: rest, acc)
      else return rename_drop_go(
        name,
        entries: rest,
        acc: RenameEntry(original: orig, qualified: q) :: acc
      )
      end
  end
end

/** Drop every entry whose `original` matches `name` from the rename map.
 *  Used to implement lexical shadowing: when a fn parameter or local `let`
 *  introduces an identifier, any toplevel-scope rename for that identifier
 *  must be hidden inside the binding's scope so the identifier resolves to
 *  the local (raw name) at codegen, not to the toplevel canonical form.
 */
export let rename_drop = fn (entries: [ RenameEntry ], name: string) -> [ RenameEntry ] do
  return rename_drop_go(name, entries, acc: [])
end

let rename_drop_many_go = fn (entries: [ RenameEntry ], names: [ string ]) -> [ RenameEntry ] do
  match names do
    | [] -> return entries
    | n :: rest -> return rename_drop_many_go(entries: rename_drop(entries, name: n), names: rest)
  end
end

/** Drop every entry whose `original` matches any of `names`. */
export let rename_drop_many = fn (entries: [ RenameEntry ], names: [ string ]) -> [ RenameEntry ] do
  return rename_drop_many_go(entries, names)
end
