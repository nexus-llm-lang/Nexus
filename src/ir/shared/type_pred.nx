/**
 * ir/shared/type_pred: Canonical TypeExpr predicates shared across passes.
 *
 * Consolidates predicates that were previously duplicated in
 * `typecheck/tcwf.nx`, `typecheck/linearity.nx`,
 * `typecheck/exhaustive/signatures.nx`, and
 * `typecheck/infer/statements.nx`.
 *
 * Exported surface:
 *   is_linear            — true iff typ is `%τ` (TyLinear)
 *   strip_mod            — strip any leading %/@/&/~ modality wrappers
 *   is_auto_droppable    — true for primitives and (recursively) their wrappers
 *   is_linear_binding_type — structural linearity probe over record typedefs
 */

import {
  TypeExpr, TyLinear, TyLazy, TyBorrow, TyRef,
  TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit,
  TyList, TyRecord,
  TyUserDefined,
  NamedType, RecordDef
} from "src/common/ast.nx"
import { Option, Some, None } from "std:option"


/** True iff `typ` is `%τ` (TyLinear). The spec's `linear` predicate used in
 *  `wfRef(~σ) ⟺ ¬linear(σ)`.
 */
export let is_linear = fn (typ: TypeExpr) -> bool do
  match typ do
    | TyLinear(_) -> return true
    | _ -> return false
  end
end


/** Strip leading modality wrappers `%`/`@`/`&`/`~` from a type, returning
 *  the innermost non-modal type. Identity on already-bare types.
 */
export let strip_mod = fn (typ: TypeExpr) -> TypeExpr do
  match typ do
    | TyLinear(inner: t) | TyLazy(inner: t)
    | TyBorrow(inner: t) | TyRef(inner: t) -> return strip_mod(typ: t)
    | _ -> return typ
  end
end


/** True when `t` is "auto-droppable" — primitive scalars and unit drop
 *  silently at scope end. Wrappers `%`/`&`/`~` peel and recurse; `@T` is
 *  NOT auto-droppable (forcing triggers side effects).
 *
 *  Note: arrays `[|σ|]` are NOT auto-droppable here; per-binding lint treats
 *  them as composites.
 */
export let is_auto_droppable = fn (t: TypeExpr) -> bool do
  match t do
    | TyI32 | TyI64 | TyF32 | TyF64
    | TyIntLit | TyFloatLit
    | TyBool | TyChar | TyString | TyUnit -> return true
    | TyLazy(_) -> return false
    | TyLinear(inner: i) | TyBorrow(inner: i) | TyRef(inner: i) -> return is_auto_droppable(t: i)
    | _ -> return false
  end
end


/** True when `t` carries linearity that must be tracked: `%T` (Linear), `@T`
 *  (Lazy — one-shot continuation). Per spec type-system-formal.md §Linearity
 *  "Linearity is entirely structural", so we recurse through `~τ` (TyRef) /
 *  `&τ` (TyBorrow) wrappers, `TyRecord` field lists, and `TyUserDefined`
 *  record-typedef field lists. The per-binding lint deliberately ignores array
 *  containment — arrays of plain values are auto-droppable — so `TyArray` is
 *  not traversed here.
 *
 *  Cycle handling: uses a visited set V (minimum fixpoint, per spec
 *  type-system-formal.md §Linearity lines 365-381).
 */
export let is_linear_binding_type = fn (t: TypeExpr, tdefs: [RecordDef]) -> bool do
  return is_linear_binding_type_visited(t, tdefs, visited: [])
end

let is_linear_binding_type_visited = fn (t: TypeExpr, tdefs: [RecordDef], visited: [string]) -> bool do
  match t do
    // Spec line 350: %σ, @σ are linear by the outermost-wrapper clause.
    | TyLinear(inner: _) | TyLazy(inner: _) -> return true
    // Spec line 376: wrapper-step threads V unchanged (no nominal unfold here).
    | TyRef(inner: i) | TyBorrow(inner: i) -> return is_linear_binding_type_visited(t: i, tdefs, visited)
    | TyList(elem: e) -> return is_linear_binding_type_visited(t: e, tdefs, visited)
    | TyRecord(fields: fs) -> return any_named_type_linear(fields: fs, tdefs, visited)
    | TyUserDefined(name: n, args: _) ->
      // Spec line 372: x ∈ V → false (minimum fixpoint base case).
      if str_member(xs: visited, target: n) then return false end
      match lin_typedef_lookup(defs: tdefs, name: n) do
        | Some(val: RecordDef(name: _, is_public: _, type_params: _, fields: rec_fields)) ->
          // Spec line 373: recurse into unfolded body with V ∪ {x}.
          return any_named_type_linear(fields: rec_fields, tdefs, visited: n :: visited)
        | None -> return false
      end
    | _ -> return false
  end
end

let any_named_type_linear = fn (fields: [NamedType], tdefs: [RecordDef], visited: [string]) -> bool do
  match fields do
    | [] -> return false
    | NamedType(name: _, typ: ft) :: rest ->
      if is_linear_binding_type_visited(t: ft, tdefs, visited) then return true end
      return any_named_type_linear(fields: rest, tdefs, visited)
  end
end

let lin_typedef_lookup = fn (defs: [RecordDef], name: string) -> Option<RecordDef> do
  match defs do
    | [] -> return None
    | RecordDef(name: n, is_public: ip, type_params: tp, fields: f) :: rest ->
      if n == name then return Some(val: RecordDef(name: n, is_public: ip, type_params: tp, fields: f)) end
      return lin_typedef_lookup(defs: rest, name)
  end
end

let str_member = fn (xs: [string], target: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == target then return true end
      return str_member(xs: rest, target)
  end
end
