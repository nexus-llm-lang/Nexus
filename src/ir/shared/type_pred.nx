/**
 * ir/shared/type_pred: Canonical TypeExpr predicates shared across passes.
 *
 * Consolidates predicates that were previously duplicated in
 * `typecheck/tcwf.nx`, `typecheck/linearity.nx`,
 * `typecheck/exhaustive/signatures.nx`, and
 * `typecheck/infer/statements.nx`.
 *
 * Exported surface:
 *   is_linear            — true iff typ is `%τ` (TyLinear)
 *   strip_mod            — strip any leading %/@/&/~ modality wrappers
 *   is_auto_droppable    — true for primitives and (recursively) their wrappers
 *   is_linear_binding_type — structural linearity probe over record typedefs
 */

import {
  TypeExpr, TyLinear, TyLazy, TyBorrow, TyRef, TyArray,
  TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit,
  TyList, TyRecord,
  TyUserDefined,
  NamedType, RecordDef, EnumDef, VariantDef, VariantField
} from "src/common/ast.nx"
import { Option, Some, None } from "std:option"

/** True iff `typ` is `%τ` (TyLinear) at the outermost level only.
 *  This is NOT the spec's structural `linear` predicate used in
 *  `wfRef(~σ) ⟺ ¬linear(σ)` — use `is_linear_binding_type` for that.
 */
export let is_linear = fn (typ: TypeExpr) -> bool do
  match typ do
    | TyLinear(_) -> return true
    | _ -> return false
  end
end

/** Strip leading modality wrappers `%`/`@`/`&`/`~` from a type, returning
 *  the innermost non-modal type. Identity on already-bare types.
 */
export let strip_mod = fn (typ: TypeExpr) -> TypeExpr do
  match typ do
    | TyLinear(inner: t) | TyLazy(inner: t, require_row: _, throw_row: _)
    | TyBorrow(inner: t) | TyRef(inner: t) -> return strip_mod(typ: t)
    | _ -> return typ
  end
end

/** True when `t` is "auto-droppable" — primitive scalars and unit drop
 *  silently at scope end. Wrappers `%`/`&`/`~` peel and recurse; `@T` is
 *  NOT auto-droppable (forcing triggers side effects).
 *
 *  Note: arrays `[|σ|]` are NOT auto-droppable here; per-binding lint treats
 *  them as composites.
 */
export let is_auto_droppable = fn (t: TypeExpr) -> bool do
  match t do
    | TyI32 | TyI64 | TyF32 | TyF64
    | TyIntLit | TyFloatLit
    | TyBool | TyChar | TyString | TyUnit -> return true
    | TyLazy(_) -> return false
    | TyLinear(inner: i) | TyBorrow(inner: i) | TyRef(inner: i) -> return is_auto_droppable(t: i)
    | _ -> return false
  end
end

/** True when `t` carries linearity that must be tracked: `%T` (Linear), `@T`
 *  (Lazy — one-shot continuation). Per spec type-system-formal.md §Linearity
 *  "Linearity is entirely structural", so we recurse through `~τ` (TyRef) /
 *  `&τ` (TyBorrow) wrappers, `TyRecord` field lists, `TyUserDefined`
 *  record-typedef and enum-def field lists, and `[|τ|]` (TyArray — always linear).
 *
 *  Cycle handling: uses a visited set V (minimum fixpoint, per spec
 *  type-system-formal.md §Linearity lines 365-381).
 */
export let is_linear_binding_type = fn (
  t: TypeExpr,
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ]
) -> bool do
  return is_linear_binding_type_visited(t, tdefs, enum_defs, visited: [])
end

let is_linear_binding_type_visited = fn (
  t: TypeExpr,
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ],
  visited: [ string ]
) -> bool do
  match t do
    // Spec §1 Modalities: %σ, @σ are linear by the outermost-wrapper clause.
    | TyLinear(inner: _) | TyLazy(inner: _, require_row: _, throw_row: _) -> return true
    // Spec §Linearity: [|σ|] (array) is always linear (q = 1).
    | TyArray(_) -> return true
    // Spec §Linearity (wrapper-step): threads V unchanged (no nominal unfold here).
    | TyRef(inner: i) | TyBorrow(inner: i) -> return is_linear_binding_type_visited(
      t: i,
      tdefs,
      enum_defs,
      visited
    )
    | TyList(elem: e) -> return is_linear_binding_type_visited(t: e, tdefs, enum_defs, visited)
    | TyRecord(fields: fs) -> return any_named_type_linear(fields: fs, tdefs, enum_defs, visited)
    | TyUserDefined(name: n, args: _) ->
      // Spec §Linearity: x ∈ V → false (minimum fixpoint base case).
      if str_member(xs: visited, target: n) then return false end
      let v2 = n :: visited
      match lin_typedef_lookup(defs: tdefs, name: n) do
        | Some(val: RecordDef(name: _, is_public: _, type_params: _, fields: rec_fields)) ->
          // Spec §Linearity: recurse into unfolded record body with V ∪ {x}.
          return any_named_type_linear(fields: rec_fields, tdefs, enum_defs, visited: v2)
        | None ->
          // Not a record typedef; try enum defs — any variant carrying a linear
          // field makes the whole enum type linear.
          return lin_enumdef_any_variant_linear(
            defs: enum_defs,
            name: n,
            tdefs,
            enum_defs2: enum_defs,
            visited: v2
          )
      end
    | _ -> return false
  end
end

let any_named_type_linear = fn (
  fields: [ NamedType ],
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ],
  visited: [ string ]
) -> bool do
  match fields do
    | [] -> return false
    | NamedType(name: _, typ: ft) :: rest ->
      if is_linear_binding_type_visited(t: ft, tdefs, enum_defs, visited) then return true end
      return any_named_type_linear(fields: rest, tdefs, enum_defs, visited)
  end
end

/** Check whether any variant of the enum named `name` has at least one field
 *  whose type is linear. Scans `defs` to find the matching EnumDef.
 */
let lin_enumdef_any_variant_linear = fn (
  defs: [ EnumDef ], name: string, tdefs: [ RecordDef ], enum_defs2: [ EnumDef ], visited: [ string ]
) -> bool do
  match defs do
    | [] -> return false
    | EnumDef(name: dn, is_public: _, is_opaque: _, type_params: _, variants: vs) :: rest ->
      if dn == name then
        return lin_variants_any_linear(variants: vs, tdefs, enum_defs: enum_defs2, visited)
      end
      return lin_enumdef_any_variant_linear(defs: rest, name, tdefs, enum_defs2, visited)
  end
end

let lin_variants_any_linear = fn (
  variants: [ VariantDef ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ], visited: [ string ]
) -> bool do
  match variants do
    | [] -> return false
    | VariantDef(name: _, fields: fs) :: rest ->
      if lin_variant_fields_any_linear(fields: fs, tdefs, enum_defs, visited) then return true end
      return lin_variants_any_linear(variants: rest, tdefs, enum_defs, visited)
  end
end

let lin_variant_fields_any_linear = fn (
  fields: [ VariantField ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ], visited: [ string ]
) -> bool do
  match fields do
    | [] -> return false
    | VariantField(name: _, typ: t) :: rest ->
      // Shallow check: only recognise TyLinear/TyLazy/TyArray as linear at the
      // field-type level, without recursing into nested TyUserDefined enum/record
      // types. Full-depth recursion would pull in e.g. PbField (which contains a
      // PbValue which contains %ByteBuffer) and mark all [PbField] params as
      // linear, breaking code that doesn't clean up on throw paths. We only need
      // to detect the direct `%T` and `@T` wrapping pattern here.
      if lin_field_type_is_shallow_linear(t) then return true end
      return lin_variant_fields_any_linear(fields: rest, tdefs, enum_defs, visited)
  end
end

/** True when `t` is TyLinear, TyLazy, TyArray, or a wrapper (TyRef/TyBorrow)
 *  around one of those — without recursing into TyUserDefined. This shallow
 *  check is used for enum-variant field linearity so that nominal types whose
 *  linearity is only transitive (e.g., PbField → PbValue → %ByteBuffer) do
 *  not propagate to the enum type itself.
 */
let lin_field_type_is_shallow_linear = fn (t: TypeExpr) -> bool do
  match t do
    | TyLinear(_) | TyLazy(_) | TyArray(_) -> return true
    | TyRef(inner: i) | TyBorrow(inner: i) -> return lin_field_type_is_shallow_linear(t: i)
    | _ -> return false
  end
end

let lin_typedef_lookup = fn (defs: [ RecordDef ], name: string) -> Option<RecordDef> do
  match defs do
    | [] -> return None
    | RecordDef(name: n, is_public: ip, type_params: tp, fields: f) :: rest ->
      if n == name then return Some(val: RecordDef(name: n, is_public: ip, type_params: tp, fields: f)) end
      return lin_typedef_lookup(defs: rest, name)
  end
end

let str_member = fn (xs: [ string ], target: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == target then return true end
      return str_member(xs: rest, target)
  end
end
