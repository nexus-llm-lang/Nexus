/**
 * resolve: Name resolution for the Nexus self-hosting compiler.
 *
 * Provides:
 * - build_rename_map: construct rename entries from an import definition
 * - default_alias: extract module stem from import path
 * - register_top_level: populate symbol table from top-level definitions
 * - extract_imports: gather all import definitions
 */
import {
  SpannedTopLevel,
  GlobalLet,
  Cap,
  ImportDef,
  ImportItem,
  EnumDef,
  VariantDef
} from "src/syntax/ast.nx"
import { RenameEntry }, * as symtab from "src/ir/shared/symtab.nx"
import { ImportNotExported } from "src/ir/shared/errors.nx"
import * as str from "std:str"
import * as list from "std:list"
import * as rdr from "src/ir/shared/rdrname.nx"
import * as pkg from "src/ir/shared/package.nx"
import { suggest_names } from "src/diagnostics/levenshtein.nx"
import { Option, Some, None } from "std:option"

let find_last_slash_go = fn (s: string, pos: i64, last: i64) -> i64 do
  if pos >= str.length(s) then return last
  else
    let ch = str.substring(s, start: pos, len: 1)
    if ch == "/" then return find_last_slash_go(s, pos: pos + 1, last: pos)
    else return find_last_slash_go(s, pos: pos + 1, last)
    end
  end
end

/** Extract the module stem from an import path.
 *  e.g., "stdlib/str.nx" -> "string", "foo.nx" -> "foo"
 */
let default_alias = fn (path: string) -> string do
  let slash_pos = find_last_slash_go(s: path, pos: 0, last: -1)
  let start = slash_pos + 1
  let rest = str.substring(s: path, start, len: str.length(s: path) - start)
  let dot_pos = str.index_of(s: rest, sub: ".")
  if dot_pos < 0 then return rest
  else return str.substring(s: rest, start: 0, len: dot_pos)
  end
end

/** Check if name is in the import items list. Returns the visible name (alias or original). */
let find_selected = fn (name: string, items: [ ImportItem ]) -> Option<string> do
  match items do
    | [] -> return None
    | ImportItem(name: item_name, item_alias: alias_opt) :: rest ->
      if item_name == name then
        match alias_opt do
          | Some(val: a) -> return Some(val: a)
          | None -> return Some(val: name)
        end
      else return find_selected(name, items: rest)
      end
  end
end

// route constructors through the import-binding rename map so a
// bare constructor reference resolves to the ctor of the enum that is IN SCOPE
// (the module's own enums via the internal/self view, or selectively/wildcard
// imported enums via the importer view) rather than first/last-wins across the
// flat whole-program variant index.
//
// To stay surgical we canonicalise ONLY constructors whose bare name COLLIDES
// across two or more distinct enums in the whole program (the `colliding` set,
// computed once in build_hir). Non-colliding ctors — the overwhelming majority,
// including every builtin and every re-exported ctor like argparse's
// SubcommandHit — keep their bare name everywhere (rename is identity on miss),
// so legacy whole-program bare visibility and re-export chains are unchanged. A
// colliding ctor maps its in-scope name to the defining module's canonical ctor
// name `source#Variant`; the stored EnumDef variants are renamed identically
// (src/ir/hir/build/defs.nx, via the same rename map) so the VariantIndex,
// typecheck `find_variant`, and the runtime tag (a pure function of the name
// string) all agree.

/** collect the bare names of every enum constructor declared in a
 *  single file's top-level defs (one entry per variant, so a ctor that recurs
 *  across two enums contributes two entries — the basis for whole-program
 *  collision detection in imports.nx). */
export let collect_enum_ctor_names_in_defs = fn (defs: [ SpannedTopLevel ]) -> [ string ] do
  return collect_enum_ctor_names_go(defs, acc: [])
end

let collect_enum_ctor_names_go = fn (defs: [ SpannedTopLevel ], acc: [ string ]) -> [ string ] do
  match defs do
    | [] -> return acc
    | SpannedTopLevel(
      node: TLEnum(def: EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs)),
      span: _
    ) :: rest ->
      return collect_enum_ctor_names_go(defs: rest, acc: collect_variant_names(variants: vs, acc))
    | _ :: rest ->
      return collect_enum_ctor_names_go(defs: rest, acc)
  end
end

let str_member = fn (xs: [ string ], s: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true end
      return str_member(xs: rest, s)
  end
end

/** Append a `bare_variant -> canonical_name(source, variant)` rename entry for
 *  each COLLIDING variant of an enum. Used for a module's own (internal/self)
 *  enums and for selectively-imported enums, where ctors are referenced bare. */
let add_variant_entries_bare = fn (
  variants: [ VariantDef ],
  source: string,
  colliding: [ string ],
  acc: [ RenameEntry ]
) -> [ RenameEntry ] do
  match variants do
    | [] -> return acc
    | VariantDef(name: vn, fields: _) :: rest ->
      let acc2 = if str_member(xs: colliding, s: vn) then
          symtab.rename_add(
            entries: acc,
            original: vn,
            qualified: rdr.canonical_name(source_path: source, name: vn)
          )
        else acc end
      return add_variant_entries_bare(variants: rest, source, colliding, acc: acc2)
  end
end

/** Append an `alias.Variant -> canonical_name(source, variant)` rename entry for
 *  each COLLIDING variant of an enum. Used for wildcard imports where ctors are
 *  referenced qualified (`m.Ctor`). */
let add_variant_entries_qualified = fn (
  variants: [ VariantDef ],
  source: string,
  alias: string,
  colliding: [ string ],
  acc: [ RenameEntry ]
) -> [ RenameEntry ] do
  match variants do
    | [] -> return acc
    | VariantDef(name: vn, fields: _) :: rest ->
      let acc2 = if str_member(xs: colliding, s: vn) then
          symtab.rename_add(
            entries: acc,
            original: alias ++ "." ++ vn,
            qualified: rdr.canonical_name(source_path: source, name: vn)
          )
        else acc end
      return add_variant_entries_qualified(variants: rest, source, alias, colliding, acc: acc2)
  end
end

/** Build internal-view rename entries for an imported module: each top-level
 *  def gets mapped to its canonical name (source#name). Produced once per
 *  import and used for the imported module's own internal calls.
 *  Internal view ignores is_public: within a module, all own names are visible.
 */
let build_internal_rename_go = fn (
  defs: [ SpannedTopLevel ],
  source: string,
  colliding: [ string ],
  acc: [ RenameEntry ]
) -> [ RenameEntry ] do
  match defs do
    | [] -> return acc
    | SpannedTopLevel(
      node: TLLet(def: GlobalLet(name, is_public: _, typ: _, value: _)),
      span: _
    ) :: rest
    | SpannedTopLevel(
      node: TLCap(def: Cap(name, is_public: _, type_params: _, functions: _)),
      span: _
    ) :: rest ->
      let acc2 = symtab.rename_add(
        entries: acc,
        original: name,
        qualified: rdr.canonical_name(source_path: source, name)
      )
      return build_internal_rename_go(defs: rest, source, colliding, acc: acc2)
    | SpannedTopLevel(
      node: TLEnum(def: EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs)),
      span: _
    ) :: rest ->
      // a module's own colliding enum ctors resolve (bare) to its
      // canonical ctor name within its own bodies.
      let acc2 = add_variant_entries_bare(variants: vs, source, colliding, acc)
      return build_internal_rename_go(defs: rest, source, colliding, acc: acc2)
    | _ :: rest ->
      return build_internal_rename_go(defs: rest, source, colliding, acc)
  end
end

/** Build the internal-view rename map for an imported module: entries for
 *  the module's own top-level defs, each mapped to its canonical name.
 *  Used when processing the imported module's function bodies.
 */
export let build_rename_map = fn (
  imported_defs: [ SpannedTopLevel ],
  import_def: ImportDef,
  import_depth: i64,
  colliding: [ string ]
) -> [ RenameEntry ] do
  let ImportDef(path, alias: _, items: _, is_external: is_ext) = import_def
  if is_ext then return []
      else
        return build_internal_rename_go(
          defs: imported_defs,
          source: pkg.resolve_import_path(path),
          colliding,
          acc: []
        )
      end
end

/** For wildcard import `import * as a from "A"`: caller sees `a.foo -> canonical(A, foo)`.
 *  Only exported (is_public=true) names are included — D-Export: the export prefix is the
 *  inter-module visibility gate; non-exported names are module-private.
 */
let build_wildcard_importer_go = fn (
  defs: [ SpannedTopLevel ],
  source: string,
  alias: string,
  colliding: [ string ],
  acc: [ RenameEntry ]
) -> [ RenameEntry ] do
  match defs do
    | [] -> return acc
    | SpannedTopLevel(
      node: TLLet(def: GlobalLet(name, is_public: true, typ: _, value: _)),
      span: _
    ) :: rest
    | SpannedTopLevel(
      node: TLCap(def: Cap(name, is_public: true, type_params: _, functions: _)),
      span: _
    ) :: rest ->
      let key = alias ++ "." ++ name
      let acc2 = symtab.rename_add(
        entries: acc,
        original: key,
        qualified: rdr.canonical_name(source_path: source, name)
      )
      return build_wildcard_importer_go(defs: rest, source, alias, colliding, acc: acc2)
    | SpannedTopLevel(
      node: TLEnum(def: EnumDef(name: _, is_public: true, is_opaque: opq, type_params: _, variants: vs)),
      span: _
    ) :: rest ->
      // wildcard `import * as m` exposes a public enum's colliding
      // ctors as `m.Ctor`. Opaque enums withhold their ctors (D-Type-Sum-Opaque),
      // so emit no qualified ctor entries for them.
      let acc2 = if opq then acc else add_variant_entries_qualified(
        variants: vs,
        source,
        alias,
        colliding,
        acc
      ) end
      return build_wildcard_importer_go(defs: rest, source, alias, colliding, acc: acc2)
    | _ :: rest ->
      return build_wildcard_importer_go(defs: rest, source, alias, colliding, acc)
  end
end

/** Collect all exported names from a list of top-level definitions.
 *  Used to build a candidate list for "did you mean?" suggestions when a
 *  selective import references a non-exported name.
 */
let collect_exported_names = fn (defs: [ SpannedTopLevel ]) -> [ string ] do
  return collect_exported_names_go(defs, acc: [])
end

let collect_exported_names_go = fn (defs: [ SpannedTopLevel ], acc: [ string ]) -> [ string ] do
  match defs do
    | [] -> return acc
    | SpannedTopLevel(
      node: TLLet(def: GlobalLet(name, is_public: true, typ: _, value: _)),
      span: _
    ) :: rest ->
      return collect_exported_names_go(defs: rest, acc: name :: acc)
    | SpannedTopLevel(
      node: TLCap(def: Cap(name, is_public: true, type_params: _, functions: _)),
      span: _
    ) :: rest ->
      return collect_exported_names_go(defs: rest, acc: name :: acc)
    | SpannedTopLevel(
      node: TLEnum(def: EnumDef(name: _, is_public: true, is_opaque: false, type_params: _, variants: vs)),
      span: _
    ) :: rest ->
      // public enum ctors are importable, so include them as
      // "did you mean?" candidates for selective imports.
      return collect_exported_names_go(defs: rest, acc: collect_variant_names(variants: vs, acc))
    | _ :: rest ->
      return collect_exported_names_go(defs: rest, acc)
  end
end

let collect_variant_names = fn (variants: [ VariantDef ], acc: [ string ]) -> [ string ] do
  match variants do
    | [] -> return acc
    | VariantDef(name: vn, fields: _) :: rest ->
      return collect_variant_names(variants: rest, acc: vn :: acc)
  end
end

/** For selective import `import { foo as bar } from "A"`: caller sees `bar -> canonical(A, foo)`.
 *  D-Export: if a selected name exists in the module but is not exported (is_public=false),
 *  raises ImportNotExported so the user gets a clear diagnostic instead of a silent miss.
 */
let build_selective_importer_go = fn (
  defs: [ SpannedTopLevel ],
  items: [ ImportItem ],
  source: string,
  colliding: [ string ],
  acc: [ RenameEntry ],
  exported: [ string ]
) -> [ RenameEntry ] throws { ImportNotExported } do
  match defs do
    | [] -> return acc
    | SpannedTopLevel(
      node: TLLet(def: GlobalLet(name, is_public, typ: _, value: _)),
      span: _
    ) :: rest ->
      match find_selected(name, items) do
        | Some(val: visible) ->
          if is_public then
            let acc2 = symtab.rename_add(
              entries: acc,
              original: visible,
              qualified: rdr.canonical_name(source_path: source, name)
            )
            return build_selective_importer_go(
              defs: rest,
              items,
              source,
              colliding,
              acc: acc2,
              exported
            )
          else
            let sugs = suggest_names(typo: name, candidates: exported)
            throw ImportNotExported(name, module_path: source, suggestions: sugs)
          end
        | None ->
          return build_selective_importer_go(defs: rest, items, source, colliding, acc, exported)
      end
    | SpannedTopLevel(
      node: TLCap(def: Cap(name, is_public, type_params: _, functions: _)),
      span: _
    ) :: rest ->
      match find_selected(name, items) do
        | Some(val: visible) ->
          if is_public then
            let acc2 = symtab.rename_add(
              entries: acc,
              original: visible,
              qualified: rdr.canonical_name(source_path: source, name)
            )
            return build_selective_importer_go(
              defs: rest,
              items,
              source,
              colliding,
              acc: acc2,
              exported
            )
          else
            let sugs = suggest_names(typo: name, candidates: exported)
            throw ImportNotExported(name, module_path: source, suggestions: sugs)
          end
        | None ->
          return build_selective_importer_go(defs: rest, items, source, colliding, acc, exported)
      end
    | SpannedTopLevel(
      node: TLEnum(def: EnumDef(name: _, is_public: enum_pub, is_opaque: opq, type_params: _, variants: vs)),
      span: _
    ) :: rest ->
      // a selectively-imported COLLIDING ctor (`import { MkV }`)
      // binds its visible name to the defining module's canonical ctor name.
      // Only public, non-opaque enums expose ctors; otherwise the name may be a
      // legal type-only import (see add_selected_variant_entries).
      let acc2 = add_selected_variant_entries(
        variants: vs,
        items,
        source,
        enum_visible: enum_pub && (! opq),
        colliding,
        acc
      )
      return build_selective_importer_go(defs: rest, items, source, colliding, acc: acc2, exported)
    | _ :: rest ->
      return build_selective_importer_go(defs: rest, items, source, colliding, acc, exported)
  end
end

/** Per-variant selective-import binding. For each enum variant
 *  named in `items`, bind its visible name to `canonical(source, variant)` — but
 *  only when the constructor is actually exposed (`enum_visible`: the enum is
 *  public and not opaque). When the enum is non-public or opaque the
 *  constructor is withheld, so we add no ctor entry and DO NOT raise: the same
 *  selective name may legally be importing the *type* (an opaque type's name is
 *  exported even though its ctor is hidden; type names resolve via whole-program
 *  typedef visibility, not this rename map). Constructor-visibility for
 *  withheld enums is enforced downstream at typecheck (register_enum_constructors
 *  keys off visible_enum_names), preserving the prior layering. */
let add_selected_variant_entries = fn (
  variants: [ VariantDef ],
  items: [ ImportItem ],
  source: string,
  enum_visible: bool,
  colliding: [ string ],
  acc: [ RenameEntry ]
) -> [ RenameEntry ] do
  if ! enum_visible then return acc end
  match variants do
    | [] -> return acc
    | VariantDef(name: vn, fields: _) :: rest ->
      let acc2 = match find_selected(name: vn, items) do
          | Some(val: visible) ->
            if str_member(xs: colliding, s: vn) then
              symtab.rename_add(
                entries: acc,
                original: visible,
                qualified: rdr.canonical_name(source_path: source, name: vn)
              )
            else acc end
          | None -> acc
        end
      return add_selected_variant_entries(
        variants: rest,
        items,
        source,
        enum_visible,
        colliding,
        acc: acc2
      )
  end
end

/** Build the importer-view rename entries for an import: the entries that
 *  the importing scope needs so its own calls (alias.foo or bare visible
 *  names from selective imports) rename to the canonical target.
 *  Raises ImportNotExported if a selective import names a non-exported symbol.
 */
export let build_importer_entries = fn (
  imported_defs: [ SpannedTopLevel ],
  import_def: ImportDef,
  colliding: [ string ]
) -> [ RenameEntry ] throws { ImportNotExported } do
  let ImportDef(path, alias: alias_opt, items, is_external: is_ext) = import_def
  if is_ext then return []
      else
        let physical = pkg.resolve_import_path(path)
        match items do
          | [] ->
            let alias = match alias_opt do
              | Some(val: a) -> a
              | None -> default_alias(path)
            end
            return build_wildcard_importer_go(
              defs: imported_defs,
              source: physical,
              alias,
              colliding,
              acc: []
            )
          | _ :: _ ->
            let exported = collect_exported_names(defs: imported_defs)
            let selective = build_selective_importer_go(
              defs: imported_defs,
              items,
              source: physical,
              colliding,
              acc: [],
              exported
            )
            match alias_opt do
              | Some(val: alias) ->
                return build_wildcard_importer_go(
                  defs: imported_defs,
                  source: physical,
                  alias,
                  colliding,
                  acc: selective
                )
              | None -> return selective
            end
        end
      end
end

let extract_imports_go = fn (defs: [ SpannedTopLevel ], acc: [ ImportDef ]) -> [ ImportDef ] do
  match defs do
    | [] -> return acc
    | head :: rest ->
      // Avoid nested constructor pattern (codegen discards inner tag checks).
      // Use shallow match + separate match on extracted node instead.
      let SpannedTopLevel(node, span: _) = head
      if let TLImport(def: imp) = node then
        return extract_imports_go(defs: rest, acc: imp :: acc)
      else
        return extract_imports_go(defs: rest, acc)
      end
  end
end

/** Extract all import definitions from a program's top-level. */
export let extract_imports = fn (defs: [ SpannedTopLevel ]) -> [ ImportDef ] do
  return list.reverse(xs: extract_imports_go(defs, acc: []))
end

/** Extract canonical names of all top-level lets in `defs`.
 *  The entry file's `main` keeps its bare name; every other top-level let
 *  canonicalises to "<sanitized-path>#name" per `rdr.canonical_name`.
 *  Used to build the typecheck allow-list (`is_local` check).
 */
export let extract_function_names = fn (defs: [ SpannedTopLevel ], source: string) -> [ string ] do
  match defs do
    | [] -> return []
    | SpannedTopLevel(
      node: TLLet(def: GlobalLet(name, is_public: _, typ: _, value: _)),
      span: _
    ) :: rest ->
      let qname = if name == "main" then "main" else rdr.canonical_name(
        source_path: source,
        name
      ) end
      return qname :: extract_function_names(defs: rest, source)
    | _ :: rest -> return extract_function_names(defs: rest, source)
  end
end

/** Add rename entries for the entry file's own top-level defs so that local
 *  calls rename to canonical targets. The entry file's `main` keeps its bare
 *  name so wasm export "main" works.
 */
export let build_entry_self_entries = fn (
  defs: [ SpannedTopLevel ],
  source: string,
  colliding: [ string ],
  acc: [ RenameEntry ]
) -> [ RenameEntry ] do
  match defs do
    | [] -> return acc
    | SpannedTopLevel(
      node: TLLet(def: GlobalLet(name, is_public: _, typ: _, value: _)),
      span: _
    ) :: rest ->
      if name == "main" then
        let acc2 = symtab.rename_add(entries: acc, original: name, qualified: "main")
        return build_entry_self_entries(defs: rest, source, colliding, acc: acc2)
      end
      let acc2 = symtab.rename_add(
        entries: acc,
        original: name,
        qualified: rdr.canonical_name(source_path: source, name)
      )
      return build_entry_self_entries(defs: rest, source, colliding, acc: acc2)
    | SpannedTopLevel(
      node: TLCap(def: Cap(name, is_public: _, type_params: _, functions: _)),
      span: _
    ) :: rest ->
      let acc2 = symtab.rename_add(
        entries: acc,
        original: name,
        qualified: rdr.canonical_name(source_path: source, name)
      )
      return build_entry_self_entries(defs: rest, source, colliding, acc: acc2)
    | SpannedTopLevel(
      node: TLEnum(def: EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs)),
      span: _
    ) :: rest ->
      // the entry file's own colliding enum ctors resolve (bare) to
      // their canonical ctor name, so they win over any same-named imported ctor
      // unless the user also selectively imported the colliding name (in which
      // case check_import_collisions diagnoses the genuine ambiguity).
      let acc2 = add_variant_entries_bare(variants: vs, source, colliding, acc)
      return build_entry_self_entries(defs: rest, source, colliding, acc: acc2)
    | _ :: rest -> return build_entry_self_entries(defs: rest, source, colliding, acc)
  end
end

/** Extract canonical names for explicitly-named items in selective imports.
 *  For `import { foo, bar } from "src/X.nx"`, produces
 *  `["src_X_nx#foo", "src_X_nx#bar"]`.
 *  Star-imports (`import * as mod`) produce no names (items list is empty).
 *  Used to build a minimal import-body-check allow-list that avoids arena
 *  exhaustion on programs that star-import many large modules.
 */
export let extract_named_import_canonical_names = fn (imports: [ ImportDef ]) -> [ string ] do
  return extract_named_import_canonical_names_go(imports, acc: [])
end

let extract_named_import_canonical_names_go = fn (
  imports: [ ImportDef ],
  acc: [ string ]
) -> [ string ] do
  match imports do
    | [] -> return acc
    | ImportDef(path: p, alias: _, items, is_external: _) :: rest ->
      let acc2 = collect_import_items_go(path: p, items, acc)
      return extract_named_import_canonical_names_go(imports: rest, acc: acc2)
  end
end

let collect_import_items_go = fn (
  path: string,
  items: [ ImportItem ],
  acc: [ string ]
) -> [ string ] do
  match items do
    | [] -> return acc
    | ImportItem(name: n, item_alias: _) :: rest ->
      let cname = rdr.canonical_name(source_path: path, name: n)
      return collect_import_items_go(path, items: rest, acc: cname :: acc)
  end
end
