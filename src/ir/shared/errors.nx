/**
 * ir/shared/errors: Import-resolution exception types.
 *
 * Covers exceptions raised by the HIR import-resolution layer:
 * cycle detection, selective-import visibility enforcement, and the
 * file-context wrapper applied when an error propagates out of an
 * imported module. All are E4xxx codes in `format_error`.
 */

/** Raised when the import graph contains a cycle. */
export exception CyclicImport(path: string)

/** Raised when a selective import names a symbol that exists in the
 *  module but is not exported. Enforces D-Export: only names with the
 *  'export' prefix are visible to importing modules.
 *  `suggestions` carries up to 3 near-match exported names (Levenshtein ≤ 2).
 */
export exception ImportNotExported(name: string, module_path: string, suggestions: [string])

/** Attach file-path context to any inner compile error that propagates
 *  out of an imported module. `detail` is the already-formatted inner
 *  message so wrappers chain naturally:
 *  InImport('b', InImport('c', '...')).
 */
export exception InImport(path: string, detail: string)
