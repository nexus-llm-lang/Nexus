/**
 * package: package-based module resolver.
 *
 * Maps `pkg:path` import strings to physical files and to the
 * `namespace:pkg/iface` module-name strings the wasm backend emits
 * on stdlib imports.
 *
 * Example: `std:stdio` resolves to `nxlib/stdlib/io/stdio.nx` and to the
 * import-module name `nexus:std/stdio`.
 *
 * Bare paths (no `:`) flow through unchanged so file-relative imports
 * continue to work.
 *
 * stdlib modules are organised into logical subdirectories under
 * `nxlib/stdlib/`.  The manifest below maps the short name that users
 * write (e.g. `list`) to the actual subpath (e.g. `collection/list`).
 * Modules not listed here (e.g. `runtime/sysio`) resolve via the
 * direct-path fallback unchanged.
 */

import * as str from "std:str"

// Default name of the standard-library package.
let std_package = "std"

// Default root directory for the `std` package (relative to cwd).
let std_package_root = "nxlib/stdlib"

let nx_ext = "nx"

// Manifest: maps a flat std module name to its subdir-qualified path.
// Only modules that have been moved into subdirectories need an entry.
// Modules under `std:runtime/...` keep their path-based layout and
// never appear here.
type ManifestEntry = ManifestEntry(name: string, subpath: string)

let std_manifest: [ManifestEntry] = [
  // collection/
  ManifestEntry(name: "list",       subpath: "collection/list"),
  ManifestEntry(name: "hashmap",    subpath: "collection/hashmap"),
  ManifestEntry(name: "stringmap",  subpath: "collection/stringmap"),
  ManifestEntry(name: "bytebuffer", subpath: "collection/bytebuffer"),
  ManifestEntry(name: "tuple",      subpath: "collection/tuple"),
  // text/
  ManifestEntry(name: "str",    subpath: "text/str"),
  ManifestEntry(name: "char",   subpath: "text/char"),
  ManifestEntry(name: "regexp", subpath: "text/regexp"),
  // io/
  ManifestEntry(name: "stdio",   subpath: "io/stdio"),
  ManifestEntry(name: "fs",      subpath: "io/fs"),
  ManifestEntry(name: "network", subpath: "io/network"),
  ManifestEntry(name: "proc",    subpath: "io/proc"),
  ManifestEntry(name: "env",     subpath: "io/env"),
  ManifestEntry(name: "log",     subpath: "io/log"),
  ManifestEntry(name: "clock",   subpath: "io/clock"),
  // encoding/
  ManifestEntry(name: "json",    subpath: "encoding/json"),
  ManifestEntry(name: "jsonrpc", subpath: "encoding/jsonrpc"),
  ManifestEntry(name: "toml",    subpath: "encoding/toml"),
  ManifestEntry(name: "yaml",    subpath: "encoding/yaml"),
  // numeric/
  ManifestEntry(name: "math", subpath: "numeric/math"),
  ManifestEntry(name: "simd", subpath: "numeric/simd"),
  ManifestEntry(name: "rand", subpath: "numeric/rand"),
  // concurrency/
  ManifestEntry(name: "lazy",      subpath: "concurrency/lazy"),
  ManifestEntry(name: "lazy_host", subpath: "concurrency/lazy_host"),
  // core/
  ManifestEntry(name: "core",   subpath: "core/core"),
  ManifestEntry(name: "option", subpath: "core/option"),
  ManifestEntry(name: "result", subpath: "core/result"),
  ManifestEntry(name: "exn",    subpath: "core/exn"),
  // meta/
  ManifestEntry(name: "pbt",      subpath: "meta/pbt"),
  ManifestEntry(name: "argparse", subpath: "meta/argparse")
]

/** Look up a short module name in the stdlib manifest.  Returns the
 *  subdir-qualified path (without extension) on a hit, or "" on a miss.
 */
let manifest_lookup = fn (name: string, entries: [ManifestEntry]) -> string do
  match entries do
    | [] -> return ""
    | ManifestEntry(name: n, subpath: sp) :: rest ->
      if n == name then return sp end
      return manifest_lookup(name, entries: rest)
  end
end

/** Result of splitting a `pkg:path` import. Empty `pkg` indicates the input
 *  had no `:` separator (or one side was empty).
 */
export type Split = Split(pkg: string, rest: string)

/** Split a `pkg:path` import into its components. */
let split_qualified = fn (path: string) -> Split do
  let colon_pos = str.index_of(s: path, sub: ":")
  if colon_pos < 0 then return Split(pkg: "", rest: "") end
  let pkg = str.substring(s: path, start: 0, len: colon_pos)
  let rest_start = colon_pos + 1
  let rest = str.substring(s: path, start: rest_start, len: str.byte_length(s: path) - rest_start)
  if str.length(s: pkg) == 0 then return Split(pkg: "", rest: "") end
  if str.length(s: rest) == 0 then return Split(pkg: "", rest: "") end
  return Split(pkg, rest)
end

/** Returns the physical root directory for a registered package, or "" when unknown. */
let package_root = fn (pkg: string) -> string do
  if pkg == std_package then return std_package_root end
  return ""
end

/** Strip a trailing `.nx` extension if present. */
let strip_nx_ext = fn (s: string) -> string do
  let suffix = "." ++ nx_ext
  if str.ends_with(s, suffix) then
    let n = str.byte_length(s) - str.byte_length(s: suffix)
    return str.substring(s, start: 0, len: n)
  end
  return s
end

/** Resolve a `pkg:path` import to its physical `.nx` filesystem path. Returns
 *  the empty string for unqualified or unknown-package paths.
 *
 *  For the `std` package, the manifest is consulted first so that flat
 *  import names like `std:list` resolve to the subdirectory layout
 *  (`nxlib/stdlib/collection/list.nx`) without changing how callers write
 *  their imports.
 */
let resolve_qualified_to_file = fn (path: string) -> string do
  let Split(pkg, rest) = split_qualified(path)
  if str.length(s: pkg) == 0 then return "" end
  let root = package_root(pkg)
  if str.length(s: root) == 0 then return "" end
  let stripped = strip_nx_ext(s: rest)
  // Consult the manifest when this is the std package and the rest has
  // no slash (i.e. a flat name like "list" rather than "runtime/sysio").
  if pkg == std_package then
    let slash_pos = str.index_of(s: stripped, sub: "/")
    if slash_pos < 0 then
      let mapped = manifest_lookup(name: stripped, entries: std_manifest)
      if str.length(s: mapped) > 0 then
        return root ++ "/" ++ mapped ++ "." ++ nx_ext
      end
    end
  end
  return root ++ "/" ++ stripped ++ "." ++ nx_ext
end

/** Resolve any import path. Qualified paths flow through the package resolver;
 *  bare paths are returned unchanged so file-relative imports continue to work.
 */
export let resolve_import_path = fn (path: string) -> string do
  let physical = resolve_qualified_to_file(path)
  if str.length(s: physical) > 0 then return physical end
  return path
end

/** Path to a package's bundled WASM artifact (used by the WASM merger to
 *  resolve `nexus:<pkg>/...` imports against `<root>/stdlib.wasm`).
 */
let package_wasm_path = fn (pkg: string) -> string do
  let root = package_root(pkg)
  if str.length(s: root) == 0 then return "" end
  return root ++ "/stdlib.wasm"
end
