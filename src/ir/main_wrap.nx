/**
 * main_wrap: HIR pass that lifts the `main function throws must be {}`
 * restriction by synthesising a top-level catch-all wrapper.
 *
 * If the user's `main` declares a non-empty throws-row, this pass:
 *   1. Renames the original `main` to `__nx_user_main` (preserving its row)
 *   2. Synthesises a fresh `main` whose body is
 *        try
 *          __nx_user_main()
 *        catch _ ->
 *          wasi_snapshot_preview1::proc_exit(1)
 *        end
 *   3. Adds the WASI proc_exit external the wrapper needs.
 *
 * The wrapper's throws-row is `{}`, so post-pass `validate_main` accepts
 * even programs whose `main` declared a narrow exception group.
 *
 * The pass is a no-op when `main` already has an empty throws-row.
 *
 * The catch arm calls `proc_exit(1)` directly rather than printing the
 * exception variant first: the stdlib is inlined per-program, so there is
 * no `nexus:std/stdio` host provider for an `eprint` import to resolve
 * against, and a suffix lookup against inlined `eprint_str` only works
 * for programs whose source already pulls in `std:stdio` transitively.
 * `proc_exit` is universal (wasmtime supplies `wasi_snapshot_preview1`
 * natively), so the wrapper trades the variant-name stderr line for an
 * unconditionally working non-zero exit. The test runner reports the
 * exit code; an inline `fd_write` intrinsic could re-add the variant name
 * later.
 */

import { Span } from "src/common/token.nx"
import * as list from "std:list"
import {
  TypeExpr, TyI32, TyI64, TyString, TyUnit, TyRow, TyVar, TyUserDefined,
  Literal, LitInt,
  SigilImmutable
} from "src/common/ast.nx"
import {
  HirProgram, HirFunction, HirParam, HirExternal, HirExpr, HirStmt,
  HirCallArg,
  EagerBody
} from "src/ir/hir/types.nx"
import { Option, Some, None } from "std:option"

let empty_row = fn () -> TypeExpr do return TyRow(types: [], rest: None) end

/** Returns true when the given throws-row is structurally empty (closed row
 *  with no entries). Anything else is treated as "needs wrapping".
 */
let throws_row_is_empty = fn (row: TypeExpr) -> bool do
  match row do
    | TyRow(types: ts, rest: r) ->
      match r do
        | Some(_) -> return false
        | None ->
          match ts do
            | [] -> return true
            | _ :: _ -> return false
          end
      end
    | TyUnit -> return true
    | _ -> return false
  end
end

/** Returns true when the throws-row is *wrappable*: a closed row whose
 *  entries are all named exception groups / variants (or the universal
 *  `Exn`). Open rows (rest = Some) and rows containing a free type
 *  variable are *not* wrappable — they fall through to validate_main and
 *  surface as `MainThrowsTooBroad`. `Exn` itself is admitted: the
 *  synthesised match dispatches every Exn variant via the wildcard arm and
 *  most fixtures declare `throws { Exn }` to mean "may throw anything".
 */
let throws_row_is_wrappable = fn (row: TypeExpr) -> bool do
  match row do
    | TyRow(types: ts, rest: r) ->
      match r do
        | Some(_) -> return false
        | None -> return throws_row_entries_are_named(entries: ts)
      end
    | _ -> return false
  end
end

let throws_row_entries_are_named = fn (entries: [TypeExpr]) -> bool do
  match entries do
    | [] -> return true
    | t :: rest ->
      match t do
        | TyUserDefined(name: _, args: _) ->
          return throws_row_entries_are_named(entries: rest)
        | _ -> return false
      end
  end
end


let host_wasi = "wasi_snapshot_preview1"
// Backtrace ops have no host provider; codegen inlines them to constants
// (bt-depth -> 0, bt-frame -> empty string, capture-backtrace -> filtered
// out of the import section so the throw-site `call` is elided). Declaring
// them under `nexus:intrinsic` is what makes codegen recognise them.
let host_bt = "nexus:intrinsic"
// Internal HIR-level names for the externals the wrapper imports. Distinct
// from any name a user file would resolve through `external X = ...` so the
// pass can blindly add them without colliding with existing imports.
let sym_proc_exit = "__nx_main_wrap_proc_exit"
let sym_cast_i32 = "__nx_main_wrap_cast_to_i32"
let sym_bt_depth = "__nx_main_wrap_bt_depth"
let sym_bt_frame = "__nx_main_wrap_bt_frame"
let sym_bt_capture = "__nx_main_wrap_bt_capture"
/** External symbol name codegen looks up to emit a `call` before each
 *  `op_throw`. Exposed so codegen.nx can resolve the import slot without
 *  importing the rest of main_wrap.
 */
export let bt_capture_symbol_name = fn () -> string do return sym_bt_capture end

let synth_externals = fn () -> [HirExternal] do
  // proc_exit: WASI's process-terminate primitive. The signature is `(i32) ->
  // ()` at the wasm level (never returns; wasmtime satisfies it natively).
  // We use it as the catch arm's only side-effect: on any uncaught throw the
  // wrapper exits with status 1. Previous versions printed the exception
  // variant name first via `nexus:std/stdio::eprint`, but that import has no
  // host provider since the stdlib became inlined per-program (Phase 7 of
  // ), and falling back to the inlined `eprint_str` by canonical
  // name only works for programs that already transitively import std:stdio
  // — tests that just `throw` and have no stdlib uses never load sysio. The
  // proc_exit-only path trades the variant name for a universally-working
  // non-zero exit.
  let e_proc_exit = HirExternal(
    name: sym_proc_exit,
    wasm_module: host_wasi,
    wasm_name: "proc_exit",
    type_params: [],
    params: [HirParam(label: "a_code", name: "a_code", sigil: SigilImmutable, typ: TyI32)],
    ret_type: TyUnit,
    throw_row: empty_row()
  )
  // cast-to-i32: i64 → i32 narrowing. Catch body has an i64 literal `1` and
  // proc_exit takes i32; this intrinsic emits a single `i32.wrap_i64`
  // (`nexus:intrinsic::cast-to-i32` in src/backend/codegen.nx).
  let e_cast_i32 = HirExternal(
    name: sym_cast_i32,
    wasm_module: host_bt,
    wasm_name: "cast-to-i32",
    type_params: [],
    params: [HirParam(label: "x", name: "x", sigil: SigilImmutable, typ: TyI64)],
    ret_type: TyI32,
    throw_row: empty_row()
  )
  // `bt-depth`/`bt-frame`/`capture-backtrace` are kept on `nexus:intrinsic`
  // so codegen lowers them to constants. They are no longer called from this
  // pass's catch body (the wrapper exits before any backtrace would print),
  // but `capture-backtrace` is still referenced by codegen at every throw
  // site via `bt_capture_symbol_name`, so the external must remain in scope.
  let e_bt_depth = HirExternal(
    name: sym_bt_depth,
    wasm_module: host_bt,
    wasm_name: "bt-depth",
    type_params: [],
    params: [],
    ret_type: TyI64,
    throw_row: empty_row()
  )
  let e_bt_frame = HirExternal(
    name: sym_bt_frame,
    wasm_module: host_bt,
    wasm_name: "bt-frame",
    type_params: [],
    params: [HirParam(label: "idx", name: "idx", sigil: SigilImmutable, typ: TyI64)],
    ret_type: TyString,
    throw_row: empty_row()
  )
  let e_bt_capture = HirExternal(
    name: sym_bt_capture,
    wasm_module: host_bt,
    wasm_name: "capture-backtrace",
    type_params: [],
    params: [],
    ret_type: TyUnit,
    throw_row: empty_row()
  )
  return [e_proc_exit, e_cast_i32, e_bt_depth, e_bt_frame, e_bt_capture]
end


let lit_i64 = fn (n: i64, sp: Span) -> HirExpr do
  return HirExpr(node: Literal(lit: LitInt(val: n)), span: sp)
end

let call1 = fn (fname: string, label: string, arg: HirExpr, sp: Span) -> HirExpr do
  return HirExpr(node: Call(func: fname, args: [HirCallArg(label, value: arg)]), span: sp)
end

let stmt_expr = fn (e: HirExpr, sp: Span) -> HirStmt do
  return HirStmt(node: Expr(expr: e), span: sp)
end


/** Build the catch body: `proc_exit(cast_to_i32(1))`. The caught exception
 *  value (bound to `catch_var`) is intentionally discarded — the wrapper
 *  only needs to terminate with a non-zero exit code so the test runner
 *  records FAIL. See the file-level docstring for why printing the
 *  variant name was dropped.
 */
let synth_catch_body = fn (catch_var: string, sp: Span) -> [HirStmt] do
  // proc_exit takes i32; lift the i64 literal 1 through cast-to-i32. The
  // caught exception (bound at `catch_var`) is intentionally discarded.
  let code_i32 = call1(fname: sym_cast_i32, label: "x", arg: lit_i64(n: 1, sp), sp)
  let exit_call = stmt_expr(
    e: call1(fname: sym_proc_exit, label: "a_code", arg: code_i32, sp),
    sp
  )
  return [exit_call]
end


/** HIR-level name used for the user's original `main` after the wrap pass
 *  renames it. Exposed so main.nx can extend `local_names` (typecheck's
 *  allow-list) to include the renamed function — otherwise
 *  check_all_functions filters it out and the user's actual main body is
 * silently un-typechecked.
 */
export let user_main_name = "__nx_user_main"
let make_wrapper_main = fn (orig_main: HirFunction) -> HirFunction do
  let HirFunction(name: _, type_params: _, params: ps, ret_type: rt, throw_row: _, body: _, span: sp, file: fp, requires: _) = orig_main
  // The wrapper accepts the same params as the original main (e.g. `args:
  // [string]`), forwards them, returns unit, and declares no throws.
  let forward_args = forward_call_args(params: ps, span: sp)
  let try_body = [HirStmt(
    node: Expr(expr: HirExpr(node: Call(func: user_main_name, args: forward_args), span: sp)),
    span: sp
  )]
  let catch_body = synth_catch_body(catch_var: "__nx_main_caught", sp)
  let try_stmt = HirStmt(
    node: Try(body: try_body, catch_param: "__nx_main_caught", catch_body),
    span: sp
  )
  // The wrapper catches all exceptions internally via the `try … catch`
  // statement, so its own throws-row is effectively empty.  We use the
  // implicit-open sentinel `TyRow([], Some(TyVar("__implicit")))` rather
  // than the literal closed-empty `TyRow([], None)` so that the
  // `check_call_throw_row_admitted` caller-side check admits the call to
  // `__nx_user_main`, which may declare a non-empty throws-row.
  // `validate_main_throw_row` has a special case for this sentinel that
  // treats it identically to a closed empty row for wrap-validation.
  return HirFunction(
    name: "main",
    type_params: [],
    params: ps,
    ret_type: rt,
    throw_row: TyRow(types: [], rest: Some(val: TyVar(name: "__implicit"))),
    body: EagerBody(stmts: [try_stmt]),
    span: sp,
    file: fp,
    // The wrapper does not declare any caps directly; the user's renamed
    // main carries the original require row (preserved by rename_main_to_user).
    requires: empty_row()
  )
end

let forward_call_args = fn (params: [HirParam], span: Span) -> [HirCallArg] do
  return forward_call_args_go(params, span, acc: [])
end

let forward_call_args_go = fn (params: [HirParam], span: Span, acc: [HirCallArg]) -> [HirCallArg] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: l, name: n, sigil: _, typ: _) :: rest ->
      let arg_expr = HirExpr(node: Variable(name: n, sigil: SigilImmutable), span)
      let arg = HirCallArg(label: l, value: arg_expr)
      return forward_call_args_go(params: rest, span, acc: arg :: acc)
  end
end

let rename_main_to_user = fn (f: HirFunction) -> HirFunction do
  let HirFunction(name: _, type_params: tps, params: ps, ret_type: rt, throw_row: tw, body: b, span: sp, file: fp, requires: req) = f
  return HirFunction(name: user_main_name, type_params: tps, params: ps, ret_type: rt, throw_row: tw, body: b, span: sp, file: fp, requires: req)
end


/** Apply the wrap pass to a HirProgram. Must run after lazy-body resolution
 *  so the original `main` is in EagerBody form (the wrapper splices the
 *  original body via a call rather than an inline expansion, so LazyBody
 *  would also be tolerable, but keeping the precondition uniform avoids
 *  surprises for downstream consumers like linearity).
 */
export let wrap_main_if_needed = fn (prog: HirProgram) -> HirProgram do
  let HirProgram(ports, functions: funcs, externals, handler_bindings, enum_defs, exception_groups, value_binding_names, type_defs, visible_enum_names) = prog
  match find_main_split(funcs, acc: []) do
    | None -> return prog
    | Some(val: MainSplit(main_fn: m, others: rest_funcs)) ->
      let HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: tw, body: _, span: _, file: _, requires: _) = m
      if throws_row_is_empty(row: tw) then
        return prog
      end
      // Too-broad rows (`{Exn}`, open rows, non-named entries) deliberately
      // fall through unchanged so `validate_main` can surface
      // `MainThrowsTooBroad`. Wrapping them would silently widen the
      // catch-all and hide the user's mis-narrowed signature.
      if !throws_row_is_wrappable(row: tw) then
        return prog
      end
      let renamed_user = rename_main_to_user(f: m)
      let wrapper = make_wrapper_main(orig_main: m)
      let new_funcs = wrapper :: renamed_user :: rest_funcs
      let new_exts = append_exts(a: synth_externals(), b: externals)
      return HirProgram(
        ports,
        functions: new_funcs,
        externals: new_exts,
        handler_bindings,
        enum_defs,
        exception_groups,
        value_binding_names,
        type_defs,
        visible_enum_names
      )
  end
end

type MainSplit = MainSplit(main_fn: HirFunction, others: [HirFunction])

/** Locate `main` in the function list. Returns the function plus the list of
 *  the *other* functions in the original order. `None` when no `main`
 *  exists — `validate_main` will throw `MissingMain` later.
 */
let find_main_split = fn (funcs: [HirFunction], acc: [HirFunction]) -> Option<MainSplit> do
  match funcs do
    | [] -> return None
    | f :: rest ->
      let HirFunction(name: n, _) = f
      if n == "main" then
        let others = list_concat_rev(rev_first: acc, tail: rest)
        return Some(val: MainSplit(main_fn: f, others))
      end
      return find_main_split(funcs: rest, acc: f :: acc)
  end
end

let list_concat_rev = fn (rev_first: [HirFunction], tail: [HirFunction]) -> [HirFunction] do
  match rev_first do
    | [] -> return tail
    | f :: rest -> return list_concat_rev(rev_first: rest, tail: f :: tail)
  end
end

let append_exts = fn (a: [HirExternal], b: [HirExternal]) -> [HirExternal] do
  match a do
    | [] -> return b
    | x :: rest -> return x :: append_exts(a: rest, b)
  end
end

