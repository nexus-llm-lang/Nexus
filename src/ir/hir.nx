/**
 * hir: AST → HIR conversion and HirProgram assembly.
 *
 * Owns:
 * - AST expression / statement / pattern conversion (convert_expr, convert_stmts, convert_pattern)
 * - Top-level definition processing (process_defs: functions, externals, handlers, ports, enums)
 * - Exception-group expansion across catch arms + handler bindings
 * - HirAccum → HirProgram assembly (accum_to_program)
 * - Lazy-body AST→HIR resolution (resolve_one_lazy, used by src/ir/demand.nx)
 *
 * Does not own:
 * - HIR type definitions (see src/ir/hir_types.nx)
 * - Reachability analysis / dead-code filtering (see src/ir/hir/reachability.nx)
 * - Iterative lazy-body resolution loop (see src/ir/demand.nx)
 * - Handler-function name mangling (see src/common/naming.nx)
 * - Rdr-name resolution (see src/ir/rdrname.nx, src/ir/symtab.nx)
 */
import { Span } from "src/common/token.nx"
import * as naming from "src/common/naming.nx"
import { SigilImmutable, SigilLazy, SigilMutable, TypeExpr, TyI64, TyUnit, TyArrow, Expr, ExprLiteral, ExprVariable, ExprBinaryOp, ExprBorrow, ExprCall, ExprConstructor, ExprRecord, ExprArray, ExprIndex, ExprFieldAccess, ExprIf, ExprMatch, ExprWhile, ExprFor, ExprLambda, ExprRaise, ExprForce, ExprExternal, ExprHandler, ExprList, StmtLet, StmtLetPattern, StmtExpr, StmtReturn, StmtAssign, StmtTry, StmtInject, PatLiteral, PatVariable, PatConstructor, PatConstructorWildcard, PatRecord, PatWildcard, PatOr, SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel, Param, Function, MatchCase, CallArg, CtorArg, NamedExpr, NamedType, CtorPatternField, RecordPatField, EnumDef, ImportDef, FunctionSig, Port, GlobalLet, CatchArm, TopLevel, TLImport, TLLet, TLPort, TLEnum, TLTypeDef, TLException, TLExceptionGroup, ExceptionGroupDef, Unqual } from "src/common/ast.nx"
import * as rdr from "src/ir/rdrname.nx"
import { RenameEntry }, * as symtab from "src/ir/symtab.nx"
import * as str from "stdlib/string_ops.nx"
import * as list from "stdlib/list.nx"
import * as hir from "src/ir/hir_types.nx"
import { HirParam, HirPortMethod, HirPort, HirExternal, HirExpr, HirStmt, HirExprKind, HirStmtKind, HirCallArg, HirNamedExpr, HirMatchCase, HirPatternKind, HirPatternField, HirRecordPatField, EagerBody, LazyBody, HirFunction, HirHandlerBinding, HirHandlerBindingEntry, HirProgram, HirAccum, ExceptionGroupEntry } from "src/ir/hir_types.nx"

// ─── AST -> HIR Conversion ──────────────────────────────────────────────────

/// Convert an AST expression (SpannedExpr) to HIR.
export let convert_expr = fn (expr: SpannedExpr, entries: [RenameEntry]) -> HirExpr do
  let SpannedExpr(node: node, span: sp) = expr
  let hir = match node do
    | ExprLiteral(lit: lit) ->
      Literal(lit: lit)
    | ExprVariable(name: name, sigil: sig) ->
      let renamed = symtab.rename(name: rdr.rdr_to_string(r: name), entries: entries)
      match sig do
        | SigilLazy ->
          // @ thunks are eagerly evaluated in nxc — force is identity
          Variable(name: renamed, sigil: SigilImmutable)
        | _ ->
          Variable(name: renamed, sigil: sig)
      end
    | ExprBinaryOp(left: l, op: op, right: r) ->
      BinOp(
        left: convert_expr(expr: l, entries: entries),
        op: op,
        right: convert_expr(expr: r, entries: entries)
      )
    | ExprBorrow(name: name, sigil: sig) ->
      Borrow(name: symtab.rename(name: name, entries: entries), sigil: sig)
    | ExprCall(func: f, args: args) ->
      Call(
        func: symtab.rename(name: rdr.rdr_to_string(r: f), entries: entries),
        args: convert_call_args(args: args, entries: entries)
      )
    | ExprConstructor(name: v, args: args) ->
      Ctor(
        variant: rdr.rdr_occ(r: v),
        args: convert_ctor_args(args: args, entries: entries)
      )
    | ExprRecord(fields: fs) ->
      Record(fields: convert_named_exprs(exprs: fs, entries: entries))
    | ExprArray(elements: es) ->
      Array(elems: convert_expr_list(exprs: es, entries: entries))
    | ExprIndex(target: t, index: i) ->
      Index(
        target: convert_expr(expr: t, entries: entries),
        index: convert_expr(expr: i, entries: entries)
      )
    | ExprFieldAccess(target: t, field: f) ->
      // Module-qualified value access: `mod.name` in value position parses as
      // FieldAccess(Variable("mod"), "name"). If "mod.name" has a rename
      // entry (added for wildcard-aliased imports), resolve as a qualified
      // variable reference rather than a struct field access. Without this,
      // `wdefs.vt_i32` compiles as a field access on an undefined variable
      // and silently returns garbage — breaking self-hosted codegen.
      // Mirrors src/compiler/passes/hir_build.rs FieldAccess handling.
      let SpannedExpr(node: target_node, span: _) = t
      match target_node do
        | ExprVariable(name: Unqual(name: mod_name), sigil: _) ->
          let qualified_key = mod_name ++ "." ++ f
          if symtab.rename_has(name: qualified_key, entries: entries) then
            Variable(name: symtab.rename(name: qualified_key, entries: entries), sigil: SigilImmutable)
          else
            FieldAccess(target: convert_expr(expr: t, entries: entries), field: f)
          end
        | _ ->
          FieldAccess(target: convert_expr(expr: t, entries: entries), field: f)
      end
    | ExprIf(cond: c, then_branch: tb, else_branch: eb) ->
      let hir_else = match eb do
        | [] -> None
        | _ :: _ -> Some(val: convert_stmts(stmts: eb, entries: entries))
      end
      If(
        cond: convert_expr(expr: c, entries: entries),
        then_branch: convert_stmts(stmts: tb, entries: entries),
        else_branch: hir_else
      )
    | ExprMatch(target: t, cases: cs) ->
      Match(
        target: convert_expr(expr: t, entries: entries),
        cases: convert_match_cases(cases: cs, entries: entries)
      )
    | ExprWhile(cond: c, body: b) ->
      While(
        cond: convert_expr(expr: c, entries: entries),
        body: convert_stmts(stmts: b, entries: entries)
      )
    | ExprFor(var: v, start: s, end_expr: e, body: b) ->
      For(
        var: v,
        start: convert_expr(expr: s, entries: entries),
        end_expr: convert_expr(expr: e, entries: entries),
        body: convert_stmts(stmts: b, entries: entries)
      )
    | ExprLambda(type_params: tps, params: ps, ret_type: rt, requires: _, throw_row: _, body: b) ->
      Lambda(
        type_params: tps,
        params: convert_params(params: ps),
        ret_type: rt,
        body: convert_stmts(stmts: b, entries: entries)
      )
    | ExprRaise(value: e) ->
      Raise(expr: convert_expr(expr: e, entries: entries))
    | ExprForce(value: e) ->
      Force(expr: convert_expr(expr: e, entries: entries))
    | ExprExternal(symbol: sym, arg_names: names, typ: t) ->
      ExternalRef(symbol: sym, arg_names: names, typ: t)
    | ExprHandler(coeffect_name: pname, requires: _, functions: fs) ->
      Handler(port_name: symtab.rename(name: pname, entries: entries), functions: convert_functions(funcs: fs, entries: entries))
    | ExprList(elements: es) ->
      // Extract inner node from desugar_list result — span comes from outer wrapping
      let HirExpr(node: desugared, span: _) = desugar_list(elems: es, entries: entries, span: sp)
      desugared
  end
  return HirExpr(node: hir, span: sp)
end

/// Convert a top-level AST expression, ALWAYS skipping body conversion.
/// Returns Lambda with empty body for everything — the caller (process_tl_let)
/// matches on the HirExprKind to distinguish Lambda from External/Handler.
/// Non-Lambda TLLets get LazyBody too, but resolve_lazy_bodies handles the
/// empty-body case gracefully (returns empty stmts).
let convert_expr_toplevel = fn (expr: SpannedExpr, entries: [RenameEntry]) -> HirExpr do
  let SpannedExpr(node: node, span: sp) = expr
  let tps = infer_tparams_from_expr(expr: node)
  let ps = infer_params_from_expr(expr: node)
  let rt = infer_ret_from_expr(expr: node)
  return HirExpr(node: Lambda(type_params: tps, params: ps, ret_type: rt, body: []), span: sp)
end

/// Desugar [a, b, c] -> a :: b :: c :: []
/// Args are unlabeled, so they must be in alphabetical field order: (rest, v)
let desugar_list = fn (elems: [SpannedExpr], entries: [RenameEntry], span: Span) -> HirExpr do
  let reversed = rev_spanned_expr(lst: elems, out: [])
  let zero = Span(offset: 0, line: 0, col: 0)
  let inner = desugar_list_go(elems: reversed, entries: entries,
    acc: HirExpr(node: Ctor(variant: "Nil", args: []), span: zero))
  let HirExpr(node: result_node, span: _) = inner
  return HirExpr(node: result_node, span: span)
end

let desugar_list_go = fn (elems: [SpannedExpr], entries: [RenameEntry], acc: HirExpr) -> HirExpr do
  match elems do
    | [] -> return acc
    | e :: rest ->
      let head = convert_expr(expr: e, entries: entries)
      let zero = Span(offset: 0, line: 0, col: 0)
      return desugar_list_go(elems: rest, entries: entries,
        acc: HirExpr(node: Ctor(variant: "Cons", args: [acc, head]), span: zero))
  end
end

let convert_call_args = fn (args: [CallArg], entries: [RenameEntry]) -> [HirCallArg] do
  return convert_call_args_go(args: args, entries: entries, acc: [])
end

let convert_call_args_go = fn (args: [CallArg], entries: [RenameEntry], acc: [HirCallArg]) -> [HirCallArg] do
  match args do
    | [] -> return rev_hir_call_arg(lst: acc, out: [])
    | CallArg(name: l, value: v) :: rest ->
      return convert_call_args_go(args: rest, entries: entries, acc: HirCallArg(label: l, value: convert_expr(expr: v, entries: entries)) :: acc)
  end
end

// ─── Constructor field sorting (alphabetical, matching memory layout) ────────

let str_less_than_loop = fn (a: string, b: string, idx: i64, la: i64, lb: i64) -> bool do
  if idx >= la then
    return idx < lb
  else
    if idx >= lb then
      return false
    else
      let ca = str.char_code(s: a, idx: idx)
      let cb = str.char_code(s: b, idx: idx)
      if ca < cb then
        return true
      else
        if ca > cb then
          return false
        else
          return str_less_than_loop(a: a, b: b, idx: idx + 1, la: la, lb: lb)
        end
      end
    end
  end
end

let str_less_than = fn (a: string, b: string) -> bool do
  return str_less_than_loop(a: a, b: b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end

let ctor_arg_name = fn (arg: CtorArg) -> string do
  match arg do
    | CtorArg(name: n, value: _) -> return n
  end
end

let insert_ctor_arg = fn (arg: CtorArg, sorted: [CtorArg]) -> [CtorArg] do
  return insert_ctor_arg_go(arg: arg, sorted: sorted, acc: [])
end

let insert_ctor_arg_go = fn (arg: CtorArg, sorted: [CtorArg], acc: [CtorArg]) -> [CtorArg] do
  match sorted do
    | [] -> return rev_ctor_arg(lst: acc, out: [arg])
    | head :: rest ->
      if str_less_than(a: ctor_arg_name(arg: arg), b: ctor_arg_name(arg: head)) then
        return rev_ctor_arg(lst: acc, out: arg :: sorted)
      else
        return insert_ctor_arg_go(arg: arg, sorted: rest, acc: head :: acc)
      end
  end
end

let sort_ctor_args = fn (args: [CtorArg]) -> [CtorArg] do
  return sort_ctor_args_go(args: args, sorted: [])
end

let sort_ctor_args_go = fn (args: [CtorArg], sorted: [CtorArg]) -> [CtorArg] do
  match args do
    | [] -> return sorted
    | a :: rest -> return sort_ctor_args_go(args: rest, sorted: insert_ctor_arg(arg: a, sorted: sorted))
  end
end

let convert_ctor_args = fn (args: [CtorArg], entries: [RenameEntry]) -> [HirExpr] do
  return convert_ctor_args_inner(args: sort_ctor_args(args: args), entries: entries)
end

let convert_ctor_args_inner = fn (args: [CtorArg], entries: [RenameEntry]) -> [HirExpr] do
  return convert_ctor_args_inner_go(args: args, entries: entries, acc: [])
end

let convert_ctor_args_inner_go = fn (args: [CtorArg], entries: [RenameEntry], acc: [HirExpr]) -> [HirExpr] do
  match args do
    | [] -> return rev_hir_expr(lst: acc, out: [])
    | CtorArg(name: _, value: v) :: rest ->
      return convert_ctor_args_inner_go(args: rest, entries: entries, acc: convert_expr(expr: v, entries: entries) :: acc)
  end
end

let convert_named_exprs = fn (exprs: [NamedExpr], entries: [RenameEntry]) -> [HirNamedExpr] do
  return convert_named_exprs_go(exprs: exprs, entries: entries, acc: [])
end

let convert_named_exprs_go = fn (exprs: [NamedExpr], entries: [RenameEntry], acc: [HirNamedExpr]) -> [HirNamedExpr] do
  match exprs do
    | [] -> return rev_hir_named_expr(lst: acc, out: [])
    | NamedExpr(name: n, value: v) :: rest ->
      return convert_named_exprs_go(exprs: rest, entries: entries, acc: HirNamedExpr(name: n, value: convert_expr(expr: v, entries: entries)) :: acc)
  end
end

let convert_expr_list = fn (exprs: [SpannedExpr], entries: [RenameEntry]) -> [HirExpr] do
  return convert_expr_list_go(exprs: exprs, entries: entries, acc: [])
end

let convert_expr_list_go = fn (exprs: [SpannedExpr], entries: [RenameEntry], acc: [HirExpr]) -> [HirExpr] do
  match exprs do
    | [] -> return rev_hir_expr(lst: acc, out: [])
    | e :: rest ->
      return convert_expr_list_go(exprs: rest, entries: entries, acc: convert_expr(expr: e, entries: entries) :: acc)
  end
end

// ─── Statement Conversion ───────────────────────────────────────────────────

/// Convert AST statements to HIR statements.
export let convert_stmts = fn (stmts: [SpannedStmt], entries: [RenameEntry]) -> [HirStmt] do
  return convert_stmts_go(stmts: stmts, entries: entries, acc: [])
end

let convert_stmts_go = fn (stmts: [SpannedStmt], entries: [RenameEntry], acc: [HirStmt]) -> [HirStmt] do
  match stmts do
    | [] -> return rev_hir_stmt(lst: acc, out: [])
    | SpannedStmt(node: StmtLet(name: n, sigil: sig, typ: t, value: v), span: sp) :: rest ->
      let hir_val = match sig do
        | SigilLazy ->
          // @ thunks compile eagerly in nxc: evaluate the expression immediately.
          // nxc doesn't have inline lambda lifting, so closures from @ desugaring
          // would produce malformed WASM. The typechecker still enforces @T linearity;
          // actual lazy/parallel execution is provided by the Rust compiler.
          convert_expr(expr: v, entries: entries)
        | _ ->
          convert_expr(expr: v, entries: entries)
      end
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Let(name: n, typ: t, value: hir_val), span: sp) :: acc)
    | SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp) :: rest ->
      // Desugar: let Pattern = expr; rest → match expr do case Pattern -> rest end
      let case_body = convert_stmts(stmts: rest, entries: entries)
      let match_case = HirMatchCase(
        pattern: convert_pattern(pat: pat, entries: entries),
        body: case_body
      )
      return rev_hir_stmt(lst: acc, out: [HirStmt(node: Expr(expr: HirExpr(node: Match(
          target: convert_expr(expr: v, entries: entries),
          cases: [match_case]
        ), span: sp)), span: sp)])
    | SpannedStmt(node: StmtExpr(expr: e), span: sp) :: rest ->
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Expr(expr: convert_expr(expr: e, entries: entries)), span: sp) :: acc)
    | SpannedStmt(node: StmtReturn(value: e), span: sp) :: rest ->
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Return(expr: convert_expr(expr: e, entries: entries)), span: sp) :: acc)
    | SpannedStmt(node: StmtAssign(target: t, value: v), span: sp) :: rest ->
      let zero = Span(offset: 0, line: 0, col: 0)
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Assign(
          target: HirExpr(node: Variable(name: symtab.rename(name: t, entries: entries), sigil: SigilMutable), span: zero),
          value: convert_expr(expr: v, entries: entries)
        ), span: sp) :: acc)
    | SpannedStmt(node: StmtTry(body: b, catch_arms: CatchArm(pattern: SpannedPattern(node: PatVariable(name: n, sigil: _), span: _), body: cb) :: []), span: sp) :: rest ->
      // Legacy single-arm variable catch: catch param -> body
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Try(
          body: convert_stmts(stmts: b, entries: entries),
          catch_param: n,
          catch_body: convert_stmts(stmts: cb, entries: entries)
        ), span: sp) :: acc)
    | SpannedStmt(node: StmtTry(body: b, catch_arms: arms), span: sp) :: rest ->
      // Multi-arm or non-variable: desugar to catch __exn -> match __exn do ... end
      let mir_cases = convert_catch_arms_to_match_cases(arms: arms, entries: entries)
      let match_expr = hir.Match(target: HirExpr(node: hir.Variable(name: "__exn", sigil: SigilImmutable), span: sp), cases: mir_cases)
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Try(
          body: convert_stmts(stmts: b, entries: entries),
          catch_param: "__exn",
          catch_body: [HirStmt(node: hir.Expr(expr: HirExpr(node: match_expr, span: sp)), span: sp)]
        ), span: sp) :: acc)
    | SpannedStmt(node: StmtInject(handlers: hs, body: b), span: sp) :: rest ->
      let handler_names = extract_handler_names(exprs: hs)
      let qualified_handlers = rename_strings(names: handler_names, entries: entries)
      return convert_stmts_go(stmts: rest, entries: entries, acc: HirStmt(node: Inject(
          handlers: qualified_handlers,
          body: convert_stmts(stmts: b, entries: entries)
        ), span: sp) :: acc)
  end
end

let rename_strings = fn (names: [string], entries: [RenameEntry]) -> [string] do
  return rename_strings_go(names: names, entries: entries, acc: [])
end

let rename_strings_go = fn (names: [string], entries: [RenameEntry], acc: [string]) -> [string] do
  match names do
    | [] -> return rev_string(lst: acc, out: [])
    | n :: rest ->
      return rename_strings_go(names: rest, entries: entries, acc: symtab.rename(name: n, entries: entries) :: acc)
  end
end

/// Extract handler variable names from inject handler expressions.
let extract_handler_names = fn (exprs: [SpannedExpr]) -> [string] do
  return extract_handler_names_go(exprs: exprs, acc: [])
end

let extract_handler_names_go = fn (exprs: [SpannedExpr], acc: [string]) -> [string] do
  match exprs do
    | [] -> return rev_string(lst: acc, out: [])
    | e :: rest ->
      let name = extract_handler_name_from_expr(expr: e)
      return extract_handler_names_go(exprs: rest, acc: name :: acc)
  end
end

/// Extract handler name from an expression. Handles both simple variables and dotted access.
let extract_handler_name_from_expr = fn (expr: SpannedExpr) -> string do
  let SpannedExpr(node: node, span: _) = expr
  return extract_name_from_node(node: node)
end

let extract_name_from_node = fn (node: Expr) -> string do
  match node do
    | ExprVariable(name: name, sigil: _) -> return rdr.rdr_to_string(r: name)
    | ExprFieldAccess(target: t, field: fld) ->
      let base = extract_handler_name_from_expr(expr: t)
      return base ++ "." ++ fld
    | _ -> return ""
  end
end

// ─── Pattern Conversion ─────────────────────────────────────────────────────

/// Convert match cases to HIR.
let convert_match_cases = fn (cases: [MatchCase], entries: [RenameEntry]) -> [HirMatchCase] do
  return convert_match_cases_go(cases: cases, entries: entries, acc: [])
end

let convert_match_cases_go = fn (cases: [MatchCase], entries: [RenameEntry], acc: [HirMatchCase]) -> [HirMatchCase] do
  match cases do
    | [] -> return rev_hir_match_case(lst: acc, out: [])
    | MatchCase(pattern: p, body: b) :: rest ->
      return convert_match_cases_go(cases: rest, entries: entries, acc: HirMatchCase(
          pattern: convert_pattern(pat: p, entries: entries),
          body: convert_stmts(stmts: b, entries: entries)
        ) :: acc)
  end
end

/// Convert a pattern to HIR pattern.
export let convert_pattern = fn (pat: SpannedPattern, entries: [RenameEntry]) -> HirPatternKind do
  match pat do
    | SpannedPattern(node: PatLiteral(lit: lit), span: _) ->
      return hir.PLit(lit: lit)
    | SpannedPattern(node: PatVariable(name: name, sigil: sig), span: _) ->
      return hir.PVar(name: name, sigil: sig)
    | SpannedPattern(node: PatConstructor(name: v, fields: fs), span: _) ->
      return hir.PCtor(
        variant: rdr.rdr_occ(r: v),
        fields: convert_pattern_fields(fs: fs, entries: entries)
      )
    | SpannedPattern(node: PatConstructorWildcard(name: v), span: _) ->
      return hir.PCtor(variant: rdr.rdr_occ(r: v), fields: [])
    | SpannedPattern(node: PatRecord(fields: fs, has_wildcard: p), span: _) ->
      return hir.PRec(
        fields: convert_record_pat_fields(fs: fs, entries: entries),
        is_partial: p
      )
    | SpannedPattern(node: PatWildcard, span: _) ->
      return hir.PWild
    | SpannedPattern(node: PatOr(alts: alts), span: _) ->
      return hir.POr(alts: convert_or_alts(alts: alts, entries: entries, acc: []))
  end
end

let convert_or_alts = fn (alts: [SpannedPattern], entries: [RenameEntry], acc: [HirPatternKind]) -> [HirPatternKind] do
  match alts do
    | [] -> return list.reverse(xs: acc)
    | a :: rest -> return convert_or_alts(alts: rest, entries: entries, acc: convert_pattern(pat: a, entries: entries) :: acc)
  end
end

let convert_catch_arms_to_match_cases = fn (arms: [CatchArm], entries: [RenameEntry]) -> [HirMatchCase] do
  return convert_catch_arms_go(arms: arms, entries: entries, acc: [])
end

let convert_catch_arms_go = fn (arms: [CatchArm], entries: [RenameEntry], acc: [HirMatchCase]) -> [HirMatchCase] do
  match arms do
    | [] -> return rev_hir_match_case(lst: acc, out: [])
    | CatchArm(pattern: p, body: b) :: rest ->
      let mc = HirMatchCase(pattern: convert_pattern(pat: p, entries: entries), body: convert_stmts(stmts: b, entries: entries))
      return convert_catch_arms_go(arms: rest, entries: entries, acc: mc :: acc)
  end
end

let convert_pattern_fields = fn (fs: [CtorPatternField], entries: [RenameEntry]) -> [HirPatternField] do
  return convert_pattern_fields_go(fs: fs, entries: entries, acc: [])
end

let convert_pattern_fields_go = fn (fs: [CtorPatternField], entries: [RenameEntry], acc: [HirPatternField]) -> [HirPatternField] do
  match fs do
    | [] -> return rev_hir_pattern_field(lst: acc, out: [])
    | CtorPatternField(name: n, pattern: p) :: rest ->
      return convert_pattern_fields_go(fs: rest, entries: entries, acc: HirPatternField(name: Some(val: n), pattern: convert_pattern(pat: p, entries: entries)) :: acc)
  end
end

let convert_record_pat_fields = fn (fs: [RecordPatField], entries: [RenameEntry]) -> [HirRecordPatField] do
  return convert_record_pat_fields_go(fs: fs, entries: entries, acc: [])
end

let convert_record_pat_fields_go = fn (fs: [RecordPatField], entries: [RenameEntry], acc: [HirRecordPatField]) -> [HirRecordPatField] do
  match fs do
    | [] -> return rev_hir_record_pat_field(lst: acc, out: [])
    | RecordPatField(name: n, pattern: p) :: rest ->
      return convert_record_pat_fields_go(fs: rest, entries: entries, acc: HirRecordPatField(name: n, pattern: convert_pattern(pat: p, entries: entries)) :: acc)
  end
end

// ─── Param / Function Conversion ────────────────────────────────────────────

/// Convert AST params to HIR params.
let convert_params = fn (params: [Param]) -> [HirParam] do
  return convert_params_go(params: params, acc: [])
end

let convert_params_go = fn (params: [Param], acc: [HirParam]) -> [HirParam] do
  match params do
    | [] -> return rev_hir_param(lst: acc, out: [])
    | Param(name: n, sigil: _, typ: t) :: rest ->
      return convert_params_go(params: rest, acc: HirParam(name: n, label: n, typ: t) :: acc)
  end
end

/// Convert AST functions to HIR functions.
let convert_functions = fn (funcs: [Function], entries: [RenameEntry]) -> [HirFunction] do
  return convert_functions_go(funcs: funcs, entries: entries, acc: [])
end

let convert_functions_go = fn (funcs: [Function], entries: [RenameEntry], acc: [HirFunction]) -> [HirFunction] do
  match funcs do
    | [] -> return rev_hir_function(lst: acc, out: [])
    | Function(name: n, is_public: _, type_params: tps, params: ps, ret_type: rt, requires: _, throw_row: _, body: b) :: rest ->
      return convert_functions_go(funcs: rest, entries: entries, acc: HirFunction(
          name: n,
          type_params: tps,
          params: convert_params(params: ps),
          ret_type: rt,
          body: EagerBody(stmts: convert_stmts(stmts: b, entries: entries)),
          span: Span(offset: 0, line: 0, col: 0)
        ) :: acc)
  end
end

// ─── Top-level definition processing ────────────────────────────────────────

/// Create an empty HirAccum.
export let empty_accum = fn () -> HirAccum do
  return HirAccum(
    ports: [], functions: [], externals: [],
    handler_bindings: [],
    // Seed Exn enum with built-in exception variants (matching Rust compiler's exn_enum_def()).
    // User-defined exceptions are added as variants via register_exn_variant.
    enum_defs: [EnumDef(name: "Exn", is_public: true, is_opaque: false,
      type_params: [],
      variants: [
        VariantDef(name: "RuntimeError", fields: [VariantField(name: Some(val: "val"), typ: TyString)]),
        VariantDef(name: "InvalidIndex", fields: [VariantField(name: Some(val: "val"), typ: TyI64)])])],
    wasm_module: None,
    exception_groups: []
  )
end

/// Register an exception as a variant of the Exn enum in enum_defs.
let register_exn_variant = fn (enum_defs: [EnumDef], vname: string, vfields: [VariantField]) -> [EnumDef] do
  return register_exn_variant_go(enum_defs: enum_defs, vname: vname, vfields: vfields, acc: [])
end

let register_exn_variant_go = fn (enum_defs: [EnumDef], vname: string, vfields: [VariantField], acc: [EnumDef]) -> [EnumDef] do
  match enum_defs do
    | [] -> return rev_enum_def(lst: acc, out: [])
    | ed :: rest ->
      match ed do | EnumDef(name: n, is_public: pub_, is_opaque: opq, type_params: tp, variants: vs) ->
        if n == "Exn" then
          let new_variant = VariantDef(name: vname, fields: vfields)
          return rev_enum_def(lst: acc, out: EnumDef(name: n, is_public: pub_, is_opaque: opq, type_params: tp,
            variants: new_variant :: vs) :: rest)
        else
          return register_exn_variant_go(enum_defs: rest, vname: vname, vfields: vfields, acc: ed :: acc)
        end
      end
  end
end

let stem_to_wit = fn (stem: string) -> string do
  if stem == "math" then return "nexus:stdlib/math" end
  if stem == "string_ops" then return "nexus:stdlib/string-ops" end
  if stem == "stdio" then return "nexus:stdlib/stdio" end
  if stem == "filesystem" then return "nexus:stdlib/filesystem" end
  if stem == "network" then return "nexus:stdlib/network" end
  if stem == "process" then return "nexus:stdlib/process" end
  if stem == "environment" then return "nexus:stdlib/environment" end
  if stem == "clock" then return "nexus:stdlib/clock" end
  if stem == "random" then return "nexus:stdlib/random" end
  if stem == "char" then return "nexus:stdlib/string-ops" end
  if stem == "bytebuffer" then return "nexus:stdlib/bytebuffer" end
  if stem == "hashmap" then return "nexus:stdlib/collections" end
  if stem == "stringmap" then return "nexus:stdlib/collections" end
  if stem == "set" then return "nexus:stdlib/collections" end
  if stem == "array" then return "nexus:stdlib/collections" end
  if stem == "core" then return "nexus:stdlib/core" end
  return ""
end

/// Extract file stem from a path: "stdlib/string_ops.nx" → "string", "src/backend/foo.nx" → "foo"
let extract_nx_stem = fn (path: string) -> string do
  let dot_pos = str.index_of(s: path, sub: ".nx")
  if dot_pos < 0 then return "" end
  let stem_start = find_last_slash(s: path, pos: dot_pos - 1) + 1
  return str.substring(s: path, start: stem_start, len: dot_pos - stem_start)
end

let map_stdlib_to_wit = fn (ext_path: string, source_file: string) -> string do
  // Only map "stdlib/stdlib.wasm" or "nxlib/stdlib/stdlib.wasm" style paths.
  if str.ends_with(s: ext_path, suffix: "stdlib.wasm") then
    // Try source_file stem first (normal case: stdlib .nx file importing stdlib.wasm)
    let stem = extract_nx_stem(path: source_file)
    let wit = stem_to_wit(stem: stem)
    if str.length(s: wit) > 0 then return wit end
    // Not a known stdlib file — keep as file path
    return ext_path
  end
  // If ext_path is a .nx file (e.g. "stdlib/hashmap.nx"), use its stem
  if str.ends_with(s: ext_path, suffix: ".nx") then
    let stem = extract_nx_stem(path: ext_path)
    let wit = stem_to_wit(stem: stem)
    if str.length(s: wit) > 0 then return wit end
  end
  return ext_path
end

/// Check if ffi_name has the __nx_ prefix.
/// Uses substring+equality instead of starts_with (starts_with triggers OOM
/// via cascading reachability changes in the Rust bump-allocator codegen).
let has_nx_prefix = fn (ffi_name: string) -> bool do
  if str.byte_length(s: ffi_name) < 5 then return false end
  return str.substring(s: ffi_name, start: 0, len: 5) == "__nx_"
end

/// Check if source_file is a stdlib path ("stdlib/" or "nxlib/stdlib/").
/// Uses intrinsics (byte_length+substring) to avoid starts_with OOM.
let is_stdlib_source = fn (path: string) -> bool do
  if str.byte_length(s: path) >= 7 then
    if str.substring(s: path, start: 0, len: 7) == "stdlib/" then return true end
  end
  if str.byte_length(s: path) >= 13 then
    if str.substring(s: path, start: 0, len: 13) == "nxlib/stdlib/" then return true end
  end
  return false
end

/// Build WIT name from position pos to end, replacing '_' with '-'.
let build_wit_name = fn (s: string, pos: i64, len: i64, acc: string) -> string do
  if pos >= len then return acc end
  let b = str.byte_at(s: s, idx: pos)
  let ch = if b == '_' then "-" else str.substring(s: s, start: pos, len: 1) end
  return build_wit_name(s: s, pos: pos + 1, len: len, acc: acc ++ ch)
end

/// Convert __nx_* FFI name to WIT-canonical kebab-case.
/// "__nx_abs_i64" → "abs-i64", "allocate" → "allocate"
let wit_canonical_name = fn (ffi_name: string) -> string do
  if has_nx_prefix(ffi_name: ffi_name) then
    return build_wit_name(s: ffi_name, pos: 5, len: str.byte_length(s: ffi_name), acc: "")
  end
  return ffi_name
end

let find_last_slash = fn (s: string, pos: i64) -> i64 do
  if pos < 0 then return -1 end
  let c = str.byte_at(s: s, idx: pos)
  if c == '/' then return pos end
  return find_last_slash(s: s, pos: pos - 1)
end

/// Process a list of top-level definitions into HIR components.
export let process_defs = fn (defs: [SpannedTopLevel], entries: [RenameEntry], accum: HirAccum, source_file: string) -> HirAccum do
  match defs do
    | [] -> return accum
    | SpannedTopLevel(node: node, span: sp) :: rest ->
      let new_accum = process_top_level(node: node, span: sp, entries: entries, accum: accum, source_file: source_file)
      return process_defs(defs: rest, entries: entries, accum: new_accum, source_file: source_file)
  end
end

let process_tl_let = fn (qname: string, orig_name: string, val: SpannedExpr, type_ann: Option<TypeExpr>,
    entries: [RenameEntry], span: Span, accum: HirAccum, source_file: string) -> HirAccum do
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs) = accum
  // Stdlib files: full convert_expr (handlers/externals/constants are cheap,
  // and keeping them as EagerBody avoids cumulative OOM during lazy resolve).
  // Non-stdlib: convert_expr_toplevel for Lambda bodies (deferred via LazyBody),
  // but convert_expr for Handler/External (cheap and must be handled correctly).
  let is_stdlib = is_stdlib_source(path: source_file)
  let SpannedExpr(node: val_peek, span: _) = val
  let hir_val = if is_stdlib then convert_expr(expr: val, entries: entries)
    else match val_peek do
      | ExprHandler(_) -> convert_expr(expr: val, entries: entries)
      | ExprExternal(_) -> convert_expr(expr: val, entries: entries)
      | _ -> convert_expr_toplevel(expr: val, entries: entries)
    end
  end
  let HirExpr(node: hir_val_node, span: _) = hir_val
  match hir_val_node do
    | Lambda(type_params: tps, params: lps, ret_type: rt, body: _) ->
      // All Lambdas (including main) get LazyBody. Resolved during resolve phase.
      // For constants (non-Lambda AST wrapped as Lambda by convert_expr_toplevel),
      // fix ret_type: infer_ret_from_expr returns TyUnit, but constants need proper type.
      // This is overridden during lazy body resolution (resolve_all_lazy_via_convert),
      // but set a reasonable default so pre-resolve analysis sees the right type.
      let effective_rt = match val_peek do
        | ExprLambda(_) -> rt
        | _ -> match type_ann do | Some(val: t) -> t | None -> TyI64 end
      end
      let func = HirFunction(name: qname, type_params: tps, params: lps,
        ret_type: effective_rt, body: LazyBody(ast_expr: val, entries: entries), span: span)
      return HirAccum(ports: ps, functions: func :: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
    | Handler(port_name: pname, functions: handler_funcs) ->
      let binding = synthesize_handler(
        binding_name: qname, port_name: pname, functions: handler_funcs)
      // ALSO add handler functions to the main functions list (workaround for
      // handler_bindings being dropped somewhere in the pipeline)
      let synth_funcs = match binding do
        | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, functions: sfuncs)) -> sfuncs
      end
      let merged_fs = append_hir_funcs(a: synth_funcs, b: fs)
      return HirAccum(ports: ps, functions: merged_fs, externals: exts,
        handler_bindings: binding :: hbs,
        enum_defs: eds, wasm_module: wmod, exception_groups: egs)
    | ExternalRef(symbol: sym, arg_names: anames, typ: t) ->
      match wmod do
        | Some(val: wm) ->
          // Only kebab-canonicalize for component-model modules (wm contains ':').
          // Raw-path modules (e.g. "stdlib/stdlib.wasm" fallback from map_stdlib_to_wit)
          // keep __nx_ snake names as-is to match the actual wasm exports.
          // Mirrors bootstrap/src/compiler/passes/hir_build.rs:441.
          let effective_sym = if str.contains(s: wm, sub: ":") then
              wit_canonical_name(ffi_name: sym)
            else sym
          end
          let ext = make_hir_external(name: qname, wasm_module: wm,
            wasm_name: effective_sym, arg_names: anames, typ: t)
          return HirAccum(ports: ps, functions: fs,
            externals: ext :: exts,
            handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
        | None -> return accum
      end
    | _ ->
      let rt = match type_ann do
        | Some(val: t) -> t
        | None -> infer_constant_type(expr: hir_val)
      end
        let debug_name = qname
      let func = HirFunction(
        name: debug_name, type_params: [], params: [], ret_type: rt,
        body: EagerBody(stmts: [HirStmt(node: Return(expr: hir_val), span: span)]),
        span: span)
      return HirAccum(ports: ps, functions: func :: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
  end
end

/// Extract type params from a raw AST expression.
let infer_tparams_from_expr = fn (expr: Expr) -> [string] do
  match expr do
    | ExprLambda(type_params: tps, params: _, ret_type: _, requires: _, throw_row: _, body: _) ->
      return tps
    | _ -> return []
  end
end

/// Extract HirParam list from a raw AST expression (ExprLambda → params, else []).
let infer_params_from_expr = fn (expr: Expr) -> [HirParam] do
  match expr do
    | ExprLambda(type_params: _, params: ps, ret_type: _, requires: _, throw_row: _, body: _) ->
      return convert_params(params: ps)
    | _ -> return []
  end
end

/// Extract return type from a raw AST expression (ExprLambda → ret_type, else TyUnit).
let infer_ret_from_expr = fn (expr: Expr) -> TypeExpr do
  match expr do
    | ExprLambda(type_params: _, params: _, ret_type: rt, requires: _, throw_row: _, body: _) ->
      return rt
    | _ -> return TyUnit
  end
end

let infer_constant_type = fn (expr: HirExpr) -> TypeExpr do
  let HirExpr(node: inner, span: _) = expr
  match inner do
    | Literal(lit: l) ->
      match l do
        | LitInt(_) -> return TyI64
        | LitFloat(_) -> return TyF64
        | LitString(_) -> return TyString
        | LitChar(_) -> return TyChar
        | LitBool(_) -> return TyBool
        | LitUnit -> return TyUnit
      end
    | _ -> return TyI64
  end
end

let process_top_level = fn (node: TopLevel, span: Span, entries: [RenameEntry], accum: HirAccum, source_file: string) -> HirAccum do
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs) = accum
  match node do
    | TLImport(def: ImportDef(path: path, alias: _, items: _, is_external: is_ext)) ->
      if is_ext then
        let mapped = map_stdlib_to_wit(ext_path: path, source_file: source_file)
        return HirAccum(ports: ps, functions: fs, externals: exts,
          handler_bindings: hbs, enum_defs: eds, wasm_module: Some(val: mapped), exception_groups: egs)
      else
        return accum
      end
    | TLLet(def: GlobalLet(name: name, is_public: _, typ: type_ann, value: val)) ->
      let qname = symtab.rename(name: name, entries: entries)
      return process_tl_let(qname: qname, orig_name: name, val: val, type_ann: type_ann, entries: entries,
        span: span, accum: accum, source_file: source_file)
    | TLPort(def: Port(name: pname, is_public: _, functions: sigs)) ->
      let qname = symtab.rename(name: pname, entries: entries)
      let hir_port = HirPort(name: qname, methods: convert_port_sigs(sigs: sigs))
      return HirAccum(ports: hir_port :: ps, functions: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
    | TLEnum(def: ed) ->
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs,
        enum_defs: ed :: eds, wasm_module: wmod, exception_groups: egs)
    | TLTypeDef(_) -> return accum
    | TLException(def: ExceptionDef(name: ename, is_public: _, fields: efields)) ->
      // Register exception as a variant of the Exn enum (matching Rust compiler's approach).
      // This ensures LIR lowering can resolve field names for sorted heap layout.
      let updated_eds = register_exn_variant(enum_defs: eds, vname: ename, vfields: efields)
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: updated_eds, wasm_module: wmod, exception_groups: egs)
    | TLExceptionGroup(def: ExceptionGroupDef(name: gname, is_public: _, members: gmembers)) ->
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: eds, wasm_module: wmod,
        exception_groups: ExceptionGroupEntry(name: gname, members: gmembers) :: egs)
  end
end

/// Build HirExternal from an external declaration's type arrow.
let make_hir_external = fn (name: string, wasm_module: string, wasm_name: string, arg_names: [string], typ: TypeExpr) -> HirExternal do
  match typ do
    | TyArrow(params: params, ret: ret, requires: _, throw_row: tw) ->
      return HirExternal(name: name, wasm_module: wasm_module, wasm_name: wasm_name,
        params: named_types_to_hir_params(nts: params),
        ret_type: ret, throw_row: tw)
    | _ ->
      return HirExternal(name: name, wasm_module: wasm_module, wasm_name: wasm_name,
        params: [], ret_type: typ, throw_row: TyUnit)
  end
end

let named_types_to_hir_params = fn (nts: [NamedType]) -> [HirParam] do
  return named_types_to_hir_params_go(nts: nts, acc: [])
end

let named_types_to_hir_params_go = fn (nts: [NamedType], acc: [HirParam]) -> [HirParam] do
  match nts do
    | [] -> return rev_hir_param(lst: acc, out: [])
    | NamedType(name: n, typ: t) :: rest ->
      return named_types_to_hir_params_go(nts: rest, acc: HirParam(name: n, label: n, typ: t) :: acc)
  end
end

let convert_port_sigs = fn (sigs: [FunctionSig]) -> [HirPortMethod] do
  return convert_port_sigs_go(sigs: sigs, acc: [])
end

let convert_port_sigs_go = fn (sigs: [FunctionSig], acc: [HirPortMethod]) -> [HirPortMethod] do
  match sigs do
    | [] -> return rev_hir_port_method(lst: acc, out: [])
    | FunctionSig(name: n, params: _, ret_type: _, requires: _, throw_row: _) :: rest ->
      return convert_port_sigs_go(sigs: rest, acc: HirPortMethod(name: n) :: acc)
  end
end

/// Synthesize handler binding: create named function entries for each method.
let synthesize_handler = fn (binding_name: string, port_name: string, functions: [HirFunction]) -> HirHandlerBindingEntry do
  let synth_funcs = synthesize_handler_funcs(binding_name: binding_name, functions: functions)
  return HirHandlerBindingEntry(
    name: binding_name,
    binding: HirHandlerBinding(port_name: port_name, functions: synth_funcs)
  )
end

let synthesize_handler_funcs = fn (binding_name: string, functions: [HirFunction]) -> [HirFunction] do
  return synthesize_handler_funcs_go(binding_name: binding_name, functions: functions, acc: [])
end

let synthesize_handler_funcs_go = fn (binding_name: string, functions: [HirFunction], acc: [HirFunction]) -> [HirFunction] do
  match functions do
    | [] -> return rev_hir_function(lst: acc, out: [])
    | HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, body: b, span: sp) :: rest ->
      let synth_name = naming.handler_func_name(handler_name: binding_name, method_name: n)
      return synthesize_handler_funcs_go(binding_name: binding_name, functions: rest, acc: HirFunction(name: synth_name, type_params: tps, params: ps, ret_type: rt, body: b, span: sp) :: acc)
  end
end

// ─── Exception Group Expansion ──────────────────────────────────────────────
// Post-processing pass: expand group constructor patterns in catch arms.
// When a catch arm matches a group name (e.g., CompileError), expand it to
// one match case per member exception (e.g., LexError, ParseError).

/// Look up a group name and return its members, or None if not a group.
let lookup_group = fn (name: string, groups: [ExceptionGroupEntry]) -> Option<[string]> do
  match groups do
    | [] -> return None
    | ExceptionGroupEntry(name: gn, members: ms) :: rest ->
      if gn == name then return Some(val: ms)
      else return lookup_group(name: name, groups: rest) end
  end
end

/// Expand group patterns in a list of match cases.
/// For each case with a PCtor whose variant is a group name, emit one case per member.
let expand_groups_in_cases = fn (cases: [HirMatchCase], groups: [ExceptionGroupEntry]) -> [HirMatchCase] do
  return expand_groups_in_cases_go(cases: cases, groups: groups, acc: [])
end

let expand_groups_in_cases_go = fn (cases: [HirMatchCase], groups: [ExceptionGroupEntry], acc: [HirMatchCase]) -> [HirMatchCase] do
  match cases do
    | [] -> return rev_hir_match_case(lst: acc, out: [])
    | HirMatchCase(pattern: pat, body: body) :: rest ->
      let expanded_body = expand_groups_in_stmts(stmts: body, groups: groups)
      match pat do
        | PCtor(variant: vname, fields: fs) ->
          match lookup_group(name: vname, groups: groups) do
            | Some(val: members) ->
              // Expand: emit one case per member with the same fields and body
              let member_cases = expand_group_members(members: members, fields: fs, body: expanded_body)
              return expand_groups_in_cases_go(cases: rest, groups: groups,
                acc: prepend_cases(cases: member_cases, acc: acc))
            | None ->
              return expand_groups_in_cases_go(cases: rest, groups: groups,
                acc: HirMatchCase(pattern: PCtor(variant: vname, fields: fs), body: expanded_body) :: acc)
          end
        | _ ->
          return expand_groups_in_cases_go(cases: rest, groups: groups,
            acc: HirMatchCase(pattern: pat, body: expanded_body) :: acc)
      end
  end
end

/// Create one HirMatchCase per member, preserving the same fields and body.
let expand_group_members = fn (members: [string], fields: [HirPatternField], body: [HirStmt]) -> [HirMatchCase] do
  return expand_group_members_go(members: members, fields: fields, body: body, acc: [])
end

let expand_group_members_go = fn (members: [string], fields: [HirPatternField], body: [HirStmt], acc: [HirMatchCase]) -> [HirMatchCase] do
  match members do
    | [] -> return acc
    | m :: rest ->
      return expand_group_members_go(members: rest, fields: fields, body: body,
        acc: HirMatchCase(pattern: PCtor(variant: m, fields: fields), body: body) :: acc)
  end
end

/// Prepend a list of cases onto an accumulator (in order).
let prepend_cases = fn (cases: [HirMatchCase], acc: [HirMatchCase]) -> [HirMatchCase] do
  match cases do
    | [] -> return acc
    | c :: rest -> return prepend_cases(cases: rest, acc: c :: acc)
  end
end

/// Expand group patterns in a list of statements.
let expand_groups_in_stmts = fn (stmts: [HirStmt], groups: [ExceptionGroupEntry]) -> [HirStmt] do
  return expand_groups_in_stmts_go(stmts: stmts, groups: groups, acc: [])
end

let expand_groups_in_stmts_go = fn (stmts: [HirStmt], groups: [ExceptionGroupEntry], acc: [HirStmt]) -> [HirStmt] do
  match stmts do
    | [] -> return rev_hir_stmt(lst: acc, out: [])
    | HirStmt(node: sk, span: sp) :: rest ->
      let expanded = expand_groups_in_stmt_kind(stmt: sk, groups: groups)
      return expand_groups_in_stmts_go(stmts: rest, groups: groups,
        acc: HirStmt(node: expanded, span: sp) :: acc)
  end
end

let expand_groups_in_stmt_kind = fn (stmt: HirStmtKind, groups: [ExceptionGroupEntry]) -> HirStmtKind do
  match stmt do
    | Let(name: n, typ: t, value: v) ->
      return Let(name: n, typ: t, value: expand_groups_in_expr(expr: v, groups: groups))
    | Expr(expr: e) ->
      return Expr(expr: expand_groups_in_expr(expr: e, groups: groups))
    | Return(expr: e) ->
      return Return(expr: expand_groups_in_expr(expr: e, groups: groups))
    | Assign(target: t, value: v) ->
      return Assign(
        target: expand_groups_in_expr(expr: t, groups: groups),
        value: expand_groups_in_expr(expr: v, groups: groups))
    | Try(body: b, catch_param: cp, catch_body: cb) ->
      return Try(
        body: expand_groups_in_stmts(stmts: b, groups: groups),
        catch_param: cp,
        catch_body: expand_groups_in_stmts(stmts: cb, groups: groups))
    | Inject(handlers: hs, body: b) ->
      return Inject(handlers: hs, body: expand_groups_in_stmts(stmts: b, groups: groups))
  end
end

let expand_groups_in_expr = fn (expr: HirExpr, groups: [ExceptionGroupEntry]) -> HirExpr do
  let HirExpr(node: inner, span: sp) = expr
  return HirExpr(node: expand_groups_in_expr_kind(expr: inner, groups: groups), span: sp)
end

let expand_groups_in_expr_kind = fn (expr: HirExprKind, groups: [ExceptionGroupEntry]) -> HirExprKind do
  match expr do
    | Literal(lit: l) -> return Literal(lit: l)
    | Variable(name: n, sigil: s) -> return Variable(name: n, sigil: s)
    | BinOp(left: l, op: o, right: r) ->
      return BinOp(
        left: expand_groups_in_expr(expr: l, groups: groups),
        op: o,
        right: expand_groups_in_expr(expr: r, groups: groups))
    | Borrow(name: n, sigil: s) -> return Borrow(name: n, sigil: s)
    | Call(func: f, args: args) ->
      return Call(func: f, args: expand_groups_in_call_args(args: args, groups: groups))
    | Ctor(variant: v, args: args) ->
      return Ctor(variant: v, args: expand_groups_in_expr_list(exprs: args, groups: groups))
    | Record(fields: fs) ->
      return Record(fields: expand_groups_in_named_exprs(exprs: fs, groups: groups))
    | Array(elems: es) ->
      return Array(elems: expand_groups_in_expr_list(exprs: es, groups: groups))
    | Index(target: t, index: i) ->
      return Index(
        target: expand_groups_in_expr(expr: t, groups: groups),
        index: expand_groups_in_expr(expr: i, groups: groups))
    | FieldAccess(target: t, field: f) ->
      return FieldAccess(target: expand_groups_in_expr(expr: t, groups: groups), field: f)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let new_eb = match eb do
        | None -> None
        | Some(val: stmts) -> Some(val: expand_groups_in_stmts(stmts: stmts, groups: groups))
      end
      return If(
        cond: expand_groups_in_expr(expr: c, groups: groups),
        then_branch: expand_groups_in_stmts(stmts: tb, groups: groups),
        else_branch: new_eb)
    | Match(target: t, cases: cs) ->
      return Match(
        target: expand_groups_in_expr(expr: t, groups: groups),
        cases: expand_groups_in_cases(cases: cs, groups: groups))
    | While(cond: c, body: b) ->
      return While(
        cond: expand_groups_in_expr(expr: c, groups: groups),
        body: expand_groups_in_stmts(stmts: b, groups: groups))
    | For(var: v, start: s, end_expr: e, body: b) ->
      return For(var: v,
        start: expand_groups_in_expr(expr: s, groups: groups),
        end_expr: expand_groups_in_expr(expr: e, groups: groups),
        body: expand_groups_in_stmts(stmts: b, groups: groups))
    | Lambda(type_params: tps, params: ps, ret_type: rt, body: b) ->
      return Lambda(type_params: tps, params: ps, ret_type: rt,
        body: expand_groups_in_stmts(stmts: b, groups: groups))
    | Raise(expr: e) ->
      return Raise(expr: expand_groups_in_expr(expr: e, groups: groups))
    | Force(expr: e) ->
      return Force(expr: expand_groups_in_expr(expr: e, groups: groups))
    | ExternalRef(symbol: s, arg_names: an, typ: t) ->
      return ExternalRef(symbol: s, arg_names: an, typ: t)
    | Handler(port_name: pn, functions: fs) ->
      return Handler(port_name: pn, functions: expand_groups_in_hir_functions(funcs: fs, groups: groups))
  end
end

let expand_groups_in_call_args = fn (args: [HirCallArg], groups: [ExceptionGroupEntry]) -> [HirCallArg] do
  return expand_groups_in_call_args_go(args: args, groups: groups, acc: [])
end

let expand_groups_in_call_args_go = fn (args: [HirCallArg], groups: [ExceptionGroupEntry], acc: [HirCallArg]) -> [HirCallArg] do
  match args do
    | [] -> return rev_hir_call_arg(lst: acc, out: [])
    | HirCallArg(label: l, value: v) :: rest ->
      return expand_groups_in_call_args_go(args: rest, groups: groups,
        acc: HirCallArg(label: l, value: expand_groups_in_expr(expr: v, groups: groups)) :: acc)
  end
end

let expand_groups_in_expr_list = fn (exprs: [HirExpr], groups: [ExceptionGroupEntry]) -> [HirExpr] do
  return expand_groups_in_expr_list_go(exprs: exprs, groups: groups, acc: [])
end

let expand_groups_in_expr_list_go = fn (exprs: [HirExpr], groups: [ExceptionGroupEntry], acc: [HirExpr]) -> [HirExpr] do
  match exprs do
    | [] -> return rev_hir_expr(lst: acc, out: [])
    | e :: rest ->
      return expand_groups_in_expr_list_go(exprs: rest, groups: groups,
        acc: expand_groups_in_expr(expr: e, groups: groups) :: acc)
  end
end

let expand_groups_in_named_exprs = fn (exprs: [HirNamedExpr], groups: [ExceptionGroupEntry]) -> [HirNamedExpr] do
  return expand_groups_in_named_exprs_go(exprs: exprs, groups: groups, acc: [])
end

let expand_groups_in_named_exprs_go = fn (exprs: [HirNamedExpr], groups: [ExceptionGroupEntry], acc: [HirNamedExpr]) -> [HirNamedExpr] do
  match exprs do
    | [] -> return rev_hir_named_expr(lst: acc, out: [])
    | HirNamedExpr(name: n, value: v) :: rest ->
      return expand_groups_in_named_exprs_go(exprs: rest, groups: groups,
        acc: HirNamedExpr(name: n, value: expand_groups_in_expr(expr: v, groups: groups)) :: acc)
  end
end

/// Expand groups in a list of HirFunctions.
let expand_groups_in_hir_functions = fn (funcs: [HirFunction], groups: [ExceptionGroupEntry]) -> [HirFunction] do
  return expand_groups_in_hir_functions_go(funcs: funcs, groups: groups, acc: [])
end

let expand_groups_in_hir_functions_go = fn (funcs: [HirFunction], groups: [ExceptionGroupEntry], acc: [HirFunction]) -> [HirFunction] do
  match funcs do
    | [] -> return rev_hir_function(lst: acc, out: [])
    | HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, body: EagerBody(stmts: b), span: sp) :: rest ->
      return expand_groups_in_hir_functions_go(funcs: rest, groups: groups,
        acc: HirFunction(name: n, type_params: tps, params: ps, ret_type: rt,
          body: EagerBody(stmts: expand_groups_in_stmts(stmts: b, groups: groups)), span: sp) :: acc)
    | HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, body: b, span: sp) :: rest ->
      // LazyBody: no stmts to expand, preserve as-is
      return expand_groups_in_hir_functions_go(funcs: rest, groups: groups,
        acc: HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, body: b, span: sp) :: acc)
  end
end

/// Top-level: expand groups in all program functions.
let expand_groups_in_functions = fn (funcs: [HirFunction], groups: [ExceptionGroupEntry]) -> [HirFunction] do
  match groups do
    | [] -> return funcs
    | _ :: _ -> return expand_groups_in_hir_functions(funcs: funcs, groups: groups)
  end
end

/// Top-level: expand groups in handler bindings.
let expand_groups_in_handler_bindings = fn (bindings: [HirHandlerBindingEntry], groups: [ExceptionGroupEntry]) -> [HirHandlerBindingEntry] do
  match groups do
    | [] -> return bindings
    | _ :: _ -> return expand_groups_in_handler_bindings_go(bindings: bindings, groups: groups, acc: [])
  end
end

let expand_groups_in_handler_bindings_go = fn (bindings: [HirHandlerBindingEntry], groups: [ExceptionGroupEntry], acc: [HirHandlerBindingEntry]) -> [HirHandlerBindingEntry] do
  match bindings do
    | [] -> return rev_hir_handler_binding_entry(lst: acc, out: [])
    | HirHandlerBindingEntry(name: n, binding: HirHandlerBinding(port_name: pn, functions: fs)) :: rest ->
      let expanded_fs = expand_groups_in_hir_functions(funcs: fs, groups: groups)
      return expand_groups_in_handler_bindings_go(bindings: rest, groups: groups,
        acc: HirHandlerBindingEntry(name: n, binding: HirHandlerBinding(port_name: pn, functions: expanded_fs)) :: acc)
  end
end


let extract_handler_functions = fn (bindings: [HirHandlerBindingEntry]) -> [HirFunction] do
  match bindings do
    | [] -> return []
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, functions: fs)) :: rest ->
      return append_hir_funcs(a: fs, b: extract_handler_functions(bindings: rest))
  end
end

let append_hir_funcs = fn (a: [HirFunction], b: [HirFunction]) -> [HirFunction] do
  match a do
    | [] -> return b
    | h :: t -> return h :: append_hir_funcs(a: t, b: b)
  end
end

/// Assemble a HirProgram from an accumulator with reachability filtering.
export let accum_to_program = fn (accum: HirAccum) -> HirProgram do
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: _, exception_groups: egs) = accum
  // Expand exception group patterns in catch arms before reachability filtering.
  let expanded_fs = expand_groups_in_functions(funcs: fs, groups: egs)
  let expanded_hbs = expand_groups_in_handler_bindings(bindings: hbs, groups: egs)
  let filtered_funcs = expanded_fs
  let filtered_exts = exts
  // Note: LazyBody functions are NOT resolved here. The caller (driver.nx)
  // resolves them after accum_to_program returns, because resolution requires
  // Fs capability to re-read source files.
  // Merge handler functions into the main functions list (codegen expects them there).
  let handler_funcs = extract_handler_functions(bindings: expanded_hbs)
  let all_funcs = append_hir_funcs(a: filtered_funcs, b: handler_funcs)
  return HirProgram(
    ports: ps,
    functions: all_funcs,
    externals: filtered_exts,
    handler_bindings: expanded_hbs,
    enum_defs: eds
  )
end

/// Resolve a single lazy body given AST stmts already extracted.
export let resolve_one_lazy = fn (ast_stmts: [SpannedStmt], entries: [RenameEntry]) -> [HirStmt] do
  return convert_stmts(stmts: ast_stmts, entries: entries)
end

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_string = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_string(lst: rest, out: x :: out)
  end
end

let rev_hir_call_arg = fn (lst: [HirCallArg], out: [HirCallArg]) -> [HirCallArg] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_call_arg(lst: rest, out: x :: out)
  end
end

let rev_ctor_arg = fn (lst: [CtorArg], out: [CtorArg]) -> [CtorArg] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_ctor_arg(lst: rest, out: x :: out)
  end
end

let rev_hir_expr = fn (lst: [HirExpr], out: [HirExpr]) -> [HirExpr] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_expr(lst: rest, out: x :: out)
  end
end

