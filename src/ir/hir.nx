  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_stmt(lst: rest, out: x :: out)
  end
end

let rev_hir_match_case = fn (lst: [HirMatchCase], out: [HirMatchCase]) -> [HirMatchCase] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_match_case(lst: rest, out: x :: out)
