/**
 * hir: AST → HIR conversion and HirProgram assembly.
 *
 * Owns:
 * - AST expression / statement / pattern conversion (convert_expr, convert_stmts, convert_pattern)
 * - Top-level definition processing (process_defs: functions, externals, handlers, ports, enums)
 * - Exception-group expansion across catch arms + handler bindings
 * - HirAccum → HirProgram assembly (accum_to_program)
 * - Lazy-body AST→HIR resolution (resolve_one_lazy, used by src/ir/demand.nx)
 *
 * Does not own:
 * - HIR type definitions (see src/ir/hir_types.nx)
 * - Reachability analysis / dead-code filtering (see src/ir/hir/reachability.nx)
 * - Iterative lazy-body resolution loop (see src/ir/demand.nx)
 * - Handler-function name mangling (see src/common/naming.nx)
 * - Rdr-name resolution (see src/ir/rdrname.nx, src/ir/symtab.nx)
 */
import { Span } from "src/common/token.nx"
import * as naming from "src/common/naming.nx"
import { SigilImmutable, SigilLazy, SigilMutable, TypeExpr, TyI64, TyUnit, TyArrow, TyRow, Expr, ExprLiteral, ExprVariable, ExprBinaryOp, ExprUnaryOp, ExprBorrow, ExprCall, ExprConstructor, ExprRecord, ExprArray, ExprIndex, ExprFieldAccess, ExprIf, ExprMatch, ExprWhile, ExprFor, ExprLambda, ExprRaise, ExprForce, ExprExternal, ExprHandler, ExprList, StmtLet, StmtLetPattern, StmtExpr, StmtReturn, StmtAssign, StmtIndexAssign, StmtTry, StmtInject, PatLiteral, PatVariable, PatConstructor, PatConstructorWildcard, PatRecord, PatWildcard, PatOr, SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel, Param, Function, HandlerArm, MatchCase, CallArg, CtorArg, NamedExpr, NamedType, CtorPatternField, RecordPatField, EnumDef, ImportDef, FunctionSig, Cap, GlobalLet, CatchArm, TopLevel, TLImport, TLLet, TLCap, TLEnum, TLTypeDef, TLException, TLExceptionGroup, ExceptionGroupDef, Unqual } from "src/common/ast.nx"
import { SymbolNotFound } from "src/common/error.nx"
import * as rdr from "src/ir/rdrname.nx"
import { RenameEntry }, * as symtab from "src/ir/symtab.nx"
import * as str from "std:str"
import * as list from "std:list"
import * as hir from "src/ir/hir_types.nx"
import { HirParam, HirPortMethod, HirPort, HirExternal, HirExpr, HirStmt, HirExprKind, HirStmtKind, HirCallArg, HirNamedExpr, HirMatchCase, HirPatternKind, HirPatternField, HirRecordPatField, EagerBody, LazyBody, HirFunction, HirHandlerArm, HirHandlerBinding, HirHandlerBindingEntry, HirProgram, HirAccum, ExceptionGroupEntry } from "src/ir/hir_types.nx"

// ─── AST -> HIR Conversion ──────────────────────────────────────────────────

/// Convert an AST expression (SpannedExpr) to HIR.
export let convert_expr = fn (expr: SpannedExpr, entries: [RenameEntry]) -> HirExpr throws { Exn } do
  let SpannedExpr(node, span: sp) = expr
  let hir = match node do
    | ExprLiteral(lit) ->
      Literal(lit)
    | ExprVariable(name, sigil: sig) ->
      let renamed = symtab.rename(name: rdr.rdr_to_string(r: name), entries)
      match sig do
        | SigilLazy ->
          Force(expr: HirExpr(node: Variable(name: renamed, sigil: SigilImmutable), span: sp))
        | _ ->
          Variable(name: renamed, sigil: sig)
      end
    | ExprBinaryOp(left: l, op, right: r) ->
      BinOp(
        left: convert_expr(expr: l, entries),
        op,
        right: convert_expr(expr: r, entries)
      )
    | ExprUnaryOp(op, operand: o) ->
      UnOp(op, operand: convert_expr(expr: o, entries))
    | ExprBorrow(name, sigil: sig) ->
      Borrow(name: symtab.rename(name, entries), sigil: sig)
    | ExprCall(func: f, args) ->
      Call(
        func: symtab.rename(name: rdr.rdr_to_string(r: f), entries),
        args: convert_call_args(args, entries)
      )
    | ExprConstructor(name: v, args) ->
      Ctor(
        variant: rdr.rdr_occ(r: v),
        args: convert_ctor_args(args, entries)
      )
    | ExprRecord(fields: fs) ->
      Record(fields: convert_named_exprs(exprs: fs, entries))
    | ExprArray(elements: es) ->
      Array(elems: convert_expr_list(exprs: es, entries))
    | ExprIndex(target: t, index: i) ->
      Index(
        target: convert_expr(expr: t, entries),
        index: convert_expr(expr: i, entries)
      )
    | ExprFieldAccess(target: t, field: f) ->
      // Module-qualified value access: `mod.name` in value position parses as
      // FieldAccess(Variable("mod"), "name"). If "mod.name" has a rename
      // entry (added for wildcard-aliased imports), resolve as a qualified
      // variable reference rather than a struct field access. Without this,
      // `wdefs.vt_i32` compiles as a field access on an undefined variable
      // and silently returns garbage — breaking self-hosted codegen.
      // Mirrors src/compiler/passes/hir_build.rs FieldAccess handling.
      let SpannedExpr(node: target_node, span: _) = t
      match target_node do
        | ExprVariable(name: Unqual(name: mod_name), sigil: _) ->
          let qualified_key = mod_name ++ "." ++ f
          if symtab.rename_has(name: qualified_key, entries) then
            Variable(name: symtab.rename(name: qualified_key, entries), sigil: SigilImmutable)
          else
            FieldAccess(target: convert_expr(expr: t, entries), field: f)
          end
        | _ ->
          FieldAccess(target: convert_expr(expr: t, entries), field: f)
      end
    | ExprIf(cond: c, then_branch: tb, else_branch: eb) ->
      let hir_else = match eb do
        | [] -> None
        | _ :: _ -> Some(val: convert_stmts(stmts: eb, entries))
      end
      If(
        cond: convert_expr(expr: c, entries),
        then_branch: convert_stmts(stmts: tb, entries),
        else_branch: hir_else
      )
    | ExprMatch(target: t, cases: cs) ->
      Match(
        target: convert_expr(expr: t, entries),
        cases: convert_match_cases(cases: cs, entries)
      )
    | ExprWhile(cond: c, body: b) ->
      While(
        cond: convert_expr(expr: c, entries),
        body: convert_stmts(stmts: b, entries)
      )
    | ExprFor(var: v, start: s, end_expr: e, body: b) ->
      For(
        var: v,
        start: convert_expr(expr: s, entries),
        end_expr: convert_expr(expr: e, entries),
        body: convert_stmts(stmts: b, entries)
      )
    | ExprLambda(type_params: tps, params: ps, ret_type: rt, requires: _, throw_row: _, body: b) ->
      Lambda(
        type_params: tps,
        params: convert_params(params: ps),
        ret_type: rt,
        body: convert_stmts(stmts: b, entries)
      )
    | ExprRaise(value: e) ->
      Raise(expr: convert_expr(expr: e, entries))
    | ExprForce(value: e) ->
      Force(expr: convert_expr(expr: e, entries))
    | ExprExternal(symbol: sym, type_params: tps, arg_names: names, typ: t) ->
      ExternalRef(symbol: sym, type_params: tps, arg_names: names, typ: t)
    | ExprHandler(coeffect_name: pname, requires: _, arms: arms) ->
      Handler(port_name: symtab.rename(name: pname, entries), arms: convert_handler_arms(arms, entries))
    | ExprList(elements: es) ->
      // Extract inner node from desugar_list result — span comes from outer wrapping
      let HirExpr(node: desugared, span: _) = desugar_list(elems: es, entries, span: sp)
      desugared
  end
  return HirExpr(node: hir, span: sp)
end

/// Convert a top-level AST expression, ALWAYS skipping body conversion.
/// Returns Lambda with empty body for everything — the caller (process_tl_let)
/// matches on the HirExprKind to distinguish Lambda from External/Handler.
/// Non-Lambda TLLets get LazyBody too, but resolve_lazy_bodies handles the
/// empty-body case gracefully (returns empty stmts).
let convert_expr_toplevel = fn (expr: SpannedExpr, entries: [RenameEntry]) -> HirExpr throws { Exn } do
  let SpannedExpr(node, span: sp) = expr
  let tps = infer_tparams_from_expr(expr: node)
  let ps = infer_params_from_expr(expr: node)
  let rt = infer_ret_from_expr(expr: node)
  return HirExpr(node: Lambda(type_params: tps, params: ps, ret_type: rt, body: []), span: sp)
end

/// Desugar [a, b, c] -> a :: b :: c :: []
/// Args are unlabeled, so they must be in alphabetical field order: (rest, v)
/// Each synthesised Cons inherits the head element's span so type errors land
/// on the offending element; the terminating Nil and the outermost wrapper
/// inherit the surrounding `[...]` span so errors against the empty list shape
/// (or the whole literal) still point at user-visible source.
let desugar_list = fn (elems: [SpannedExpr], entries: [RenameEntry], span: Span) -> HirExpr throws { Exn } do
  let reversed = rev_spanned_expr(lst: elems, out: [])
  let inner = desugar_list_go(elems: reversed, entries,
    acc: HirExpr(node: Ctor(variant: "Nil", args: []), span))
  let HirExpr(node: result_node, span: _) = inner
  return HirExpr(node: result_node, span)
end

let desugar_list_go = fn (elems: [SpannedExpr], entries: [RenameEntry], acc: HirExpr) -> HirExpr throws { Exn } do
  match elems do
    | [] -> return acc
    | e :: rest ->
      let SpannedExpr(node: _, span: head_sp) = e
      let head = convert_expr(expr: e, entries)
      return desugar_list_go(elems: rest, entries,
        acc: HirExpr(node: Ctor(variant: "Cons", args: [acc, head]), span: head_sp))
  end
end

let convert_call_args = fn (args: [CallArg], entries: [RenameEntry]) -> [HirCallArg] throws { Exn } do
  return convert_call_args_go(args, entries, acc: [])
end

let convert_call_args_go = fn (args: [CallArg], entries: [RenameEntry], acc: [HirCallArg]) -> [HirCallArg] throws { Exn } do
  match args do
    | [] -> return rev_hir_call_arg(lst: acc, out: [])
    | CallArg(name: l, value: v) :: rest ->
      return convert_call_args_go(args: rest, entries, acc: HirCallArg(label: l, value: convert_expr(expr: v, entries)) :: acc)
  end
end

// ─── Constructor field sorting (alphabetical, matching memory layout) ────────

let str_less_than_loop = fn (a: string, b: string, idx: i64, la: i64, lb: i64) -> bool throws { Exn } do
  if idx >= la then
    return idx < lb
  else if idx >= lb then
    return false
  else
    let ca = str.char_code(s: a, idx)
    let cb = str.char_code(s: b, idx)
    if ca < cb then
      return true
    else if ca > cb then
      return false
    else
      return str_less_than_loop(a, b, idx: idx + 1, la, lb)
    end
  end
end

let str_less_than = fn (a: string, b: string) -> bool throws { Exn } do
  return str_less_than_loop(a, b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end

let ctor_arg_name = fn (arg: CtorArg) -> string throws { Exn } do
  match arg do
    | CtorArg(name: n, value: _) -> return n
  end
end

let insert_ctor_arg = fn (arg: CtorArg, sorted: [CtorArg]) -> [CtorArg] throws { Exn } do
  return insert_ctor_arg_go(arg, sorted, acc: [])
end

let insert_ctor_arg_go = fn (arg: CtorArg, sorted: [CtorArg], acc: [CtorArg]) -> [CtorArg] throws { Exn } do
  match sorted do
    | [] -> return rev_ctor_arg(lst: acc, out: [arg])
    | head :: rest ->
      if str_less_than(a: ctor_arg_name(arg), b: ctor_arg_name(arg: head)) then
        return rev_ctor_arg(lst: acc, out: arg :: sorted)
      else
        return insert_ctor_arg_go(arg, sorted: rest, acc: head :: acc)
      end
  end
end

let sort_ctor_args = fn (args: [CtorArg]) -> [CtorArg] throws { Exn } do
  return sort_ctor_args_go(args, sorted: [])
end

let sort_ctor_args_go = fn (args: [CtorArg], sorted: [CtorArg]) -> [CtorArg] throws { Exn } do
  match args do
    | [] -> return sorted
    | a :: rest -> return sort_ctor_args_go(args: rest, sorted: insert_ctor_arg(arg: a, sorted))
  end
end

let convert_ctor_args = fn (args: [CtorArg], entries: [RenameEntry]) -> [HirExpr] throws { Exn } do
  return convert_ctor_args_inner(args: sort_ctor_args(args), entries)
end

let convert_ctor_args_inner = fn (args: [CtorArg], entries: [RenameEntry]) -> [HirExpr] throws { Exn } do
  return convert_ctor_args_inner_go(args, entries, acc: [])
end

let convert_ctor_args_inner_go = fn (args: [CtorArg], entries: [RenameEntry], acc: [HirExpr]) -> [HirExpr] throws { Exn } do
  match args do
    | [] -> return rev_hir_expr(lst: acc, out: [])
    | CtorArg(name: _, value: v) :: rest ->
      return convert_ctor_args_inner_go(args: rest, entries, acc: convert_expr(expr: v, entries) :: acc)
  end
end

let convert_named_exprs = fn (exprs: [NamedExpr], entries: [RenameEntry]) -> [HirNamedExpr] throws { Exn } do
  return convert_named_exprs_go(exprs, entries, acc: [])
end

let convert_named_exprs_go = fn (exprs: [NamedExpr], entries: [RenameEntry], acc: [HirNamedExpr]) -> [HirNamedExpr] throws { Exn } do
  match exprs do
    | [] -> return rev_hir_named_expr(lst: acc, out: [])
    | NamedExpr(name: n, value: v) :: rest ->
      return convert_named_exprs_go(exprs: rest, entries, acc: HirNamedExpr(name: n, value: convert_expr(expr: v, entries)) :: acc)
  end
end

let convert_expr_list = fn (exprs: [SpannedExpr], entries: [RenameEntry]) -> [HirExpr] throws { Exn } do
  return convert_expr_list_go(exprs, entries, acc: [])
end

let convert_expr_list_go = fn (exprs: [SpannedExpr], entries: [RenameEntry], acc: [HirExpr]) -> [HirExpr] throws { Exn } do
  match exprs do
    | [] -> return rev_hir_expr(lst: acc, out: [])
    | e :: rest ->
      return convert_expr_list_go(exprs: rest, entries, acc: convert_expr(expr: e, entries) :: acc)
  end
end

// ─── Statement Conversion ───────────────────────────────────────────────────

/// Convert AST statements to HIR statements.
export let convert_stmts = fn (stmts: [SpannedStmt], entries: [RenameEntry]) -> [HirStmt] throws { Exn } do
  return convert_stmts_go(stmts, entries, acc: [])
end

let convert_stmts_go = fn (stmts: [SpannedStmt], entries: [RenameEntry], acc: [HirStmt]) -> [HirStmt] throws { Exn } do
  match stmts do
    | [] -> return rev_hir_stmt(lst: acc, out: [])
    | SpannedStmt(node: StmtLet(name: n, sigil: sig, typ: t, value: v), span: sp) :: rest ->
      let SpannedExpr(node: _, span: vsp) = v
      let hir_val = match sig do
        | SigilLazy ->
          HirExpr(node: Thunk(body: convert_expr(expr: v, entries)), span: vsp)
        | _ ->
          convert_expr(expr: v, entries)
      end
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Let(name: n, sigil: sig, typ: t, value: hir_val), span: sp) :: acc)
    | SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp) :: rest ->
      // Desugar: let Pattern = expr; rest → match expr do case Pattern -> rest end
      let case_body = convert_stmts(stmts: rest, entries)
      let match_case = HirMatchCase(
        pattern: convert_pattern(pat, entries),
        body: case_body
      )
      return rev_hir_stmt(lst: acc, out: [HirStmt(node: Expr(expr: HirExpr(node: Match(
          target: convert_expr(expr: v, entries),
          cases: [match_case]
        ), span: sp)), span: sp)])
    | SpannedStmt(node: StmtExpr(expr: e), span: sp) :: rest ->
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Expr(expr: convert_expr(expr: e, entries)), span: sp) :: acc)
    | SpannedStmt(node: StmtReturn(value: e), span: sp) :: rest ->
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Return(expr: convert_expr(expr: e, entries)), span: sp) :: acc)
    | SpannedStmt(node: StmtAssign(target: t, value: v), span: sp) :: rest ->
      // Synthetic Variable target inherits the assignment statement span so
      // unbound-target errors land on the user's `x = ...` line rather than 0.
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Assign(
          target: HirExpr(node: Variable(name: symtab.rename(name: t, entries), sigil: SigilMutable), span: sp),
          value: convert_expr(expr: v, entries)
        ), span: sp) :: acc)
    | SpannedStmt(node: StmtIndexAssign(target: arr, index: idx, value: v), span: sp) :: rest ->
      // Indexed assignment `arr[idx] <- val` (nexus-s06g): convert to HIR
      // Assign with an Index target. HIR Assign already takes HirExpr, so
      // downstream IR / typecheck see a uniform shape.
      let arr_hir = convert_expr(expr: arr, entries)
      let idx_hir = convert_expr(expr: idx, entries)
      let v_hir = convert_expr(expr: v, entries)
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Assign(
          target: HirExpr(node: Index(target: arr_hir, index: idx_hir), span: sp),
          value: v_hir
        ), span: sp) :: acc)
    | SpannedStmt(node: StmtTry(body: b, catch_arms: CatchArm(pattern: SpannedPattern(node: PatVariable(name: n, sigil: _), span: _), body: cb) :: []), span: sp) :: rest ->
      // Legacy single-arm variable catch: catch param -> body
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Try(
          body: convert_stmts(stmts: b, entries),
          catch_param: n,
          catch_body: convert_stmts(stmts: cb, entries)
        ), span: sp) :: acc)
    | SpannedStmt(node: StmtTry(body: b, catch_arms: arms), span: sp) :: rest ->
      // Multi-arm or non-variable: desugar to catch __exn -> match __exn do ... end
      let mir_cases = convert_catch_arms_to_match_cases(arms, entries)
      let match_expr = hir.Match(target: HirExpr(node: hir.Variable(name: "__exn", sigil: SigilImmutable), span: sp), cases: mir_cases)
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Try(
          body: convert_stmts(stmts: b, entries),
          catch_param: "__exn",
          catch_body: [HirStmt(node: hir.Expr(expr: HirExpr(node: match_expr, span: sp)), span: sp)]
        ), span: sp) :: acc)
    | SpannedStmt(node: StmtInject(handlers: hs, body: b), span: sp) :: rest ->
      let handler_names = extract_handler_names(exprs: hs)
      let qualified_handlers = rename_strings(names: handler_names, entries)
      return convert_stmts_go(stmts: rest, entries, acc: HirStmt(node: Inject(
          handlers: qualified_handlers,
          body: convert_stmts(stmts: b, entries)
        ), span: sp) :: acc)
  end
end

let rename_strings = fn (names: [string], entries: [RenameEntry]) -> [string] throws { Exn } do
  return rename_strings_go(names, entries, acc: [])
end

let rename_strings_go = fn (names: [string], entries: [RenameEntry], acc: [string]) -> [string] throws { Exn } do
  match names do
    | [] -> return rev_string(lst: acc, out: [])
    | n :: rest ->
      return rename_strings_go(names: rest, entries, acc: symtab.rename(name: n, entries) :: acc)
  end
end

/// Extract handler variable names from inject handler expressions.
let extract_handler_names = fn (exprs: [SpannedExpr]) -> [string] throws { Exn } do
  return extract_handler_names_go(exprs, acc: [])
end

let extract_handler_names_go = fn (exprs: [SpannedExpr], acc: [string]) -> [string] throws { Exn } do
  match exprs do
    | [] -> return rev_string(lst: acc, out: [])
    | e :: rest ->
      let name = extract_handler_name_from_expr(expr: e)
      return extract_handler_names_go(exprs: rest, acc: name :: acc)
  end
end

/// Extract handler name from an expression. Handles both simple variables and dotted access.
let extract_handler_name_from_expr = fn (expr: SpannedExpr) -> string throws { Exn } do
  let SpannedExpr(node, span: _) = expr
  return extract_name_from_node(node)
end

let extract_name_from_node = fn (node: Expr) -> string throws { Exn } do
  match node do
    | ExprVariable(name, sigil: _) -> return rdr.rdr_to_string(r: name)
    | ExprFieldAccess(target: t, field: fld) ->
      let base = extract_handler_name_from_expr(expr: t)
      return base ++ "." ++ fld
    | _ -> raise SymbolNotFound(name: "<non-name expression>", kind: "inject handler", context: "extract_name_from_node: inject handler must be a variable or dotted path")
  end
end

// ─── Pattern Conversion ─────────────────────────────────────────────────────

/// Convert match cases to HIR.
let convert_match_cases = fn (cases: [MatchCase], entries: [RenameEntry]) -> [HirMatchCase] throws { Exn } do
  return convert_match_cases_go(cases, entries, acc: [])
end

let convert_match_cases_go = fn (cases: [MatchCase], entries: [RenameEntry], acc: [HirMatchCase]) -> [HirMatchCase] throws { Exn } do
  match cases do
    | [] -> return rev_hir_match_case(lst: acc, out: [])
    | MatchCase(pattern: p, body: b) :: rest ->
      return convert_match_cases_go(cases: rest, entries, acc: HirMatchCase(
          pattern: convert_pattern(pat: p, entries),
          body: convert_stmts(stmts: b, entries)
        ) :: acc)
  end
end

/// Convert a pattern to HIR pattern.
export let convert_pattern = fn (pat: SpannedPattern, entries: [RenameEntry]) -> HirPatternKind throws { Exn } do
  match pat do
    | SpannedPattern(node: PatLiteral(lit), span: _) ->
      return hir.PLit(lit)
    | SpannedPattern(node: PatVariable(name, sigil: sig), span: _) ->
      return hir.PVar(name, sigil: sig)
    | SpannedPattern(node: PatConstructor(name: v, fields: fs), span: _) ->
      return hir.PCtor(
        variant: rdr.rdr_occ(r: v),
        fields: convert_pattern_fields(fs, entries)
      )
    | SpannedPattern(node: PatConstructorWildcard(name: v), span: _) ->
      return hir.PCtor(variant: rdr.rdr_occ(r: v), fields: [])
    | SpannedPattern(node: PatRecord(fields: fs, has_wildcard: p), span: _) ->
      return hir.PRec(
        fields: convert_record_pat_fields(fs, entries),
        is_partial: p
      )
    | SpannedPattern(node: PatWildcard, span: _) ->
      return hir.PWild
    | SpannedPattern(node: PatOr(alts), span: _) ->
      return hir.POr(alts: convert_or_alts(alts, entries, acc: []))
  end
end

let convert_or_alts = fn (alts: [SpannedPattern], entries: [RenameEntry], acc: [HirPatternKind]) -> [HirPatternKind] throws { Exn } do
  match alts do
    | [] -> return list.reverse(xs: acc)
    | a :: rest -> return convert_or_alts(alts: rest, entries, acc: convert_pattern(pat: a, entries) :: acc)
  end
end

let convert_catch_arms_to_match_cases = fn (arms: [CatchArm], entries: [RenameEntry]) -> [HirMatchCase] throws { Exn } do
  return convert_catch_arms_go(arms, entries, acc: [])
end

let convert_catch_arms_go = fn (arms: [CatchArm], entries: [RenameEntry], acc: [HirMatchCase]) -> [HirMatchCase] throws { Exn } do
  match arms do
    | [] -> return rev_hir_match_case(lst: acc, out: [])
    | CatchArm(pattern: p, body: b) :: rest ->
      let mc = HirMatchCase(pattern: convert_pattern(pat: p, entries), body: convert_stmts(stmts: b, entries))
      return convert_catch_arms_go(arms: rest, entries, acc: mc :: acc)
  end
end

let convert_pattern_fields = fn (fs: [CtorPatternField], entries: [RenameEntry]) -> [HirPatternField] throws { Exn } do
  return convert_pattern_fields_go(fs, entries, acc: [])
end

let convert_pattern_fields_go = fn (fs: [CtorPatternField], entries: [RenameEntry], acc: [HirPatternField]) -> [HirPatternField] throws { Exn } do
  match fs do
    | [] -> return rev_hir_pattern_field(lst: acc, out: [])
    | CtorPatternField(name: n, pattern: p) :: rest ->
      return convert_pattern_fields_go(fs: rest, entries, acc: HirPatternField(name: Some(val: n), pattern: convert_pattern(pat: p, entries)) :: acc)
  end
end

let convert_record_pat_fields = fn (fs: [RecordPatField], entries: [RenameEntry]) -> [HirRecordPatField] throws { Exn } do
  return convert_record_pat_fields_go(fs, entries, acc: [])
end

let convert_record_pat_fields_go = fn (fs: [RecordPatField], entries: [RenameEntry], acc: [HirRecordPatField]) -> [HirRecordPatField] throws { Exn } do
  match fs do
    | [] -> return rev_hir_record_pat_field(lst: acc, out: [])
    | RecordPatField(name: n, pattern: p) :: rest ->
      return convert_record_pat_fields_go(fs: rest, entries, acc: HirRecordPatField(name: n, pattern: convert_pattern(pat: p, entries)) :: acc)
  end
end

// ─── Param / Function Conversion ────────────────────────────────────────────

/// Convert AST params to HIR params.
let convert_params = fn (params: [Param]) -> [HirParam] throws { Exn } do
  return convert_params_go(params, acc: [])
end

let convert_params_go = fn (params: [Param], acc: [HirParam]) -> [HirParam] throws { Exn } do
  match params do
    | [] -> return rev_hir_param(lst: acc, out: [])
    | Param(name: n, sigil: _, typ: t) :: rest ->
      return convert_params_go(params: rest, acc: HirParam(name: n, label: n, typ: t) :: acc)
  end
end

/// Convert a handler's HandlerArm list to HIR handler arms. Each arm's
/// inner Function is converted via convert_one_function; the cont_binder
/// (if any) propagates through to MIR/codegen for lowering to wasm
/// stack-switching (Phase 2 of nexus-x7w).
let convert_handler_arms = fn (arms: [HandlerArm], entries: [RenameEntry]) -> [HirHandlerArm] throws { Exn } do
  return convert_handler_arms_go(arms, entries, acc: [])
end

let convert_handler_arms_go = fn (arms: [HandlerArm], entries: [RenameEntry], acc: [HirHandlerArm]) -> [HirHandlerArm] throws { Exn } do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | HandlerArm(arm: f, cont_binder: kb, span: _) :: rest ->
      let hir_fn = convert_one_function(func: f, entries)
      return convert_handler_arms_go(arms: rest, entries, acc: HirHandlerArm(arm: hir_fn, cont_binder: kb) :: acc)
  end
end

/// Lowers an AST `Function` into a `HirFunction`. The `span` field threads
/// the source position (e.g. the `fn` keyword for handler arms) through to
/// HIR so LSP hover/definition queries land on byte-accurate offsets.
///
/// `file` is left empty here — only handler arms reach this entry, and
/// `synthesize_handler` rewrites every arm with the binding's `source_file`
/// before the arm is exposed via `extract_handler_functions`. Direct
/// consumers of the unmangled arm function would see the empty sentinel
/// (issue nexus-qgfh design choice ii).
let convert_one_function = fn (func: Function, entries: [RenameEntry]) -> HirFunction throws { Exn } do
  let Function(name: n, is_public: _, type_params: tps, params: ps, ret_type: rt, requires: _, throw_row: tw, body: b, span: sp) = func
  return HirFunction(
    name: n,
    type_params: tps,
    params: convert_params(params: ps),
    ret_type: rt,
    throw_row: tw,
    body: EagerBody(stmts: convert_stmts(stmts: b, entries)),
    span: sp,
    file: ""
  )
end

// ─── Top-level definition processing ────────────────────────────────────────

/// Create an empty HirAccum.
export let empty_accum = fn () -> HirAccum throws { Exn } do
  return HirAccum(
    ports: [], functions: [], externals: [],
    handler_bindings: [],
    // Seed Exn enum with built-in exception variants (matching Rust compiler's exn_enum_def()).
    // User-defined exceptions are added as variants via register_exn_variant.
    enum_defs: [EnumDef(name: "Exn", is_public: true, is_opaque: false,
      type_params: [],
      variants: [
        VariantDef(name: "RuntimeError", fields: [VariantField(name: Some(val: "val"), typ: TyString)]),
        VariantDef(name: "InvalidIndex", fields: [VariantField(name: Some(val: "val"), typ: TyI64)])])],
    wasm_module: None,
    exception_groups: []
  )
end

/// Register an exception as a variant of the Exn enum in enum_defs.
let register_exn_variant = fn (enum_defs: [EnumDef], vname: string, vfields: [VariantField]) -> [EnumDef] throws { Exn } do
  return register_exn_variant_go(enum_defs, vname, vfields, acc: [])
end

let register_exn_variant_go = fn (enum_defs: [EnumDef], vname: string, vfields: [VariantField], acc: [EnumDef]) -> [EnumDef] throws { Exn } do
  match enum_defs do
    | [] -> return rev_enum_def(lst: acc, out: [])
    | ed :: rest ->
      match ed do | EnumDef(name: n, is_public: pub_, is_opaque: opq, type_params: tp, variants: vs) ->
        if n == "Exn" then
          let new_variant = VariantDef(name: vname, fields: vfields)
          return rev_enum_def(lst: acc, out: EnumDef(name: n, is_public: pub_, is_opaque: opq, type_params: tp,
            variants: new_variant :: vs) :: rest)
        else
          return register_exn_variant_go(enum_defs: rest, vname, vfields, acc: ed :: acc)
        end
      end
  end
end

let stem_to_wit = fn (stem: string) -> string throws { Exn } do
  if stem == "math" then return "nexus:std/math" end
  if stem == "str" then return "nexus:std/str" end
  if stem == "stdio" then return "nexus:std/stdio" end
  if stem == "fs" then return "nexus:std/fs" end
  if stem == "network" then return "nexus:std/network" end
  if stem == "proc" then return "nexus:std/proc" end
  if stem == "env" then return "nexus:std/env" end
  if stem == "clock" then return "nexus:std/clock" end
  if stem == "rand" then return "nexus:std/rand" end
  if stem == "char" then return "nexus:std/str" end
  if stem == "bytebuffer" then return "nexus:std/bytebuffer" end
  if stem == "hashmap" then return "nexus:std/collections" end
  if stem == "stringmap" then return "nexus:std/collections" end
  if stem == "set" then return "nexus:std/collections" end
  if stem == "array" then return "nexus:std/collections" end
  if stem == "core" then return "nexus:std/core" end
  return ""
end

/// Extract file stem from a path: "stdlib/str.nx" → "string", "src/backend/foo.nx" → "foo"
let extract_nx_stem = fn (path: string) -> string throws { Exn } do
  let dot_pos = str.index_of(s: path, sub: ".nx")
  if dot_pos < 0 then return "" end
  let stem_start = find_last_slash(s: path, pos: dot_pos - 1) + 1
  return str.substring(s: path, start: stem_start, len: dot_pos - stem_start)
end

/// Convert `pkg:path` to `nexus:pkg/path` per the package-resolver convention.
/// Returns the empty string for paths without a `:` separator.
let qualified_to_wit = fn (ext_path: string) -> string throws { Exn } do
  let colon_pos = str.index_of(s: ext_path, sub: ":")
  if colon_pos < 0 then return "" end
  let pkg = str.substring(s: ext_path, start: 0, len: colon_pos)
  let rest = str.substring(s: ext_path, start: colon_pos + 1, len: str.byte_length(s: ext_path) - colon_pos - 1)
  if str.length(s: pkg) == 0 then return "" end
  if str.length(s: rest) == 0 then return "" end
  // Already a `namespace:pkg/iface` WIT name — leave it alone.
  if str.contains(s: rest, sub: "/") then return ext_path end
  return "nexus:" ++ pkg ++ "/" ++ rest
end

let map_stdlib_to_wit = fn (ext_path: string, source_file: string) -> string throws { Exn } do
  // New convention: `pkg:iface` resolves to `nexus:pkg/iface` directly.
  let qual = qualified_to_wit(ext_path)
  if str.length(s: qual) > 0 then return qual end
  // Legacy "stdlib/stdlib.wasm" form: derive WIT name from source file stem.
  if str.ends_with(s: ext_path, suffix: "stdlib.wasm") then
    let stem = extract_nx_stem(path: source_file)
    let wit = stem_to_wit(stem)
    if str.length(s: wit) > 0 then return wit end
    return ext_path
  end
  // Legacy ".nx" form: derive from the .nx file's stem.
  if str.ends_with(s: ext_path, suffix: ".nx") then
    let stem = extract_nx_stem(path: ext_path)
    let wit = stem_to_wit(stem)
    if str.length(s: wit) > 0 then return wit end
  end
  return ext_path
end

/// Check if ffi_name has the __nx_ prefix.
/// Uses substring+equality instead of starts_with (starts_with triggers OOM
/// via cascading reachability changes in the Rust bump-allocator codegen).
let has_nx_prefix = fn (ffi_name: string) -> bool throws { Exn } do
  if str.byte_length(s: ffi_name) < 5 then return false end
  return str.substring(s: ffi_name, start: 0, len: 5) == "__nx_"
end

/// Check if source_file is a stdlib path ("stdlib/" or "nxlib/stdlib/").
/// Uses intrinsics (byte_length+substring) to avoid starts_with OOM.
let is_stdlib_source = fn (path: string) -> bool throws { Exn } do
  if str.byte_length(s: path) >= 7 then
    if str.substring(s: path, start: 0, len: 7) == "stdlib/" then return true end
  end
  if str.byte_length(s: path) >= 13 then
    if str.substring(s: path, start: 0, len: 13) == "nxlib/stdlib/" then return true end
  end
  return false
end

/// Build WIT name from position pos to end, replacing '_' with '-'.
let build_wit_name = fn (s: string, pos: i64, len: i64, acc: string) -> string throws { Exn } do
  if pos >= len then return acc end
  let b = str.byte_at(s, idx: pos)
  let ch = if b == '_' then "-" else str.substring(s, start: pos, len: 1) end
  return build_wit_name(s, pos: pos + 1, len, acc: acc ++ ch)
end

/// Convert __nx_* FFI name to WIT-canonical kebab-case.
/// "__nx_abs_i64" → "abs-i64", "allocate" → "allocate"
let wit_canonical_name = fn (ffi_name: string) -> string throws { Exn } do
  if has_nx_prefix(ffi_name) then
    return build_wit_name(s: ffi_name, pos: 5, len: str.byte_length(s: ffi_name), acc: "")
  end
  return ffi_name
end

let find_last_slash = fn (s: string, pos: i64) -> i64 throws { Exn } do
  if pos < 0 then return -1 end
  let c = str.byte_at(s, idx: pos)
  if c == '/' then return pos end
  return find_last_slash(s, pos: pos - 1)
end

/// Process a list of top-level definitions into HIR components.
export let process_defs = fn (defs: [SpannedTopLevel], entries: [RenameEntry], accum: HirAccum, source_file: string) -> HirAccum throws { Exn } do
  match defs do
    | [] -> return accum
    | SpannedTopLevel(node, span: sp) :: rest ->
      let new_accum = process_top_level(node, span: sp, entries, accum, source_file)
      return process_defs(defs: rest, entries, accum: new_accum, source_file)
  end
end

let process_tl_let = fn (qname: string, orig_name: string, val: SpannedExpr, type_ann: Option<TypeExpr>,
    entries: [RenameEntry], span: Span, accum: HirAccum, source_file: string) -> HirAccum throws { Exn } do
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs) = accum
  // Stdlib files: full convert_expr (handlers/externals/constants are cheap,
  // and keeping them as EagerBody avoids cumulative OOM during lazy resolve).
  // Non-stdlib: convert_expr_toplevel for Lambda bodies (deferred via LazyBody),
  // but convert_expr for Handler/External (cheap and must be handled correctly).
  let is_stdlib = is_stdlib_source(path: source_file)
  let SpannedExpr(node: val_peek, span: _) = val
  let hir_val = if is_stdlib then convert_expr(expr: val, entries)
    else match val_peek do
      | ExprHandler(_) -> convert_expr(expr: val, entries)
      | ExprExternal(_) -> convert_expr(expr: val, entries)
      | _ -> convert_expr_toplevel(expr: val, entries)
    end
  end
  let HirExpr(node: hir_val_node, span: _) = hir_val
  match hir_val_node do
    | Lambda(type_params: tps, params: lps, ret_type: rt, body: _) ->
      // Lambdas get LazyBody — ret_type is the user-declared return type (rt).
      // Non-lambda globals wrapped as Lambda (by convert_expr_toplevel) reach
      // here for `let x = <expr>`. The TyI64 fallback for un-annotated cases
      // is a placeholder: resolve_all_lazy_via_convert re-runs body inference
      // and overwrites the HirFunction ret_type with the real type before
      // typecheck sees it. Raising here would reject legitimate un-annotated
      // globals like `let x = Some(val: 1)`. See nexus-9lp4.18.
      let effective_rt = match val_peek do
        | ExprLambda(_) -> rt
        | _ -> match type_ann do | Some(val: t) -> t | None -> TyI64 end
      end
      // Pull throw_row from the ExprLambda when present; non-lambda lazy bodies
      // (e.g. constant `let x = expr`) carry no row, so default to empty.
      let lambda_throw_row = match val_peek do
        | ExprLambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: tw, body: _) -> tw
        | _ -> TyRow(types: [], rest: None)
      end
      let func = HirFunction(name: qname, type_params: tps, params: lps,
        ret_type: effective_rt, throw_row: lambda_throw_row, body: LazyBody(ast_expr: val, entries), span, file: source_file)
      return HirAccum(ports: ps, functions: func :: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
    | Handler(port_name: pname, arms: handler_arms) ->
      let binding = synthesize_handler(
        binding_name: qname, port_name: pname, arms: handler_arms, source_file)
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: binding :: hbs,
        enum_defs: eds, wasm_module: wmod, exception_groups: egs)
    | ExternalRef(symbol: sym, type_params: tps, arg_names: anames, typ: t) ->
      match wmod do
        | Some(val: wm) ->
          // Only kebab-canonicalize for component-model modules (wm contains ':').
          // Raw-path modules (e.g. "stdlib/stdlib.wasm" fallback from map_stdlib_to_wit)
          // keep __nx_ snake names as-is to match the actual wasm exports.
          // Mirrors bootstrap/src/compiler/passes/hir_build.rs:441.
          let effective_sym = if str.contains(s: wm, sub: ":") then
              wit_canonical_name(ffi_name: sym)
            else sym
          end
          let ext = make_hir_external(name: qname, wasm_module: wm,
            wasm_name: effective_sym, type_params: tps, arg_names: anames, typ: t)
          return HirAccum(ports: ps, functions: fs,
            externals: ext :: exts,
            handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
        | None -> raise SymbolNotFound(name: qname, kind: "external", context: "hir.convert_global: external declaration requires a preceding 'import external \"path/to.wasm\"' — none found in this file")
      end
    | _ ->
      let rt = match type_ann do
        | Some(val: t) -> t
        | None -> infer_constant_type(expr: hir_val)
      end
        let debug_name = qname
      let func = HirFunction(
        name: debug_name, type_params: [], params: [], ret_type: rt,
        throw_row: TyRow(types: [], rest: None),
        body: EagerBody(stmts: [HirStmt(node: Return(expr: hir_val), span)]),
        span,
        file: source_file)
      return HirAccum(ports: ps, functions: func :: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
  end
end

/// Extract type params from a raw AST expression.
let infer_tparams_from_expr = fn (expr: Expr) -> [string] throws { Exn } do
  if let ExprLambda(type_params: tps, params: _, ret_type: _, requires: _, throw_row: _, body: _) = expr then
    return tps
  else
    return []
  end
end

/// Extract HirParam list from a raw AST expression (ExprLambda → params, else []).
let infer_params_from_expr = fn (expr: Expr) -> [HirParam] throws { Exn } do
  if let ExprLambda(type_params: _, params: ps, ret_type: _, requires: _, throw_row: _, body: _) = expr then
    return convert_params(params: ps)
  else
    return []
  end
end

/// Extract return type from a raw AST expression (ExprLambda → ret_type, else TyUnit).
let infer_ret_from_expr = fn (expr: Expr) -> TypeExpr throws { Exn } do
  if let ExprLambda(type_params: _, params: _, ret_type: rt, requires: _, throw_row: _, body: _) = expr then
    return rt
  else
    return TyUnit
  end
end

let infer_constant_type = fn (expr: HirExpr) -> TypeExpr throws { Exn } do
  let HirExpr(node: inner, span: _) = expr
  if let Literal(lit: l) = inner then
    match l do
      | LitInt(_) -> return TyI64
      | LitFloat(_) -> return TyF64
      | LitString(_) -> return TyString
      | LitChar(_) -> return TyChar
      | LitBool(_) -> return TyBool
      | LitUnit -> return TyUnit
    end
  else
    // Non-literal globals reach here only at HIR-build time, before typecheck
    // has run. The TyI64 placeholder is overwritten with the real inferred
    // type during typecheck (see check.check_function: the env_insert for a
    // zero-arg let rebinds at the real type once body inference completes).
    // We cannot run inference here because the env is not yet populated.
    // Raising would reject legitimate non-annotated globals like
    // `let x = Some(val: 1)` whose type typecheck derives from the body.
    return TyI64
  end
end

let process_top_level = fn (node: TopLevel, span: Span, entries: [RenameEntry], accum: HirAccum, source_file: string) -> HirAccum throws { Exn } do
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs) = accum
  match node do
    | TLImport(def: ImportDef(path, alias: _, items: _, is_external: is_ext)) ->
      if is_ext then
        let mapped = map_stdlib_to_wit(ext_path: path, source_file)
        return HirAccum(ports: ps, functions: fs, externals: exts,
          handler_bindings: hbs, enum_defs: eds, wasm_module: Some(val: mapped), exception_groups: egs)
      else
        return accum
      end
    | TLLet(def: GlobalLet(name, is_public: _, typ: type_ann, value: val)) ->
      let qname = symtab.rename(name, entries)
      return process_tl_let(qname, orig_name: name, val, type_ann, entries,
        span, accum, source_file)
    | TLCap(def: Cap(name: pname, is_public: _, functions: sigs)) ->
      let qname = symtab.rename(name: pname, entries)
      let hir_port = HirPort(name: qname, methods: convert_port_sigs(sigs))
      return HirAccum(ports: hir_port :: ps, functions: fs,
        externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: wmod, exception_groups: egs)
    | TLEnum(def: ed) ->
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs,
        enum_defs: ed :: eds, wasm_module: wmod, exception_groups: egs)
    | TLTypeDef(_) -> return accum
    | TLException(def: ExceptionDef(name: ename, is_public: _, fields: efields)) ->
      // Register exception as a variant of the Exn enum (matching Rust compiler's approach).
      // This ensures LIR lowering can resolve field names for sorted heap layout.
      let updated_eds = register_exn_variant(enum_defs: eds, vname: ename, vfields: efields)
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: updated_eds, wasm_module: wmod, exception_groups: egs)
    | TLExceptionGroup(def: ExceptionGroupDef(name: gname, is_public: _, members: gmembers)) ->
      return HirAccum(ports: ps, functions: fs, externals: exts,
        handler_bindings: hbs, enum_defs: eds, wasm_module: wmod,
        exception_groups: ExceptionGroupEntry(name: gname, members: gmembers) :: egs)
  end
end

/// Build HirExternal from an external declaration's type arrow.
let make_hir_external = fn (name: string, wasm_module: string, wasm_name: string, type_params: [string], arg_names: [string], typ: TypeExpr) -> HirExternal throws { Exn } do
  if let TyArrow(params, ret, requires: _, throw_row: tw) = typ then
    return HirExternal(name, wasm_module, wasm_name, type_params,
      params: named_types_to_hir_params(nts: params),
      ret_type: ret, throw_row: tw)
  else
    return HirExternal(name, wasm_module, wasm_name, type_params,
      params: [], ret_type: typ, throw_row: TyUnit)
  end
end

let named_types_to_hir_params = fn (nts: [NamedType]) -> [HirParam] throws { Exn } do
  return named_types_to_hir_params_go(nts, acc: [])
end

let named_types_to_hir_params_go = fn (nts: [NamedType], acc: [HirParam]) -> [HirParam] throws { Exn } do
  match nts do
    | [] -> return rev_hir_param(lst: acc, out: [])
    | NamedType(name: n, typ: t) :: rest ->
      return named_types_to_hir_params_go(nts: rest, acc: HirParam(name: n, label: n, typ: t) :: acc)
  end
end

let convert_port_sigs = fn (sigs: [FunctionSig]) -> [HirPortMethod] throws { Exn } do
  return convert_port_sigs_go(sigs, acc: [])
end

let convert_port_sigs_go = fn (sigs: [FunctionSig], acc: [HirPortMethod]) -> [HirPortMethod] throws { Exn } do
  match sigs do
    | [] -> return rev_hir_port_method(lst: acc, out: [])
    | FunctionSig(name: n, params: _, ret_type: _, requires: _, throw_row: _) :: rest ->
      return convert_port_sigs_go(sigs: rest, acc: HirPortMethod(name: n) :: acc)
  end
end

/// Synthesize handler binding: create named arm entries for each method.
/// `source_file` is the path of the file declaring the handler binding —
/// every synthesised arm function is tagged with it so cross-file LSP
/// diagnostics can attribute typecheck failures inside the arm body to
/// the right file (issue nexus-qgfh).
let synthesize_handler = fn (binding_name: string, port_name: string, arms: [HirHandlerArm], source_file: string) -> HirHandlerBindingEntry throws { Exn } do
  let synth_arms = synthesize_handler_arms(binding_name, arms, source_file)
  return HirHandlerBindingEntry(
    name: binding_name,
    binding: HirHandlerBinding(port_name, arms: synth_arms)
  )
end

let synthesize_handler_arms = fn (binding_name: string, arms: [HirHandlerArm], source_file: string) -> [HirHandlerArm] throws { Exn } do
  return synthesize_handler_arms_go(binding_name, arms, source_file, acc: [])
end

let synthesize_handler_arms_go = fn (binding_name: string, arms: [HirHandlerArm], source_file: string, acc: [HirHandlerArm]) -> [HirHandlerArm] throws { Exn } do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | HirHandlerArm(arm: HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, throw_row: tw, body: b, span: sp, file: _), cont_binder: kb) :: rest ->
      let synth_name = naming.handler_func_name(handler_name: binding_name, method_name: n)
      let synth_params = match kb do
        | Some(val: k) ->
          let k_p = HirParam(name: k, label: k, typ: TyLazy(inner: rt))
          list.concat(xs: ps, ys: [k_p])
        | None -> ps
      end
      let synth_arm = HirHandlerArm(arm: HirFunction(name: synth_name, type_params: tps, params: synth_params, ret_type: rt, throw_row: tw, body: b, span: sp, file: source_file), cont_binder: kb)
      return synthesize_handler_arms_go(binding_name, arms: rest, source_file, acc: synth_arm :: acc)
  end
end

/// Extract just the inner HirFunctions from a list of arms, dropping
/// cont_binder info. Used when feeding the global function table that
/// only knows about plain functions; cont_binder semantics live in
/// HirHandlerBinding which is processed separately.
export let handler_arm_functions = fn (arms: [HirHandlerArm]) -> [HirFunction] throws { Exn } do
  return handler_arm_functions_go(arms, acc: [])
end

let handler_arm_functions_go = fn (arms: [HirHandlerArm], acc: [HirFunction]) -> [HirFunction] throws { Exn } do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | HirHandlerArm(arm: f, cont_binder: _) :: rest ->
      return handler_arm_functions_go(arms: rest, acc: f :: acc)
  end
end

// ─── Exception Group Expansion ──────────────────────────────────────────────
// Post-processing pass: expand group constructor patterns in catch arms.
// When a catch arm matches a group name (e.g., CompileError), expand it to
// one match case per member exception (e.g., LexError, ParseError).

/// Look up a group name and return its members, or None if not a group.
let lookup_group = fn (name: string, groups: [ExceptionGroupEntry]) -> Option<[string]> throws { Exn } do
  match groups do
    | [] -> return None
    | ExceptionGroupEntry(name: gn, members: ms) :: rest ->
      if gn == name then return Some(val: ms)
      else return lookup_group(name, groups: rest) end
  end
end

/// Expand group patterns in a list of match cases.
/// For each case with a PCtor whose variant is a group name, emit one case per member.
let expand_groups_in_cases = fn (cases: [HirMatchCase], groups: [ExceptionGroupEntry]) -> [HirMatchCase] throws { Exn } do
  return expand_groups_in_cases_go(cases, groups, acc: [])
end

let expand_groups_in_cases_go = fn (cases: [HirMatchCase], groups: [ExceptionGroupEntry], acc: [HirMatchCase]) -> [HirMatchCase] throws { Exn } do
  match cases do
    | [] -> return rev_hir_match_case(lst: acc, out: [])
    | HirMatchCase(pattern: pat, body) :: rest ->
      let expanded_body = expand_groups_in_stmts(stmts: body, groups)
      match pat do
        | PCtor(variant: vname, fields: fs) ->
          match lookup_group(name: vname, groups) do
            | Some(val: members) ->
              // Expand: emit one case per member with the same fields and body
              let member_cases = expand_group_members(members, fields: fs, body: expanded_body)
              return expand_groups_in_cases_go(cases: rest, groups,
                acc: prepend_cases(cases: member_cases, acc))
            | None ->
              return expand_groups_in_cases_go(cases: rest, groups,
                acc: HirMatchCase(pattern: PCtor(variant: vname, fields: fs), body: expanded_body) :: acc)
          end
        | _ ->
          return expand_groups_in_cases_go(cases: rest, groups,
            acc: HirMatchCase(pattern: pat, body: expanded_body) :: acc)
      end
  end
end

/// Create one HirMatchCase per member, preserving the same fields and body.
let expand_group_members = fn (members: [string], fields: [HirPatternField], body: [HirStmt]) -> [HirMatchCase] throws { Exn } do
  return expand_group_members_go(members, fields, body, acc: [])
end

let expand_group_members_go = fn (members: [string], fields: [HirPatternField], body: [HirStmt], acc: [HirMatchCase]) -> [HirMatchCase] throws { Exn } do
  match members do
    | [] -> return acc
    | m :: rest ->
      return expand_group_members_go(members: rest, fields, body,
        acc: HirMatchCase(pattern: PCtor(variant: m, fields), body) :: acc)
  end
end

/// Prepend a list of cases onto an accumulator (in order).
let prepend_cases = fn (cases: [HirMatchCase], acc: [HirMatchCase]) -> [HirMatchCase] throws { Exn } do
  match cases do
    | [] -> return acc
    | c :: rest -> return prepend_cases(cases: rest, acc: c :: acc)
  end
end

/// Expand group patterns in a list of statements.
let expand_groups_in_stmts = fn (stmts: [HirStmt], groups: [ExceptionGroupEntry]) -> [HirStmt] throws { Exn } do
  return expand_groups_in_stmts_go(stmts, groups, acc: [])
end

let expand_groups_in_stmts_go = fn (stmts: [HirStmt], groups: [ExceptionGroupEntry], acc: [HirStmt]) -> [HirStmt] throws { Exn } do
  match stmts do
    | [] -> return rev_hir_stmt(lst: acc, out: [])
    | HirStmt(node: sk, span: sp) :: rest ->
      let expanded = expand_groups_in_stmt_kind(stmt: sk, groups)
      return expand_groups_in_stmts_go(stmts: rest, groups,
        acc: HirStmt(node: expanded, span: sp) :: acc)
  end
end

let expand_groups_in_stmt_kind = fn (stmt: HirStmtKind, groups: [ExceptionGroupEntry]) -> HirStmtKind throws { Exn } do
  match stmt do
    | Let(name: n, sigil: sig, typ: t, value: v) ->
      return Let(name: n, sigil: sig, typ: t, value: expand_groups_in_expr(expr: v, groups))
    | Expr(expr: e) ->
      return Expr(expr: expand_groups_in_expr(expr: e, groups))
    | Return(expr: e) ->
      return Return(expr: expand_groups_in_expr(expr: e, groups))
    | Assign(target: t, value: v) ->
      return Assign(
        target: expand_groups_in_expr(expr: t, groups),
        value: expand_groups_in_expr(expr: v, groups))
    | Try(body: b, catch_param: cp, catch_body: cb) ->
      return Try(
        body: expand_groups_in_stmts(stmts: b, groups),
        catch_param: cp,
        catch_body: expand_groups_in_stmts(stmts: cb, groups))
    | Inject(handlers: hs, body: b) ->
      return Inject(handlers: hs, body: expand_groups_in_stmts(stmts: b, groups))
  end
end

let expand_groups_in_expr = fn (expr: HirExpr, groups: [ExceptionGroupEntry]) -> HirExpr throws { Exn } do
  let HirExpr(node: inner, span: sp) = expr
  return HirExpr(node: expand_groups_in_expr_kind(expr: inner, groups), span: sp)
end

let expand_groups_in_expr_kind = fn (expr: HirExprKind, groups: [ExceptionGroupEntry]) -> HirExprKind throws { Exn } do
  match expr do
    | Literal(lit: l) -> return Literal(lit: l)
    | Variable(name: n, sigil: s) -> return Variable(name: n, sigil: s)
    | BinOp(left: l, op: o, right: r) ->
      return BinOp(
        left: expand_groups_in_expr(expr: l, groups),
        op: o,
        right: expand_groups_in_expr(expr: r, groups))
    | UnOp(op: o, operand: x) ->
      return UnOp(op: o, operand: expand_groups_in_expr(expr: x, groups))
    | Borrow(name: n, sigil: s) -> return Borrow(name: n, sigil: s)
    | Call(func: f, args) ->
      return Call(func: f, args: expand_groups_in_call_args(args, groups))
    | Ctor(variant: v, args) ->
      return Ctor(variant: v, args: expand_groups_in_expr_list(exprs: args, groups))
    | Record(fields: fs) ->
      return Record(fields: expand_groups_in_named_exprs(exprs: fs, groups))
    | Array(elems: es) ->
      return Array(elems: expand_groups_in_expr_list(exprs: es, groups))
    | Index(target: t, index: i) ->
      return Index(
        target: expand_groups_in_expr(expr: t, groups),
        index: expand_groups_in_expr(expr: i, groups))
    | FieldAccess(target: t, field: f) ->
      return FieldAccess(target: expand_groups_in_expr(expr: t, groups), field: f)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let new_eb = match eb do
        | None -> None
        | Some(val: stmts) -> Some(val: expand_groups_in_stmts(stmts, groups))
      end
      return If(
        cond: expand_groups_in_expr(expr: c, groups),
        then_branch: expand_groups_in_stmts(stmts: tb, groups),
        else_branch: new_eb)
    | Match(target: t, cases: cs) ->
      return Match(
        target: expand_groups_in_expr(expr: t, groups),
        cases: expand_groups_in_cases(cases: cs, groups))
    | While(cond: c, body: b) ->
      return While(
        cond: expand_groups_in_expr(expr: c, groups),
        body: expand_groups_in_stmts(stmts: b, groups))
    | For(var: v, start: s, end_expr: e, body: b) ->
      return For(var: v,
        start: expand_groups_in_expr(expr: s, groups),
        end_expr: expand_groups_in_expr(expr: e, groups),
        body: expand_groups_in_stmts(stmts: b, groups))
    | Lambda(type_params: tps, params: ps, ret_type: rt, body: b) ->
      return Lambda(type_params: tps, params: ps, ret_type: rt,
        body: expand_groups_in_stmts(stmts: b, groups))
    | Raise(expr: e) ->
      return Raise(expr: expand_groups_in_expr(expr: e, groups))
    | Force(expr: e) ->
      return Force(expr: expand_groups_in_expr(expr: e, groups))
    | Thunk(body: b) ->
      return Thunk(body: expand_groups_in_expr(expr: b, groups))
    | ExternalRef(symbol: s, type_params: tps, arg_names: an, typ: t) ->
      return ExternalRef(symbol: s, type_params: tps, arg_names: an, typ: t)
    | Handler(port_name: pn, arms: arms) ->
      return Handler(port_name: pn, arms: expand_groups_in_hir_arms(arms, groups))
  end
end

let expand_groups_in_call_args = fn (args: [HirCallArg], groups: [ExceptionGroupEntry]) -> [HirCallArg] throws { Exn } do
  return expand_groups_in_call_args_go(args, groups, acc: [])
end

let expand_groups_in_call_args_go = fn (args: [HirCallArg], groups: [ExceptionGroupEntry], acc: [HirCallArg]) -> [HirCallArg] throws { Exn } do
  match args do
    | [] -> return rev_hir_call_arg(lst: acc, out: [])
    | HirCallArg(label: l, value: v) :: rest ->
      return expand_groups_in_call_args_go(args: rest, groups,
        acc: HirCallArg(label: l, value: expand_groups_in_expr(expr: v, groups)) :: acc)
  end
end

let expand_groups_in_expr_list = fn (exprs: [HirExpr], groups: [ExceptionGroupEntry]) -> [HirExpr] throws { Exn } do
  return expand_groups_in_expr_list_go(exprs, groups, acc: [])
end

let expand_groups_in_expr_list_go = fn (exprs: [HirExpr], groups: [ExceptionGroupEntry], acc: [HirExpr]) -> [HirExpr] throws { Exn } do
  match exprs do
    | [] -> return rev_hir_expr(lst: acc, out: [])
    | e :: rest ->
      return expand_groups_in_expr_list_go(exprs: rest, groups,
        acc: expand_groups_in_expr(expr: e, groups) :: acc)
  end
end

let expand_groups_in_named_exprs = fn (exprs: [HirNamedExpr], groups: [ExceptionGroupEntry]) -> [HirNamedExpr] throws { Exn } do
  return expand_groups_in_named_exprs_go(exprs, groups, acc: [])
end

let expand_groups_in_named_exprs_go = fn (exprs: [HirNamedExpr], groups: [ExceptionGroupEntry], acc: [HirNamedExpr]) -> [HirNamedExpr] throws { Exn } do
  match exprs do
    | [] -> return rev_hir_named_expr(lst: acc, out: [])
    | HirNamedExpr(name: n, value: v) :: rest ->
      return expand_groups_in_named_exprs_go(exprs: rest, groups,
        acc: HirNamedExpr(name: n, value: expand_groups_in_expr(expr: v, groups)) :: acc)
  end
end

/// Expand groups in a list of HirFunctions.
let expand_groups_in_hir_functions = fn (funcs: [HirFunction], groups: [ExceptionGroupEntry]) -> [HirFunction] throws { Exn } do
  return expand_groups_in_hir_functions_go(funcs, groups, acc: [])
end

let expand_groups_in_hir_functions_go = fn (funcs: [HirFunction], groups: [ExceptionGroupEntry], acc: [HirFunction]) -> [HirFunction] throws { Exn } do
  match funcs do
    | [] -> return rev_hir_function(lst: acc, out: [])
    | HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, throw_row: tw, body: EagerBody(stmts: b), span: sp, file: fp) :: rest ->
      return expand_groups_in_hir_functions_go(funcs: rest, groups,
        acc: HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, throw_row: tw,
          body: EagerBody(stmts: expand_groups_in_stmts(stmts: b, groups)), span: sp, file: fp) :: acc)
    | HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, throw_row: tw, body: b, span: sp, file: fp) :: rest ->
      // LazyBody: no stmts to expand, preserve as-is
      return expand_groups_in_hir_functions_go(funcs: rest, groups,
        acc: HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, throw_row: tw, body: b, span: sp, file: fp) :: acc)
  end
end

/// Top-level: expand groups in all program functions.
let expand_groups_in_functions = fn (funcs: [HirFunction], groups: [ExceptionGroupEntry]) -> [HirFunction] throws { Exn } do
  match groups do
    | [] -> return funcs
    | _ :: _ -> return expand_groups_in_hir_functions(funcs, groups)
  end
end

/// Top-level: expand groups in handler bindings.
let expand_groups_in_handler_bindings = fn (bindings: [HirHandlerBindingEntry], groups: [ExceptionGroupEntry]) -> [HirHandlerBindingEntry] throws { Exn } do
  match groups do
    | [] -> return bindings
    | _ :: _ -> return expand_groups_in_handler_bindings_go(bindings, groups, acc: [])
  end
end

let expand_groups_in_handler_bindings_go = fn (bindings: [HirHandlerBindingEntry], groups: [ExceptionGroupEntry], acc: [HirHandlerBindingEntry]) -> [HirHandlerBindingEntry] throws { Exn } do
  match bindings do
    | [] -> return rev_hir_handler_binding_entry(lst: acc, out: [])
    | HirHandlerBindingEntry(name: n, binding: HirHandlerBinding(port_name: pn, arms: arms)) :: rest ->
      let expanded_arms = expand_groups_in_hir_arms(arms, groups)
      return expand_groups_in_handler_bindings_go(bindings: rest, groups,
        acc: HirHandlerBindingEntry(name: n, binding: HirHandlerBinding(port_name: pn, arms: expanded_arms)) :: acc)
  end
end

/// Run group-expansion over each arm's inner function, preserving the
/// arm's cont_binder.
let expand_groups_in_hir_arms = fn (arms: [HirHandlerArm], groups: [ExceptionGroupEntry]) -> [HirHandlerArm] throws { Exn } do
  return expand_groups_in_hir_arms_go(arms, groups, acc: [])
end

let expand_groups_in_hir_arms_go = fn (arms: [HirHandlerArm], groups: [ExceptionGroupEntry], acc: [HirHandlerArm]) -> [HirHandlerArm] throws { Exn } do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | HirHandlerArm(arm: f, cont_binder: kb) :: rest ->
      let expanded = expand_groups_in_hir_functions(funcs: [f], groups)
      let f2 = match expanded do | h :: _ -> h | [] -> f end
      return expand_groups_in_hir_arms_go(arms: rest, groups,
        acc: HirHandlerArm(arm: f2, cont_binder: kb) :: acc)
  end
end


let extract_handler_functions = fn (bindings: [HirHandlerBindingEntry]) -> [HirFunction] throws { Exn } do
  match bindings do
    | [] -> return []
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, arms: arms)) :: rest ->
      return append_hir_funcs(a: handler_arm_functions(arms), b: extract_handler_functions(bindings: rest))
  end
end

let append_hir_funcs = fn (a: [HirFunction], b: [HirFunction]) -> [HirFunction] throws { Exn } do
  match a do
    | [] -> return b
    | h :: t -> return h :: append_hir_funcs(a: t, b)
  end
end

/// Assemble a HirProgram from an accumulator with reachability filtering.
export let accum_to_program = fn (accum: HirAccum) -> HirProgram throws { Exn } do
  let HirAccum(ports: ps, functions: fs, externals: exts, handler_bindings: hbs, enum_defs: eds, wasm_module: _, exception_groups: egs) = accum
  // Expand exception group patterns in catch arms before reachability filtering.
  let expanded_fs = expand_groups_in_functions(funcs: fs, groups: egs)
  let expanded_hbs = expand_groups_in_handler_bindings(bindings: hbs, groups: egs)
  let filtered_funcs = expanded_fs
  let filtered_exts = exts
  // Note: LazyBody functions are NOT resolved here. The caller (driver.nx)
  // resolves them after accum_to_program returns, because resolution requires
  // Fs capability to re-read source files.
  // Handler arm functions are lowered separately via lower_handler_functions
  // (which sets cont_binders for `with @k` arms). Don't merge them into the
  // global function table — they would otherwise be lowered twice.
  let all_funcs = filtered_funcs
  return HirProgram(
    ports: ps,
    functions: all_funcs,
    externals: filtered_exts,
    handler_bindings: expanded_hbs,
    enum_defs: eds,
    exception_groups: egs
  )
end

/// Resolve a single lazy body given AST stmts already extracted.
export let resolve_one_lazy = fn (ast_stmts: [SpannedStmt], entries: [RenameEntry]) -> [HirStmt] throws { Exn } do
  return convert_stmts(stmts: ast_stmts, entries)
end

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_string = fn (lst: [string], out: [string]) -> [string] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_string(lst: rest, out: x :: out)
  end
end

let rev_hir_call_arg = fn (lst: [HirCallArg], out: [HirCallArg]) -> [HirCallArg] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_call_arg(lst: rest, out: x :: out)
  end
end

let rev_ctor_arg = fn (lst: [CtorArg], out: [CtorArg]) -> [CtorArg] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_ctor_arg(lst: rest, out: x :: out)
  end
end

let rev_hir_expr = fn (lst: [HirExpr], out: [HirExpr]) -> [HirExpr] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_expr(lst: rest, out: x :: out)
  end
end

let rev_hir_named_expr = fn (lst: [HirNamedExpr], out: [HirNamedExpr]) -> [HirNamedExpr] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_named_expr(lst: rest, out: x :: out)
  end
end

let rev_hir_stmt = fn (lst: [HirStmt], out: [HirStmt]) -> [HirStmt] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_stmt(lst: rest, out: x :: out)
  end
end

let rev_hir_match_case = fn (lst: [HirMatchCase], out: [HirMatchCase]) -> [HirMatchCase] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_match_case(lst: rest, out: x :: out)
  end
end

let rev_hir_pattern_field = fn (lst: [HirPatternField], out: [HirPatternField]) -> [HirPatternField] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_pattern_field(lst: rest, out: x :: out)
  end
end

let rev_hir_record_pat_field = fn (lst: [HirRecordPatField], out: [HirRecordPatField]) -> [HirRecordPatField] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_record_pat_field(lst: rest, out: x :: out)
  end
end

let rev_hir_param = fn (lst: [HirParam], out: [HirParam]) -> [HirParam] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_param(lst: rest, out: x :: out)
  end
end

let rev_hir_function = fn (lst: [HirFunction], out: [HirFunction]) -> [HirFunction] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_function(lst: rest, out: x :: out)
  end
end

let rev_enum_def = fn (lst: [EnumDef], out: [EnumDef]) -> [EnumDef] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_enum_def(lst: rest, out: x :: out)
  end
end

let rev_hir_port_method = fn (lst: [HirPortMethod], out: [HirPortMethod]) -> [HirPortMethod] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_port_method(lst: rest, out: x :: out)
  end
end

let rev_hir_handler_binding_entry = fn (lst: [HirHandlerBindingEntry], out: [HirHandlerBindingEntry]) -> [HirHandlerBindingEntry] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_handler_binding_entry(lst: rest, out: x :: out)
  end
end

let rev_spanned_expr = fn (lst: [SpannedExpr], out: [SpannedExpr]) -> [SpannedExpr] throws { Exn } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_spanned_expr(lst: rest, out: x :: out)
  end
end
