let rev_hir_handler_binding_entry = fn (lst: [HirHandlerBindingEntry], out: [HirHandlerBindingEntry]) -> [HirHandlerBindingEntry] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_handler_binding_entry(lst: rest, out: x :: out)
