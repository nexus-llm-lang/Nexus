let rev_hir_pattern_field = fn (lst: [HirPatternField], out: [HirPatternField]) -> [HirPatternField] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_pattern_field(lst: rest, out: x :: out)
  end
end

let rev_hir_record_pat_field = fn (lst: [HirRecordPatField], out: [HirRecordPatField]) -> [HirRecordPatField] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_record_pat_field(lst: rest, out: x :: out)
  end
end

let rev_hir_param = fn (lst: [HirParam], out: [HirParam]) -> [HirParam] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_param(lst: rest, out: x :: out)
  end
