/**
 * fmt_core: Pure byte-level formatter for Nexus source files.
 *
 * Split out from src/tools/fmt.nx so that downstream
 * consumers — notably the LSP `textDocument/formatting` handler — can
 * import `format_source` without pulling in the argparse-driven CLI
 * surface that lives in fmt.nx proper. Keeping the LSP build's
 * transitive reach trimmed avoids the codegen-DCE manifestation
 * that surfaces when a large reachable set of stdlib helpers comes
 * along for the ride.
 *
 * Scope mirrors the v1 spec from fmt.nx, plus v2 inner-spacing, v3 line-wrap,
 * and v4 join:
 *   1. Tab -> 2 spaces in leading indentation.
 *   2. Strip trailing whitespace on every line.
 *   3. Collapse runs of 2+ blank lines down to a single blank line.
 *   4. Ensure exactly one trailing newline at EOF.
 *   5. Record literals `{a: 1}` -> `{ a: 1 }` (inner spaces).
 *   6. List literals `[a, b]` -> `[ a, b ]` (inner spaces).
 *      Index expressions `arr[i]` stay TIGHT (no spaces added).
 *      Empty `{}` and `[]` stay tight.
 *   7. Lines exceeding 100 columns are broken at the first comma-separated
 *      group at the outermost nesting level (pass-2 line-wrapping).
 *   8. Multi-line groups whose joined form fits in 100 cols are collapsed
 *      back to one line (pass-3 joining — inverse of pass 2). Passes 2
 *      and 3 compose to a stable fixpoint: canonical form is one-line
 *      iff <= 100 cols, expanded otherwise.
 *      Re-indentation by do/end depth is NOT applied (deferred).
 *
 * The pass is byte-level and preserves string/char literals, line
 * comments, block comments (nested), and bracket strings `[=[ ... ]=]`
 * byte-for-byte — including any newlines they contain.
 *
 * Literal vs. index `[` classification: `[` is treated as an index
 * (no inner spacing) when the last emitted code byte (non-ws, non-nl)
 * is a letter, digit, `_`, `)`, or `]`. All other positions yield a
 * list literal and receive inner spaces.
 *
 * Pass-2 (line wrapping) lives in src/fmt/wrap.nx.
 * Pass-3 (group joining)  lives in src/fmt/join.nx.
 * Shared byte-scanners    live in src/fmt/scan.nx.
 */

import * as str from "std:str"
import * as char from "std:char"
import * as bb from "std:bytebuffer"
import { Option, Some, None } from "std:option"
import {
  scan_line_comment,
  scan_block_comment,
  scan_string,
  scan_char,
  scan_bracket_string,
  block_comment_closed,
  string_closed,
  bracket_string_closed,
  chunk_ended_on_newline
} from "src/fmt/scan.nx"
import { wrap_long_lines } from "src/fmt/wrap.nx"
import { join_broken_lines } from "src/fmt/join.nx"

// FmtState carries the per-byte state of the single-pass walk:
//   - pos / len: cursor into `src`
//   - buf: output ByteBuffer (linear)
//   - ws_run_len: bytes of pending whitespace held back at the end of the
//     current code line. Emitted on a non-whitespace byte; discarded on
//     newline (this implements trailing-whitespace strip).
//   - pending_nls: count of newlines awaiting emission. Newlines are NOT
//     emitted greedily — they are buffered and released at the next
//     non-newline byte (capped at 2 = one blank line) or at EOF (capped at
//     1 = a single trailing terminator). This is what collapses runs of
//     blank lines and what trims trailing blank lines.
//   - pending_indent: count of leading-indent spaces (after tab expansion)
//     awaiting emission. Held back until we see the first non-ws byte on
//     the line; discarded along with pending_nls if the line turns out to
//     be blank. This is how trailing-whitespace strip handles blank lines
//     that are not literally empty (e.g. "   \n").
//   - emitted_anything: true once at least one non-newline byte has been
//     emitted. Until then pending newlines are discarded — this strips
//     leading blank lines at the top of the file.
//   - at_line_start: true iff next non-newline non-whitespace byte will be
//     the first non-blank on its line. Drives the tab-as-indent expansion.
//   - last_code_byte: the last byte written to buf that is not whitespace
//     or a newline (0 = nothing written yet). Used to classify `[` as
//     literal vs. index and to decide whether to inject a closing space.
//   - bracket_depth: total count of unclosed `[` (both literal and index).
//   - lit_bracket_depth: count of unclosed literal `[` only. When
//     bracket_depth == lit_bracket_depth, the innermost open bracket is
//     literal and the closing `]` should receive a space.
//   - brace_depth: count of unclosed `{`. Every `{` in Nexus is a record
//     or row (never a block), so all braces receive inner spacing.
export type FmtState = FmtState(
  src: string,
  len: i64,
  pos: i64,
  buf: %ByteBuffer,
  ws_run_len: i64,
  pending_nls: i64,
  pending_indent: i64,
  emitted_anything: bool,
  at_line_start: bool,
  last_code_byte: i64,
  bracket_depth: i64,
  lit_bracket_depth: i64,
  brace_depth: i64
)

// Walk the source looking for any token that starts a protected region but
// never closes. Returns `true` if such an unterminated token is found.
// This drives the bail-out in `format_source`: if the source contains an
// unclosed `/*`, `"`, or `[=[`, we return the original bytes unchanged so
// that repeated `fmt` passes cannot accumulate trailing whitespace.
let contains_unterminated_token = fn (src: string, len: i64, pos: i64) -> bool do
  if pos >= len then return false end
  let b = str.byte_at(s: src, idx: pos)
  // Line comment: skip to end of line — always terminates at '\n' or EOF, never a problem.
  if b == '/' && pos + 1 < len && str.byte_at(s: src, idx: pos + 1) == '/' then
    let line_end = scan_line_comment(src, pos: pos + 2, len)
    return contains_unterminated_token(src, len, pos: line_end)
  end
  // Block comment: closed iff block_comment_closed returns true.
  if b == '/' && pos + 1 < len && str.byte_at(s: src, idx: pos + 1) == '*' then
    let end_pos = scan_block_comment(src, pos: pos + 2, len, depth: 1)
    if !block_comment_closed(src, pos: pos + 2, len, depth: 1) then return true end
    return contains_unterminated_token(src, len, pos: end_pos)
  end
  // String literal: unterminated if scan reaches EOF without a closing `"`.
  // `scan_string` returns the position after the closing `"`. If the closing
  // `"` was the very last byte, it returns `len` (= byte-after-last). So we
  // cannot use `end_pos >= len` as the sole sentinel. Instead we re-check
  // whether the character before end_pos is actually `"`.
  if b == '"' then
    let end_pos = scan_string(src, pos: pos + 1, len)
    if !string_closed(src, end_pos, len) then return true end
    return contains_unterminated_token(src, len, pos: end_pos)
  end
  // Bracket string: unterminated if scan reaches EOF without `]=]`.
  if b == '[' && pos + 1 < len && str.byte_at(s: src, idx: pos + 1) == '='
     && pos + 2 < len && str.byte_at(s: src, idx: pos + 2) == '[' then
    let end_pos = scan_bracket_string(src, pos: pos + 3, len)
    if !bracket_string_closed(src, end_pos, len) then return true end
    return contains_unterminated_token(src, len, pos: end_pos)
  end
  return contains_unterminated_token(src, len, pos: pos + 1)
end

// Format the entire source string. Pure (no I/O), so callable from tests.
// Idempotence is the property to maintain: format(format(src)) == format(src).
//
// Pipeline:
//   Pass 1 (walk): tab->space, trailing-ws strip, blank-collapse, inner spacing.
//   Pass 2 (wrap_long_lines): break lines > 100 chars at first comma group.
//   Pass 3 (join_broken_lines): collapse multi-line groups that fit <= 100 cols.
//   Pass 2 again: re-wrap any lines that join produced > 100 cols (no-op in
//     practice since join only emits <= 100-col lines, but keeps the pipeline
//     visibly closed under composition).
//
// Passes 2 and 3 each loop to their own fixpoint. Together they converge to a
// canonical form: one-line iff the group fits in <= 100 cols, expanded otherwise.
//
// If the source contains an unterminated protected region (unclosed block
// comment, unterminated string literal, or unclosed bracket string), the
// original source is returned unchanged. This prevents repeated fmt passes
// from accumulating trailing newlines on parse-error fixture files.
export let format_source = fn (src: string) -> string do
  let len = str.byte_length(s: src)
  if contains_unterminated_token(src, len, pos: 0) then return src end
  let %buf = bb.empty()
  let st = FmtState(
    src,
    len,
    pos: 0,
    buf: %buf,
    ws_run_len: 0,
    pending_nls: 0,
    pending_indent: 0,
    emitted_anything: false,
    at_line_start: true,
    last_code_byte: 0,
    bracket_depth: 0,
    lit_bracket_depth: 0,
    brace_depth: 0
  )
  let st_final = walk(st)
  let FmtState(
    src: _,
    len: _,
    pos: _,
    buf: %final_buf,
    ws_run_len: _,
    pending_nls: _,
    pending_indent: _,
    emitted_anything,
    at_line_start: _,
    last_code_byte: _,
    bracket_depth: _,
    lit_bracket_depth: _,
    brace_depth: _
  ) = st_final
  if emitted_anything then
      let %buf_final = bb.push_byte(buf: %final_buf, byte: char.ord(c: '\n'))
      let pass1 = bb.to_string(buf: &buf_final)
      bb.free(buf: %buf_final)
      let pass2 = wrap_long_lines(src: pass1)
      let pass3 = join_broken_lines(src: pass2)
      return wrap_long_lines(src: pass3)
    end
    let pass1 = bb.to_string(buf: &final_buf)
    bb.free(buf: %final_buf)
    let pass2 = wrap_long_lines(src: pass1)
    let pass3 = join_broken_lines(src: pass2)
    return wrap_long_lines(src: pass3)
end

// Release any buffered newlines into the output buffer. Cap mid-stream
// flushes at 2 (one line-break + one blank line). Skipped entirely if
// nothing has been emitted yet — this drops leading blank lines at the top
// of the file.
let flush_pending_nls = fn (
  buf: %ByteBuffer,
  pending_nls: i64,
  emitted_anything: bool
) -> %ByteBuffer do
  if !emitted_anything then return buf end
  if pending_nls <= 0 then return buf end
  let n = if pending_nls > 2 then 2 else pending_nls end
  return push_n_newlines(buf: %buf, n)
end

let push_n_newlines = fn (buf: %ByteBuffer, n: i64) -> %ByteBuffer do
  if n <= 0 then return buf end
  let %buf2 = bb.push_byte(buf: %buf, byte: char.ord(c: '\n'))
  return push_n_newlines(buf: %buf2, n: n - 1)
end

// Returns true if `last_code_byte` indicates the `[` at the current position
// is a subscript/index expression rather than a list literal.
// `[` is an index when immediately preceded (in the output) by a letter,
// digit, `_`, `)`, or `]` — the end of a value that can be subscripted.
let is_index_context = fn (last_code_byte: i64) -> bool do
  if last_code_byte == 0 then return false end
  let b = last_code_byte
  if b == char.ord(c: ')') then return true end
  if b == char.ord(c: ']') then return true end
  if b == char.ord(c: '_') then return true end
  if b >= char.ord(c: 'a') && b <= char.ord(c: 'z') then return true end
  if b >= char.ord(c: 'A') && b <= char.ord(c: 'Z') then return true end
  if b >= char.ord(c: '0') && b <= char.ord(c: '9') then return true end
  return false
end

let walk = fn (st: FmtState) -> FmtState do
  let FmtState(
    src,
    len,
    pos,
    buf: %buf,
    ws_run_len,
    pending_nls,
    pending_indent,
    emitted_anything,
    at_line_start,
    last_code_byte,
    bracket_depth,
    lit_bracket_depth,
    brace_depth
  ) = st
  if pos >= len then return FmtState(
      src,
      len,
      pos,
      buf: %buf,
      ws_run_len,
      pending_nls,
      pending_indent,
      emitted_anything,
      at_line_start,
      last_code_byte,
      bracket_depth,
      lit_bracket_depth,
      brace_depth
    ) end
    let b = str.byte_at(s: src, idx: pos)
    // ── Newline ──────────────────────────────────────────────────────────
    if b == '\n' then
      return walk(st: FmtState(src, len, pos: pos + 1, buf: %buf, ws_run_len: 0, pending_nls: pending_nls + 1, pending_indent: 0, emitted_anything, at_line_start: true, last_code_byte, bracket_depth, lit_bracket_depth, brace_depth))
    end
    // ── Carriage return ──────────────────────────────────────────────────
    if b == '\r' then
      return walk(st: FmtState(src, len, pos: pos + 1, buf: %buf, ws_run_len, pending_nls, pending_indent, emitted_anything, at_line_start, last_code_byte, bracket_depth, lit_bracket_depth, brace_depth))
    end
    // ── Whitespace ───────────────────────────────────────────────────────
    if b == ' ' || b == '\t' then
      if at_line_start then
        let add = if b == '\t' then 2 else 1 end
        return walk(st: FmtState(src, len, pos: pos + 1, buf: %buf, ws_run_len: 0, pending_nls, pending_indent: pending_indent + add, emitted_anything, at_line_start: true, last_code_byte, bracket_depth, lit_bracket_depth, brace_depth))
      end
      return walk(st: FmtState(src, len, pos: pos + 1, buf: %buf, ws_run_len: ws_run_len + 1, pending_nls, pending_indent, emitted_anything, at_line_start: false, last_code_byte, bracket_depth, lit_bracket_depth, brace_depth))
    end
    // ── Protected regions (line/block comments, strings, chars, bracket) ─
    if b == '/' && pos + 1 < len && str.byte_at(s: src, idx: pos + 1) == '/' then
      let line_end = scan_line_comment(src, pos: pos + 2, len)
      let body_end = trim_trailing_ws_in(src, start: pos, end_pos: line_end)
      let %buf_nl = flush_pending_nls(buf: %buf, pending_nls, emitted_anything)
      let %buf_ind = flush_pending_indent(buf: %buf_nl, n: pending_indent)
      let %buf_ws = flush_ws(buf: %buf_ind, src, ws_run_len, pos)
      let chunk = str.byte_substring(s: src, start: pos, len: body_end - pos)
      let %buf_done = bb.push_string(buf: %buf_ws, s: chunk)
      // The last byte of a line comment is just before line_end (a non-ws char).
      // We don't update last_code_byte for comments since comments are
      // skipped by the parser — whatever preceded the comment determines context.
      return walk(st: FmtState(src, len, pos: line_end, buf: %buf_done, ws_run_len: 0, pending_nls: 0, pending_indent: 0, emitted_anything: true, at_line_start: false, last_code_byte, bracket_depth, lit_bracket_depth, brace_depth))
    end
    if b == '/' && pos + 1 < len && str.byte_at(s: src, idx: pos + 1) == '*' then
      return emit_protected_chunk(
        st: FmtState(
          src,
          len,
          pos,
          buf: %buf,
          ws_run_len,
          pending_nls,
          pending_indent,
          emitted_anything,
          at_line_start,
          last_code_byte,
          bracket_depth,
          lit_bracket_depth,
          brace_depth
        ),
        end_pos: scan_block_comment(src, pos: pos + 2, len, depth: 1)
      )
    end
    if b == '"' then
      return emit_protected_chunk(
        st: FmtState(
          src,
          len,
          pos,
          buf: %buf,
          ws_run_len,
          pending_nls,
          pending_indent,
          emitted_anything,
          at_line_start,
          last_code_byte,
          bracket_depth,
          lit_bracket_depth,
          brace_depth
        ),
        end_pos: scan_string(src, pos: pos + 1, len)
      )
    end
    if b == '\'' then
      let end_pos_opt = scan_char(src, pos: pos + 1, len)
      match end_pos_opt do
        | Some(val: end_pos) ->
          return emit_protected_chunk(
            st: FmtState(
              src,
              len,
              pos,
              buf: %buf,
              ws_run_len,
              pending_nls,
              pending_indent,
              emitted_anything,
              at_line_start,
              last_code_byte,
              bracket_depth,
              lit_bracket_depth,
              brace_depth
            ),
            end_pos
          )
        | None ->
          let %buf_nl = flush_pending_nls(buf: %buf, pending_nls, emitted_anything)
          let %buf_ind = flush_pending_indent(buf: %buf_nl, n: pending_indent)
          let %buf_ws = flush_ws(buf: %buf_ind, src, ws_run_len, pos)
          let %buf_done = bb.push_byte(buf: %buf_ws, byte: char.ord(c: b))
          return walk(st: FmtState(src, len, pos: pos + 1, buf: %buf_done, ws_run_len: 0, pending_nls: 0, pending_indent: 0, emitted_anything: true, at_line_start: false, last_code_byte: char.ord(c: b), bracket_depth, lit_bracket_depth, brace_depth))
      end
    end
    if b == '[' && pos + 1 < len && str.byte_at(s: src, idx: pos + 1) == '='
       && pos + 2 < len && str.byte_at(s: src, idx: pos + 2) == '[' then
      return emit_protected_chunk(
        st: FmtState(
          src,
          len,
          pos,
          buf: %buf,
          ws_run_len,
          pending_nls,
          pending_indent,
          emitted_anything,
          at_line_start,
          last_code_byte,
          bracket_depth,
          lit_bracket_depth,
          brace_depth
        ),
        end_pos: scan_bracket_string(src, pos: pos + 3, len)
      )
    end
    // ── Record open `{` ───────────────────────────────────────────────────
    // Every `{` in Nexus is a record literal or a row constraint — never a
    // block delimiter (`do`/`end` are used for blocks). So all `{` receive
    // inner spacing, unless the collection is empty (`{}`) or the next byte
    // is already a space/newline (source already has spacing).
    if b == '{' then
      let %buf_nl = flush_pending_nls(buf: %buf, pending_nls, emitted_anything)
      let %buf_ind = flush_pending_indent(buf: %buf_nl, n: pending_indent)
      let %buf_ws = flush_ws(buf: %buf_ind, src, ws_run_len, pos)
      let %buf1 = bb.push_byte(buf: %buf_ws, byte: char.ord(c: '{'))
      // Check the immediately next byte (do NOT skip whitespace). If it is
      // `}`, `\n`, `\r`, ` `, `\t`, or EOF, no space is needed:
      //   - `}` -> empty record `{}`, stay tight.
      //   - space/tab -> source already has a space, natural ws buffering handles it.
      //   - newline -> multiline record, first element is on its own line.
      // Any other byte means a code byte follows without a gap -> inject a space.
      let next_b = if pos + 1 < len then str.byte_at(s: src, idx: pos + 1) else '\0' end
      let inject_sp = next_b != '}' && next_b != ' ' && next_b != '\t' && next_b != '\n' && next_b != '\r' && next_b != '\0'
      let %buf2 = if inject_sp then
        bb.push_byte(buf: %buf1, byte: char.ord(c: ' '))
      else
        %buf1
      end
      let new_brace_depth = brace_depth + 1
      return walk(st: FmtState(src, len, pos: pos + 1, buf: %buf2, ws_run_len: 0, pending_nls: 0, pending_indent: 0, emitted_anything: true, at_line_start: false, last_code_byte: char.ord(c: '{'), bracket_depth, lit_bracket_depth, brace_depth: new_brace_depth))
    end
    // ── Record close `}` ──────────────────────────────────────────────────
    // Inject a space before `}` when the last code byte is not `{` (which
    // would mean the collection is empty — `{}`).
    if b == '}' then
      let %buf_nl = flush_pending_nls(buf: %buf, pending_nls, emitted_anything)
      let %buf_ind = flush_pending_indent(buf: %buf_nl, n: pending_indent)
      // Inject space before `}` if needed: no pending ws, no pending newlines
      // (which would mean `}` is on its own line in a multiline record), and
      // the previous content byte is not the matching `{` (empty record).
      let needs_sp = ws_run_len == 0 && pending_indent == 0 && pending_nls == 0 && last_code_byte != char.ord(c: '{') && last_code_byte != 0
      let %buf_ws = flush_ws(buf: %buf_ind, src, ws_run_len, pos)
      let %buf1 = if needs_sp then
        bb.push_byte(buf: %buf_ws, byte: char.ord(c: ' '))
      else
        %buf_ws
      end
      let %buf2 = bb.push_byte(buf: %buf1, byte: char.ord(c: '}'))
      let new_brace_depth = if brace_depth > 0 then brace_depth - 1 else 0 end
      return walk(st: FmtState(src, len, pos: pos + 1, buf: %buf2, ws_run_len: 0, pending_nls: 0, pending_indent: 0, emitted_anything: true, at_line_start: false, last_code_byte: char.ord(c: '}'), bracket_depth, lit_bracket_depth, brace_depth: new_brace_depth))
    end
    // ── List literal open `[` (not `[=[ ... ]=]` bracket string) ─────────
    // Classify `[` as literal or index based on the last emitted code byte.
    // Literal `[` gets a space after it (unless the list is empty `[]`).
    // Index `[` is left tight (`arr[i]` stays `arr[i]`).
    if b == '[' then
      let %buf_nl = flush_pending_nls(buf: %buf, pending_nls, emitted_anything)
      let %buf_ind = flush_pending_indent(buf: %buf_nl, n: pending_indent)
      let %buf_ws = flush_ws(buf: %buf_ind, src, ws_run_len, pos)
      let %buf1 = bb.push_byte(buf: %buf_ws, byte: char.ord(c: '['))
      let is_idx = is_index_context(last_code_byte)
      // Check the immediately next byte (do NOT skip whitespace). If it is
      // `]`, `|` (array literal `[|`), ` `, `\t`, `\n`, `\r`, or EOF, no
      // space is needed:
      //   - `]` -> empty list `[]`, stay tight.
      //   - `|` -> array literal `[| ... |]`; the `[|` delimiter is its own
      //     token — do not insert a space inside it.
      //   - space/tab -> source already has spacing.
      //   - newline -> multiline list, first element on its own line.
      let next_b2 = if pos + 1 < len then str.byte_at(s: src, idx: pos + 1) else '\0' end
      let inject_sp2 = !is_idx && next_b2 != ']' && next_b2 != '|' && next_b2 != ' ' && next_b2 != '\t' && next_b2 != '\n' && next_b2 != '\r' && next_b2 != '\0'
      let %buf2 = if inject_sp2 then
        bb.push_byte(buf: %buf1, byte: char.ord(c: ' '))
      else
        %buf1
      end
      let new_bracket_depth = bracket_depth + 1
      let new_lit_bracket_depth = if is_idx then lit_bracket_depth else lit_bracket_depth + 1 end
      return walk(st: FmtState(src, len, pos: pos + 1, buf: %buf2, ws_run_len: 0, pending_nls: 0, pending_indent: 0, emitted_anything: true, at_line_start: false, last_code_byte: char.ord(c: '['), bracket_depth: new_bracket_depth, lit_bracket_depth: new_lit_bracket_depth, brace_depth))
    end
    // ── List close `]` ────────────────────────────────────────────────────
    // Inject a space before `]` only when closing a literal bracket and the
    // last code byte is not `[` (empty list stays tight).
    if b == ']' then
      // Determine whether the closest open bracket is a literal.
      // When bracket_depth == lit_bracket_depth, all open brackets are
      // literal, so the innermost one is literal.
      let closing_literal = bracket_depth > 0 && bracket_depth == lit_bracket_depth
      let %buf_nl = flush_pending_nls(buf: %buf, pending_nls, emitted_anything)
      let %buf_ind = flush_pending_indent(buf: %buf_nl, n: pending_indent)
      // Do not inject a space if:
      //   - last_code_byte == '[' (empty `[]`)
      //   - last_code_byte == '|' (inside array literal `[| ... |]`, the
      //     closing `|]` should stay tight)
      //   - last_code_byte == 0 (nothing emitted)
      //   - pending_nls > 0 (closing `]` is on its own line in a multiline list)
      let needs_sp = closing_literal && ws_run_len == 0 && pending_indent == 0 && pending_nls == 0 && last_code_byte != char.ord(c: '[') && last_code_byte != char.ord(c: '|') && last_code_byte != 0
      let %buf_ws = flush_ws(buf: %buf_ind, src, ws_run_len, pos)
      let %buf1 = if needs_sp then
        bb.push_byte(buf: %buf_ws, byte: char.ord(c: ' '))
      else
        %buf_ws
      end
      let %buf2 = bb.push_byte(buf: %buf1, byte: char.ord(c: ']'))
      let new_bracket_depth = if bracket_depth > 0 then bracket_depth - 1 else 0 end
      let new_lit_bracket_depth = if closing_literal && lit_bracket_depth > 0 then lit_bracket_depth - 1 else lit_bracket_depth end
      return walk(st: FmtState(src, len, pos: pos + 1, buf: %buf2, ws_run_len: 0, pending_nls: 0, pending_indent: 0, emitted_anything: true, at_line_start: false, last_code_byte: char.ord(c: ']'), bracket_depth: new_bracket_depth, lit_bracket_depth: new_lit_bracket_depth, brace_depth))
    end
    // ── Code byte ────────────────────────────────────────────────────────
    let %buf_nl = flush_pending_nls(buf: %buf, pending_nls, emitted_anything)
    let %buf_ind = flush_pending_indent(buf: %buf_nl, n: pending_indent)
    let %buf_ws = flush_ws(buf: %buf_ind, src, ws_run_len, pos)
    let %buf_done = bb.push_byte(buf: %buf_ws, byte: char.ord(c: b))
    return walk(st: FmtState(src, len, pos: pos + 1, buf: %buf_done, ws_run_len: 0, pending_nls: 0, pending_indent: 0, emitted_anything: true, at_line_start: false, last_code_byte: char.ord(c: b), bracket_depth, lit_bracket_depth, brace_depth))
end

let flush_pending_indent = fn (buf: %ByteBuffer, n: i64) -> %ByteBuffer do
  if n <= 0 then return buf end
  let %buf2 = bb.push_byte(buf: %buf, byte: char.ord(c: ' '))
  return flush_pending_indent(buf: %buf2, n: n - 1)
end

let emit_protected_chunk = fn (st: FmtState, end_pos: i64) -> FmtState do
  let FmtState(
    src,
    len,
    pos,
    buf: %buf,
    ws_run_len,
    pending_nls,
    pending_indent,
    emitted_anything,
    at_line_start: _,
    last_code_byte,
    bracket_depth,
    lit_bracket_depth,
    brace_depth
  ) = st
  let %buf_nl = flush_pending_nls(buf: %buf, pending_nls, emitted_anything)
    let %buf_ind = flush_pending_indent(buf: %buf_nl, n: pending_indent)
    let %buf_ws = flush_ws(buf: %buf_ind, src, ws_run_len, pos)
    let chunk = str.byte_substring(s: src, start: pos, len: end_pos - pos)
    let %buf_done = bb.push_string(buf: %buf_ws, s: chunk)
    let new_at_ls = chunk_ended_on_newline(s: chunk)
    // The last code byte of a protected chunk is the last byte of the chunk
    // (important so that a closing `"` counts as a non-identifier context,
    // which is correct — `"foo"[i]` would be a string-index, classified as
    // index if `"` counts here; but we do NOT update last_code_byte for
    // protected chunks because the content is opaque). Keep it unchanged.
    return walk(st: FmtState(src, len, pos: end_pos, buf: %buf_done, ws_run_len: 0, pending_nls: 0, pending_indent: 0, emitted_anything: true, at_line_start: new_at_ls, last_code_byte, bracket_depth, lit_bracket_depth, brace_depth))
end

let flush_ws = fn (buf: %ByteBuffer, src: string, ws_run_len: i64, pos: i64) -> %ByteBuffer do
  if ws_run_len <= 0 then return buf end
  return flush_ws_go(buf: %buf, src, pos: pos - ws_run_len, end_pos: pos)
end

let flush_ws_go = fn (buf: %ByteBuffer, src: string, pos: i64, end_pos: i64) -> %ByteBuffer do
  if pos >= end_pos then return buf end
  let b = str.byte_at(s: src, idx: pos)
  let %buf2 = bb.push_byte(buf: %buf, byte: char.ord(c: b))
  return flush_ws_go(buf: %buf2, src, pos: pos + 1, end_pos)
end

let trim_trailing_ws_in = fn (src: string, start: i64, end_pos: i64) -> i64 do
  if end_pos <= start then return start end
  let b = str.byte_at(s: src, idx: end_pos - 1)
  if b == ' ' || b == '\t' then return trim_trailing_ws_in(src, start, end_pos: end_pos - 1) end
  return end_pos
end
