/**
 * scan: Shared byte-scanner primitives for the Nexus formatter.
 *
 * These functions are used by multiple formatter passes (pass-1 walk,
 * pass-2 wrap, pass-3 join). They scan over protected regions (string
 * literals, char literals, block comments, bracket strings, line comments)
 * and provide helpers for whitespace trimming and line boundary detection.
 */

import * as str from "std:str"
import * as char from "std:char"
import { Option, Some, None } from "std:option"

// Advance past a line comment body (after the opening `//`).
// Returns the position of the terminating `\n`, or `len` on EOF.
export let scan_line_comment = fn (src: string, pos: i64, len: i64) -> i64 do
  if pos >= len then return len end
  let b = str.byte_at(s: src, idx: pos)
  if b == '\n' then return pos end
  return scan_line_comment(src, pos: pos + 1, len)
end

// Advance past a block comment body (after the opening `/*`, depth=1).
// Returns position just after the matching `*/`. Handles nesting.
export let scan_block_comment = fn (src: string, pos: i64, len: i64, depth: i64) -> i64 do
  if pos >= len then return len end
  if depth <= 0 then return pos end
  let b = str.byte_at(s: src, idx: pos)
  if b == '*' && pos + 1 < len && str.byte_at(s: src, idx: pos + 1) == '/' then
    return scan_block_comment(src, pos: pos + 2, len, depth: depth - 1)
  end
  if b == '/' && pos + 1 < len && str.byte_at(s: src, idx: pos + 1) == '*' then
    return scan_block_comment(src, pos: pos + 2, len, depth: depth + 1)
  end
  return scan_block_comment(src, pos: pos + 1, len, depth)
end

// Advance past a string literal body (after the opening `"`).
// Returns position just after the closing `"`, or `len` on EOF.
export let scan_string = fn (src: string, pos: i64, len: i64) -> i64 do
  if pos >= len then return len end
  let b = str.byte_at(s: src, idx: pos)
  if b == '"' then return pos + 1 end
  if b == '\\' && pos + 1 < len then
    return scan_string(src, pos: pos + 2, len)
  end
  return scan_string(src, pos: pos + 1, len)
end

// Advance past a char literal body (after the opening `'`).
// Returns Some(pos_after_closing_quote) or None if not a valid char literal.
export let scan_char = fn (src: string, pos: i64, len: i64) -> Option<i64> do
  return scan_char_go(src, pos, len, budget: 12)
end

let scan_char_go = fn (src: string, pos: i64, len: i64, budget: i64) -> Option<i64> do
  if budget <= 0 then return None end
  if pos >= len then return None end
  let b = str.byte_at(s: src, idx: pos)
  if b == '\'' then return Some(val: pos + 1) end
  if b == '\\' && pos + 1 < len then
    return scan_char_go(src, pos: pos + 2, len, budget: budget - 1)
  end
  if b == '\n' then return None end
  return scan_char_go(src, pos: pos + 1, len, budget: budget - 1)
end

// Advance past a bracket string body (after the opening `[=[`).
// Returns position just after the closing `]=]`, or `len` on EOF.
export let scan_bracket_string = fn (src: string, pos: i64, len: i64) -> i64 do
  if pos >= len then return len end
  let b = str.byte_at(s: src, idx: pos)
  if b == ']'
     && pos + 1 < len && str.byte_at(s: src, idx: pos + 1) == '='
     && pos + 2 < len && str.byte_at(s: src, idx: pos + 2) == ']' then
    return pos + 3
  end
  if b == '\\' && pos + 3 < len
     && str.byte_at(s: src, idx: pos + 1) == ']'
     && str.byte_at(s: src, idx: pos + 2) == '='
     && str.byte_at(s: src, idx: pos + 3) == ']' then
    return scan_bracket_string(src, pos: pos + 4, len)
  end
  return scan_bracket_string(src, pos: pos + 1, len)
end

// Returns true iff the block comment that starts just before `pos` (scanning
// from `pos` with `depth` remaining) closes before EOF.
export let block_comment_closed = fn (src: string, pos: i64, len: i64, depth: i64) -> bool do
  if depth <= 0 then return true end
  if pos >= len then return false end
  let b = str.byte_at(s: src, idx: pos)
  if b == '*' && pos + 1 < len && str.byte_at(s: src, idx: pos + 1) == '/' then
    return block_comment_closed(src, pos: pos + 2, len, depth: depth - 1)
  end
  if b == '/' && pos + 1 < len && str.byte_at(s: src, idx: pos + 1) == '*' then
    return block_comment_closed(src, pos: pos + 2, len, depth: depth + 1)
  end
  return block_comment_closed(src, pos: pos + 1, len, depth)
end

// Returns true iff `scan_string` returned `end_pos` that is past a closing `"`.
export let string_closed = fn (src: string, end_pos: i64, len: i64) -> bool do
  if end_pos <= 0 then return false end
  if end_pos > len then return false end
  return str.byte_at(s: src, idx: end_pos - 1) == '"'
end

// Returns true iff `scan_bracket_string` returned `end_pos` past `]=]`.
export let bracket_string_closed = fn (src: string, end_pos: i64, len: i64) -> bool do
  if end_pos < 3 then return false end
  if end_pos > len then return false end
  if str.byte_at(s: src, idx: end_pos - 1) != ']' then return false end
  if str.byte_at(s: src, idx: end_pos - 2) != '=' then return false end
  if str.byte_at(s: src, idx: end_pos - 3) != ']' then return false end
  return true
end

// Returns true iff the last byte of `s` is `\n`.
export let chunk_ended_on_newline = fn (s: string) -> bool do
  let n = str.byte_length(s)
  if n <= 0 then return false end
  return str.byte_at(s, idx: n - 1) == '\n'
end

// Return the position of `\n` ending the current line, or `len` at EOF.
export let find_line_end = fn (src: string, len: i64, pos: i64) -> i64 do
  if pos >= len then return len end
  let b = str.byte_at(s: src, idx: pos)
  if b == '\n' then return pos end
  return find_line_end(src, len, pos: pos + 1)
end

// One-past-last non-space position in s[start..end_p).
export let rtrim_in_s = fn (s: string, start: i64, end_p: i64) -> i64 do
  if end_p <= start then return start end
  let b = str.byte_at(s, idx: end_p - 1)
  if b == ' ' then return rtrim_in_s(s, start, end_p: end_p - 1) end
  return end_p
end
