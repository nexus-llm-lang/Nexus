/**
 * driver: Self-hosting compiler CLI entry point.
 *
 * Reads a Nexus source file, processes imports with cycle detection,
 * and compiles through the full pipeline:
 *   Lex → Parse → HIR → MIR → LIR → WASM
 */

import * as lexer from "src/frontend/lexer.nx"
import * as parser from "src/frontend/parser.nx"
import * as arena from "std:arena"
import { Program, SpannedTopLevel, EnumDef, GlobalLet, SpannedExpr, ExprLambda, TypeExpr, TyRow, TyUserDefined } from "src/common/ast.nx"
import { InvalidUsage, WriteFailed, InTargetFile }, * as err from "src/common/error.nx"
import { RenameEntry }, * as symtab from "src/ir/symtab.nx"
import * as resolve from "src/ir/resolve.nx"
import { CacheEntry, ImportResult, get_defs, process_imports, append_entries, dump_import_graph } from "src/ir/imports.nx"
import { iterative_resolve } from "src/ir/demand.nx"
import * as rdr from "src/ir/rdrname.nx"
import { HirProgram } from "src/ir/hir_types.nx"
import * as hir from "src/ir/hir.nx"
import * as mir from "src/ir/mir.nx"
import * as lir from "src/ir/lir.nx"
import * as lir_opt from "src/ir/lir_opt.nx"
import * as codegen from "src/backend/codegen.nx"
import * as tc from "src/typecheck/check.nx"
import * as linearity from "src/ir/linearity.nx"
import * as tc_linearity from "src/typecheck/linearity.nx"
import * as bb from "std:bytebuffer"
import * as wmerge from "src/backend/wasm/merge.nx"
import * as pkg from "src/ir/package.nx"
import { rd_uleb, pval, uleb_size } from "src/backend/wasm/read.nx"
import { Fs }, * as fs_mod from "std:fs"
import { Console }, * as stdio from "std:stdio"
import { Clock }, * as clock_mod from "std:clock"
import * as str from "std:str"
import * as proc from "std:proc"
import { IndexOutOfBounds }, * as list from "std:list"
import { Option, Some, None } from "std:option"

// ─── Dep memory pages reader ────────────────────────────────────────────────
// Read initial pages from a WASM binary's memory section (section 5).
// Uses the shared ULEB reader from src/backend/wasm/read.nx.
let read_dep_pages = fn (buf: &ByteBuffer) -> i64 do
  return scan_sections(buf, pos: 8, end_pos: bb.length(buf))
end
let scan_sections = fn (buf: &ByteBuffer, pos: i64, end_pos: i64) -> i64 do
  if pos >= end_pos then return 0 end
  let sec_id = bb.get_byte(buf, idx: pos)
  let sec_size = pval(pk: rd_uleb(buf, pos: pos + 1))
  let hdr = uleb_size(buf, pos: pos + 1)
  let next = pos + 1 + hdr + sec_size
  if sec_id == 5 then
    // Memory section: skip count ULEB, skip flags byte, read min pages ULEB
    let body = pos + 1 + hdr
    let count_sz = uleb_size(buf, pos: body)
    let flags_pos = body + count_sz
    let min_pos = flags_pos + 1
    return pval(pk: rd_uleb(buf, pos: min_pos))
  end
  return scan_sections(buf, pos: next, end_pos)
end

// ─── Pipeline ───────────────────────────────────────────────────────────────

let list_has_str = fn (xs: [string], s: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true end
      return list_has_str(xs: rest, s)
  end
end

let extract_function_names = fn (defs: [SpannedTopLevel]) -> [string] do
  match defs do
    | [] -> return []
    | SpannedTopLevel(node: TLLet(def: GlobalLet(name, is_public: _, typ: _, value: _)), span: _) :: rest ->
      return name :: extract_function_names(defs: rest)
    | _ :: rest -> return extract_function_names(defs: rest)
  end
end

let get_enum_defs = fn (hir: HirProgram) -> [EnumDef] do
  match hir do | HirProgram(ports: _, functions: _, externals: _, handler_bindings: _, enum_defs: eds, _) -> eds end
end

type HirBuildResult = HirBuildResult(program: HirProgram, import_cache: [CacheEntry])

/// Add rename entries for the entry file's own top-level defs so that local
/// calls (foo(), Console.println(...)) rename to canonical targets.
/// The entry file's `main` function keeps its bare name so wasm export "main" works.
let build_entry_self_entries = fn (defs: [SpannedTopLevel], source: string, acc: [RenameEntry]) -> [RenameEntry] do
  match defs do
    | [] -> return acc
    | SpannedTopLevel(node: TLLet(def: GlobalLet(name, is_public: _, typ: _, value: _)), span: _) :: rest ->
      if name == "main" then
        let acc2 = symtab.rename_add(entries: acc, original: name, qualified: "main")
        return build_entry_self_entries(defs: rest, source, acc: acc2)
      end
      let acc2 = symtab.rename_add(entries: acc, original: name, qualified: canonical_name_string(source, name))
      return build_entry_self_entries(defs: rest, source, acc: acc2)
    | SpannedTopLevel(node: TLCap(def: Cap(name, is_public: _, functions: _)), span: _) :: rest ->
      let acc2 = symtab.rename_add(entries: acc, original: name, qualified: canonical_name_string(source, name))
      return build_entry_self_entries(defs: rest, source, acc: acc2)
    | _ :: rest -> return build_entry_self_entries(defs: rest, source, acc)
  end
end

let canonical_name_string = fn (source: string, name: string) -> string do
  return rdr.canonical_name(source_path: source, name)
end

let build_hir = fn (prog: Program, source_file: string, verbose: bool) -> HirBuildResult require { Fs, Console } throws { Exn } do
  let defs = get_defs(prog)
  let imports = resolve.extract_imports(defs)
  let result = process_imports(imports, accum: hir.empty_accum(), import_stack: [], visited: [], cache: [], caller_entries: [], depth: 1, verbose)
  match result do | ImportResult(accum, visited: _, cache: import_cache, caller_entries) ->
    let self_entries = build_entry_self_entries(defs, source: source_file, acc: [])
    let entries = append_entries(xs: self_entries, ys: caller_entries)
    let accum2 = hir.process_defs(defs, entries, accum, source_file)
    return HirBuildResult(program: hir.accum_to_program(accum: accum2), import_cache)
  end
end


let str_nth = fn (xs: [string], n: i64) -> string throws { Exn } do
  match xs do
    | [] -> raise IndexOutOfBounds(op: "str_nth", index: n)
    | v :: rest ->
      if n == 0 then return v end
      return str_nth(xs: rest, n: n - 1)
  end
end

/// Check if --verbose flag is present in args list.
let has_verbose_flag = fn (xs: [string]) -> bool do
  match xs do
    | [] -> return false
    | v :: rest ->
      if v == "--verbose" then return true end
      return has_verbose_flag(xs: rest)
  end
end

/// Remove --verbose flag from args list, preserving order.
let strip_verbose_flag = fn (xs: [string]) -> [string] do
  match xs do
    | [] -> return []
    | v :: rest ->
      if v == "--verbose" then return strip_verbose_flag(xs: rest) end
      return v :: strip_verbose_flag(xs: rest)
  end
end

let get_output_path = fn (xs: [string], argc: i64) -> string throws { Exn } do
  if argc >= 3 then return str_nth(xs, n: 2) end
  return "out.wasm"
end

/// Resolve the output path: prefer `-o`/`--output` value, otherwise fall back to
/// the positional `[output]` arg or the default `main.wasm`.
let resolve_output_path = fn (opt_output: Option<string>, xs: [string], argc: i64) -> string throws { Exn } do
  match opt_output do
    | Some(val: o) -> return o
    | None -> return get_output_path(xs, argc)
  end
end

type ParsedOutputFlag = ParsedOutputFlag(remaining: [string], output: Option<string>)

/// Strip `-o <path>` and `--output <path>` pairs from `xs`. Mirrors bootstrap's
/// `-o`/`--output` flag so users can use the same invocation form.
let strip_output_flag = fn (xs: [string], output: Option<string>) -> ParsedOutputFlag throws { Exn } do
  match xs do
    | [] -> return ParsedOutputFlag(remaining: [], output)
    | flag :: rest ->
      if flag == "-o" || flag == "--output" then
        match rest do
          | [] -> raise InvalidUsage(detail: "-o/--output requires a path")
          | value :: rest2 -> return strip_output_flag(xs: rest2, output: Some(val: value))
        end
      end
      let ParsedOutputFlag(remaining: rest_args, output: out2) = strip_output_flag(xs: rest, output)
      return ParsedOutputFlag(remaining: flag :: rest_args, output: out2)
  end
end

/// Skip a leading `build` subcommand so `nexus build foo.nx` works the same
/// way as the Rust bootstrap. `args[0]` is the program name; `args[1]` is the
/// first user-supplied token.
let strip_build_subcommand = fn (xs: [string]) -> [string] do
  match xs do
    | [] -> return []
    | prog :: rest ->
      match rest do
        | [] -> return xs
        | second :: rest2 ->
          if second == "build" then return prog :: rest2 end
          return xs
      end
  end
end

type ParsedTypecheckSubcommand = ParsedTypecheckSubcommand(remaining: [string], typecheck_only: bool)

/// Detect a leading `typecheck` subcommand. When present, strip it and signal
/// that the driver should run the front-end pipeline only (parse → HIR →
/// resolve → linearity → typecheck → tc-linearity) and skip MIR/LIR/codegen.
/// The form is `nexus typecheck <input.nx>`; positional output is rejected
/// because typecheck-only never writes a wasm artifact.
let strip_typecheck_subcommand = fn (xs: [string]) -> ParsedTypecheckSubcommand do
  match xs do
    | [] -> return ParsedTypecheckSubcommand(remaining: [], typecheck_only: false)
    | prog :: rest ->
      match rest do
        | [] -> return ParsedTypecheckSubcommand(remaining: xs, typecheck_only: false)
        | second :: rest2 ->
          if second == "typecheck" then
            return ParsedTypecheckSubcommand(remaining: prog :: rest2, typecheck_only: true)
          end
          return ParsedTypecheckSubcommand(remaining: xs, typecheck_only: false)
      end
  end
end

let write_and_free = fn (buf: %ByteBuffer, path: string) -> bool do
  let ok = bb.write_file(&buf, path)
  bb.free(%buf)
  return ok
end

// ─── Capability reporting (--explain-capabilities) ──────────────────────────
// Mirrors bootstrap/src/artifact.rs. Extracts the entry's `require { Perm… }`
// row from the parsed AST, maps `PermX` → `X`, and prints either text or JSON
// describing the capabilities (and, in `wasmtime` mode, a ready-to-run command).

type ExplainCaps = ExplainYes | ExplainNone | ExplainWasmtime

type ExplainFormat = FormatText | FormatJson

type ParsedExplainArgs = ParsedExplainArgs(remaining: [string], explain: ExplainCaps, format: ExplainFormat)

let parse_explain_caps_value = fn (s: string) -> Option<ExplainCaps> do
  if s == "yes" then return Some(val: ExplainYes) end
  if s == "none" then return Some(val: ExplainNone) end
  if s == "wasmtime" then return Some(val: ExplainWasmtime) end
  return None
end

let parse_explain_format_value = fn (s: string) -> Option<ExplainFormat> do
  if s == "text" then return Some(val: FormatText) end
  if s == "json" then return Some(val: FormatJson) end
  return None
end

let perm_to_cap_name = fn (perm: string) -> Option<string> do
  if perm == "PermFs" then return Some(val: "Fs") end
  if perm == "PermNet" then return Some(val: "Net") end
  if perm == "PermConsole" then return Some(val: "Console") end
  if perm == "PermRandom" then return Some(val: "Random") end
  if perm == "PermClock" then return Some(val: "Clock") end
  if perm == "PermProc" then return Some(val: "Proc") end
  if perm == "PermEnv" then return Some(val: "Env") end
  return None
end

let collect_cap_names = fn (xs: [TypeExpr]) -> [string] do
  match xs do
    | [] -> return []
    | TyUserDefined(name, args: []) :: rest ->
      if let Some(val: c) = perm_to_cap_name(perm: name) then
        return c :: collect_cap_names(xs: rest)
      end
      return collect_cap_names(xs: rest)
    | _ :: rest -> return collect_cap_names(xs: rest)
  end
end

let extract_caps_from_row = fn (row: TypeExpr) -> [string] do
  if let TyRow(types, rest: _) = row then
    return collect_cap_names(xs: types)
  end
  return []
end

/// Walk top-level defs; for `let main = fn (...) require { Perm… }`, return
/// the capability names. Adds `Proc` when `main` takes `args` so argv can
/// be read at runtime (matches bootstrap behavior).
let find_main_caps = fn (defs: [SpannedTopLevel]) -> [string] do
  match defs do
    | [] -> return []
    | SpannedTopLevel(node: TLLet(def: GlobalLet(name, is_public: _, typ: _, value: SpannedExpr(node: ExprLambda(type_params: _, params, ret_type: _, requires, throw_row: _, body: _), span: _))), span: _) :: rest ->
      if name == "main" then
        let caps = extract_caps_from_row(row: requires)
        if list.length(xs: params) > 0 then
          if list_has_str(xs: caps, s: "Proc") then return caps end
          return list.concat(xs: caps, ys: ["Proc"])
        end
        return caps
      end
      return find_main_caps(defs: rest)
    | _ :: rest -> return find_main_caps(defs: rest)
  end
end

/// Strip `--explain-capabilities VALUE` and `--explain-capabilities-format VALUE`
/// pairs from `xs`. Other args are preserved in order.
let strip_explain_flags = fn (xs: [string], explain: ExplainCaps, format: ExplainFormat) -> ParsedExplainArgs throws { Exn } do
  match xs do
    | [] -> return ParsedExplainArgs(remaining: [], explain, format)
    | flag :: rest ->
      if flag == "--explain-capabilities" then
        match rest do
          | [] -> raise InvalidUsage(detail: "--explain-capabilities requires a value (yes|none|wasmtime)")
          | value :: rest2 ->
            if let Some(val: e) = parse_explain_caps_value(s: value) then
              return strip_explain_flags(xs: rest2, explain: e, format)
            end
            raise InvalidUsage(detail: "invalid --explain-capabilities value: " ++ value)
        end
      end
      if flag == "--explain-capabilities-format" then
        match rest do
          | [] -> raise InvalidUsage(detail: "--explain-capabilities-format requires a value (text|json)")
          | value :: rest2 ->
            if let Some(val: f) = parse_explain_format_value(s: value) then
              return strip_explain_flags(xs: rest2, explain, format: f)
            end
            raise InvalidUsage(detail: "invalid --explain-capabilities-format value: " ++ value)
        end
      end
      let ParsedExplainArgs(remaining: rest_args, explain: e2, format: f2) = strip_explain_flags(xs: rest, explain, format)
      return ParsedExplainArgs(remaining: flag :: rest_args, explain: e2, format: f2)
  end
end

let cap_wasmtime_flags = fn (name: string) -> [string] do
  if name == "Net" then return ["--wasi", "http", "--wasi", "inherit-network"] end
  if name == "Fs" then return ["--dir", "."] end
  return []
end

let collect_all_wasmtime_flags = fn (caps: [string]) -> [string] do
  match caps do
    | [] -> return []
    | c :: rest -> return list.concat(xs: cap_wasmtime_flags(name: c), ys: collect_all_wasmtime_flags(caps: rest))
  end
end

/// Wasm proposals required at runtime. The bundled stdlib uses every one of
/// these (TCO, raise/throws, closures, handlers), so emit all four whenever
/// wasmtime mode is selected — detection on the user's AST alone would
/// underreport because stdlib brings them in regardless.
let wasmtime_feature_flags = fn () -> [string] do
  return ["-W", "tail-call=y", "-W", "exceptions=y", "-W", "function-references=y", "-W", "stack-switching=y"]
end

let quote_strings = fn (xs: [string]) -> [string] do
  match xs do
    | [] -> return []
    | v :: rest -> return ("\"" ++ v ++ "\"") :: quote_strings(xs: rest)
  end
end

let build_run_cmd = fn (output_name: string, caps: [string]) -> string do
  let feat_flags = wasmtime_feature_flags()
  let cap_flags = collect_all_wasmtime_flags(caps)
  let argv = list.concat(xs: feat_flags, ys: list.concat(xs: cap_flags, ys: [output_name]))
  return "wasmtime run " ++ str.join(xs: argv, sep: " ")
end

let print_build_result_text = fn (output_name: string, caps: [string], explain: ExplainCaps) -> unit require { Console } do
  Console.eprintln(val: "Built " ++ output_name)
  match explain do
    | ExplainNone -> return ()
    | ExplainYes ->
      if list.length(xs: caps) > 0 then
        Console.eprintln(val: "Capabilities: " ++ str.join(xs: caps, sep: ", "))
      end
    | ExplainWasmtime ->
      if list.length(xs: caps) > 0 then
        Console.eprintln(val: "Capabilities: " ++ str.join(xs: caps, sep: ", "))
      end
      Console.eprintln(val: "Run: " ++ build_run_cmd(output_name, caps))
  end
end

let print_build_result_json = fn (output_name: string, caps: [string], explain: ExplainCaps) -> unit require { Console } do
  match explain do
    | ExplainNone ->
      Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\"}")
    | ExplainYes ->
      let caps_quoted = quote_strings(xs: caps)
      Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\",\"capabilities\":[" ++ str.join(xs: caps_quoted, sep: ",") ++ "]}")
    | ExplainWasmtime ->
      let caps_quoted = quote_strings(xs: caps)
      let all_flags = list.concat(xs: wasmtime_feature_flags(), ys: collect_all_wasmtime_flags(caps))
      let flags_quoted = quote_strings(xs: all_flags)
      let cmd = build_run_cmd(output_name, caps)
      Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\",\"capabilities\":[" ++ str.join(xs: caps_quoted, sep: ",") ++ "],\"wasmtime\":{\"command\":\"" ++ cmd ++ "\",\"flags\":[" ++ str.join(xs: flags_quoted, sep: ",") ++ "]}}")
  end
end

let print_build_result = fn (output_name: string, caps: [string], explain: ExplainCaps, format: ExplainFormat) -> unit require { Console } do
  match format do
    | FormatText -> print_build_result_text(output_name, caps, explain)
    | FormatJson -> print_build_result_json(output_name, caps, explain)
  end
end

let main = fn (args: [string]) -> unit require { PermFs, PermConsole, PermClock } do
  inject stdio.system_handler, fs_mod.system_handler, clock_mod.system_handler do
  try
    let verbose = has_verbose_flag(xs: args)
    let args_after_verbose = strip_verbose_flag(xs: args)
    let ParsedExplainArgs(remaining: args_after_explain, explain, format) = strip_explain_flags(xs: args_after_verbose, explain: ExplainYes, format: FormatText)
    let ParsedOutputFlag(remaining: args_after_output, output: opt_output) = strip_output_flag(xs: args_after_explain, output: None)
    let ParsedTypecheckSubcommand(remaining: args_after_tc, typecheck_only) = strip_typecheck_subcommand(xs: args_after_output)
    let clean_args = strip_build_subcommand(xs: args_after_tc)
    let argc = list.length(xs: clean_args)
    if argc < 2 then
      Console.eprintln(val: "Usage: nexus [build] <input.nx> [output.wasm]")
      Console.eprintln(val: "       nexus [build] [-o output.wasm] <input.nx>")
      Console.eprintln(val: "       nexus typecheck <input.nx>")
      Console.eprintln(val: "       nexus --dump-imports <input.nx>")
      Console.eprintln(val: "       nexus --verbose [build] <input.nx> [output.wasm]")
      Console.eprintln(val: "       nexus [--explain-capabilities yes|none|wasmtime] [--explain-capabilities-format text|json] [build] <input.nx> [output.wasm]")
      raise InvalidUsage(detail: "missing input file argument")
    end

    let first_arg = str_nth(xs: clean_args, n: 1)
    if first_arg == "--dump-imports" then
      if argc < 3 then
        raise InvalidUsage(detail: "usage: nexus --dump-imports <input.nx>")
      end
      dump_import_graph(input_path: str_nth(xs: clean_args, n: 2))
      return ()
    end

    let input_path = first_arg
    let output_path = resolve_output_path(opt_output, xs: clean_args, argc)

    if verbose then
      if typecheck_only then
        Console.eprintln(val: "nxc: typechecking " ++ input_path)
      else
        Console.eprintln(val: "nxc: compiling " ++ input_path ++ " -> " ++ output_path)
      end
    end

    // Nested try wraps pipeline errors with the target file name so the final
    // diagnostic reads "<root>: in imported module '<x>': <error>".
    try
    let t0 = Clock.now()
    let src = Fs.read_to_string(path: input_path)
    let t1 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] read source (" ++ str.from_i64(val: t1 - t0) ++ "ms)") end

    // Mark heap before compilation pipeline. All IR data allocated below
    // can be freed after codegen completes (ByteBuffer is host-managed).
    let pipeline_mark = arena.heap_mark()

    let tokens = lexer.tokenize(src)
    let t2 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] lex (" ++ str.from_i64(val: t2 - t1) ++ "ms)") end

    let prog = parser.parse(tokens)
    let t3 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] parse (" ++ str.from_i64(val: t3 - t2) ++ "ms)") end

    let hir_result = build_hir(prog, source_file: input_path, verbose)
    let HirBuildResult(program: hir_raw, import_cache: _) = hir_result
    let t4 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] HIR (" ++ str.from_i64(val: t4 - t3) ++ "ms)") end

    // Iterative resolve: filter by reachability, resolve, repeat until stable.
    let hir = match hir_raw do
      | HirProgram(ports: hp, functions: hf, externals: he, handler_bindings: hb, enum_defs: hed, exception_groups: heg) ->
        let resolved = iterative_resolve(funcs: hf, hb, max_rounds: 100)
        HirProgram(ports: hp, functions: resolved, externals: he, handler_bindings: hb, enum_defs: hed, exception_groups: heg)
    end
    let t4b = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] resolve (" ++ str.from_i64(val: t4b - t4) ++ "ms)") end

    linearity.check_program(prog: hir)
    let t4c = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] linearity (" ++ str.from_i64(val: t4c - t4b) ++ "ms)") end

    // Extract enum_defs and local_names eagerly so hir/prog can die after typecheck.
    // This removes cross-phase references that would prevent future region resets.
    let enum_defs = get_enum_defs(hir)
    let local_names = extract_function_names(defs: get_defs(prog))
    let hir_checked = tc.check_program(hir, local_names)
    let t5 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] typecheck (" ++ str.from_i64(val: t5 - t4c) ++ "ms)") end

    // %T linear lint pass (issue nexus-7eex.3): runs after typecheck so the
    // sig-map sees post-resolution function signatures. Implements the same
    // discipline as the bootstrap (linear use-once, branch consistency,
    // throwable-call leak from issue nexus-7eex.2, and Strategy A try-catch
    // from issue nexus-7eex.1).
    tc_linearity.check_program(prog: hir_checked)
    let t5b = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] tc-linearity (" ++ str.from_i64(val: t5b - t5) ++ "ms)") end
    // After this point: prog, hir, local_names are dead.
    // hir_checked and enum_defs are the only live compiler data.

    // typecheck-only mode: skip MIR/LIR/codegen/write entirely. The full
    // typecheck (including tc-linearity) has already run and any error has
    // raised through the catch handlers below.
    if typecheck_only then
      if verbose then
        Console.eprintln(val: "nxc: typecheck-only " ++ input_path ++ " (total " ++ str.from_i64(val: t5b - t0) ++ "ms)")
      end
      arena.heap_reset(mark: pipeline_mark)
      return ()
    end

    let mir = mir.lower_hir_to_mir(hir: hir_checked)
    let t6 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] MIR (" ++ str.from_i64(val: t6 - t5) ++ "ms)") end
    // hir_checked is dead; mir and enum_defs are live.

    let lir = lir.lower_mir_to_lir(mir, enum_defs)
    let t7 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] LIR (" ++ str.from_i64(val: t7 - t6) ++ "ms)") end
    // mir and enum_defs are dead; lir is live.

    let lir_opt = lir_opt.optimize_lir(program: lir)
    let t8 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] optimize (" ++ str.from_i64(val: t8 - t7) ++ "ms)") end

    // String data placed after the std package's data section in the merged output.
    let std_wasm_path = pkg.package_wasm_path(pkg: "std")
    let %dep = bb.read_binary_file(path: std_wasm_path)
    let dep_pages = read_dep_pages(buf: &dep)
    bb.free(buf: %dep)
    let str_base = dep_pages * 65536
    let %wasm_buf = codegen.compile_lir_to_wasm(program: lir_opt, string_data_base: str_base)
    let t9 = Clock.now()
    if verbose then Console.eprintln(val: "[nxc] codegen (" ++ str.from_i64(val: t9 - t8) ++ "ms)") end

    let %wasm_buf = wmerge.merge_with_stdlib(core_wasm: %wasm_buf, stdlib_path: std_wasm_path)

    let ok = write_and_free(buf: %wasm_buf, path: output_path)
    let t10 = Clock.now()

    if ok then
      if verbose then
        Console.eprintln(val: "[nxc] write (" ++ str.from_i64(val: t10 - t9) ++ "ms)")
        Console.eprintln(val: "nxc: wrote " ++ output_path ++ " (total " ++ str.from_i64(val: t10 - t0) ++ "ms)")
      end
      // Extract capabilities from the entry program's `main` requires-row
      // before resetting the arena (the AST lives in the marked region).
      let caps = find_main_caps(defs: get_defs(prog))
      print_build_result(output_name: output_path, caps, explain, format)
    else
      raise WriteFailed(path: output_path)
    end

    // All IR data is now dead. ByteBuffer is host-managed (not on nexus heap).
    // Reset heap to free all compiler data structures.
    arena.heap_reset(mark: pipeline_mark)
    catch inner ->
      raise InTargetFile(path: input_path, detail: err.format_error(err: inner))
    end
  catch
    | InvalidUsage(detail: d) ->
      Console.eprintln(val: err.format_error(err: InvalidUsage(detail: d)))
      proc.exit(status: 2)
    | e ->
      Console.eprintln(val: err.format_error(err: e))
      proc.exit(status: 1)
  end
  end
end
