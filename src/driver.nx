// Backtrace-elision percentage (issue nexus-kyf8): integer percent of raise
// sites where codegen elides the bt-capture call. Guards against division
// by zero (programs with no raise sites) by returning 0.
let compute_elision_pct = fn (skip: i64, total: i64) -> i64 do
  if total == 0 then return 0 end
  return (skip * 100) / total
end

// Multi-error parser (issue nexus-in6i) emits a list of structured
// CompilerDiagnostics (issue nexus-kmel). Stream each to stderr so the user sees
// every parse failure in one round-trip; the eventual `ParseErrorsCollected`
// raise renders the summary line via the standard error-handling path.
// Under `--format=json` each CompilerDiagnostic prints as one JSON object per line
// (NDJSON); under `--format=text` we go through the existing `format_error`.
let print_parse_diags_text = fn (diags: [CompilerDiagnostic]) -> unit require { Console } do
  match diags do
    | [] -> return ()
    | d :: rest ->
      // Reassemble the legacy "<message> [<code>]" rendering directly from
      // the CompilerDiagnostic fields. Byte-identical to pre-kmel output
      // for the parse-arm path (the only one that funnels through here in
      // V1); when the diag has no code (file-context wrappers etc.), the
      // bracket is omitted.
      match d do | CompilerDiagnostic(code, severity: _, file: _, line: _, column: _, message) ->
        let line_str = if str.length(s: code) > 0 then message ++ " [" ++ code ++ "]" else message end
        Console.eprintln(val: line_str)
      end
      return print_parse_diags_text(diags: rest)
  end
end

let print_parse_diags_json = fn (diags: [CompilerDiagnostic]) -> unit require { Console } do
  match diags do
    | [] -> return ()
    | d :: rest ->
      Console.eprintln(val: format_diagnostic_json(diag: d))
      return print_parse_diags_json(diags: rest)
  end
end

let print_parse_diags = fn (diags: [CompilerDiagnostic], format: ExplainFormat) -> unit require { Console } do
  match format do
    | FormatText -> print_parse_diags_text(diags)
    | FormatJson -> print_parse_diags_json(diags)
  end
end
// ─── Pipeline ───────────────────────────────────────────────────────────────

let list_has_str = fn (xs: [string], s: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true end
      return list_has_str(xs: rest, s)
  end
end

/** Extract canonical names of all top-level lets in `defs` so they match
 *  the names assigned by `process_top_level` in src/ir/hir/hir.nx (which runs
 *  `symtab.rename(name, entries)` against the same rename table built in
 *  `build_entry_self_entries`). The entry file's `main` keeps its bare
 *  name; every other top-level let canonicalises to "<sanitized-path>#name"
 *  per `rdr.canonical_name`. Building the typecheck allow-list with bare
 *  names (the previous behaviour) silently skipped every non-main top-level
 *  function body because `is_local` only matches by string equality
 *  (issue nexus-rfh1).
 */
let extract_function_names = fn (defs: [SpannedTopLevel], source: string) -> [string] do
  match defs do
    | [] -> return []
    | SpannedTopLevel(node: TLLet(def: GlobalLet(name, is_public: _, typ: _, value: _)), span: _) :: rest ->
      let qname = if name == "main" then "main" else canonical_name_string(source, name) end
      return qname :: extract_function_names(defs: rest, source)
    | _ :: rest -> return extract_function_names(defs: rest, source)
  end
end

let get_enum_defs = fn (hir: HirProgram) -> [EnumDef] do
  match hir do | HirProgram(ports: _, functions: _, externals: _, handler_bindings: _, enum_defs: eds, _) -> eds end
end

let get_type_defs = fn (hir: HirProgram) -> [RecordDef] do
  match hir do | HirProgram(ports: _, functions: _, externals: _, handler_bindings: _, enum_defs: _, exception_groups: _, value_binding_names: _, type_defs: tds) -> tds end
end

type HirBuildResult = HirBuildResult(program: HirProgram, import_cache: [CacheEntry])

// Bundled result of the capability extraction + wasm write phase. The
// non-polyglot branch runs them in parallel via `std:lazy_host`; both
// branches funnel through this record so the surrounding driver code
// reads `caps` / `ok` uniformly.
type CapsWriteResult = CapsWriteResult(caps: [string], ok: bool)

/** Add rename entries for the entry file's own top-level defs so that local
 *  calls (foo(), Console.println(...)) rename to canonical targets.
 *  The entry file's `main` function keeps its bare name so wasm export "main" works.
 */
let build_entry_self_entries = fn (defs: [SpannedTopLevel], source: string, acc: [RenameEntry]) -> [RenameEntry] do
  match defs do
    | [] -> return acc
    | SpannedTopLevel(node: TLLet(def: GlobalLet(name, is_public: _, typ: _, value: _)), span: _) :: rest ->
      if name == "main" then
        let acc2 = symtab.rename_add(entries: acc, original: name, qualified: "main")
        return build_entry_self_entries(defs: rest, source, acc: acc2)
      end
      let acc2 = symtab.rename_add(entries: acc, original: name, qualified: canonical_name_string(source, name))
      return build_entry_self_entries(defs: rest, source, acc: acc2)
    | SpannedTopLevel(node: TLCap(def: Cap(name, is_public: _, functions: _)), span: _) :: rest ->
      let acc2 = symtab.rename_add(entries: acc, original: name, qualified: canonical_name_string(source, name))
      return build_entry_self_entries(defs: rest, source, acc: acc2)
    | _ :: rest -> return build_entry_self_entries(defs: rest, source, acc)
  end
end

let canonical_name_string = fn (source: string, name: string) -> string do
  return rdr.canonical_name(source_path: source, name)
end

let build_hir = fn (prog: Program, source_file: string, verbose: bool) -> HirBuildResult require { Console, Fs } throws { HirError } do
  let defs = get_defs(prog)
  let imports = resolve.extract_imports(defs)
  let result = process_imports(imports, accum: hir.empty_accum(), import_stack: [], visited: [], cache: [], caller_entries: [], depth: 1, verbose)
  match result do | ImportResult(accum, visited: _, cache: import_cache, caller_entries) ->
    let self_entries = build_entry_self_entries(defs, source: source_file, acc: [])
    let entries = append_entries(xs: self_entries, ys: caller_entries)
    let accum2 = hir.process_defs(defs, entries, accum, source_file)
    return HirBuildResult(program: hir.accum_to_program(accum: accum2), import_cache)
  end
end

let str_nth = fn (xs: [string], n: i64) -> string throws { IndexOutOfBounds } do
  match xs do
    | [] -> raise IndexOutOfBounds(op: "str_nth", index: n)
    | v :: rest ->
      if n == 0 then return v end
      return str_nth(xs: rest, n: n - 1)
  end
end

// ─── Argparse spec table (issue nexus-8vu5) ────────────────────────────────
//
// One source of truth for every argument the driver recognises. Drives:
//   - `parse_global_args` (one-shot replacement for the legacy chain of
//     strip_verbose_flag / strip_output_flag / strip_polyglot_flags /
//     strip_coverage_flag / strip_format_flag / strip_explain_flags).
//   - `print_usage`, which now feeds `argparse.render_usage` (no more
//     hand-edited literal — the old block at driver.nx:301).
//
// Subcommand entries are advisory only — argparse never consumes them.
// Subcommand routing still happens via `detect_subcommand` calls in the
// main dispatcher because the order is load-bearing (`repl` short-circuits
// before flag parsing; `test`/`fmt` short-circuit before MIR/codegen).

/** Build emit selector. `BareBinary` writes the raw merged wasm;
 *  `PolyglotLauncher` wraps it in the self-extracting POSIX-sh launcher.
 */
type OutputMode = BareBinary | PolyglotLauncher

let cli_specs = fn () -> [ArgSpec] do
  return [
    // Subcommands (one entry per top-level routing arm; consumed by
    // detect_subcommand rather than argparse.parse).
    spec_subcommand(name: "build", help: "<input.nx> [-o output.wasm] [--polyglot [--remain-manifest]]"),
    spec_subcommand(name: "run", help: "<input.nx> [-- ARGS...]"),
    spec_subcommand(name: "typecheck", help: "<input.nx>"),
    spec_subcommand(name: "ast", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "hir", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "lir", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "types", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "caps", help: "<symbol> <input.nx> [--format=text|json]"),
    spec_subcommand(name: "repl", help: "interactive REPL"),
    spec_subcommand(name: "mcp", help: "JSON-RPC tool server (stdio)"),
    spec_subcommand(name: "explain", help: "<symbol> [--file FILE] [--format text|json]"),
    spec_subcommand(name: "context", help: "<file> [--format text|json]"),
    spec_subcommand(name: "test", help: "[path] [--junit FILE] [--nexus-bin PATH] [--wasmtime-bin PATH]"),
    spec_subcommand(name: "fmt", help: "[--check] FILE|- [FILE...]"),
    spec_subcommand(name: "grep", help: "<pattern> [path...]"),
    spec_subcommand(name: "lint", help: "[--check] FILE [FILE...]"),
    spec_subcommand(name: "fix",  help: "[--check|--write|--diff] FILE [FILE...]"),
    spec_subcommand(name: "skill", help: "--emit [--out PATH] | --check"),
    spec_subcommand(name: "help", help: "[subcommand]"),
    // Global options
    spec_flag(name: "verbose", short: "", long: "--verbose", help: "enable per-pass timing output"),
    spec_opt(name: "output", short: "-o", long: "--output", required: false, help: "output wasm path"),
    spec_opt(name: "format", short: "", long: "--format", required: false, help: "diagnostic format (text|json)"),
    spec_opt(name: "explain-capabilities", short: "", long: "--explain-capabilities", required: false, help: "capability reporting (yes|none|wasmtime)"),
    spec_opt(name: "explain-capabilities-format", short: "", long: "--explain-capabilities-format", required: false, help: "capability report format (text|json)"),
    spec_flag(name: "coverage", short: "", long: "--coverage", help: "emit coverage counters and custom section"),
    spec_flag(name: "polyglot", short: "", long: "--polyglot", help: "emit self-extracting POSIX-sh + wasm launcher"),
    spec_flag(name: "remain-manifest", short: "", long: "--remain-manifest", help: "polyglot launcher keeps the manifest layout"),
    spec_flag(name: "dump-imports", short: "", long: "--dump-imports", help: "print the import graph and exit"),
  ]
end

/** Spec table for the top-level `nexus help` overview (issue nexus-qpuz).
 *  Only TRULY global flags belong here — i.e. flags accepted by every
 *  subcommand. Per-subcommand flags (-o, --format, --explain-capabilities,
 *  --explain-capabilities-format, --coverage, --polyglot, --remain-manifest,
 *  --dump-imports) live in their respective `*_subspec()` entries and are
 *  rendered by `nexus <sub> --help` / `nexus help <sub>` (issue nexus-z35v).
 *
 *  Note: `cli_specs()` above still lists every flag because it is fed to
 *  `parse_permissive` for the one-shot global-argv parse — argparse needs
 *  the full schema to recognise each flag. Help rendering uses this
 *  smaller, correctly partitioned table.
 */
export let global_help_specs = fn () -> [ArgSpec] do
  return [
    // Subcommands (mirrors cli_specs())
    spec_subcommand(name: "build", help: "<input.nx> [-o output.wasm] [--polyglot [--remain-manifest]]"),
    spec_subcommand(name: "run", help: "<input.nx> [-- ARGS...]"),
    spec_subcommand(name: "typecheck", help: "<input.nx>"),
    spec_subcommand(name: "ast", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "hir", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "lir", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "types", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "caps", help: "<symbol> <input.nx> [--format=text|json]"),
    spec_subcommand(name: "repl", help: "interactive REPL"),
    spec_subcommand(name: "mcp", help: "JSON-RPC tool server (stdio)"),
    spec_subcommand(name: "explain", help: "<symbol> [--file FILE] [--format text|json]"),
    spec_subcommand(name: "context", help: "<file> [--format text|json]"),
    spec_subcommand(name: "test", help: "[path] [--junit FILE] [--nexus-bin PATH] [--wasmtime-bin PATH]"),
    spec_subcommand(name: "fmt", help: "[--check] FILE|- [FILE...]"),
    spec_subcommand(name: "grep", help: "<pattern> [path...]"),
    spec_subcommand(name: "lint", help: "[--check] FILE [FILE...]"),
    spec_subcommand(name: "fix",  help: "[--check|--write|--diff] FILE [FILE...]"),
    spec_subcommand(name: "skill", help: "--emit [--out PATH] | --check"),
    spec_subcommand(name: "help", help: "[subcommand]"),
    // Truly global flags only. Run `nexus <sub> --help` for sub-local flags.
    spec_flag(name: "verbose", short: "", long: "--verbose", help: "enable per-pass timing output")
  ]
end

/** True-global flags only — the argparse spec list fed to
 *  `render_subcommand_overview` for the "Options:" block of `nexus help`.
 *  Per-subcommand flags live in their `*_subspec()` entries and surface
 *  via `nexus <sub> --help` (issue nexus-z35v). Separated from
 *  `global_help_specs()` so the bmu7 grouped overview can be rendered
 *  without dragging the legacy flat subcommand-stub list around. */
let global_help_flag_specs = fn () -> [ArgSpec] do
  return [
    spec_flag(name: "verbose", short: "", long: "--verbose", help: "enable per-pass timing output")
  ]
end

/** Render the consolidated usage block (issue nexus-8vu5).
 *
 *  Top-level overview now (issue nexus-bmu7) emits subcommands grouped by
 *  `SubcommandCategory` (Build / Context / Safety / Tooling) — driven by
 *  the `category` field on each `*_subspec()`. Per-subcommand detail
 *  (build / typecheck / repl / test) is still delivered via
 *  `subcommand_specs()` + `render_subcommand_help` (issue nexus-z35v).
 *  Routing of `help [sub]` is handled by `dispatch_help` below (extends
 *  the nexus-npo6 short-circuit).
 *
 *  nexus-qpuz: the "Options:" block is fed `global_help_flag_specs()`
 *  (truly-global flags only) so per-subcommand flags can no longer leak.
 */
// nexus-8s1l: usage is emitted on stdout (help is not an error).
// Error paths that still want to surface usage (e.g. the no-input-file
// branch at the bottom of `run`) format render_subcommand_overview
// inline on stderr rather than going through this helper.
let print_usage = fn () -> unit require { Console } do
  Console.println(val: render_subcommand_overview(
    summary: "Usage: nexus <subcommand> [options] <args>",
    subs: subcommand_specs(),
    globals: global_help_flag_specs()
  ))
end

// ─── Per-subcommand help table (issue nexus-z35v) ──────────────────────────
//
// One SubcommandSpec per top-level routing arm. Each carries:
//   - synopsis      one-line usage shape (no `nexus` prefix)
//   - description   multi-paragraph prose explaining the command
//   - flags         per-sub ArgSpec list (auto-derived FLAGS table)
//   - examples      worked invocations
//   - see_also      related subcommand names
//   - exit_codes    canonical exit status meanings
//
// Lookups go through `lookup_subcommand_spec(name)`. The top-level
// `help` dispatch (extending nexus-npo6) routes both `nexus <sub> --help`
// and `nexus help <sub>` through `render_subcommand_help`, so the two
// invocations produce byte-identical output.

let std_exit_codes = fn () -> [ExitCode] do
  return [
    exit_code(code: 0, meaning: "success"),
    exit_code(code: 1, meaning: "compilation or runtime failure (diagnostic on stderr)"),
    exit_code(code: 2, meaning: "invalid CLI usage (E4002 / E4004)")
  ]
end

// Global flags relevant to every build-pipeline subcommand
// (build / run / typecheck / ast / hir / lir / types). Keeping them in
// one helper avoids spec drift between subs.
let pipeline_flags = fn () -> [ArgSpec] do
  return [
    spec_flag(name: "verbose", short: "", long: "--verbose", help: "enable per-pass timing output"),
    spec_opt(name: "format", short: "", long: "--format", required: false, help: "diagnostic format (text|json)"),
    spec_opt(name: "explain-capabilities", short: "", long: "--explain-capabilities", required: false, help: "capability reporting (yes|none|wasmtime)"),
    spec_opt(name: "explain-capabilities-format", short: "", long: "--explain-capabilities-format", required: false, help: "capability report format (text|json)")
  ]
end

let build_subspec = fn () -> SubcommandSpec do
  let flags = list.concat(
    xs: [
      spec_opt(name: "output", short: "-o", long: "--output", required: false, help: "output wasm path (default: out.wasm)"),
      spec_flag(name: "polyglot", short: "", long: "--polyglot", help: "emit self-extracting POSIX-sh + wasm launcher"),
      spec_flag(name: "remain-manifest", short: "", long: "--remain-manifest", help: "polyglot launcher keeps manifest layout"),
      spec_flag(name: "coverage", short: "", long: "--coverage", help: "emit coverage counters and custom section"),
      spec_flag(name: "dump-imports", short: "", long: "--dump-imports", help: "print the import graph and exit")
    ],
    ys: pipeline_flags()
  )
  return subspec(
    name: "build",
    synopsis: "<input.nx> [-o <output.wasm>] [--polyglot [--remain-manifest]] [--coverage]",
    description: "Compile a Nexus source file to a self-contained WebAssembly module.\nThe full pipeline runs (parse, resolve, HIR/MIR/LIR, codegen, link, merge) and\nthe resulting wasm is written to the path given by -o (default: out.wasm).\n\nWith --polyglot the output is wrapped in a POSIX-sh self-extracting launcher\nthat embeds wasmtime invocation; the file is executable on any POSIX shell.",
    flags,
    examples: [
      example(command: "nexus build examples/hello.nx -o hello.wasm", comment: "compile a single source file to a wasm module"),
      example(command: "nexus build src/driver.nx -o nexus.wasm --polyglot", comment: "produce a polyglot launcher (sh + wasm in one file)"),
      example(command: "nexus build foo.nx --coverage -o foo.cov.wasm", comment: "instrument with coverage counters")
    ],
    see_also: ["run", "typecheck", "test"],
    exit_codes: std_exit_codes(),
    category: CategoryBuild
  )
end

let run_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "run",
    synopsis: "<input.nx> [-- <user-args>...]",
    description: "Compile a Nexus source file and immediately execute it via wasmtime.\nArguments after `--` are forwarded verbatim to the running program.\n\nFor short iteration cycles this is preferable to `nexus build` followed by\nan explicit wasmtime invocation.",
    flags: pipeline_flags(),
    examples: [
      example(command: "nexus run examples/hello.nx", comment: "compile and run; no program args"),
      example(command: "nexus run scripts/count.nx -- file1.txt file2.txt", comment: "forward two arguments after `--` to the script")
    ],
    see_also: ["build", "repl"],
    exit_codes: std_exit_codes(),
    category: CategoryBuild
  )
end

let typecheck_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "typecheck",
    synopsis: "<input.nx>",
    description: "Run only the front-end: parse, resolve, HIR construction, and full\ntypechecking (including effect rows + linearity). No MIR/LIR/codegen.\n\nUseful as a fast feedback loop and as the pre-commit hook target.",
    flags: pipeline_flags(),
    examples: [
      example(command: "nexus typecheck src/driver.nx", comment: "fast typecheck of the self-hosting driver"),
      example(command: "nexus typecheck foo.nx --format json", comment: "emit JSON diagnostics for editor integration")
    ],
    see_also: ["build", "types"],
    exit_codes: std_exit_codes(),
    category: CategoryBuild
  )
end

let ast_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "ast",
    synopsis: "<input.nx> [--format text|json]",
    description: "Pretty-print the parsed AST for the given source file. Useful when\ndebugging parser issues or building tooling on top of Nexus.\n\nThe JSON variant is stable enough to feed into external linters.",
    flags: list.concat(
      xs: [spec_opt(name: "format", short: "", long: "--format", required: false, help: "output format (text|json)")],
      ys: pipeline_flags()
    ),
    examples: [
      example(command: "nexus ast examples/hello.nx", comment: "pretty-print the AST as text"),
      example(command: "nexus ast examples/hello.nx --format json", comment: "machine-readable AST dump")
    ],
    see_also: ["hir", "lir", "types"],
    exit_codes: std_exit_codes(),
    category: CategoryContext
  )
end

