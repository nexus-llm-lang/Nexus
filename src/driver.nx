let types_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "types",
    synopsis: "<input.nx> [--transitive] [--format text|json]",
    description: "Dump <input.nx>'s own top-level bindings' inferred types after full\ntypechecking. By default the output is scoped to symbols defined in\n<input.nx> and identifiers appear as bare names. Pass --transitive\nto include imported symbols too; imported identifiers render in the\nmodule-path form used by import statements (e.g. `std:str.load_at`).\nWith --format json the output is keyed by symbol and includes effect\nrows, which is the canonical input to editor hover/`explain` flows.",
    flags: list.concat(
      xs: [
        spec_opt(name: "format", short: "", long: "--format", required: false, help: "output format (text|json)"),
        spec_opt(name: "transitive", short: "", long: "--transitive", required: false, help: "include types for symbols imported from other files")
      ],
      ys: pipeline_flags()
    ),
    examples: [
      example(command: "nexus types foo.nx", comment: "text dump of foo.nx's own bindings (bare names)"),
      example(command: "nexus types foo.nx --transitive", comment: "include imported symbols (rendered as std:str.load_at etc.)"),
      example(command: "nexus types src/driver.nx --format json", comment: "JSON for editor integration")
    ],
    see_also: ["typecheck", "explain"],
    exit_codes: std_exit_codes(),
    category: CategoryContext
  )
end

let caps_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "caps",
    synopsis: "<symbol> <input.nx> [--format text|json]",
    description: "Dump the transitive capability closure of one named function: every\ncapability (Fs / Net / Console / Random / Clock / Proc / Env) reached\nby any function transitively called from <symbol>. Useful for agents\nor reviewers asking 'does this function touch the filesystem?' before\nan edit. Symbol resolution accepts either the canonical qualified form\n(`<sanitized_path>#<name>`) or the bare suffix.",
    flags: list.concat(
      xs: [spec_opt(name: "format", short: "", long: "--format", required: false, help: "output format (text|json)")],
      ys: pipeline_flags()
