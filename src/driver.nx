let skill_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "skill",
    category: CategoryTooling,
    synopsis: "--emit [--out PATH] | --check [--out PATH]",
    description: "Auto-regenerate the CLI-reference markdown from the compiler's\nauthoritative spec tables (`subcommand_specs()` / `global_help_specs()`\nin src/driver.nx). The intent is to keep the LLM context harness\n(skills/nexus-lang, AGENTS.md) in lockstep with the actual subcommand\nand flag inventory — handy when adding or renaming a subcommand.\n\nDefault output path: docs/cli-reference.md. With --check the on-disk\nfile is read and compared against the freshly-rendered output; mismatch\nexits 1 (suitable as a CI gate).",
    flags: [
      spec_flag(name: "emit", short: "", long: "--emit", help: "regenerate the CLI-reference document (default action)"),
      spec_flag(name: "check", short: "", long: "--check", help: "verify the on-disk file matches; exit 1 on drift"),
      spec_opt(name: "out", short: "", long: "--out", required: false, help: "output path (default: docs/cli-reference.md)")
    ],
    examples: [
      example(command: "nexus skill --emit", comment: "regenerate docs/cli-reference.md from compiler state"),
      example(command: "nexus skill --emit --out skills/nexus-lang/references/cli.md", comment: "redirect to a different path (e.g. inside the skill bundle)"),
      example(command: "nexus skill --check", comment: "CI gate — exits 1 if docs/cli-reference.md is stale")
    ],
    see_also: ["help", "explain"],
    exit_codes: [
      exit_code(code: 0, meaning: "emitted successfully or --check matched"),
      exit_code(code: 1, meaning: "--check detected drift, or write/read failed"),
      exit_code(code: 2, meaning: "invalid CLI usage")
    ]
  )
end

let help_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "help",
    synopsis: "[<subcommand>]",
    description: "With no argument, print the top-level usage overview (the same output\nas `nexus --help`). With a subcommand name, print that subcommand's\nstructured help (the same output as `nexus <sub> --help`).",
    flags: [],
    examples: [
      example(command: "nexus help", comment: "top-level overview"),
      example(command: "nexus help build", comment: "structured help for `nexus build`")
    ],
    see_also: ["build", "run", "test"],
    exit_codes: [exit_code(code: 0, meaning: "help printed")],
    category: CategoryTooling
  )
end

/** Per-subcommand spec table. Order is the canonical sort order used by
 *  the top-level overview. */
let subcommand_specs = fn () -> [SubcommandSpec] do
  return [
    build_subspec(),
    run_subspec(),
    typecheck_subspec(),
    ast_subspec(),
    hir_subspec(),
    lir_subspec(),
    types_subspec(),
    caps_subspec(),
    repl_subspec(),
    mcp_subspec(),
    explain_subspec(),
    context_subspec(),
    test_subspec(),
    fmt_subspec(),
    grep_subspec(),
    skill_subspec(),
    help_subspec()
  ]
end

let lookup_subcommand_spec = fn (specs: [SubcommandSpec], name: string) -> Option<SubcommandSpec> do
  match specs do
    | [] -> return None
    | s :: rest ->
      match s do | SubcommandSpec(name: n, synopsis: _, description: _, flags: _, examples: _, see_also: _, exit_codes: _, category: _) ->
        if n == name then return Some(val: s) end
        return lookup_subcommand_spec(specs: rest, name)
      end
  end
end

/** Print the rich per-subcommand help for `sub_name`. Returns true when
 *  printed; false when no spec was found (caller falls back to the
 *  top-level overview).
 */
let print_subcommand_help = fn (sub_name: string) -> bool require { Console } do
  match lookup_subcommand_spec(specs: subcommand_specs(), name: sub_name) do
    | None -> return false
    | Some(val: s) ->
      Console.eprintln(val: render_subcommand_help(prog: "nexus", spec: s))
      return true
  end
end

/** Recognise `nexus help <sub>` / `nexus <sub> --help` / `nexus <sub> -h`
 *  shapes and emit the structured per-sub help. Returns true when help
 *  was handled (caller exits 0); false when args did not look like a
 *  help-shaped request (caller continues with normal parsing).
 *
 *  Unknown sub-names after `help` or before `--help` fall back to the
 *  top-level overview rather than failing — keeps the help routing
 *  uniformly successful.
 */
let try_dispatch_help = fn (args: [string]) -> bool require { Console } do
  match args do
    | _ :: a :: b :: _ ->
      if a == "help" then
        if print_subcommand_help(sub_name: b) then return true end
        print_usage()
        return true
      end
      if b == "--help" || b == "-h" then
        if print_subcommand_help(sub_name: a) then return true end
        print_usage()
        return true
      end
      return false
    | _ -> return false
  end
end

// Bundled global flags resolved by `parse_global_args`. Replaces the
// chain of per-flag Parsed* records the legacy strip_* helpers carried.
type GlobalFlags = GlobalFlags(
  positionals: [string],
  remaining: [string],
  verbose: bool,
  output: Option<string>,
  diag_format: ExplainFormat,
  explain: ExplainCaps,
  explain_format: ExplainFormat,
  coverage: bool,
  output_mode: OutputMode,
  manifest_mode: ManifestMode,
  dump_imports: bool
)

let parse_explain_caps_or_fail = fn (val: string) -> ExplainCaps throws { InvalidUsage } do
  if let Some(val: e) = parse_explain_caps_value(s: val) then return e end
  raise InvalidUsage(detail: "invalid --explain-capabilities value: " ++ val)
end

let parse_format_or_fail = fn (val: string, flag_name: string) -> ExplainFormat throws { InvalidUsage } do
  if let Some(val: f) = parse_explain_format_value(s: val) then return f end
  raise InvalidUsage(detail: "invalid " ++ flag_name ++ " value: " ++ val ++ " (expected text|json)")
end

let read_explain_caps_opt = fn (result: ParseResult) -> ExplainCaps throws { InvalidUsage } do
  match get_opt(result, name: "explain-capabilities") do
    | None -> return ExplainYes
    | Some(val: v) -> return parse_explain_caps_or_fail(val: v)
  end
end

let read_format_opt = fn (result: ParseResult, name: string, flag_name: string) -> ExplainFormat throws { InvalidUsage } do
  match get_opt(result, name) do
    | None -> return FormatText
    | Some(val: v) -> return parse_format_or_fail(val: v, flag_name)
  end
end

/** One-shot replacement for the legacy strip_verbose_flag / strip_output_flag
 *  / strip_polyglot_flags / strip_coverage_flag / strip_format_flag /
 *  strip_explain_flags chain (issue nexus-8vu5). Parses every driver-global
 *  flag in a single argparse pass, leaving subcommand keywords + the input
 *  filename in `positionals` and any post-`--` user-program argv in
 *  `remaining`.
 */
let parse_global_args = fn (args: [string]) -> GlobalFlags throws { InvalidUsage } do
  let result = parse_permissive(args, specs: cli_specs())
  if !is_ok(result) then
    raise InvalidUsage(detail: first_error(result))
  end
  let verbose = get_flag(result, name: "verbose")
  let output = get_opt(result, name: "output")
  let diag_format = read_format_opt(result, name: "format", flag_name: "--format")
  let explain = read_explain_caps_opt(result)
  let explain_format = read_format_opt(result, name: "explain-capabilities-format", flag_name: "--explain-capabilities-format")
  let coverage = get_flag(result, name: "coverage")
  let polyglot = get_flag(result, name: "polyglot")
  let remain_manifest = get_flag(result, name: "remain-manifest")
  let dump_imports = get_flag(result, name: "dump-imports")
  let output_mode = if polyglot then PolyglotLauncher else BareBinary end
  let manifest_mode = if remain_manifest then KeepManifest else StripManifest end
  return GlobalFlags(
    positionals: get_positionals_all(result),
    remaining: get_remaining(result),
    verbose, output, diag_format, explain, explain_format, coverage,
    output_mode, manifest_mode, dump_imports
  )
end

// ─── Back-compat exports (issue nexus-8vu5) ────────────────────────────────
//
// The legacy `strip_typecheck_subcommand` / `strip_run_subcommand` shapes
// + their Parsed* record types survive as thin wrappers over argparse's
// `detect_subcommand` primitive. The regression tests under
// tests/runtime/{m8ey,tr79}_*_test.nx assert the CLI-shape contract those
// shapes encode; rewriting the tests against the argparse-based dispatcher
// is mechanical but out of scope for this issue.

export type ParsedTypecheckSubcommand = ParsedTypecheckSubcommand(remaining: [string], typecheck_only: bool)

export let strip_typecheck_subcommand = fn (xs: [string]) -> ParsedTypecheckSubcommand do
  match detect_subcommand(args: xs, kw: "typecheck") do | SubcommandHit(present, remaining) ->
    return ParsedTypecheckSubcommand(remaining, typecheck_only: present)
  end
end

export type ParsedRunSubcommand = ParsedRunSubcommand(remaining: [string], run_mode: bool, run_args: [string])

let split_run_args = fn (xs: [string], prefix: [string]) -> ParsedRunSubcommand do
  match xs do
    | [] -> return ParsedRunSubcommand(remaining: list.reverse(xs: prefix), run_mode: true, run_args: [])
    | v :: rest ->
      if v == "--" then
        return ParsedRunSubcommand(remaining: list.reverse(xs: prefix), run_mode: true, run_args: rest)
      end
      return split_run_args(xs: rest, prefix: v :: prefix)
  end
end

export let strip_run_subcommand = fn (xs: [string]) -> ParsedRunSubcommand do
  match detect_subcommand(args: xs, kw: "run") do | SubcommandHit(present, remaining) ->
    if !present then return ParsedRunSubcommand(remaining, run_mode: false, run_args: []) end
    match remaining do
      | [] -> return ParsedRunSubcommand(remaining: [], run_mode: true, run_args: [])
      | prog :: post ->
        let ParsedRunSubcommand(remaining: pre, run_mode: _, run_args) = split_run_args(xs: post, prefix: [])
        return ParsedRunSubcommand(remaining: prog :: pre, run_mode: true, run_args)
    end
  end
end

/** Resolve the output path: prefer `-o`/`--output` value, otherwise fall back to
 *  the positional `[output]` arg or the default `main.wasm`.
 */
let resolve_output_path = fn (opt_output: Option<string>, xs: [string], argc: i64) -> string throws { IndexOutOfBounds } do
  match opt_output do
    | Some(val: o) -> return o
    | None ->
      if argc >= 3 then return str_nth(xs, n: 2) end
      return "out.wasm"
  end
end

let write_and_free = fn (buf: %ByteBuffer, path: string) -> bool do
  let ok = bb.write_file(&buf, path)
  bb.free(%buf)
  return ok
end

/** Emit either the raw merged wasm or, when `output` is `PolyglotLauncher`,
 *  the self-extracting launcher. Both paths consume `wasm_buf` and free it;
 *  the boolean return matches `write_and_free`.
 */
let write_emit = fn (wasm_buf: %ByteBuffer, output_path: string, caps: [string], output: OutputMode, manifest: ManifestMode, verbose: bool) -> bool require { Console } do
  let polyglot_mode = if let PolyglotLauncher = output then true else false end
  if polyglot_mode then
    let payload_size = bb.length(buf: &wasm_buf)
    let %launcher = polyglot.pack_polyglot(wasm: &wasm_buf, caps, manifest)
    bb.free(buf: %wasm_buf)
    if verbose then
      let header_n = polyglot.header_size(caps, manifest, payload_size)
      let total_n = bb.length(buf: &launcher)
      Console.eprintln(val: "[nexus] polyglot launcher = header(" ++ str.from_i64(val: header_n)
        ++ ") + payload(" ++ str.from_i64(val: payload_size)
        ++ ") = total(" ++ str.from_i64(val: total_n) ++ ")")
    end
    return write_and_free(buf: %launcher, path: output_path)
  end
  return write_and_free(buf: %wasm_buf, path: output_path)
end

// ─── Capability reporting (--explain-capabilities) ──────────────────────────
// Extracts the entry's `require { Perm… }` row from the parsed AST, maps
// `PermX` → `X`, and prints either text or JSON describing the capabilities
// (and, in `wasmtime` mode, a ready-to-run command).

type ExplainCaps = ExplainYes | ExplainNone | ExplainWasmtime

type ExplainFormat = FormatText | FormatJson

let parse_explain_caps_value = fn (s: string) -> Option<ExplainCaps> do
  if s == "yes" then return Some(val: ExplainYes) end
  if s == "none" then return Some(val: ExplainNone) end
  if s == "wasmtime" then return Some(val: ExplainWasmtime) end
  return None
end

let parse_explain_format_value = fn (s: string) -> Option<ExplainFormat> do
  if s == "text" then return Some(val: FormatText) end
  if s == "json" then return Some(val: FormatJson) end
  return None
end

// ─── Driver-wide diagnostic format (--format=json|text, issue nexus-kmel) ───
//
// Distinct from `--explain-capabilities-format` (which only controls the
// "Built foo.wasm" build-result blurb). `--format` selects the rendering for
// every compiler diagnostic: parse-error NDJSON in V1, with typecheck /
// linearity to follow in nexus-kmel.2. The two flags share the same
// `ExplainFormat = FormatText | FormatJson` algebra because the underlying
// choice is identical and the migration cost is zero.
//
// Both --format and --explain-capabilities-format are parsed in one shot
// by `parse_global_args` (above) via the argparse spec table.

let perm_to_cap_name = fn (perm: string) -> Option<string> do
  if perm == "PermFs" then return Some(val: "Fs") end
  if perm == "PermNet" then return Some(val: "Net") end
  if perm == "PermConsole" then return Some(val: "Console") end
  if perm == "PermRandom" then return Some(val: "Random") end
  if perm == "PermClock" then return Some(val: "Clock") end
  if perm == "PermProc" then return Some(val: "Proc") end
  if perm == "PermEnv" then return Some(val: "Env") end
  return None
end

let collect_cap_names = fn (xs: [TypeExpr]) -> [string] do
  match xs do
    | [] -> return []
    | TyUserDefined(name, args: []) :: rest ->
      if let Some(val: c) = perm_to_cap_name(perm: name) then
        return c :: collect_cap_names(xs: rest)
      end
      return collect_cap_names(xs: rest)
    | _ :: rest -> return collect_cap_names(xs: rest)
  end
end

let extract_caps_from_row = fn (row: TypeExpr) -> [string] do
  if let TyRow(types, rest: _) = row then
    return collect_cap_names(xs: types)
  end
  return []
end

/** Walk top-level defs; for `let main = fn (...) require { Perm… }`, return
 *  the capability names. Adds `Proc` when `main` takes `args` so argv can
 *  be read at runtime.
 */
let find_main_caps = fn (defs: [SpannedTopLevel]) -> [string] do
  match defs do
    | [] -> return []
    | SpannedTopLevel(node: TLLet(def: GlobalLet(name, is_public: _, typ: _, value: SpannedExpr(node: ExprLambda(type_params: _, params, ret_type: _, requires, throw_row: _, body: _), span: _))), span: _) :: rest ->
      if name == "main" then
        let caps = extract_caps_from_row(row: requires)
        if list.length(xs: params) > 0 then
          if list_has_str(xs: caps, s: "Proc") then return caps end
          return list.concat(xs: caps, ys: ["Proc"])
        end
        return caps
      end
      return find_main_caps(defs: rest)
    | _ :: rest -> return find_main_caps(defs: rest)
  end
end

// `--explain-capabilities VALUE` and `--explain-capabilities-format VALUE`
// are now parsed in one shot by `parse_global_args` (above). The
// renamed-fields ExplainCaps / ExplainFormat values land in GlobalFlags.

let cap_wasmtime_flags = fn (name: string) -> [string] do
  // Net: only `-S inherit-network` is safe on the preview1 core wasm we
  // emit; `-S http` (wasi-http) requires a preview2 component and would
  // fail at startup with "Cannot enable wasi-http for core wasm modules"
  // (nexus-yx5i). Until a preview2 bridge lands the stdlib HTTP primitives
  // are stubs anyway (see nxlib/stdlib/network.nx), so this flag is mostly
  // a marker that the program touches the network.
  if name == "Net" then return ["--wasi", "inherit-network"] end
  if name == "Fs" then return ["--dir", "."] end
  return []
end

let collect_all_wasmtime_flags = fn (caps: [string]) -> [string] do
  match caps do
    | [] -> return []
    | c :: rest -> return list.concat(xs: cap_wasmtime_flags(name: c), ys: collect_all_wasmtime_flags(caps: rest))
  end
end

/** Wasm proposals required at runtime. The inlined stdlib uses every one of
 *  these (TCO, raise/throws, closures, handlers, threads/atomics for `@`), so
 *  emit them all whenever wasmtime mode is selected — detection on the user's
 *  AST alone would underreport because stdlib brings them in regardless.
 */
let wasmtime_feature_flags = fn () -> [string] do
  return ["-W", "tail-call=y", "-W", "exceptions=y", "-W", "function-references=y", "-W", "stack-switching=y", "-W", "threads=y", "-W", "shared-memory=y", "-S", "threads"]
end

let quote_strings = fn (xs: [string]) -> [string] do
  match xs do
    | [] -> return []
    | v :: rest -> return ("\"" ++ v ++ "\"") :: quote_strings(xs: rest)
  end
end

let build_run_cmd = fn (output_name: string, caps: [string]) -> string do
  let feat_flags = wasmtime_feature_flags()
  let cap_flags = collect_all_wasmtime_flags(caps)
  let argv = list.concat(xs: feat_flags, ys: list.concat(xs: cap_flags, ys: [output_name]))
  return "wasmtime run " ++ str.join(xs: argv, sep: " ")
end

/** Build the wasmtime argv for `nexus run`: `["run", -W..., -S..., cap-flags,
 *  wasm_path, user_args...]`. Mirrors `build_run_cmd` but emits a list so it
 *  can be fed straight to `Proc.exec`.
 */
let build_wasmtime_run_argv = fn (wasm_path: string, caps: [string], user_args: [string]) -> [string] do
  let feat_flags = wasmtime_feature_flags()
  let cap_flags = collect_all_wasmtime_flags(caps)
  let prefix = list.concat(xs: ["run"], ys: list.concat(xs: feat_flags, ys: cap_flags))
  return list.concat(xs: prefix, ys: list.concat(xs: [wasm_path], ys: user_args))
end

/** Spawn `wasmtime run` against the freshly-built artifact and return the
 *  child's exit code. The Proc.exec stub returns -1 under WASI preview1 (the
 *  wasmtime profile this driver actually runs under); detect that and tell
 *  the user to switch to the polyglot `./nexus` launcher, which intercepts
 *  `run` at the shell layer and drives wasmtime directly.
 */
let exec_run_artifact = fn (wasm_path: string, source: string, caps: [string], user_args: [string], verbose: bool) -> i64 require { Console, Proc } do
  let argv = build_wasmtime_run_argv(wasm_path, caps, user_args)
  if verbose then
    Console.eprintln(val: "[nexus] exec wasmtime " ++ str.join(xs: argv, sep: " "))
  end
  match Proc.exec(cmd: "wasmtime", args: argv) do | ExecResult(exit_code, stdout, stderr) ->
    if exit_code == (0 - 1) then
      Console.eprintln(val: "nexus run: subprocess unavailable (WASI preview1 has no exec).")
      Console.eprintln(val: "  Run via the polyglot launcher (`./nexus run " ++ source ++ "`) — it")
      Console.eprintln(val: "  drives wasmtime from the host shell.")
      return 1
    end
    // Stream the child's stdio so `nexus run` is transparent. `eprint` /
    // `print` (without -ln) preserve any trailing newline emitted by the
    // program so output is byte-identical to a direct wasmtime invocation.
    if str.length(s: stdout) > 0 then Console.print(val: stdout) end
    if str.length(s: stderr) > 0 then Console.eprint(val: stderr) end
    return exit_code
  end
end

let print_build_result_text = fn (output_name: string, caps: [string], explain: ExplainCaps, output: OutputMode) -> unit require { Console } do
  let polyglot_mode = if let PolyglotLauncher = output then true else false end
  Console.eprintln(val: "Built " ++ output_name)
  match explain do
    | ExplainNone -> return ()
    | ExplainYes ->
      if list.length(xs: caps) > 0 then
        Console.eprintln(val: "Capabilities: " ++ str.join(xs: caps, sep: ", "))
      end
    | ExplainWasmtime ->
      if list.length(xs: caps) > 0 then
        Console.eprintln(val: "Capabilities: " ++ str.join(xs: caps, sep: ", "))
      end
      // Polyglot launchers are run via `chmod +x && ./<launcher>`; the
      // wasmtime command is embedded inside the launcher itself, so the
      // user-facing run hint switches to the chmod form.
      if polyglot_mode then
        Console.eprintln(val: "Run: chmod +x " ++ output_name ++ " && ./" ++ output_name)
      else
        Console.eprintln(val: "Run: " ++ build_run_cmd(output_name, caps))
      end
  end
end

let print_build_result_json = fn (output_name: string, caps: [string], explain: ExplainCaps, output: OutputMode) -> unit require { Console } do
  let polyglot_mode = if let PolyglotLauncher = output then true else false end
  match explain do
    | ExplainNone ->
      Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\"}")
    | ExplainYes ->
      let caps_quoted = quote_strings(xs: caps)
      Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\",\"capabilities\":[" ++ str.join(xs: caps_quoted, sep: ",") ++ "]}")
    | ExplainWasmtime ->
      let caps_quoted = quote_strings(xs: caps)
      if polyglot_mode then
        let cmd = "chmod +x " ++ output_name ++ " && ./" ++ output_name
        Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\",\"capabilities\":[" ++ str.join(xs: caps_quoted, sep: ",") ++ "],\"polyglot\":{\"command\":\"" ++ cmd ++ "\"}}")
      else
        let all_flags = list.concat(xs: wasmtime_feature_flags(), ys: collect_all_wasmtime_flags(caps))
        let flags_quoted = quote_strings(xs: all_flags)
        let cmd = build_run_cmd(output_name, caps)
        Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\",\"capabilities\":[" ++ str.join(xs: caps_quoted, sep: ",") ++ "],\"wasmtime\":{\"command\":\"" ++ cmd ++ "\",\"flags\":[" ++ str.join(xs: flags_quoted, sep: ",") ++ "]}}")
      end
  end
end

let print_build_result = fn (output_name: string, caps: [string], explain: ExplainCaps, format: ExplainFormat, output: OutputMode) -> unit require { Console } do
  match format do
    | FormatText -> print_build_result_text(output_name, caps, explain, output)
    | FormatJson -> print_build_result_json(output_name, caps, explain, output)
  end
end

// ─── IR-dump subcommand runners (nexus-ud6j) ───────────────────────────────
//
// Both `nexus hir <file>` and `nexus lir <file>` run a slimmed pipeline:
// read → lex → parse → HIR build → (for LIR: + MIR + LIR lower). Output
// goes to stdout as either text (default) or `--format=json` JSON. We
// reuse the same parse-error -> NDJSON path as the build pipeline so the
// diagnostic shape stays consistent.

// `nexus ast <file>` (issue nexus-qqvz). Pre-typecheck, pre-HIR dump: lex +
// parse only, then format the spanned AST. The JSON envelope mirrors the V1
// `{kind, ...}` family shipped by ir_dump so agent consumers can use one
// generic node walker.
let run_ast_dump_subcommand = fn (args: [string], format: ExplainFormat, verbose: bool) -> i64 require { Clock, Console, Fs } do
  let _ = verbose
  try
    match args do
      | [] -> raise InvalidUsage(detail: "usage: nexus ast <input.nx> [--format=text|json]")
      | input_path :: _ ->
        let src = Fs.read_to_string(path: input_path)
        let tokens = lexer.tokenize(src)
        let ParseDiagnostics(prog: prog, diags: parse_diags) = parser.parse_collect(tokens, file: input_path)
        print_parse_diags(diags: parse_diags, format)
        let n_parse_diags = list.length(xs: parse_diags)
        if n_parse_diags > 0 then
          match format do
            | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
            | FormatText -> ()
          end
          raise ParseErrorsCollected(count: n_parse_diags)
        end
        let out = match format do
          | FormatText -> ast_to_text(prog)
          | FormatJson -> ast_to_json(prog)
        end
        Console.println(val: out)
        return 0
    end
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

let run_hir_dump_subcommand = fn (args: [string], format: ExplainFormat, verbose: bool) -> i64 require { Clock, Console, Fs } do
  try
    match args do
      | [] -> raise InvalidUsage(detail: "usage: nexus hir <input.nx> [--format=text|json]")
      | input_path :: _ ->
        let src = Fs.read_to_string(path: input_path)
        let tokens = lexer.tokenize(src)
        let ParseDiagnostics(prog: prog, diags: parse_diags) = parser.parse_collect(tokens, file: input_path)
        print_parse_diags(diags: parse_diags, format)
        let n_parse_diags = list.length(xs: parse_diags)
        if n_parse_diags > 0 then
          match format do
            | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
            | FormatText -> ()
          end
          raise ParseErrorsCollected(count: n_parse_diags)
        end
        let HirBuildResult(program: hir_raw, import_cache: _) = build_hir(prog, source_file: input_path, verbose)
        // Run the same resolve+DCE loop as build so the dump reflects the
        // post-link HIR rather than raw lazy bodies. Mirrors the inline
        // `match hir_raw` block in `main`.
        let hir_resolved = match hir_raw do
          | HirProgram(ports: hp, functions: hf, externals: he, handler_bindings: hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds) ->
            let resolved = iterative_resolve(funcs: hf, hb, max_rounds: 100)
            let expanded_fs = hir.expand_groups_in_functions(funcs: resolved, groups: heg)
            let expanded_hb = hir.expand_groups_in_handler_bindings(bindings: hb, groups: heg)
            let trimmed_reach = reach.collect_reachable_no_thread_start(functions: expanded_fs, handler_bindings: expanded_hb)
            let final_fs = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then expanded_fs
              else reach.filter_reachable_functions(functions: expanded_fs, reachable: trimmed_reach)
            end
            let final_reach = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then
                reach.collect_reachable(functions: final_fs, handler_bindings: expanded_hb)
              else trimmed_reach
            end
            let filtered_exts = reach.filter_reachable_externals(externals: he, reachable: final_reach)
            HirProgram(ports: hp, functions: final_fs, externals: filtered_exts, handler_bindings: expanded_hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds)
        end
        let out = match format do
          | FormatText -> hir_to_text(prog: hir_resolved)
          | FormatJson -> hir_to_json(prog: hir_resolved)
        end
        Console.println(val: out)
        return 0
    end
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

let lir_program_functions = fn (p: LirProgram) -> [LirFunction] do
  match p do | LirProgram(functions, externals: _) -> return functions end
end

let run_lir_dump_subcommand = fn (args: [string], format: ExplainFormat, verbose: bool) -> i64 require { Clock, Console, Fs } do
  try
    match args do
      | [] -> raise InvalidUsage(detail: "usage: nexus lir <input.nx> [--format=text|json]")
      | input_path :: _ ->
        let src = Fs.read_to_string(path: input_path)
        let tokens = lexer.tokenize(src)
        let ParseDiagnostics(prog: prog, diags: parse_diags) = parser.parse_collect(tokens, file: input_path)
        print_parse_diags(diags: parse_diags, format)
        let n_parse_diags = list.length(xs: parse_diags)
        if n_parse_diags > 0 then
          match format do
            | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
            | FormatText -> ()
          end
          raise ParseErrorsCollected(count: n_parse_diags)
        end
        let HirBuildResult(program: hir_raw, import_cache: _) = build_hir(prog, source_file: input_path, verbose)
        let hir_resolved = match hir_raw do
          | HirProgram(ports: hp, functions: hf, externals: he, handler_bindings: hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds) ->
            let resolved = iterative_resolve(funcs: hf, hb, max_rounds: 100)
            let expanded_fs = hir.expand_groups_in_functions(funcs: resolved, groups: heg)
            let expanded_hb = hir.expand_groups_in_handler_bindings(bindings: hb, groups: heg)
            let trimmed_reach = reach.collect_reachable_no_thread_start(functions: expanded_fs, handler_bindings: expanded_hb)
            let final_fs = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then expanded_fs
              else reach.filter_reachable_functions(functions: expanded_fs, reachable: trimmed_reach)
            end
            let final_reach = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then
                reach.collect_reachable(functions: final_fs, handler_bindings: expanded_hb)
              else trimmed_reach
            end
            let filtered_exts = reach.filter_reachable_externals(externals: he, reachable: final_reach)
            HirProgram(ports: hp, functions: final_fs, externals: filtered_exts, handler_bindings: expanded_hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds)
        end
        let enum_defs = get_enum_defs(hir: hir_resolved)
        let type_defs = get_type_defs(hir: hir_resolved)
        let mir_prog = mir.lower_hir_to_mir(hir: hir_resolved)
        let lir_prog = lir.lower_mir_to_lir(mir: mir_prog, enum_defs, type_defs)
        let funcs = lir_program_functions(p: lir_prog)
        let out = match format do
          | FormatText -> lir_to_text(funcs)
          | FormatJson -> lir_to_json(funcs)
        end
        Console.println(val: out)
        return 0
    end
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

// ─── `nexus types` subcommand (nexus-g5el) ────────────────────────────────
//
// Runs the front-end through typecheck and dumps the inferred type of each
// top-level binding as text (default) or JSON. The pipeline is shorter than
// `nexus build`: parse → HIR build → resolve (no DCE) → linearity →
// typecheck → render. No MIR/LIR/codegen — types_dump only needs the
// post-resolution HirProgram plus the source AST (for the `requires` row).
/** Scan `xs` for the `--transitive` flag. Lightweight inline scan because
 *  `--transitive` is the only types-subcommand-specific flag; the global
 *  argparse pass already consumed `--format` and the pipeline flags. */
let has_transitive_flag = fn (xs: [string]) -> bool do
  match xs do
    | [] -> return false
    | h :: rest ->
      if h == "--transitive" then return true end
      return has_transitive_flag(xs: rest)
  end
end

let run_types_dump_subcommand = fn (args: [string], format: ExplainFormat, verbose: bool) -> i64 require { Clock, Console, Fs } do
  try
    match args do
      | [] -> raise InvalidUsage(detail: "usage: nexus types <input.nx> [--transitive] [--format=text|json]")
      | input_path :: rest_args ->
        let scope = if has_transitive_flag(xs: rest_args) then ScopeAll else ScopeOwn(file: input_path) end
        let src = Fs.read_to_string(path: input_path)
        let tokens = lexer.tokenize(src)
        let ParseDiagnostics(prog: prog, diags: parse_diags) = parser.parse_collect(tokens, file: input_path)
        print_parse_diags(diags: parse_diags, format)
        let n_parse_diags = list.length(xs: parse_diags)
        if n_parse_diags > 0 then
          match format do
            | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
            | FormatText -> ()
          end
          raise ParseErrorsCollected(count: n_parse_diags)
        end
        let HirBuildResult(program: hir_raw, import_cache: _) = build_hir(prog, source_file: input_path, verbose)
        // Skip the build-pipeline's reachability DCE pass: dumping types for a
        // library file (no `main`) would otherwise collapse to "0 bindings"
        // because `iterative_resolve` filters by reachability from `main`.
        // Mirrors the LSP diagnostics pipeline (src/lsp/diagnostics_pipeline.nx)
        // which calls `resolve_all_lazy_no_filter` so every loaded def is
        // typechecked regardless of call-graph membership.
        let hir_resolved = match hir_raw do
          | HirProgram(ports: hp, functions: hf, externals: he, handler_bindings: hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds) ->
            let resolved = resolve_all_lazy_no_filter(funcs: hf)
            let expanded_fs = hir.expand_groups_in_functions(funcs: resolved, groups: heg)
            let expanded_hb = hir.expand_groups_in_handler_bindings(bindings: hb, groups: heg)
            HirProgram(ports: hp, functions: expanded_fs, externals: he, handler_bindings: expanded_hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds)
        end
        // Run the same linearity + typecheck the build path does so the dump
        // reflects a fully validated HIR. require_main: false allows library
        // files without `main` to be queried for type info.
        let hir_wrapped = main_wrap.wrap_main_if_needed(prog: hir_resolved)
        linearity.check_program(prog: hir_wrapped)
        let local_names = main_wrap.user_main_name() :: extract_function_names(defs: get_defs(prog), source: input_path)
        let hir_checked = tc.check_program(hir: hir_wrapped, local_names, require_main: false)
        let out = match format do
          | FormatText -> types_to_text(prog, hir: hir_checked, scope)
          | FormatJson -> types_to_json(prog, hir: hir_checked, scope)
        end
        Console.println(val: out)
        return 0
    end
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

// ─── `nexus caps` subcommand (nexus-8fzi) ─────────────────────────────────
//
// Resolves <symbol> in <input.nx> and prints the transitive capability
// closure as text or JSON. Pipeline shape mirrors run_types_dump_subcommand
// (parse + HIR build + resolve_all_lazy_no_filter, no codegen) because the
// closure walk consumes the same fully-resolved HIR. linearity / typecheck
// are intentionally skipped: the cap walk reads name strings + the external
// table, neither of which the later passes refine, and skipping them keeps
// caps cheap to run as a pre-flight before an edit.
//
// Exit codes track caps_subspec(): 0 on success, 1 on symbol-not-found
// (the JSON path still emits a parseable found:false envelope so machine
// consumers don't have to inspect stderr).

// Shared HIR build helper for `nexus caps`. Mirrors the pipeline shape of
// run_types_dump_subcommand: parse → build_hir → resolve_all_lazy_no_filter
// → expand_groups (functions + handler bindings). The closure walk consumes
// fully-resolved HIR but never typecheck/linearity, because caps only reads
// names + the external table.
let build_hir_for_caps = fn (src: string, label_path: string, verbose: bool, format: ExplainFormat) -> HirProgram require { Console, Fs } throws { Exn } do
  let tokens = lexer.tokenize(src)
  let ParseDiagnostics(prog, diags: parse_diags) = parser.parse_collect(tokens, file: label_path)
  print_parse_diags(diags: parse_diags, format)
  let n_parse_diags = list.length(xs: parse_diags)
  if n_parse_diags > 0 then
    match format do
      | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
      | FormatText -> ()
    end
    raise ParseErrorsCollected(count: n_parse_diags)
  end
  let HirBuildResult(program: hir_raw, import_cache: _) = build_hir(prog, source_file: label_path, verbose)
  match hir_raw do
    | HirProgram(ports: hp, functions: hf, externals: he, handler_bindings: hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds) ->
      let resolved = resolve_all_lazy_no_filter(funcs: hf)
      let expanded_fs = hir.expand_groups_in_functions(funcs: resolved, groups: heg)
      let expanded_hb = hir.expand_groups_in_handler_bindings(bindings: hb, groups: heg)
      return HirProgram(ports: hp, functions: expanded_fs, externals: he, handler_bindings: expanded_hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds)
  end
end

// Manual flag extraction (nexus-2v8n). The caps subcommand has already been
// stripped by strip_caps_subcommand, so `args` is whatever the user typed
// *after* `caps`. We accept either form:
//   --diff <rev>          user-facing form; the polyglot launcher pre-runs
//                         `git show <rev>:<file>` and rewrites this to
//                         --diff-base <tmp>, because Proc.exec is a -1-stub
//                         under WASI preview1 (the wasm payload's runtime).
//   --diff-base <path>    in-wasm form; pre-fetched base source on disk.
//                         The flag is accepted directly so callers without
//                         a git working copy (CI artifacts, dirty trees) can
//                         still drive the diff against an arbitrary baseline.
// Flags can appear anywhere in the tail; positional args are preserved in
// input order.
type CapsDiffFlag = CapsDiffFlag(rev: Option<string>, base_path: Option<string>, rest: [string])

let extract_diff_flag_go = fn (args: [string], acc_rev: Option<string>, acc_base: Option<string>, acc_rest: [string]) -> CapsDiffFlag throws { Exn } do
  match args do
    | [] -> return CapsDiffFlag(rev: acc_rev, base_path: acc_base, rest: list.reverse(xs: acc_rest))
    | a :: rest ->
      if a == "--diff" then
        match rest do
          | [] -> raise InvalidUsage(detail: "--diff requires a git revision (e.g., --diff HEAD~1)")
          | rev :: tail -> return extract_diff_flag_go(args: tail, acc_rev: Some(val: rev), acc_base, acc_rest)
        end
      end
      if a == "--diff-base" then
        match rest do
          | [] -> raise InvalidUsage(detail: "--diff-base requires a path to the base source")
          | bp :: tail -> return extract_diff_flag_go(args: tail, acc_rev, acc_base: Some(val: bp), acc_rest)
        end
      end
      return extract_diff_flag_go(args: rest, acc_rev, acc_base, acc_rest: a :: acc_rest)
  end
end

let extract_diff_flag = fn (args: [string]) -> CapsDiffFlag throws { Exn } do
  return extract_diff_flag_go(args, acc_rev: None, acc_base: None, acc_rest: [])
end

let run_caps_dump_subcommand = fn (args: [string], format: ExplainFormat, verbose: bool) -> i64 require { Clock, Console, Fs } do
  try
    let CapsDiffFlag(rev: rev_opt, base_path: base_opt, rest: pos_args) = extract_diff_flag(args)
    // --diff is the user-facing form but the in-wasm path can't run git
    // (preview1 has no subprocess); the polyglot launcher must intercept
    // and convert --diff <rev> into --diff-base <tmp>. If we still see
    // --diff at this point, the user invoked the wasm payload directly.
    if let Some(val: rev_str) = rev_opt then
      if let None = base_opt then
        raise InvalidUsage(detail: "--diff " ++ rev_str ++ ": in-wasm `nexus caps` cannot run `git show` under preview1. Invoke via the polyglot launcher (./nexus), which intercepts --diff and prefetches the base revision.")
      end
    end
    match pos_args do
      | [] -> raise InvalidUsage(detail: "usage: nexus caps <symbol> <input.nx> [--format=text|json] [--diff <rev>]")
      | _ :: [] -> raise InvalidUsage(detail: "usage: nexus caps <symbol> <input.nx> [--format=text|json] [--diff <rev>]")
      | symbol :: input_path :: _ ->
        let src = Fs.read_to_string(path: input_path)
        let hir_resolved = build_hir_for_caps(src, label_path: input_path, verbose, format)
        let found = caps_symbol_exists_impl(prog: hir_resolved, symbol)
        match base_opt do
          | None ->
            let out = match format do
              | FormatText -> caps_to_text(prog: hir_resolved, symbol)
              | FormatJson -> caps_to_json(prog: hir_resolved, symbol)
            end
            Console.println(val: out)
            if found then return 0 else return 1 end
          | Some(val: base_path) ->
            // Two-pass: replay the same pipeline against the base revision's
            // source. The base file path is supplied by the polyglot
            // launcher (or by the user directly with --diff-base), so the
            // in-wasm side only needs Fs.read_to_string + the standard
            // build_hir_for_caps pipeline.
            let base_src = Fs.read_to_string(path: base_path)
            let hir_base = build_hir_for_caps(src: base_src, label_path: base_path, verbose, format)
            let found_base = caps_symbol_exists_impl(prog: hir_base, symbol)
            // Symbol missing on either side: report the diff anyway against
            // an empty list. A new symbol (absent in base) reads as "all
            // caps added" which is the correct widening semantics; a removed
            // symbol reads as "all caps removed" (narrowing).
            let base_caps = if found_base then caps_closure_capabilities(cl: caps_compute_closure(prog: hir_base, symbol)) else [] end
            let current_caps = if found then caps_closure_capabilities(cl: caps_compute_closure(prog: hir_resolved, symbol)) else [] end
            let d = compute_caps_diff(symbol, base: base_caps, current: current_caps)
            let out = match format do
              | FormatText -> caps_diff_to_text(d)
              | FormatJson -> caps_diff_to_json(d)
            end
            Console.println(val: out)
            // Exit code: 0 = no widening, 1 = widening present. Errors
            // (parse failure, git failure) take the catch arm and also
            // yield 1 (we don't distinguish error from widening to keep
            // the CI contract simple: zero exit iff caps unchanged or
            // narrowed).
            if diff_is_widening(d) then return 1 else return 0 end
        end
    end
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

// ─── `nexus fix` subcommand (nexus-rwoj) ──────────────────────────────────
//
// Runs the front-end pipeline against each file, catches the first
// fix-able diagnostic (LazyBindingUnused / LinearUnused), and either
// reports the suggested rewrite (--check), rewrites the file in place
// looping until no further fix-its appear (--write), or prints a
// before/after view (--diff). Pipeline shape mirrors run_types_dump_subcommand
// but without the render step — we only care whether the pipeline raised.
//
// Iteration cap: under --write we run at most `fix_max_passes` passes per
// file to guarantee termination even if a future fix-it generator emits
// a no-op rewrite (which would otherwise loop forever).

let fix_max_passes = fn () -> i64 do return 32 end

/** Outcome of one front-end pass against `src`. We can't return an
 *  Exn through Option (the typer can't carry the open exception row as a
 *  generic-arg payload), so we model the success/failure axis with our
 *  own variant and stash the rewrite eagerly during the catch arm. */
type FixOutcome = FixOk | FixSkipped(message: string) | FixApplied(src: string, sp: Span, fix: Fixit)

// Run parse + HIR + linearity + typecheck against `src` (no codegen).
// On success: FixOk. On a fix-able diagnostic: FixApplied(new_src,...).
// On any other diagnostic: FixSkipped(formatted message).
//
// The mode-aware "what to print / whether to write" decision lives in
// fix_loop; this helper is concerned only with classifying the outcome
// of the front-end against the supplied source text.
let typecheck_for_fix = fn (src: string, input_path: string, verbose: bool) -> FixOutcome require { Console, Fs } do
  try
    let tokens = lexer.tokenize(src)
    let ParseDiagnostics(prog: prog, diags: parse_diags) = parser.parse_collect(tokens, file: input_path)
    let n_parse_diags = list.length(xs: parse_diags)
    if n_parse_diags > 0 then
      raise ParseErrorsCollected(count: n_parse_diags)
    end
    let HirBuildResult(program: hir_raw, import_cache: _) = build_hir(prog, source_file: input_path, verbose)
    let hir_resolved = match hir_raw do
      | HirProgram(ports: hp, functions: hf, externals: he, handler_bindings: hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds) ->
        let resolved = resolve_all_lazy_no_filter(funcs: hf)
        let expanded_fs = hir.expand_groups_in_functions(funcs: resolved, groups: heg)
        let expanded_hb = hir.expand_groups_in_handler_bindings(bindings: hb, groups: heg)
        HirProgram(ports: hp, functions: expanded_fs, externals: he, handler_bindings: expanded_hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds)
    end
    let hir_wrapped = main_wrap.wrap_main_if_needed(prog: hir_resolved)
    linearity.check_program(prog: hir_wrapped)
    let local_names = main_wrap.user_main_name() :: extract_function_names(defs: get_defs(prog), source: input_path)
    let hir_checked = tc.check_program(hir: hir_wrapped, local_names, require_main: false)
    // tc_linearity is the typecheck-phase linearity pass (separate from
    // src/ir/linearity.nx above). LinearUnused / LinearReuse / LinearMismatch
    // raise here — the variants we know how to fix. The main build path runs
    // both, so we mirror it.
    tc_linearity.check_program(prog: hir_checked)
    return FixOk
  catch e ->
    match e do
      | LazyBindingUnused(name: _, span: sp) ->
        match fixit_for_exn(src, err: e) do
          | Some(val: fix) -> return FixApplied(src, sp, fix)
          | None -> return FixSkipped(message: err.format_error(err: e))
        end
      | LinearUnused(name: _, span: sp) ->
        match fixit_for_exn(src, err: e) do
          | Some(val: fix) -> return FixApplied(src, sp, fix)
          | None -> return FixSkipped(message: err.format_error(err: e))
        end
      | _ -> return FixSkipped(message: err.format_error(err: e))
    end
  end
end

// Per-file driver. Under --write the loop reruns the pipeline against the
// rewritten text until no fix-it appears or the iteration cap fires.
// --check / --diff terminate after the first fix-it (they don't mutate).
let run_fix_on_file = fn (path: string, mode: FixMode, verbose: bool) -> i64 require { Clock, Console, Fs } do
  if Fs.exists(path) == false then
    Console.eprintln(val: "nexus fix: file not found: " ++ path)
    return 1
  end
  try
    let initial_src = Fs.read_to_string(path)
    return fix_loop(path, src: initial_src, mode, verbose, pass: 0, fixes_applied: 0)
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

let fix_loop = fn (path: string, src: string, mode: FixMode, verbose: bool, pass: i64, fixes_applied: i64) -> i64 require { Clock, Console, Fs } do
  if pass >= fix_max_passes() then
    Console.eprintln(val: "nexus fix: iteration cap reached for " ++ path ++ "; remaining fix-its skipped")
    return 0
  end
  let outcome = typecheck_for_fix(src, input_path: path, verbose)
  match outcome do
    | FixOk ->
      return 0
    | FixSkipped(message) ->
      Console.eprintln(val: message)
      if fixes_applied > 0 then return 0 end
      return 1
    | FixApplied(src: _orig_src, sp, fix) ->
      match mode do
        | ModeCheck ->
          Console.println(val: format_check_line(file: path, sp, fix))
          return 0
        | ModeDiff ->
          let old_text = slice_old_text(src, fix)
          Console.println(val: format_diff_block(file: path, fix, old_text))
          return 0
        | ModeWrite ->
          let src2 = apply_fixit(src, fix)
          if src2 == src then
            Console.eprintln(val: "nexus fix: rewrite was a no-op for " ++ path ++ " at pass " ++ str.from_i64(val: pass))
            return 0
          end
          Fs.write_string(path, content: src2)
          Console.println(val: format_check_line(file: path, sp, fix))
          return fix_loop(path, src: src2, mode, verbose, pass: pass + 1, fixes_applied: fixes_applied + 1)
      end
  end
end

let run_fix_subcommand = fn (args: [string]) -> i64 require { Clock, Console, Fs } throws { InvalidUsage } do
  // --help short-circuits before argparse so the user can self-discover
  // the flag set even before nexus-z35v's per-sub help router lands.
  if contains_help_flag(args) then
    Console.println(val: fix_usage())
    return 0
  end
  let opts = parse_fix_options(args)
  match opts do | FixOptions(mode, paths) ->
    if list.length(xs: paths) == 0 then
      Console.eprintln(val: fix_usage())
      return 2
    end
    return run_fix_each(paths, mode, all_ok: true)
  end
end

let contains_help_flag = fn (args: [string]) -> bool do
  match args do
    | [] -> return false
    | a :: rest ->
      if a == "--help" || a == "-h" then return true end
      return contains_help_flag(args: rest)
  end
end

let run_fix_each = fn (paths: [string], mode: FixMode, all_ok: bool) -> i64 require { Clock, Console, Fs } do
  match paths do
    | [] ->
      if all_ok then return 0 else return 1 end
    | p :: rest ->
      let rc = run_fix_on_file(path: p, mode, verbose: false)
      let ok2 = all_ok && (rc == 0)
      return run_fix_each(paths: rest, mode, all_ok: ok2)
  end
end

let main = fn (args: [string]) -> unit require { PermClock, PermConsole, PermFs, PermProc } do
  inject stdio.system_handler, fs_mod.system_handler, clock_mod.system_handler, proc.system_handler do
  try
    // help / --help / -h short-circuits before any other parsing.
    // `nexus help [sub]` (nexus-npo6) and `nexus <sub> --help`
    // (nexus-z35v) are unified here: when a subcommand name is paired
    // with help (in either direction), look it up in
    // `subcommand_specs()` and emit the structured per-sub help. With
    // only the help token (`nexus help`, `nexus --help`, `nexus -h`),
    // fall back to the top-level overview.
    // `--help`/`-h` retain the print-and-exit-0 contract.
    // No-args (`nexus` alone) is unified onto the same path as `nexus
    // help`: stdout + exit 0 (issue nexus-8s1l). The legacy E4002 raise
    // is gone; explicit error-via-no-args is no longer worth the DX
    // cost (git/cargo/go all print help here).
    // (Levenshtein-based did-you-mean is deferred until nexus-rxpz —
    // adding reachable arity-2+ helpers here trips that codegen bug.)
    if try_dispatch_help(args) then proc.exit(status: 0) end
    match args do
      | _ :: tok :: _ ->
        if tok == "help" || tok == "--help" || tok == "-h" then
          print_usage()
          proc.exit(status: 0)
        end
      | _ -> ()
    end
    if list.length(xs: args) < 2 then
      print_usage()
      proc.exit(status: 0)
    end
    // `repl` / `mcp` are no-input subcommands; intercept them before the
    // global-flag parser (which assumes an input-file pipeline) so they
    // run cleanly with no other arguments. Same for `explain` and
    // `context`: those owned their own --file / --format parsing under
    // `*_subcommand_args` (issue nexus-cgfd).
    match detect_subcommand(args, kw: "repl") do | SubcommandHit(present: p_repl, _) ->
      if p_repl then
        repl_mod.run(max_iters: -1)
        return ()
      end
    end
    match detect_subcommand(args, kw: "mcp") do | SubcommandHit(present: p_mcp, _) ->
      if p_mcp then
        mcp_mod.run_mcp_server(max_iters: -1)
        return ()
      end
    end
    match explain_mod.strip_explain_subcommand(xs: args) do | ParsedExplainSubcommand(remaining: args_after_explain_sub, is_explain) ->
      if is_explain then
        let explain_args = match args_after_explain_sub do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = explain_mod.run_explain_subcommand(args: explain_args)
        proc.exit(status: exit_code)
      end
    end
    match context_mod.strip_context_subcommand(xs: args) do | ParsedContextSubcommand(remaining: args_after_context_sub, is_context) ->
      if is_context then
        let context_args = match args_after_context_sub do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = context_mod.run_context_subcommand(args: context_args)
        proc.exit(status: exit_code)
      end
    end
    // All driver-global flags are now resolved in one argparse pass
    // (issue nexus-8vu5). What used to be six chained strip_* helpers
    // (verbose / output / format / explain-flags / coverage / polyglot)
    // is one declarative spec table + one `parse` call.
    let gf = parse_global_args(args)
    let GlobalFlags(positionals, remaining: args_after_run, verbose, output: opt_output, diag_format, explain, explain_format: format, coverage: coverage_enabled, output_mode, manifest_mode, dump_imports: dump_imports_flag) = gf
    let polyglot_mode = if let PolyglotLauncher = output_mode then true else false end
    let remain_manifest = if let KeepManifest = manifest_mode then true else false end
    // `nexus test [path] [flags]` short-circuits before MIR/codegen because
    // the test runner spawns the host nexus binary itself, not the in-process
    // pipeline.
    match strip_test_subcommand(xs: positionals) do | ParsedTestSubcommand(remaining: args_after_test, is_test) ->
      if is_test then
        let test_args = match args_after_test do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_test_subcommand(args: test_args)
        proc.exit(status: exit_code)
      end
    end
    // `nexus fmt [--check] FILE...` short-circuits before MIR/codegen.
    match strip_fmt_subcommand(xs: positionals) do | ParsedFmtSubcommand(remaining: args_after_fmt, is_fmt) ->
      if is_fmt then
        let fmt_args = match args_after_fmt do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_fmt_subcommand(args: fmt_args)
        proc.exit(status: exit_code)
      end
    end
    // `nexus grep <pattern> [path...]` (issue nexus-a02c V1).
    match strip_grep_subcommand(xs: positionals) do | ParsedGrepSubcommand(remaining: args_after_grep, is_grep) ->
      if is_grep then
        let grep_args = match args_after_grep do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_grep_subcommand(args: grep_args)
        proc.exit(status: exit_code)
      end
    end
    match strip_lint_subcommand(xs: positionals) do | ParsedLintSubcommand(remaining: args_after_lint, is_lint) ->
      if is_lint then
        let lint_args = match args_after_lint do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_lint_subcommand(args: lint_args)
        proc.exit(status: exit_code)
      end
    end
    match strip_fix_subcommand(xs: positionals) do | ParsedFixSubcommand(remaining: args_after_fix, is_fix) ->
      if is_fix then
        let fix_args = match args_after_fix do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_fix_subcommand(args: fix_args)
        proc.exit(status: exit_code)
      end
    end
    // `nexus skill --emit` (issue nexus-9j8x). Auto-regenerate the CLI
    // reference markdown from `subcommand_specs()` + `global_help_specs()`.
    // Front-end-only — no input file, no codegen.
    match strip_skill_subcommand(xs: positionals) do | ParsedSkillSubcommand(remaining: args_after_skill, is_skill) ->
      if is_skill then
        let skill_args = match args_after_skill do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_skill_subcommand(args: skill_args, global_specs: global_help_specs(), sub_specs: subcommand_specs())
        proc.exit(status: exit_code)
      end
    end
    // `nexus ast <input.nx>` (issue nexus-qqvz). Front-end-only dump.
    match strip_ast_subcommand(xs: positionals) do | ParsedAstSubcommand(remaining: args_after_ast, is_ast) ->
      if is_ast then
        let ast_args = match args_after_ast do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_ast_dump_subcommand(args: ast_args, format: diag_format, verbose)
        proc.exit(status: exit_code)
      end
    end
    // `nexus hir <input.nx>` / `nexus lir <input.nx>` / `nexus types <input.nx>`
    // short-circuit before typecheck/MIR/codegen.
    match strip_hir_subcommand(xs: positionals) do | ParsedHirSubcommand(remaining: args_after_hir, is_hir) ->
      if is_hir then
        let hir_args = match args_after_hir do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_hir_dump_subcommand(args: hir_args, format: diag_format, verbose)
        proc.exit(status: exit_code)
      end
    end
    match strip_lir_subcommand(xs: positionals) do | ParsedLirSubcommand(remaining: args_after_lir, is_lir) ->
      if is_lir then
        let lir_args = match args_after_lir do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_lir_dump_subcommand(args: lir_args, format: diag_format, verbose)
        proc.exit(status: exit_code)
      end
    end
    match strip_types_subcommand(xs: positionals) do | ParsedTypesSubcommand(remaining: args_after_types, is_types) ->
      if is_types then
        let types_args = match args_after_types do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_types_dump_subcommand(args: types_args, format: diag_format, verbose)
        proc.exit(status: exit_code)
      end
    end
    // `nexus caps <symbol> <input.nx>` (issue nexus-8fzi). Capability closure dump.
    match strip_caps_subcommand(xs: positionals) do | ParsedCapsSubcommand(remaining: args_after_caps, is_caps) ->
      if is_caps then
        let caps_args = match args_after_caps do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_caps_dump_subcommand(args: caps_args, format: diag_format, verbose)
        proc.exit(status: exit_code)
      end
    end
    // typecheck / run / build are all build-pipeline routes. The argparse
    // pass already consumed every global flag; what remains in `positionals`
    // is `[prog, subcommand_keyword, input.nx, ...]`. `run` forwards every
    // post-`--` token to the built program via gf.remaining (issue nexus-tr79).
    let tc_hit = detect_subcommand(args: positionals, kw: "typecheck")
    let SubcommandHit(present: typecheck_only, remaining: positionals_after_tc) = tc_hit
    let run_hit = detect_subcommand(args: positionals_after_tc, kw: "run")
    let SubcommandHit(present: run_mode, remaining: positionals_after_run) = run_hit
    let run_args = args_after_run
    if run_mode && typecheck_only then
      raise InvalidUsage(detail: "`run` is incompatible with `typecheck`")
    end
    if remain_manifest && !polyglot_mode then
      raise InvalidUsage(detail: "--remain-manifest requires --polyglot")
    end
    if polyglot_mode && typecheck_only then
      raise InvalidUsage(detail: "--polyglot is incompatible with `typecheck`")
    end
    if polyglot_mode && run_mode then
      raise InvalidUsage(detail: "--polyglot is incompatible with `run`")
    end
    // When `typecheck` or `run` has already been stripped, args lack `build` by design.
    // Otherwise require a `build` subcommand for symmetry with `repl`/`typecheck`/`test`
    // (the bare `nexus foo.nx` form is rejected). `--dump-imports` is a subcommand-
    // shaped global flag handled downstream so it bypasses the requirement.
    let clean_args = if typecheck_only || run_mode || dump_imports_flag then positionals_after_run
      else
        let bld_hit = detect_subcommand(args: positionals_after_run, kw: "build")
        match bld_hit do | SubcommandHit(present: has_build, remaining: positionals_after_build) ->
          if !has_build then
            raise InvalidUsage(detail: "missing subcommand: did you mean 'build'?")
          end
          positionals_after_build
        end
      end
    // Override output to a side-by-side temp wasm when running. We avoid TMPDIR
    // (would require PermEnv) and `Fs` is already on the driver's cap list, so
    // a cwd-relative path needs no extra `--dir` mount.
    let run_output_path = "./.nexus-run.wasm"
    let argc = list.length(xs: clean_args)
    if dump_imports_flag then
      if argc < 2 then
        raise InvalidUsage(detail: "usage: nexus --dump-imports <input.nx>")
      end
      dump_import_graph(input_path: str_nth(xs: clean_args, n: 1))
      return ()
    end
    if argc < 2 then
      // Error path: render usage onto stderr (print_usage helper now
      // targets stdout per nexus-8s1l).
      Console.eprintln(val: render_subcommand_overview(
        summary: "Usage: nexus <subcommand> [options] <args>",
        subs: subcommand_specs(),
        globals: global_help_flag_specs()
      ))
      raise InvalidUsage(detail: "missing input file argument")
    end

    let input_path = str_nth(xs: clean_args, n: 1)
    let output_path = if run_mode then run_output_path else resolve_output_path(opt_output, xs: clean_args, argc) end

    if verbose then
      if typecheck_only then
        Console.eprintln(val: "nexus: typechecking " ++ input_path)
      else
        Console.eprintln(val: "nexus: compiling " ++ input_path ++ " -> " ++ output_path)
      end
    end

    // Nested try wraps pipeline errors with the target file name so the final
    // diagnostic reads "<root>: in imported module '<x>': <error>".
    try
    let t0 = Clock.now()
    let src = Fs.read_to_string(path: input_path)
    let t1 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] read source (" ++ str.from_i64(val: t1 - t0) ++ "ms)") end

    // Mark heap before compilation pipeline. All IR data allocated below
    // can be freed after codegen completes (ByteBuffer is host-managed).
    let pipeline_mark = arena.heap_mark()

    let tokens = lexer.tokenize(src)
    let t2 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] lex (" ++ str.from_i64(val: t2 - t1) ++ "ms)") end

    // Use multi-error parse: collect every parse failure in the file
    // instead of aborting on the first one (issue nexus-in6i). On any
    // diagnostic, dump every (now-structured, issue nexus-kmel)
    // CompilerDiagnostic to stderr and raise a single summary exception so the
    // standard error-handling path runs. The `--format=json` path also
    // emits an NDJSON summary-trailer line before the raise.
    let ParseDiagnostics(prog: prog, diags: parse_diags) = parser.parse_collect(tokens, file: input_path)
    print_parse_diags(diags: parse_diags, format: diag_format)
    let n_parse_diags = list.length(xs: parse_diags)
    if n_parse_diags > 0 then
      match diag_format do
        | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
        | FormatText -> ()
      end
      raise ParseErrorsCollected(count: n_parse_diags)
    end
    let t3 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] parse (" ++ str.from_i64(val: t3 - t2) ++ "ms)") end

    let hir_result = build_hir(prog, source_file: input_path, verbose)
    let HirBuildResult(program: hir_raw, import_cache: _) = hir_result
    let t4 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] HIR (" ++ str.from_i64(val: t4 - t3) ++ "ms)") end

    // Pre-DCE introduction-site wfCap/wfThrow (nexus-t9cl.24/.25). Must run
    // BEFORE iterative_resolve/reachability filtering: the spec rationale
    // (type-system-formal.md §1 line 112) explicitly mentions that a typo'd
    // capability would otherwise "surface only at a use site that happens
    // to look it up — and may never if the cap is unused". DCE drops
    // unused functions before typecheck, so without a pre-DCE pass the
    // typo would silently escape on any dead-code introduction site.
    tcwf.check_program_wf_rows(prog: hir_raw)

    // Iterative resolve: filter by reachability, resolve, repeat until stable.
    // After LazyBody resolution we re-run exception-group expansion: the first
    // pass in accum_to_program only saw stub bodies, so catch arms inside
    // newly-resolved bodies still reference raw group names (nexus-vks5).
    let hir_resolved = match hir_raw do
      | HirProgram(ports: hp, functions: hf, externals: he, handler_bindings: hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds) ->
        let resolved = iterative_resolve(funcs: hf, hb, max_rounds: 100)
        let expanded_fs = hir.expand_groups_in_functions(funcs: resolved, groups: heg)
        let expanded_hb = hir.expand_groups_in_handler_bindings(bindings: hb, groups: heg)
        // Post-DCE pass (issue nexus-g6qr). `iterative_resolve` always seeds
        // `wasi_thread_start` so the lazy-runtime callback survives normal
        // reachability. But fixtures that merely `import std:lazy` without
        // invoking `lazy.spawn` need none of that runtime — and leaving
        // `lazy_run_task` in the program emits a `call_indirect (table 0)`
        // against a closure table that codegen never built. Re-run
        // reachability without the thread-start seed: if `lazy_spawn` is in
        // the result, the program really uses parallel forces and we keep
        // the original (already-seeded) set; otherwise we replace it with
        // the trimmed set so DCE pulls `wasi_thread_start` and friends.
        let trimmed_reach = reach.collect_reachable_no_thread_start(functions: expanded_fs, handler_bindings: expanded_hb)
        let final_fs = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then expanded_fs
          else reach.filter_reachable_functions(functions: expanded_fs, reachable: trimmed_reach)
        end
        let final_reach = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then
            reach.collect_reachable(functions: final_fs, handler_bindings: expanded_hb)
          else trimmed_reach
        end
        let filtered_exts = reach.filter_reachable_externals(externals: he, reachable: final_reach)
        HirProgram(ports: hp, functions: final_fs, externals: filtered_exts, handler_bindings: expanded_hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds)
    end
    let t4b = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] resolve (" ++ str.from_i64(val: t4b - t4) ++ "ms)") end

    // Synthesise a top-level catch-all wrapper for `main` if its declared
    // throws-row is non-empty (issue nexus-urf5). The wrapper renames the
    // user's main to `__nx_user_main` and forwards through a try/catch that
    // prints the variant + backtrace and exits non-zero. No-op otherwise.
    let hir = main_wrap.wrap_main_if_needed(prog: hir_resolved)

    linearity.check_program(prog: hir)
    let t4c = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] linearity (" ++ str.from_i64(val: t4c - t4b) ++ "ms)") end

    // Extract enum_defs, type_defs and local_names eagerly so hir/prog can die after typecheck.
    // This removes cross-phase references that would prevent future region resets.
    let enum_defs = get_enum_defs(hir)
    let type_defs = get_type_defs(hir)
    // Append `__nx_user_main` to the typecheck allow-list. When `main` declared
    // a non-empty throws-row, main_wrap.wrap_main_if_needed renamed it to
    // `__nx_user_main` and synthesised a fresh wrapper `main`. The user's
    // original main body now lives under the renamed function — but
    // extract_function_names builds local_names from the *pre-wrap* AST, so
    // the renamed body would be absent from the allow-list and
    // check_all_functions would skip it (issue nexus-1eta). Adding the name
    // unconditionally is harmless when the wrap was a no-op: the function
    // simply isn't in the HIR and check_all_functions never visits it.
    //
    // `extract_function_names` produces canonical names matching how
    // `process_top_level` in src/ir/hir/hir.nx renames each entry-file def
    // (issue nexus-rfh1). Without canonicalisation, bare AST names would
    // never match the qualified HIR names and every non-main entry-file
    // function body would silently bypass typecheck.
    let local_names = main_wrap.user_main_name() :: extract_function_names(defs: get_defs(prog), source: input_path)
    let hir_checked = tc.check_program(hir, local_names, require_main: !typecheck_only)
    let t5 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] typecheck (" ++ str.from_i64(val: t5 - t4c) ++ "ms)") end

    // %T linear lint pass (issue nexus-7eex.3): runs after typecheck so the
    // sig-map sees post-resolution function signatures. Enforces linear
    // use-once, branch consistency, throwable-call leak from issue
    // nexus-7eex.2, and Strategy A try-catch from issue nexus-7eex.1.
    tc_linearity.check_program(prog: hir_checked)
    let t5b = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] tc-linearity (" ++ str.from_i64(val: t5b - t5) ++ "ms)") end
    // After this point: prog, hir, local_names are dead.
    // hir_checked and enum_defs are the only live compiler data.

    // typecheck-only mode: skip MIR/LIR/codegen/write entirely. The full
    // typecheck (including tc-linearity) has already run and any error has
    // raised through the catch handlers below.
    if typecheck_only then
      if verbose then
        Console.eprintln(val: "nexus: typecheck-only " ++ input_path ++ " (total " ++ str.from_i64(val: t5b - t0) ++ "ms)")
      end
      arena.heap_reset(mark: pipeline_mark)
      return ()
    end

    let mir = mir.lower_hir_to_mir(hir: hir_checked)
    let t6 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] MIR (" ++ str.from_i64(val: t6 - t5) ++ "ms)") end
    // hir_checked is dead; mir and enum_defs are live.

    let lir = lir.lower_mir_to_lir(mir: mir, enum_defs: enum_defs, type_defs: type_defs)
    let t7 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] LIR (" ++ str.from_i64(val: t7 - t6) ++ "ms)") end
    // mir and enum_defs are dead; lir is live.

    // Per-function effect summary (issue nexus-j5zi) runs on the un-optimised
    // LIR so its results are available to effect-gated rewrites in optimize.
    // The build/foldr stream fusion (issue nexus-00lw) consults this map to
    // gate fusion on combining-function purity. Recomputing after optimise
    // is unnecessary because optimise preserves the call graph.
    let %effect_map = effect_analysis.analyze_effects(program: lir)
    let t7b = Clock.now()
    if verbose then
      Console.eprintln(val: "[nexus] effect-analysis ("
        ++ str.from_i64(val: t7b - t7) ++ "ms, "
        ++ str.from_i64(val: emap.effect_map_size(em: &effect_map)) ++ " functions)")
      // Per-class breakdown (issue nexus-kyf8): partitions every function
      // summary into pure / can_throw / impure-no-throw so the elision
      // measurement below has a denominator.
      let EffectClassCounts(pure, can_throw, impure_no_throw, total) = emap.classify_effect_map(em: &effect_map)
      Console.eprintln(val: "[nexus] effect-summary: "
        ++ str.from_i64(val: pure) ++ " pure, "
        ++ str.from_i64(val: can_throw) ++ " throw, "
        ++ str.from_i64(val: impure_no_throw) ++ " impure ("
        ++ str.from_i64(val: total) ++ " total)")
    end

    let lir_opt = lir_opt.optimize_lir_with_effects(program: lir, effects: &effect_map)
    let t8 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] optimize (" ++ str.from_i64(val: t8 - t7b) ++ "ms)") end

    // Backtrace-elision metric (issue nexus-kyf8): walk lir_opt (the
    // program codegen actually consumes) and count LirExprRaise sites,
    // mirroring codegen.resolve_bt_capture_for_func to classify each as
    // emitted (enclosing function may throw) or elided (cannot throw).
    if verbose then
      let RaiseSiteCounts(emitted: bt_emit, elided: bt_skip, total: bt_total) =
        effect_analysis.count_raise_sites(program: lir_opt, em: &effect_map)
      let pct = compute_elision_pct(skip: bt_skip, total: bt_total)
      Console.eprintln(val: "[nexus] backtrace: "
        ++ str.from_i64(val: bt_emit) ++ " capture-call sites emitted, "
        ++ str.from_i64(val: bt_skip) ++ " skipped ("
        ++ str.from_i64(val: pct) ++ "% elision)")
    end

    // Memoisation eligibility plan (issue nexus-e6uh): identify pure
    // functions whose call sites are eligible for argument-keyed result
    // caching. Stand-alone for now — the codegen consumer (call-site
    // emission) is tracked as a separate milestone; this pass just builds
    // and reports the plan.
    let memo = memo_plan.plan_memoization(program: lir_opt, em: &effect_map)
    let t8c = Clock.now()
    if verbose then
      Console.eprintln(val: "[nexus] memo-plan ("
        ++ str.from_i64(val: t8c - t8) ++ "ms, "
        ++ str.from_i64(val: memo_plan.memo_plan_size(plan: memo)) ++ " eligible)")
    end

    // String data starts at offset 32. The reserved low memory [0,32) holds:
    //   [0,8)   the unified atomic bump-pointer cell (heap_ptr_cell = 0)
    //   [8,16)  std:runtime/sysio's lazy-scratch-pointer slot
    //   [16,24) std:runtime/sysio's fd->path side-table head pointer
    //   [24,32) std:env's environ-override side-table head pointer
    let str_base = 32
    let coverage_flag = if coverage_enabled then 1 else 0 end
    let %wasm_buf = codegen.compile_lir_to_wasm_with_coverage(program: lir_opt, string_data_base: str_base,
                                                  effect_map: &effect_map,
                                                  coverage_flag)
    // Codegen and metric passes have run; release the EffectMap's StringMap
    // handle now so the linear value does not outlive its usefulness.
    emap.free_effect_map(em: %effect_map)
    let t9 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] codegen (" ++ str.from_i64(val: t9 - t8c) ++ "ms)") end

    // Capabilities must be extracted before the arena reset; for the polyglot
    // emit path they are also baked into the launcher header, so the extract
    // is bracketed with `write_emit` either inline (polyglot, must precede the
    // header) or in parallel (non-polyglot, `write_emit` ignores `caps`).
    //
    // The non-polyglot branch dogfoods `std:lazy_host.host_spawn` /
    // `host_join`: `find_main_caps` is pure (no I/O, no raises) and only
    // reads the AST, which lives in the shared arena-backed heap, so it is
    // safe to force on a worker thread while the main thread runs
    // `write_emit` (file I/O, also non-raising). The two operations cannot
    // raise so the linear `%Task<T>` handle is always joined exactly once.
    let CapsWriteResult(caps: caps, ok: ok) = if polyglot_mode then
        let caps_now = find_main_caps(defs: get_defs(prog))
        let ok_now = write_emit(%wasm_buf, output_path, caps: caps_now, output: PolyglotLauncher, manifest: manifest_mode, verbose)
        CapsWriteResult(caps: caps_now, ok: ok_now)
      else
        let @caps_thunk = find_main_caps(defs: get_defs(prog))
        let caps_task = lazy_host.host_spawn(a: caps_thunk)
        let ok_par = write_emit(%wasm_buf, output_path, caps: [], output: BareBinary, manifest: manifest_mode, verbose)
        let caps_par = lazy_host.host_join(handle: caps_task)
        CapsWriteResult(caps: caps_par, ok: ok_par)
      end
    let t10 = Clock.now()

    if ok then
      if verbose then
        Console.eprintln(val: "[nexus] write (" ++ str.from_i64(val: t10 - t9) ++ "ms)")
        Console.eprintln(val: "nexus: wrote " ++ output_path ++ " (total " ++ str.from_i64(val: t10 - t0) ++ "ms)")
      end
      // `run` swallows the build-result chatter: the goal is the program's
      // output, not the compile artifact.
      if !run_mode then
        print_build_result(output_name: output_path, caps, explain, format, output: output_mode)
      end
    else
      raise WriteFailed(path: output_path)
    end

    // All IR data is now dead. ByteBuffer is host-managed (not on nexus heap).
    // Reset heap to free all compiler data structures.
    arena.heap_reset(mark: pipeline_mark)

    if run_mode then
      let exit_code = exec_run_artifact(wasm_path: output_path, source: input_path, caps, user_args: run_args, verbose)
      proc.exit(status: exit_code)
    end
    catch inner ->
      raise InTargetFile(path: input_path, detail: err.format_error(err: inner))
    end
  catch
    | InvalidUsage(detail: d) ->
      Console.eprintln(val: err.format_error(err: InvalidUsage(detail: d)))
      proc.exit(status: 2)
    | e ->
      Console.eprintln(val: err.format_error(err: e))
      proc.exit(status: 1)
  end
  end
end
