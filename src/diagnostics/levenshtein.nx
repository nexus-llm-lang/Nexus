/**
 * diagnostics/levenshtein: edit-distance helpers for "did you mean?" diagnostics.
 *
 * Provides `levenshtein_distance(a, b)` — standard Wagner-Fischer DP — and
 * `suggest_names(typo, candidates)` which returns up to 3 candidate names
 * with edit-distance ≤ 2, sorted ascending by distance then lexicographically.
 *
 * Complexity: O(|a| × |b|) per pair. Computing suggestions for a name of
 * length L against N candidates of average length M is O(N × L × M).
 */

import * as str from "std:str"

/** Build a list `[0, 1, ..., n]` (length n+1). */
let build_initial_row = fn (n: i64) -> [ i64 ] do
  return build_initial_row_go(n, i: 0, acc: [])
end

let build_initial_row_go = fn (n: i64, i: i64, acc: [ i64 ]) -> [ i64 ] do
  if i > n then return rev_i64(lst: acc, out: []) end
  return build_initial_row_go(n, i: i + 1, acc: i :: acc)
end

let rev_i64 = fn (lst: [ i64 ], out: [ i64 ]) -> [ i64 ] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_i64(lst: rest, out: x :: out)
  end
end

let i64_min3 = fn (a: i64, b: i64, c: i64) -> i64 do
  let ab = if a < b then a else b end
  return if ab < c then ab else c end
end

/** Compute one DP row for source-character index `i` (1-based).
 *  `prev` is the previous row (length n+1), `t` is the target string.
 *  Returns the new row, also length n+1.
 *
 *  We walk the previous row left-to-right, building the new row by
 *  computing each cell. `diag` tracks `prev[j-1]` (the diagonal predecessor).
 */
let compute_row = fn (s: string, i: i64, t: string, n: i64, prev: [ i64 ]) -> [ i64 ] do
  let s_ch = str.char_at(s, idx: i - 1)
  let first_cell = i
  let diag = list_nth_i64(lst: prev, n: 0)
  let prev_above = list_drop_first(prev)
  return compute_row_cols(
    t,
    n,
    j: 1,
    prev_above,
    diag,
    left: first_cell,
    acc: first_cell :: [],
    s_ch
  )
end

/** Walk columns j=1..n, building new row cells.
 *  `prev_above` is the remaining slice of prev starting at index j.
 *  `diag` is prev[j-1], `left` is new_row[j-1], `acc` accumulates new_row in reverse.
 */
let compute_row_cols = fn (
  t: string,
  n: i64,
  j: i64,
  prev_above: [ i64 ],
  diag: i64,
  left: i64,
  acc: [ i64 ],
  s_ch: char
) -> [ i64 ] do
  if j > n then return rev_i64(lst: acc, out: []) end
  let above = list_head_i64(prev_above)
  let t_ch = str.char_at(t, idx: j - 1)
  let cost = if s_ch == t_ch then 0 else 1 end
  let cell = i64_min3(a: above + 1, b: left + 1, c: diag + cost)
  return compute_row_cols(
    t,
    n,
    j: j + 1,
    prev_above: list_drop_first(prev_above),
    diag: above,
    left: cell,
    acc: cell :: acc,
    s_ch
  )
end

/** Iterate row by row. */
let levenshtein_rows = fn (s: string, m: i64, t: string, n: i64, i: i64, prev: [ i64 ]) -> i64 do
  if i > m then return list_nth_i64(lst: prev, n: n) end
  let cur = compute_row(s, i, t, n, prev)
  return levenshtein_rows(s, m, t, n, i: i + 1, prev: cur)
end

let list_head_i64 = fn (lst: [ i64 ]) -> i64 do
  match lst do
    | [] -> return 0
    | x :: _ -> return x
  end
end

let list_drop_first = fn (lst: [ i64 ]) -> [ i64 ] do
  match lst do
    | [] -> return []
    | _ :: rest -> return rest
  end
end

let list_nth_i64 = fn (lst: [ i64 ], n: i64) -> i64 do
  if n == 0 then return list_head_i64(lst) end
  return list_nth_i64(lst: list_drop_first(lst), n: n - 1)
end

/** Compute the Levenshtein edit distance between strings `a` and `b`. */
export let levenshtein_distance = fn (a: string, b: string) -> i64 do
  let m = str.length(s: a)
  let n = str.length(s: b)
  if m == 0 then return n end
  if n == 0 then return m end
  let initial = build_initial_row(n)
  return levenshtein_rows(s: a, m, t: b, n, i: 1, prev: initial)
end

/** Collect candidates with edit distance ≤ 2, capped at 3.
 *  Returns at most 3 names sorted by distance (then insertion order).
 */
export let suggest_names = fn (typo: string, candidates: [ string ]) -> [ string ] do
  return suggest_names_go(typo, candidates, acc_d1: [], acc_d2: [])
end

let suggest_names_go = fn (
  typo: string,
  candidates: [ string ],
  acc_d1: [ string ],
  acc_d2: [ string ]
) -> [ string ] do
  match candidates do
    | [] ->
      let top = take3(lst: rev_strings(lst: acc_d1, out: []))
      let need = 3 - list_length_strings(top)
      if need <= 0 then return top end
      return string_concat_take3(prefix: top, extra: rev_strings(lst: acc_d2, out: []), need)
    | c :: rest ->
      let d = levenshtein_distance(a: typo, b: c)
      if d == 0 then
        return suggest_names_go(typo, candidates: rest, acc_d1, acc_d2)
      end
      if d == 1 then
        return suggest_names_go(typo, candidates: rest, acc_d1: c :: acc_d1, acc_d2)
      end
      if d == 2 then
        return suggest_names_go(typo, candidates: rest, acc_d1, acc_d2: c :: acc_d2)
      end
      return suggest_names_go(typo, candidates: rest, acc_d1, acc_d2)
  end
end

let rev_strings = fn (lst: [ string ], out: [ string ]) -> [ string ] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_strings(lst: rest, out: x :: out)
  end
end

let list_length_strings = fn (lst: [ string ]) -> i64 do
  match lst do
    | [] -> return 0
    | _ :: rest -> return 1 + list_length_strings(lst: rest)
  end
end

let take3 = fn (lst: [ string ]) -> [ string ] do
  match lst do
    | [] -> return []
    | a :: [] -> return [a]
    | a :: b :: [] -> return [a, b]
    | a :: b :: c :: _ -> return [a, b, c]
  end
end

let string_concat_take3 = fn (prefix: [ string ], extra: [ string ], need: i64) -> [ string ] do
  if need <= 0 then return prefix end
  match extra do
    | [] -> return prefix
    | x :: rest ->
      return string_concat_take3(prefix: prefix_append(prefix, x), extra: rest, need: need - 1)
  end
end

let prefix_append = fn (lst: [ string ], x: string) -> [ string ] do
  return rev_strings(lst: x :: rev_strings(lst, out: []), out: [])
end
