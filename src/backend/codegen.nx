// ─── Memo target list extractors (nexus-e6uh) ──────────────────────────────
// CodegenCtx stores name/slot lists in parallel rather than the structured
// MemoTarget type so the per-call lookup stays a tight string compare without
// re-deconstructing a record on every call site. These extractors split the
// MemoTarget list once at module-assembly time.

let extract_memo_names = fn (targets: [MemoTarget], acc: [string]) -> [string] do
  match targets do
    | [] -> return reverse_str_list(lst: acc, out: [])
    | MemoTarget(name: n, slot: _) :: rest ->
      return extract_memo_names(targets: rest, acc: n :: acc)
  end
end

let extract_memo_slots = fn (targets: [MemoTarget], acc: [i64]) -> [i64] do
  match targets do
    | [] -> return reverse_i64_list(lst: acc, out: [])
    | MemoTarget(name: _, slot: s) :: rest ->
      return extract_memo_slots(targets: rest, acc: s :: acc)
  end
end

let reverse_str_list = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_str_list(lst: rest, out: x :: out)
  end
end

let reverse_i64_list = fn (lst: [i64], out: [i64]) -> [i64] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_i64_list(lst: rest, out: x :: out)
  end
end

// ─── Inline-emitted runtime intrinsics ──────────────────────────────────────
// All compiler intrinsics — raw memory load/store, atomic ops, f64 ops, integer
// width casts, SIMD lane ops, the bump allocator's mark/reset/swap/alloc-raw,
// and the lazy `@`-thunk type-puns — live under one wasm-module name,
// `nexus:intrinsic` (declared by the stdlib's intrinsic decl files via
// `import external "nexus:intrinsic"`). Their externals are emitted as inline
// WASM (load/store, f64 unary, etc.), never as host calls, and are filtered out
// of the import section entirely (`filter_intrinsic_externals`). Recognition,
// the import-filter test, and codegen dispatch all key on the `wasm_name`
// string (the kebab-cased FFI name, e.g. `mem-load-i32`, `heap-mark`,
// `f64-sqrt`, `force-closure`).
let is_intrinsic_external = fn (ext: LirExternal) -> bool do
  match ext do
    | LirExternal(name: _, wasm_module: m, wasm_name: _, params: _, ret_type: _, throw_row: _) ->
      return m == "nexus:intrinsic"
  end
end

/** Returns the `wasm_name` of `func` if it resolves to a `nexus:intrinsic` */
/** external, `""` otherwise. The returned string is the dispatch key consumed */
/** by `emit_intrinsic` (e.g. `"mem-load-i32"`, `"heap-mark"`, `"f64-sqrt"`, */
/** `"force-closure"`). */
let get_intrinsic_wasm_name = fn (func: string, exts: [LirExternal]) -> string do
  match wdefs.find_external(name: func, exts) do
    | None -> ""
    | Some(val: ext) ->
      if !is_intrinsic_external(ext) then return "" end
      match ext do
        | LirExternal(name: _, wasm_module: _, wasm_name: wn, params: _, ret_type: _, throw_row: _) -> wn
      end
  end
end

/** True when name corresponds to a lifted lambda (`__closure_N`). Matches both */
/** the bare form and the canonical-path form (`<sanitized-path>#__closure_N`) */
/** because `lift_lambda` (mir.nx) names lambdas `__closure_N` but downstream */
/** passes may prepend the source-file path to disambiguate cross-module */
/** imports. Distinct from `is_closure_func`, which also matches inject bodies */
/** and the sched trampoline — those need a function-table elem entry for */
/** ref.func but follow their own (non-canonical-closure) signature. */
let is_closure_lift = fn (name: string) -> bool do
  let nlen = str.length(s: name)
  let bare = "__closure_"
  let blen = str.length(s: bare)
  if nlen >= blen then
    if str.substring(s: name, start: 0, len: blen) == bare then return true end
  end
  let infix = "#__closure_"
  let ilen = str.length(s: infix)
  return nlen >= ilen && str.contains(s: name, sub: infix)
end

/** `__nx_sched_set_next(k)` is a compiler intrinsic that compiles to inline */
/** `global.set ss_resume_slot_global_idx`. Routing it through a host call */
/** trips wasmtime's CallThreadState chain when invoked inside a continuation */
/** arm body (after suspend, before resume); inline emission sidesteps the */
/** host-side trap-handler bookkeeping entirely. */
let is_sched_set_next = fn (func: string, exts: [LirExternal]) -> bool do
  match wdefs.find_external(name: func, exts) do
    | None -> false
    | Some(val: LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _)) ->
      return m == "nexus:runtime/sched" && wn == "sched-set-next"
  end
end

let emit_sched_set_next = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_global_set)
      return bb.push_uleb128(%buf, val: wdefs.ss_resume_slot_global_idx)
    | _ ->
      raise SymbolNotFound(name: "__nx_sched_set_next", kind: "sched intrinsic arg", context: "")
      return %buf
  end
end

/** `__nx_sched_spawn(thunk)` is a compiler intrinsic that turns a `@unit` thunk */
/** into a fresh fiber: pushes the thunk onto the host's pending-thunk FIFO, */
/** allocates a new cont_table slot, cont.new's the trampoline body for that */
/** slot, and enqueues the slot in the run queue. The spawned fiber actually */
/** starts running when the dispatcher dequeues the slot, resumes the cont, */
/** and the trampoline pops the matching thunk and forces it. */
let is_sched_spawn = fn (func: string, exts: [LirExternal]) -> bool do
  match wdefs.find_external(name: func, exts) do
    | None -> false
    | Some(val: LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _)) ->
      return m == "nexus:runtime/sched" && wn == "sched-spawn"
  end
end

/** Look up a function by suffix match. Used to locate the sched trampoline */
/** regardless of which package path (nxlib/stdlib/sched.nx vs an alias) the */
/** stdlib was imported from. */
let find_func_idx_by_suffix = fn (suffix: string, funcs: [LirFunction], internal_func_map: &HashMap) -> i64 throws { CodegenError } do
  match funcs do
    | [] -> return -1
    | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      let slen = str.length(s: n)
      let suflen = str.length(s: suffix)
      if slen >= suflen then
        if str.substring(s: n, start: slen - suflen, len: suflen) == suffix then
          return wdefs.lookup_func_fast(name: n, map: internal_func_map)
        end
      end
      return find_func_idx_by_suffix(suffix, funcs: rest, internal_func_map)
  end
end

/** Find a function index by source-qualified `#name` suffix match (mirrors */
/// If the program defines `wasi_thread_start` (pulled in via `std:lazy` /
/// `std:lazy_host`), it must be exported under exactly that name so wasi-threads
/// workers can find it; its `(i32, i32) -> ()` signature is produced by the
/// `lazy.nx` source. Returns a singleton `[ExportNameIdx]` or `[]`.
let wasi_thread_start_export = fn (funcs: [LirFunction], internal_func_map: &HashMap) -> [ExportNameIdx] throws { CodegenError } do
  let bare = wdefs.lookup_func_fast(name: "wasi_thread_start", map: internal_func_map)
  let idx = if bare >= 0 then bare else find_func_idx_by_suffix(suffix: "#wasi_thread_start", funcs, internal_func_map) end
  if idx < 0 then return [] end
  return [ExportNameIdx(name: "wasi_thread_start", index: idx)]
end

/** Find the import index for a sched runtime function by its wasm_name. Uses */
/** linear scan over the externals list because hash lookup by Nexus FFI name */
/** is fragile when several `nexus:runtime/sched` imports share a prefix. */
/** Skips arena and intrinsic-sched externals to mirror `filter_intrinsic_externals` */
/** — those entries are inlined and thus excluded from the wasm import section, */
/** so they do not occupy index slots in the codegen's pre-merge function space. */
let find_sched_import_idx = fn (wn: string, exts: [LirExternal], idx: i64) -> i64 throws { CodegenError } do
  match exts do
    | [] -> return -1
    | e :: rest ->
      if is_intrinsic_external(ext: e) || is_intrinsic_sched_external(ext: e) then
        return find_sched_import_idx(wn, exts: rest, idx)
      end
      match e do | LirExternal(name: _, wasm_module: m, wasm_name: w, params: _, ret_type: _, throw_row: _) ->
        if m == "nexus:runtime/sched" && w == wn then return idx end
        return find_sched_import_idx(wn, exts: rest, idx: idx + 1)
      end
  end
end

let emit_sched_spawn = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let CodegenCtx(functions: fns, internal_func_map: ifm, ss_cont_type_idx: cti, _) = ctx
      let exts = wdefs.ctx_externals(ctx)
      // Push thunk to host pending-thunk queue
      let %buf = emit_atom(atom: a, %buf, ctx)
      let push_idx = find_sched_import_idx(wn: "sched-push-pending", exts, idx: 0)
      if push_idx < 0 then
        raise SymbolNotFound(name: "sched-push-pending", kind: "sched intrinsic", context: "spawn requires push_pending external")
      end
      let %buf = bb.push_byte(%buf, byte: op_call)
      let %buf = bb.push_uleb128(%buf, val: push_idx)

      // slot = next_alloc + 1 (skip past the captured-cont slot the surrounding
      // InjectResume dispatcher just claimed for its own arm-call bookkeeping);
      // next_alloc = slot + 1 so the dispatcher's post-arm `++` advances to a
      // fresh free slot instead of overwriting our trampoline cont.
      let slot_local = wdefs.ctx_temps_base(ctx) + 4
      let %buf = bb.push_byte(%buf, byte: op_global_get)
      let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 1)
      let %buf = bb.push_byte(%buf, byte: op_i64_add)
      let %buf = bb.push_byte(%buf, byte: op_local_tee)
      let %buf = bb.push_uleb128(%buf, val: slot_local)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 1)
      let %buf = bb.push_byte(%buf, byte: op_i64_add)
      let %buf = bb.push_byte(%buf, byte: op_global_set)
      let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)

      // cont_table[slot] = cont.new(ref.func $trampoline)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: slot_local)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let tramp_idx = find_func_idx_by_suffix(
        suffix: "__nx_sched_trampoline_body",
        funcs: fns,
        internal_func_map: &ifm)
      if tramp_idx < 0 then
        raise SymbolNotFound(name: "__nx_sched_trampoline_body", kind: "sched intrinsic", context: "spawn requires sched.nx import")
      end
      let %buf = bb.push_byte(%buf, byte: op_ref_func)
      let %buf = bb.push_uleb128(%buf, val: tramp_idx)
      let %buf = bb.push_byte(%buf, byte: op_cont_new)
      let %buf = bb.push_uleb128(%buf, val: cti)
      let %buf = bb.push_byte(%buf, byte: op_table_set)
      let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_table_idx)

      // enqueue(slot)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: slot_local)
      let enqueue_idx = find_sched_import_idx(wn: "sched-enqueue", exts, idx: 0)
      if enqueue_idx < 0 then
        raise SymbolNotFound(name: "sched-enqueue", kind: "sched intrinsic", context: "spawn requires enqueue external")
      end
      let %buf = bb.push_byte(%buf, byte: op_call)
      let %buf = bb.push_uleb128(%buf, val: enqueue_idx)
      return %buf
    | _ ->
      raise SymbolNotFound(name: "__nx_sched_spawn", kind: "sched intrinsic arg", context: "")
      return %buf
  end
end

let filter_intrinsic_externals = fn (exts: [LirExternal]) -> [LirExternal] do
  match exts do
    | [] -> return []
    | e :: rest ->
      if is_intrinsic_external(ext: e) || is_intrinsic_sched_external(ext: e) then
        return filter_intrinsic_externals(exts: rest)
      else
        return e :: filter_intrinsic_externals(exts: rest)
      end
  end
end

/** True if this `nexus:runtime/sched` external is fulfilled inline by a */
/** compiler intrinsic, so the import entry must be elided from the final */
/** import section. `sched-set-next` and `sched-spawn` qualify; the others */
/** (enqueue, dequeue, push/pop_pending, queue-size) still go through the */
/** host linker. */
let is_intrinsic_sched_external = fn (ext: LirExternal) -> bool do
  match ext do
    | LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _) ->
      if m != "nexus:runtime/sched" then return false end
      return wn == "sched-set-next" || wn == "sched-spawn"
  end
end

/** Emit inline WASM for the bump-allocator (arena) intrinsics. */
/** */
/** Since the allocator is now a single atomic bump pointer at linear-memory */
/** cell `wdefs.heap_ptr_cell`, a region "mark" *is* the bump-pointer value: */
/** `heap_mark` reads the cell, `heap_reset` stores a previous value back, */
/** and `heap_swap` does both (returning the old). All three operate */
/** atomically; everything that allocates bumps the same cell, so a reset */
/** reclaims it all at once. */
let emit_heap_mark = fn (buf: %ByteBuffer) -> %ByteBuffer do
  // i32.atomic.load cell → i64.extend_i32_u
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
  let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_load, offset: 0)
  return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
end

let emit_heap_reset = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      // i32.atomic.store cell <- i32.wrap_i64(mark)   (pops [addr, value])
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
      let %buf = emit_atom(atom: a, buf: %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      return wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_store, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_heap_reset", kind: "arena intrinsic arg", context: "")
      return %buf
  end
end

let emit_heap_swap = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      // old = i32.atomic.load cell ; cell <- i32.wrap_i64(base) ; push old (i64)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_load, offset: 0)
      let %buf = bb.push_byte(%buf, byte: op_i64_extend_i32_u)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      return wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_store, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_heap_swap", kind: "arena intrinsic arg", context: "")
      return %buf
  end
end

/** `alloc-raw : (size: i64) -> i64` — raw byte allocation */
/** off the unified atomic bump cell. Used by stdlib runtime impls. Emits: */
/** wrap the i64 size to i32, atomic-bump (rounds up to 8, grows memory), */
/** zero-extend the resulting i32 base pointer back to i64. */
let emit_alloc_raw = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = emit_atom(atom: a, buf: %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = emit_atomic_bump(%buf, ctx, ptr_local: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_alloc_raw", kind: "arena intrinsic arg", context: "")
      return %buf
  end
end

// ─── Memory intrinsics (mem-load-* / mem-store-* / mem-size / mem-grow) ─────
// Inline-emit raw load/store and memory.size/grow ops. Argument policy
// (kebab-canonical, all i64 across the FFI boundary):
//   mem-load-i32(addr)        : i32.wrap addr → i32.load{align=2,offset=0} → i64.extend_i32_s
//   mem-store-i32(addr, val)  : i32.wrap addr; i32.wrap val; i32.store{align=2,offset=0}
//   mem-load-u8(addr)         : i32.wrap addr → i32.load8_u{align=0,offset=0} → i64.extend_i32_u
//   mem-store-u8(addr, val)   : i32.wrap addr; i32.wrap val; i32.store8{align=0,offset=0}
//   mem-load-i64(addr)        : i32.wrap addr → i64.load{align=3,offset=0}
//   mem-store-i64(addr, val)  : i32.wrap addr; val (already i64); i64.store{align=3,offset=0}
//   mem-size()                : memory.size(mem 0) → i64.extend_i32_u   (returns pages)
//   mem-grow(delta)           : i32.wrap delta → memory.grow(mem 0) → i64.extend_i32_s
//                               (sign-extend so the wasm `-1` failure sentinel surfaces as `-1`)

let emit_addr_arg = fn (atom: LirAtom, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  // Nexus i64 → wasm i32 address (truncating wrap).
  let %buf = emit_atom(atom, %buf, ctx)
  return bb.push_byte(%buf, byte: op_i32_wrap_i64)
end

let emit_mem_load_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_load)
      let %buf = wdefs.emit_memarg_i32(%buf, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_s)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_load_i32", kind: "memory intrinsic arg", context: "")
      return %buf
  end
end

let emit_mem_store_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = bb.push_byte(%buf, byte: op_i32_store)
      return wdefs.emit_memarg_i32(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_store_i32", kind: "memory intrinsic arg", context: "")
      return %buf
  end
end

let emit_mem_load_u8 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_load8_u)
      let %buf = wdefs.emit_memarg_i8(%buf)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_load_u8", kind: "memory intrinsic arg", context: "")
      return %buf
  end
end

let emit_mem_store_u8 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = bb.push_byte(%buf, byte: op_i32_store8)
      return wdefs.emit_memarg_i8(%buf)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_store_u8", kind: "memory intrinsic arg", context: "")
      return %buf
  end
end

let emit_mem_load_i64 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      return wdefs.emit_memarg_i64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_load_i64", kind: "memory intrinsic arg", context: "")
      return %buf
  end
end

let emit_mem_store_i64 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i64_store)
      return wdefs.emit_memarg_i64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_store_i64", kind: "memory intrinsic arg", context: "")
      return %buf
  end
end

// f32 / f64 mem ops (nexus-ybda). Float values cross the FFI as Nexus `float`
// (= wasm f64), so load_f32 promotes (f32 -> f64) on read and store_f32
// demotes (f64 -> f32) on write. Roundtrip is bitwise-stable as long as the
// stored value is exactly representable in f32 (which holds when the value
// originally came from a load_f32 or an f32 SIMD lane).
let emit_mem_load_f32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_f32_load)
      let %buf = wdefs.emit_memarg_f32(%buf, offset: 0)
      return bb.push_byte(%buf, byte: op_f64_promote_f32)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_load_f32", kind: "memory intrinsic arg", context: "")
      return %buf
  end
end

let emit_mem_store_f32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_f32_demote_f64)
      let %buf = bb.push_byte(%buf, byte: op_f32_store)
      return wdefs.emit_memarg_f32(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_store_f32", kind: "memory intrinsic arg", context: "")
      return %buf
  end
end

let emit_mem_load_f64 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_f64_load)
      return wdefs.emit_memarg_f64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_load_f64", kind: "memory intrinsic arg", context: "")
      return %buf
  end
end

let emit_mem_store_f64 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_f64_store)
      return wdefs.emit_memarg_f64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_store_f64", kind: "memory intrinsic arg", context: "")
      return %buf
  end
end

let emit_mem_size = fn (buf: %ByteBuffer) -> %ByteBuffer do
  // memory.size mem_idx=0 → i32 pages → extend_u to i64
  let %buf = bb.push_byte(%buf, byte: op_memory_size)
  let %buf = bb.push_byte(%buf, byte: 0)
  return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
end

let emit_mem_grow = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = bb.push_byte(%buf, byte: op_memory_grow)
      let %buf = bb.push_byte(%buf, byte: 0)
      // Sign-extend so the wasm `-1` failure sentinel surfaces unchanged at i64.
      return bb.push_byte(%buf, byte: op_i64_extend_i32_s)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_grow", kind: "memory intrinsic arg", context: "")
      return %buf
  end
end

// ─── Atomic intrinsics (atomic-rmw-add-i32 / atomic-load-i32 / ...) ─────────
// Each lowers to a single 0xFE-prefixed wasm instruction (no host call). Like
// the memory intrinsics, addresses/values cross the FFI as Nexus `i64` and are
// wrapped to wasm i32 at the boundary. `wait32` / `notify` trap unless the
// linear memory is `shared`. These externals are filtered from the import
// section (filter_intrinsic_externals).

let emit_atomic_rmw_add_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_rmw_add, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_rmw_add_i32", kind: "atomic intrinsic arg", context: "")
      return %buf
  end
end

let emit_atomic_load_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_load, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_load_i32", kind: "atomic intrinsic arg", context: "")
      return %buf
  end
end

let emit_atomic_store_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      return wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_store, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_store_i32", kind: "atomic intrinsic arg", context: "")
      return %buf
  end
end

let emit_atomic_cmpxchg_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: ex) :: LirCallArg(label: _, value: rp) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: ex, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = emit_atom(atom: rp, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_rmw_cmpxchg, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_cmpxchg_i32", kind: "atomic intrinsic arg", context: "")
      return %buf
  end
end

let emit_atomic_wait32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: ex) :: LirCallArg(label: _, value: tmo) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: ex, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      // wait32's timeout operand is i64; pass through unwrapped.
      let %buf = emit_atom(atom: tmo, %buf, ctx)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_atomic_wait32, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_wait32", kind: "atomic intrinsic arg", context: "")
      return %buf
  end
end

let emit_atomic_notify = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: c) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: c, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_atomic_notify, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_notify", kind: "atomic intrinsic arg", context: "")
      return %buf
  end
end

// ─── Width-cast intrinsics (cast-to-i32 / cast-to-i64) ─────────────────────
// i32_of(x: i64) -> i32  emits  i32.wrap_i64 ; i64_of(x: i32) -> i64  emits  i64.extend_i32_u

let emit_cast_to_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      return bb.push_byte(%buf, byte: op_i32_wrap_i64)
    | _ ->
      raise SymbolNotFound(name: "__nx_cast_to_i32", kind: "cast intrinsic arg", context: "")
      return %buf
  end
end

let emit_cast_to_i64 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_cast_to_i64", kind: "cast intrinsic arg", context: "")
      return %buf
  end
end

// ─── Lazy / WASI-threads intrinsics (force-closure / thunk-addr / value-of-i64) 

/// `__nx_thunk_addr(t: @T) -> i64` / `__nx_value_of_i64(x: i64) -> T`: both are
/// pure type puns at the WASM level (every Nexus value is an i64). Emit the
/// argument atom and nothing else.
let emit_lazy_passthrough = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ -> return emit_atom(atom: a, %buf, ctx)
    | _ ->
      raise SymbolNotFound(name: "__nx_lazy_passthrough", kind: "lazy intrinsic arg", context: "")
      return %buf
  end
end

// ─── Backtrace intrinsics (nexus:runtime/backtrace, now nexus:intrinsic) ────
//
// WASM cannot introspect its own call stack without a host. There is no
// in-tree provider for `nexus:runtime/backtrace`, so these ops are inlined to
// constants: `raise` works, `Exn.backtrace(e)` returns `[]`, and the
// main_wrap catch-all prints the variant name then 0 frames.

/// `__nx_bt_depth() -> i64`: number of captured frames — always 0.
let emit_bt_depth = fn (buf: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(%buf, byte: op_i64_const)
  return bb.push_sleb128(%buf, val: 0)
end

/// `__nx_bt_frame(idx: i64) -> string`: name of frame `idx` — always the
/// empty string (packed `(ptr << 32) | len` value 0).
let emit_bt_frame = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_drop)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      return bb.push_sleb128(%buf, val: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_bt_frame", kind: "backtrace intrinsic arg", context: "")
      return %buf
  end
end

/// `capture-backtrace(...) -> unit`: snapshot the call stack before a raise
/// unwinds it — a no-op (no host). Drops every argument; unit return = empty
/// stack. Normally never reached: the external is filtered from the import
/// section so the raise-site `call` is elided, but kept for completeness.
let emit_capture_backtrace = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  return drop_all_args(args, %buf, ctx)
end

let drop_all_args = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | [] -> return %buf
    | LirCallArg(label: _, value: a) :: rest ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_drop)
      return drop_all_args(args: rest, %buf, ctx)
  end
end

/// `__nx_force_closure(p: i64) -> i64`: invoke `p` as a 0-arg closure — mirror
/// of `LirExprForce` (closure pointer is the env arg; word 0 is the funcref
/// table index; `call_indirect (type closure/0) (table 0)`).
let emit_force_closure = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_call_indirect])
      let CodegenCtx(closure_type_indices: cti, _) = ctx
      let type_idx = lookup_closure_type_idx_pairs(arity: 0, pairs: cti)
      let %buf = bb.push_uleb128(%buf, val: type_idx)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      return %buf
    | _ ->
      raise SymbolNotFound(name: "__nx_force_closure", kind: "lazy intrinsic arg", context: "")
      return %buf
  end
end

// ─── Array intrinsic (__array_get) ──────────────────────────────────────────
// MirIndex (`arr[idx]`) lowers to LirExprCall("__array_get", arr, idx). Arrays
// are heap records `[tag(i64) | e0(i64) | e1(i64) | ...]` (see MirArray in
// src/ir/lir.nx). The array atom is the canonical packed `(ptr<<32) | len`
// form — pointer in the upper 32 bits, length in the lower 32 bits — so the
// host stub `__nx_array_length(ptr: i32, len: i32) -> i64` and any other
// extern receiving `&[| T |]` can read both fields after a single packed-i64
// argument. `__array_get` is never registered as a real wasm import; emit_call
// detects the symbol and inlines a `(ptr + (idx + 1) * 8) -> i64.load`
// sequence below, extracting `ptr` via `(arr_atom >> 32)`.

let emit_array_get = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: arr_atom) :: LirCallArg(label: _, value: idx_atom) :: _ ->
      // Push base ptr: extract upper 32 bits of arr_atom -> i32
      let %buf = emit_atom(atom: arr_atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 32)
      let %buf = bb.push_byte(%buf, byte: op_i64_shr_u)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      // Push offset: i32_wrap_i64(idx) * 8 + 8
      let %buf = emit_atom(atom: idx_atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 8)
      let %buf = bb.push_byte(%buf, byte: op_i32_mul)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 8)
      let %buf = bb.push_byte(%buf, byte: op_i32_add)
      // Combine: ptr + offset
      let %buf = bb.push_byte(%buf, byte: op_i32_add)
      // Load i64 element
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      return wdefs.emit_memarg_i64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__array_get", kind: "array intrinsic arg", context: "expected (arr, idx)")
      return %buf
  end
end

// `__array_set(arr, idx, val)` is the write counterpart to __array_get.
// Layout matches: `(ptr + (idx + 1) * 8) <- i64.store val`. The intrinsic
// returns unit; emit_stmt's LirStmtLet branch detects expr_type == TyUnit
// and leaves the stack untouched (no drop, no local_set), so emit_array_set
// must NOT push any synthetic value — exactly mirroring how a real
// unit-returning host call (e.g. `__nx_heap_reset`) ends.
let emit_array_set = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: arr_atom) :: LirCallArg(label: _, value: idx_atom) :: LirCallArg(label: _, value: val_atom) :: _ ->
      // Push address: base_ptr + ((idx + 1) * 8)
      // arr_atom is the canonical `(ptr<<32) | len` i64 — extract ptr via
      // `(arr_atom >> 32) -> i32_wrap_i64`, exactly mirroring emit_array_get.
      // (Earlier this used a bare i32_wrap_i64 which gave the LEN low half,
      //  causing writes to land in the array's length cell — nexus-tf49.)
      let %buf = emit_atom(atom: arr_atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 32)
      let %buf = bb.push_byte(%buf, byte: op_i64_shr_u)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = emit_atom(atom: idx_atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 8)
      let %buf = bb.push_byte(%buf, byte: op_i32_mul)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 8)
      let %buf = bb.push_byte(%buf, byte: op_i32_add)
      let %buf = bb.push_byte(%buf, byte: op_i32_add)
      // Push value
      let %buf = emit_atom(atom: val_atom, %buf, ctx)
      // Store i64 — leaves no stack value (matches TyUnit return).
      let %buf = bb.push_byte(%buf, byte: op_i64_store)
      return wdefs.emit_memarg_i64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__array_set", kind: "array intrinsic arg", context: "expected (arr, idx, val)")
      return %buf
  end
end

// `array-length(arr: &[| T |]) -> i64` — the `nexus:intrinsic` op behind the
// `__nx_array_length` FFI name (kebab-cased). Array atoms are the canonical
// packed `(ptr<<32) | len` i64, so the count is the low 32 bits: emit the
// atom, then `i64.const 0xFFFFFFFF`, then `i64.and`. Mirrors how
// `emit_array_get` recovers the pointer via `arr >> 32`.
let emit_array_length = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: arr_atom) :: _ ->
      let %buf = emit_atom(atom: arr_atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 4294967295)
      return bb.push_byte(%buf, byte: op_i64_and)
    | _ ->
      raise SymbolNotFound(name: "array-length", kind: "array intrinsic arg", context: "expected (arr)")
      return %buf
  end
end

// ─── Math intrinsics (f64-sqrt / f64-floor / f64-ceil / f64-abs) ────────────
// Inline-emit f64 unary ops. Each takes a single `val: float` and pushes the
// f64 result; no coercion needed since the FFI types are already f64.

let emit_f64_unary = fn (opcode: i64, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx, name: string) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      return bb.push_byte(%buf, byte: opcode)
    | _ ->
      raise SymbolNotFound(name, kind: "math intrinsic arg", context: "f64 unary requires one argument")
      return %buf
  end
end

// ─── SIMD intrinsics (simd-f32x4-add / simd-...-array / ...) ────────────────
// 128-bit fixed-width SIMD primitives — `simd-{lane}x{count}-{op}` for the
// f32x4 / f64x2 / i32x4 / i64x2 lane shapes and add / mul lane-wise ops, plus
// `simd-f32x4-add-array` which expands to a SIMD loop over a contiguous
// quad-aligned region (the autovectorized form of an element-wise scalar
// `dst[i] = a[i] + b[i]` loop).
//
// Argument policy: addresses are i64 across the FFI boundary, truncating to
// i32 for wasm load/store. Lane width is implicit in the wasm_name. A v128
// never escapes a single intrinsic emission — load → op → store stays inside
// one instruction sequence so v128 never becomes a Nexus-visible local type
// (which would require widening type_to_valtype + bootstrap regen).
//
// Verified opcodes (see wasm/defs.nx for the full table):
//   v128.load (sub 0x00) / v128.store (sub 0x0B): memarg align=4 offset=0
//   {i32x4,i64x2,f32x4,f64x2}.add / .mul: no further operand bytes
//
// SIMD extension is part of the WebAssembly 2.0 baseline and is enabled by
// default in wasmtime 13+; bootstrap.sh's launch flags inherit that default
// (no explicit -W simd toggle is required).

/** Emit a single v128 lane-wise binary op: load 16 bytes from each input */
/** address, run the lane-op, store 16 bytes to dst. Address args are in */
/** LirCallArg order `(a_addr, b_addr, dst_addr)`. Caller passes the SIMD */
/** sub-opcode (e.g. `op_simd_f32x4_add`) for the lane operation. */
let emit_simd_binop_one = fn (sub_op: i64, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx, name: string) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: b) :: LirCallArg(label: _, value: d) :: _ ->
      // dst_addr (for the final store) — push first so the store's base addr
      // is below the v128 result on the wasm operand stack.
      let %buf = emit_addr_arg(atom: d, %buf, ctx)
      // v128.load a_addr
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_load)
      let %buf = wdefs.emit_memarg_v128(%buf, offset: 0)
      // v128.load b_addr
      let %buf = emit_addr_arg(atom: b, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_load)
      let %buf = wdefs.emit_memarg_v128(%buf, offset: 0)
      // lane-op
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: sub_op)
      // v128.store
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_store)
      return wdefs.emit_memarg_v128(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name, kind: "simd intrinsic arg", context: "simd lane binop requires (a_addr, b_addr, dst_addr)")
      return %buf
  end
end

/** Emit an autovectorized SIMD loop: for each of `n` quads (16-byte chunks), */
/** load v128 from a, load v128 from b, lane-op, v128.store to dst, advance */
/** each pointer by 16. This is the autovectorized form of: */
/**   for i in 0..(n*4): dst[i] = a[i] + b[i]   (when sub_op = f32x4.add) */
/** */
/** Arg policy: `(a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64)`. */
/** Local-slot layout (drawn from the reserved-temps range that */
/** section.nx::emit_local_decls declares — 2x i64, 2x i32, 2x i64, 7x i32, */
/** then the tcmc pair): */
/**   counter at temps_base+0   (i64 slot — quad-remaining countdown) */
/**   a_ptr   at temps_base+2   (i32 slot — wasm address) */
/**   b_ptr   at temps_base+3   (i32 slot — wasm address; also used by */
/**                             emit_alloc_object as obj_ptr, but that helper */
/**                             sets+uses+is-done before any caller, so the */
/**                             slot is dead when the SIMD intrinsic body runs) */
/**   d_ptr   at temps_base+6   (i32 slot — wasm address; shared with the */
/**                             throw-path retptr which is similarly dead) */
/** Mismatched-type local.set/get would fail wasm validation; the slot */
/** assignments above honour the reserved-type bands. */
/** */
/** Loop shape (mirrors emit_memcpy_loop in codegen/atom.nx): */
/**   block */
/**     loop */
/**       local.get counter ; i64.eqz ; br_if 1   ; exit when 0 */
/**       <SIMD body: load a_ptr; load b_ptr; lane-op; store d_ptr> */
/**       a_ptr += 16; b_ptr += 16; d_ptr += 16 */
/**       counter -= 1 */
/**       br 0 */
/**     end */
/**   end */
let emit_simd_binop_array = fn (sub_op: i64, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx, name: string) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: b) :: LirCallArg(label: _, value: d) :: LirCallArg(label: _, value: n) :: _ ->
      let temps = wdefs.ctx_temps_base(ctx)
      let counter = temps        // i64 slot
      let a_ptr = temps + 2      // i32 slot
      let b_ptr = temps + 3      // i32 slot
      let d_ptr = temps + 6      // i32 slot
      // Initialize pointer locals from the i64 address args (truncate to i32).
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: a_ptr)
      let %buf = emit_addr_arg(atom: b, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: b_ptr)
      let %buf = emit_addr_arg(atom: d, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: d_ptr)
      // counter (i64) ← n
      let %buf = emit_atom(atom: n, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: counter)
      // block ; loop
      let %buf = bb.push_byte(%buf, byte: op_block)
      let %buf = bb.push_byte(%buf, byte: bt_void)
      let %buf = bb.push_byte(%buf, byte: op_loop)
      let %buf = bb.push_byte(%buf, byte: bt_void)
      // counter == 0 → break out (br 1 → exits the outer block)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: counter)
      let %buf = bb.push_byte(%buf, byte: 80)   // i64.eqz
      let %buf = bb.push_byte(%buf, byte: op_br_if)
      let %buf = bb.push_uleb128(%buf, val: 1)
      // SIMD body: emit equivalent of one-shot binop using the i32 pointer locals.
      // dst pointer first so the store's base sits below v128 on the stack.
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: d_ptr)
      // load a
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: a_ptr)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_load)
      let %buf = wdefs.emit_memarg_v128(%buf, offset: 0)
      // load b
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: b_ptr)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_load)
      let %buf = wdefs.emit_memarg_v128(%buf, offset: 0)
      // lane-op
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: sub_op)
      // store dst
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_store)
      let %buf = wdefs.emit_memarg_v128(%buf, offset: 0)
      // a_ptr += 16
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: a_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 16)
      let %buf = bb.push_byte(%buf, byte: op_i32_add)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: a_ptr)
      // b_ptr += 16
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: b_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 16)
      let %buf = bb.push_byte(%buf, byte: op_i32_add)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: b_ptr)
      // d_ptr += 16
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: d_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 16)
      let %buf = bb.push_byte(%buf, byte: op_i32_add)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: d_ptr)
      // counter -= 1
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: counter)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 1)
      let %buf = bb.push_byte(%buf, byte: op_i64_sub)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: counter)
      // br 0 (loop back)
      let %buf = bb.push_byte(%buf, byte: op_br)
      let %buf = bb.push_uleb128(%buf, val: 0)
      // end loop ; end block
      let %buf = bb.push_byte(%buf, byte: op_end)
      let %buf = bb.push_byte(%buf, byte: op_end)
      return %buf
    | _ ->
      raise SymbolNotFound(name, kind: "simd intrinsic arg", context: "simd array binop requires (a_addr, b_addr, dst_addr, n_quads)")
      return %buf
  end
end

// ─── TCMC detection + emission live in codegen/tcmc.nx ─────────────────────
// ─── Atom / coercion / alloc / memcpy helpers: see codegen/atom.nx ─────────
// All leaf helpers that don't recurse through emit_expr / emit_stmt live
// in the atom/string/tcmc modules, so emission stays a thin glue layer.

// ─── String concat / compare live in codegen/string.nx ─────────────────────

// ─── Binary operation ───────────────────────────────────────────────────────

// Determine common operand type for binary ops. Both operands will be
// coerced to this type before the binary opcode.
let binary_operand_type = fn (op: BinaryOp, lhs_type: TypeExpr, rhs_type: TypeExpr) -> TypeExpr do
  let lt = wdefs.peel_linear(typ: lhs_type)
  let rt = wdefs.peel_linear(typ: rhs_type)
  // Logical And/Or always operate on booleans (i32)
  match op do
    | OpAnd -> return TyBool
    | OpOr -> return TyBool
    | _ -> ()
  end
  let lt_vt = wdefs.type_to_valtype(typ: lt)
  let rt_vt = wdefs.type_to_valtype(typ: rt)
  // If both have the same valtype, prefer the left type
  if lt_vt == rt_vt then return lt end
  // Mixed i32/i64: widen to i64
  if (lt_vt == vt_i32 && rt_vt == vt_i64) || (lt_vt == vt_i64 && rt_vt == vt_i32) then
    return TyI64
  end
  // Fallback: use left type
  return lt
end

let emit_binary = fn (op: BinaryOp, operand_type: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer throws { CodegenError } do
  let use_i32 = match wdefs.peel_linear(typ: operand_type) do
    | TyBool -> true | TyI32 -> true | TyChar -> true | _ -> false
  end
  // Float ops dispatch on f32 vs f64 valtype; non-float ops ignore use_f32.
  let use_f32 = match wdefs.peel_linear(typ: operand_type) do
    | TyF32 -> true | _ -> false
  end
  let opcode = match op do
    | OpAdd -> match use_i32 do | true -> op_i32_add | false -> op_i64_add end
    | OpSub -> match use_i32 do | true -> op_i32_sub | false -> op_i64_sub end
    | OpMul -> match use_i32 do | true -> op_i32_mul | false -> op_i64_mul end
    | OpDiv -> op_i64_div_s | OpMod -> op_i64_rem_s
    | OpFAdd -> match use_f32 do | true -> op_f32_add | false -> op_f64_add end
    | OpFSub -> match use_f32 do | true -> op_f32_sub | false -> op_f64_sub end
    | OpFMul -> match use_f32 do | true -> op_f32_mul | false -> op_f64_mul end
    | OpFDiv -> match use_f32 do | true -> op_f32_div | false -> op_f64_div end
    | OpEq -> match use_i32 do | true -> op_i32_eq | false -> op_i64_eq end
    | OpNe -> match use_i32 do | true -> op_i32_ne | false -> op_i64_ne end
    | OpLt -> match use_i32 do | true -> op_i32_lt_s | false -> op_i64_lt_s end
    | OpLe -> match use_i32 do | true -> op_i32_le_s | false -> op_i64_le_s end
    | OpGt -> match use_i32 do | true -> op_i32_gt_s | false -> op_i64_gt_s end
    | OpGe -> match use_i32 do | true -> op_i32_ge_s | false -> op_i64_ge_s end
    | OpFEq -> match use_f32 do | true -> op_f32_eq | false -> op_f64_eq end
    | OpFNe -> match use_f32 do | true -> op_f32_ne | false -> op_f64_ne end
    | OpFLt -> match use_f32 do | true -> op_f32_lt | false -> op_f64_lt end
    | OpFLe -> match use_f32 do | true -> op_f32_le | false -> op_f64_le end
    | OpFGt -> match use_f32 do | true -> op_f32_gt | false -> op_f64_gt end
    | OpFGe -> match use_f32 do | true -> op_f32_ge | false -> op_f64_ge end
    | OpBitAnd -> match use_i32 do | true -> op_i32_and | false -> op_i64_and end
    | OpBitOr -> match use_i32 do | true -> op_i32_or | false -> op_i64_or end
    | OpBitXor -> match use_i32 do | true -> op_i32_xor | false -> op_i64_xor end
    | OpShl -> op_i64_shl | OpShr -> op_i64_shr_s
    | OpAnd -> match use_i32 do | true -> op_i32_and | false -> op_i64_and end
    | OpOr -> match use_i32 do | true -> op_i32_or | false -> op_i64_or end
    | OpConcat -> raise SymbolNotFound(name: "OpConcat", kind: "binary operator", context: "emit_binary: string concat must go through emit_string_concat, not emit_binary")
  end
  return bb.push_byte(%buf, byte: opcode)
end

// ─── External call arg ──────────────────────────────────────────────────────

let emit_external_arg = fn (atom: LirAtom, param_type: TypeExpr, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match wdefs.peel_linear(typ: param_type) do
    | TyString ->
      let packed_tmp = wdefs.ctx_temps_base(ctx)
      let %buf = emit_atom(atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 32)
      let %buf = bb.push_bytes(%buf, bytes: [op_i64_shr_s, op_i32_wrap_i64, op_local_get])
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      return bb.push_byte(%buf, byte: op_i32_wrap_i64)
    | TyArray(_) ->
      let packed_tmp = wdefs.ctx_temps_base(ctx)
      let %buf = emit_atom(atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 32)
      let %buf = bb.push_bytes(%buf, bytes: [op_i64_shr_s, op_i32_wrap_i64, op_local_get])
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      return bb.push_byte(%buf, byte: op_i32_wrap_i64)
    | TyChar ->
      // Internal and external both use i32 for char — no conversion needed
      let %buf = emit_atom(atom, %buf, ctx)
      return emit_coercion(from_type: wdefs.atom_type(atom), to_type: param_type, %buf)
    | _ ->
      let %buf = emit_atom(atom, %buf, ctx)
      return emit_coercion(from_type: wdefs.atom_type(atom), to_type: param_type, %buf)
  end
end

// ─── Constructor/record field emission ──────────────────────────────────────

let emit_constructor_fields = fn (buf: %ByteBuffer, args: [LirAtom], ctx: CodegenCtx,
                                   obj_ptr: i64, field_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match args do
    | [] -> %buf
    | a :: rest ->
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = emit_typed_field_store(typ: wdefs.atom_type(atom: a), %buf, offset: field_idx * 8)
      emit_constructor_fields(%buf, args: rest, ctx, obj_ptr, field_idx: field_idx + 1)
  end
end

let emit_record_fields = fn (buf: %ByteBuffer, fields: [LirNamedAtom], ctx: CodegenCtx,
                              obj_ptr: i64, field_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match fields do
    | [] -> %buf
    | LirNamedAtom(name: _, value: v) :: rest ->
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = emit_typed_field_store(typ: wdefs.atom_type(atom: v), %buf, offset: field_idx * 8)
      emit_record_fields(%buf, fields: rest, ctx, obj_ptr, field_idx: field_idx + 1)
  end
end

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_strings = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_strings(lst: rest, out: x :: out)
  end
end

let rev_local_entries = fn (lst: [LocalEntry], out: [LocalEntry]) -> [LocalEntry] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_local_entries(lst: rest, out: x :: out)
  end
end

let rev_func_entries = fn (lst: [FuncEntry], out: [FuncEntry]) -> [FuncEntry] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_func_entries(lst: rest, out: x :: out)
  end
end

let rev_arity_type_idxs = fn (lst: [ArityTypeIdx], out: [ArityTypeIdx]) -> [ArityTypeIdx] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_arity_type_idxs(lst: rest, out: x :: out)
  end
end

let rev_i64s = fn (lst: [i64], out: [i64]) -> [i64] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_i64s(lst: rest, out: x :: out)
  end
end

let extract_field_names = fn (fields: [LirNamedAtom]) -> [string] throws { CodegenError } do
  return extract_field_names_go(fields, acc: [])
end
let extract_field_names_go = fn (fields: [LirNamedAtom], acc: [string]) -> [string] throws { CodegenError } do
  match fields do
    | [] -> return rev_strings(lst: acc, out: [])
    | LirNamedAtom(name: n, value: _) :: rest ->
      return extract_field_names_go(fields: rest, acc: n :: acc)
  end
end

// Array literals (`[| e0, e1, ... |]`) lower to `LirExprRecord` with field
// names `"0", "1", ..., "n-1"` (see lower_expr_to_atom MirArray case in
// src/ir/lir.nx). Detect that shape so the record codegen can emit the
// packed `(ptr<<32) | len` atom layout that `emit_external_arg(TyArray)`
// expects, instead of the `i64.extend_i32_u(ptr)` form used by real
// records. Real records always have alphabetic field names — there is no
// source syntax that produces a record whose field is literally `"0"`.
// Empty fields are ambiguous (both `{}` and `[||]` lower to no-fields), so
// they keep the legacy zero-extended-pointer form to avoid corrupting
// downstream record field-access of `{}` — `[||]` length stays as the
// pre-existing corner case.
let is_array_record = fn (fields: [LirNamedAtom]) -> bool throws { CodegenError } do
  return is_array_record_go(fields, idx: 0)
end
let is_array_record_go = fn (fields: [LirNamedAtom], idx: i64) -> bool throws { CodegenError } do
  match fields do
    | [] -> return idx > 0
    | LirNamedAtom(name: n, value: _) :: rest ->
      if n == str.from_i64(val: idx) then
        return is_array_record_go(fields: rest, idx: idx + 1)
      else return false
      end
  end
end

// ─── Call emission ──────────────────────────────────────────────────────────

let emit_internal_call_args = fn (buf: %ByteBuffer, args: [LirCallArg], params: [LirParam], ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | [] -> %buf
    | LirCallArg(label: _, value: v) :: rest_args ->
      match params do
        | [] -> %buf
        | LirParam(label: _, name: _, typ: pt) :: rest_params ->
          let %buf = emit_atom(atom: v, %buf, ctx)
          let %buf = emit_coercion(from_type: wdefs.atom_type(atom: v), to_type: pt, %buf)
          emit_internal_call_args(%buf, args: rest_args, params: rest_params, ctx)
      end
  end
end

let find_call_arg_value = fn (label: string, args: [LirCallArg]) -> LirAtom throws { CodegenError } do
  match args do
    | [] -> raise SymbolNotFound(name: label, kind: "call argument label", context: "find_call_arg_value")
    | LirCallArg(label: l, value: v) :: rest ->
      if l == label then return v
      else return find_call_arg_value(label, args: rest)
      end
  end
end

let emit_external_call_args = fn (buf: %ByteBuffer, args: [LirCallArg], params: [LirParam], ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  // Iterate params in source order (matching stdlib ABI), look up args by label
  match params do
    | [] -> %buf
    | LirParam(label: pl, name: _, typ: pt) :: rest_params ->
      let v = find_call_arg_value(label: pl, args)
      let %buf = emit_external_arg(atom: v, param_type: pt, %buf, ctx)
      emit_external_call_args(%buf, args, params: rest_params, ctx)
  end
end

// ─── Call emission ──────────────────────────────────────────────────────────

let emit_internal_call = fn (func: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx,
                              is_tail: bool, in_try: bool, int_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match wdefs.ctx_find_function(ctx, name: func) do
    | Some(val: LirFunction(name: _, params, ret_type: callee_rt, body: _, ret: _, span: _)) ->
      let CodegenCtx(func_ret_type: caller_rt, memo_target_names: mtn, memo_target_slots: mts, _) = ctx
      // return_call requires callee return type ≡ caller return type. When a
      // unit-returning fn is tail-called from a non-unit-returning wrapper
      // (e.g. closure body wrapping `let @t = unit_returning_fn()`), fall
      // back to a regular call so emit_return_value can supply the placeholder.
      let types_match = wdefs.is_unit(typ: callee_rt) == wdefs.is_unit(typ: caller_rt)
      let use_tail = is_tail && !in_try && types_match

      // Memoization (nexus-e6uh): single-slot last-call cache for 1-arg
      // single-word-key pure fns, gated on slot-table membership and a
      // non-tail / non-try call site so the if/else result discipline holds.
      let memo_slot = lookup_memo_slot(name: func, targets_names: mtn,
                                          targets_slots: mts)
      if !use_tail && !in_try && memo_slot >= 0 then
        return emit_memoized_internal_call(func: func, args, params, callee_rt: callee_rt,
                                            buf: %buf, ctx: ctx,
                                            int_idx: int_idx, slot: memo_slot)
      end

      let %buf = emit_internal_call_args(%buf, args, params, ctx)
      let call_op = match use_tail do | true -> op_return_call | false -> op_call end
      let %buf = bb.push_byte(%buf, byte: call_op)
      bb.push_uleb128(%buf, val: int_idx)
    | None ->
      raise SymbolNotFound(name: func, kind: "function", context: "internal call")
      return %buf
  end
end

/** Emit a memoized call sequence for a 1-arg single-word-key pure function. */
/** Pre-condition (caller-enforced): slot is valid, args.length == 1, */
/** param_types[0] is a single-word-key type per memo.is_single_word_key_type, */
/** !is_tail, !in_try. */
let emit_memoized_internal_call = fn (func: string, args: [LirCallArg], params: [LirParam],
                                         callee_rt: TypeExpr,
                                         buf: %ByteBuffer, ctx: CodegenCtx,
                                         int_idx: i64, slot: i64) -> %ByteBuffer throws { CodegenError } do
  let CodegenCtx(memo_globals_base: memo_base, _) = ctx
  let valid_idx = memo.memo_valid_global_idx(base: memo_base, slot)
  let key_idx = memo.memo_key_global_idx(base: memo_base, slot)
  let val_idx = memo.memo_val_global_idx(base: memo_base, slot)
  let key_local = wdefs.ctx_temps_base(ctx) + memo.memo_key_local_offset
  let val_local = wdefs.ctx_temps_base(ctx) + memo.memo_val_local_offset

  // Step 1 — emit and capture the single argument as i64 cache key.
  let %buf = emit_internal_call_args(%buf, args, params, ctx)
  // emit_internal_call_args coerces the arg to the param type (already i64
  // for our single-word-key admission). pack_arg_to_key widens i32-flavoured
  // values and reinterprets f64. Stack: [key:i64].
  let arg_type = match params do
    | LirParam(label: _, name: _, typ: t) :: _ -> t
    | [] -> callee_rt
  end
  let %buf = memo.emit_pack_arg_to_key(buf: %buf, arg_type: arg_type)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: key_local)

  // Step 2 — compute hit condition: valid && key == cached_key.
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: valid_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: key_local)
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: key_idx)
  let %buf = bb.push_byte(%buf, byte: op_i64_eq)
  let %buf = bb.push_byte(%buf, byte: op_i32_and)

  // Step 3 — if (result i64): hit branch returns cached val.
  let %buf = bb.push_byte(%buf, byte: op_if)
  let %buf = bb.push_byte(%buf, byte: bt_i64)
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: val_idx)

  // Step 4 — else: miss branch invokes the callee, writes the cache.
  let %buf = bb.push_byte(%buf, byte: op_else)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: key_local)
  // The callee expects its declared param type, which we pre-coerced into
  // the i64 key above. Reverse-coerce when the param type isn't already i64
  // so we hand the call exactly the type wasm needs.
  let %buf = unpack_key_to_param(buf: %buf, param_type: arg_type)
  // Note: param_type intentionally aliases arg_type — the call's argument
  // type IS the callee's param type after emit_internal_call_args coercion.
  let %buf = bb.push_byte(%buf, byte: op_call)
  let %buf = bb.push_uleb128(%buf, val: int_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_tee)
  let %buf = bb.push_uleb128(%buf, val: val_local)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: val_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: key_local)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: key_idx)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: valid_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: val_local)

  // end of if
  return bb.push_byte(%buf, byte: op_end)
end

/** Identity since only i64/IntLit pass eligibility. Kept as a seam for */
/** widening + reverse-coerce when other key types open up. */
let unpack_key_to_param = fn (buf: %ByteBuffer, param_type: TypeExpr) -> %ByteBuffer do
  match wdefs.peel_linear(typ: param_type) do
    | TyI64 -> return %buf
    | TyIntLit -> return %buf
    | _ -> return %buf
  end
end

let emit_external_call = fn (func: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx,
                               ext_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match wdefs.find_external(name: func, exts: wdefs.ctx_externals(ctx)) do
    | Some(val: LirExternal(name: _, wasm_module: m, wasm_name: _, params, ret_type: rt, throw_row: _)) ->
      let canonical_str_ret = str.contains(s: m, sub: ":")
        && m != "nexus:intrinsic"
        && !str.starts_with(s: m, prefix: "nexus:runtime/")
        && !str.starts_with(s: m, prefix: "nexus:std/")
        && (match wdefs.peel_linear(typ: rt) do | TyString -> true | _ -> false end)
      let %buf = if canonical_str_ret then
        // Allocate an 8-byte retptr (always 8-aligned) for the canonical
        // string return, off the unified atomic bump cell.
        // i32 temp locals: temps_base+6=retptr, +7=tmp_ptr, +8=tmp_len.
        let retptr_local = wdefs.ctx_temps_base(ctx) + 6
        let %buf = bb.push_byte(%buf, byte: op_i32_const)
        let %buf = bb.push_sleb128(%buf, val: 8)
        emit_atomic_bump(%buf, ctx, ptr_local: retptr_local)
      else %buf end
      let %buf = emit_external_call_args(%buf, args, params, ctx)
      // For canonical string return: push retptr as last argument
      let %buf = if canonical_str_ret then
        let retptr_local = wdefs.ctx_temps_base(ctx) + 6
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        bb.push_uleb128(%buf, val: retptr_local)
      else %buf end
      let %buf = bb.push_byte(%buf, byte: op_call)
      let %buf = bb.push_uleb128(%buf, val: ext_idx)
      // For canonical string return: read (ptr, len) from retptr and pack to i64
      let %buf = if canonical_str_ret then
        let retptr_local = wdefs.ctx_temps_base(ctx) + 6
        let tmp_ptr = wdefs.ctx_temps_base(ctx) + 7
        let tmp_len = wdefs.ctx_temps_base(ctx) + 8
        // Load ptr (i32) from retptr+0
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        let %buf = bb.push_uleb128(%buf, val: retptr_local)
        let %buf = bb.push_byte(%buf, byte: op_i32_load)
        let %buf = bb.push_byte(%buf, byte: 2)
        let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
        let %buf = bb.push_byte(%buf, byte: op_local_set)
        let %buf = bb.push_uleb128(%buf, val: tmp_ptr)
        // Load len (i32) from retptr+4
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        let %buf = bb.push_uleb128(%buf, val: retptr_local)
        let %buf = bb.push_byte(%buf, byte: op_i32_load)
        let %buf = bb.push_byte(%buf, byte: 2)
        let %buf = bb.push_uleb128(%buf, val: 4)
        let %buf = bb.push_byte(%buf, byte: op_local_set)
        let %buf = bb.push_uleb128(%buf, val: tmp_len)
        // Pack: (ptr_i64 << 32) | len_i64
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        let %buf = bb.push_uleb128(%buf, val: tmp_ptr)
        let %buf = bb.push_bytes(%buf, bytes: [op_i64_extend_i32_u, op_i64_const])
        let %buf = bb.push_sleb128(%buf, val: 32)
        let %buf = bb.push_bytes(%buf, bytes: [op_i64_shl, op_local_get])
        let %buf = bb.push_uleb128(%buf, val: tmp_len)
        let %buf = bb.push_byte(%buf, byte: op_i64_extend_i32_u)
        bb.push_byte(%buf, byte: op_i64_or)
      else %buf end
      return %buf
    | None ->
      raise SymbolNotFound(name: func, kind: "function", context: "external call")
      return %buf
  end
end

/** The unified intrinsic dispatch: one table keyed on the kebab-cased */
/** `wasm_name` (`wit_canonical_name` strips the `__nx_` prefix and converts */
/** underscores to hyphens). Every `nexus:intrinsic` external — across the */
/** former arena / memory / math / simd / atomic / cast / lazy domains — flows */
/** through here. Each arm just calls the matching `emit_*` helper; no nested */
/** `let`/`if` (the Nexus parser collapses `else if` only inside one chain, so */
/** nesting double-nests past what chain-collapsing can close — see merge.nx */
/** rw_instrs comment for the same constraint). */
let emit_intrinsic = fn (name: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  if name == "heap-mark" then return emit_heap_mark(%buf)
  else if name == "heap-reset" then return emit_heap_reset(args, %buf, ctx)
  else if name == "heap-swap" then return emit_heap_swap(args, %buf, ctx)
  else if name == "alloc-raw" then return emit_alloc_raw(args, %buf, ctx)
  else if name == "mem-load-i32" then return emit_mem_load_i32(args, %buf, ctx)
  else if name == "mem-store-i32" then return emit_mem_store_i32(args, %buf, ctx)
  else if name == "mem-load-u8" then return emit_mem_load_u8(args, %buf, ctx)
  else if name == "mem-store-u8" then return emit_mem_store_u8(args, %buf, ctx)
  else if name == "mem-load-i64" then return emit_mem_load_i64(args, %buf, ctx)
  else if name == "mem-store-i64" then return emit_mem_store_i64(args, %buf, ctx)
  else if name == "mem-load-f32" then return emit_mem_load_f32(args, %buf, ctx)
  else if name == "mem-store-f32" then return emit_mem_store_f32(args, %buf, ctx)
  else if name == "mem-load-f64" then return emit_mem_load_f64(args, %buf, ctx)
  else if name == "mem-store-f64" then return emit_mem_store_f64(args, %buf, ctx)
  else if name == "mem-size" then return emit_mem_size(%buf)
  else if name == "mem-grow" then return emit_mem_grow(args, %buf, ctx)
  else if name == "atomic-rmw-add-i32" then return emit_atomic_rmw_add_i32(args, %buf, ctx)
  else if name == "atomic-load-i32" then return emit_atomic_load_i32(args, %buf, ctx)
  else if name == "atomic-store-i32" then return emit_atomic_store_i32(args, %buf, ctx)
  else if name == "atomic-cmpxchg-i32" then return emit_atomic_cmpxchg_i32(args, %buf, ctx)
  else if name == "atomic-wait32" then return emit_atomic_wait32(args, %buf, ctx)
  else if name == "atomic-notify" then return emit_atomic_notify(args, %buf, ctx)
  else if name == "cast-to-i32" then return emit_cast_to_i32(args, %buf, ctx)
  else if name == "cast-to-i64" then return emit_cast_to_i64(args, %buf, ctx)
  else if name == "force-closure" then return emit_force_closure(args, %buf, ctx)
  else if name == "thunk-addr" then return emit_lazy_passthrough(args, %buf, ctx)
  else if name == "value-of-i64" then return emit_lazy_passthrough(args, %buf, ctx)
  else if name == "array-length" then return emit_array_length(args, %buf, ctx)
  else if name == "f64-sqrt" then return emit_f64_unary(opcode: op_f64_sqrt, args, %buf, ctx, name: "__nx_f64_sqrt")
  else if name == "f64-floor" then return emit_f64_unary(opcode: op_f64_floor, args, %buf, ctx, name: "__nx_f64_floor")
  else if name == "f64-ceil" then return emit_f64_unary(opcode: op_f64_ceil, args, %buf, ctx, name: "__nx_f64_ceil")
  else if name == "f64-abs" then return emit_f64_unary(opcode: op_f64_abs, args, %buf, ctx, name: "__nx_f64_abs")
  else if name == "simd-f32x4-add" then return emit_simd_binop_one(sub_op: op_simd_f32x4_add, args, %buf, ctx, name: "__nx_simd_f32x4_add")
  else if name == "simd-f32x4-mul" then return emit_simd_binop_one(sub_op: op_simd_f32x4_mul, args, %buf, ctx, name: "__nx_simd_f32x4_mul")
  else if name == "simd-f64x2-add" then return emit_simd_binop_one(sub_op: op_simd_f64x2_add, args, %buf, ctx, name: "__nx_simd_f64x2_add")
  else if name == "simd-f64x2-mul" then return emit_simd_binop_one(sub_op: op_simd_f64x2_mul, args, %buf, ctx, name: "__nx_simd_f64x2_mul")
  else if name == "simd-i32x4-add" then return emit_simd_binop_one(sub_op: op_simd_i32x4_add, args, %buf, ctx, name: "__nx_simd_i32x4_add")
  else if name == "simd-i32x4-mul" then return emit_simd_binop_one(sub_op: op_simd_i32x4_mul, args, %buf, ctx, name: "__nx_simd_i32x4_mul")
  else if name == "simd-i64x2-add" then return emit_simd_binop_one(sub_op: op_simd_i64x2_add, args, %buf, ctx, name: "__nx_simd_i64x2_add")
  else if name == "simd-i64x2-mul" then return emit_simd_binop_one(sub_op: op_simd_i64x2_mul, args, %buf, ctx, name: "__nx_simd_i64x2_mul")
  else if name == "simd-f32x4-add-array" then return emit_simd_binop_array(sub_op: op_simd_f32x4_add, args, %buf, ctx, name: "__nx_simd_f32x4_add_array")
  else if name == "simd-f64x2-add-array" then return emit_simd_binop_array(sub_op: op_simd_f64x2_add, args, %buf, ctx, name: "__nx_simd_f64x2_add_array")
  else if name == "simd-i32x4-add-array" then return emit_simd_binop_array(sub_op: op_simd_i32x4_add, args, %buf, ctx, name: "__nx_simd_i32x4_add_array")
  else if name == "simd-i64x2-add-array" then return emit_simd_binop_array(sub_op: op_simd_i64x2_add, args, %buf, ctx, name: "__nx_simd_i64x2_add_array")
  else if name == "simd-f32x4-mul-array" then return emit_simd_binop_array(sub_op: op_simd_f32x4_mul, args, %buf, ctx, name: "__nx_simd_f32x4_mul_array")
  else if name == "simd-f64x2-mul-array" then return emit_simd_binop_array(sub_op: op_simd_f64x2_mul, args, %buf, ctx, name: "__nx_simd_f64x2_mul_array")
  else if name == "simd-i32x4-mul-array" then return emit_simd_binop_array(sub_op: op_simd_i32x4_mul, args, %buf, ctx, name: "__nx_simd_i32x4_mul_array")
  else if name == "simd-i64x2-mul-array" then return emit_simd_binop_array(sub_op: op_simd_i64x2_mul, args, %buf, ctx, name: "__nx_simd_i64x2_mul_array")
  else if name == "simd-f32x4-sub-array" then return emit_simd_binop_array(sub_op: op_simd_f32x4_sub, args, %buf, ctx, name: "__nx_simd_f32x4_sub_array")
  else if name == "simd-f64x2-sub-array" then return emit_simd_binop_array(sub_op: op_simd_f64x2_sub, args, %buf, ctx, name: "__nx_simd_f64x2_sub_array")
  else if name == "simd-i32x4-sub-array" then return emit_simd_binop_array(sub_op: op_simd_i32x4_sub, args, %buf, ctx, name: "__nx_simd_i32x4_sub_array")
  else if name == "simd-i64x2-sub-array" then return emit_simd_binop_array(sub_op: op_simd_i64x2_sub, args, %buf, ctx, name: "__nx_simd_i64x2_sub_array")
  else if name == "simd-f32x4-div-array" then return emit_simd_binop_array(sub_op: op_simd_f32x4_div, args, %buf, ctx, name: "__nx_simd_f32x4_div_array")
  else if name == "simd-f64x2-div-array" then return emit_simd_binop_array(sub_op: op_simd_f64x2_div, args, %buf, ctx, name: "__nx_simd_f64x2_div_array")
  else if name == "bt-depth" then return emit_bt_depth(%buf)
  else if name == "bt-frame" then return emit_bt_frame(args, %buf, ctx)
  else if name == "capture-backtrace" then return emit_capture_backtrace(args, %buf, ctx)
  else
    raise SymbolNotFound(name, kind: "intrinsic", context: "emit_intrinsic")
    return %buf
  end
end

let emit_call = fn (func: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx,
                     is_tail: bool, in_try: bool) -> %ByteBuffer throws { CodegenError } do
  // `nexus:intrinsic` externals: emit inline WASM, no function call. Resolve
  // the dispatch key (the external's kebab-cased wasm_name) and hand off to
  // emit_intrinsic. The sched intrinsics keep their own func+exts-shaped
  // recognisers (they consult the externals list for the host run-queue
  // imports), so they stay separate arms in this flat else-if chain.
  let exts = wdefs.ctx_externals(ctx)
  let intr_wn = get_intrinsic_wasm_name(func, exts)
  if func == "__array_get" then return emit_array_get(args, %buf, ctx)
  else if func == "__array_set" then return emit_array_set(args, %buf, ctx)
  else if intr_wn != "" then return emit_intrinsic(name: intr_wn, args, %buf, ctx)
  else if is_sched_set_next(func, exts) then return emit_sched_set_next(args, %buf, ctx)
  else if is_sched_spawn(func, exts) then return emit_sched_spawn(args, %buf, ctx)
  else
    let CodegenCtx(internal_func_map: ifm, external_func_map: efm, _) = ctx
    let int_idx = wdefs.lookup_func_fast(name: func, map: &ifm)
    if int_idx >= 0 then
      return emit_internal_call(func, args, %buf, ctx, is_tail, in_try, int_idx)
    else
      let ext_idx = wdefs.lookup_func_fast(name: func, map: &efm)
      if ext_idx >= 0 then
        return emit_external_call(func, args, %buf, ctx, ext_idx)
      else
        raise SymbolNotFound(name: func, kind: "function", context: "emit_call")
      end
    end
  end
end

// ─── Closure helpers ────────────────────────────────────────────────────────

/** Returns the table index (position) for a closure function name. */
let lookup_closure_table_idx = fn (name: string, entries: [FuncEntry]) -> i64 throws { CodegenError } do
  return lookup_closure_table_idx_go(name, entries, pos: 0)
end

let lookup_closure_table_idx_go = fn (name: string, entries: [FuncEntry], pos: i64) -> i64 throws { CodegenError } do
  match entries do
    | [] -> return -1
    | FuncEntry(name: n, index: _) :: rest ->
      if n == name then return pos
      else return lookup_closure_table_idx_go(name, entries: rest, pos: pos + 1)
      end
  end
end

/** Look up the type section index for a closure call with the given arity. */
let lookup_closure_type_idx_pairs = fn (arity: i64, pairs: [ArityTypeIdx]) -> i64 throws { CodegenError } do
  match pairs do
    | [] -> raise SymbolNotFound(name: str.from_i64(val: arity), kind: "closure arity", context: "lookup_closure_type_idx_pairs")
    | ArityTypeIdx(arity: a, type_idx: ti) :: rest ->
      if a == arity then return ti
      else return lookup_closure_type_idx_pairs(arity, pairs: rest)
      end
  end
end

let emit_closure_captures = fn (buf: %ByteBuffer, caps: [LirAtom], ctx: CodegenCtx, obj_ptr: i64, field_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match caps do
    | [] -> %buf
    | a :: rest ->
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = emit_typed_field_store(typ: wdefs.atom_type(atom: a), %buf, offset: field_idx * 8)
      emit_closure_captures(%buf, caps: rest, ctx, obj_ptr, field_idx: field_idx + 1)
  end
end

let emit_closure_call_args = fn (buf: %ByteBuffer, args: [LirCallArg], ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | [] -> %buf
    | LirCallArg(label: _, value: a) :: rest ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = emit_pack_to_i64(typ: wdefs.atom_type(atom: a), %buf)
      emit_closure_call_args(%buf, args: rest, ctx)
  end
end

// ─── Expression emission ────────────────────────────────────────────────────

let emit_expr = fn (expr: LirExpr, buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool) -> %ByteBuffer throws { CodegenError } do
  match expr do
    | LirExprAtom(atom: a) -> emit_atom(atom: a, %buf, ctx)

    | LirExprBinary(op, lhs: l, rhs: r, typ: t) ->
      if is_string_concat_op(op, typ: t) then
        return emit_string_concat(lhs: l, rhs: r, %buf, ctx)
      end
      if is_string_op(op, lhs_type: wdefs.atom_type(atom: l), rhs_type: wdefs.atom_type(atom: r)) then
        return emit_string_compare(op, lhs: l, rhs: r, %buf, ctx)
      end
      let lhs_type = wdefs.atom_type(atom: l)
      let rhs_type = wdefs.atom_type(atom: r)
      let op_type = binary_operand_type(op, lhs_type, rhs_type)
      let %buf = emit_atom(atom: l, %buf, ctx)
      let %buf = emit_coercion(from_type: lhs_type, to_type: op_type, %buf)
      let %buf = emit_atom(atom: r, %buf, ctx)
      let %buf = emit_coercion(from_type: rhs_type, to_type: op_type, %buf)
      return emit_binary(op, operand_type: op_type, %buf)

    | LirExprCall(func: fname, args, typ: _) ->
      emit_call(func: fname, args, %buf, ctx, is_tail: false, in_try)

    | LirExprTailCall(func: fname, args, typ: _) ->
      emit_call(func: fname, args, %buf, ctx, is_tail: true, in_try)

    | LirExprConstructor(name: cname, args: cargs, typ: _) ->
      let arity = list.length(xs: cargs)
      let tag = wdefs.constructor_tag(name: cname, arity)
      let %buf = emit_alloc_object(%buf, ctx, words: 1 + arity)
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: tag)
      let %buf = bb.push_byte(%buf, byte: op_i64_store)
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = emit_constructor_fields(%buf, args: cargs, ctx, obj_ptr, field_idx: 1)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)

    | LirExprRecord(fields, typ: _) ->
      let names = extract_field_names(fields)
      let tag = wdefs.record_tag(sorted_names: names)
      let n_fields = list.length(xs: fields)
      let %buf = emit_alloc_object(%buf, ctx, words: 1 + n_fields)
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: tag)
      let %buf = bb.push_byte(%buf, byte: op_i64_store)
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = emit_record_fields(%buf, fields, ctx, obj_ptr, field_idx: 1)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      // Array shape (numeric field names "0".."n-1"): emit packed
      // `(ptr<<32) | len` matching emit_external_arg(TyArray)'s unpack.
      // Plain records: zero-extend ptr to i64 (upper 32 = 0).
      if is_array_record(fields) then
        let %buf = bb.push_byte(%buf, byte: op_i64_extend_i32_u)
        let %buf = bb.push_byte(%buf, byte: op_i64_const)
        let %buf = bb.push_sleb128(%buf, val: 32)
        let %buf = bb.push_byte(%buf, byte: op_i64_shl)
        let %buf = bb.push_byte(%buf, byte: op_i64_const)
        let %buf = bb.push_sleb128(%buf, val: n_fields)
        return bb.push_byte(%buf, byte: op_i64_or)
      else
        return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
      end

    | LirExprObjectTag(value: v, typ: _) ->
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      return wdefs.emit_memarg_i64(%buf, offset: 0)

    | LirExprObjectField(value: v, index: idx, typ: ftyp) ->
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      return emit_typed_field_load(typ: ftyp, %buf, offset: (idx + 1) * 8)

    | LirExprRaise(value: v, typ: _) ->
      // Per-function backtrace capture (issue nexus-55x0). Emit a `call`
      // to the imported `__nx_main_wrap_bt_capture` immediately before
      // `op_throw` so the host can snapshot the wasm call stack before
      // unwinding. bt_capture_idx is -1 when the enclosing function's
      // EffectMap entry has can_throw=false or when the capture import
      // was never resolved (no main_wrap fired).
      let CodegenCtx(bt_capture_idx: bt_capture_idx, _) = ctx
      let %buf = if bt_capture_idx >= 0 then
        let %b = bb.push_byte(%buf, byte: op_call)
        bb.push_uleb128(buf: %b, val: bt_capture_idx)
      else %buf end
      let %buf = emit_atom(atom: v, %buf, ctx)
      // Unit-typed raise: push i64(0) as payload
      let %buf = if wdefs.is_unit(typ: wdefs.atom_type(atom: v)) then
        let %b = bb.push_byte(%buf, byte: op_i64_const)
        bb.push_sleb128(buf: %b, val: 0)
      else %buf end
      let %buf = bb.push_byte(%buf, byte: op_throw)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      return %buf

    | LirExprForce(value: v, typ: _) ->
      // Force a lazy value: invoke the 0-arg thunk closure via call_indirect.
      // Mirror of LirExprCallClosure with n_args = 0 (env only).
      let %buf = emit_atom(atom: v, %buf, ctx)
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_call_indirect])
      let CodegenCtx(closure_type_indices: cti, _) = ctx
      let type_idx = lookup_closure_type_idx_pairs(arity: 0, pairs: cti)
      let %buf = bb.push_uleb128(%buf, val: type_idx)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      return %buf

    | LirExprMakeClosure(func_name: fname, captures: caps, typ: _) ->
      // Allocate (1 + n_captures) words on heap
      let n_caps = list.length(xs: caps)
      let %buf = emit_alloc_object(%buf, ctx, words: 1 + n_caps)
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      // Store table_idx at offset 0
      let CodegenCtx(closure_table: ctab, _) = ctx
      let table_idx = lookup_closure_table_idx(name: fname, entries: ctab)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: table_idx)
      let %buf = bb.push_byte(%buf, byte: op_i64_store)
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      // Store captures at offset 8, 16, ...
      let %buf = emit_closure_captures(%buf, caps, ctx, obj_ptr, field_idx: 1)
      // Result: obj_ptr as i64
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)

    | LirExprCallClosure(closure: clos, args: cargs, typ: _) ->
      // Push env (closure pointer) as first arg
      let %buf = emit_atom(atom: clos, %buf, ctx)
      // Push actual args (packed to i64)
      let %buf = emit_closure_call_args(%buf, args: cargs, ctx)
      // Load table_idx from "closure"
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = emit_atom(atom: clos, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      // call_indirect: type_idx, table 0
      let n_args = list.length(xs: cargs)
      let CodegenCtx(closure_type_indices: cti, _) = ctx
      let type_idx = lookup_closure_type_idx_pairs(arity: n_args, pairs: cti)
      let %buf = bb.push_byte(%buf, byte: op_call_indirect)
      let %buf = bb.push_uleb128(%buf, val: type_idx)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      return %buf

    | LirExprSuspend(tag_name: tn, payload: p, typ: t) ->
      let %buf = emit_atom(atom: p, %buf, ctx)
      let %buf = if wdefs.is_unit(typ: wdefs.atom_type(atom: p)) then
        let %b = bb.push_byte(%buf, byte: op_i64_const)
        bb.push_sleb128(buf: %b, val: 0)
      else %buf end
      let %buf = bb.push_byte(%buf, byte: op_suspend)
      // Multi-arm dispatch: each `<port>::<method>` gets its own wasm tag.
      // ss_base = the wasm tag index of the FIRST stack-switching tag (after
      // the optional EH tag); offset = position of `tn` in `ss_tag_names`.
      let CodegenCtx(ss_tag_idx: ss_base, ss_tag_names: tns, _) = ctx
      let tag_offset = wcollect.lookup_tag_idx(tag_name: tn, tag_names: tns)
      if tag_offset < 0 then
        raise SymbolNotFound(name: tn, kind: "suspend tag", context: "LirExprSuspend tag missing in ss_tag_names")
      end
      let ss_idx = ss_base + tag_offset
      let %buf = bb.push_uleb128(%buf, val: ss_idx)
      // suspend's tag has no result types; if the expression's wasm type is
      // unit, leave the value-stack alone. Otherwise push an i64 0 placeholder
      // — replaced by the resume-site's value when LirExprResume codegen lands.
      if wdefs.is_unit(typ: t) then return %buf end
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 0)
      return %buf
    | LirExprResume(cont: c, value: _, typ: _) ->
      let %buf = emit_atom(atom: c, %buf, ctx)
      let %buf = bb.push_byte(buf: %buf, byte: op_global_set)
      let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_resume_slot_global_idx)
      return %buf
    | LirExprContNew(_) -> raise StackSwitchingNotImplemented(node: "cont.new")
    | LirExprInjectResume(body_fn: bfn, arm_fns: afs, arm_tags: ats, typ: _) ->
      return emit_inject_resume_multi(buf: %buf, body_fn: bfn, arm_fns: afs, arm_tags: ats, ctx)
  end
end

/** Multi-arm InjectResume frame. */
/** */
/** Layout for N=2 arms (innermost = arm 0): */
/** */
/**   block @outer */
/**     setup body cont; resume_slot = next_alloc; next_alloc++ */
/**     loop @loop */
/**       block @arm_1 (type dispatch_t_idx) */
/**         block @arm_0 (type dispatch_t_idx) */
/**           resume cont_t (on tag_0 @arm_0) (on tag_1 @arm_1) */
/**           br 3       ;; resume returned normally → exit @outer (depth N+1) */
/**         end */
/**         ;; tag_0 caught: dispatch arm 0 with [payload, contref] */
/**         br 1         ;; back to @loop (depth N - 0 - 1 = 1) */
/**       end */
/**       ;; tag_1 caught */
/**       br 0           ;; back to @loop (depth N - 1 - 1 = 0) */
/**     end */
/**   end */
/** */
/** Every match arm uses explicit `return` (defensive against an earlier */
/** bootstrap-self-compile hang whose root cause was never nailed; uniform */
/** returns sidestep whatever Nexus runtime pattern was responsible). */
let emit_inject_resume_multi = fn (buf: %ByteBuffer, body_fn: string, arm_fns: [string],
                                    arm_tags: [string], ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  let CodegenCtx(internal_func_map: ifm, ss_cont_type_idx: cont_t_idx,
                  ss_dispatch_block_type_idx: dispatch_t_idx, ss_tag_idx: ss_base,
                  ss_tag_names: tag_names, _) = ctx
  let body_idx = wdefs.lookup_func_fast(name: body_fn, map: &ifm)
  let n_arms_raw = list.length(xs: arm_fns)
  // Phase-2 fallback: arm_tags may be empty (legacy MIR path). Force a
  // single-on-clause shape so the dispatcher remains valid; first arm gets
  // tag 0. arm_fns must have at least one entry (InjectResume is only
  // constructed when at least one with-kont arm exists).
  let n_arms = if n_arms_raw == 0 then 1 else n_arms_raw end

  // @outer
  let %buf = bb.push_byte(buf: %buf, byte: op_block)
  let %buf = bb.push_byte(buf: %buf, byte: bt_void)

  // Body cont setup
  let %buf = bb.push_byte(buf: %buf, byte: op_global_get)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_wrap_i64)
  let %buf = bb.push_byte(buf: %buf, byte: op_ref_func)
  let %buf = bb.push_uleb128(buf: %buf, val: body_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_cont_new)
  let %buf = bb.push_uleb128(buf: %buf, val: cont_t_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_table_set)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_cont_table_idx)

  let %buf = bb.push_byte(buf: %buf, byte: op_global_get)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_global_set)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_resume_slot_global_idx)

  let %buf = bb.push_byte(buf: %buf, byte: op_global_get)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_i64_const)
  let %buf = bb.push_sleb128(buf: %buf, val: 1)
  let %buf = bb.push_byte(buf: %buf, byte: op_i64_add)
  let %buf = bb.push_byte(buf: %buf, byte: op_global_set)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_next_alloc_global_idx)

  // @loop
  let %buf = bb.push_byte(buf: %buf, byte: op_loop)
  let %buf = bb.push_byte(buf: %buf, byte: bt_void)

  // N nested arm blocks (outermost first)
  let %buf = open_nested_arm_blocks(buf: %buf, dispatch_t_idx, n: n_arms)

  // resume + on-clauses
  let %buf = bb.push_byte(buf: %buf, byte: op_global_get)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_resume_slot_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_wrap_i64)
  let %buf = bb.push_byte(buf: %buf, byte: op_table_get)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_cont_table_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_resume)
  let %buf = bb.push_uleb128(buf: %buf, val: cont_t_idx)
  let %buf = bb.push_uleb128(buf: %buf, val: n_arms)
  let %buf = emit_arm_on_clauses(buf: %buf, arm_tags, ss_base, tag_names, n_arms, idx: 0)

  // Normal-return path. The naive `br N+1` (exit dispatcher) prematurely
  // strands queued fibers when the spawner cont (main's body) finishes
  // first — bes5 Q3 termination. Instead: dequeue the next runnable; if
  // queue empty (sched-dequeue returns -1), THEN exit. Otherwise set
  // resume_slot and br back to @loop so the fibers drain.
  let dequeue_idx = find_sched_import_idx(wn: "sched-dequeue", exts: wdefs.ctx_externals(ctx), idx: 0)
  let %buf = if dequeue_idx >= 0 then
    let tmp_local = wdefs.ctx_temps_base(ctx) + 5
    let %b = bb.push_byte(buf: %buf, byte: op_call)
    let %b = bb.push_uleb128(buf: %b, val: dequeue_idx)
    let %b = bb.push_byte(buf: %b, byte: op_local_tee)
    let %b = bb.push_uleb128(buf: %b, val: tmp_local)
    let %b = bb.push_byte(buf: %b, byte: op_i64_const)
    let %b = bb.push_sleb128(buf: %b, val: 0)
    let %b = bb.push_byte(buf: %b, byte: op_i64_lt_s)
    let %b = bb.push_byte(buf: %b, byte: op_br_if)
    let %b = bb.push_uleb128(buf: %b, val: n_arms + 1)
    let %b = bb.push_byte(buf: %b, byte: op_local_get)
    let %b = bb.push_uleb128(buf: %b, val: tmp_local)
    let %b = bb.push_byte(buf: %b, byte: op_global_set)
    let %b = bb.push_uleb128(buf: %b, val: wdefs.ss_resume_slot_global_idx)
    let %b = bb.push_byte(buf: %b, byte: op_br)
    bb.push_uleb128(buf: %b, val: n_arms)
  else
    // No sched runtime imported (e.g., handler_with_kont_resume which uses
    // a hand-rolled handler with no global queue). Fall back to the simple
    // exit-on-normal-return path.
    let %b = bb.push_byte(buf: %buf, byte: op_br)
    bb.push_uleb128(buf: %b, val: n_arms + 1)
  end

  // Close arm blocks innermost first; emit per-arm dispatch + br to @loop
  let %buf = close_and_dispatch_arms(buf: %buf, arm_fns, n_arms, ctx, idx: 0)

  let %buf = bb.push_byte(buf: %buf, byte: op_end)  // close @loop
  return bb.push_byte(buf: %buf, byte: op_end)      // close @outer
end

let open_nested_arm_blocks = fn (buf: %ByteBuffer, dispatch_t_idx: i64, n: i64) -> %ByteBuffer throws { CodegenError } do
  if n <= 0 then return %buf end
  let %buf = bb.push_byte(buf: %buf, byte: op_block)
  let %buf = bb.push_sleb128(buf: %buf, val: dispatch_t_idx)
  return open_nested_arm_blocks(buf: %buf, dispatch_t_idx, n: n - 1)
end

/** Emit one `(on tag → label)` per arm. Arm `i` targets label depth `i` */
/** (innermost arm = depth 0). When arm_tags is empty (legacy single-arm */
/** path), fall through to ss_base for the only on-clause. */
let emit_arm_on_clauses = fn (buf: %ByteBuffer, arm_tags: [string],
                              ss_base: i64, tag_names: [string], n_arms: i64, idx: i64) -> %ByteBuffer throws { CodegenError } do
  if idx >= n_arms then return %buf end
  let tag_idx = match arm_tags do
    | [] -> ss_base
    | _ -> ss_base + arm_tag_offset_at(arm_tags, idx, tag_names)
  end
  let %buf = bb.push_byte(buf: %buf, byte: 0)
  let %buf = bb.push_uleb128(buf: %buf, val: tag_idx)
  let %buf = bb.push_uleb128(buf: %buf, val: idx)
  return emit_arm_on_clauses(buf: %buf, arm_tags, ss_base, tag_names, n_arms, idx: idx + 1)
end

let arm_tag_offset_at = fn (arm_tags: [string], idx: i64, tag_names: [string]) -> i64 throws { CodegenError } do
  let tn = nth_string(xs: arm_tags, idx)
  let off = wcollect.lookup_tag_idx(tag_name: tn, tag_names)
  if off < 0 then
    raise SymbolNotFound(name: tn, kind: "arm tag", context: "arm_tag_offset_at: tag missing in ss_tag_names")
  end
  return off
end

let nth_string = fn (xs: [string], idx: i64) -> string throws { CodegenError } do
  match xs do
    | [] -> raise SymbolNotFound(name: "<arm_tag>", kind: "arm tag index", context: "nth_string out of range")
    | x :: rest ->
      if idx <= 0 then return x end
      return nth_string(xs: rest, idx: idx - 1)
  end
end

let close_and_dispatch_arms = fn (buf: %ByteBuffer, arm_fns: [string], n_arms: i64,
                                   ctx: CodegenCtx, idx: i64) -> %ByteBuffer throws { CodegenError } do
  if idx >= n_arms then return %buf end
  let %buf = bb.push_byte(buf: %buf, byte: op_end)  // close arm `idx`'s block
  let arm_fn = nth_string(xs: arm_fns, idx)
  let %buf = emit_arm_dispatch(buf: %buf, arm_fn, ctx)
  let %buf = bb.push_byte(buf: %buf, byte: op_br)
  let %buf = bb.push_uleb128(buf: %buf, val: n_arms - idx - 1)
  return close_and_dispatch_arms(buf: %buf, arm_fns, n_arms, ctx, idx: idx + 1)
end

let emit_arm_dispatch = fn (buf: %ByteBuffer, arm_fn: string, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  let CodegenCtx(internal_func_map: ifm, _) = ctx
  let arm_idx = wdefs.lookup_func_fast(name: arm_fn, map: &ifm)
  if arm_idx < 0 then
    raise SymbolNotFound(name: arm_fn, kind: "arm function", context: "emit_arm_dispatch")
  end
  let arm_param_count = match wdefs.ctx_find_function(ctx, name: arm_fn) do
    | Some(val: LirFunction(name: _, params: ps, ret_type: _, body: _, ret: _, span: _)) -> list.length(xs: ps)
    | None -> 2
  end
  let temp_idx = wdefs.ctx_temps_base(ctx)
  let %buf = bb.push_byte(buf: %buf, byte: op_global_set)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_cont_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_set)
  let %buf = bb.push_uleb128(buf: %buf, val: temp_idx)

  let %buf = bb.push_byte(buf: %buf, byte: op_global_get)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_wrap_i64)
  let %buf = bb.push_byte(buf: %buf, byte: op_global_get)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_cont_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_table_set)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_cont_table_idx)

  let %buf = bb.push_byte(buf: %buf, byte: op_global_get)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = if arm_param_count >= 2 then
    let %bb = bb.push_byte(buf: %buf, byte: op_local_get)
    bb.push_uleb128(buf: %bb, val: temp_idx)
  else %buf end
  let %buf = bb.push_byte(buf: %buf, byte: op_call)
  let %buf = bb.push_uleb128(buf: %buf, val: arm_idx)

  let %buf = bb.push_byte(buf: %buf, byte: op_global_get)
  let %buf = bb.push_uleb128(buf: %buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_i64_const)
  let %buf = bb.push_sleb128(buf: %buf, val: 1)
  let %buf = bb.push_byte(buf: %buf, byte: op_i64_add)
  let %buf = bb.push_byte(buf: %buf, byte: op_global_set)
  return bb.push_uleb128(buf: %buf, val: wdefs.ss_next_alloc_global_idx)
end

let emit_if_return_unconditional = fn (buf: %ByteBuffer, then_body: [LirStmt], then_ret: LirAtom,
    ret_type: TypeExpr, ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { CodegenError } do
  let %buf = emit_stmts(stmts: then_body, %buf, ctx, in_try, tcmc)
  return emit_return_with_tcmc(%buf, ret_val: then_ret, ret_type, ctx, tcmc)
end

let emit_if_return_conditional = fn (buf: %ByteBuffer, cond: LirAtom, then_body: [LirStmt], then_ret: LirAtom,
    else_body: [LirStmt], else_ret: Option<LirAtom>, ret_type: TypeExpr,
    ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { CodegenError } do
  let %buf = emit_atom(atom: cond, %buf, ctx)
  let %buf = emit_coercion(from_type: wdefs.atom_type(atom: cond), to_type: TyBool, %buf)
  let %buf = bb.push_byte(%buf, byte: op_if)
  let %buf = bb.push_byte(%buf, byte: bt_void)
  let %buf = emit_stmts(stmts: then_body, %buf, ctx, in_try, tcmc)
  let %buf = emit_return_with_tcmc(%buf, ret_val: then_ret, ret_type, ctx, tcmc)
  let has_else = list.length(xs: else_body) > 0
  let has_else_ret = if let Some(_) = else_ret then true else false end
  let %buf = if has_else || has_else_ret then
    let %buf = bb.push_byte(%buf, byte: op_else)
    let %buf = emit_stmts(stmts: else_body, %buf, ctx, in_try, tcmc)
    match else_ret do
      | Some(val: a) -> emit_return_with_tcmc(%buf, ret_val: a, ret_type, ctx, tcmc)
      | None -> %buf
    end
  else %buf end
  return bb.push_byte(%buf, byte: op_end)
end

let is_unconditional_return = fn (cond: LirAtom, else_body: [LirStmt], else_ret: Option<LirAtom>) -> bool throws { CodegenError } do
  if let LirAtomBool(val: true) = cond then
    let has_else = list.length(xs: else_body) > 0
    let has_else_ret = if let Some(_) = else_ret then true else false end
    return !(has_else || has_else_ret)
  end
  return false
end

// ─── Statement emission (mutually recursive) ────────────────────────────────

let emit_stmt = fn (stmt: LirStmt, buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { CodegenError } do
  match stmt do
    | LirStmtLet(name: n, typ: t, expr: e) ->
      // TCMC interception: skip self-call, intercept constructor
      match tcmc do
        | TcmcActive(head_local: _, prev_local: _, rest_field_idx: _, call_var: cv,
                         cons_var: consv, call_args: _, ctor_name: _, ctor_args: _, func_name: _, loop_depth: _) ->
          if n == cv then
            if let LirExprCall(_) = e then return %buf end
          end
          if n == consv then
            if let LirExprConstructor(_) = e then
              return emit_tcmc_cons_and_loop(%buf, ctx, tcmc)
            end
          end
        | NoTcmc -> ()
      end
      let %buf = emit_expr(expr: e, %buf, ctx, in_try)
      let et = wdefs.expr_type(expr: e)
      if wdefs.is_unit(typ: t) then
        if !wdefs.is_unit(typ: et) then return bb.push_byte(%buf, byte: op_drop)
        else return %buf end
      else
        // If expr is Unit-typed but binding is not, emit a default value.
        // This happens for dead-code Let bindings where value comes from
        // explicit returns inside branches (if/match).
        let %buf = if wdefs.is_unit(typ: et) then
          emit_default_for_type(%buf, typ: t)
        else
          emit_coercion(from_type: et, to_type: t, %buf)
        end
        // Single-scan packed lookup folds the previous double linear scan
        // (issue nexus-m2xq). Layout: `(index << 32) | valtype`.
        let CodegenCtx(locals: locs, _) = ctx
        let packed = wdefs.lookup_local_packed(name: n, entries: locs)
        let idx = if packed < 0 then
          raise SymbolNotFound(name: n, kind: "local variable", context: "emit_stmt: let-binding target")
        else packed / 4294967296 end
        // Widen i32→i64 if local was widened due to type conflict
        let expr_vt = wdefs.type_to_valtype(typ: wdefs.peel_linear(typ: et))
        let local_vt = packed - idx * 4294967296
        let %buf = if expr_vt == vt_i32 && local_vt == vt_i64 then
          bb.push_byte(%buf, byte: op_i64_extend_i32_u)
        else %buf end
        let %buf = bb.push_byte(%buf, byte: op_local_set)
        return bb.push_uleb128(%buf, val: idx)
      end

    | LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let %buf = emit_atom(atom: c, %buf, ctx)
      let %buf = emit_coercion(from_type: wdefs.atom_type(atom: c), to_type: TyBool, %buf)
      let %buf = bb.push_byte(%buf, byte: op_if)
      let %buf = bb.push_byte(%buf, byte: bt_void)
      let inner_tcmc = tcmc_deeper(tcmc, n: 1)
      let %buf = emit_stmts(stmts: tb, %buf, ctx, in_try, tcmc: inner_tcmc)
      let %buf = if list.length(xs: eb) > 0 then
        let %buf = bb.push_byte(%buf, byte: op_else)
        emit_stmts(stmts: eb, %buf, ctx, in_try, tcmc: inner_tcmc)
      else %buf end
      return bb.push_byte(%buf, byte: op_end)

    | LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr, else_body: eb, else_ret: er, ret_type: rt) ->
      // Optimize: if cond is always true and no else, emit body directly (no if wrapper)
      if is_unconditional_return(cond: c, else_body: eb, else_ret: er) then
        return emit_if_return_unconditional(%buf, then_body: tb, then_ret: tr,
          ret_type: rt, ctx, in_try, tcmc)
      end
      let inner_tcmc = tcmc_deeper(tcmc, n: 1)
      return emit_if_return_conditional(%buf, cond: c, then_body: tb, then_ret: tr,
        else_body: eb, else_ret: er, ret_type: rt, ctx, in_try, tcmc: inner_tcmc)

    | LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      let inner_tcmc = tcmc_deeper(tcmc, n: 2)
      let %buf = bb.push_byte(%buf, byte: op_block)
      let %buf = bb.push_byte(%buf, byte: bt_void)
      let %buf = bb.push_byte(%buf, byte: op_loop)
      let %buf = bb.push_byte(%buf, byte: bt_void)
      let %buf = emit_stmts(stmts: cs, %buf, ctx, in_try, tcmc: inner_tcmc)
      let %buf = emit_atom(atom: c, %buf, ctx)
      let %buf = emit_coercion(from_type: wdefs.atom_type(atom: c), to_type: TyBool, %buf)
      let %buf = bb.push_byte(%buf, byte: op_br_if)
      let %buf = bb.push_uleb128(%buf, val: 1)
      let %buf = emit_stmts(stmts: b, %buf, ctx, in_try, tcmc: inner_tcmc)
      let %buf = bb.push_byte(%buf, byte: op_br)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      let %buf = bb.push_byte(%buf, byte: op_end)
      return bb.push_byte(%buf, byte: op_end)

    | LirStmtTryCatch(body: b, body_ret: br, catch_param: cp, catch_param_typ: _,
                          catch_body: cb, catch_ret: cr) ->
      let CodegenCtx(locals: locs, func_ret_type: ret_t, _) = ctx
      let catch_local_idx = wdefs.lookup_local(name: cp, entries: locs)

      // WASM EH: block $skip { block $catch (result i64) { try_table (catch tag0 $catch) { body } end; br 1 } end; catch body } end
      // Emit block $skip
      let %buf = bb.push_byte(%buf, byte: op_block)
      let %buf = bb.push_byte(%buf, byte: bt_void)
      // Emit block $catch (result i64)
      let %buf = bb.push_byte(%buf, byte: op_block)
      let %buf = bb.push_byte(%buf, byte: bt_i64)
      // Emit try_table (catch tag0 label0)
      let %buf = bb.push_byte(%buf, byte: op_try_table)
      let %buf = bb.push_byte(%buf, byte: bt_void)
      let %buf = bb.push_uleb128(%buf, val: 1)
      let %buf = bb.push_byte(%buf, byte: catch_kind_one)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)

      // Emit try body
      let %buf = emit_stmts(stmts: b, %buf, ctx, in_try: true, tcmc: NoTcmc)
      let %buf = match br do
        | Some(val: a) ->
          let %b = emit_atom(atom: a, %buf, ctx)
          let %b = emit_coercion(from_type: wdefs.atom_type(atom: a), to_type: ret_t, buf: %b)
          bb.push_byte(buf: %b, byte: op_return)
        | None -> %buf
      end
      let %buf = bb.push_byte(%buf, byte: op_end)

      // Try succeeded — skip catch
      let %buf = bb.push_byte(%buf, byte: op_br)
      let %buf = bb.push_uleb128(%buf, val: 1)
      let %buf = bb.push_byte(%buf, byte: op_end)

      // Catch body — i64 payload on stack from $catch block
      let %buf = if catch_local_idx >= 0 then
        let %buf = bb.push_byte(%buf, byte: op_local_set)
        bb.push_uleb128(%buf, val: catch_local_idx)
      else %buf end
      let %buf = emit_stmts(stmts: cb, %buf, ctx, in_try, tcmc: NoTcmc)
      let %buf = match cr do
        | Some(val: a) ->
          let %b = emit_atom(atom: a, %buf, ctx)
          let %b = emit_coercion(from_type: wdefs.atom_type(atom: a), to_type: ret_t, buf: %b)
          bb.push_byte(buf: %b, byte: op_return)
        | None -> %buf
      end
      return bb.push_byte(%buf, byte: op_end)

  end
end

let emit_stmts = fn (stmts: [LirStmt], buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { CodegenError } do
  match stmts do
    | [] -> %buf
    | s :: rest ->
      emit_stmts(stmts: rest, buf: emit_stmt(stmt: s, %buf, ctx, in_try, tcmc), ctx, in_try, tcmc)
  end
end

// ─── Function body compilation ──────────────────────────────────────────────

let emit_default_for_type = fn (buf: %ByteBuffer, typ: TypeExpr) -> %ByteBuffer throws { CodegenError } do
  let vt = wdefs.type_to_valtype(typ)
  if vt == vt_i32 then
    let %buf = bb.push_byte(%buf, byte: op_i32_const)
    return bb.push_sleb128(%buf, val: 0)
  end
  if vt == vt_f64 then
    let %buf = bb.push_byte(%buf, byte: op_f64_const)
    return bb.push_f64_str_le(%buf, s: "0.0")
  end
  let %buf = bb.push_byte(%buf, byte: op_i64_const)
  return bb.push_sleb128(%buf, val: 0)
end

let emit_return_value = fn (body: %ByteBuffer, rt: TypeExpr, r: LirAtom, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  if wdefs.is_unit(typ: rt) then return %body end
  let actual = match r do
    | LirAtomUnit -> emit_default_for_type(buf: %body, typ: rt)
    | _ ->
      let %body = emit_atom(atom: r, buf: %body, ctx)
      emit_coercion(from_type: wdefs.atom_type(atom: r), to_type: rt, buf: %body)
  end
  return actual
end

let compile_function_body = fn (func: LirFunction, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  let LirFunction(name: fname, params: ps, ret_type: raw_rt, body: b, ret: r, span: _) = func
  // Lifted lambdas (`__closure_N`) get a canonical (env+args of i64) -> i64
  // wasm signature regardless of the underlying lambda's return type. When
  // the body's implicit return is unit (e.g. wrapping `fiber1()` where
  // fiber1 returns unit), the body still has to push an i64 placeholder
  // before `end`. Inject bodies (`__inject_N`) and the sched trampoline
  // both go through the function-table elem segment for ref.func eligibility
  // but keep their source `() -> ()` signature, so this coercion does not
  // apply to them.
  let rt = if is_closure_lift(name: fname) && wdefs.is_unit(typ: raw_rt) then TyI64 else raw_rt end
  let %body = bb.empty()
  let CodegenCtx(locals: locs, _) = ctx
  let %body = wsect.emit_local_decls(buf: %body, locals: locs, param_count: list.length(xs: ps))

  // TCMC: detect pattern and set up locals
  let tcmc_raw = detect_tcmc(body: b, func_name: fname)
  let tcmc = match tcmc_raw do
    | NoTcmc -> NoTcmc
    | TcmcActive(head_local: _, prev_local: _, rest_field_idx: rfi, call_var: cv,
                     cons_var: consv, call_args: ca, ctor_name: cn, ctor_args: cta,
                     func_name: fn2, loop_depth: _) ->
      TcmcActive(head_local: wdefs.ctx_temps_base(ctx) + 13,
                  prev_local: wdefs.ctx_temps_base(ctx) + 14,
                  rest_field_idx: rfi, call_var: cv, cons_var: consv, call_args: ca,
                  ctor_name: cn, ctor_args: cta, func_name: fn2, loop_depth: 0)
  end

  // TCMC init (before loop, runs once)
  let %body = emit_tcmc_init(buf: %body, tcmc)
  // Wrap body in loop if TCMC detected
  let is_tcmc = match tcmc do | TcmcActive(_) -> true | NoTcmc -> false end
  let %body = if is_tcmc then
    let %body = bb.push_byte(buf: %body, byte: op_loop)
    bb.push_byte(buf: %body, byte: bt_void)
  else %body end

  let %body = emit_stmts(stmts: b, buf: %body, ctx, in_try: false, tcmc)

  let %body = if is_tcmc then
    bb.push_byte(buf: %body, byte: op_end)
  else %body end

  let %body = emit_return_value(%body, rt, r, ctx)
  bb.push_byte(buf: %body, byte: op_end)
end

/** cabi_realloc: bump allocator emitted alongside the canonical-ABI */
/** string-lift/lower path (currently dormant — see collect.needs_cabi_realloc). */
/** Bumps the unified atomic heap cell (`wdefs.heap_ptr_cell`); the cell always */
/** holds an 8-aligned value (every bump is a multiple of 8), which covers the */
/** canonical ABI's `align` (always <= 8), so the `align` parameter is ignored. */
/** Like emit_atomic_bump, it lazily seeds the cell via */
/** `cmpxchg(cell, 0, memory.size()*65536)` so it is correct even before any */
/** other allocation has run. Signature: */
/** `(orig_ptr i32, orig_size i32, align i32, new_size i32) -> i32`. */
let compile_cabi_realloc = fn (heap_base: i64) -> %ByteBuffer throws { CodegenError } do
  let _ = heap_base
  let %body = bb.empty()
  // 2 locals: rounded_size (i32) at idx 4, ptr (i32) at idx 5
  let %body = bb.push_uleb128(buf: %body, val: 1)
  let %body = bb.push_uleb128(buf: %body, val: 2)
  let %body = bb.push_byte(buf: %body, byte: vt_i32)
  // Idempotent seed: cmpxchg(cell, 0, memory.size()*65536); drop old.
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: wdefs.heap_ptr_cell)
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: 0)
  let %body = bb.push_byte(buf: %body, byte: op_memory_size)
  let %body = bb.push_byte(buf: %body, byte: 0)
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: 16)
  let %body = bb.push_byte(buf: %body, byte: wdefs.op_i32_shl)
  let %body = wdefs.emit_atomic_op32(buf: %body, sub_op: wdefs.op_i32_atomic_rmw_cmpxchg, offset: 0)
  let %body = bb.push_byte(buf: %body, byte: op_drop)
  // rounded_size = (new_size + 7) & ~8
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 3) // new_size
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: 7)
  let %body = bb.push_byte(buf: %body, byte: op_i32_add)
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: 0 - 8)
  let %body = bb.push_byte(buf: %body, byte: op_i32_and)
  let %body = bb.push_byte(buf: %body, byte: op_local_set)
  let %body = bb.push_uleb128(buf: %body, val: 4)
  // ptr = atomic.rmw.add(cell, rounded_size)
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: wdefs.heap_ptr_cell)
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 4)
  let %body = wdefs.emit_atomic_op32(buf: %body, sub_op: wdefs.op_i32_atomic_rmw_add, offset: 0)
  let %body = bb.push_byte(buf: %body, byte: op_local_set)
  let %body = bb.push_uleb128(buf: %body, val: 5)
  // new_top = ptr + rounded_size  (reuse idx 4)
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 5)
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 4)
  let %body = bb.push_byte(buf: %body, byte: op_i32_add)
  let %body = bb.push_byte(buf: %body, byte: op_local_set)
  let %body = bb.push_uleb128(buf: %body, val: 4)
  // if (new_top > memory.size * 65536) { memory.grow(ceil((new_top - mem_bytes)/65536)); drop }
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 4)
  let %body = bb.push_byte(buf: %body, byte: op_memory_size)
  let %body = bb.push_byte(buf: %body, byte: 0)
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: 16)
  let %body = bb.push_byte(buf: %body, byte: wdefs.op_i32_shl)
  let %body = bb.push_bytes(buf: %body, bytes: [wdefs.op_i32_gt_u, op_if])
  let %body = bb.push_byte(buf: %body, byte: bt_void)
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 4)
  let %body = bb.push_byte(buf: %body, byte: op_memory_size)
  let %body = bb.push_byte(buf: %body, byte: 0)
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: 16)
  let %body = bb.push_bytes(buf: %body, bytes: [wdefs.op_i32_shl, op_i32_sub])
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: 65535)
  let %body = bb.push_byte(buf: %body, byte: op_i32_add)
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: 16)
  let %body = bb.push_byte(buf: %body, byte: wdefs.op_i32_shr_u)
  let %body = bb.push_byte(buf: %body, byte: op_memory_grow)
  let %body = bb.push_byte(buf: %body, byte: 0)
  let %body = bb.push_byte(buf: %body, byte: op_drop)
  let %body = bb.push_byte(buf: %body, byte: op_end)
  // return ptr
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 5)
  return bb.push_byte(buf: %body, byte: op_end)
end

let find_func_by_suffix = fn (funcs: [LirFunction], map: &HashMap, suffix: string) -> i64 do
  match funcs do
    | [] -> return -1
    | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      if str.ends_with(s: n, suffix) then
        let idx = wdefs.lookup_func_fast(name: n, map)
        if idx >= 0 then return idx end
      end
      return find_func_by_suffix(funcs: rest, map, suffix)
  end
end

let compile_wasi_run_wrapper = fn (main_idx: i64, main_ret_type: TypeExpr,
    argv_idx: i64) -> %ByteBuffer throws { CodegenError } do
  let %body = bb.empty()
  let %body = bb.push_uleb128(buf: %body, val: 0)
  // If argv_idx >= 0, main takes args: call argv() first, pass result to main
  let %body = if argv_idx >= 0 then
    let %body = bb.push_byte(buf: %body, byte: op_call)
    bb.push_uleb128(buf: %body, val: argv_idx)
  else %body end
  let %body = bb.push_byte(buf: %body, byte: op_call)
  let %body = bb.push_uleb128(buf: %body, val: main_idx)
  let %body = if wdefs.is_unit(typ: main_ret_type) then
    %body
  else
    bb.push_byte(buf: %body, byte: op_drop)
  end
  return bb.push_byte(buf: %body, byte: op_end)
end

// ─── Code section / context building ────────────────────────────────────────

let build_param_locals = fn (params: [LirParam], idx: i64) -> [LocalEntry] throws { CodegenError } do
  return build_param_locals_go(params, idx, acc: [])
end
let build_param_locals_go = fn (params: [LirParam], idx: i64, acc: [LocalEntry]) -> [LocalEntry] throws { CodegenError } do
  match params do
    | [] -> return rev_local_entries(lst: acc, out: [])
    | LirParam(label: _, name: n, typ: t) :: rest ->
      return build_param_locals_go(params: rest, idx: idx + 1, acc: LocalEntry(name: n, index: idx, valtype: wdefs.type_to_valtype(typ: t)) :: acc)
  end
end

let build_func_ctx = fn (func: LirFunction, internal_funcs: [FuncEntry],
                          external_funcs: [FuncEntry], string_lits: [StringEntry],
                          alloc_mode: i64, functions: [LirFunction],
                          externals: [LirExternal],
                          closure_table: [FuncEntry],
                          closure_type_indices: [ArityTypeIdx],
                          internal_func_map: &HashMap,
                          external_func_map: &HashMap,
                          ss_tag_idx: i64,
                          ss_cont_type_idx: i64,
                          ss_dispatch_block_type_idx: i64,
                          ss_tag_names: [string],
                          bt_capture_idx: i64,
                          memo_target_names: [string],
                          memo_target_slots: [i64],
                          memo_globals_base: i64,
                          import_count: i64) -> CodegenCtx throws { CodegenError } do
  let LirFunction(name: fname, params: ps, ret_type: rt, body: b, ret: _, span: _) = func
  let param_locals = build_param_locals(params: ps, idx: 0)
  let param_count = list.length(xs: ps)
  let %local_map = wdefs.build_local_map(entries: param_locals)
  match wcollect.collect_local_stmts(stmts: b, locals: param_locals, next_idx: param_count, %local_map) do | LocalResult(locals: collected_locals, next_idx: collected_next_idx, local_map: lm) ->
  hmap.free(map: %lm)
  return CodegenCtx(
    locals: collected_locals, internal_funcs, external_funcs,
    string_lits, alloc_mode, temps_base: collected_next_idx,
    func_ret_type: rt, functions, externals,
    closure_table, closure_type_indices,
    internal_func_map, external_func_map,
    func_name: fname,
    ss_tag_idx: ss_tag_idx,
    ss_cont_type_idx: ss_cont_type_idx,
    ss_dispatch_block_type_idx: ss_dispatch_block_type_idx,
    ss_tag_names: ss_tag_names,
    bt_capture_idx: bt_capture_idx,
    memo_target_names,
    memo_target_slots,
    memo_globals_base,
    import_count
  )
  end
end

let append_body_to_buf = fn (buf: %ByteBuffer, body: %ByteBuffer) -> %ByteBuffer do
  let body_len = bb.length(buf: &body)
  let %buf = bb.push_uleb128(%buf, val: body_len)
  let %buf = bb.push_buf(dst: %buf, src: &body)
  bb.free(buf: %body)
  return %buf
end

/** Per-function backtrace-capture index for `func_name`. */
/** Returns -1 (= elide) when `bt_capture_idx_global == -1` (capture import */
/** absent from the program) or when the function's EffectMap entry says */
/** `can_throw == false` (issue nexus-55x0). Otherwise returns the import slot */
/** of `__nx_main_wrap_bt_capture` so emit_expr/LirExprRaise can call it. */
/** Exported so tests can exercise the elision rule directly without */
/** bringing up the full codegen pipeline. */
export let resolve_bt_capture_for_func = fn (func_name: string, effect_map: &EffectMap,
                                        bt_capture_idx_global: i64) -> i64 do
  if bt_capture_idx_global < 0 then return -1 end
  match lookup_bits(em: effect_map, name: func_name) do
    | Some(val: EffectBits(can_throw: ct, is_pure: _)) ->
      if ct then return bt_capture_idx_global end
      return -1
    | None ->
      // Function not in EffectMap (synthesised wrapper, etc.) — keep capture
      // emission enabled to preserve backtrace fidelity. EffectMap covers
      // every LirFunction in the program by construction, so a miss means
      // either a pre-LIR synthesised body or a stale lookup; both cases
      // sound on the conservative side.
      return bt_capture_idx_global
  end
end

let emit_one_body = fn (buf: %ByteBuffer, f: LirFunction,
                         internal_funcs: [FuncEntry], external_funcs: [FuncEntry],
                         string_lits: [StringEntry], alloc_mode: i64,
                         functions: [LirFunction], externals: [LirExternal],
                         closure_table: [FuncEntry],
                         closure_type_indices: [ArityTypeIdx],
                         internal_func_map: &HashMap,
                         external_func_map: &HashMap,
                         ss_tag_idx: i64,
                         ss_cont_type_idx: i64,
                         ss_dispatch_block_type_idx: i64,
                         ss_tag_names: [string],
                         effect_map: &EffectMap,
                         bt_capture_idx_global: i64,
                         memo_target_names: [string],
                         memo_target_slots: [i64],
                         memo_globals_base: i64,
                         import_count: i64) -> %ByteBuffer throws { CodegenError } do
  let LirFunction(name: fname, _) = f
  let bt_capture_idx = resolve_bt_capture_for_func(func_name: fname, effect_map,
                                                     bt_capture_idx_global)
  let ctx = build_func_ctx(func: f, internal_funcs,
                            external_funcs, string_lits,
                            alloc_mode, functions, externals,
                            closure_table, closure_type_indices,
                            internal_func_map, external_func_map,
                            ss_tag_idx: ss_tag_idx,
                            ss_cont_type_idx: ss_cont_type_idx,
                            ss_dispatch_block_type_idx: ss_dispatch_block_type_idx,
                            ss_tag_names: ss_tag_names,
                            bt_capture_idx: bt_capture_idx,
                            memo_target_names,
                            memo_target_slots,
                            memo_globals_base,
                            import_count)
  let %body = compile_function_body(func: f, ctx)
  return append_body_to_buf(%buf, %body)
end

let emit_code_bodies = fn (buf: %ByteBuffer, funcs: [LirFunction],
                            internal_funcs: [FuncEntry], external_funcs: [FuncEntry],
                            string_lits: [StringEntry], alloc_mode: i64,
                            functions: [LirFunction], externals: [LirExternal],
                            closure_table: [FuncEntry],
                            closure_type_indices: [ArityTypeIdx],
                            internal_func_map: &HashMap,
                            external_func_map: &HashMap,
                            ss_tag_idx: i64,
                            ss_cont_type_idx: i64,
                            ss_dispatch_block_type_idx: i64,
                            ss_tag_names: [string],
                            effect_map: &EffectMap,
                            bt_capture_idx_global: i64,
                            memo_target_names: [string],
                            memo_target_slots: [i64],
                            memo_globals_base: i64,
                            import_count: i64) -> %ByteBuffer throws { CodegenError } do
  match funcs do
    | [] -> return %buf
    | f :: rest ->
      let %buf = emit_one_body(%buf, f, internal_funcs,
                                external_funcs, string_lits,
                                alloc_mode, functions, externals,
                                closure_table, closure_type_indices,
                                internal_func_map, external_func_map,
                                ss_tag_idx: ss_tag_idx,
                                ss_cont_type_idx: ss_cont_type_idx,
                                ss_dispatch_block_type_idx: ss_dispatch_block_type_idx,
                                ss_tag_names: ss_tag_names,
                                effect_map: effect_map,
                                bt_capture_idx_global: bt_capture_idx_global,
                                memo_target_names,
                                memo_target_slots,
                                memo_globals_base,
                                import_count)
      return emit_code_bodies(%buf, funcs: rest, internal_funcs,
                        external_funcs, string_lits,
                        alloc_mode, functions, externals,
                        closure_table, closure_type_indices,
                        internal_func_map, external_func_map,
                        ss_tag_idx: ss_tag_idx,
                        ss_cont_type_idx: ss_cont_type_idx,
                        ss_dispatch_block_type_idx: ss_dispatch_block_type_idx,
                        ss_tag_names: ss_tag_names,
                        effect_map: effect_map,
                        bt_capture_idx_global: bt_capture_idx_global,
                        memo_target_names,
                        memo_target_slots,
                        memo_globals_base,
                        import_count)
  end
end

// ─── Module assembly ────────────────────────────────────────────────────────

let build_internal_func_entries = fn (funcs: [LirFunction], import_count: i64, idx: i64) -> [FuncEntry] throws { CodegenError } do
  return build_internal_func_entries_go(funcs, import_count, idx, acc: [])
end
let build_internal_func_entries_go = fn (funcs: [LirFunction], import_count: i64, idx: i64, acc: [FuncEntry]) -> [FuncEntry] throws { CodegenError } do
  match funcs do
    | [] -> return rev_func_entries(lst: acc, out: [])
    | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      return build_internal_func_entries_go(funcs: rest, import_count, idx: idx + 1, acc: FuncEntry(name: n, index: import_count + idx) :: acc)
  end
end

let build_external_func_entries = fn (exts: [LirExternal], idx: i64) -> [FuncEntry] throws { CodegenError } do
  return build_external_func_entries_go(exts, idx, acc: [])
end
let build_external_func_entries_go = fn (exts: [LirExternal], idx: i64, acc: [FuncEntry]) -> [FuncEntry] throws { CodegenError } do
  match exts do
    | [] -> return rev_func_entries(lst: acc, out: [])
    | LirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) :: rest ->
      return build_external_func_entries_go(exts: rest, idx: idx + 1, acc: FuncEntry(name: n, index: idx) :: acc)
  end
end

/** Locate the import slot for the backtrace-capture host function. Returns */
/** -1 when the symbol is absent (e.g. the program has no main_wrap-injected */
/** catch handler). The match is by Nexus-side symbol name so codegen does */
/** not need to know the kebab-cased wasm_name. */
let find_bt_capture_idx = fn (exts: [LirExternal]) -> i64 do
  return find_bt_capture_idx_go(exts, idx: 0)
end

let find_bt_capture_idx_go = fn (exts: [LirExternal], idx: i64) -> i64 do
  match exts do
    | [] -> return -1
    | LirExternal(name: n, _) :: rest ->
      if n == bt_capture_symbol_name() then return idx end
      return find_bt_capture_idx_go(exts: rest, idx: idx + 1)
  end
end

// ─── External deduplication ─────────────────────────────────────────────────
// Multiple Nexus names can point to the same WASM import (diamond imports).
// Deduplicate by (wasm_module, wasm_name), keeping only the first occurrence.
// Returns deduped ext list + FuncEntry remaps for duplicate names.

type DedupExtResult = DedupExtResult(exts: [LirExternal], remaps: [FuncEntry])

let find_ext_dedup_index = fn (exts: [LirExternal], wm: string, wn: string, idx: i64) -> i64 do
  match exts do
    | [] -> return -1
    | LirExternal(name: _, wasm_module: m, wasm_name: n, params: _, ret_type: _, throw_row: _) :: rest ->
      if m == wm && n == wn then return idx end
      return find_ext_dedup_index(exts: rest, wm, wn, idx: idx + 1)
  end
end

let rev_externals = fn (lst: [LirExternal], out: [LirExternal]) -> [LirExternal] do
  match lst do
    | [] -> out
    | x :: rest -> rev_externals(lst: rest, out: x :: out)
  end
end

let dedup_externals = fn (exts: [LirExternal]) -> DedupExtResult throws { CodegenError } do
  return dedup_externals_go(exts, deduped: [], remaps: [], dedup_idx: 0)
end

let dedup_externals_go = fn (exts: [LirExternal], deduped: [LirExternal], remaps: [FuncEntry], dedup_idx: i64) -> DedupExtResult throws { CodegenError } do
  match exts do
    | [] -> return DedupExtResult(exts: rev_externals(lst: deduped, out: []), remaps)
    | e :: rest ->
      let LirExternal(name: n, wasm_module: wm, wasm_name: wn, params: _, ret_type: _, throw_row: _) = e
      let existing = find_ext_dedup_index(exts: rev_externals(lst: deduped, out: []), wm, wn, idx: 0)
      if existing >= 0 then
        return dedup_externals_go(exts: rest, deduped, remaps: FuncEntry(name: n, index: existing) :: remaps, dedup_idx)
      else
        return dedup_externals_go(exts: rest, deduped: e :: deduped, remaps, dedup_idx: dedup_idx + 1)
      end
  end
end

let append_func_entries = fn (a: [FuncEntry], b: [FuncEntry]) -> [FuncEntry] do
  match a do
    | [] -> b
    | x :: rest -> x :: append_func_entries(a: rest, b)
  end
end

// ─── Closure analysis helpers ───────────────────────────────────────────────

/** Build closure table entries: maps table index → function index for __closure_* functions. */
let build_closure_table = fn (funcs: [LirFunction], internal_func_map: &HashMap, table_idx: i64) -> [FuncEntry] throws { CodegenError } do
  return build_closure_table_go(funcs, internal_func_map, table_idx, acc: [])
end
let build_closure_table_go = fn (funcs: [LirFunction], internal_func_map: &HashMap, table_idx: i64, acc: [FuncEntry]) -> [FuncEntry] throws { CodegenError } do
  match funcs do
    | [] -> return rev_func_entries(lst: acc, out: [])
    | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      if wdefs.is_closure_func(name: n) then
        let func_idx = wdefs.lookup_func_fast(name: n, map: internal_func_map)
        return build_closure_table_go(funcs: rest, internal_func_map, table_idx: table_idx + 1, acc: FuncEntry(name: n, index: func_idx) :: acc)
      end
      return build_closure_table_go(funcs: rest, internal_func_map, table_idx, acc)
  end
end

/** Insert a value into a sorted list, skipping if already present. O(K) per insert. */
let insert_sorted_i64 = fn (val: i64, xs: [i64]) -> [i64] throws { CodegenError } do
  return insert_sorted_i64_go(val, xs, acc: [])
end

let insert_sorted_i64_go = fn (val: i64, xs: [i64], acc: [i64]) -> [i64] throws { CodegenError } do
  match xs do
    | [] -> return rev_i64s(lst: acc, out: [val])
    | x :: rest ->
      if val == x then
        return rev_i64s(lst: acc, out: xs)
      end
      if val < x then
        return rev_i64s(lst: acc, out: val :: xs)
      end
      return insert_sorted_i64_go(val, xs: rest, acc: x :: acc)
  end
end

/** Get distinct closure arities from __closure_* functions. */
/** Arity = param count - 1 (subtract the __env param). */
/** Builds a sorted+deduped list in a single pass. Seeds arity 0 so */
/** `LirExprCallClosure(args: [])` and `LirExprForce` (lazy thunks) always */
/** resolve their `lookup_closure_type_idx_pairs(arity: 0)` lookup, even */
/** when no `__closure_*` wrapper or sched trampoline carries arity 0. */
let collect_closure_arities = fn (funcs: [LirFunction]) -> [i64] throws { CodegenError } do
  return collect_closure_arities_acc(funcs, acc: [0])
end

let collect_closure_arities_acc = fn (funcs: [LirFunction], acc: [i64]) -> [i64] throws { CodegenError } do
  match funcs do
    | [] -> acc
    | LirFunction(name: n, params: ps, ret_type: _, body: _, ret: _, span: _) :: rest ->
      // Only `__closure_*` and `__inject_*` carry the canonical
      // (env: i64, arg0..argN-1) -> i64 closure-call signature whose arity
      // must be registered in the type section. The sched trampoline is
      // `() -> ()` and uses a regular call_indirect against the existing
      // arity-0 closure type — its presence in the elem segment for ref.func
      // does not add a new arity entry, but its body forces arity 0 to be
      // present in the type table. A 0-arity closure call also forces arity
      // 0 even when no __closure_* wrapper carries it (e.g. `let f = pure_fn; f()`
      // where pure_fn is a top-level let bound to `fn () -> T`).
      if wdefs.is_sched_trampoline_func(name: n) then
        return collect_closure_arities_acc(funcs: rest, acc: insert_sorted_i64(val: 0, xs: acc))
      end
      if wdefs.is_closure_func(name: n) then
        let arity = list.length(xs: ps) - 1
        return collect_closure_arities_acc(funcs: rest, acc: insert_sorted_i64(val: arity, xs: acc))
      end
      return collect_closure_arities_acc(funcs: rest, acc)
  end
end

// ─── Name section (custom) ─────────────────────────────────────────────────

/** Build name subsection entries for external (imported) functions */
let emit_external_name_entries = fn (buf: %ByteBuffer, exts: [LirExternal], idx: i64) -> %ByteBuffer throws { CodegenError } do
  match exts do
    | [] -> return %buf
    | LirExternal(name: _, wasm_module: _, wasm_name: wn, params: _, ret_type: _, throw_row: _) :: rest ->
      let %buf = bb.push_uleb128(%buf, val: idx)
      let %buf = wdefs.emit_name(%buf, name: wn)
      return emit_external_name_entries(%buf, exts: rest, idx: idx + 1)
  end
end

/** Build name subsection entries for internal functions */
let emit_internal_name_entries = fn (buf: %ByteBuffer, funcs: [LirFunction], idx: i64) -> %ByteBuffer throws { CodegenError } do
  match funcs do
    | [] -> return %buf
    | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      let %buf = bb.push_uleb128(%buf, val: idx)
      let %buf = wdefs.emit_name(%buf, name: n)
      return emit_internal_name_entries(%buf, funcs: rest, idx: idx + 1)
  end
end

/** Build the WASM name custom section payload (section name + function subsection) */
let build_name_section = fn (exts: [LirExternal], funcs: [LirFunction],
                              has_alloc: bool,
                              n_exts: i64, n_alloc_imports: i64,
                              total_funcs: i64) -> %ByteBuffer throws { CodegenError } do
  let %entries = bb.empty()
  let %entries = bb.push_uleb128(buf: %entries, val: total_funcs)
  let %entries = emit_external_name_entries(buf: %entries, exts, idx: 0)
  let %entries = if has_alloc then
    let %entries = bb.push_uleb128(buf: %entries, val: n_exts)
    let %entries = wdefs.emit_name(buf: %entries, name: "allocate")
    let %entries = bb.push_uleb128(buf: %entries, val: n_exts + 1)
    let %entries = wdefs.emit_name(buf: %entries, name: "__nx_alloc_mark")
    let %entries = bb.push_uleb128(buf: %entries, val: n_exts + 2)
    wdefs.emit_name(buf: %entries, name: "__nx_alloc_reset")
  else %entries end
  let internal_start = n_exts + n_alloc_imports
  let %entries = emit_internal_name_entries(buf: %entries, funcs, idx: internal_start)
  let wasi_idx = total_funcs - 1
  let %entries = bb.push_uleb128(buf: %entries, val: wasi_idx)
  let %entries = wdefs.emit_name(buf: %entries, name: "wasi:cli/run@0.2.0#run")

  let entries_len = bb.length(buf: &entries)
  let %subsec = bb.empty()
  let %subsec = bb.push_byte(buf: %subsec, byte: 1)
  let %subsec = bb.push_uleb128(buf: %subsec, val: entries_len)
  let %subsec = bb.push_buf(dst: %subsec, src: &entries)
  bb.free(buf: %entries)

  let %payload = bb.empty()
  let %payload = wdefs.emit_name(buf: %payload, name: "name")
  let %payload = bb.push_buf(dst: %payload, src: &subsec)
  bb.free(buf: %subsec)
  return %payload
end

// ─── Module entry point ────────────────────────────────────────────────────

export let compile_lir_to_wasm = fn (program: LirProgram, string_data_base: i64,
                                       effect_map: &EffectMap) -> %ByteBuffer throws { CodegenError } do
  match program do
    | LirProgram(functions: funcs, externals: all_exts) ->

      // Filter out arena intrinsics — they are emitted as inline WASM, not imported.
      let intrinsic_filtered = filter_intrinsic_externals(exts: all_exts)
      let has_intrinsics = list.length(xs: all_exts) != list.length(xs: intrinsic_filtered)
      // Deduplicate externals by (wasm_module, wasm_name) — diamond imports can
      // register the same WASM function under multiple Nexus names.
      let DedupExtResult(exts, remaps: ext_remaps) = dedup_externals(exts: intrinsic_filtered)
      let filtered_program = LirProgram(functions: funcs, externals: exts)
      let n_exts = list.length(xs: exts)
      let n_funcs = list.length(xs: funcs)
      // Resolve the program-wide import index of the backtrace-capture host
      // function. main_wrap synthesises this external whenever it wraps a
      // throwing main; it is absent for programs without a wrapped main.
      // emit_one_body refines this per-function via EffectMap.can_throw
      // (issue nexus-55x0): functions that cannot transitively throw skip
      // the call entirely, while functions that may throw retain it.
      let bt_capture_idx_global = find_bt_capture_idx(exts)
      let has_eh = wcollect.program_needs_eh(funcs)
      let has_ss = wcollect.program_needs_stack_switching(funcs)
      let heap_enabled = wcollect.program_uses_heap(funcs)
      let has_cabi = wcollect.needs_cabi_realloc(exts)
      let n_cabi = if has_cabi then 1 else 0 end
      // alloc_mode (legacy — still stored in CodegenCtx but no longer branched
      // on by emit_*): 1 = program allocates on the heap, 0 = it does not. All
      // allocations now bump the atomic cell at wdefs.heap_ptr_cell.
      let alloc_mode = if heap_enabled then 1 else 0 end
      let import_count = n_exts

      let internal_funcs = build_internal_func_entries(funcs, import_count, idx: 0)
      let base_external_funcs = build_external_func_entries(exts, idx: 0)
      // Add remap entries for deduplicated externals (duplicate names → original index)
      let external_funcs = append_func_entries(a: ext_remaps, b: base_external_funcs)

      // Build hash maps for O(1) function lookup
      let %internal_func_map = wdefs.build_func_map(entries: internal_funcs)
      let %external_func_map = wdefs.build_func_map(entries: external_funcs)

      // Closure analysis
      let closure_table = build_closure_table(funcs, &internal_func_map, table_idx: 0)
      let n_closures = list.length(xs: closure_table)
      let closure_arities = collect_closure_arities(funcs)

      let main_idx = wdefs.lookup_func_fast(name: "main", map: &internal_func_map)
      // Implicit `wasi_thread_start` export when the lazy/threads runtime is
      // linked (so wasi-threads workers can find the trampoline). `[]` otherwise.
      let extra_exports = wasi_thread_start_export(funcs, internal_func_map: &internal_func_map)
      let main_ret = match wdefs.find_function_fast(name: "main", funcs, map: &internal_func_map, import_count) do
        | Some(val: LirFunction(name: _, params: _, ret_type: rt, body: _, ret: _, span: _)) -> rt
        | None -> TyUnit
      end
      // If main takes params, find argv for wasi_run wrapper.
      // Under source-qualified canonical naming, `argv` is registered as
      // `<source>#argv`; fall back to a suffix match when the bare name
      // isn't found.
      let argv_idx = match wdefs.find_function_fast(name: "main", funcs, map: &internal_func_map, import_count) do
        | Some(val: LirFunction(name: _, params: _ :: _, ret_type: _, body: _, ret: _, span: _)) ->
          let bare = wdefs.lookup_func_fast(name: "argv", map: &internal_func_map)
          if bare >= 0 then bare
          else find_func_by_suffix(funcs, map: &internal_func_map, suffix: "#argv") end
        | _ -> -1
      end

      let all_strings = wcollect.collect_program_strings(funcs, acc: [])
      let string_entries = wcollect.build_string_entries(strings: all_strings, next_offset: string_data_base, acc: [])
      let has_strings = list.length(xs: string_entries) > 0

      let mem_mode = wcollect.choose_memory_mode(externals: exts, has_strings, has_heap: heap_enabled)

      let last_end = wcollect.compute_last_string_end(entries: string_entries)
      let heap_base_raw = match last_end > string_data_base do | true -> last_end | false -> string_data_base end
      let heap_base = wcollect.align8(v: heap_base_raw)

      let cabi_realloc_idx = import_count + n_funcs
      let wasi_run_idx = import_count + n_funcs + n_cabi

      // WASM magic + version
      let %m = bb.empty()
      let %m = bb.push_byte(buf: %m, byte: 0)
      let %m = bb.push_byte(buf: %m, byte: 97)
      let %m = bb.push_byte(buf: %m, byte: 115)
      let %m = bb.push_byte(buf: %m, byte: 109)
      let %m = bb.push_byte(buf: %m, byte: 1)
      let %m = bb.push_byte(buf: %m, byte: 0)
      let %m = bb.push_byte(buf: %m, byte: 0)
      let %m = bb.push_byte(buf: %m, byte: 0)

      // Type section — deduplicated by signature; returns canonical indices per entity.
      // No `__nx_allocate` import any more: the allocator is fully inline
      // (atomic bump cell), so the alloc-related type slots are never reserved.
      let has_alloc = false
      let DedupedTypes(section: %type_sec, count: _,
                       ext_type_idxs: ext_type_idxs,
                       func_type_idxs: func_type_idxs,
                       wasi_run_type_idx: wasi_run_type_idx,
                       exn_tag_type_idx: exn_tag_type_idx,
                       ss_tag_type_idx: ss_tag_type_idx,
                       alloc_type_idx: alloc_type_idx,
                       alloc_mark_type_idx: alloc_mark_type_idx,
                       alloc_reset_type_idx: alloc_reset_type_idx,
                       cabi_type_idx: cabi_type_idx,
                       closure_type_idxs: closure_type_idxs,
                       ss_cont_type_idx: my_cont_idx,
                       ss_dispatch_block_type_idx: my_dispatch_idx) =
        wsect.build_type_section_dedup(program: filtered_program, has_eh, has_ss, has_alloc,
                                       has_cabi_realloc: has_cabi, closure_arities)
      let ss_cont_type_idx = my_cont_idx
      let ss_dispatch_block_type_idx = my_dispatch_idx
      let %m = wdefs.emit_section(buf: %m, id: sec_type, content: %type_sec)

      // Import section
      if n_exts > 0 || (mem_mode != "none" && mem_mode != "defined") || has_alloc then
        let %m = wdefs.emit_section(buf: %m, id: sec_import,
                               content: wsect.build_import_section(exts, ext_type_idxs,
                                 mem_mode, has_alloc,
                                 alloc_type_idx,
                                 alloc_mark_type_idx, alloc_reset_type_idx,
                                 alloc_module: mem_mode))
      end

      // Function section
      let %m = wdefs.emit_section(buf: %m, id: sec_function,
                             content: wsect.build_function_section(func_type_idxs,
                                                                   wasi_run_type_idx,
                                                                   has_cabi,
                                                                   cabi_type_idx))

      // Table section (closures and/or cont ref table for stack-switching)
      let %m = if n_closures > 0 || has_ss then
        wdefs.emit_section(buf: %m, id: sec_table, content: wsect.build_table_section(n_closures, has_ss, ss_cont_type_idx))
      else %m end

      // Memory section
      let %m = if mem_mode == "defined" then
        wdefs.emit_section(buf: %m, id: sec_memory, content: wsect.build_memory_section())
      else %m end

      // Tag section — emits the EH tag and the stack-switching tag if either
      // is in use. Must come after memory, before global.
      // Phase-3 multi-arm dispatch: one wasm tag per distinct cap method
      // (`<port>::<method>`) collected at codegen time. Computed here (early
      // enough for the tag section emission) and re-used downstream by
      // emit_code_bodies via ctx.ss_tag_names.
      let ss_tag_names_for_tags = wcollect.collect_program_tag_names(funcs)
      let n_ss_tags = if has_ss then list.length(xs: ss_tag_names_for_tags) else 0 end
      let %m = if has_eh || has_ss then
        wdefs.emit_section(buf: %m, id: sec_tag, content: wsect.build_tag_section(exn_tag_type_idx, ss_tag_type_idx, has_eh, n_ss_tags))
      else %m end

      // Memo cache plan (nexus-e6uh). Re-runs effect analysis +
      // memo_plan inside codegen so the driver doesn't have to thread the
      // plan through compile_lir_to_wasm; the cost is one extra LIR walk per
      // build, which is negligible next to wasm assembly.
      // Effect analysis must see all externals (incl. mem.* / sched.*) — the
      // arena-filtered set hides runtime effects, so functions calling
      // mem.load_i64 etc. would appear pure and get incorrectly memoised
      // (nexus-bavy soundness fix).
      let unfiltered_program = LirProgram(functions: funcs, externals: all_exts)
      let %memo_em = effect_analysis.analyze_effects(program: unfiltered_program)
      let memo_plan_full = memo_plan.plan_memoization(program: unfiltered_program, em: &memo_em)
      effect_analysis.free_effect_map(em: %memo_em)
      let memo_targets = build_memo_targets(plan: memo_plan_full)
      let n_memo_targets = memo_target_count(targets: memo_targets)
      let memo_target_names = extract_memo_names(targets: memo_targets, acc: [])
      let memo_target_slots = extract_memo_slots(targets: memo_targets, acc: [])
      // memo_globals_base is the index of the FIRST memo global in the main
      // module's local global namespace. wmerge later applies a glo_off to
      // these instructions when concatenating with the dep stdlib.
      let memo_globals_base = 3 + (if has_ss then 3 else 0 end)

      // Global section — needed for bump allocator, cabi_realloc, arena, string
      // literals, or any memo-cache target. G1 (str_base) is always needed
      // when there are string literals; memo cache globals demand a global
      // section even when none of the prior conditions apply.
      // G0/G1/G2 are vestigial now (the allocator no longer uses them; wmerge
      // still patches them). Emit when the program uses the heap, cabi_realloc,
      // arena intrinsics, string literals, stack switching, or a memo cache slot.
      let needs_global = heap_enabled || has_cabi || has_intrinsics || has_strings || has_ss || n_memo_targets > 0
      let %m = if needs_global then
        wdefs.emit_section(buf: %m, id: sec_global, content: wsect.build_global_section(heap_base, has_ss, ss_cont_type_idx, memo_cache_count: n_memo_targets))
      else %m end

      // Export section
      let %m = wdefs.emit_section(buf: %m, id: sec_export,
                             content: wsect.build_export_section(main_idx, wasi_run_idx,
                                                           cabi_realloc_idx,
                                                           has_cabi_realloc: has_cabi,
                                                           mem_mode,
                                                           has_table: n_closures > 0,
                                                           has_ss,
                                                           extra_exports: extra_exports))

      // Element section (populate funcref table)
      let %m = if n_closures > 0 then
        wdefs.emit_section(buf: %m, id: sec_element, content: wsect.build_element_section(closure_entries: closure_table))
      else %m end

      // Code section
      // Build closure_type_indices: map arity → canonical (deduped) type section index
      let closure_type_idx_list = build_closure_type_idx_list(arities: closure_arities, type_idxs: closure_type_idxs)
      let %code = bb.empty()
      let %code = bb.push_uleb128(buf: %code, val: n_funcs + n_cabi + 1)
      // Pass all_exts (including arena) so emit_arena_intrinsic can find them via find_external
      // ss_tag_idx is the tag-section ordinal of the stack-switching tag:
      // 1 if EH is also enabled (EH tag at 0), 0 if SS-only, -1 if absent.
      let ss_tag_idx = if has_ss then (if has_eh then 1 else 0 end) else -1 end
      // Reuse the list computed earlier for the tag section so we don't
      // re-walk the LIR program.
      let ss_tag_names = ss_tag_names_for_tags
      let %code = emit_code_bodies(buf: %code, funcs, internal_funcs,
                                    external_funcs, string_lits: string_entries,
                                    alloc_mode, functions: funcs, externals: all_exts,
                                    closure_table, closure_type_indices: closure_type_idx_list,
                                    &internal_func_map, &external_func_map,
                                    ss_tag_idx: ss_tag_idx,
                                    ss_cont_type_idx: my_cont_idx,
                                    ss_dispatch_block_type_idx: ss_dispatch_block_type_idx,
                                    ss_tag_names: ss_tag_names,
                                    effect_map: effect_map,
                                    bt_capture_idx_global: bt_capture_idx_global,
                                    memo_target_names,
                                    memo_target_slots,
                                    memo_globals_base,
                                    import_count)
      // cabi_realloc: aligned bump allocator for the canonical-ABI string path
      let %code = if has_cabi then
        let %cabi_body = compile_cabi_realloc(heap_base)
        append_body_to_buf(buf: %code, body: %cabi_body)
      else %code end
      let %wasi_body = compile_wasi_run_wrapper(main_idx, main_ret_type: main_ret, argv_idx)
      let %code = append_body_to_buf(buf: %code, body: %wasi_body)
      let %m = wdefs.emit_section(buf: %m, id: sec_code, content: %code)

      // Data section — string literals only. The atomic bump cell at
      // wdefs.heap_ptr_cell is NOT data-segment initialised: under WASI threads
      // each worker spawns a fresh instance that re-runs the module's data
      // segments against the SHARED linear memory, so a cell-0 data segment
      // would clobber the bump pointer mid-run. Instead emit_atomic_bump's
      // idempotent `cmpxchg(cell, 0, memory.size()*65536)` lazily seeds the
      // cell on the first allocation (the seed is the top of all static data,
      // since string literals live in the initial pages).
      let %m = wdefs.emit_section(buf: %m, id: sec_data, content: wsect.build_data_section(entries: string_entries, cell_init: 0 - 1))

      // Name section (custom)
      let total_named_funcs = import_count + n_funcs + 1
      let %name_payload = build_name_section(exts, funcs,
                                              has_alloc,
                                              n_exts,
                                              n_alloc_imports: 0,
                                              total_funcs: total_named_funcs)
      let name_payload_len = bb.length(buf: &name_payload)
      let %m = bb.push_byte(buf: %m, byte: sec_custom)
      let %m = bb.push_uleb128(buf: %m, val: name_payload_len)
      let %m = bb.push_buf(dst: %m, src: &name_payload)
      bb.free(buf: %name_payload)

      // Free function lookup maps
      wdefs.free_func_map(map: %internal_func_map)
      wdefs.free_func_map(map: %external_func_map)

      return %m
  end
end

let build_closure_type_idx_list = fn (arities: [i64], type_idxs: [i64]) -> [ArityTypeIdx] throws { CodegenError } do
  return build_closure_type_idx_list_go(arities, type_idxs, acc: [])
end
let build_closure_type_idx_list_go = fn (arities: [i64], type_idxs: [i64], acc: [ArityTypeIdx]) -> [ArityTypeIdx] throws { CodegenError } do
  match arities do
    | [] -> return rev_arity_type_idxs(lst: acc, out: [])
    | a :: rest_a ->
      match type_idxs do
        | [] -> return rev_arity_type_idxs(lst: acc, out: [])
        | ti :: rest_ti ->
          return build_closure_type_idx_list_go(arities: rest_a, type_idxs: rest_ti,
            acc: ArityTypeIdx(arity: a, type_idx: ti) :: acc)
      end
  end
end

