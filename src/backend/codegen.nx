// ─── Memo extractors + nexus:intrinsic op emitters live in codegen/intrinsics.nx ─
// Memo extract_*, arena heap-*, mem-* / atomic-* / cast-* / lazy-passthrough /
// bt-* / array-* / f64-* / simd-* / sched-* — all reachable from the
// `emit_intrinsic` dispatcher below. Only `emit_force_closure` stays here
// because it consults `lookup_closure_type_idx_pairs` from the closure
// helpers band downstream.

// Recover the import-module name to thread into `alloc_module`. The allocator
// shares the linear-memory provider's module, so this maps `MemoryImported(m)`
// to `m`; the two non-imported modes never co-occur with `has_alloc=true` but
// must yield a placeholder to satisfy the string-typed parameter.
let mem_mode_to_module_name = fn (mode: MemoryMode) -> string do
  if let MemoryImported(name: m) = mode then return m end
  return "env"
end

let emit_force_closure = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_i64_load])
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_call_indirect])
      let CodegenCtx(closure_type_indices: cti, _) = ctx
      let type_idx = lookup_closure_type_idx_pairs(arity: 0, pairs: cti)
      let %buf = bb.push_uleb128(%buf, val: type_idx)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      return %buf
    | _ ->
      raise SymbolNotFound(name: "__nx_force_closure", kind: "lazy intrinsic arg", context: "")
      return %buf
  end
end

// ─── TCMC detection + emission live in codegen/tcmc.nx ─────────────────────
// ─── Atom / coercion / alloc / memcpy helpers: see codegen/atom.nx ─────────
// All leaf helpers that don't recurse through emit_expr / emit_stmt live
// in the atom/string/tcmc modules, so emission stays a thin glue layer.

// ─── String concat / compare live in codegen/string.nx ─────────────────────
// ─── Binary op (binary_operand_type + emit_binary) lives in codegen/binop.nx ───

// ─── External call arg ──────────────────────────────────────────────────────

let emit_external_arg = fn (atom: LirAtom, param_type: TypeExpr, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match wdefs.peel_linear(typ: param_type) do
    | TyString | TyArray(_) ->
      let packed_tmp = wdefs.ctx_temps_base(ctx)
      let %buf = emit_atom(atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 32)
      let %buf = bb.push_bytes(%buf, bytes: [op_i64_shr_s, op_i32_wrap_i64, op_local_get])
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      return bb.push_byte(%buf, byte: op_i32_wrap_i64)
    | TyChar ->
      // Internal and external both use i32 for char — no conversion needed
      let %buf = emit_atom(atom, %buf, ctx)
      return emit_coercion(from_type: wdefs.atom_type(atom), to_type: param_type, %buf)
    | _ ->
      let %buf = emit_atom(atom, %buf, ctx)
      return emit_coercion(from_type: wdefs.atom_type(atom), to_type: param_type, %buf)
  end
end

// ─── Constructor/record field emission ──────────────────────────────────────

let emit_constructor_fields = fn (buf: %ByteBuffer, args: [LirAtom], ctx: CodegenCtx,
                                   obj_ptr: i64, field_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match args do
    | [] -> %buf
    | a :: rest ->
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = emit_typed_field_store(typ: wdefs.atom_type(atom: a), %buf, offset: field_idx * 8)
      emit_constructor_fields(%buf, args: rest, ctx, obj_ptr, field_idx: field_idx + 1)
  end
end

let emit_record_fields = fn (buf: %ByteBuffer, fields: [LirNamedAtom], ctx: CodegenCtx,
                              obj_ptr: i64, field_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match fields do
    | [] -> %buf
    | LirNamedAtom(name: _, value: v) :: rest ->
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = emit_typed_field_store(typ: wdefs.atom_type(atom: v), %buf, offset: field_idx * 8)
      emit_record_fields(%buf, fields: rest, ctx, obj_ptr, field_idx: field_idx + 1)
  end
end

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_strings = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_strings(lst: rest, out: x :: out)
  end
end

let rev_local_entries = fn (lst: [LocalEntry], out: [LocalEntry]) -> [LocalEntry] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_local_entries(lst: rest, out: x :: out)
  end
end

let extract_field_names = fn (fields: [LirNamedAtom]) -> [string] throws { CodegenError } do
  return extract_field_names_go(fields, acc: [])
end
let extract_field_names_go = fn (fields: [LirNamedAtom], acc: [string]) -> [string] throws { CodegenError } do
  match fields do
    | [] -> return rev_strings(lst: acc, out: [])
    | LirNamedAtom(name: n, value: _) :: rest ->
      return extract_field_names_go(fields: rest, acc: n :: acc)
  end
end

// Array literals (`[| e0, e1, ... |]`) lower to `LirExprRecord` with field
// names `"0", "1", ..., "n-1"` (see lower_expr_to_atom MirArray case in
// src/ir/lir/lir.nx). Detect that shape so the record codegen can emit the
// packed `(ptr<<32) | len` atom layout that `emit_external_arg(TyArray)`
// expects, instead of the `i64.extend_i32_u(ptr)` form used by real
// records. Real records always have alphabetic field names — there is no
// source syntax that produces a record whose field is literally `"0"`.
// Empty fields are ambiguous (both `{}` and `[||]` lower to no-fields), so
// they keep the legacy zero-extended-pointer form to avoid corrupting
// downstream record field-access of `{}` — `[||]` length stays as the
// pre-existing corner case.
let is_array_record = fn (fields: [LirNamedAtom]) -> bool throws { CodegenError } do
  return is_array_record_go(fields, idx: 0)
end
let is_array_record_go = fn (fields: [LirNamedAtom], idx: i64) -> bool throws { CodegenError } do
  match fields do
    | [] -> return idx > 0
    | LirNamedAtom(name: n, value: _) :: rest ->
      if n == str.from_i64(val: idx) then
        return is_array_record_go(fields: rest, idx: idx + 1)
      else return false
      end
  end
end

// ─── Call emission ──────────────────────────────────────────────────────────

let emit_internal_call_args = fn (buf: %ByteBuffer, args: [LirCallArg], params: [LirParam], ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | [] -> %buf
    | LirCallArg(label: _, value: v) :: rest_args ->
      match params do
        | [] -> %buf
        | LirParam(label: _, name: _, typ: pt) :: rest_params ->
          let %buf = emit_atom(atom: v, %buf, ctx)
          let %buf = emit_coercion(from_type: wdefs.atom_type(atom: v), to_type: pt, %buf)
          emit_internal_call_args(%buf, args: rest_args, params: rest_params, ctx)
      end
  end
end

let find_call_arg_value = fn (label: string, args: [LirCallArg]) -> LirAtom throws { CodegenError } do
  match args do
    | [] -> raise SymbolNotFound(name: label, kind: "call argument label", context: "find_call_arg_value")
    | LirCallArg(label: l, value: v) :: rest ->
      if l == label then return v
      else return find_call_arg_value(label, args: rest)
      end
  end
end

let emit_external_call_args = fn (buf: %ByteBuffer, args: [LirCallArg], params: [LirParam], ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  // Iterate params in source order (matching stdlib ABI), look up args by label
  match params do
    | [] -> %buf
    | LirParam(label: pl, name: _, typ: pt) :: rest_params ->
      let v = find_call_arg_value(label: pl, args)
      let %buf = emit_external_arg(atom: v, param_type: pt, %buf, ctx)
      emit_external_call_args(%buf, args, params: rest_params, ctx)
  end
end

let emit_internal_call = fn (func: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx,
                              is_tail: bool, in_try: bool, int_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match wdefs.ctx_find_function(ctx, name: func) do
    | Some(val: LirFunction(name: _, params, ret_type: callee_rt, body: _, ret: _, span: _)) ->
      let CodegenCtx(func_ret_type: caller_rt, memo_target_names: mtn, memo_target_slots: mts, _) = ctx
      // return_call requires callee return type ≡ caller return type. When a
      // unit-returning fn is tail-called from a non-unit-returning wrapper
      // (e.g. closure body wrapping `let @t = unit_returning_fn()`), fall
      // back to a regular call so emit_return_value can supply the placeholder.
      let types_match = wdefs.is_unit(typ: callee_rt) == wdefs.is_unit(typ: caller_rt)
      let use_tail = is_tail && !in_try && types_match

      // Memoization (nexus-e6uh): single-slot last-call cache for 1-arg
      // single-word-key pure fns, gated on slot-table membership and a
      // non-tail / non-try call site so the if/else result discipline holds.
      let memo_slot = lookup_memo_slot(name: func, targets_names: mtn,
                                          targets_slots: mts)
      if !use_tail && !in_try && memo_slot >= 0 then
        return emit_memoized_internal_call(func, args, params, callee_rt,
                                            %buf, ctx,
                                            int_idx, slot: memo_slot)
      end

      let %buf = emit_internal_call_args(%buf, args, params, ctx)
      let call_op = match use_tail do | true -> op_return_call | false -> op_call end
      let %buf = bb.push_byte(%buf, byte: call_op)
      bb.push_uleb128(%buf, val: int_idx)
    | None ->
      raise SymbolNotFound(name: func, kind: "function", context: "internal call")
      return %buf
  end
end

/** Emit a memoized call sequence for a 1-arg single-word-key pure function. */
/** Pre-condition (caller-enforced): slot is valid, args.length == 1, */
/** param_types[0] is a single-word-key type per memo.is_single_word_key_type, */
/** !is_tail, !in_try. */
let emit_memoized_internal_call = fn (func: string, args: [LirCallArg], params: [LirParam],
                                         callee_rt: TypeExpr,
                                         buf: %ByteBuffer, ctx: CodegenCtx,
                                         int_idx: i64, slot: i64) -> %ByteBuffer throws { CodegenError } do
  let CodegenCtx(memo_globals_base: memo_base, _) = ctx
  let valid_idx = memo.memo_valid_global_idx(base: memo_base, slot)
  let key_idx = memo.memo_key_global_idx(base: memo_base, slot)
  let val_idx = memo.memo_val_global_idx(base: memo_base, slot)
  let key_local = wdefs.ctx_temps_base(ctx) + memo.memo_key_local_offset
  let val_local = wdefs.ctx_temps_base(ctx) + memo.memo_val_local_offset

  // Step 1 — emit and capture the single argument as i64 cache key.
  let %buf = emit_internal_call_args(%buf, args, params, ctx)
  // emit_internal_call_args coerces the arg to the param type (already i64
  // for our single-word-key admission). pack_arg_to_key widens i32-flavoured
  // values and reinterprets f64. Stack: [key:i64].
  let arg_type = match params do
    | LirParam(label: _, name: _, typ: t) :: _ -> t
    | [] -> callee_rt
  end
  let %buf = memo.emit_pack_arg_to_key(%buf, arg_type)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: key_local)

  // Step 2 — compute hit condition: valid && key == cached_key.
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: valid_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: key_local)
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: key_idx)
  let %buf = bb.push_bytes(%buf, bytes: [op_i64_eq, op_i32_and])

  // Step 3 — if (result i64): hit branch returns cached val.
  let %buf = bb.push_bytes(%buf, bytes: [op_if, bt_i64, op_global_get])
  let %buf = bb.push_uleb128(%buf, val: val_idx)

  // Step 4 — else: miss branch invokes the callee, writes the cache.
  let %buf = bb.push_bytes(%buf, bytes: [op_else, op_local_get])
  let %buf = bb.push_uleb128(%buf, val: key_local)
  // The callee expects its declared param type, which we pre-coerced into
  // the i64 key above. Reverse-coerce when the param type isn't already i64
  // so we hand the call exactly the type wasm needs.
  let %buf = unpack_key_to_param(%buf, param_type: arg_type)
  // Note: param_type intentionally aliases arg_type — the call's argument
  // type IS the callee's param type after emit_internal_call_args coercion.
  let %buf = bb.push_byte(%buf, byte: op_call)
  let %buf = bb.push_uleb128(%buf, val: int_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_tee)
  let %buf = bb.push_uleb128(%buf, val: val_local)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: val_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: key_local)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: key_idx)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: valid_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: val_local)

  // end of if
  return bb.push_byte(%buf, byte: op_end)
end

/** Identity since only i64/IntLit pass eligibility. Kept as a seam for */
/** widening + reverse-coerce when other key types open up. */
let unpack_key_to_param = fn (buf: %ByteBuffer, param_type: TypeExpr) -> %ByteBuffer do
  match wdefs.peel_linear(typ: param_type) do
    | TyI64 | TyIntLit | _ -> return %buf
  end
end

let emit_external_call = fn (func: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx,
                               ext_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match wdefs.find_external(name: func, exts: wdefs.ctx_externals(ctx)) do
    | Some(val: LirExternal(name: _, wasm_module: m, wasm_name: _, params, ret_type: rt, throw_row: _)) ->
      let canonical_str_ret = str.contains(s: m, sub: ":")
        && m != "nexus:intrinsic"
        && !str.starts_with(s: m, prefix: "nexus:runtime/")
        && !str.starts_with(s: m, prefix: "nexus:std/")
        && (match wdefs.peel_linear(typ: rt) do | TyString -> true | _ -> false end)
      let %buf = if canonical_str_ret then
        // Allocate an 8-byte retptr (always 8-aligned) for the canonical
        // string return, off the unified atomic bump cell.
        // i32 temp locals: temps_base+6=retptr, +7=tmp_ptr, +8=tmp_len.
        let retptr_local = wdefs.ctx_temps_base(ctx) + 6
        let %buf = bb.push_byte(%buf, byte: op_i32_const)
        let %buf = bb.push_sleb128(%buf, val: 8)
        emit_atomic_bump(%buf, ctx, ptr_local: retptr_local)
      else %buf end
      let %buf = emit_external_call_args(%buf, args, params, ctx)
      // For canonical string return: push retptr as last argument
      let %buf = if canonical_str_ret then
        let retptr_local = wdefs.ctx_temps_base(ctx) + 6
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        bb.push_uleb128(%buf, val: retptr_local)
      else %buf end
      let %buf = bb.push_byte(%buf, byte: op_call)
      let %buf = bb.push_uleb128(%buf, val: ext_idx)
      // For canonical string return: read (ptr, len) from retptr and pack to i64
      let %buf = if canonical_str_ret then
        let retptr_local = wdefs.ctx_temps_base(ctx) + 6
        let tmp_ptr = wdefs.ctx_temps_base(ctx) + 7
        let tmp_len = wdefs.ctx_temps_base(ctx) + 8
        // Load ptr (i32) from retptr+0
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        let %buf = bb.push_uleb128(%buf, val: retptr_local)
        let %buf = bb.push_bytes(%buf, bytes: [op_i32_load, 2])
        let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
        let %buf = bb.push_byte(%buf, byte: op_local_set)
        let %buf = bb.push_uleb128(%buf, val: tmp_ptr)
        // Load len (i32) from retptr+4
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        let %buf = bb.push_uleb128(%buf, val: retptr_local)
        let %buf = bb.push_bytes(%buf, bytes: [op_i32_load, 2])
        let %buf = bb.push_uleb128(%buf, val: 4)
        let %buf = bb.push_byte(%buf, byte: op_local_set)
        let %buf = bb.push_uleb128(%buf, val: tmp_len)
        // Pack: (ptr_i64 << 32) | len_i64
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        let %buf = bb.push_uleb128(%buf, val: tmp_ptr)
        let %buf = bb.push_bytes(%buf, bytes: [op_i64_extend_i32_u, op_i64_const])
        let %buf = bb.push_sleb128(%buf, val: 32)
        let %buf = bb.push_bytes(%buf, bytes: [op_i64_shl, op_local_get])
        let %buf = bb.push_uleb128(%buf, val: tmp_len)
        let %buf = bb.push_byte(%buf, byte: op_i64_extend_i32_u)
        bb.push_byte(%buf, byte: op_i64_or)
      else %buf end
      return %buf
    | None ->
      raise SymbolNotFound(name: func, kind: "function", context: "external call")
      return %buf
  end
end

/** The unified intrinsic dispatch: one match on the parsed `Intrinsic` tag */
/** (see codegen/intrinsics.nx). `parse_intrinsic` keys on the kebab-cased */
/** `wasm_name` (`wit_canonical_name` strips the `__nx_` prefix and converts */
/** underscores to hyphens). Every `nexus:intrinsic` external — across the */
/** former arena / memory / math / simd / atomic / cast / lazy domains — flows */
/** through here. Each arm just calls the matching `emit_*` helper. */
/** `UnknownIntrinsic(name)` surfaces the same `SymbolNotFound` the old */
/** if-chain produced; adding a new intrinsic without an arm is a compile */
/** error rather than a runtime trap. */
let emit_intrinsic = fn (name: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match parse_intrinsic(s: name) do
    | HeapMark -> return emit_heap_mark(%buf)
    | HeapReset -> return emit_heap_reset(args, %buf, ctx)
    | HeapSwap -> return emit_heap_swap(args, %buf, ctx)
    | AllocRaw -> return emit_alloc_raw(args, %buf, ctx)
    | MemLoadI32 -> return emit_mem_load_i32(args, %buf, ctx)
    | MemStoreI32 -> return emit_mem_store_i32(args, %buf, ctx)
    | MemLoadU8 -> return emit_mem_load_u8(args, %buf, ctx)
    | MemStoreU8 -> return emit_mem_store_u8(args, %buf, ctx)
    | MemLoadI64 -> return emit_mem_load_i64(args, %buf, ctx)
    | MemStoreI64 -> return emit_mem_store_i64(args, %buf, ctx)
    | MemLoadF32 -> return emit_mem_load_f32(args, %buf, ctx)
    | MemStoreF32 -> return emit_mem_store_f32(args, %buf, ctx)
    | MemLoadF64 -> return emit_mem_load_f64(args, %buf, ctx)
    | MemStoreF64 -> return emit_mem_store_f64(args, %buf, ctx)
    | MemSize -> return emit_mem_size(%buf)
    | MemGrow -> return emit_mem_grow(args, %buf, ctx)
    | AtomicRmwAddI32 -> return emit_atomic_rmw_add_i32(args, %buf, ctx)
    | AtomicLoadI32 -> return emit_atomic_load_i32(args, %buf, ctx)
    | AtomicStoreI32 -> return emit_atomic_store_i32(args, %buf, ctx)
    | AtomicCmpxchgI32 -> return emit_atomic_cmpxchg_i32(args, %buf, ctx)
    | AtomicWait32 -> return emit_atomic_wait32(args, %buf, ctx)
    | AtomicNotify -> return emit_atomic_notify(args, %buf, ctx)
    | CastToI32 -> return emit_cast_to_i32(args, %buf, ctx)
    | CastToI64 -> return emit_cast_to_i64(args, %buf, ctx)
    | ForceClosure -> return emit_force_closure(args, %buf, ctx)
    | ThunkAddr | ValueOfI64 -> return emit_lazy_passthrough(args, %buf, ctx)
    | ArrayLength -> return emit_array_length(args, %buf, ctx)
    | F64Sqrt -> return emit_f64_unary(opcode: op_f64_sqrt, args, %buf, ctx, name: "__nx_f64_sqrt")
    | F64Floor -> return emit_f64_unary(opcode: op_f64_floor, args, %buf, ctx, name: "__nx_f64_floor")
    | F64Ceil -> return emit_f64_unary(opcode: op_f64_ceil, args, %buf, ctx, name: "__nx_f64_ceil")
    | F64Abs -> return emit_f64_unary(opcode: op_f64_abs, args, %buf, ctx, name: "__nx_f64_abs")
    | SimdF32x4Add -> return emit_simd_binop_one(sub_op: op_simd_f32x4_add, args, %buf, ctx, name: "__nx_simd_f32x4_add")
    | SimdF32x4Mul -> return emit_simd_binop_one(sub_op: op_simd_f32x4_mul, args, %buf, ctx, name: "__nx_simd_f32x4_mul")
    | SimdF64x2Add -> return emit_simd_binop_one(sub_op: op_simd_f64x2_add, args, %buf, ctx, name: "__nx_simd_f64x2_add")
    | SimdF64x2Mul -> return emit_simd_binop_one(sub_op: op_simd_f64x2_mul, args, %buf, ctx, name: "__nx_simd_f64x2_mul")
    | SimdI32x4Add -> return emit_simd_binop_one(sub_op: op_simd_i32x4_add, args, %buf, ctx, name: "__nx_simd_i32x4_add")
    | SimdI32x4Mul -> return emit_simd_binop_one(sub_op: op_simd_i32x4_mul, args, %buf, ctx, name: "__nx_simd_i32x4_mul")
    | SimdI64x2Add -> return emit_simd_binop_one(sub_op: op_simd_i64x2_add, args, %buf, ctx, name: "__nx_simd_i64x2_add")
    | SimdI64x2Mul -> return emit_simd_binop_one(sub_op: op_simd_i64x2_mul, args, %buf, ctx, name: "__nx_simd_i64x2_mul")
    | SimdF32x4AddArray -> return emit_simd_binop_array(sub_op: op_simd_f32x4_add, args, %buf, ctx, name: "__nx_simd_f32x4_add_array")
    | SimdF64x2AddArray -> return emit_simd_binop_array(sub_op: op_simd_f64x2_add, args, %buf, ctx, name: "__nx_simd_f64x2_add_array")
    | SimdI32x4AddArray -> return emit_simd_binop_array(sub_op: op_simd_i32x4_add, args, %buf, ctx, name: "__nx_simd_i32x4_add_array")
    | SimdI64x2AddArray -> return emit_simd_binop_array(sub_op: op_simd_i64x2_add, args, %buf, ctx, name: "__nx_simd_i64x2_add_array")
    | SimdF32x4MulArray -> return emit_simd_binop_array(sub_op: op_simd_f32x4_mul, args, %buf, ctx, name: "__nx_simd_f32x4_mul_array")
    | SimdF64x2MulArray -> return emit_simd_binop_array(sub_op: op_simd_f64x2_mul, args, %buf, ctx, name: "__nx_simd_f64x2_mul_array")
    | SimdI32x4MulArray -> return emit_simd_binop_array(sub_op: op_simd_i32x4_mul, args, %buf, ctx, name: "__nx_simd_i32x4_mul_array")
    | SimdI64x2MulArray -> return emit_simd_binop_array(sub_op: op_simd_i64x2_mul, args, %buf, ctx, name: "__nx_simd_i64x2_mul_array")
    | SimdF32x4SubArray -> return emit_simd_binop_array(sub_op: op_simd_f32x4_sub, args, %buf, ctx, name: "__nx_simd_f32x4_sub_array")
    | SimdF64x2SubArray -> return emit_simd_binop_array(sub_op: op_simd_f64x2_sub, args, %buf, ctx, name: "__nx_simd_f64x2_sub_array")
    | SimdI32x4SubArray -> return emit_simd_binop_array(sub_op: op_simd_i32x4_sub, args, %buf, ctx, name: "__nx_simd_i32x4_sub_array")
    | SimdI64x2SubArray -> return emit_simd_binop_array(sub_op: op_simd_i64x2_sub, args, %buf, ctx, name: "__nx_simd_i64x2_sub_array")
    | SimdF32x4DivArray -> return emit_simd_binop_array(sub_op: op_simd_f32x4_div, args, %buf, ctx, name: "__nx_simd_f32x4_div_array")
    | SimdF64x2DivArray -> return emit_simd_binop_array(sub_op: op_simd_f64x2_div, args, %buf, ctx, name: "__nx_simd_f64x2_div_array")
    | BtDepth -> return emit_bt_depth(%buf)
    | BtFrame -> return emit_bt_frame(args, %buf, ctx)
    | CaptureBacktrace -> return emit_capture_backtrace(args, %buf, ctx)
    | UnknownIntrinsic(name: n) ->
      raise SymbolNotFound(name: n, kind: "intrinsic", context: "emit_intrinsic")
      return %buf
  end
end

let emit_call = fn (func: string, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx,
                     is_tail: bool, in_try: bool) -> %ByteBuffer throws { CodegenError } do
  // `nexus:intrinsic` externals: emit inline WASM, no function call. Resolve
  // the dispatch key (the external's kebab-cased wasm_name) and hand off to
  // emit_intrinsic. The sched intrinsics keep their own func+exts-shaped
  // recognisers (they consult the externals list for the host run-queue
  // imports), so they stay separate arms in this flat else-if chain.
  let exts = wdefs.ctx_externals(ctx)
  let intr_wn = get_intrinsic_wasm_name(func, exts)
  if func == "__array_get" then return emit_array_get(args, %buf, ctx)
  else if func == "__array_set" then return emit_array_set(args, %buf, ctx)
  else if intr_wn != "" then return emit_intrinsic(name: intr_wn, args, %buf, ctx)
  else if is_sched_set_next(func, exts) then return emit_sched_set_next(args, %buf, ctx)
  else if is_sched_spawn(func, exts) then return emit_sched_spawn(args, %buf, ctx)
  else
    let CodegenCtx(internal_func_map: ifm, external_func_map: efm, _) = ctx
    let int_idx = wdefs.lookup_func_fast(name: func, map: &ifm)
    if int_idx >= 0 then
      return emit_internal_call(func, args, %buf, ctx, is_tail, in_try, int_idx)
    else
      let ext_idx = wdefs.lookup_func_fast(name: func, map: &efm)
      if ext_idx >= 0 then
        return emit_external_call(func, args, %buf, ctx, ext_idx)
      else
        raise SymbolNotFound(name: func, kind: "function", context: "emit_call")
      end
    end
  end
end

// ─── Closure helpers ────────────────────────────────────────────────────────

/** Returns the table index (position) for a closure function name. */
let lookup_closure_table_idx = fn (name: string, entries: [FuncEntry]) -> i64 throws { CodegenError } do
  return lookup_closure_table_idx_go(name, entries, pos: 0)
end

let lookup_closure_table_idx_go = fn (name: string, entries: [FuncEntry], pos: i64) -> i64 throws { CodegenError } do
  match entries do
    | [] -> return -1
    | FuncEntry(name: n, index: _) :: rest ->
      if n == name then return pos
      else return lookup_closure_table_idx_go(name, entries: rest, pos: pos + 1)
      end
  end
end

/** Look up the type section index for a closure call with the given arity. */
let lookup_closure_type_idx_pairs = fn (arity: i64, pairs: [ArityTypeIdx]) -> i64 throws { CodegenError } do
  match pairs do
    | [] -> raise SymbolNotFound(name: str.from_i64(val: arity), kind: "closure arity", context: "lookup_closure_type_idx_pairs")
    | ArityTypeIdx(arity: a, type_idx: ti) :: rest ->
      if a == arity then return ti
      else return lookup_closure_type_idx_pairs(arity, pairs: rest)
      end
  end
end

let emit_closure_captures = fn (buf: %ByteBuffer, caps: [LirAtom], ctx: CodegenCtx, obj_ptr: i64, field_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match caps do
    | [] -> %buf
    | a :: rest ->
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = emit_typed_field_store(typ: wdefs.atom_type(atom: a), %buf, offset: field_idx * 8)
      emit_closure_captures(%buf, caps: rest, ctx, obj_ptr, field_idx: field_idx + 1)
  end
end

let emit_closure_call_args = fn (buf: %ByteBuffer, args: [LirCallArg], ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | [] -> %buf
    | LirCallArg(label: _, value: a) :: rest ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = emit_pack_to_i64(typ: wdefs.atom_type(atom: a), %buf)
      emit_closure_call_args(%buf, args: rest, ctx)
  end
end

// ─── Expression emission ────────────────────────────────────────────────────

let emit_expr = fn (expr: LirExpr, buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool) -> %ByteBuffer throws { CodegenError } do
  match expr do
    | LirExprAtom(atom: a) -> emit_atom(atom: a, %buf, ctx)

    | LirExprBinary(op, lhs: l, rhs: r, typ: t) ->
      if is_string_concat_op(op, typ: t) then
        return emit_string_concat(lhs: l, rhs: r, %buf, ctx)
      end
      if is_string_op(op, lhs_type: wdefs.atom_type(atom: l), rhs_type: wdefs.atom_type(atom: r)) then
        return emit_string_compare(op, lhs: l, rhs: r, %buf, ctx)
      end
      let lhs_type = wdefs.atom_type(atom: l)
      let rhs_type = wdefs.atom_type(atom: r)
      let op_type = binary_operand_type(op, lhs_type, rhs_type)
      let %buf = emit_atom(atom: l, %buf, ctx)
      let %buf = emit_coercion(from_type: lhs_type, to_type: op_type, %buf)
      let %buf = emit_atom(atom: r, %buf, ctx)
      let %buf = emit_coercion(from_type: rhs_type, to_type: op_type, %buf)
      return emit_binary(op, operand_type: op_type, %buf)

    | LirExprCall(func: fname, args, typ: _) ->
      emit_call(func: fname, args, %buf, ctx, is_tail: false, in_try)

    | LirExprTailCall(func: fname, args, typ: _) ->
      emit_call(func: fname, args, %buf, ctx, is_tail: true, in_try)

    | LirExprConstructor(name: cname, args: cargs, typ: _) ->
      let arity = list.length(xs: cargs)
      let tag = wdefs.constructor_tag(name: cname, arity)
      let %buf = emit_alloc_object(%buf, ctx, words: 1 + arity)
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: tag)
      let %buf = bb.push_byte(%buf, byte: op_i64_store)
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = emit_constructor_fields(%buf, args: cargs, ctx, obj_ptr, field_idx: 1)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)

    | LirExprRecord(fields, typ: _) ->
      let names = extract_field_names(fields)
      let tag = wdefs.record_tag(sorted_names: names)
      let n_fields = list.length(xs: fields)
      let %buf = emit_alloc_object(%buf, ctx, words: 1 + n_fields)
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: tag)
      let %buf = bb.push_byte(%buf, byte: op_i64_store)
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = emit_record_fields(%buf, fields, ctx, obj_ptr, field_idx: 1)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      // Array shape (numeric field names "0".."n-1"): emit packed
      // `(ptr<<32) | len` matching emit_external_arg(TyArray)'s unpack.
      // Plain records: zero-extend ptr to i64 (upper 32 = 0).
      if is_array_record(fields) then
        let %buf = bb.push_bytes(%buf, bytes: [op_i64_extend_i32_u, op_i64_const])
        let %buf = bb.push_sleb128(%buf, val: 32)
        let %buf = bb.push_bytes(%buf, bytes: [op_i64_shl, op_i64_const])
        let %buf = bb.push_sleb128(%buf, val: n_fields)
        return bb.push_byte(%buf, byte: op_i64_or)
      else
        return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
      end

    | LirExprObjectTag(value: v, typ: _) ->
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      return wdefs.emit_memarg_i64(%buf, offset: 0)

    | LirExprObjectField(value: v, index: idx, typ: ftyp) ->
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      return emit_typed_field_load(typ: ftyp, %buf, offset: (idx + 1) * 8)

    | LirExprRaise(value: v, typ: _) ->
      // Per-function backtrace capture (issue nexus-55x0). Emit a `call`
      // to the imported `__nx_main_wrap_bt_capture` immediately before
      // `op_throw` so the host can snapshot the wasm call stack before
      // unwinding. bt_capture_idx is -1 when the enclosing function's
      // EffectMap entry has can_throw=false or when the capture import
      // was never resolved (no main_wrap fired).
      let CodegenCtx(bt_capture_idx, _) = ctx
      let %buf = if bt_capture_idx >= 0 then
        let %b = bb.push_byte(%buf, byte: op_call)
        bb.push_uleb128(buf: %b, val: bt_capture_idx)
      else %buf end
      let %buf = emit_atom(atom: v, %buf, ctx)
      // Unit-typed raise: push i64(0) as payload
      let %buf = if wdefs.is_unit(typ: wdefs.atom_type(atom: v)) then
        let %b = bb.push_byte(%buf, byte: op_i64_const)
        bb.push_sleb128(buf: %b, val: 0)
      else %buf end
      let %buf = bb.push_byte(%buf, byte: op_throw)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      return %buf

    | LirExprForce(value: v, typ: _) ->
      // Force a lazy value: invoke the 0-arg thunk closure via call_indirect.
      // Mirror of LirExprCallClosure with n_args = 0 (env only).
      let %buf = emit_atom(atom: v, %buf, ctx)
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_call_indirect])
      let CodegenCtx(closure_type_indices: cti, _) = ctx
      let type_idx = lookup_closure_type_idx_pairs(arity: 0, pairs: cti)
      let %buf = bb.push_uleb128(%buf, val: type_idx)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      return %buf

    | LirExprMakeClosure(func_name: fname, captures: caps, typ: _) ->
      // Allocate (1 + n_captures) words on heap
      let n_caps = list.length(xs: caps)
      let %buf = emit_alloc_object(%buf, ctx, words: 1 + n_caps)
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let CodegenCtx(closure_table: ctab, _) = ctx
      let table_idx = lookup_closure_table_idx(name: fname, entries: ctab)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: table_idx)
      let %buf = bb.push_byte(%buf, byte: op_i64_store)
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = emit_closure_captures(%buf, caps, ctx, obj_ptr, field_idx: 1)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)

    | LirExprCallClosure(closure: clos, args: cargs, typ: _) ->
      let %buf = emit_atom(atom: clos, %buf, ctx)
      let %buf = emit_closure_call_args(%buf, args: cargs, ctx)
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = emit_atom(atom: clos, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let n_args = list.length(xs: cargs)
      let CodegenCtx(closure_type_indices: cti, _) = ctx
      let type_idx = lookup_closure_type_idx_pairs(arity: n_args, pairs: cti)
      let %buf = bb.push_byte(%buf, byte: op_call_indirect)
      let %buf = bb.push_uleb128(%buf, val: type_idx)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      return %buf

    | LirExprSuspend(tag_name: tn, payload: p, typ: t) ->
      let %buf = emit_atom(atom: p, %buf, ctx)
      let %buf = if wdefs.is_unit(typ: wdefs.atom_type(atom: p)) then
        let %b = bb.push_byte(%buf, byte: op_i64_const)
        bb.push_sleb128(buf: %b, val: 0)
      else %buf end
      let %buf = bb.push_byte(%buf, byte: op_suspend)
      // Multi-arm dispatch: each `<port>::<method>` gets its own wasm tag.
      // ss_base = the wasm tag index of the FIRST stack-switching tag (after
      // the optional EH tag); offset = position of `tn` in `ss_tag_names`.
      let CodegenCtx(ss_tag_idx: ss_base, ss_tag_names: tns, _) = ctx
      let tag_offset = wcollect.lookup_tag_idx(tag_name: tn, tag_names: tns)
      if tag_offset < 0 then
        raise SymbolNotFound(name: tn, kind: "suspend tag", context: "LirExprSuspend tag missing in ss_tag_names")
      end
      let ss_idx = ss_base + tag_offset
      let %buf = bb.push_uleb128(%buf, val: ss_idx)
      // suspend's tag has no result types; if the expression's wasm type is
      // unit, leave the value-stack alone. Otherwise push an i64 0 placeholder
      // — replaced by the resume-site's value when LirExprResume codegen lands.
      if wdefs.is_unit(typ: t) then return %buf end
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 0)
      return %buf
    | LirExprResume(cont: c, value: _, typ: _) ->
      let %buf = emit_atom(atom: c, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_global_set)
      let %buf = bb.push_uleb128(%buf, val: wdefs.ss_resume_slot_global_idx)
      return %buf
    | LirExprContNew(_) -> raise StackSwitchingNotImplemented(node: "cont.new")
    | LirExprInjectResume(body_fn: bfn, arm_fns: afs, arm_tags: ats, typ: _) ->
      return emit_inject_resume_multi(%buf, body_fn: bfn, arm_fns: afs, arm_tags: ats, ctx)
  end
end

/** Multi-arm InjectResume frame. */
/** */
/** Layout for N=2 arms (innermost = arm 0): */
/** */
/**   block @outer */
/**     setup body cont; resume_slot = next_alloc; next_alloc++ */
/**     loop @loop */
/**       block @arm_1 (type dispatch_t_idx) */
/**         block @arm_0 (type dispatch_t_idx) */
/**           resume cont_t (on tag_0 @arm_0) (on tag_1 @arm_1) */
/**           br 3       ;; resume returned normally → exit @outer (depth N+1) */
/**         end */
/**         ;; tag_0 caught: dispatch arm 0 with [payload, contref] */
/**         br 1         ;; back to @loop (depth N - 0 - 1 = 1) */
/**       end */
/**       ;; tag_1 caught */
/**       br 0           ;; back to @loop (depth N - 1 - 1 = 0) */
/**     end */
/**   end */
/** */
/** Every match arm uses explicit `return` (defensive against an earlier */
/** self-compile hang whose root cause was never nailed; uniform returns */
/** sidestep whatever runtime pattern was responsible). */
let emit_inject_resume_multi = fn (buf: %ByteBuffer, body_fn: string, arm_fns: [string],
                                    arm_tags: [string], ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  let CodegenCtx(internal_func_map: ifm, ss_cont_type_idx: cont_t_idx,
                  ss_dispatch_block_type_idx: dispatch_t_idx, ss_tag_idx: ss_base,
                  ss_tag_names: tag_names, _) = ctx
  let body_idx = wdefs.lookup_func_fast(name: body_fn, map: &ifm)
  let n_arms_raw = list.length(xs: arm_fns)
  // Phase-2 fallback: arm_tags may be empty (legacy MIR path). Force a
  // single-on-clause shape so the dispatcher remains valid; first arm gets
  // tag 0. arm_fns must have at least one entry (InjectResume is only
  // constructed when at least one with-kont arm exists).
  let n_arms = if n_arms_raw == 0 then 1 else n_arms_raw end

  // @outer
  let %buf = bb.push_bytes(%buf, bytes: [op_block, bt_void])

  // Body cont setup
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_ref_func])
  let %buf = bb.push_uleb128(%buf, val: body_idx)
  let %buf = bb.push_byte(%buf, byte: op_cont_new)
  let %buf = bb.push_uleb128(%buf, val: cont_t_idx)
  let %buf = bb.push_byte(%buf, byte: op_table_set)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_table_idx)

  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_resume_slot_global_idx)

  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_i64_const)
  let %buf = bb.push_sleb128(%buf, val: 1)
  let %buf = bb.push_bytes(%buf, bytes: [op_i64_add, op_global_set])
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)

  // @loop
  let %buf = bb.push_bytes(%buf, bytes: [op_loop, bt_void])

  // N nested arm blocks (outermost first)
  let %buf = open_nested_arm_blocks(%buf, dispatch_t_idx, n: n_arms)

  // resume + on-clauses
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_resume_slot_global_idx)
  let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_table_get])
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_table_idx)
  let %buf = bb.push_byte(%buf, byte: op_resume)
  let %buf = bb.push_uleb128(%buf, val: cont_t_idx)
  let %buf = bb.push_uleb128(%buf, val: n_arms)
  let %buf = emit_arm_on_clauses(%buf, arm_tags, ss_base, tag_names, n_arms, idx: 0)

  // Normal-return path. The naive `br N+1` (exit dispatcher) prematurely
  // strands queued fibers when the spawner cont (main's body) finishes
  // first — bes5 Q3 termination. Instead: dequeue the next runnable; if
  // queue empty (sched-dequeue returns -1), THEN exit. Otherwise set
  // resume_slot and br back to @loop so the fibers drain.
  let dequeue_idx = find_sched_import_idx(wn: "sched-dequeue", exts: wdefs.ctx_externals(ctx), idx: 0)
  let %buf = if dequeue_idx >= 0 then
    let tmp_local = wdefs.ctx_temps_base(ctx) + 5
    let %b = bb.push_byte(%buf, byte: op_call)
    let %b = bb.push_uleb128(buf: %b, val: dequeue_idx)
    let %b = bb.push_byte(buf: %b, byte: op_local_tee)
    let %b = bb.push_uleb128(buf: %b, val: tmp_local)
    let %b = bb.push_byte(buf: %b, byte: op_i64_const)
    let %b = bb.push_sleb128(buf: %b, val: 0)
    let %b = bb.push_bytes(buf: %b, bytes: [op_i64_lt_s, op_br_if])
    let %b = bb.push_uleb128(buf: %b, val: n_arms + 1)
    let %b = bb.push_byte(buf: %b, byte: op_local_get)
    let %b = bb.push_uleb128(buf: %b, val: tmp_local)
    let %b = bb.push_byte(buf: %b, byte: op_global_set)
    let %b = bb.push_uleb128(buf: %b, val: wdefs.ss_resume_slot_global_idx)
    let %b = bb.push_byte(buf: %b, byte: op_br)
    bb.push_uleb128(buf: %b, val: n_arms)
  else
    // No sched runtime imported (e.g., handler_with_kont_resume which uses
    // a hand-rolled handler with no global queue). Fall back to the simple
    // exit-on-normal-return path.
    let %b = bb.push_byte(%buf, byte: op_br)
    bb.push_uleb128(buf: %b, val: n_arms + 1)
  end

  // Close arm blocks innermost first; emit per-arm dispatch + br to @loop
  let %buf = close_and_dispatch_arms(%buf, arm_fns, n_arms, ctx, idx: 0)

  let %buf = bb.push_byte(%buf, byte: op_end)  // close @loop
  return bb.push_byte(%buf, byte: op_end)      // close @outer
end

let open_nested_arm_blocks = fn (buf: %ByteBuffer, dispatch_t_idx: i64, n: i64) -> %ByteBuffer throws { CodegenError } do
  if n <= 0 then return %buf end
  let %buf = bb.push_byte(%buf, byte: op_block)
  let %buf = bb.push_sleb128(%buf, val: dispatch_t_idx)
  return open_nested_arm_blocks(%buf, dispatch_t_idx, n: n - 1)
end

/** Emit one `(on tag → label)` per arm. Arm `i` targets label depth `i` */
/** (innermost arm = depth 0). When arm_tags is empty (legacy single-arm */
/** path), fall through to ss_base for the only on-clause. */
let emit_arm_on_clauses = fn (buf: %ByteBuffer, arm_tags: [string],
                              ss_base: i64, tag_names: [string], n_arms: i64, idx: i64) -> %ByteBuffer throws { CodegenError } do
  if idx >= n_arms then return %buf end
  let tag_idx = match arm_tags do
    | [] -> ss_base
    | _ -> ss_base + arm_tag_offset_at(arm_tags, idx, tag_names)
  end
  let %buf = bb.push_byte(%buf, byte: 0)
  let %buf = bb.push_uleb128(%buf, val: tag_idx)
  let %buf = bb.push_uleb128(%buf, val: idx)
  return emit_arm_on_clauses(%buf, arm_tags, ss_base, tag_names, n_arms, idx: idx + 1)
end

let arm_tag_offset_at = fn (arm_tags: [string], idx: i64, tag_names: [string]) -> i64 throws { CodegenError } do
  let tn = nth_string(xs: arm_tags, idx)
  let off = wcollect.lookup_tag_idx(tag_name: tn, tag_names)
  if off < 0 then
    raise SymbolNotFound(name: tn, kind: "arm tag", context: "arm_tag_offset_at: tag missing in ss_tag_names")
  end
  return off
end

let nth_string = fn (xs: [string], idx: i64) -> string throws { CodegenError } do
  match xs do
    | [] -> raise SymbolNotFound(name: "<arm_tag>", kind: "arm tag index", context: "nth_string out of range")
    | x :: rest ->
      if idx <= 0 then return x end
      return nth_string(xs: rest, idx: idx - 1)
  end
end

let close_and_dispatch_arms = fn (buf: %ByteBuffer, arm_fns: [string], n_arms: i64,
                                   ctx: CodegenCtx, idx: i64) -> %ByteBuffer throws { CodegenError } do
  if idx >= n_arms then return %buf end
  let %buf = bb.push_byte(%buf, byte: op_end)  // close arm `idx`'s block
  let arm_fn = nth_string(xs: arm_fns, idx)
  let %buf = emit_arm_dispatch(%buf, arm_fn, ctx)
  let %buf = bb.push_byte(%buf, byte: op_br)
  let %buf = bb.push_uleb128(%buf, val: n_arms - idx - 1)
  return close_and_dispatch_arms(%buf, arm_fns, n_arms, ctx, idx: idx + 1)
end

let emit_arm_dispatch = fn (buf: %ByteBuffer, arm_fn: string, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  let CodegenCtx(internal_func_map: ifm, _) = ctx
  let arm_idx = wdefs.lookup_func_fast(name: arm_fn, map: &ifm)
  if arm_idx < 0 then
    raise SymbolNotFound(name: arm_fn, kind: "arm function", context: "emit_arm_dispatch")
  end
  let arm_param_count = match wdefs.ctx_find_function(ctx, name: arm_fn) do
    | Some(val: LirFunction(name: _, params: ps, ret_type: _, body: _, ret: _, span: _)) -> list.length(xs: ps)
    | None -> 2
  end
  let temp_idx = wdefs.ctx_temps_base(ctx)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: temp_idx)

  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_global_get])
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_table_set)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_table_idx)

  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = if arm_param_count >= 2 then
    let %bb = bb.push_byte(%buf, byte: op_local_get)
    bb.push_uleb128(buf: %bb, val: temp_idx)
  else %buf end
  let %buf = bb.push_byte(%buf, byte: op_call)
  let %buf = bb.push_uleb128(%buf, val: arm_idx)

  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_i64_const)
  let %buf = bb.push_sleb128(%buf, val: 1)
  let %buf = bb.push_bytes(%buf, bytes: [op_i64_add, op_global_set])
  return bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
end

// nexus-eo09: when the body of a LirStmtIfReturn already ends with a
// LirStmtIfReturn whose then_ret matches the outer's then_ret, the outer's
// trailing op_return would fire with a STALE value on fall-through paths
// inside the inner conditional. The atom matches because lir.nx hoisted the
// inner's then_ret up to the outer wrapper via fallback_ret_from_*. Detect
// the hoist at codegen time and skip the trailing op_return so control falls
// through naturally to the next branch / function tail.
let lir_atom_eq = fn (a: LirAtom, b: LirAtom) -> bool throws { CodegenError } do
  match a do
    | LirAtomVar(name: na, typ: _) ->
      match b do
        | LirAtomVar(name: nb, typ: _) -> return na == nb
        | _ -> return false
      end
    | LirAtomInt(val: va) ->
      match b do | LirAtomInt(val: vb) -> return va == vb | _ -> return false end
    | LirAtomBool(val: va) ->
      match b do | LirAtomBool(val: vb) -> return va == vb | _ -> return false end
    | LirAtomChar(val: va) ->
      match b do | LirAtomChar(val: vb) -> return va == vb | _ -> return false end
    | LirAtomString(val: va) ->
      match b do | LirAtomString(val: vb) -> return va == vb | _ -> return false end
    | LirAtomFloat(val: va) ->
      match b do | LirAtomFloat(val: vb) -> return va == vb | _ -> return false end
    | LirAtomUnit ->
      match b do | LirAtomUnit -> return true | _ -> return false end
  end
end

// True iff the last stmt of `stmts` is a LirStmtIfReturn whose `then_ret`
// atom equals `outer_ret` — i.e., the outer wrapper's return value was
// hoisted from this inner conditional via lir.nx fallback_ret_from_*.
let body_ends_with_hoisted_inner = fn (stmts: [LirStmt], outer_ret: LirAtom) -> bool throws { CodegenError } do
  match stmts do
    | [] -> return false
    | [LirStmtIfReturn(cond: _, then_body: _, then_ret: tr, else_body: _, else_ret: _, ret_type: _)] ->
      return lir_atom_eq(a: tr, b: outer_ret)
    | [_] -> return false
    | _ :: rest -> return body_ends_with_hoisted_inner(stmts: rest, outer_ret)
  end
end

let emit_if_return_unconditional = fn (buf: %ByteBuffer, then_body: [LirStmt], then_ret: LirAtom,
    ret_type: TypeExpr, ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { CodegenError } do
  let %buf = emit_stmts(stmts: then_body, %buf, ctx, in_try, tcmc)
  // nexus-eo09: skip the redundant op_return if the body already ends with a
  // LirStmtIfReturn whose then_ret is the SAME atom we'd be returning. The
  // inner's op_return handles the genuine path; on fall-through, the outer's
  // op_return would fire with a stale (uninitialised) value.
  if body_ends_with_hoisted_inner(stmts: then_body, outer_ret: then_ret) then
    return %buf
  end
  return emit_return_with_tcmc(%buf, ret_val: then_ret, ret_type, ctx, tcmc)
end

let emit_if_return_conditional = fn (buf: %ByteBuffer, cond: LirAtom, then_body: [LirStmt], then_ret: LirAtom,
    else_body: [LirStmt], else_ret: Option<LirAtom>, ret_type: TypeExpr,
    ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { CodegenError } do
  let %buf = emit_atom(atom: cond, %buf, ctx)
  let %buf = emit_coercion(from_type: wdefs.atom_type(atom: cond), to_type: TyBool, %buf)
  let %buf = bb.push_bytes(%buf, bytes: [op_if, bt_void])
  let %buf = emit_stmts(stmts: then_body, %buf, ctx, in_try, tcmc)
  // nexus-eo09: see comment in emit_if_return_unconditional. Same hoist
  // hazard applies inside the then-branch of a conditional IfReturn.
  let skip_then_ret = body_ends_with_hoisted_inner(stmts: then_body, outer_ret: then_ret)
  let %buf = if skip_then_ret then %buf
             else emit_return_with_tcmc(%buf, ret_val: then_ret, ret_type, ctx, tcmc) end
  let has_else = list.length(xs: else_body) > 0
  let has_else_ret = if let Some(_) = else_ret then true else false end
  let %buf = if has_else || has_else_ret then
    let %buf = bb.push_byte(%buf, byte: op_else)
    let %buf = emit_stmts(stmts: else_body, %buf, ctx, in_try, tcmc)
    match else_ret do
      | Some(val: a) ->
        let er_skip = body_ends_with_hoisted_inner(stmts: else_body, outer_ret: a)
        if er_skip then %buf else emit_return_with_tcmc(%buf, ret_val: a, ret_type, ctx, tcmc) end
      | None -> %buf
    end
  else %buf end
  return bb.push_byte(%buf, byte: op_end)
end

let is_unconditional_return = fn (cond: LirAtom, else_body: [LirStmt], else_ret: Option<LirAtom>) -> bool throws { CodegenError } do
  if let LirAtomBool(val: true) = cond then
    let has_else = list.length(xs: else_body) > 0
    let has_else_ret = if let Some(_) = else_ret then true else false end
    return !(has_else || has_else_ret)
  end
  return false
end

// ─── Statement emission (mutually recursive) ────────────────────────────────

let emit_stmt = fn (stmt: LirStmt, buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { CodegenError } do
  match stmt do
    | LirStmtLet(name: n, typ: t, expr: e) ->
      match tcmc do
        | TcmcActive(head_local: _, prev_local: _, rest_field_idx: _, call_var: cv,
                         cons_var: consv, call_args: _, ctor_name: _, ctor_args: _, func_name: _, loop_depth: _) ->
          if n == cv then
            if let LirExprCall(_) = e then return %buf end
          end
          if n == consv then
            if let LirExprConstructor(_) = e then
              return emit_tcmc_cons_and_loop(%buf, ctx, tcmc)
            end
          end
        | NoTcmc -> ()
      end
      let %buf = emit_expr(expr: e, %buf, ctx, in_try)
      let et = wdefs.expr_type(expr: e)
      if wdefs.is_unit(typ: t) then
        if !wdefs.is_unit(typ: et) then return bb.push_byte(%buf, byte: op_drop)
        else return %buf end
      else
        // If expr is Unit-typed but binding is not, emit a default value.
        // This happens for dead-code Let bindings where value comes from
        // explicit returns inside branches (if/match).
        let %buf = if wdefs.is_unit(typ: et) then
          emit_default_for_type(%buf, typ: t)
        else
          emit_coercion(from_type: et, to_type: t, %buf)
        end
        // O(1) packed local lookup via per-function HashMap (issue nexus-m2xq).
        // Layout: `(index << 32) | valtype`.
        let packed = wdefs.ctx_lookup_local(ctx, name: n)
        let idx = if packed < 0 then
          raise SymbolNotFound(name: n, kind: "local variable", context: "emit_stmt: let-binding target")
        else packed / wdefs.u32_radix end
        // Widen i32→i64 if local was widened due to type conflict
        let expr_vt = wdefs.type_to_valtype(typ: wdefs.peel_linear(typ: et))
        let local_vt = packed - idx * wdefs.u32_radix
        let %buf = if expr_vt == vt_i32 && local_vt == vt_i64 then
          bb.push_byte(%buf, byte: op_i64_extend_i32_u)
        else %buf end
        let %buf = bb.push_byte(%buf, byte: op_local_set)
        return bb.push_uleb128(%buf, val: idx)
      end

    | LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      let %buf = emit_atom(atom: c, %buf, ctx)
      let %buf = emit_coercion(from_type: wdefs.atom_type(atom: c), to_type: TyBool, %buf)
      let %buf = bb.push_bytes(%buf, bytes: [op_if, bt_void])
      let inner_tcmc = tcmc_deeper(tcmc, n: 1)
      let %buf = emit_stmts(stmts: tb, %buf, ctx, in_try, tcmc: inner_tcmc)
      let %buf = if list.length(xs: eb) > 0 then
        let %buf = bb.push_byte(%buf, byte: op_else)
        emit_stmts(stmts: eb, %buf, ctx, in_try, tcmc: inner_tcmc)
      else %buf end
      return bb.push_byte(%buf, byte: op_end)

    | LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr, else_body: eb, else_ret: er, ret_type: rt) ->
      if is_unconditional_return(cond: c, else_body: eb, else_ret: er) then
        return emit_if_return_unconditional(%buf, then_body: tb, then_ret: tr,
          ret_type: rt, ctx, in_try, tcmc)
      end
      let inner_tcmc = tcmc_deeper(tcmc, n: 1)
      return emit_if_return_conditional(%buf, cond: c, then_body: tb, then_ret: tr,
        else_body: eb, else_ret: er, ret_type: rt, ctx, in_try, tcmc: inner_tcmc)

    | LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      let inner_tcmc = tcmc_deeper(tcmc, n: 2)
      let %buf = bb.push_bytes(%buf, bytes: [op_block, bt_void, op_loop, bt_void])
      let %buf = emit_stmts(stmts: cs, %buf, ctx, in_try, tcmc: inner_tcmc)
      let %buf = emit_atom(atom: c, %buf, ctx)
      let %buf = emit_coercion(from_type: wdefs.atom_type(atom: c), to_type: TyBool, %buf)
      let %buf = bb.push_byte(%buf, byte: op_br_if)
      let %buf = bb.push_uleb128(%buf, val: 1)
      let %buf = emit_stmts(stmts: b, %buf, ctx, in_try, tcmc: inner_tcmc)
      let %buf = bb.push_byte(%buf, byte: op_br)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      return bb.push_bytes(%buf, bytes: [op_end, op_end])

    | LirStmtTryCatch(body: b, body_ret: br, catch_param: cp, catch_param_typ: _,
                          catch_body: cb, catch_ret: cr) ->
      let CodegenCtx(func_ret_type: ret_t, _) = ctx
      // O(1) catch-param lookup; -1 = catch param is Unit/unused (issue nexus-m2xq).
      let packed = wdefs.ctx_lookup_local(ctx, name: cp)
      let catch_local_idx = if packed < 0 then 0 - 1 else packed / wdefs.u32_radix end

      // WASM EH layout: block $skip { block $catch (result i64) { try_table (catch tag0 $catch) { body } end; br 1 } end; catch body } end
      let %buf = bb.push_bytes(%buf, bytes: [op_block, bt_void])
      let %buf = bb.push_bytes(%buf, bytes: [op_block, bt_i64])
      let %buf = bb.push_bytes(%buf, bytes: [op_try_table, bt_void])
      let %buf = bb.push_uleb128(%buf, val: 1)
      let %buf = bb.push_byte(%buf, byte: catch_kind_one)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)

      let %buf = emit_stmts(stmts: b, %buf, ctx, in_try: true, tcmc: NoTcmc)
      let %buf = match br do
        | Some(val: a) ->
          let %b = emit_atom(atom: a, %buf, ctx)
          let %b = emit_coercion(from_type: wdefs.atom_type(atom: a), to_type: ret_t, buf: %b)
          bb.push_byte(buf: %b, byte: op_return)
        | None -> %buf
      end
      let %buf = bb.push_byte(%buf, byte: op_end)

      // Try-success path: br over the catch body.
      let %buf = bb.push_byte(%buf, byte: op_br)
      let %buf = bb.push_uleb128(%buf, val: 1)
      let %buf = bb.push_byte(%buf, byte: op_end)

      // Catch entry: i64 payload is sitting on the stack from the $catch block.
      let %buf = if catch_local_idx >= 0 then
        let %buf = bb.push_byte(%buf, byte: op_local_set)
        bb.push_uleb128(%buf, val: catch_local_idx)
      else %buf end
      let %buf = emit_stmts(stmts: cb, %buf, ctx, in_try, tcmc: NoTcmc)
      let %buf = match cr do
        | Some(val: a) ->
          let %b = emit_atom(atom: a, %buf, ctx)
          let %b = emit_coercion(from_type: wdefs.atom_type(atom: a), to_type: ret_t, buf: %b)
          bb.push_byte(buf: %b, byte: op_return)
        | None -> %buf
      end
      return bb.push_byte(%buf, byte: op_end)

  end
end

let emit_stmts = fn (stmts: [LirStmt], buf: %ByteBuffer, ctx: CodegenCtx, in_try: bool, tcmc: TcmcCtx) -> %ByteBuffer throws { CodegenError } do
  match stmts do
    | [] -> %buf
    | s :: rest ->
      emit_stmts(stmts: rest, buf: emit_stmt(stmt: s, %buf, ctx, in_try, tcmc), ctx, in_try, tcmc)
  end
end

// ─── Function body compilation ──────────────────────────────────────────────

let emit_default_for_type = fn (buf: %ByteBuffer, typ: TypeExpr) -> %ByteBuffer throws { CodegenError } do
  let vt = wdefs.type_to_valtype(typ)
  if vt == vt_i32 then
    let %buf = bb.push_byte(%buf, byte: op_i32_const)
    return bb.push_sleb128(%buf, val: 0)
  end
  if vt == vt_f64 then
    let %buf = bb.push_byte(%buf, byte: op_f64_const)
    return bb.push_f64_str_le(%buf, s: "0.0")
  end
  let %buf = bb.push_byte(%buf, byte: op_i64_const)
  return bb.push_sleb128(%buf, val: 0)
end

let emit_return_value = fn (body: %ByteBuffer, rt: TypeExpr, r: LirAtom, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  if wdefs.is_unit(typ: rt) then return %body end
  let actual = match r do
    | LirAtomUnit -> emit_default_for_type(buf: %body, typ: rt)
    | _ ->
      let %body = emit_atom(atom: r, buf: %body, ctx)
      emit_coercion(from_type: wdefs.atom_type(atom: r), to_type: rt, buf: %body)
  end
  return actual
end

let compile_function_body = fn (func: LirFunction, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  let LirFunction(name: fname, params: ps, ret_type: raw_rt, body: b, ret: r, span: _) = func
  // Lifted lambdas (`__closure_N`) get a canonical (env+args of i64) -> i64
  // wasm signature regardless of the underlying lambda's return type. When
  // the body's implicit return is unit (e.g. wrapping `fiber1()` where
  // fiber1 returns unit), the body still has to push an i64 placeholder
  // before `end`. Inject bodies (`__inject_N`) and the sched trampoline
  // both go through the function-table elem segment for ref.func eligibility
  // but keep their source `() -> ()` signature, so this coercion does not
  // apply to them.
  let rt = if is_closure_lift(name: fname) && wdefs.is_unit(typ: raw_rt) then TyI64 else raw_rt end
  let %body = bb.empty()
  let CodegenCtx(locals: locs, _) = ctx
  let %body = wsect.emit_local_decls(buf: %body, locals: locs, param_count: list.length(xs: ps))

  // TCMC: detect pattern and set up locals
  let tcmc_raw = detect_tcmc(body: b, func_name: fname)
  let tcmc = match tcmc_raw do
    | NoTcmc -> NoTcmc
    | TcmcActive(head_local: _, prev_local: _, rest_field_idx: rfi, call_var: cv,
                     cons_var: consv, call_args: ca, ctor_name: cn, ctor_args: cta,
                     func_name: fn2, loop_depth: _) ->
      TcmcActive(head_local: wdefs.ctx_temps_base(ctx) + 13,
                  prev_local: wdefs.ctx_temps_base(ctx) + 14,
                  rest_field_idx: rfi, call_var: cv, cons_var: consv, call_args: ca,
                  ctor_name: cn, ctor_args: cta, func_name: fn2, loop_depth: 0)
  end

  // TCMC init (before loop, runs once)
  let %body = emit_tcmc_init(buf: %body, tcmc)
  // Wrap body in loop if TCMC detected
  let is_tcmc = match tcmc do | TcmcActive(_) -> true | NoTcmc -> false end
  let %body = if is_tcmc then
    let %body = bb.push_byte(buf: %body, byte: op_loop)
    bb.push_byte(buf: %body, byte: bt_void)
  else %body end

  let %body = emit_stmts(stmts: b, buf: %body, ctx, in_try: false, tcmc)

  let %body = if is_tcmc then
    bb.push_byte(buf: %body, byte: op_end)
  else %body end

  let %body = emit_return_value(%body, rt, r, ctx)
  bb.push_byte(buf: %body, byte: op_end)
end

/** cabi_realloc: bump allocator emitted alongside the canonical-ABI */
/** string-lift/lower path (currently dormant — see collect.needs_cabi_realloc). */
/** Bumps the unified atomic heap cell (`wdefs.heap_ptr_cell`); the cell always */
/** holds an 8-aligned value (every bump is a multiple of 8), which covers the */
/** canonical ABI's `align` (always <= 8), so the `align` parameter is ignored. */
/** Like emit_atomic_bump, it lazily seeds the cell via */
/** `cmpxchg(cell, 0, memory.size()*65536)` so it is correct even before any */
/** other allocation has run. Signature: */
/** `(orig_ptr i32, orig_size i32, align i32, new_size i32) -> i32`. */
let compile_cabi_realloc = fn (heap_base: i64) -> %ByteBuffer throws { CodegenError } do
  let _ = heap_base
  let %body = bb.empty()
  // 2 locals: rounded_size (i32) at idx 4, ptr (i32) at idx 5
  let %body = bb.push_uleb128(buf: %body, val: 1)
  let %body = bb.push_uleb128(buf: %body, val: 2)
  let %body = bb.push_byte(buf: %body, byte: vt_i32)
  // Idempotent seed: cmpxchg(cell, 0, memory.size()*65536); drop old.
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: wdefs.heap_ptr_cell)
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: 0)
  let %body = bb.push_bytes(buf: %body, bytes: [op_memory_size, 0, op_i32_const])
  let %body = bb.push_sleb128(buf: %body, val: 16)
  let %body = bb.push_byte(buf: %body, byte: wdefs.op_i32_shl)
  let %body = wdefs.emit_atomic_op32(buf: %body, sub_op: wdefs.op_i32_atomic_rmw_cmpxchg, offset: 0)
  let %body = bb.push_byte(buf: %body, byte: op_drop)
  // rounded_size = (new_size + 7) & ~8
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 3) // new_size
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: 7)
  let %body = bb.push_bytes(buf: %body, bytes: [op_i32_add, op_i32_const])
  let %body = bb.push_sleb128(buf: %body, val: 0 - 8)
  let %body = bb.push_bytes(buf: %body, bytes: [op_i32_and, op_local_set])
  let %body = bb.push_uleb128(buf: %body, val: 4)
  // ptr = atomic.rmw.add(cell, rounded_size)
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: wdefs.heap_ptr_cell)
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 4)
  let %body = wdefs.emit_atomic_op32(buf: %body, sub_op: wdefs.op_i32_atomic_rmw_add, offset: 0)
  let %body = bb.push_byte(buf: %body, byte: op_local_set)
  let %body = bb.push_uleb128(buf: %body, val: 5)
  // new_top = ptr + rounded_size  (reuse idx 4)
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 5)
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 4)
  let %body = bb.push_bytes(buf: %body, bytes: [op_i32_add, op_local_set])
  let %body = bb.push_uleb128(buf: %body, val: 4)
  // if (new_top > memory.size * 65536) { memory.grow(ceil((new_top - mem_bytes)/65536)); drop }
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 4)
  let %body = bb.push_bytes(buf: %body, bytes: [op_memory_size, 0, op_i32_const])
  let %body = bb.push_sleb128(buf: %body, val: 16)
  let %body = bb.push_byte(buf: %body, byte: wdefs.op_i32_shl)
  let %body = bb.push_bytes(buf: %body, bytes: [wdefs.op_i32_gt_u, op_if])
  let %body = bb.push_bytes(buf: %body, bytes: [bt_void, op_local_get])
  let %body = bb.push_uleb128(buf: %body, val: 4)
  let %body = bb.push_bytes(buf: %body, bytes: [op_memory_size, 0, op_i32_const])
  let %body = bb.push_sleb128(buf: %body, val: 16)
  let %body = bb.push_bytes(buf: %body, bytes: [wdefs.op_i32_shl, op_i32_sub])
  let %body = bb.push_byte(buf: %body, byte: op_i32_const)
  let %body = bb.push_sleb128(buf: %body, val: 65535)
  let %body = bb.push_bytes(buf: %body, bytes: [op_i32_add, op_i32_const])
  let %body = bb.push_sleb128(buf: %body, val: 16)
  let %body = bb.push_bytes(buf: %body, bytes: [wdefs.op_i32_shr_u, op_memory_grow, 0, op_drop, op_end])
  // return ptr
  let %body = bb.push_byte(buf: %body, byte: op_local_get)
  let %body = bb.push_uleb128(buf: %body, val: 5)
  return bb.push_byte(buf: %body, byte: op_end)
end

let find_func_by_suffix = fn (funcs: [LirFunction], map: &HashMap, suffix: string) -> i64 do
  match funcs do
    | [] -> return -1
    | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      if str.ends_with(s: n, suffix) then
        let idx = wdefs.lookup_func_fast(name: n, map)
        if idx >= 0 then return idx end
      end
      return find_func_by_suffix(funcs: rest, map, suffix)
  end
end

/// True when `main` in the program is declared with one or more params
/// (e.g. `main(args: [string])`). The wasi_run wrapper must supply an
/// argument before `call main` in that case (issue nexus-6z4h).
let program_main_has_args = fn (funcs: [LirFunction]) -> bool do
  match funcs do
    | [] -> return false
    | LirFunction(name: n, params: ps, ret_type: _, body: _, ret: _, span: _) :: rest ->
      if n == "main" then
        match ps do
          | [] -> return false
          | _ :: _ -> return true
        end
      end
      return program_main_has_args(funcs: rest)
  end
end

let compile_wasi_run_wrapper = fn (main_idx: i64, main_ret_type: TypeExpr,
    argv_idx: i64, synth_empty_argv: bool) -> %ByteBuffer throws { CodegenError } do
  let %body = bb.empty()
  // Locals: one i32 for the synthesised Nil pointer when synthesising, else 0.
  let %body = if synth_empty_argv then
    let %body = bb.push_uleb128(buf: %body, val: 1)
    let %body = bb.push_uleb128(buf: %body, val: 1)
    bb.push_byte(buf: %body, byte: vt_i32)
  else
    bb.push_uleb128(buf: %body, val: 0)
  end
  // If argv_idx >= 0, main takes args: call argv() first, pass result to main.
  // Else if synth_empty_argv, bump-allocate a 1-word Nil object and pass
  // its pointer (extended to i64) as the args list. Else: nothing pushed.
  let %body = if argv_idx >= 0 then
    let %body = bb.push_byte(buf: %body, byte: op_call)
    bb.push_uleb128(buf: %body, val: argv_idx)
  else if synth_empty_argv then
    // obj_ptr = global.get G0; local.tee 0; G0 = ptr + 8
    let %body = bb.push_byte(buf: %body, byte: op_global_get)
    let %body = bb.push_uleb128(buf: %body, val: heap_global_idx)
    let %body = bb.push_byte(buf: %body, byte: op_local_tee)
    let %body = bb.push_uleb128(buf: %body, val: 0)
    let %body = bb.push_byte(buf: %body, byte: op_i32_const)
    let %body = bb.push_sleb128(buf: %body, val: 8)
    let %body = bb.push_byte(buf: %body, byte: op_i32_add)
    let %body = bb.push_byte(buf: %body, byte: op_global_set)
    let %body = bb.push_uleb128(buf: %body, val: heap_global_idx)
    let %body = emit_memory_grow_check(buf: %body, skip: false)
    // mem[obj_ptr] = Nil tag (i64)
    let nil_tag = wdefs.constructor_tag(name: "Nil", arity: 0)
    let %body = bb.push_byte(buf: %body, byte: op_local_get)
    let %body = bb.push_uleb128(buf: %body, val: 0)
    let %body = bb.push_byte(buf: %body, byte: op_i64_const)
    let %body = bb.push_sleb128(buf: %body, val: nil_tag)
    let %body = bb.push_byte(buf: %body, byte: op_i64_store)
    let %body = wdefs.emit_memarg_i64(buf: %body, offset: 0)
    // Push obj_ptr (extended to i64) as the main argument.
    let %body = bb.push_byte(buf: %body, byte: op_local_get)
    let %body = bb.push_uleb128(buf: %body, val: 0)
    bb.push_byte(buf: %body, byte: op_i64_extend_i32_u)
  else %body end
  let %body = bb.push_byte(buf: %body, byte: op_call)
  let %body = bb.push_uleb128(buf: %body, val: main_idx)
  let %body = if wdefs.is_unit(typ: main_ret_type) then
    %body
  else
    bb.push_byte(buf: %body, byte: op_drop)
  end
  return bb.push_byte(buf: %body, byte: op_end)
end

// ─── Code section / context building ────────────────────────────────────────

let build_param_locals = fn (params: [LirParam], idx: i64) -> [LocalEntry] throws { CodegenError } do
  return build_param_locals_go(params, idx, acc: [])
end
let build_param_locals_go = fn (params: [LirParam], idx: i64, acc: [LocalEntry]) -> [LocalEntry] throws { CodegenError } do
  match params do
    | [] -> return rev_local_entries(lst: acc, out: [])
    | LirParam(label: _, name: n, typ: t) :: rest ->
      return build_param_locals_go(params: rest, idx: idx + 1, acc: LocalEntry(name: n, index: idx, valtype: wdefs.type_to_valtype(typ: t)) :: acc)
  end
end

/** Per-function locals data: `[LocalEntry]` for decl emission, packed map */
/** for O(1) name lookup, and `temps_base` for scratch-local indexing. The */
/** %HashMap is owned by `emit_one_body` so it can be freed after the body */
/** finishes (locals never escape a function). */
export type LocalsResult = LocalsResult(locals: [LocalEntry], temps_base: i64, local_map: %HashMap)

let build_func_locals = fn (func: LirFunction) -> LocalsResult do
  let LirFunction(name: _, params: ps, ret_type: _, body: b, ret: _, span: _) = func
  let param_locals = build_param_locals(params: ps, idx: 0)
  let param_count = list.length(xs: ps)
  let %local_map = wdefs.build_local_map(entries: param_locals)
  match wcollect.collect_local_stmts(stmts: b, locals: param_locals, next_idx: param_count, %local_map) do
    | LocalResult(locals: collected_locals, next_idx: collected_next_idx, local_map: lm) ->
      return LocalsResult(locals: collected_locals, temps_base: collected_next_idx, local_map: %lm)
  end
end

let build_func_ctx = fn (func: LirFunction,
                          locals: [LocalEntry], temps_base: i64, local_map: &HashMap,
                          internal_funcs: [FuncEntry],
                          external_funcs: [FuncEntry], string_lits: [StringEntry],
                          alloc_mode: i64, functions: [LirFunction],
                          externals: [LirExternal],
                          closure_table: [FuncEntry],
                          closure_type_indices: [ArityTypeIdx],
                          internal_func_map: &HashMap,
                          external_func_map: &HashMap,
                          ss_tag_idx: i64,
                          ss_cont_type_idx: i64,
                          ss_dispatch_block_type_idx: i64,
                          ss_tag_names: [string],
                          bt_capture_idx: i64,
                          memo_target_names: [string],
                          memo_target_slots: [i64],
                          memo_globals_base: i64,
                          import_count: i64) -> CodegenCtx do
  let LirFunction(name: fname, params: _, ret_type: rt, body: _, ret: _, span: _) = func
  return CodegenCtx(
    locals, internal_funcs, external_funcs,
    string_lits, alloc_mode, temps_base,
    func_ret_type: rt, functions, externals,
    closure_table, closure_type_indices,
    internal_func_map, external_func_map,
    func_name: fname,
    ss_tag_idx,
    ss_cont_type_idx,
    ss_dispatch_block_type_idx,
    ss_tag_names,
    bt_capture_idx,
    memo_target_names,
    memo_target_slots,
    memo_globals_base,
    import_count,
    local_map
  )
end

let append_body_to_buf = fn (buf: %ByteBuffer, body: %ByteBuffer) -> %ByteBuffer do
  let body_len = bb.length(buf: &body)
  let %buf = bb.push_uleb128(%buf, val: body_len)
  let %buf = bb.push_buf(dst: %buf, src: &body)
  bb.free(buf: %body)
  return %buf
end

/** Per-function backtrace-capture index for `func_name`. */
/** Returns -1 (= elide) when `bt_capture_idx_global == -1` (capture import */
/** absent from the program) or when the function's EffectMap entry says */
/** `can_throw == false` (issue nexus-55x0). Otherwise returns the import slot */
/** of `__nx_main_wrap_bt_capture` so emit_expr/LirExprRaise can call it. */
/** Exported so tests can exercise the elision rule directly without */
/** bringing up the full codegen pipeline. */
export let resolve_bt_capture_for_func = fn (func_name: string, effect_map: &EffectMap,
                                        bt_capture_idx_global: i64) -> i64 do
  if bt_capture_idx_global < 0 then return -1 end
  match lookup_bits(em: effect_map, name: func_name) do
    | Some(val: EffectBits(can_throw: ct, is_pure: _)) ->
      if ct then return bt_capture_idx_global end
      return -1
    | None ->
      // Function not in EffectMap (synthesised wrapper, etc.) — keep capture
      // emission enabled to preserve backtrace fidelity. EffectMap covers
      // every LirFunction in the program by construction, so a miss means
      // either a pre-LIR synthesised body or a stale lookup; both cases
      // sound on the conservative side.
      return bt_capture_idx_global
  end
end

let emit_one_body = fn (buf: %ByteBuffer, f: LirFunction,
                         internal_funcs: [FuncEntry], external_funcs: [FuncEntry],
                         string_lits: [StringEntry], alloc_mode: i64,
                         functions: [LirFunction], externals: [LirExternal],
                         closure_table: [FuncEntry],
                         closure_type_indices: [ArityTypeIdx],
                         internal_func_map: &HashMap,
                         external_func_map: &HashMap,
                         ss_tag_idx: i64,
                         ss_cont_type_idx: i64,
                         ss_dispatch_block_type_idx: i64,
                         ss_tag_names: [string],
                         effect_map: &EffectMap,
                         bt_capture_idx_global: i64,
                         memo_target_names: [string],
                         memo_target_slots: [i64],
                         memo_globals_base: i64,
                         import_count: i64) -> %ByteBuffer throws { CodegenError } do
  let LirFunction(name: fname, _) = f
  let bt_capture_idx = resolve_bt_capture_for_func(func_name: fname, effect_map,
                                                     bt_capture_idx_global)
  // Build locals + packed map up front; map is owned here so we can free it
  // after the body finishes (issue nexus-m2xq).
  match build_func_locals(func: f) do
    | LocalsResult(locals: ls, temps_base: tb, local_map: lm) ->
      let ctx = build_func_ctx(func: f, locals: ls, temps_base: tb, local_map: &lm,
                                internal_funcs,
                                external_funcs, string_lits,
                                alloc_mode, functions, externals,
                                closure_table, closure_type_indices,
                                internal_func_map, external_func_map,
                                ss_tag_idx,
                                ss_cont_type_idx,
                                ss_dispatch_block_type_idx,
                                ss_tag_names,
                                bt_capture_idx,
                                memo_target_names,
                                memo_target_slots,
                                memo_globals_base,
                                import_count)
      let %body = compile_function_body(func: f, ctx)
      hmap.free(map: %lm)
      return append_body_to_buf(%buf, %body)
  end
end

let emit_code_bodies = fn (buf: %ByteBuffer, funcs: [LirFunction],
                            internal_funcs: [FuncEntry], external_funcs: [FuncEntry],
                            string_lits: [StringEntry], alloc_mode: i64,
                            functions: [LirFunction], externals: [LirExternal],
                            closure_table: [FuncEntry],
                            closure_type_indices: [ArityTypeIdx],
                            internal_func_map: &HashMap,
                            external_func_map: &HashMap,
                            ss_tag_idx: i64,
                            ss_cont_type_idx: i64,
                            ss_dispatch_block_type_idx: i64,
                            ss_tag_names: [string],
                            effect_map: &EffectMap,
                            bt_capture_idx_global: i64,
                            memo_target_names: [string],
                            memo_target_slots: [i64],
                            memo_globals_base: i64,
                            import_count: i64) -> %ByteBuffer throws { CodegenError } do
  match funcs do
    | [] -> return %buf
    | f :: rest ->
      let %buf = emit_one_body(%buf, f, internal_funcs,
                                external_funcs, string_lits,
                                alloc_mode, functions, externals,
                                closure_table, closure_type_indices,
                                internal_func_map, external_func_map,
                                ss_tag_idx,
                                ss_cont_type_idx,
                                ss_dispatch_block_type_idx,
                                ss_tag_names,
                                effect_map,
                                bt_capture_idx_global,
                                memo_target_names,
                                memo_target_slots,
                                memo_globals_base,
                                import_count)
      return emit_code_bodies(%buf, funcs: rest, internal_funcs,
                        external_funcs, string_lits,
                        alloc_mode, functions, externals,
                        closure_table, closure_type_indices,
                        internal_func_map, external_func_map,
                        ss_tag_idx,
                        ss_cont_type_idx,
                        ss_dispatch_block_type_idx,
                        ss_tag_names,
                        effect_map,
                        bt_capture_idx_global,
                        memo_target_names,
                        memo_target_slots,
                        memo_globals_base,
                        import_count)
  end
end


// ─── Module entry point ────────────────────────────────────────────────────

export let compile_lir_to_wasm = fn (program: LirProgram, string_data_base: i64,
                                       effect_map: &EffectMap) -> %ByteBuffer throws { CodegenError } do
  match program do
    | LirProgram(functions: funcs, externals: all_exts) ->

      // Arena intrinsics are emitted as inline WASM, not imported.
      let intrinsic_filtered = filter_intrinsic_externals(exts: all_exts)
      let has_intrinsics = list.length(xs: all_exts) != list.length(xs: intrinsic_filtered)
      // Diamond imports can register the same WASM function under multiple Nexus
      // names; collapse them so the import section has one entry per WASM target.
      let DedupExtResult(exts, remaps: ext_remaps) = dedup_externals(exts: intrinsic_filtered)
      let filtered_program = LirProgram(functions: funcs, externals: exts)
      let n_exts = list.length(xs: exts)
      let n_funcs = list.length(xs: funcs)
      // Resolve the program-wide import index of the backtrace-capture host
      // function. main_wrap synthesises this external whenever it wraps a
      // throwing main; it is absent for programs without a wrapped main.
      // emit_one_body refines this per-function via EffectMap.can_throw
      // (issue nexus-55x0): functions that cannot transitively throw skip
      // the call entirely, while functions that may throw retain it.
      let bt_capture_idx_global = find_bt_capture_idx(exts)
      let has_eh = wcollect.program_needs_eh(funcs)
      let has_ss = wcollect.program_needs_stack_switching(funcs)
      // When `main(args)` is declared but `argv` isn't compiled in (no
      // `import "std:proc"`), the wasi_run wrapper synthesises an empty
      // Nil-shaped list on the bump heap — force heap_enabled so G0 and
      // own memory exist (issue nexus-6z4h).
      let main_has_args = program_main_has_args(funcs)
      let heap_enabled = wcollect.program_uses_heap(funcs) || main_has_args
      let has_cabi = wcollect.needs_cabi_realloc(exts)
      let n_cabi = if has_cabi then 1 else 0 end
      // alloc_mode (legacy — still stored in CodegenCtx but no longer branched
      // on by emit_*): 1 = program allocates on the heap, 0 = it does not. All
      // allocations now bump the atomic cell at wdefs.heap_ptr_cell.
      let alloc_mode = if heap_enabled then 1 else 0 end
      let import_count = n_exts

      let internal_funcs = build_internal_func_entries(funcs, import_count, idx: 0)
      let base_external_funcs = build_external_func_entries(exts, idx: 0)
      // Remap entries point duplicate names at the surviving external's index.
      let external_funcs = append_func_entries(a: ext_remaps, b: base_external_funcs)

      let %internal_func_map = wdefs.build_func_map(entries: internal_funcs)
      let %external_func_map = wdefs.build_func_map(entries: external_funcs)

      let closure_table = build_closure_table(funcs, &internal_func_map, table_idx: 0)
      let n_closures = list.length(xs: closure_table)
      let closure_arities = collect_closure_arities(funcs)

      let main_idx = wdefs.lookup_func_fast(name: "main", map: &internal_func_map)
      // Implicit `wasi_thread_start` export when the lazy/threads runtime is
      // linked (so wasi-threads workers can find the trampoline). `[]` otherwise.
      let extra_exports = wasi_thread_start_export(funcs, &internal_func_map)
      let main_ret = match wdefs.find_function_fast(name: "main", funcs, map: &internal_func_map, import_count) do
        | Some(val: LirFunction(name: _, params: _, ret_type: rt, body: _, ret: _, span: _)) -> rt
        | None -> TyUnit
      end
      // If main takes params, find argv for wasi_run wrapper.
      // Under source-qualified canonical naming, `argv` is registered as
      // `<source>#argv`; fall back to a suffix match when the bare name
      // isn't found.
      let argv_idx = match wdefs.find_function_fast(name: "main", funcs, map: &internal_func_map, import_count) do
        | Some(val: LirFunction(name: _, params: _ :: _, ret_type: _, body: _, ret: _, span: _)) ->
          let bare = wdefs.lookup_func_fast(name: "argv", map: &internal_func_map)
          if bare >= 0 then bare
          else find_func_by_suffix(funcs, map: &internal_func_map, suffix: "#argv") end
        | _ -> -1
      end

      let all_strings = wcollect.collect_program_strings(funcs, acc: [])
      let string_entries = wcollect.build_string_entries(strings: all_strings, next_offset: string_data_base, acc: [])
      let has_strings = list.length(xs: string_entries) > 0

      let mem_mode = wcollect.choose_memory_mode(externals: exts, has_strings, has_heap: heap_enabled)

      let last_end = wcollect.compute_last_string_end(entries: string_entries)
      let heap_base_raw = match last_end > string_data_base do | true -> last_end | false -> string_data_base end
      let heap_base = wcollect.align8(v: heap_base_raw)

      let cabi_realloc_idx = import_count + n_funcs
      let wasi_run_idx = import_count + n_funcs + n_cabi

      let %m = bb.empty()
      let %m = bb.push_bytes(buf: %m, bytes: [0, 97, 115, 109, 1, 0, 0, 0])

      // The allocator is fully inline (atomic bump cell), so no `__nx_allocate`
      // import — the alloc-related type slots are never reserved.
      let has_alloc = false
      let DedupedTypes(section: %type_sec, count: _,
                       ext_type_idxs,
                       func_type_idxs,
                       wasi_run_type_idx,
                       exn_tag_type_idx,
                       ss_tag_type_idx,
                       alloc_type_idx,
                       alloc_mark_type_idx,
                       alloc_reset_type_idx,
                       cabi_type_idx,
                       closure_type_idxs,
                       ss_cont_type_idx: my_cont_idx,
                       ss_dispatch_block_type_idx: my_dispatch_idx) =
        wsect.build_type_section_dedup(program: filtered_program, has_eh, has_ss, has_alloc,
                                       has_cabi_realloc: has_cabi, closure_arities)
      let ss_cont_type_idx = my_cont_idx
      let ss_dispatch_block_type_idx = my_dispatch_idx
      let %m = wdefs.emit_section(buf: %m, id: sec_type, content: %type_sec)

      let mem_is_imported = if let MemoryImported(_) = mem_mode then true else false end
      if n_exts > 0 || mem_is_imported || has_alloc then
        let %m = wdefs.emit_section(buf: %m, id: sec_import,
                               content: wsect.build_import_section(exts, ext_type_idxs,
                                 mem_mode, has_alloc,
                                 alloc_type_idx,
                                 alloc_mark_type_idx, alloc_reset_type_idx,
                                 alloc_module: mem_mode_to_module_name(mode: mem_mode)))
      end

      let %m = wdefs.emit_section(buf: %m, id: sec_function,
                             content: wsect.build_function_section(func_type_idxs,
                                                                   wasi_run_type_idx,
                                                                   has_cabi,
                                                                   cabi_type_idx))

      let %m = if n_closures > 0 || has_ss then
        wdefs.emit_section(buf: %m, id: sec_table, content: wsect.build_table_section(n_closures, has_ss, ss_cont_type_idx))
      else %m end

      let %m = if let MemoryDefined = mem_mode then
        wdefs.emit_section(buf: %m, id: sec_memory, content: wsect.build_memory_section())
      else %m end

      // Tag section must come after memory and before global.
      // Phase-3 multi-arm dispatch: one wasm tag per distinct cap method
      // (`<port>::<method>`) collected at codegen time. Computed here (early
      // enough for the tag section emission) and re-used downstream by
      // emit_code_bodies via ctx.ss_tag_names.
      let ss_tag_names_for_tags = wcollect.collect_program_tag_names(funcs)
      let n_ss_tags = if has_ss then list.length(xs: ss_tag_names_for_tags) else 0 end
      let %m = if has_eh || has_ss then
        wdefs.emit_section(buf: %m, id: sec_tag, content: wsect.build_tag_section(exn_tag_type_idx, ss_tag_type_idx, has_eh, n_ss_tags))
      else %m end

      // Memo cache plan (nexus-e6uh). Re-runs effect analysis +
      // memo_plan inside codegen so the driver doesn't have to thread the
      // plan through compile_lir_to_wasm; the cost is one extra LIR walk per
      // build, which is negligible next to wasm assembly.
      // Effect analysis must see all externals (incl. mem.* / sched.*) — the
      // arena-filtered set hides runtime effects, so functions calling
      // mem.load_i64 etc. would appear pure and get incorrectly memoised
      // (nexus-bavy soundness fix).
      let unfiltered_program = LirProgram(functions: funcs, externals: all_exts)
      let %memo_em = effect_analysis.analyze_effects(program: unfiltered_program)
      let memo_plan_full = memo_plan.plan_memoization(program: unfiltered_program, em: &memo_em)
      emap.free_effect_map(em: %memo_em)
      let memo_targets = build_memo_targets(plan: memo_plan_full)
      let n_memo_targets = memo_target_count(targets: memo_targets)
      let memo_target_names = extract_memo_names(targets: memo_targets, acc: [])
      let memo_target_slots = extract_memo_slots(targets: memo_targets, acc: [])
      // memo_globals_base is the index of the FIRST memo global in the main
      // module's local global namespace. wmerge later applies a glo_off to
      // these instructions when concatenating with the dep stdlib.
      let memo_globals_base = 3 + (if has_ss then 3 else 0 end)

      // Global section — needed for bump allocator, cabi_realloc, arena, string
      // literals, or any memo-cache target. G1 (str_base) is always needed
      // when there are string literals; memo cache globals demand a global
      // section even when none of the prior conditions apply.
      // G0/G1/G2 are vestigial now (the allocator no longer uses them; wmerge
      // still patches them). Emit when the program uses the heap, cabi_realloc,
      // arena intrinsics, string literals, stack switching, or a memo cache slot.
      let needs_global = heap_enabled || has_cabi || has_intrinsics || has_strings || has_ss || n_memo_targets > 0
      let %m = if needs_global then
        wdefs.emit_section(buf: %m, id: sec_global, content: wsect.build_global_section(heap_base, has_ss, ss_cont_type_idx, memo_cache_count: n_memo_targets))
      else %m end

      let %m = wdefs.emit_section(buf: %m, id: sec_export,
                             content: wsect.build_export_section(main_idx, wasi_run_idx,
                                                           cabi_realloc_idx,
                                                           has_cabi_realloc: has_cabi,
                                                           mem_mode,
                                                           has_table: n_closures > 0,
                                                           has_ss,
                                                           extra_exports))

      let %m = if n_closures > 0 then
        wdefs.emit_section(buf: %m, id: sec_element, content: wsect.build_element_section(closure_entries: closure_table))
      else %m end

      let closure_type_idx_list = build_closure_type_idx_list(arities: closure_arities, type_idxs: closure_type_idxs)
      let %code = bb.empty()
      let %code = bb.push_uleb128(buf: %code, val: n_funcs + n_cabi + 1)
      // ss_tag_idx is the tag-section ordinal of the stack-switching tag:
      // 1 when EH is also enabled (EH tag at 0), 0 if SS-only, -1 if absent.
      let ss_tag_idx = if has_ss then (if has_eh then 1 else 0 end) else -1 end
      // Reuse the list computed for the tag section above.
      let ss_tag_names = ss_tag_names_for_tags
      let %code = emit_code_bodies(buf: %code, funcs, internal_funcs,
                                    external_funcs, string_lits: string_entries,
                                    alloc_mode, functions: funcs, externals: all_exts,
                                    closure_table, closure_type_indices: closure_type_idx_list,
                                    &internal_func_map, &external_func_map,
                                    ss_tag_idx,
                                    ss_cont_type_idx: my_cont_idx,
                                    ss_dispatch_block_type_idx,
                                    ss_tag_names,
                                    effect_map,
                                    bt_capture_idx_global,
                                    memo_target_names,
                                    memo_target_slots,
                                    memo_globals_base,
                                    import_count)
      let %code = if has_cabi then
        let %cabi_body = compile_cabi_realloc(heap_base)
        append_body_to_buf(buf: %code, body: %cabi_body)
      else %code end
      // Synthesise an empty argv only when main has args but the program
      // doesn't pull in `argv` (issue nexus-6z4h). Requires heap_enabled
      // (forced above) so G0 + own memory exist.
      let synth_empty_argv = main_has_args && argv_idx < 0 && heap_enabled
      let %wasi_body = compile_wasi_run_wrapper(main_idx, main_ret_type: main_ret, argv_idx, synth_empty_argv)
      let %code = append_body_to_buf(buf: %code, body: %wasi_body)
      let %m = wdefs.emit_section(buf: %m, id: sec_code, content: %code)

      // Data section — string literals only. The atomic bump cell at
      // wdefs.heap_ptr_cell is NOT data-segment initialised: under WASI threads
      // each worker spawns a fresh instance that re-runs the module's data
      // segments against the SHARED linear memory, so a cell-0 data segment
      // would clobber the bump pointer mid-run. Instead emit_atomic_bump's
      // idempotent `cmpxchg(cell, 0, memory.size()*65536)` lazily seeds the
      // cell on the first allocation (the seed is the top of all static data,
      // since string literals live in the initial pages).
      let %m = wdefs.emit_section(buf: %m, id: sec_data, content: wsect.build_data_section(entries: string_entries, cell_init: 0 - 1))

      let total_named_funcs = import_count + n_funcs + 1
      let %name_payload = build_name_section(exts, funcs,
                                              has_alloc,
                                              n_exts,
                                              n_alloc_imports: 0,
                                              total_funcs: total_named_funcs)
      let name_payload_len = bb.length(buf: &name_payload)
      let %m = bb.push_byte(buf: %m, byte: sec_custom)
      let %m = bb.push_uleb128(buf: %m, val: name_payload_len)
      let %m = bb.push_buf(dst: %m, src: &name_payload)
      bb.free(buf: %name_payload)

      wdefs.free_func_map(map: %internal_func_map)
      wdefs.free_func_map(map: %external_func_map)

      return %m
  end
end

