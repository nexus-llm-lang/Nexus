/**
 * backend/errors: Codegen-phase exception types.
 *
 * `SymbolKind` discriminates the lookup kind for `SymbolNotFound`.
 * `StackSwitchingNotImplemented` gates the unimplemented with-kont path.
 * Both belong to `CodegenError` (E3xxx codes in `format_error`).
 */

/** Symbol-kind discriminator for `SymbolNotFound`.
 *  The variant set below is the audited enumeration of every value the
 *  throw sites actually used. The human label string is recovered by
 *  `symbol_kind_label` in `src/diagnostics/error.nx`.
 */
export type SymbolKind =
    SkFunction
  | SkExternal
  | SkIntrinsic
  | SkIntrinsicArg
  | SkBinaryOp
  | SkVariable
  | SkClosureArity
  | SkArmTag
  | SkArmTagIndex
  | SkSuspendTag
  | SkCallArgLabel
  | SkInjectHandler

/** Public exception SymbolNotFound. */
export exception SymbolNotFound(name: string, kind: SymbolKind, context: string)

/** Raised when codegen encounters a stack-switching IR node (LirExprSuspend,
 *  LirExprResume, LirExprContNew). The IR types exist as placeholders; codegen
 *  for the with-kont (`with @k`) path is not yet implemented.
 */
export exception StackSwitchingNotImplemented(node: string)

/** Raised by `remap_elem_go` in `wasm/merge/section_emit` when an element
 *  segment with a non-zero kind byte is encountered. The merge phase only
 *  handles kind=0 (active, implicit table 0); kinds 1-7 (passive, active
 *  with explicit table index, declarative, expression-based variants) require
 *  a dedicated forward-skip or full decode that is not yet implemented.
 *  `kind` is the raw kind byte read from the wasm binary.
 */
export exception WasmMergeUnsupported(detail: string)

/** Public exception group CodegenError. */
export exception group CodegenError = SymbolNotFound | StackSwitchingNotImplemented | WasmMergeUnsupported
