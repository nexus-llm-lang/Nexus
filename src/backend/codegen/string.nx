/**
 * codegen/string: string-valued binary-op emission.
 *
 * Owns:
 * - emit_string_concat (OpConcat / OpAdd on TyString)
 * - emit_string_compare (OpEq / OpNe on TyString)
 * - is_string_type, is_string_op, is_string_concat_op classifiers
 *
 * Does not own:
 * - emit_atom / emit_unpack_string / emit_memcpy_loop / emit_memory_grow_check
 *   (see src/backend/codegen/atom.nx)
 * - Dispatch from LirExprBinary (stays in codegen.nx emit_expr)
 *
 * Exists so codegen.nx's binary-op dispatch is one classify + one call per
 * string case instead of 200L of inline byte emission.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { BinaryOp, TypeExpr } from "src/common/ast.nx"
import { LirAtom } from "src/ir/lir_types.nx"
import { CodegenCtx,
         bt_i32, bt_void,
         heap_global_idx,
         op_call,
         op_local_get, op_local_set, op_local_tee, op_global_get, op_global_set,
         op_i32_const, op_i64_const,
         op_i32_add, op_i32_ne, op_i32_ge_u, op_i32_eqz,
         op_i64_extend_i32_u,
         op_i64_shl, op_i64_or,
         op_block, op_loop, op_br, op_br_if, op_end }, * as wdefs from "src/backend/wasm/defs.nx"
import { emit_atom, emit_unpack_string, emit_memcpy_loop, emit_memcpy_loop_offset, emit_atomic_bump } from "src/backend/codegen/atom.nx"
import { CodegenError } from "src/common/error.nx"

export let emit_string_concat = fn (lhs: LirAtom, rhs: LirAtom, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  let t = wdefs.ctx_temps_base(ctx)
  let lhs_packed = t + 4
  let rhs_packed = t + 5
  let lhs_ptr = t + 6
  let lhs_len = t + 7
  let rhs_ptr = t + 8
  let rhs_len = t + 9
  let out_ptr = t + 10
  let out_len = t + 11
  let idx_var = t + 12

  let %buf = emit_atom(atom: lhs, %buf, ctx)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: lhs_packed)
  let %buf = emit_atom(atom: rhs, %buf, ctx)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: rhs_packed)
  let %buf = emit_unpack_string(%buf, packed_local: lhs_packed, ptr_local: lhs_ptr, len_local: lhs_len)
  let %buf = emit_unpack_string(%buf, packed_local: rhs_packed, ptr_local: rhs_ptr, len_local: rhs_len)

  // out_len = lhs_len + rhs_len
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: lhs_len)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: rhs_len)
  let %buf = bb.push_bytes(%buf, bytes: [op_i32_add, op_local_set])
  let %buf = bb.push_uleb128(%buf, val: out_len)

  // Allocate on heap — unified atomic bump cell (rounds out_len up to 8;
  // the memcpy below still copies exactly lhs_len + rhs_len bytes).
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: out_len)
  let %buf = emit_atomic_bump(%buf, ctx, ptr_local: out_ptr)

  let %buf = emit_memcpy_loop(%buf, src_ptr: lhs_ptr, dst_ptr: out_ptr, dst_offset: -1,
                               len_local: lhs_len, idx_local: idx_var)
  let %buf = emit_memcpy_loop_offset(%buf, src_ptr: rhs_ptr, dst_ptr: out_ptr,
                                      offset_local: lhs_len, len_local: rhs_len, idx_local: idx_var)

  // Pack result: (out_ptr as i64) << 32 | (out_len as i64)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: out_ptr)
  let %buf = bb.push_bytes(%buf, bytes: [op_i64_extend_i32_u, op_i64_const])
  let %buf = bb.push_sleb128(%buf, val: 32)
  let %buf = bb.push_bytes(%buf, bytes: [op_i64_shl, op_local_get])
  let %buf = bb.push_uleb128(%buf, val: out_len)
  let %buf = bb.push_byte(%buf, byte: op_i64_extend_i32_u)
  return bb.push_byte(%buf, byte: op_i64_or)
end

// ─── String compare ─────────────────────────────────────────────────────────

export let is_string_type = fn (t: TypeExpr) -> bool do
  if let TyString = wdefs.peel_linear(typ: t) then true else false end
end

export let is_string_op = fn (op: BinaryOp, lhs_type: TypeExpr, rhs_type: TypeExpr) -> bool do
  // Either operand being TyString indicates string operation.
  // Pattern-extracted string vars have TyI64 (WASM type), but string literals
  // have TyString. If either side is TyString, use string comparison/concat.
  if is_string_type(t: lhs_type) || is_string_type(t: rhs_type) then
    match op do
      | OpEq -> return true | OpNe -> return true
      | OpConcat -> return true | OpAdd -> return true
      | _ -> return false
    end
  end
  return false
end

export let is_string_concat_op = fn (op: BinaryOp, typ: TypeExpr) -> bool do
  if let TyString = wdefs.peel_linear(typ) then
    match op do | OpConcat -> true | OpAdd -> true | _ -> false end
  else false end
end

export let emit_string_compare = fn (op: BinaryOp, lhs: LirAtom, rhs: LirAtom,
                               buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  let t = wdefs.ctx_temps_base(ctx)
  let lhs_packed = t + 4
  let rhs_packed = t + 5
  let lhs_ptr = t + 6
  let lhs_len = t + 7
  let rhs_ptr = t + 8
  let rhs_len = t + 9
  let idx_var = t + 12

  let %buf = emit_atom(atom: lhs, %buf, ctx)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: lhs_packed)
  let %buf = emit_atom(atom: rhs, %buf, ctx)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: rhs_packed)
  let %buf = emit_unpack_string(%buf, packed_local: lhs_packed, ptr_local: lhs_ptr, len_local: lhs_len)
  let %buf = emit_unpack_string(%buf, packed_local: rhs_packed, ptr_local: rhs_ptr, len_local: rhs_len)

  // block $done (result i32) { block $not_equal {
  let %buf = bb.push_byte(%buf, byte: op_block)
  let %buf = bb.push_byte(%buf, byte: bt_i32)
  let %buf = bb.push_byte(%buf, byte: op_block)
  let %buf = bb.push_byte(%buf, byte: bt_void)

  // Compare lengths
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: lhs_len)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: rhs_len)
  let %buf = bb.push_bytes(%buf, bytes: [op_i32_ne, op_br_if])
  let %buf = bb.push_uleb128(%buf, val: heap_global_idx)

  // Byte comparison loop
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: idx_var)
  let %buf = bb.push_byte(%buf, byte: op_block)
  let %buf = bb.push_byte(%buf, byte: bt_void)
  let %buf = bb.push_byte(%buf, byte: op_loop)
  let %buf = bb.push_byte(%buf, byte: bt_void)

  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: idx_var)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: lhs_len)
  let %buf = bb.push_bytes(%buf, bytes: [op_i32_ge_u, op_br_if])
  let %buf = bb.push_uleb128(%buf, val: 1)

  // Compare bytes
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: lhs_ptr)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: idx_var)
  let %buf = bb.push_byte(%buf, byte: op_i32_add)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_i32_load8_u)
  let %buf = wdefs.emit_memarg_i8(%buf)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: rhs_ptr)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: idx_var)
  let %buf = bb.push_byte(%buf, byte: op_i32_add)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_i32_load8_u)
  let %buf = wdefs.emit_memarg_i8(%buf)
  let %buf = bb.push_bytes(%buf, bytes: [op_i32_ne, op_br_if])
  let %buf = bb.push_uleb128(%buf, val: 2)

  // idx++
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: idx_var)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 1)
  let %buf = bb.push_bytes(%buf, bytes: [op_i32_add, op_local_set])
  let %buf = bb.push_uleb128(%buf, val: idx_var)
  let %buf = bb.push_byte(%buf, byte: op_br)
  let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
  let %buf = bb.push_bytes(%buf, bytes: [op_end, op_end])

  // Equal: push 1, br $done
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: op_br)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: op_end)
  // Not equal: push 0
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_byte(%buf, byte: op_end)

  return if let OpNe = op then bb.push_byte(%buf, byte: op_i32_eqz) else %buf end
end
