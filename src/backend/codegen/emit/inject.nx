/**
 * codegen/inject: inject / resume multi-arm emission.
 *
 * Owns:
 * - emit_inject_resume_multi — outer/loop/arm-block frame layout
 * - open_nested_arm_blocks — N nested block instructions
 * - emit_arm_on_clauses — (on tag → label) per arm
 * - arm_tag_offset_at / nth_string — tag-index lookup helpers
 * - close_and_dispatch_arms / emit_arm_dispatch — arm body dispatch + br
 *
 * Does not own:
 * - The LirExprInjectResume dispatch arm (see emit_expr in codegen.nx)
 * - Sched import detection (is_sched_set_next etc. in codegen/intrinsics/sched.nx)
 *
 * None of these functions recurse through emit_expr / emit_stmt.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { TypeExpr, TyI64 } from "src/types/type_expr.nx"
import { LirFunction, LirParam } from "src/ir/lir/types.nx"
import { emit_coercion } from "src/backend/codegen/emit/atom.nx"
import { CodegenCtx, ctx_temps_base, ctx_lookup_function } from "src/backend/codegen/ctx/context.nx"
import { bt_void,
         op_block, op_loop, op_end, op_br, op_br_if,
         op_call, op_global_get, op_global_set,
         op_local_get, op_local_set, op_local_tee,
         op_table_get, op_table_set,
         op_ref_func,
         op_resume, op_cont_new,
         op_i32_wrap_i64,
         op_i64_const, op_i64_lt_s, op_i64_add }, * as wdefs from "src/backend/wasm/defs.nx"
import { find_func_idx_by_suffix } from "src/backend/codegen/intrinsics/sched.nx"
import { Map } from "std:collection/map"
import * as wcollect from "src/backend/wasm/collect.nx"
import * as list from "std:list"
import {
  SymbolNotFound,
  CodegenError,
  SkFunction,
  SkArmTag,
  SkArmTagIndex
} from "src/backend/errors.nx"

/** Multi-arm InjectResume frame.
 *
 *  Layout for N=2 arms (innermost = arm 0):
 *
 *  block @outer
 *  setup body cont; resume_slot = next_alloc; next_alloc++
 *  loop @loop
 *  block @arm_1 (type dispatch_t_idx)
 *  block @arm_0 (type dispatch_t_idx)
 *  resume cont_t (on tag_0 @arm_0) (on tag_1 @arm_1)
 *  br 3       ;; resume returned normally → exit @outer (depth N+1)
 *  end
 *  ;; tag_0 caught: dispatch arm 0 with [payload, contref]
 *  br 1         ;; back to @loop (depth N - 0 - 1 = 1)
 *  end
 *  ;; tag_1 caught
 *  br 0           ;; back to @loop (depth N - 1 - 1 = 0)
 *  end
 *  end
 *
 *  Every match arm uses explicit `return` (defensive against an earlier
 *  self-compile hang whose root cause was never nailed; uniform returns
 *  sidestep whatever runtime pattern was responsible).
 */
export let emit_inject_resume_multi = fn (buf: %ByteBuffer, body_fn: string, arm_fns: [ string ],
                                           arm_tags: [ string ], result_typ: TypeExpr, arm_cont_binders: [ string ], ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  let CodegenCtx(locals: _, string_lits: _, temps_base: _, func_ret_type: _, functions: _,
                  externals: _, closure_table: _, closure_type_indices: _,
                  internal_func_map: ifm, external_func_map: _, ss_tag_idx: ss_base,
                  ss_cont_type_idx: cont_t_idx, ss_dispatch_block_type_idx: dispatch_t_idx,
                  ss_tag_idx_map: tag_idx_map, _) = ctx
  let body_idx = wdefs.lookup_func_fast(name: body_fn, map: &ifm)
  let n_arms_raw = list.length(xs: arm_fns)
  // arm_tags may be empty when the MIR path doesn't populate tags. Force
  // a single-on-clause shape so the dispatcher remains valid; first arm
  // gets tag 0. arm_fns must have at least one entry (InjectResume is only
  // constructed when at least one with-kont arm exists).
  let n_arms = if n_arms_raw == 0 then 1 else n_arms_raw end

  // @outer
  let %buf = bb.push_bytes(%buf, bytes: [ op_block, bt_void ])

  // kidtq: capture the ss_next_alloc high-water at THIS inject's entry into the
  // per-frame base_alloc local. Reset to it at @outer exit so the slots this
  // inject claims (its body cont + any spawns) are reclaimed when it finishes —
  // sequential injects then reuse the same slots instead of climbing toward the
  // fixed 64-slot cont table. (Companion to cur_slot, which already keeps a
  // single inject's yields from growing it.)
  let base_alloc = ctx_temps_base(ctx) + 18
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: base_alloc)

  // Body cont setup
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_wrap_i64, op_ref_func ])
  let %buf = bb.push_uleb128(%buf, val: body_idx)
  let %buf = bb.push_byte(%buf, byte: op_cont_new)
  let %buf = bb.push_uleb128(%buf, val: cont_t_idx)
  let %buf = bb.push_byte(%buf, byte: op_table_set)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_table_idx)

  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_resume_slot_global_idx)

  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_i64_const)
  let %buf = bb.push_sleb128(%buf, val: 1)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i64_add, op_global_set ])
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)

  // @loop
  let %buf = bb.push_bytes(%buf, bytes: [ op_loop, bt_void ])

  // Snapshot the slot to resume into the per-frame `cur_slot` local. The global
  // ss_resume_slot is the arm→loop handoff; pinning it to a LOCAL de-globalizes
  // the resume target so (a) a nested suspend cannot clobber which slot THIS
  // frame resumes, and (b) the arm can reuse this exact slot — which the resume
  // is about to CONSUME (continuations are one-shot) — for its suspend reify,
  // instead of bump-allocating a fresh one. That bounds the cont table by the
  // number of live fibers rather than the cumulative suspend count, so a long-
  // running coop loop (generator / scheduler) no longer exhausts the 64 slots.
  let cur_slot = ctx_temps_base(ctx) + 17
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_resume_slot_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: cur_slot)

  // N nested arm blocks (outermost first)
  let %buf = open_nested_arm_blocks(%buf, dispatch_t_idx, n: n_arms)

  // resume table[cur_slot] + on-clauses
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: cur_slot)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_wrap_i64, op_table_get ])
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_table_idx)
  let %buf = bb.push_byte(%buf, byte: op_resume)
  let %buf = bb.push_uleb128(%buf, val: cont_t_idx)
  let %buf = bb.push_uleb128(%buf, val: n_arms)
  let %buf = emit_arm_on_clauses(%buf, arm_tags, ss_base, tag_idx_map, n_arms, idx: 0)

  // Normal-return path. The naive `br N+1` (exit dispatcher) prematurely
  // strands queued fibers when the spawner cont (main's body) finishes
  // first. Instead: dequeue the next runnable; if the run queue is empty
  // (__nx_sched_dequeue returns -1), THEN exit. Otherwise set resume_slot and
  // br back to @loop so the fibers drain. The dequeue op resolves to the in-wasm
  // Nexus function in nxlib/stdlib/runtime/sched.nx (located by suffix), so no
  // host import is required.
  //
  // The drain must be emitted ONLY for THIS dispatcher when it is the
  // cooperative SCHEDULER — i.e. one of its `with @k` arms enqueues/dequeues the
  // shared run queue (std:concurrency/coop). A NESTED generator dispatcher
  // (collector arm = bare `@k`) or a plain inject must NOT drain, or it would
  // drain the ENCLOSING scheduler's queue and steal/reorder its ready tasks
  // (nexus-5eqzh). Gating only on the module-global existence of
  // `__nx_sched_dequeue` is too coarse: it fires the drain in every dispatcher
  // whenever a coop scheduler appears anywhere in the module.
  let CodegenCtx(
    locals: _,
    string_lits: _,
    temps_base: _,
    func_ret_type: _,
    functions: disp_fns,
    externals: _,
    closure_table: _,
    closure_type_indices: _,
    internal_func_map: disp_ifm,
    _
  ) = ctx
  let dequeue_idx = find_func_idx_by_suffix(
    suffix: "__nx_sched_dequeue",
    funcs: disp_fns,
    internal_func_map: &disp_ifm)
  let is_scheduler = any_arm_drains_run_queue(arm_fns, ctx)
  let %buf = if dequeue_idx >= 0 && is_scheduler then
    let tmp_local = ctx_temps_base(ctx) + 5
    let %b = bb.push_byte(%buf, byte: op_call)
    let %b = bb.push_uleb128(buf: %b, val: dequeue_idx)
    let %b = bb.push_byte(buf: %b, byte: op_local_tee)
    let %b = bb.push_uleb128(buf: %b, val: tmp_local)
    let %b = bb.push_byte(buf: %b, byte: op_i64_const)
    let %b = bb.push_sleb128(buf: %b, val: 0)
    let %b = bb.push_bytes(buf: %b, bytes: [ op_i64_lt_s, op_br_if ])
    let %b = bb.push_uleb128(buf: %b, val: n_arms + 1)
    let %b = bb.push_byte(buf: %b, byte: op_local_get)
    let %b = bb.push_uleb128(buf: %b, val: tmp_local)
    let %b = bb.push_byte(buf: %b, byte: op_global_set)
    let %b = bb.push_uleb128(buf: %b, val: wdefs.ss_resume_slot_global_idx)
    let %b = bb.push_byte(buf: %b, byte: op_br)
    bb.push_uleb128(buf: %b, val: n_arms)
  else
    // Not the scheduler dispatcher: either no sched runtime is imported (e.g.
    // handler_with_kont_resume, a hand-rolled handler with no global queue), or
    // this is a generator / plain inject whose arms do not own the run queue.
    // Fall back to the simple exit-on-normal-return path — draining here would
    // steal the enclosing scheduler's ready fibers (nexus-5eqzh).
    let %b = bb.push_byte(%buf, byte: op_br)
    bb.push_uleb128(buf: %b, val: n_arms + 1)
  end

  // Close arm blocks innermost first; emit per-arm dispatch + br to @loop
  let %buf = close_and_dispatch_arms(%buf, arm_fns, arm_cont_binders, n_arms, ctx, idx: 0)

  let %buf = bb.push_byte(%buf, byte: op_end)  // close @loop
  let %buf = bb.push_byte(%buf, byte: op_end)  // close @outer

  // kidtq: reclaim this inject's cont-table slots by resetting ss_next_alloc to
  // the entry high-water (base_alloc). By @outer exit every fiber this inject
  // created (its body cont + any spawns) has completed — the scheduler drains
  // remaining tasks on the body's normal return — so those slots are dead; the
  // reset lets the next inject/spawn reuse them instead of the cursor climbing
  // monotonically toward the 64-slot cap. Emitted before the pending-exn
  // re-throw below so the reclaim also runs on the exceptional exit path.
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: base_alloc)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)

  // Re-throw any pending escaped throw on the parent stack (see
  // emit_pending_exn_rethrow). Gated on EH being present.
  let CodegenCtx(
    locals: _,
    string_lits: _,
    temps_base: _,
    func_ret_type: _,
    functions: _,
    externals: _,
    closure_table: _,
    closure_type_indices: _,
    internal_func_map: _,
    external_func_map: _,
    ss_tag_idx: ss_base_eh,
    _
  ) = ctx
  let %buf = emit_pending_exn_rethrow(%buf, has_eh: ss_base_eh >= 1)

  // Value-producing inject: the body stored its trailing value
  // into ss_inject_value before its `() -> ()` continuation returned. Read it
  // back here so the inject expression leaves the body's value on the stack.
  // Unit injects leave the stack empty (the frame is `bt_void`), as before.
  if wdefs.is_unit(typ: result_typ) then return %buf end
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  return bb.push_uleb128(%buf, val: wdefs.ss_inject_value_global_idx)
end

/** True iff THIS dispatcher is the cooperative scheduler — i.e. any of its
 *  `with @k` arm functions calls a sched run-queue intrinsic
 *  (`__nx_sched_enqueue` / `__nx_sched_dequeue`). The coop scheduler arm
 *  (std:concurrency/coop) enqueues the suspended task and dequeues the next
 *  ready one; a generator collector arm just `@k`-resumes (no queue ops), and a
 *  plain inject has no arm. Only the scheduler may drain the run queue on a
 *  body's normal return — a nested generator dispatcher draining it would steal
 *  the enclosing scheduler's ready fibers (nexus-5eqzh). Arms whose function
 *  body is not found (defensive) are treated as non-scheduler. */
let any_arm_drains_run_queue = fn (arm_fns: [ string ], ctx: CodegenCtx) -> bool do
  match arm_fns do
    | [] -> return false
    | arm :: rest ->
      let drains = match ctx_lookup_function(ctx, name: arm) do
        | Some(val: f) -> wcollect.function_calls_sched_queue(f: f)
        | None -> false
      end
      if drains then return true end
      return any_arm_drains_run_queue(arm_fns: rest, ctx)
  end
end

/** Re-throw a throw that escaped the resumed `__inject_N` body, on the parent
 *  (dispatcher) stack. wasmtime-44 stack-switching SWALLOWS an exception raised
 *  inside a resumed continuation — it never unwinds across `op_resume` into
 *  this frame (nexus-uqpe4). The body's own landing pad (compile_function_body)
 *  instead caught it, set ss_pending_exn, and stashed the payload in
 *  ss_pending_payload, then returned normally. We are now back on the parent
 *  stack (the resume frame exited); if the flag is set, clear it and re-throw
 *  the payload via the exn tag, where it propagates normally to any enclosing
 *  guest try/catch and honours the declared `throws` row. The original throw's
 *  backtrace snapshot is preserved (no re-snapshot). Emits:
 *    if ss_pending_exn != 0 { ss_pending_exn = 0; throw ss_pending_payload }
 *  No-op when `has_eh` is false (no exn tag exists to throw). */
let emit_pending_exn_rethrow = fn (
  buf: %ByteBuffer,
  has_eh: bool
) -> %ByteBuffer throws { CodegenError } do
  if !has_eh then return %buf end
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_pending_exn_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_i64_const)
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_bytes(%buf, bytes: [ wdefs.op_i64_ne, wdefs.op_if, bt_void ])
  // clear the flag so a later inject in the same function starts clean
  let %buf = bb.push_byte(%buf, byte: op_i64_const)
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_pending_exn_global_idx)
  // push payload, re-throw on the parent stack via the exn tag
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_pending_payload_global_idx)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_throw)
  let %buf = bb.push_uleb128(%buf, val: wdefs.heap_global_idx)
  return bb.push_byte(%buf, byte: op_end)  // close if
end

let open_nested_arm_blocks = fn (
  buf: %ByteBuffer,
  dispatch_t_idx: i64,
  n: i64
) -> %ByteBuffer throws { CodegenError } do
  if n <= 0 then return %buf end
  let %buf = bb.push_byte(%buf, byte: op_block)
  let %buf = bb.push_sleb128(%buf, val: dispatch_t_idx)
  return open_nested_arm_blocks(%buf, dispatch_t_idx, n: n - 1)
end

/** Emit one `(on tag → label)` per arm. Arm `i` targets label depth `i`
 *  (innermost arm = depth 0). When arm_tags is empty (single-arm path),
 *  fall through to ss_base for the only on-clause.
 */
let emit_arm_on_clauses = fn (buf: %ByteBuffer, arm_tags: [ string ],
                              ss_base: i64, tag_idx_map: Map<string, i64>, n_arms: i64, idx: i64) -> %ByteBuffer throws { CodegenError } do
  if idx >= n_arms then return %buf end
  let tag_idx = match arm_tags do
    | [] -> ss_base
    | _ -> ss_base + arm_tag_offset_at(arm_tags, idx, tag_idx_map)
  end
  let %buf = bb.push_byte(%buf, byte: 0)
  let %buf = bb.push_uleb128(%buf, val: tag_idx)
  let %buf = bb.push_uleb128(%buf, val: idx)
  return emit_arm_on_clauses(%buf, arm_tags, ss_base, tag_idx_map, n_arms, idx: idx + 1)
end

let arm_tag_offset_at = fn (
  arm_tags: [ string ],
  idx: i64,
  tag_idx_map: Map<string, i64>
) -> i64 throws { CodegenError } do
  let tn = nth_string(xs: arm_tags, idx)
  let off = wcollect.lookup_tag_idx_map(tag_name: tn, idx_map: tag_idx_map)
  if off < 0 then
    throw SymbolNotFound(
      name: tn,
      kind: SkArmTag,
      context: "arm_tag_offset_at: tag missing in ss_tag_names"
    )
  end
  return off
end

let nth_string = fn (xs: [ string ], idx: i64) -> string throws { CodegenError } do
  match xs do
    | [] -> throw SymbolNotFound(
      name: "<arm_tag>",
      kind: SkArmTagIndex,
      context: "nth_string out of range"
    )
    | x :: rest ->
      if idx <= 0 then return x end
      return nth_string(xs: rest, idx: idx - 1)
  end
end

let close_and_dispatch_arms = fn (buf: %ByteBuffer, arm_fns: [ string ], arm_cont_binders: [ string ], n_arms: i64,
                                   ctx: CodegenCtx, idx: i64) -> %ByteBuffer throws { CodegenError } do
  if idx >= n_arms then return %buf end
  // Resolve the throwable string lookups BEFORE threading the linear `%buf`
  // through `bb.push_byte`: if `nth_string` raised while a freshly-produced
  // `%buf` were live, that buffer would leak (E0540).  Doing the lookups
  // first keeps no producer-result buffer live across a throwable call.
  let arm_fn = nth_string(xs: arm_fns, idx)
  // The cont-binder name is parallel to arm_fns; fall back to "" (treat all
  // params as payload) when absent so a tag-less single-arm path still emits.
  let cont_binder = match arm_cont_binders do
    | [] -> ""
    | _ -> nth_string(xs: arm_cont_binders, idx)
  end
  let %buf = bb.push_byte(%buf, byte: op_end)  // close arm `idx`'s block
  let %buf = emit_arm_dispatch(%buf, arm_fn, cont_binder, ctx)
  let %buf = bb.push_byte(%buf, byte: op_br)
  let %buf = bb.push_uleb128(%buf, val: n_arms - idx - 1)
  return close_and_dispatch_arms(%buf, arm_fns, arm_cont_binders, n_arms, ctx, idx: idx + 1)
end

/** Look up the handler arm's (label-sorted) LIR parameters. Empty on miss. */
let arm_params = fn (ctx: CodegenCtx, arm_fn: string) -> [ LirParam ] do
  match ctx_lookup_function(ctx, name: arm_fn) do
    | Some(val: LirFunction(name: _, params: ps, ret_type: _, body: _, ret: _, span: _)) -> return ps
    | None -> return []
  end
end

/** Emit the call arguments for one handler arm in its (label-sorted) parameter
 *  order. Two logical values are routed to their parameters by NAME:
 *   - the `with @k` cont-binder parameter (name == `cont_binder`) receives the
 *     resume-slot value `ss_next_alloc` (i64, the freshly reified continuation
 *     table slot — the same value the post-call bookkeeping increments);
 *   - every other parameter is the cap-method payload, delivered on the uniform
 *     i64 channel via `temp_idx`, narrowed back to the parameter's native type
 *     (bool/i32/char → i32, f64 reinterpret; i64/string unchanged).
 *  Parameters are alphabetically label-sorted at LIR lowering, so the binder is
 *  NOT necessarily first — emitting strictly in param order keeps the wasm call
 *  ABI aligned regardless of how `k` sorts against the payload label. */
let emit_arm_call_args = fn (
  buf: %ByteBuffer,
  params: [ LirParam ],
  cont_binder: string,
  temp_idx: i64,
  ctx: CodegenCtx
) -> %ByteBuffer throws { CodegenError } do
  match params do
    | [] -> return %buf
    | LirParam(label: _, name: pn, typ: pt) :: rest ->
      let %buf = if pn == cont_binder then
        // Cont-binder parameter: cur_slot (the per-frame local holding the slot
        // the dispatcher just resumed and reified the suspended continuation back
        // into). Forcing @k therefore resumes exactly that slot.
        let %b = bb.push_byte(%buf, byte: op_local_get)
        bb.push_uleb128(buf: %b, val: ctx_temps_base(ctx) + 17)
      else
        // Payload parameter: read off the i64 channel, narrow to native type.
        let %b = bb.push_byte(%buf, byte: op_local_get)
        let %b = bb.push_uleb128(buf: %b, val: temp_idx)
        emit_coercion(from_type: TyI64, to_type: pt, buf: %b)
      end
      return emit_arm_call_args(%buf, params: rest, cont_binder, temp_idx, ctx)
  end
end

let emit_arm_dispatch = fn (
  buf: %ByteBuffer,
  arm_fn: string,
  cont_binder: string,
  ctx: CodegenCtx
) -> %ByteBuffer throws { CodegenError } do
  let CodegenCtx(
    locals: _,
    string_lits: _,
    temps_base: _,
    func_ret_type: _,
    functions: _,
    externals: _,
    closure_table: _,
    closure_type_indices: _,
    internal_func_map: ifm,
    _
  ) = ctx
  let arm_idx = wdefs.lookup_func_fast(name: arm_fn, map: &ifm)
  if arm_idx < 0 then
    bb.free(buf: %buf)
    throw SymbolNotFound(name: arm_fn, kind: SkFunction, context: "emit_arm_dispatch")
  end
  let params = arm_params(ctx, arm_fn)
  let temp_idx = ctx_temps_base(ctx)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: temp_idx)

  // Reify the suspended continuation back into the slot the loop just resumed
  // (cur_slot, the per-frame local). That slot's previous continuation was
  // consumed by the resume (continuations are one-shot), so reusing it is sound
  // — and a yield therefore does NOT grow the cont table: a fiber keeps its slot
  // across suspend/resume, so the table is bounded by the live-fiber count, not
  // the cumulative suspend count (a long coop loop no longer exhausts 64 slots).
  // Because cur_slot is a per-frame LOCAL (not the shared ss_next_alloc global),
  // a nested suspend reifies into ITS OWN frame's slot and cannot clobber this
  // one — this subsumes the earlier ss_next_alloc reserve-before-call jmvqp fix.
  let cur_slot = ctx_temps_base(ctx) + 17
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: cur_slot)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_wrap_i64, op_global_get ])
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_table_set)
  let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_table_idx)

  // Push the arm's arguments in label-sorted parameter order: the cont-binder
  // gets cur_slot (the slot we just reified into), the (narrowed) payload goes
  // on the i64 channel to the cap-method param.
  let %buf = emit_arm_call_args(%buf, params, cont_binder, temp_idx, ctx)
  let %buf = bb.push_byte(%buf, byte: op_call)
  return bb.push_uleb128(%buf, val: arm_idx)
end
