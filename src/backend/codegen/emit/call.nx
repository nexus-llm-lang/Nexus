/**
 * codegen/call: internal / external / closure / memoized / intrinsic call emission.
 *
 * Owns:
 * - emit_force_closure — 0-arg thunk call via call_indirect
 * - emit_external_arg — ABI coercion for external call arguments
 * - emit_internal_call_args / emit_external_call_args / find_call_arg_value
 * - emit_internal_call — direct WASM call with tail/memo branching
 * - emit_memoized_internal_call — last-call cache for 1-arg pure fns
 * - unpack_key_to_param — reverse-coerce memo key to param type
 * - emit_external_call — canonical string return + arg packing
 * - emit_intrinsic — unified intrinsic dispatch (HeapMark … UnknownIntrinsic)
 * - emit_call — top-level call dispatcher (intrinsic / sched / internal / external)
 * - lookup_closure_table_idx
 * - lookup_closure_type_idx_pairs
 * - emit_closure_captures / emit_closure_call_args
 *
 * Does not own:
 * - The LirExprCall / LirExprTailCall / LirExprMakeClosure / LirExprCallClosure
 *   dispatch arms (see emit_expr in codegen.nx — it calls emit_call etc. from here)
 * - emit_expr / emit_stmt (those form the SCC in codegen.nx)
 *
 * None of these functions recurse through emit_expr / emit_stmt.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { TypeExpr, TyI64, TyIntLit } from "src/types/type_expr.nx"
import { LirAtom, LirCallArg, LirParam, LirExternal, LirFunction } from "src/ir/lir/types.nx"
import {
  CodegenCtx,
  ctx_temps_base,
  ctx_externals,
  ctx_lookup_function
} from "src/backend/codegen/ctx/context.nx"
import { FuncEntry, ArityTypeIdx,
         heap_global_idx,
         op_call, op_call_indirect, op_return_call,
         op_local_get, op_local_set, op_local_tee,
         op_global_get, op_global_set,
         op_i32_load,
         op_i32_const, op_i64_const,
         op_i32_wrap_i64, op_i64_extend_i32_u, op_i64_load,
         op_i64_eq, op_i64_shl, op_i64_shr_s, op_i64_or,
         op_i32_and,
         op_f64_sqrt, op_f64_floor, op_f64_ceil, op_f64_abs,
         op_simd_f32x4_add, op_simd_f32x4_sub, op_simd_f32x4_mul, op_simd_f32x4_div,
         op_simd_f64x2_add, op_simd_f64x2_sub, op_simd_f64x2_mul, op_simd_f64x2_div,
         op_simd_i32x4_add, op_simd_i32x4_sub, op_simd_i32x4_mul,
         op_simd_i64x2_add, op_simd_i64x2_sub, op_simd_i64x2_mul,
         bt_i64, op_if, op_else, op_end }, * as wdefs from "src/backend/wasm/defs.nx"
import {
  emit_atom,
  emit_coercion,
  emit_pack_to_i64,
  emit_typed_field_store,
  emit_atomic_bump
} from "src/backend/codegen/emit/atom.nx"
import { parse_intrinsic, get_intrinsic_wasm_name,
         HeapMark, HeapReset, HeapSwap, AllocRaw,
         MemLoadI32, MemStoreI32, MemLoadU8, MemStoreU8,
         MemLoadI64, MemStoreI64, MemLoadF32, MemStoreF32, MemLoadF64, MemStoreF64,
         MemSize, MemGrow,
         AtomicRmwAddI32, AtomicLoadI32, AtomicStoreI32,
         AtomicCmpxchgI32, AtomicWait32, AtomicNotify, AtomicFence,
         CastToI32, CastToI64,
         ForceClosure, ThunkAddr, ValueOfI64,
         ArrayLength,
         F64Sqrt, F64Floor, F64Ceil, F64Abs,
         SimdF32x4Add, SimdF32x4Mul, SimdF64x2Add, SimdF64x2Mul,
         SimdI32x4Add, SimdI32x4Mul, SimdI64x2Add, SimdI64x2Mul,
         SimdF32x4AddArray, SimdF64x2AddArray, SimdI32x4AddArray, SimdI64x2AddArray,
         SimdF32x4MulArray, SimdF64x2MulArray, SimdI32x4MulArray, SimdI64x2MulArray,
         SimdF32x4SubArray, SimdF64x2SubArray, SimdI32x4SubArray, SimdI64x2SubArray,
         SimdF32x4DivArray, SimdF64x2DivArray,
         BtDepth, BtFrame, CaptureBacktrace,
         UnknownIntrinsic } from "src/backend/codegen/intrinsics.nx"
import { is_sched_set_next, emit_sched_set_next,
         is_sched_spawn, emit_sched_spawn } from "src/backend/codegen/intrinsics/sched.nx"
import {
  emit_heap_mark,
  emit_heap_reset,
  emit_heap_swap,
  emit_alloc_raw
} from "src/backend/codegen/intrinsics/heap.nx"
import { emit_mem_load_i32, emit_mem_store_i32, emit_mem_load_u8, emit_mem_store_u8,
         emit_mem_load_i64, emit_mem_store_i64,
         emit_mem_load_f32, emit_mem_store_f32, emit_mem_load_f64, emit_mem_store_f64,
         emit_mem_size, emit_mem_grow,
         emit_atomic_rmw_add_i32, emit_atomic_load_i32, emit_atomic_store_i32,
         emit_atomic_cmpxchg_i32, emit_atomic_wait32, emit_atomic_notify,
         emit_atomic_fence,
         emit_cast_to_i32, emit_cast_to_i64 } from "src/backend/codegen/intrinsics/mem.nx"
import { emit_lazy_passthrough,
         emit_bt_depth, emit_bt_frame, emit_capture_backtrace,
         emit_array_get, emit_array_set, emit_array_length,
         emit_hreg_get, emit_hreg_set,
         emit_inject_env_get, emit_inject_env_set } from "src/backend/codegen/intrinsics/threads.nx"
import { emit_f64_unary } from "src/backend/codegen/intrinsics/math.nx"
import { emit_simd_binop_one, emit_simd_binop_array } from "src/backend/codegen/intrinsics/simd.nx"
import { lookup_memo_slot }, * as memo from "src/backend/codegen/ctx/memo.nx"
import { Map }, * as map from "std:collection/map"
import * as list from "std:list"
import * as str from "std:str"
import { SymbolNotFound, CodegenError,
         SkFunction, SkIntrinsic, SkIntrinsicArg, SkClosureArity, SkCallArgLabel, SkSuspendTag } from "src/backend/errors.nx"

// Result of `lookup_closure_type_idx_pairs_keep_buf`: carries the code buffer
// back out alongside the resolved closure-call type index.
type TypeIdxWithBuf = TypeIdxWithBuf(buf: %ByteBuffer, type_idx: i64)

// `lookup_closure_type_idx_pairs` is throwable (raises SymbolNotFound when the
// arity is absent) and the code buffer `%buf` is live across it but is not
// consumed by it, so on a raise `%buf` would leak. Take `%buf` by move so this
// helper owns its disposal: free it on the throw path and hand it back on
// success together with the resolved type index.
let lookup_closure_type_idx_pairs_keep_buf = fn (
  buf: %ByteBuffer,
  arity: i64,
  pairs: [ ArityTypeIdx ]
) -> TypeIdxWithBuf throws { CodegenError } do
  try
    let ti = lookup_closure_type_idx_pairs(arity, pairs)
    return TypeIdxWithBuf(buf: %buf, type_idx: ti)
  catch e ->
    bb.free(buf: %buf)
    throw e
  end
end

// Result of `find_call_arg_value_keep_buf`: carries the code buffer back out
// alongside the resolved call-argument atom.
type ArgValueWithBuf = ArgValueWithBuf(buf: %ByteBuffer, value: LirAtom)

// `find_call_arg_value` is throwable (raises SymbolNotFound when the label is
// absent) and the code buffer `%buf` is live across it but is not consumed by
// it, so on a raise `%buf` would leak. Take `%buf` by move so this helper owns
// its disposal: free it on the throw path and hand it back on success together
// with the resolved argument atom.
let find_call_arg_value_keep_buf = fn (
  buf: %ByteBuffer,
  label: string,
  args: [ LirCallArg ]
) -> ArgValueWithBuf throws { CodegenError } do
  try
    let v = find_call_arg_value(label, args)
    return ArgValueWithBuf(buf: %buf, value: v)
  catch e ->
    bb.free(buf: %buf)
    throw e
  end
end

let emit_force_closure = fn (
  args: [ LirCallArg ],
  buf: %ByteBuffer,
  ctx: CodegenCtx
) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [ op_i32_wrap_i64, op_i64_load ])
      let %buf = wdefs.emit_memarg_i64(%buf, offset: 0)
      let %buf = bb.push_bytes(%buf, bytes: [ op_i32_wrap_i64, op_call_indirect ])
      let CodegenCtx(locals: _, string_lits: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: cti, _) = ctx
      // `%buf` is live across the throwable closure-type lookup; the helper
      // takes it by move and frees it on the throw path.
      let TypeIdxWithBuf(buf: %buf, type_idx) =
        lookup_closure_type_idx_pairs_keep_buf(buf: %buf, arity: 0, pairs: cti)
      let %buf = bb.push_uleb128(%buf, val: type_idx)
      let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
      return %buf
    | _ ->
      bb.free(buf: %buf)
      throw SymbolNotFound(name: "__nx_force_closure", kind: SkIntrinsicArg, context: "")
  end
end

let emit_external_arg = fn (
  atom: LirAtom,
  param_type: TypeExpr,
  buf: %ByteBuffer,
  ctx: CodegenCtx
) -> %ByteBuffer throws { CodegenError } do
  match wdefs.peel_linear(typ: param_type) do
    | TyString | TyArray(_) ->
      let packed_tmp = ctx_temps_base(ctx)
      let %buf = emit_atom(atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 32)
      let %buf = bb.push_bytes(%buf, bytes: [ op_i64_shr_s, op_i32_wrap_i64, op_local_get ])
      let %buf = bb.push_uleb128(%buf, val: packed_tmp)
      return bb.push_byte(%buf, byte: op_i32_wrap_i64)
    | TyChar ->
      // Internal and external both use i32 for char — no conversion needed
      let %buf = emit_atom(atom, %buf, ctx)
      return emit_coercion(from_type: wdefs.atom_type(atom), to_type: param_type, %buf)
    | _ ->
      let %buf = emit_atom(atom, %buf, ctx)
      return emit_coercion(from_type: wdefs.atom_type(atom), to_type: param_type, %buf)
  end
end

let emit_internal_call_args = fn (
  buf: %ByteBuffer,
  args: [ LirCallArg ],
  params: [ LirParam ],
  ctx: CodegenCtx
) -> %ByteBuffer throws { CodegenError } do
  match args do
    | [] -> return %buf
    | LirCallArg(label: _, value: v) :: rest_args ->
      match params do
        | [] -> return %buf
        | LirParam(label: _, name: _, typ: pt) :: rest_params ->
          // unit is represented as i64 in the wasm ABI (one slot per param),
          // but emit_atom(LirAtomUnit) is a no-op that pushes nothing. Push
          // the canonical i64 0 placeholder so the call has the right arity.
          let %buf = if wdefs.is_unit(typ: pt) then
            let %buf = bb.push_byte(%buf, byte: op_i64_const)
            bb.push_sleb128(%buf, val: 0)
          else
            let %buf = emit_atom(atom: v, %buf, ctx)
            emit_coercion(from_type: wdefs.atom_type(atom: v), to_type: pt, %buf)
          end
          return emit_internal_call_args(%buf, args: rest_args, params: rest_params, ctx)
      end
  end
end

let find_call_arg_value = fn (
  label: string,
  args: [ LirCallArg ]
) -> LirAtom throws { CodegenError } do
  match args do
    | [] -> throw SymbolNotFound(name: label, kind: SkCallArgLabel, context: "find_call_arg_value")
    | LirCallArg(label: l, value: v) :: rest ->
      if l == label then return v
      else return find_call_arg_value(label, args: rest)
      end
  end
end

let emit_external_call_args = fn (
  buf: %ByteBuffer,
  args: [ LirCallArg ],
  params: [ LirParam ],
  ctx: CodegenCtx
) -> %ByteBuffer throws { CodegenError } do
  // Iterate params in source order (matching stdlib ABI), look up args by label
  match params do
    | [] -> return %buf
    | LirParam(label: pl, name: _, typ: pt) :: rest_params ->
      // `%buf` is live across the throwable arg-label lookup; the helper takes
      // it by move and frees it on the throw path.
      let ArgValueWithBuf(buf: %buf, value: v) =
        find_call_arg_value_keep_buf(buf: %buf, label: pl, args)
      let %buf = emit_external_arg(atom: v, param_type: pt, %buf, ctx)
      return emit_external_call_args(%buf, args, params: rest_params, ctx)
  end
end

let emit_internal_call = fn (func: string, args: [ LirCallArg ], buf: %ByteBuffer, ctx: CodegenCtx,
                                     is_tail: bool, in_try: bool, int_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match ctx_lookup_function(ctx, name: func) do
    | Some(val: LirFunction(name: _, params, ret_type: callee_rt, body: _, ret: _, span: _)) ->
      let CodegenCtx(
        locals: _,
        string_lits: _,
        temps_base: _,
        func_ret_type: caller_rt,
        functions: _,
        externals: _,
        closure_table: _,
        closure_type_indices: _,
        internal_func_map: _,
        external_func_map: _,
        ss_tag_idx: _,
        ss_cont_type_idx: _,
        ss_dispatch_block_type_idx: _,
        ss_tag_idx_map: _,
        bt_capture_idx: _,
        memo_target_map: mtm,
        _
      ) = ctx
      // return_call requires callee return type ≡ caller return type. When a
      // unit-returning fn is tail-called from a non-unit-returning wrapper
      // (e.g. closure body wrapping `let @t = unit_returning_fn()`), fall
      // back to a regular call so emit_return_value can supply the placeholder.
      // also reject when the wasm value-types (TyBool→i32,
      // TyI64→i64, etc.) differ — a lifted-lambda wrapper coerces its
      // declared ret type to i64 (canonical closure slot), but the underlying
      // callee may return i32 (bool). Without this check, return_call emits
      // a wasm with mismatched types that the validator rejects.
      let units_match = wdefs.is_unit(typ: callee_rt) == wdefs.is_unit(typ: caller_rt)
      let slots_match = wdefs.type_to_valtype(typ: callee_rt) == wdefs.type_to_valtype(typ: caller_rt)
      let types_match = units_match && slots_match
      let use_tail = is_tail && !in_try && types_match

      // Memoization: single-slot last-call cache for 1-arg
      // single-word-key pure fns, gated on slot-table membership and a
      // non-tail / non-try call site so the if/else result discipline holds.
      let memo_slot = lookup_memo_slot(name: func, targets: mtm)
      if !use_tail && !in_try && memo_slot >= 0 then
        return emit_memoized_internal_call(func, args, params, callee_rt,
                                            %buf, ctx,
                                            int_idx, slot: memo_slot)
      end

      let %buf = emit_internal_call_args(%buf, args, params, ctx)
      let call_op = match use_tail do | true -> op_return_call | false -> op_call end
      let %buf = bb.push_byte(%buf, byte: call_op)
      return bb.push_uleb128(%buf, val: int_idx)
    | None ->
      bb.free(buf: %buf)
      throw SymbolNotFound(name: func, kind: SkFunction, context: "internal call")
  end
end

/** Emit a memoized call sequence for a 1-arg single-word-key pure function.
 *  Pre-condition (caller-enforced): slot is valid, args.length == 1,
 *  param_types[0] is a single-word-key type per memo.is_single_word_key_type,
 *  !is_tail, !in_try.
 */
let emit_memoized_internal_call = fn (func: string, args: [ LirCallArg ], params: [ LirParam ],
                                         callee_rt: TypeExpr,
                                         buf: %ByteBuffer, ctx: CodegenCtx,
                                         int_idx: i64, slot: i64) -> %ByteBuffer throws { CodegenError } do
  let CodegenCtx(locals: _, string_lits: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_idx_map: _, bt_capture_idx: _, memo_target_map: _, memo_globals_base: memo_base, _) = ctx
  let valid_idx = memo.memo_valid_global_idx(base: memo_base, slot)
  let key_idx = memo.memo_key_global_idx(base: memo_base, slot)
  let val_idx = memo.memo_val_global_idx(base: memo_base, slot)
  let key_local = ctx_temps_base(ctx) + memo.memo_key_local_offset
  let val_local = ctx_temps_base(ctx) + memo.memo_val_local_offset

  // Step 1 — emit and capture the single argument as i64 cache key.
  let %buf = emit_internal_call_args(%buf, args, params, ctx)
  // emit_internal_call_args coerces the arg to the param type (already i64
  // for our single-word-key admission). pack_arg_to_key widens i32-flavoured
  // values and reinterprets f64. Stack: [key:i64].
  let arg_type = match params do
    | LirParam(label: _, name: _, typ: t) :: _ -> t
    | [] -> callee_rt
  end
  let %buf = memo.emit_pack_arg_to_key(%buf, arg_type)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: key_local)

  // Step 2 — compute hit condition: valid && key == cached_key.
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: valid_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: key_local)
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: key_idx)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i64_eq, op_i32_and ])

  // Step 3 — if (result i64): hit branch returns cached val.
  let %buf = bb.push_bytes(%buf, bytes: [ op_if, bt_i64, op_global_get ])
  let %buf = bb.push_uleb128(%buf, val: val_idx)

  // Step 4 — else: miss branch invokes the callee, writes the cache.
  let %buf = bb.push_bytes(%buf, bytes: [ op_else, op_local_get ])
  let %buf = bb.push_uleb128(%buf, val: key_local)
  // The callee expects its declared param type, which we pre-coerced into
  // the i64 key above. Reverse-coerce when the param type isn't already i64
  // so we hand the call exactly the type wasm needs.
  let %buf = unpack_key_to_param(%buf, param_type: arg_type)
  // Note: param_type intentionally aliases arg_type — the call's argument
  // type IS the callee's param type after emit_internal_call_args coercion.
  let %buf = bb.push_byte(%buf, byte: op_call)
  let %buf = bb.push_uleb128(%buf, val: int_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_tee)
  let %buf = bb.push_uleb128(%buf, val: val_local)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: val_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: key_local)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: key_idx)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: op_global_set)
  let %buf = bb.push_uleb128(%buf, val: valid_idx)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: val_local)

  // end of if
  return bb.push_byte(%buf, byte: op_end)
end

/** Identity since only i64/IntLit pass eligibility. Kept as a seam for
 *  widening + reverse-coerce when other key types open up.
 */
let unpack_key_to_param = fn (buf: %ByteBuffer, param_type: TypeExpr) -> %ByteBuffer do
  match wdefs.peel_linear(typ: param_type) do
    | TyI64 | TyIntLit | _ -> return %buf
  end
end

let emit_external_call = fn (func: string, args: [ LirCallArg ], buf: %ByteBuffer, ctx: CodegenCtx,
                                     ext_idx: i64) -> %ByteBuffer throws { CodegenError } do
  match wdefs.lookup_external(name: func, exts: ctx_externals(ctx)) do
    | Some(val: LirExternal(name: _, wasm_module: m, wasm_name: _, params, ret_type: rt, throw_row: _)) ->
      let canonical_str_ret = str.contains(s: m, sub: ":")
        && m != "nexus:intrinsic"
        && !str.starts_with(s: m, prefix: "nexus:runtime/")
        && !str.starts_with(s: m, prefix: "nexus:std/")
        && (match wdefs.peel_linear(typ: rt) do | TyString -> true | _ -> false end)
      let %buf = if canonical_str_ret then
        // Allocate an 8-byte retptr (always 8-aligned) for the canonical
        // string return, off the unified atomic bump cell.
        // i32 temp locals: temps_base+6=retptr, +7=tmp_ptr, +8=tmp_len.
        let retptr_local = ctx_temps_base(ctx) + 6
        let %buf = bb.push_byte(%buf, byte: op_i32_const)
        let %buf = bb.push_sleb128(%buf, val: 8)
        emit_atomic_bump(%buf, ctx, ptr_local: retptr_local)
      else %buf end
      let %buf = emit_external_call_args(%buf, args, params, ctx)
      // For canonical string return: push retptr as last argument
      let %buf = if canonical_str_ret then
        let retptr_local = ctx_temps_base(ctx) + 6
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        bb.push_uleb128(%buf, val: retptr_local)
      else %buf end
      let %buf = bb.push_byte(%buf, byte: op_call)
      let %buf = bb.push_uleb128(%buf, val: ext_idx)
      // For canonical string return: read (ptr, len) from retptr and pack to i64
      let %buf = if canonical_str_ret then
        let retptr_local = ctx_temps_base(ctx) + 6
        let tmp_ptr = ctx_temps_base(ctx) + 7
        let tmp_len = ctx_temps_base(ctx) + 8
        // Load ptr (i32) from retptr+0
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        let %buf = bb.push_uleb128(%buf, val: retptr_local)
        let %buf = bb.push_bytes(%buf, bytes: [ op_i32_load, 2 ])
        let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
        let %buf = bb.push_byte(%buf, byte: op_local_set)
        let %buf = bb.push_uleb128(%buf, val: tmp_ptr)
        // Load len (i32) from retptr+4
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        let %buf = bb.push_uleb128(%buf, val: retptr_local)
        let %buf = bb.push_bytes(%buf, bytes: [ op_i32_load, 2 ])
        let %buf = bb.push_uleb128(%buf, val: 4)
        let %buf = bb.push_byte(%buf, byte: op_local_set)
        let %buf = bb.push_uleb128(%buf, val: tmp_len)
        // Pack: (ptr_i64 << 32) | len_i64
        let %buf = bb.push_byte(%buf, byte: op_local_get)
        let %buf = bb.push_uleb128(%buf, val: tmp_ptr)
        let %buf = bb.push_bytes(%buf, bytes: [ op_i64_extend_i32_u, op_i64_const ])
        let %buf = bb.push_sleb128(%buf, val: 32)
        let %buf = bb.push_bytes(%buf, bytes: [ op_i64_shl, op_local_get ])
        let %buf = bb.push_uleb128(%buf, val: tmp_len)
        let %buf = bb.push_byte(%buf, byte: op_i64_extend_i32_u)
        bb.push_byte(%buf, byte: op_i64_or)
      else %buf end
      return %buf
    | None ->
      bb.free(buf: %buf)
      throw SymbolNotFound(name: func, kind: SkFunction, context: "external call")
  end
end

/** The unified intrinsic dispatch: one match on the parsed `Intrinsic` tag
 *  (see codegen/intrinsics.nx). `parse_intrinsic` keys on the kebab-cased
 *  `wasm_name` (`wit_canonical_name` strips the `__nx_` prefix and converts
 *  underscores to hyphens). Every `nexus:intrinsic` external — across the
 *  former arena / memory / math / simd / atomic / cast / lazy domains — flows
 *  through here. Each arm just calls the matching `emit_*` helper.
 *  `UnknownIntrinsic(name)` surfaces the same `SymbolNotFound` the old
 *  if-chain produced; adding a new intrinsic without an arm is a compile
 *  error rather than a runtime trap.
 */
let emit_intrinsic = fn (
  name: string,
  args: [ LirCallArg ],
  buf: %ByteBuffer,
  ctx: CodegenCtx
) -> %ByteBuffer throws { CodegenError } do
  match parse_intrinsic(s: name) do
    | HeapMark -> return emit_heap_mark(%buf)
    | HeapReset -> return emit_heap_reset(args, %buf, ctx)
    | HeapSwap -> return emit_heap_swap(args, %buf, ctx)
    | AllocRaw -> return emit_alloc_raw(args, %buf, ctx)
    | MemLoadI32 -> return emit_mem_load_i32(args, %buf, ctx)
    | MemStoreI32 -> return emit_mem_store_i32(args, %buf, ctx)
    | MemLoadU8 -> return emit_mem_load_u8(args, %buf, ctx)
    | MemStoreU8 -> return emit_mem_store_u8(args, %buf, ctx)
    | MemLoadI64 -> return emit_mem_load_i64(args, %buf, ctx)
    | MemStoreI64 -> return emit_mem_store_i64(args, %buf, ctx)
    | MemLoadF32 -> return emit_mem_load_f32(args, %buf, ctx)
    | MemStoreF32 -> return emit_mem_store_f32(args, %buf, ctx)
    | MemLoadF64 -> return emit_mem_load_f64(args, %buf, ctx)
    | MemStoreF64 -> return emit_mem_store_f64(args, %buf, ctx)
    | MemSize -> return emit_mem_size(%buf)
    | MemGrow -> return emit_mem_grow(args, %buf, ctx)
    | AtomicRmwAddI32 -> return emit_atomic_rmw_add_i32(args, %buf, ctx)
    | AtomicLoadI32 -> return emit_atomic_load_i32(args, %buf, ctx)
    | AtomicStoreI32 -> return emit_atomic_store_i32(args, %buf, ctx)
    | AtomicCmpxchgI32 -> return emit_atomic_cmpxchg_i32(args, %buf, ctx)
    | AtomicWait32 -> return emit_atomic_wait32(args, %buf, ctx)
    | AtomicNotify -> return emit_atomic_notify(args, %buf, ctx)
    | AtomicFence -> return emit_atomic_fence(%buf)
    | CastToI32 -> return emit_cast_to_i32(args, %buf, ctx)
    | CastToI64 -> return emit_cast_to_i64(args, %buf, ctx)
    | ForceClosure -> return emit_force_closure(args, %buf, ctx)
    | ThunkAddr | ValueOfI64 -> return emit_lazy_passthrough(args, %buf, ctx)
    | ArrayLength -> return emit_array_length(args, %buf, ctx)
    | F64Sqrt -> return emit_f64_unary(opcode: op_f64_sqrt, args, %buf, ctx, name: "__nx_f64_sqrt")
    | F64Floor -> return emit_f64_unary(
      opcode: op_f64_floor,
      args,
      %buf,
      ctx,
      name: "__nx_f64_floor"
    )
    | F64Ceil -> return emit_f64_unary(opcode: op_f64_ceil, args, %buf, ctx, name: "__nx_f64_ceil")
    | F64Abs -> return emit_f64_unary(opcode: op_f64_abs, args, %buf, ctx, name: "__nx_f64_abs")
    | SimdF32x4Add -> return emit_simd_binop_one(
      sub_op: op_simd_f32x4_add,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f32x4_add"
    )
    | SimdF32x4Mul -> return emit_simd_binop_one(
      sub_op: op_simd_f32x4_mul,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f32x4_mul"
    )
    | SimdF64x2Add -> return emit_simd_binop_one(
      sub_op: op_simd_f64x2_add,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f64x2_add"
    )
    | SimdF64x2Mul -> return emit_simd_binop_one(
      sub_op: op_simd_f64x2_mul,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f64x2_mul"
    )
    | SimdI32x4Add -> return emit_simd_binop_one(
      sub_op: op_simd_i32x4_add,
      args,
      %buf,
      ctx,
      name: "__nx_simd_i32x4_add"
    )
    | SimdI32x4Mul -> return emit_simd_binop_one(
      sub_op: op_simd_i32x4_mul,
      args,
      %buf,
      ctx,
      name: "__nx_simd_i32x4_mul"
    )
    | SimdI64x2Add -> return emit_simd_binop_one(
      sub_op: op_simd_i64x2_add,
      args,
      %buf,
      ctx,
      name: "__nx_simd_i64x2_add"
    )
    | SimdI64x2Mul -> return emit_simd_binop_one(
      sub_op: op_simd_i64x2_mul,
      args,
      %buf,
      ctx,
      name: "__nx_simd_i64x2_mul"
    )
    | SimdF32x4AddArray -> return emit_simd_binop_array(
      sub_op: op_simd_f32x4_add,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f32x4_add_array"
    )
    | SimdF64x2AddArray -> return emit_simd_binop_array(
      sub_op: op_simd_f64x2_add,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f64x2_add_array"
    )
    | SimdI32x4AddArray -> return emit_simd_binop_array(
      sub_op: op_simd_i32x4_add,
      args,
      %buf,
      ctx,
      name: "__nx_simd_i32x4_add_array"
    )
    | SimdI64x2AddArray -> return emit_simd_binop_array(
      sub_op: op_simd_i64x2_add,
      args,
      %buf,
      ctx,
      name: "__nx_simd_i64x2_add_array"
    )
    | SimdF32x4MulArray -> return emit_simd_binop_array(
      sub_op: op_simd_f32x4_mul,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f32x4_mul_array"
    )
    | SimdF64x2MulArray -> return emit_simd_binop_array(
      sub_op: op_simd_f64x2_mul,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f64x2_mul_array"
    )
    | SimdI32x4MulArray -> return emit_simd_binop_array(
      sub_op: op_simd_i32x4_mul,
      args,
      %buf,
      ctx,
      name: "__nx_simd_i32x4_mul_array"
    )
    | SimdI64x2MulArray -> return emit_simd_binop_array(
      sub_op: op_simd_i64x2_mul,
      args,
      %buf,
      ctx,
      name: "__nx_simd_i64x2_mul_array"
    )
    | SimdF32x4SubArray -> return emit_simd_binop_array(
      sub_op: op_simd_f32x4_sub,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f32x4_sub_array"
    )
    | SimdF64x2SubArray -> return emit_simd_binop_array(
      sub_op: op_simd_f64x2_sub,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f64x2_sub_array"
    )
    | SimdI32x4SubArray -> return emit_simd_binop_array(
      sub_op: op_simd_i32x4_sub,
      args,
      %buf,
      ctx,
      name: "__nx_simd_i32x4_sub_array"
    )
    | SimdI64x2SubArray -> return emit_simd_binop_array(
      sub_op: op_simd_i64x2_sub,
      args,
      %buf,
      ctx,
      name: "__nx_simd_i64x2_sub_array"
    )
    | SimdF32x4DivArray -> return emit_simd_binop_array(
      sub_op: op_simd_f32x4_div,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f32x4_div_array"
    )
    | SimdF64x2DivArray -> return emit_simd_binop_array(
      sub_op: op_simd_f64x2_div,
      args,
      %buf,
      ctx,
      name: "__nx_simd_f64x2_div_array"
    )
    | BtDepth -> return emit_bt_depth(%buf)
    | BtFrame -> return emit_bt_frame(args, %buf, ctx)
    | CaptureBacktrace -> return emit_capture_backtrace(args, %buf, ctx)
    | UnknownIntrinsic(name: n) ->
      bb.free(buf: %buf)
      throw SymbolNotFound(name: n, kind: SkIntrinsic, context: "emit_intrinsic")
  end
end

export let emit_call = fn (func: string, args: [ LirCallArg ], buf: %ByteBuffer, ctx: CodegenCtx,
                            is_tail: bool, in_try: bool) -> %ByteBuffer throws { CodegenError } do
  // `nexus:intrinsic` externals: emit inline WASM, no function call. Resolve
  // the dispatch key (the external's kebab-cased wasm_name) and hand off to
  // emit_intrinsic. The sched intrinsics keep their own func+exts-shaped
  // recognisers (they consult the externals list for the host run-queue
  // imports), so they stay separate arms in this flat else-if chain.
  let exts = ctx_externals(ctx)
  let intr_wn = get_intrinsic_wasm_name(func, exts)
  if func == "__array_get" then return emit_array_get(args, %buf, ctx)
  else if func == "__array_set" then return emit_array_set(args, %buf, ctx)
  else if func == "__hreg_get" then return emit_hreg_get(args, %buf, ctx)
  else if func == "__hreg_set" then return emit_hreg_set(args, %buf, ctx)
  else if func == "__inject_env_get" then return emit_inject_env_get(%buf, ctx)
  else if func == "__inject_env_set" then return emit_inject_env_set(args, %buf, ctx)
  else if intr_wn != "" then return emit_intrinsic(name: intr_wn, args, %buf, ctx)
  else if is_sched_set_next(func, exts) then return emit_sched_set_next(args, %buf, ctx)
  else if is_sched_spawn(func, exts) then return emit_sched_spawn(args, %buf, ctx)
  else
    let CodegenCtx(locals: _, string_lits: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: ifm, external_func_map: efm, _) = ctx
    let int_idx = wdefs.lookup_func_fast(name: func, map: &ifm)
    if int_idx >= 0 then
      return emit_internal_call(func, args, %buf, ctx, is_tail, in_try, int_idx)
    else
      let ext_idx = wdefs.lookup_func_fast(name: func, map: &efm)
      if ext_idx >= 0 then
        return emit_external_call(func, args, %buf, ctx, ext_idx)
      else
        bb.free(buf: %buf)
        throw SymbolNotFound(name: func, kind: SkFunction, context: "emit_call")
      end
    end
  end
end

/** Returns the table index (position) for a closure function name, or -1 if
 *  absent (hot path — called per closure-make site; -1 sentinel per rule 1 of
 *  the error-contract in src/diagnostics/error.nx). O(1) lookup over the
 *  `name -> position` map built once by `build_closure_idx_map`.
 */
export let lookup_closure_table_idx = fn (name: string, entries: Map<string, i64>) -> i64 do
  match map.get(m: entries, k: name) do
    | Some(val: pos) -> return pos
    | None -> return -1
  end
end

/** Look up the type section index for a closure call with the given arity. */
export let lookup_closure_type_idx_pairs = fn (
  arity: i64,
  pairs: [ ArityTypeIdx ]
) -> i64 throws { CodegenError } do
  match pairs do
    | [] -> throw SymbolNotFound(
      name: str.from_i64(val: arity),
      kind: SkClosureArity,
      context: "lookup_closure_type_idx_pairs"
    )
    | ArityTypeIdx(arity: a, type_idx: ti) :: rest ->
      if a == arity then return ti
      else return lookup_closure_type_idx_pairs(arity, pairs: rest)
      end
  end
end

export let emit_closure_captures = fn (
  buf: %ByteBuffer,
  caps: [ LirAtom ],
  ctx: CodegenCtx,
  obj_ptr: i64,
  field_idx: i64
) -> %ByteBuffer throws { CodegenError } do
  match caps do
    | [] -> return %buf
    | a :: rest ->
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = emit_typed_field_store(typ: wdefs.atom_type(atom: a), %buf, offset: field_idx * 8)
      return emit_closure_captures(%buf, caps: rest, ctx, obj_ptr, field_idx: field_idx + 1)
  end
end

export let emit_closure_call_args = fn (
  buf: %ByteBuffer,
  args: [ LirCallArg ],
  ctx: CodegenCtx
) -> %ByteBuffer throws { CodegenError } do
  match args do
    | [] -> return %buf
    | LirCallArg(label: _, value: a) :: rest ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = emit_pack_to_i64(typ: wdefs.atom_type(atom: a), %buf)
      return emit_closure_call_args(%buf, args: rest, ctx)
  end
end
