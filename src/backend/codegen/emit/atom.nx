/**
 * codegen/atom: self-contained WASM emission leaves for LIR atoms and types.
 *
 * Owns:
 * - emit_atom, emit_atom_var (LirAtom → WASM constant / local.get / call)
 * - emit_coercion, emit_pack_to_i64 (value-type bridging)
 * - emit_typed_field_store, emit_typed_field_load (typed record/object I/O)
 * - emit_memory_grow_check, emit_alloc_object (heap allocation)
 * - emit_unpack_string (string ptr/len unpack)
 * - emit_memcpy_loop, emit_memcpy_loop_offset (byte copy loops)
 *
 * Does not own:
 * - The emit_expr / emit_stmt / emit_atom mutual recursion entry (see
 *   src/backend/codegen.nx)
 * - Binary operators, call emission, string concat/compare, TCMC — those
 *   live in codegen.nx / codegen/string.nx / codegen/tcmc.nx.
 *
 * Exists so codegen/string.nx and codegen/tcmc.nx can share the atom
 * helpers without creating a cyclic import back to codegen.nx. Every
 * function here is a leaf: it may call other leaves but never recurses
 * through emit_expr / emit_stmt.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { SymbolNotFound, CodegenError, SkVariable } from "src/backend/errors.nx"
import { TypeExpr } from "src/types/type_expr.nx"
import {
  LirAtom,
  LirAtomVar,
  LirAtomInt,
  LirAtomFloat,
  LirAtomBool,
  LirAtomChar,
  LirAtomString,
  LirAtomUnit
} from "src/ir/lir/types.nx"
import { CodegenCtx, ctx_temps_base, ctx_lookup_local } from "src/backend/codegen/ctx/context.nx"
import { vt_i32, vt_i64, vt_f32, vt_f64, bt_void,
         heap_global_idx,
         op_call, op_drop,
         op_local_get, op_local_set, op_local_tee, op_global_get, op_global_set,
         op_i32_load, op_i64_load, op_f64_load, op_i32_load8_u, op_i32_store, op_i64_store, op_f64_store, op_i32_store8,
         op_i32_const, op_i64_const, op_f64_const,
         op_i32_add, op_i32_sub, op_i32_shl, op_i32_shr_u, op_i32_ge_u, op_i32_gt_u,
         op_i32_wrap_i64, op_i64_extend_i32_s, op_i64_extend_i32_u,
         op_i64_reinterpret_f64, op_f64_reinterpret_i64,
         op_i32_reinterpret_f32, op_f32_reinterpret_i32,
         op_f32_demote_f64, op_f64_promote_f32,
         op_memory_size, op_memory_grow,
         op_block, op_loop, op_if, op_end, op_br, op_br_if, bt_void }, * as wdefs from "src/backend/wasm/defs.nx"

let emit_atom_var = fn (
  name: string,
  typ: TypeExpr,
  buf: %ByteBuffer,
  ctx: CodegenCtx
) -> %ByteBuffer throws { CodegenError } do
  if let TyUnit = typ then return %buf end
  let CodegenCtx(internal_func_map: ifm, external_func_map: efm, _) = ctx
  // O(1) packed local lookup via per-function HashMap.
  // Layout: `(index << 32) | valtype`; -1 = absent (try top-level fallback).
  let packed = ctx_lookup_local(ctx, name)
  if packed < 0 then
    let func_idx = wdefs.lookup_func_fast(name, map: &ifm)
    if func_idx >= 0 then
      let %buf = bb.push_byte(%buf, byte: op_call)
      return bb.push_uleb128(%buf, val: func_idx)
    end
    let ext_idx = wdefs.lookup_func_fast(name, map: &efm)
    if ext_idx >= 0 then
      let %buf = bb.push_byte(%buf, byte: op_call)
      return bb.push_uleb128(%buf, val: ext_idx)
    end
    bb.free(buf: %buf)
    throw SymbolNotFound(name, kind: SkVariable, context: "emit_atom_var")
  end
  let raw_idx = packed / wdefs.u32_radix
  let local_vt = packed - raw_idx * wdefs.u32_radix
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: raw_idx)
  // Recover the original value when the local slot was widened to i64 but the
  // atom type is narrower: i32 → i32.wrap_i64; f64 → f64.reinterpret_i64;
  // f32 → i32.wrap_i64 then f32.reinterpret_i32 (reverse of the store hop).
  let atom_vt = wdefs.type_to_valtype(typ: wdefs.peel_linear(typ))
  return if atom_vt == vt_i32 && local_vt == vt_i64 then
    bb.push_byte(%buf, byte: op_i32_wrap_i64)
  else if atom_vt == vt_f64 && local_vt == vt_i64 then
    bb.push_byte(%buf, byte: op_f64_reinterpret_i64)
  else if atom_vt == vt_f32 && local_vt == vt_i64 then
    let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
    bb.push_byte(%buf, byte: op_f32_reinterpret_i32)
  else
    %buf
  end
end

/** Emit the wasm bytes that push a single `LirAtom` onto the operand stack: a `local.get`/`call` for variables (with possible i64→i32 narrowing), an `i{32,64}.const` / `f64.const` for literals, or a no-op for `LirAtomUnit`. The leaf emitter shared by `emit_expr` and the helper modules; never recurses through expression emission. */
export let emit_atom = fn (
  atom: LirAtom,
  buf: %ByteBuffer,
  ctx: CodegenCtx
) -> %ByteBuffer throws { CodegenError } do
  match atom do
    | LirAtomVar(name: n, typ: at) ->
      return emit_atom_var(name: n, typ: at, %buf, ctx)
    | LirAtomInt(val: v) ->
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      return bb.push_sleb128(%buf, val: v)
    | LirAtomFloat(val: s) ->
      let %buf = bb.push_byte(%buf, byte: op_f64_const)
      return bb.push_f64_str_le(%buf, s)
    | LirAtomBool(val: bv) ->
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      return bb.push_sleb128(%buf, val: if bv then 1 else 0 end)
    | LirAtomChar(val: cv) ->
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      return bb.push_sleb128(%buf, val: cv)
    | LirAtomString(val: s) ->
      let CodegenCtx(string_lits: sl, _) = ctx
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      return bb.push_sleb128(%buf, val: wdefs.lookup_string(value: s, entries: sl))
    | LirAtomUnit -> %buf
  end
end

/** Bridge values between WASM valtypes when `from_type` and `to_type` peel to different `vt_*`: emits the minimum cast instruction (`i32.wrap_i64`, `i64.extend_i32_s`, `f32.demote_f64`, `f64.promote_f32`) for the int/float-width casts, and bit-preserving reinterprets (`{i64,f64}.reinterpret`, plus an `i32`-hop for f32) for the i64-erasure boundary that arises when a generic type variable (lowered to the i64 value channel) is instantiated at a float type. No-op for identical valtypes or any `TyUnit` endpoint. Used after `emit_atom` to align operand widths before binops, stores, or generic call arguments. */
export let emit_coercion = fn (
  from_type: TypeExpr,
  to_type: TypeExpr,
  buf: %ByteBuffer
) -> %ByteBuffer do
  let f = wdefs.peel_linear(typ: from_type)
  let t = wdefs.peel_linear(typ: to_type)
  if let TyUnit = f then return %buf end
  if let TyUnit = t then return %buf end
  let fv = wdefs.type_to_valtype(typ: f)
  let tv = wdefs.type_to_valtype(typ: t)
  if fv == tv then return %buf
  else if fv == vt_i64 && tv == vt_i32 then return bb.push_byte(%buf, byte: op_i32_wrap_i64)
  else if fv == vt_i32 && tv == vt_i64 then return bb.push_byte(%buf, byte: op_i64_extend_i32_s)
  else if fv == vt_f64 && tv == vt_f32 then return bb.push_byte(%buf, byte: op_f32_demote_f64)
  else if fv == vt_f32 && tv == vt_f64 then return bb.push_byte(%buf, byte: op_f64_promote_f32)
  // i64-erasure boundary: a float value crossing into / out of the i64 value
  // channel must be bit-reinterpreted (NOT numerically converted), so a generic
  // instantiated at f64/f32 round-trips its exact bits.
  else if fv == vt_f64 && tv == vt_i64 then return bb.push_byte(%buf, byte: op_i64_reinterpret_f64)
  else if fv == vt_i64 && tv == vt_f64 then return bb.push_byte(%buf, byte: op_f64_reinterpret_i64)
  else if fv == vt_f32 && tv == vt_i64 then
    let %buf = bb.push_byte(%buf, byte: op_i32_reinterpret_f32)
    return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
  else if fv == vt_i64 && tv == vt_f32 then
    let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
    return bb.push_byte(%buf, byte: op_f32_reinterpret_i32)
  else return %buf
  end
end

/** Widen the current top-of-stack to `i64` so it can be stored in a uniform 64-bit slot: sign-extends `i32`/bool/char, reinterprets `f64` bitwise, and replaces a `unit` (which carries no payload) with a literal `i64 0`. Used to pack heterogeneously-typed values into closure environments and other word-sized cells. */
export let emit_pack_to_i64 = fn (typ: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer do
  match wdefs.peel_linear(typ) do
    | TyI32 | TyBool | TyChar -> bb.push_byte(%buf, byte: op_i64_extend_i32_s)
    | TyUnit ->
      let %buf = bb.push_bytes(%buf, bytes: [ op_drop, op_i64_const ])
      bb.push_sleb128(%buf, val: 0)
    | TyF64 -> bb.push_byte(%buf, byte: op_i64_reinterpret_f64)
    | _ -> %buf
  end
end

/** Store the top-of-stack value at `[addr + offset]` using the narrowest WASM store instruction for `typ` (`i32.store`/`f64.store`/`i64.store`); `TyUnit` consumes the address with a `drop`. Saves the `pack_to_i64`/`unpack_from_i64` round-trip for fields whose type is known at codegen time. */
export let emit_typed_field_store = fn (
  typ: TypeExpr,
  buf: %ByteBuffer,
  offset: i64
) -> %ByteBuffer do
  match wdefs.peel_linear(typ) do
    | TyI32 | TyBool | TyChar ->
      let %buf = bb.push_byte(%buf, byte: op_i32_store)
      return wdefs.emit_memarg_i32(%buf, offset)
    | TyF64 ->
      let %buf = bb.push_byte(%buf, byte: op_f64_store)
      return wdefs.emit_memarg_i64(%buf, offset)
    | TyUnit ->
      return bb.push_byte(%buf, byte: op_drop)
    | _ ->
      let %buf = bb.push_byte(%buf, byte: op_i64_store)
      return wdefs.emit_memarg_i64(%buf, offset)
  end
end

/** Load the field at `[addr + offset]` directly into its native WASM type (`i32`/`f64`/`i64`), avoiding the `unpack_from_i64` overhead callers would otherwise need. Stack: `[addr:i32] → [value:<native>]`; `TyUnit` drops the address. */
export let emit_typed_field_load = fn (
  typ: TypeExpr,
  buf: %ByteBuffer,
  offset: i64
) -> %ByteBuffer do
  match wdefs.peel_linear(typ) do
    | TyI32 | TyBool | TyChar ->
      let %buf = bb.push_byte(%buf, byte: op_i32_load)
      return wdefs.emit_memarg_i32(%buf, offset)
    | TyF64 ->
      let %buf = bb.push_byte(%buf, byte: op_f64_load)
      return wdefs.emit_memarg_i64(%buf, offset)
    | TyUnit ->
      return bb.push_byte(%buf, byte: op_drop)
    | _ ->
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      return wdefs.emit_memarg_i64(%buf, offset)
  end
end

/** Emit a guarded `memory.grow` so that the heap-top global stays within backed pages: roughly `if (heap_global > memory.size * 65536) { memory.grow(needed_pages); drop }`. The `skip` flag short-circuits when the caller has already proven sufficient memory (e.g. inside a freshly-grown allocator). */
export let emit_memory_grow_check = fn (buf: %ByteBuffer, skip: bool) -> %ByteBuffer do
  if skip then return %buf end
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_memory_size)
  let %buf = bb.push_byte(%buf, byte: 0) // mem index 0
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 16)
  let %buf = bb.push_byte(%buf, byte: op_i32_shl) // pages * 65536
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_gt_u, op_if ])
  let %buf = bb.push_byte(%buf, byte: bt_void)
  let %buf = bb.push_byte(%buf, byte: op_global_get)
  let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
  let %buf = bb.push_byte(%buf, byte: op_memory_size)
  let %buf = bb.push_byte(%buf, byte: 0) // mem index 0
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 16)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_shl, op_i32_sub ]) // overflow bytes
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 65535)
  let %buf = bb.push_byte(%buf, byte: op_i32_add) // round up
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 16)
  let %buf = bb.push_byte(%buf, byte: op_i32_shr_u) // / 65536 = pages
  let %buf = bb.push_byte(%buf, byte: op_memory_grow)
  let %buf = bb.push_byte(%buf, byte: 0) // mem index 0
  let %buf = bb.push_byte(%buf, byte: op_drop) // discard result (-1 on failure)
  return bb.push_byte(%buf, byte: op_end)
end

/** Atomic bump allocation against linear-memory cell `wdefs.heap_ptr_cell`.
 *
 *  Stack in:  [size_bytes : i32]   (consumed)
 *  Stack out: []                                (clean)
 *  Effect:    (1) if the cell is still 0 (the "uninitialised" sentinel), seed
 *  it to `memory.size() * 65536` via a compare-and-swap (the cell
 *  is never data-segment initialised — see codegen.nx — so this
 *  seed is the live one; concurrent first calls converge).
 *  (2) round `size_bytes` up to a multiple of 8, atomically
 *  add it to the cell, store the *old* cell value (= the freshly-
 *  allocated, 8-aligned base pointer) into `ptr_local` (an i32
 *  local), then grow linear memory so `[ptr, ptr + rounded)` is
 *  backed.
 *
 *  Scratch:   `temps_base + 2` (i32) is used transiently.
 */
export let emit_atomic_bump = fn (
  buf: %ByteBuffer,
  ctx: CodegenCtx,
  ptr_local: i64
) -> %ByteBuffer do
  let scratch = ctx_temps_base(ctx) + 2
  // Idempotent seed via cmpxchg(cell, 0, memory.size()*65536); see docstring.
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_bytes(%buf, bytes: [ op_memory_size, 0, op_i32_const ])
  let %buf = bb.push_sleb128(%buf, val: 16)
  let %buf = bb.push_byte(%buf, byte: op_i32_shl)
  let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_rmw_cmpxchg, offset: 0)
  let %buf = bb.push_byte(%buf, byte: op_drop)
  // rounded = (size + 7) & ~8   (i.e. round up to a multiple of 8)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 7)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_add, op_i32_const ])
  let %buf = bb.push_sleb128(%buf, val: 0 - 8)
  let %buf = bb.push_bytes(%buf, bytes: [ wdefs.op_i32_and, op_local_set ])
  let %buf = bb.push_uleb128(%buf, val: scratch)
  // ptr = atomic.rmw.add(cell, rounded)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: scratch)
  let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_rmw_add, offset: 0)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: ptr_local)
  // new_top = ptr + rounded   (reuse `scratch` to hold it; `rounded` is dead)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: ptr_local)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: scratch)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_add, op_local_set ])
  let %buf = bb.push_uleb128(%buf, val: scratch)
  // if (new_top > memory.size * 65536) { memory.grow(ceil((new_top - mem_bytes)/65536)); drop }
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: scratch)
  let %buf = bb.push_bytes(%buf, bytes: [ op_memory_size, 0, op_i32_const ])
  let %buf = bb.push_sleb128(%buf, val: 16)
  let %buf = bb.push_byte(%buf, byte: op_i32_shl)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_gt_u, op_if ])
  let %buf = bb.push_bytes(%buf, bytes: [ bt_void, op_local_get ])
  let %buf = bb.push_uleb128(%buf, val: scratch)
  let %buf = bb.push_bytes(%buf, bytes: [ op_memory_size, 0, op_i32_const ])
  let %buf = bb.push_sleb128(%buf, val: 16)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_shl, op_i32_sub ])
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 65535)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_add, op_i32_const ])
  let %buf = bb.push_sleb128(%buf, val: 16)
  return bb.push_bytes(%buf, bytes: [ op_i32_shr_u, op_memory_grow, 0, op_drop, op_end ])
end

/** Allocate `words * 8` bytes via `emit_atomic_bump`, leaving the resulting base pointer in the per-function `obj_ptr` local (`temps_base + 3`). Convenience wrapper used for fixed-arity object/record allocation where the size is statically known. */
export let emit_alloc_object = fn (buf: %ByteBuffer, ctx: CodegenCtx, words: i64) -> %ByteBuffer do
  let obj_ptr = ctx_temps_base(ctx) + 3
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: words * 8)
  return emit_atomic_bump(%buf, ctx, ptr_local: obj_ptr)
end

/** Split a packed string handle held in `packed_local` (`(ptr << 32) | len`) into separate `ptr_local` and `len_local` i32 locals. Used whenever string contents need to be addressed directly — concat, compare, slice — without re-decoding the i64 each time. */
export let emit_unpack_string = fn (
  buf: %ByteBuffer,
  packed_local: i64,
  ptr_local: i64,
  len_local: i64
) -> %ByteBuffer do
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: packed_local)
  let %buf = bb.push_byte(%buf, byte: op_i64_const)
  let %buf = bb.push_sleb128(%buf, val: 32)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_i64_shr_u)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_wrap_i64, op_local_set ])
  let %buf = bb.push_uleb128(%buf, val: ptr_local)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: packed_local)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_wrap_i64, op_local_set ])
  return bb.push_uleb128(%buf, val: len_local)
end

/** Emit a byte-wise loop that copies `len_local` bytes from `[src_ptr, +len)` to `[dst_ptr, +len)`, using `idx_local` as the induction counter. Chosen over `memory.copy` so the compiler stays compatible with WASM engines that lack the bulk-memory proposal; `dst_offset` is reserved for symmetry with the offset variant and currently ignored by callers. */
export let emit_memcpy_loop = fn (buf: %ByteBuffer, src_ptr: i64, dst_ptr: i64, dst_offset: i64,
                            len_local: i64, idx_local: i64) -> %ByteBuffer do
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_bytes(%buf, bytes: [ op_block, bt_void, op_loop, bt_void, op_local_get ])
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: len_local)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_ge_u, op_br_if ])
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: dst_ptr)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_add, op_local_get ])
  let %buf = bb.push_uleb128(%buf, val: src_ptr)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_add, op_i32_load8_u ])
  let %buf = wdefs.emit_memarg_i8(%buf)
  let %buf = bb.push_byte(%buf, byte: op_i32_store8)
  let %buf = wdefs.emit_memarg_i8(%buf)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 1)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_add, op_local_set ])
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_byte(%buf, byte: op_br)
  let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
  return bb.push_bytes(%buf, bytes: [ op_end, op_end ])
end

/** Same byte-wise copy loop as `emit_memcpy_loop` but applies a runtime `offset_local` to the destination, so the caller can paste a source buffer into the middle of a larger destination without first materialising an offset pointer. */
export let emit_memcpy_loop_offset = fn (buf: %ByteBuffer, src_ptr: i64, dst_ptr: i64,
                                   offset_local: i64, len_local: i64, idx_local: i64) -> %ByteBuffer do
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_byte(%buf, byte: op_local_set)
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_bytes(%buf, bytes: [ op_block, bt_void, op_loop, bt_void, op_local_get ])
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: len_local)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_ge_u, op_br_if ])
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: dst_ptr)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: offset_local)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_add, op_local_get ])
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_byte(%buf, byte: op_i32_add)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: src_ptr)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_add, op_i32_load8_u ])
  let %buf = wdefs.emit_memarg_i8(%buf)
  let %buf = bb.push_byte(%buf, byte: op_i32_store8)
  let %buf = wdefs.emit_memarg_i8(%buf)
  let %buf = bb.push_byte(%buf, byte: op_local_get)
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 1)
  let %buf = bb.push_bytes(%buf, bytes: [ op_i32_add, op_local_set ])
  let %buf = bb.push_uleb128(%buf, val: idx_local)
  let %buf = bb.push_byte(%buf, byte: op_br)
  let %buf = bb.push_uleb128(%buf, val: heap_global_idx)
  return bb.push_bytes(%buf, bytes: [ op_end, op_end ])
end
