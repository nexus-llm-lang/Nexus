/**
 * codegen/atom: self-contained WASM emission leaves for LIR atoms and types.
 *
 * Owns:
 * - emit_atom, emit_atom_var (LirAtom → WASM constant / local.get / call)
 * - emit_coercion, emit_pack_to_i64 (value-type bridging)
 * - emit_typed_field_store, emit_typed_field_load (typed record/object I/O)
 * - emit_memory_grow_check, emit_alloc_object (heap allocation)
 * - emit_unpack_string (string ptr/len unpack)
 * - emit_memcpy_loop, emit_memcpy_loop_offset (byte copy loops)
 *
 * Does not own:
 * - The emit_expr / emit_stmt / emit_atom mutual recursion entry (see
 *   src/backend/codegen.nx)
 * - Binary operators, call emission, string concat/compare, TCMC — those
 *   live in codegen.nx / codegen/string.nx / codegen/tcmc.nx.
 *
 * Exists so codegen/string.nx and codegen/tcmc.nx can share the atom
 * helpers without creating a cyclic import back to codegen.nx. Every
 * function here is a leaf: it may call other leaves but never recurses
 * through emit_expr / emit_stmt.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { SymbolNotFound } from "src/common/error.nx"
import { TypeExpr } from "src/common/ast.nx"
import { LirAtom, LirAtomVar, LirAtomInt, LirAtomFloat, LirAtomBool, LirAtomChar, LirAtomString, LirAtomUnit } from "src/ir/lir_types.nx"
import { CodegenCtx,
         vt_i32, vt_i64, bt_void,
         heap_global_idx,
         op_call, op_drop,
         op_local_get, op_local_set, op_local_tee, op_global_get, op_global_set,
         op_i32_load, op_i64_load, op_f64_load, op_i32_load8_u, op_i32_store, op_i64_store, op_f64_store, op_i32_store8,
         op_i32_const, op_i64_const, op_f64_const,
         op_i32_add, op_i32_sub, op_i32_shl, op_i32_shr_u, op_i32_ge_u, op_i32_gt_u,
         op_i32_wrap_i64, op_i64_extend_i32_s,
         op_i64_reinterpret_f64,
         op_memory_size, op_memory_grow,
         op_block, op_loop, op_if, op_end, op_br, op_br_if }, * as wdefs from "src/backend/wasm_defs.nx"

// ─── Atom emission ──────────────────────────────────────────────────────────

export let emit_atom_var = fn (name: string, typ: TypeExpr, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  if let TyUnit = wdefs.peel_linear(typ: typ) then return %buf end
  let raw_idx = wdefs.lookup_local(name: name, entries: wdefs.ctx_locals(ctx: ctx))
  match raw_idx < 0 do
    | true ->
      // Not a local — try top-level function (zero-arg constant)
      let func_idx = wdefs.lookup_func_fast(name: name, map: wdefs.ctx_internal_func_map(ctx: ctx))
      match func_idx >= 0 do
        | true ->
          let %buf = bb.push_byte(buf: %buf, byte: op_call)
          return bb.push_uleb128(buf: %buf, val: func_idx)
        | false ->
          let ext_idx = wdefs.lookup_func_fast(name: name, map: wdefs.ctx_external_func_map(ctx: ctx))
          match ext_idx >= 0 do
            | true ->
              let %buf = bb.push_byte(buf: %buf, byte: op_call)
              return bb.push_uleb128(buf: %buf, val: ext_idx)
            | false ->
              raise SymbolNotFound(name: name, kind: "variable", context: "emit_atom_var")
          end
      end
    | false ->
      let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
      let %buf = bb.push_uleb128(buf: %buf, val: raw_idx)
      // Narrow i64→i32 if local was widened but atom type is i32
      let atom_vt = wdefs.type_to_valtype(typ: wdefs.peel_linear(typ: typ))
      let local_vt = wdefs.lookup_local_valtype(name: name, entries: wdefs.ctx_locals(ctx: ctx))
      return match atom_vt == vt_i32 && local_vt == vt_i64 do
        | true -> bb.push_byte(buf: %buf, byte: op_i32_wrap_i64)
        | false -> %buf
      end
  end
end

export let emit_atom = fn (atom: LirAtom, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  match atom do
    | LirAtomVar(name: n, typ: at) ->
      return emit_atom_var(name: n, typ: at, buf: %buf, ctx: ctx)
    | LirAtomInt(val: v) ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i64_const)
      return bb.push_sleb128(buf: %buf, val: v)
    | LirAtomFloat(val: s) ->
      let %buf = bb.push_byte(buf: %buf, byte: op_f64_const)
      return bb.push_f64_str_le(buf: %buf, s: s)
    | LirAtomBool(val: bv) ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
      return bb.push_sleb128(buf: %buf, val: match bv do | true -> 1 | false -> 0 end)
    | LirAtomChar(val: cv) ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
      return bb.push_sleb128(buf: %buf, val: cv)
    | LirAtomString(val: s) ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i64_const)
      return bb.push_sleb128(buf: %buf, val: wdefs.lookup_string(value: s, entries: wdefs.ctx_string_lits(ctx: ctx)))
    | LirAtomUnit -> %buf
  end
end

// ─── Coercion / pack / unpack ───────────────────────────────────────────────

export let emit_coercion = fn (from_type: TypeExpr, to_type: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer throws { Exn } do
  let f = wdefs.peel_linear(typ: from_type)
  let t = wdefs.peel_linear(typ: to_type)
  if let TyUnit = f then return %buf end
  if let TyUnit = t then return %buf end
  let fv = wdefs.type_to_valtype(typ: f)
  let tv = wdefs.type_to_valtype(typ: t)
  if fv == tv then return %buf
  else if fv == vt_i64 && tv == vt_i32 then return bb.push_byte(buf: %buf, byte: op_i32_wrap_i64)
  else if fv == vt_i32 && tv == vt_i64 then return bb.push_byte(buf: %buf, byte: op_i64_extend_i32_s)
  else return %buf
  end
end

export let emit_pack_to_i64 = fn (typ: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer throws { Exn } do
  match wdefs.peel_linear(typ: typ) do
    | TyI32 -> bb.push_byte(buf: %buf, byte: op_i64_extend_i32_s)
    | TyBool -> bb.push_byte(buf: %buf, byte: op_i64_extend_i32_s)
    | TyChar -> bb.push_byte(buf: %buf, byte: op_i64_extend_i32_s)
    | TyUnit ->
      let %buf = bb.push_bytes(buf: %buf, bytes: [op_drop, op_i64_const])
      bb.push_sleb128(buf: %buf, val: 0)
    | TyF64 -> bb.push_byte(buf: %buf, byte: op_i64_reinterpret_f64)
    | _ -> %buf
  end
end

export let emit_typed_field_store = fn (typ: TypeExpr, buf: %ByteBuffer, offset: i64) -> %ByteBuffer throws { Exn } do
  match wdefs.peel_linear(typ: typ) do
    | TyI32 ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_store)
      return wdefs.emit_memarg_i32(buf: %buf, offset: offset)
    | TyBool ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_store)
      return wdefs.emit_memarg_i32(buf: %buf, offset: offset)
    | TyChar ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_store)
      return wdefs.emit_memarg_i32(buf: %buf, offset: offset)
    | TyF64 ->
      let %buf = bb.push_byte(buf: %buf, byte: op_f64_store)
      return wdefs.emit_memarg_i64(buf: %buf, offset: offset)
    | TyUnit ->
      return bb.push_byte(buf: %buf, byte: op_drop)
    | _ ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i64_store)
      return wdefs.emit_memarg_i64(buf: %buf, offset: offset)
  end
end

// Typed field load: loads a value in its native WASM type, avoiding unpack_from_i64 overhead.
// Stack: [addr:i32] → [value:<native>].
export let emit_typed_field_load = fn (typ: TypeExpr, buf: %ByteBuffer, offset: i64) -> %ByteBuffer throws { Exn } do
  match wdefs.peel_linear(typ: typ) do
    | TyI32 ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_load)
      return wdefs.emit_memarg_i32(buf: %buf, offset: offset)
    | TyBool ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_load)
      return wdefs.emit_memarg_i32(buf: %buf, offset: offset)
    | TyChar ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_load)
      return wdefs.emit_memarg_i32(buf: %buf, offset: offset)
    | TyF64 ->
      let %buf = bb.push_byte(buf: %buf, byte: op_f64_load)
      return wdefs.emit_memarg_i64(buf: %buf, offset: offset)
    | TyUnit ->
      return bb.push_byte(buf: %buf, byte: op_drop)
    | _ ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i64_load)
      return wdefs.emit_memarg_i64(buf: %buf, offset: offset)
  end
end

// ─── Memory grow check ───────────────────────────────────────────────────────
// Emit: if (global.get 0 > memory.size * 65536) { memory.grow(needed_pages); drop }
// This pattern matches the Rust codegen (module.rs:610-631, emit.rs:47-66).

export let emit_memory_grow_check = fn (buf: %ByteBuffer, skip: bool) -> %ByteBuffer do
  if skip then return %buf end
  // if (heap_ptr > current_memory_bytes)
  let %buf = bb.push_byte(buf: %buf, byte: op_global_get)
  let %buf = bb.push_uleb128(buf: %buf, val: heap_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_memory_size)
  let %buf = bb.push_byte(buf: %buf, byte: 0) // mem index 0
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(buf: %buf, val: 16)
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_shl) // pages * 65536
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_gt_u, op_if])
  let %buf = bb.push_byte(buf: %buf, byte: 64) // blocktype void
  // pages_needed = ceil((heap_ptr - current_bytes) / 65536)
  let %buf = bb.push_byte(buf: %buf, byte: op_global_get)
  let %buf = bb.push_uleb128(buf: %buf, val: heap_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_memory_size)
  let %buf = bb.push_byte(buf: %buf, byte: 0) // mem index 0
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(buf: %buf, val: 16)
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_shl, op_i32_sub]) // overflow bytes
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(buf: %buf, val: 65535)
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_add) // round up
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(buf: %buf, val: 16)
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_shr_u) // / 65536 = pages
  let %buf = bb.push_byte(buf: %buf, byte: op_memory_grow)
  let %buf = bb.push_byte(buf: %buf, byte: 0) // mem index 0
  let %buf = bb.push_byte(buf: %buf, byte: op_drop) // discard result (-1 on failure)
  return bb.push_byte(buf: %buf, byte: op_end)
end


// ─── Object allocation ──────────────────────────────────────────────────────

export let emit_alloc_object = fn (buf: %ByteBuffer, ctx: CodegenCtx, words: i64) -> %ByteBuffer throws { Exn } do
  let obj_ptr = wdefs.ctx_temps_base(ctx: ctx) + 3
  let alloc_idx = wdefs.lookup_func_fast(name: "__nx_allocate", map: wdefs.ctx_external_func_map(ctx: ctx))
  match alloc_idx >= 0 do
    | true ->
      // stdlib allocate: call allocate(bytes) -> ptr
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(buf: %buf, val: words * 8)
      let %buf = bb.push_byte(buf: %buf, byte: op_call)
      let %buf = bb.push_uleb128(buf: %buf, val: alloc_idx)
      let %buf = bb.push_byte(buf: %buf, byte: op_local_set)
      return bb.push_uleb128(buf: %buf, val: obj_ptr)
    | false ->
      // bump allocator: global_get 0, tee ptr, add bytes, global_set 0
      let %buf = bb.push_byte(buf: %buf, byte: op_global_get)
      let %buf = bb.push_uleb128(buf: %buf, val: heap_global_idx)
      let %buf = bb.push_byte(buf: %buf, byte: op_local_tee)
      let %buf = bb.push_uleb128(buf: %buf, val: obj_ptr)
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(buf: %buf, val: words * 8)
      let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_add, op_global_set])
      let %buf = bb.push_uleb128(buf: %buf, val: heap_global_idx)
      // Grow memory if heap exceeds current pages (skip when stdlib manages memory)
      return emit_memory_grow_check(buf: %buf, skip: wdefs.ctx_alloc_mode(ctx: ctx) == 2)
  end
end

// ─── String unpack ──────────────────────────────────────────────────────────

export let emit_unpack_string = fn (buf: %ByteBuffer, packed_local: i64, ptr_local: i64, len_local: i64) -> %ByteBuffer throws { Exn } do
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: packed_local)
  let %buf = bb.push_byte(buf: %buf, byte: op_i64_const)
  let %buf = bb.push_sleb128(buf: %buf, val: 32)
  let %buf = bb.push_byte(buf: %buf, byte: wdefs.op_i64_shr_u)
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_wrap_i64, op_local_set])
  let %buf = bb.push_uleb128(buf: %buf, val: ptr_local)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: packed_local)
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_wrap_i64, op_local_set])
  return bb.push_uleb128(buf: %buf, val: len_local)
end

// ─── Memcpy loops ───────────────────────────────────────────────────────────

export let emit_memcpy_loop = fn (buf: %ByteBuffer, src_ptr: i64, dst_ptr: i64, dst_offset: i64,
                            len_local: i64, idx_local: i64) -> %ByteBuffer throws { Exn } do
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(buf: %buf, val: 0)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_set)
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_byte(buf: %buf, byte: op_block)
  let %buf = bb.push_byte(buf: %buf, byte: bt_void)
  let %buf = bb.push_byte(buf: %buf, byte: op_loop)
  let %buf = bb.push_byte(buf: %buf, byte: bt_void)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: len_local)
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_ge_u, op_br_if])
  let %buf = bb.push_uleb128(buf: %buf, val: 1)
  // dst[idx] = src[idx]
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: dst_ptr)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_add, op_local_get])
  let %buf = bb.push_uleb128(buf: %buf, val: src_ptr)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_add, op_i32_load8_u])
  let %buf = wdefs.emit_memarg_i8(buf: %buf)
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_store8)
  let %buf = wdefs.emit_memarg_i8(buf: %buf)
  // idx++
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(buf: %buf, val: 1)
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_add, op_local_set])
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_byte(buf: %buf, byte: op_br)
  let %buf = bb.push_uleb128(buf: %buf, val: heap_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_end)
  return bb.push_byte(buf: %buf, byte: op_end)
end

export let emit_memcpy_loop_offset = fn (buf: %ByteBuffer, src_ptr: i64, dst_ptr: i64,
                                   offset_local: i64, len_local: i64, idx_local: i64) -> %ByteBuffer throws { Exn } do
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(buf: %buf, val: 0)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_set)
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_byte(buf: %buf, byte: op_block)
  let %buf = bb.push_byte(buf: %buf, byte: bt_void)
  let %buf = bb.push_byte(buf: %buf, byte: op_loop)
  let %buf = bb.push_byte(buf: %buf, byte: bt_void)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: len_local)
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_ge_u, op_br_if])
  let %buf = bb.push_uleb128(buf: %buf, val: 1)
  // dst[offset + idx]
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: dst_ptr)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: offset_local)
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_add, op_local_get])
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_add)
  // src[idx]
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: src_ptr)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_add, op_i32_load8_u])
  let %buf = wdefs.emit_memarg_i8(buf: %buf)
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_store8)
  let %buf = wdefs.emit_memarg_i8(buf: %buf)
  let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(buf: %buf, val: 1)
  let %buf = bb.push_bytes(buf: %buf, bytes: [op_i32_add, op_local_set])
  let %buf = bb.push_uleb128(buf: %buf, val: idx_local)
  let %buf = bb.push_byte(buf: %buf, byte: op_br)
  let %buf = bb.push_uleb128(buf: %buf, val: heap_global_idx)
  let %buf = bb.push_byte(buf: %buf, byte: op_end)
  return bb.push_byte(buf: %buf, byte: op_end)
end
