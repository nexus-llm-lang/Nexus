/**
 * codegen/intrinsics/math: f64 unary math intrinsics.
 *
 * Owns `emit_f64_unary` — a generic dispatcher for single-operand f64 wasm
 * ops (sqrt / floor / ceil / abs). The caller passes the wasm opcode and the
 * intrinsic's wire name (for error reporting); no coercion is needed since
 * the FFI types are already f64.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { LirCallArg } from "src/ir/lir/types.nx"
import { CodegenCtx } from "src/backend/codegen/ctx/context.nx"
import { emit_atom } from "src/backend/codegen/emit/atom.nx"
import { SymbolNotFound, CodegenError, SkIntrinsicArg } from "src/backend/errors.nx"

/** Emit a single-operand f64 wasm op (sqrt / floor / ceil / abs) on the argument atom; `name` carries the intrinsic's wire name only so a missing-arg `SymbolNotFound` can carry an actionable identifier. */
export let emit_f64_unary = fn (
  opcode: i64,
  args: [ LirCallArg ],
  buf: %ByteBuffer,
  ctx: CodegenCtx,
  name: string
) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      return bb.push_byte(%buf, byte: opcode)
    | _ ->
      throw SymbolNotFound(name, kind: SkIntrinsicArg, context: "f64 unary requires one argument")
      return %buf
  end
end
