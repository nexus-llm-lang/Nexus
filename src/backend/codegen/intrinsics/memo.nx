/**
 * codegen/intrinsics/memo: MemoTarget list extractors.
 *
 * CodegenCtx stores name/slot lists in parallel rather than the structured
 * MemoTarget type so the per-call lookup stays a tight string compare without
 * re-deconstructing a record on every call site. These extractors split the
 * MemoTarget list once at module-assembly time.
 */
import * as list from "std:list"
import { MemoTarget } from "src/backend/codegen/ctx/memo.nx"

/** Project the `name` field out of each `MemoTarget`; returned in source order so it pairs positionally with `extract_memo_slots`. Used to split the structured target list into the parallel string/i64 lists that `CodegenCtx` stores for hot-path lookup. */
export let extract_memo_names = fn (targets: [MemoTarget], acc: [string]) -> [string] do
  match targets do
    | [] -> return list.reverse(xs: acc)
    | MemoTarget(name: n, slot: _) :: rest ->
      return extract_memo_names(targets: rest, acc: n :: acc)
  end
end

/** Project the `slot` field out of each `MemoTarget`; positionally aligned with `extract_memo_names` so a `(name, slot)` cache entry can be reconstructed by index. */
export let extract_memo_slots = fn (targets: [MemoTarget], acc: [i64]) -> [i64] do
  match targets do
    | [] -> return list.reverse(xs: acc)
    | MemoTarget(name: _, slot: s) :: rest ->
      return extract_memo_slots(targets: rest, acc: s :: acc)
  end
end
