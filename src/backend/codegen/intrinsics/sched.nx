/**
 * codegen/intrinsics/sched: nexus:runtime/sched inline intrinsics.
 *
 * Owns:
 * - `is_sched_set_next` / `emit_sched_set_next` — inline `global.set` for
 *   the resume slot so the host-call detour cannot corrupt wasmtime's
 *   CallThreadState chain inside continuation arm bodies.
 * - `is_sched_spawn` / `emit_sched_spawn` — inline fiber spawn: push
 *   thunk, allocate cont slot, `cont.new` trampoline, enqueue slot.
 * - `find_sched_import_idx` — linear scan over filtered externals to locate
 *   `nexus:runtime/sched` import indices for spawn's push/enqueue calls.
 * - `find_func_idx_by_suffix` — suffix-match helper for locating the sched
 *   trampoline regardless of package-path aliasing.
 * - `wasi_thread_start_export` — locates the optional `wasi_thread_start`
 *   internal for the wasm export section.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { LirFunction, LirExternal, LirCallArg } from "src/ir/lir/types.nx"
import { CodegenCtx, ctx_temps_base, ctx_externals } from "src/backend/codegen/ctx/context.nx"
import { ExportNameIdx,
         op_call,
         op_ref_func, op_cont_new, op_table_set,
         op_local_get, op_local_tee, op_global_get, op_global_set,
         op_i32_const, op_i64_const,
         op_i64_add,
         op_i32_wrap_i64 }, * as wdefs from "src/backend/wasm/defs.nx"
import { emit_atom } from "src/backend/codegen/emit/atom.nx"
import { HashMap } from "std:hashmap"
import { Some, None } from "std:option"
import * as str from "std:str"
import { SymbolNotFound, CodegenError, SkIntrinsic, SkIntrinsicArg } from "src/backend/errors.nx"

// Inline the intrinsic-filter logic so this module does not import from
// intrinsics.nx (which itself imports from here — avoiding a circular dep).

let is_intrinsic_external_local = fn (ext: LirExternal) -> bool do
  match ext do
    | LirExternal(name: _, wasm_module: m, wasm_name: _, params: _, ret_type: _, throw_row: _) ->
      return m == "nexus:intrinsic"
  end
end

let is_intrinsic_sched_external_local = fn (ext: LirExternal) -> bool do
  match ext do
    | LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _) ->
      if m != "nexus:runtime/sched" then return false end
      return wn == "sched-set-next" || wn == "sched-spawn"
  end
end

/** `__nx_sched_set_next(k)` is a compiler intrinsic that compiles to inline
 *  `global.set ss_resume_slot_global_idx`. Routing it through a host call
 *  trips wasmtime's CallThreadState chain when invoked inside a continuation
 *  arm body (after suspend, before resume); inline emission sidesteps the
 *  host-side trap-handler bookkeeping entirely.
 */
export let is_sched_set_next = fn (func: string, exts: [ LirExternal ]) -> bool do
  match wdefs.lookup_external(name: func, exts) do
    | None -> false
    | Some(val: LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _)) ->
      return m == "nexus:runtime/sched" && wn == "sched-set-next"
  end
end

/** Inline body for `__nx_sched_set_next(k)`: emit the i64 arg and store it into the scheduler's `ss_resume_slot` global so the next `resume` picks up `k`. Avoids the host-call detour that would otherwise corrupt wasmtime's CallThreadState chain inside continuation arm bodies. */
export let emit_sched_set_next = fn (args: [ LirCallArg ], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_global_set)
      return bb.push_uleb128(%buf, val: wdefs.ss_resume_slot_global_idx)
    | _ ->
      throw SymbolNotFound(name: "__nx_sched_set_next", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

/** `__nx_sched_spawn(thunk)` is a compiler intrinsic that turns a `@unit` thunk
 *  into a fresh fiber: pushes the thunk onto the host's pending-thunk FIFO,
 *  allocates a new cont_table slot, cont.new's the trampoline body for that
 *  slot, and enqueues the slot in the run queue. The spawned fiber actually
 *  starts running when the dispatcher dequeues the slot, resumes the cont,
 *  and the trampoline pops the matching thunk and forces it.
 */
export let is_sched_spawn = fn (func: string, exts: [ LirExternal ]) -> bool do
  match wdefs.lookup_external(name: func, exts) do
    | None -> false
    | Some(val: LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _)) ->
      return m == "nexus:runtime/sched" && wn == "sched-spawn"
  end
end

/** Look up a function by suffix match (-1 if absent). Used to locate the sched
 *  trampoline regardless of which package path (nxlib/stdlib/sched.nx vs an
 *  alias) the stdlib was imported from.
 */
let find_func_idx_by_suffix = fn (suffix: string, funcs: [ LirFunction ], internal_func_map: &HashMap) -> i64 do
  match funcs do
    | [] -> return -1
    | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      let slen = str.length(s: n)
      let suflen = str.length(s: suffix)
      if slen >= suflen then
        if str.substring(s: n, start: slen - suflen, len: suflen) == suffix then
          return wdefs.lookup_func_fast(name: n, map: internal_func_map)
        end
      end
      return find_func_idx_by_suffix(suffix, funcs: rest, internal_func_map)
  end
end

/**
If the program defines `wasi_thread_start` (pulled in via `std:lazy` /
`std:task`), it must be exported under exactly that name so wasi-threads
workers can find it; its `(i32, i32) -> ()` signature is produced by the
`lazy.nx` source. Returns a singleton `[ExportNameIdx]` or `[]`.
*/
export let wasi_thread_start_export = fn (funcs: [ LirFunction ], internal_func_map: &HashMap) -> [ ExportNameIdx ] throws { CodegenError } do
  let bare = wdefs.lookup_func_fast(name: "wasi_thread_start", map: internal_func_map)
  let idx = if bare >= 0 then bare else find_func_idx_by_suffix(suffix: "#wasi_thread_start", funcs, internal_func_map) end
  if idx < 0 then return [] end
  return [ExportNameIdx(name: "wasi_thread_start", index: idx)]
end

/** Find the import index for a sched runtime function by its wasm_name. Uses
 *  linear scan over the externals list because hash lookup by Nexus FFI name
 *  is fragile when several `nexus:runtime/sched` imports share a prefix.
 *  Skips arena and intrinsic-sched externals to mirror `filter_intrinsic_externals`
 *  — those entries are inlined and thus excluded from the wasm import section,
 *  so they do not occupy index slots in the codegen's pre-merge function space.
 */
export let find_sched_import_idx = fn (wn: string, exts: [ LirExternal ], idx: i64) -> i64 throws { CodegenError } do
  match exts do
    | [] -> return -1
    | e :: rest ->
      if is_intrinsic_external_local(ext: e) || is_intrinsic_sched_external_local(ext: e) then
        return find_sched_import_idx(wn, exts: rest, idx)
      end
      match e do | LirExternal(name: _, wasm_module: m, wasm_name: w, params: _, ret_type: _, throw_row: _) ->
        if m == "nexus:runtime/sched" && w == wn then return idx end
        return find_sched_import_idx(wn, exts: rest, idx: idx + 1)
      end
  end
end

/** Inline body for `__nx_sched_spawn(thunk)`: push the thunk to the host pending-thunks FIFO, claim the next free cont slot (with `+1` skip to avoid clobbering the surrounding `InjectResume` dispatcher's own bookkeeping), `cont.new` the trampoline body into the slot, and enqueue the slot. The trampoline pops the matching thunk and forces it when the dispatcher resumes the cont. */
export let emit_sched_spawn = fn (args: [ LirCallArg ], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let CodegenCtx(functions: fns, internal_func_map: ifm, ss_cont_type_idx: cti, _) = ctx
      let exts = ctx_externals(ctx)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let push_idx = find_sched_import_idx(wn: "sched-push-pending", exts, idx: 0)
      if push_idx < 0 then
        throw SymbolNotFound(name: "sched-push-pending", kind: SkIntrinsic, context: "spawn requires push_pending external")
      end
      let %buf = bb.push_byte(%buf, byte: op_call)
      let %buf = bb.push_uleb128(%buf, val: push_idx)

      // slot = next_alloc + 1 to skip the cont slot the surrounding
      // InjectResume dispatcher just claimed for its own arm-call bookkeeping;
      // next_alloc = slot + 1 so the dispatcher's post-arm `++` advances to a
      // fresh free slot instead of overwriting our trampoline cont.
      let slot_local = ctx_temps_base(ctx) + 4
      let %buf = bb.push_byte(%buf, byte: op_global_get)
      let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 1)
      let %buf = bb.push_bytes(%buf, bytes: [ op_i64_add, op_local_tee ])
      let %buf = bb.push_uleb128(%buf, val: slot_local)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 1)
      let %buf = bb.push_bytes(%buf, bytes: [ op_i64_add, op_global_set ])
      let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)

      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: slot_local)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let tramp_idx = find_func_idx_by_suffix(
        suffix: "__nx_sched_trampoline_body",
        funcs: fns,
        internal_func_map: &ifm)
      if tramp_idx < 0 then
        throw SymbolNotFound(name: "__nx_sched_trampoline_body", kind: SkIntrinsic, context: "spawn requires sched.nx import")
      end
      let %buf = bb.push_byte(%buf, byte: op_ref_func)
      let %buf = bb.push_uleb128(%buf, val: tramp_idx)
      let %buf = bb.push_byte(%buf, byte: op_cont_new)
      let %buf = bb.push_uleb128(%buf, val: cti)
      let %buf = bb.push_byte(%buf, byte: op_table_set)
      let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_table_idx)

      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: slot_local)
      let enqueue_idx = find_sched_import_idx(wn: "sched-enqueue", exts, idx: 0)
      if enqueue_idx < 0 then
        throw SymbolNotFound(name: "sched-enqueue", kind: SkIntrinsic, context: "spawn requires enqueue external")
      end
      let %buf = bb.push_byte(%buf, byte: op_call)
      let %buf = bb.push_uleb128(%buf, val: enqueue_idx)
      return %buf
    | _ ->
      throw SymbolNotFound(name: "__nx_sched_spawn", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end
