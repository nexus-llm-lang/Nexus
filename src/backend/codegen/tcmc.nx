/**
 * codegen/tcmc: Tail Call Modulo Constructor (TCMC) detection + emission.
 *
 * Owns:
 * - TcmcCtx type and tcmc_deeper (loop-depth bookkeeping)
 * - detect_tcmc / find_tcmc_in_stmts / find_tcmc_in_branches /
 *   check_tcmc_pair / find_var_in_atoms (detection)
 * - emit_tcmc_init, emit_tcmc_cons_and_loop (in-place list build + rebranch)
 * - emit_tcmc_non_rec_fields / emit_tcmc_param_push / emit_tcmc_param_set
 * - emit_return_with_tcmc (conditional link + return)
 *
 * Does not own:
 * - The emit_stmt interception point (see src/backend/codegen.nx) — it
 *   calls emit_tcmc_cons_and_loop on a TCMC constructor match.
 * - compile_function_body's TCMC probe + init call (see codegen.nx).
 *
 * Note: detect_tcmc currently returns NoTcmc unconditionally (TCMC is
 * disabled pending fixes to nxc codegen — see dtq5). The helpers are kept
 * live so the code path can be re-enabled by flipping detect_tcmc's body.
 */
import { ByteBuffer }, * as bb from "stdlib/bytebuffer.nx"
import { TypeExpr } from "src/common/ast.nx"
import { LirFunction, LirStmt, LirStmtIf, LirStmtIfReturn, LirStmtLoop, LirStmtLet,
         LirExpr, LirExprCall, LirExprConstructor,
         LirAtom, LirAtomVar, LirParam, LirCallArg } from "src/ir/lir_types.nx"
import { CodegenCtx,
         bt_void,
         op_return, op_br, op_if, op_else, op_end,
         op_local_get, op_local_set,
         op_i32_const, op_i64_const, op_i32_ne,
         op_i64_extend_i32_u, op_i64_store }, * as wdefs from "src/backend/wasm_defs.nx"
import { emit_atom, emit_coercion, emit_alloc_object, emit_typed_field_store } from "src/backend/codegen/atom.nx"
import * as list from "stdlib/list.nx"
import { SymbolNotFound } from "src/common/error.nx"

/// TCMC context: tracks in-place list building state.
/// head_local/prev_local at temps_base + 13/14 (always allocated).
export type TcmcCtx = NoTcmc | TcmcActive(
  head_local: i64, prev_local: i64, rest_field_idx: i64,
  call_var: string, cons_var: string,
  call_args: [LirCallArg],   // self-call args (for param reassignment)
  ctor_name: string,          // constructor name (for tag computation)
  ctor_args: [LirAtom],       // constructor field values (including placeholder rest)
  func_name: string,
  loop_depth: i64             // WASM block depth from current pos to TCO loop header
)

/// Return TcmcCtx with loop_depth incremented by n (for entering WASM blocks).
export let tcmc_deeper = fn (tcmc: TcmcCtx, n: i64) -> TcmcCtx throws { Exn } do
  match tcmc do
    | NoTcmc -> NoTcmc
    | TcmcActive(head_local: hl, prev_local: pl, rest_field_idx: rfi,
                     call_var: cv, cons_var: consv, call_args: ca,
                     ctor_name: cn, ctor_args: cta, func_name: fn2, loop_depth: d) ->
      TcmcActive(head_local: hl, prev_local: pl, rest_field_idx: rfi,
                  call_var: cv, cons_var: consv, call_args: ca,
                  ctor_name: cn, ctor_args: cta, func_name: fn2, loop_depth: d + n)
  end
end

/// Detect TCMC pattern: consecutive Let Call(self) + Let Constructor using the call result.
// TODO: TCMC detection disabled — runtime bugs in nxc codegen need fixing
export let detect_tcmc = fn (body: [LirStmt], func_name: string) -> TcmcCtx throws { Exn } do
  return NoTcmc
end

/// Check if two consecutive stmts form a TCMC pair: Let Call(self) + Let Constructor.
let check_tcmc_pair = fn (first: LirStmt, rest: [LirStmt], func_name: string) -> TcmcCtx throws { Exn } do
  match first do
    | LirStmtLet(name: call_name, typ: _, expr: LirExprCall(func: f, args: call_args, typ: _)) ->
      if f == func_name then
        match rest do
          | LirStmtLet(name: cons_name, typ: _, expr: LirExprConstructor(name: ctor_name, args: ctor_args, typ: _)) :: _ ->
            match find_var_in_atoms(atoms: ctor_args, target: call_name, idx: 0) do
              | Some(val: rest_idx) ->
                return TcmcActive(head_local: 0, prev_local: 0, rest_field_idx: rest_idx,
                  call_var: call_name, cons_var: cons_name, call_args: call_args,
                  ctor_name: ctor_name, ctor_args: ctor_args, func_name: func_name,
                  loop_depth: 0)
              | None -> return NoTcmc
            end
          | _ -> return NoTcmc
        end
      else return NoTcmc
      end
    | _ -> return NoTcmc
  end
end

/// Recurse into a statement's branches looking for TCMC patterns.
let find_tcmc_in_branches = fn (stmt: LirStmt, func_name: string) -> TcmcCtx throws { Exn } do
  match stmt do
    | LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
      match find_tcmc_in_stmts(stmts: tb, func_name: func_name) do
        | NoTcmc -> return find_tcmc_in_stmts(stmts: eb, func_name: func_name)
        | found -> return found
      end
    | LirStmtIfReturn(cond: _, then_body: tb, then_ret: _, else_body: eb, else_ret: _, ret_type: _) ->
      match find_tcmc_in_stmts(stmts: tb, func_name: func_name) do
        | NoTcmc -> return find_tcmc_in_stmts(stmts: eb, func_name: func_name)
        | found -> return found
      end
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      match find_tcmc_in_stmts(stmts: cs, func_name: func_name) do
        | NoTcmc -> return find_tcmc_in_stmts(stmts: b, func_name: func_name)
        | found -> return found
      end
    | _ -> return NoTcmc
  end
end

let find_tcmc_in_stmts = fn (stmts: [LirStmt], func_name: string) -> TcmcCtx throws { Exn } do
  match stmts do
    | s :: rest ->
      // Check if s + rest[0] form a TCMC pair
      match check_tcmc_pair(first: s, rest: rest, func_name: func_name) do
        | NoTcmc ->
          // Not a pair — recurse into branches of s, then continue with rest
          match find_tcmc_in_branches(stmt: s, func_name: func_name) do
            | NoTcmc -> return find_tcmc_in_stmts(stmts: rest, func_name: func_name)
            | found -> return found
          end
        | found -> return found
      end
    | [] -> return NoTcmc
  end
end

let find_var_in_atoms = fn (atoms: [LirAtom], target: string, idx: i64) -> Option<i64> throws { Exn } do
  match atoms do
    | [] -> return None
    | LirAtomVar(name: n, typ: _) :: rest ->
      if n == target then return Some(val: idx)
      else return find_var_in_atoms(atoms: rest, target: target, idx: idx + 1)
      end
    | _ :: rest -> return find_var_in_atoms(atoms: rest, target: target, idx: idx + 1)
  end
end

/// Emit TCMC init: head = 0, prev = 0 (called before the loop, runs once).
export let emit_tcmc_init = fn (buf: %ByteBuffer, tcmc: TcmcCtx) -> %ByteBuffer throws { Exn } do
  match tcmc do
    | NoTcmc -> return %buf
    | TcmcActive(head_local: hl, prev_local: pl, rest_field_idx: _, call_var: _,
                     cons_var: _, call_args: _, ctor_name: _, ctor_args: _, func_name: _, loop_depth: _) ->
      let %buf = bb.push_byte(buf: %buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(buf: %buf, val: 0)
      let %buf = bb.push_byte(buf: %buf, byte: op_local_set)
      let %buf = bb.push_uleb128(buf: %buf, val: hl)
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(buf: %buf, val: 0)
      let %buf = bb.push_byte(buf: %buf, byte: op_local_set)
      return bb.push_uleb128(buf: %buf, val: pl)
  end
end

/// Emit TCMC alloc + link + param reassign + br to loop.
export let emit_tcmc_cons_and_loop = fn (buf: %ByteBuffer, ctx: CodegenCtx, tcmc: TcmcCtx) -> %ByteBuffer throws { Exn } do
  match tcmc do
    | NoTcmc -> return %buf
    | TcmcActive(head_local: hl, prev_local: pl, rest_field_idx: rfi,
                     call_var: _, cons_var: _, call_args: cargs,
                     ctor_name: cname, ctor_args: cargs_ctor, func_name: fname,
                     loop_depth: ldepth) ->
      let obj_ptr = wdefs.ctx_temps_base(ctx: ctx) + 3
      // Find the function to get its params
      match wdefs.find_function(name: fname, funcs: wdefs.ctx_functions(ctx: ctx)) do
        | None ->
          raise SymbolNotFound(name: fname, kind: "function", context: "TCMC")
          return %buf
        | Some(val: LirFunction(name: _, params: params, ret_type: _, body: _, ret: _, span: _)) ->
          let arity = list.length(xs: cargs_ctor)
          // 1. Allocate constructor cell
          let %buf = emit_alloc_object(buf: %buf, ctx: ctx, words: 1 + arity)
          // Store tag
          let tag = wdefs.constructor_tag(name: cname, arity: arity)
          let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
          let %buf = bb.push_uleb128(buf: %buf, val: obj_ptr)
          let %buf = bb.push_byte(buf: %buf, byte: op_i64_const)
          let %buf = bb.push_sleb128(buf: %buf, val: tag)
          let %buf = bb.push_byte(buf: %buf, byte: op_i64_store)
          let %buf = wdefs.emit_memarg_i64(buf: %buf, offset: 0)
          // Store rest = 0 placeholder
          let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
          let %buf = bb.push_uleb128(buf: %buf, val: obj_ptr)
          let %buf = bb.push_byte(buf: %buf, byte: op_i64_const)
          let %buf = bb.push_sleb128(buf: %buf, val: 0)
          let %buf = bb.push_byte(buf: %buf, byte: op_i64_store)
          let %buf = wdefs.emit_memarg_i64(buf: %buf, offset: (rfi + 1) * 8)
          // Store non-recursive fields (all fields except rest_field_idx)
          let %buf = emit_tcmc_non_rec_fields(buf: %buf, ctx: ctx, obj_ptr: obj_ptr,
            args: cargs_ctor, rest_idx: rfi, field_idx: 0)

          // 2. Link: if prev != 0 → prev.rest = current, else head = current
          let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
          let %buf = bb.push_uleb128(buf: %buf, val: pl)
          let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
          let %buf = bb.push_sleb128(buf: %buf, val: 0)
          let %buf = bb.push_byte(buf: %buf, byte: op_i32_ne)
          let %buf = bb.push_byte(buf: %buf, byte: op_if)
          let %buf = bb.push_byte(buf: %buf, byte: bt_void)
          // prev.rest = current cell ptr (i64)
          let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
          let %buf = bb.push_uleb128(buf: %buf, val: pl)
          let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
          let %buf = bb.push_uleb128(buf: %buf, val: obj_ptr)
          let %buf = bb.push_byte(buf: %buf, byte: op_i64_extend_i32_u)
          let %buf = bb.push_byte(buf: %buf, byte: op_i64_store)
          let %buf = wdefs.emit_memarg_i64(buf: %buf, offset: (rfi + 1) * 8)
          let %buf = bb.push_byte(buf: %buf, byte: op_else)
          // head = current cell ptr
          let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
          let %buf = bb.push_uleb128(buf: %buf, val: obj_ptr)
          let %buf = bb.push_byte(buf: %buf, byte: op_i64_extend_i32_u)
          let %buf = bb.push_byte(buf: %buf, byte: op_local_set)
          let %buf = bb.push_uleb128(buf: %buf, val: hl)
          let %buf = bb.push_byte(buf: %buf, byte: op_end)

          // 3. Update prev = current
          let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
          let %buf = bb.push_uleb128(buf: %buf, val: obj_ptr)
          let %buf = bb.push_byte(buf: %buf, byte: op_local_set)
          let %buf = bb.push_uleb128(buf: %buf, val: pl)

          // 4. Reassign params from call_args + br to loop
          let %buf = emit_tcmc_param_push(buf: %buf, args: cargs, params: params, ctx: ctx)
          let %buf = emit_tcmc_param_set(buf: %buf, params: list.reverse(xs: params), ctx: ctx)
          let %buf = bb.push_byte(buf: %buf, byte: op_br)
          return bb.push_uleb128(buf: %buf, val: ldepth)
      end
  end
end

/// Emit non-recursive constructor fields (skip the rest_field_idx).
let emit_tcmc_non_rec_fields = fn (buf: %ByteBuffer, ctx: CodegenCtx, obj_ptr: i64,
                                     args: [LirAtom], rest_idx: i64, field_idx: i64) -> %ByteBuffer throws { Exn } do
  match args do
    | [] -> return %buf
    | a :: rest ->
      if field_idx == rest_idx then
        // Skip rest field (already set to 0)
        return emit_tcmc_non_rec_fields(buf: %buf, ctx: ctx, obj_ptr: obj_ptr,
          args: rest, rest_idx: rest_idx, field_idx: field_idx + 1)
      else
        let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
        let %buf = bb.push_uleb128(buf: %buf, val: obj_ptr)
        let %buf = emit_atom(atom: a, buf: %buf, ctx: ctx)
        let %buf = emit_typed_field_store(typ: wdefs.atom_type(atom: a), buf: %buf, offset: (field_idx + 1) * 8)
        return emit_tcmc_non_rec_fields(buf: %buf, ctx: ctx, obj_ptr: obj_ptr,
          args: rest, rest_idx: rest_idx, field_idx: field_idx + 1)
      end
  end
end

/// Push all call arg values onto the WASM stack (for param reassignment).
let emit_tcmc_param_push = fn (buf: %ByteBuffer, args: [LirCallArg], params: [LirParam], ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  match args do
    | [] -> return %buf
    | LirCallArg(label: _, value: a) :: arest ->
      match params do
        | [] -> return %buf
        | LirParam(label: _, name: _, typ: pt) :: prest ->
          let %buf = emit_atom(atom: a, buf: %buf, ctx: ctx)
          let %buf = emit_coercion(from_type: wdefs.atom_type(atom: a), to_type: pt, buf: %buf)
          return emit_tcmc_param_push(buf: %buf, args: arest, params: prest, ctx: ctx)
      end
  end
end

/// Pop params from stack in reverse order (WASM stack is LIFO).
let emit_tcmc_param_set = fn (buf: %ByteBuffer, params: [LirParam], ctx: CodegenCtx) -> %ByteBuffer throws { Exn } do
  match params do
    | [] -> return %buf
    | LirParam(label: _, name: n, typ: _) :: rest ->
      let idx = wdefs.lookup_local(name: n, entries: wdefs.ctx_locals(ctx: ctx))
      let %buf = bb.push_byte(buf: %buf, byte: op_local_set)
      let %buf = bb.push_uleb128(buf: %buf, val: idx)
      return emit_tcmc_param_set(buf: %buf, params: rest, ctx: ctx)
  end
end

/// Emit a return value with conditional TCMC linking.
/// If TCMC prev != 0: link last cell's rest to ret_val, return head.
/// Otherwise: return ret_val normally.
export let emit_return_with_tcmc = fn (buf: %ByteBuffer, ret_val: LirAtom, ret_type: TypeExpr,
                                 ctx: CodegenCtx, tcmc: TcmcCtx) -> %ByteBuffer throws { Exn } do
  match tcmc do
    | NoTcmc ->
      let %buf = emit_atom(atom: ret_val, buf: %buf, ctx: ctx)
      let %buf = emit_coercion(from_type: wdefs.atom_type(atom: ret_val), to_type: ret_type, buf: %buf)
      return bb.push_byte(buf: %buf, byte: op_return)
    | TcmcActive(head_local: hl, prev_local: pl, rest_field_idx: rfi,
                     call_var: _, cons_var: _, call_args: _, ctor_name: _, ctor_args: _, func_name: _, loop_depth: _) ->
      // if (prev != 0)
      let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
      let %buf = bb.push_uleb128(buf: %buf, val: pl)
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(buf: %buf, val: 0)
      let %buf = bb.push_byte(buf: %buf, byte: op_i32_ne)
      let %buf = bb.push_byte(buf: %buf, byte: op_if)
      let %buf = bb.push_byte(buf: %buf, byte: bt_void)
      // Link: prev.rest = ret_val
      let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
      let %buf = bb.push_uleb128(buf: %buf, val: pl)
      let %buf = emit_atom(atom: ret_val, buf: %buf, ctx: ctx)
      let %buf = emit_typed_field_store(typ: wdefs.atom_type(atom: ret_val), buf: %buf, offset: (rfi + 1) * 8)
      // Return head
      let %buf = bb.push_byte(buf: %buf, byte: op_local_get)
      let %buf = bb.push_uleb128(buf: %buf, val: hl)
      let %buf = bb.push_byte(buf: %buf, byte: op_return)
      let %buf = bb.push_byte(buf: %buf, byte: op_else)
      // Normal return
      let %buf = emit_atom(atom: ret_val, buf: %buf, ctx: ctx)
      let %buf = emit_coercion(from_type: wdefs.atom_type(atom: ret_val), to_type: ret_type, buf: %buf)
      let %buf = bb.push_byte(buf: %buf, byte: op_return)
      return bb.push_byte(buf: %buf, byte: op_end)
  end
end
