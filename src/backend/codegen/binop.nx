/**
 * codegen/binop: integer/float/bool binary-op emission.
 *
 * Owns:
 * - binary_operand_type (operand-type unification for BinaryOp)
 * - emit_binary (one push_byte after operand coercion)
 *
 * Does not own:
 * - String concat / compare (see codegen/string.nx)
 * - Operand atom emission + coercion (see codegen/atom.nx)
 * - Dispatch from LirExprBinary — stays in codegen.nx emit_expr because
 *   the surrounding chain (emit_atom + emit_coercion + emit_binary) is
 *   trivial enough to inline at the only call site.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { BinaryOp, TypeExpr } from "src/common/ast.nx"
import { vt_i32, vt_i64,
         op_i32_eq, op_i32_ne, op_i32_lt_s, op_i32_gt_s, op_i32_le_s, op_i32_ge_s,
         op_i32_add, op_i32_sub, op_i32_mul, op_i32_xor,
         op_i64_eq, op_i64_ne, op_i64_lt_s, op_i64_le_s, op_i64_gt_s, op_i64_ge_s,
         op_i64_add, op_i64_sub, op_i64_mul, op_i64_div_s, op_i64_rem_s,
         op_i64_and, op_i64_or, op_i64_xor, op_i64_shl, op_i64_shr_s,
         op_f64_eq, op_f64_ne, op_f64_lt, op_f64_le, op_f64_gt, op_f64_ge,
         op_f64_add, op_f64_sub, op_f64_mul, op_f64_div,
         op_f32_eq, op_f32_ne, op_f32_lt, op_f32_le, op_f32_gt, op_f32_ge,
         op_f32_add, op_f32_sub, op_f32_mul, op_f32_div,
         op_i32_and, op_i32_or }, * as wdefs from "src/backend/wasm/defs.nx"
import { TyI64 } from "src/common/ast.nx"
import { SymbolNotFound, CodegenError } from "src/common/error.nx"

// Determine common operand type for binary ops. Both operands will be
// coerced to this type before the binary opcode.
export let binary_operand_type = fn (op: BinaryOp, lhs_type: TypeExpr, rhs_type: TypeExpr) -> TypeExpr do
  let lt = wdefs.peel_linear(typ: lhs_type)
  let rt = wdefs.peel_linear(typ: rhs_type)
  // Logical And/Or always operate on booleans (i32)
  match op do
    | OpAnd -> return TyBool
    | OpOr -> return TyBool
    | _ -> ()
  end
  let lt_vt = wdefs.type_to_valtype(typ: lt)
  let rt_vt = wdefs.type_to_valtype(typ: rt)
  // If both have the same valtype, prefer the left type
  if lt_vt == rt_vt then return lt end
  // Mixed i32/i64: widen to i64
  if (lt_vt == vt_i32 && rt_vt == vt_i64) || (lt_vt == vt_i64 && rt_vt == vt_i32) then
    return TyI64
  end
  // Fallback: use left type
  return lt
end

export let emit_binary = fn (op: BinaryOp, operand_type: TypeExpr, buf: %ByteBuffer) -> %ByteBuffer throws { CodegenError } do
  let use_i32 = match wdefs.peel_linear(typ: operand_type) do
    | TyBool -> true | TyI32 -> true | TyChar -> true | _ -> false
  end
  // Float ops dispatch on f32 vs f64 valtype; non-float ops ignore use_f32.
  let use_f32 = match wdefs.peel_linear(typ: operand_type) do
    | TyF32 -> true | _ -> false
  end
  let opcode = match op do
    | OpAdd -> match use_i32 do | true -> op_i32_add | false -> op_i64_add end
    | OpSub -> match use_i32 do | true -> op_i32_sub | false -> op_i64_sub end
    | OpMul -> match use_i32 do | true -> op_i32_mul | false -> op_i64_mul end
    | OpDiv -> op_i64_div_s | OpMod -> op_i64_rem_s
    | OpFAdd -> match use_f32 do | true -> op_f32_add | false -> op_f64_add end
    | OpFSub -> match use_f32 do | true -> op_f32_sub | false -> op_f64_sub end
    | OpFMul -> match use_f32 do | true -> op_f32_mul | false -> op_f64_mul end
    | OpFDiv -> match use_f32 do | true -> op_f32_div | false -> op_f64_div end
    | OpEq -> match use_i32 do | true -> op_i32_eq | false -> op_i64_eq end
    | OpNe -> match use_i32 do | true -> op_i32_ne | false -> op_i64_ne end
    | OpLt -> match use_i32 do | true -> op_i32_lt_s | false -> op_i64_lt_s end
    | OpLe -> match use_i32 do | true -> op_i32_le_s | false -> op_i64_le_s end
    | OpGt -> match use_i32 do | true -> op_i32_gt_s | false -> op_i64_gt_s end
    | OpGe -> match use_i32 do | true -> op_i32_ge_s | false -> op_i64_ge_s end
    | OpFEq -> match use_f32 do | true -> op_f32_eq | false -> op_f64_eq end
    | OpFNe -> match use_f32 do | true -> op_f32_ne | false -> op_f64_ne end
    | OpFLt -> match use_f32 do | true -> op_f32_lt | false -> op_f64_lt end
    | OpFLe -> match use_f32 do | true -> op_f32_le | false -> op_f64_le end
    | OpFGt -> match use_f32 do | true -> op_f32_gt | false -> op_f64_gt end
    | OpFGe -> match use_f32 do | true -> op_f32_ge | false -> op_f64_ge end
    | OpBitAnd -> match use_i32 do | true -> op_i32_and | false -> op_i64_and end
    | OpBitOr -> match use_i32 do | true -> op_i32_or | false -> op_i64_or end
    | OpBitXor -> match use_i32 do | true -> op_i32_xor | false -> op_i64_xor end
    | OpShl -> op_i64_shl | OpShr -> op_i64_shr_s
    | OpAnd -> match use_i32 do | true -> op_i32_and | false -> op_i64_and end
    | OpOr -> match use_i32 do | true -> op_i32_or | false -> op_i64_or end
    | OpConcat -> raise SymbolNotFound(name: "OpConcat", kind: "binary operator", context: "emit_binary: string concat must go through emit_string_concat, not emit_binary")
  end
  return bb.push_byte(%buf, byte: opcode)
end
