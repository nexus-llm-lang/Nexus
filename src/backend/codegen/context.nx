/**
 * codegen/context: CodegenCtx type + per-context accessor helpers.
 *
 * Extracted from src/backend/wasm/defs.nx so that the leaf codegen modules
 * under src/backend/codegen/ can import the context carrier without pulling
 * in the full wasm-constants namespace.
 *
 * The companion helper types (LocalEntry, FuncEntry, StringEntry,
 * ArityTypeIdx, ExportNameIdx) and the low-level lookup primitives
 * (lookup_function_fast, hash_name, widen_local, lookup_string,
 * build_func_map, build_local_map) remain in src/backend/wasm/defs.nx
 * because they are also consumed by section.nx, collect.nx, and
 * module_asm.nx.
 */

import { TypeExpr } from "src/common/ast.nx"
import { LirFunction, LirExternal } from "src/ir/lir/types.nx"
import { HashMap }, * as hmap from "std:hashmap"
import { StrMap } from "src/common/strmap.nx"
import { LocalEntry, FuncEntry, StringEntry, ArityTypeIdx,
         lookup_function_fast, hash_name } from "src/backend/wasm/defs.nx"

/** Threaded codegen-time context: every local/func/external map, the active
 *  function's name, stack-switching slots, memo cache, and the bt-capture
 *  import slot. Linear in `internal_func_map`/`external_func_map`/`local_map`
 *  so consumers must thread the carrier.
 */
export type CodegenCtx = CodegenCtx(
  locals: [LocalEntry],
  internal_funcs: [FuncEntry],
  external_funcs: [FuncEntry],
  string_lits: [StringEntry],
  alloc_mode: i64,
  temps_base: i64,
  func_ret_type: TypeExpr,
  functions: [LirFunction],
  externals: [LirExternal],
  closure_table: [FuncEntry],
  closure_type_indices: [ArityTypeIdx],
  internal_func_map: &HashMap,
  external_func_map: &HashMap,
  func_name: string,
  ss_tag_idx: i64,
  ss_cont_type_idx: i64,
  ss_dispatch_block_type_idx: i64,
  ss_tag_names: [string],
  /** O(1) lookup parallel to `ss_tag_names`: `tag_name -> position`. Built
   *  once at program scope from `ss_tag_names` and threaded through codegen.
   */
  ss_tag_idx_map: StrMap<i64>,
  // Wasm function index of the imported `__nx_main_wrap_bt_capture` (a.k.a.
  // `nexus:intrinsic.capture-backtrace`) call target for this function's
  // throw sites, or -1 when capture should be skipped. Set per-function from
  // EffectMap.can_throw: functions whose transitive
  // callees never throw skip the call entirely; functions that may throw
  // receive the program-wide capture import index. -1 also covers the case
  // where the program does not import the capture external at all — which,
  // post the runtime/backtrace -> intrinsic move, is now ALWAYS the case:
  // `capture-backtrace` is filtered out of the import section so the throw-
  // site `call` is elided unconditionally.
  bt_capture_idx: i64,
  // Eligible memoization-target function names paired
  // with their cache slot. Codegen reads this to decide whether emit_call
  // wraps an internal call site in a single-slot last-call cache. The slot
  // address-translates to globals (memo_globals_base + 3*slot + offset).
  memo_target_names: [string],
  memo_target_slots: [i64],
  memo_globals_base: i64,
  import_count: i64,
  // Per-function packed local-name map for O(1) Variable-atom
  // emission. Each value is `(local_index << 32) | valtype`; -1 = absent.
  // Owned at `emit_one_body` scope, borrowed here, freed after each function
  // body finishes (locals don't survive across functions).
  local_map: &HashMap
)

/** Read `temps_base` (the first reserved-temp local index) out of the codegen context. */
export let ctx_temps_base = fn (ctx: CodegenCtx) -> i64 do
  let CodegenCtx(temps_base: t, _) = ctx
  return t
end

/** Read the program's external import list out of the codegen context. */
export let ctx_externals = fn (ctx: CodegenCtx) -> [LirExternal] do
  let CodegenCtx(externals: e, _) = ctx
  return e
end

/** Look up an internal `LirFunction` by name via the per-function index hashmap; `None` if absent. */
export let ctx_lookup_function = fn (ctx: CodegenCtx, name: string) -> Option<LirFunction> do
  let CodegenCtx(functions: fs, internal_func_map: m, import_count: ic, _) = ctx
  return lookup_function_fast(name, funcs: fs, map: &m, import_count: ic)
end

/** O(1) per-Variable-atom lookup over the function's local table.
 *  Returns `(index << 32) | valtype` or -1 when `name` is absent.
 */
export let ctx_lookup_local = fn (ctx: CodegenCtx, name: string) -> i64 do
  let CodegenCtx(local_map: lm, _) = ctx
  return hmap.get_or(map: lm, key: hash_name(name), default: -1)
end
