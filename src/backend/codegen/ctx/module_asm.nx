/**
 * codegen/module_asm: module-assembly helpers for compile_lir_to_wasm.
 *
 * Owns:
 * - FuncEntry list builders for internal / external imports
 * - find_bt_capture_idx (locate __nx_main_wrap_bt_capture import slot)
 * - External deduplication (DedupExtResult, dedup_externals, remaps)
 * - Closure analysis: build_closure_table, collect_closure_arities,
 *   insert_sorted_i64 helper
 * - WASM name custom-section payload (build_name_section)
 * - build_closure_type_idx_list (arity → canonical type index pair list)
 *
 * Does not own:
 * - compile_lir_to_wasm itself — the top-level entry stays in codegen.nx
 *   because it sequences calls into emit_code_bodies / compile_function_body
 *   which live with the recursive emit_expr / emit_stmt chain.
 * - Code-section emission (emit_one_body / emit_code_bodies / compile_*)
 *
 * Functions here are reachable only by the module-assembly path (after
 * all function bodies are compiled). None recurse through emit_expr.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { LirFunction, LirExternal } from "src/ir/lir/types.nx"
import { FuncEntry, ArityTypeIdx }, * as wdefs from "src/backend/wasm/defs.nx"
import { HashMap } from "std:hashmap"
import { Map }, * as map from "std:collection/map"
import { bt_capture_symbol_name } from "src/ir/main_wrap.nx"
import * as list from "std:list"
import * as str from "std:str"
import { CodegenError } from "src/backend/errors.nx"

/** Build `(name, wasm_index)` entries for each user-defined `LirFunction`, with `import_count + idx` as the base index so internal functions live in the wasm index space right after all imports. Returns the entries in source order; the wasm function section then writes the type indices in this same order. */
export let build_internal_func_entries = fn (
  funcs: [ LirFunction ],
  import_count: i64,
  idx: i64
) -> [ FuncEntry ] throws { CodegenError } do
  return build_internal_func_entries_go(funcs, import_count, idx, acc: [])
end
let build_internal_func_entries_go = fn (
  funcs: [ LirFunction ],
  import_count: i64,
  idx: i64,
  acc: [ FuncEntry ]
) -> [ FuncEntry ] throws { CodegenError } do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      return build_internal_func_entries_go(
        funcs: rest,
        import_count,
        idx: idx + 1,
        acc: FuncEntry(name: n, index: import_count + idx) :: acc
      )
  end
end

/** Build `(name, wasm_index)` entries for imported externals starting at `idx`; mirrors `build_internal_func_entries` for the import-section side and is consumed by the same `lookup_func_fast` hash table. */
export let build_external_func_entries = fn (
  exts: [ LirExternal ],
  idx: i64
) -> [ FuncEntry ] throws { CodegenError } do
  return build_external_func_entries_go(exts, idx, acc: [])
end
let build_external_func_entries_go = fn (
  exts: [ LirExternal ],
  idx: i64,
  acc: [ FuncEntry ]
) -> [ FuncEntry ] throws { CodegenError } do
  match exts do
    | [] -> return list.reverse(xs: acc)
    | LirExternal(
      name: n,
      wasm_module: _,
      wasm_name: _,
      params: _,
      ret_type: _,
      throw_row: _
    ) :: rest ->
      return build_external_func_entries_go(
        exts: rest,
        idx: idx + 1,
        acc: FuncEntry(name: n, index: idx) :: acc
      )
  end
end

/** Locate the import slot for the backtrace-capture host function. Returns
 *  -1 when the symbol is absent (e.g. the program has no main_wrap-injected
 *  catch handler). The match is by Nexus-side symbol name so codegen does
 *  not need to know the kebab-cased wasm_name.
 */
export let find_bt_capture_idx = fn (exts: [ LirExternal ]) -> i64 do
  return find_bt_capture_idx_go(exts, idx: 0)
end

let find_bt_capture_idx_go = fn (exts: [ LirExternal ], idx: i64) -> i64 do
  match exts do
    | [] -> return -1
    | LirExternal(name: n, _) :: rest ->
      if n == bt_capture_symbol_name() then return idx end
      return find_bt_capture_idx_go(exts: rest, idx: idx + 1)
  end
end

// Multiple Nexus names can point to the same WASM import (diamond imports).
// Deduplicate by (wasm_module, wasm_name), keeping only the first occurrence.
// Returns deduped ext list + FuncEntry remaps for duplicate names.

/** Result of external-import deduplication: `exts` is the deduped list (one entry per unique `(wasm_module, wasm_name)`) and `remaps` lists `(duplicate_name → keeper's wasm_index)` so call sites that referenced the dropped names still resolve. */
export type DedupExtResult = DedupExtResult(exts: [ LirExternal ], remaps: [ FuncEntry ])

let find_ext_dedup_index = fn (exts: [ LirExternal ], wm: string, wn: string, idx: i64) -> i64 do
  match exts do
    | [] -> return -1
    | LirExternal(
      name: _,
      wasm_module: m,
      wasm_name: n,
      params: _,
      ret_type: _,
      throw_row: _
    ) :: rest ->
      if m == wm && n == wn then return idx end
      return find_ext_dedup_index(exts: rest, wm, wn, idx: idx + 1)
  end
end

/** Collapse diamond imports — multiple Nexus names binding the same `(wasm_module, wasm_name)` pair — into a single import slot, returning a `DedupExtResult` that callers fold into the function map so the wasm module declares each host symbol exactly once. */
export let dedup_externals = fn (exts: [ LirExternal ]) -> DedupExtResult throws { CodegenError } do
  return dedup_externals_go(exts, deduped: [], remaps: [], dedup_idx: 0)
end

let dedup_externals_go = fn (
  exts: [ LirExternal ],
  deduped: [ LirExternal ],
  remaps: [ FuncEntry ],
  dedup_idx: i64
) -> DedupExtResult throws { CodegenError } do
  match exts do
    | [] -> return DedupExtResult(exts: list.reverse(xs: deduped), remaps)
    | e :: rest ->
      let LirExternal(
        name: n,
        wasm_module: wm,
        wasm_name: wn,
        params: _,
        ret_type: _,
        throw_row: _
      ) = e
      let existing = find_ext_dedup_index(exts: list.reverse(xs: deduped), wm, wn, idx: 0)
      if existing >= 0 then
        return dedup_externals_go(
          exts: rest,
          deduped,
          remaps: FuncEntry(name: n, index: existing) :: remaps,
          dedup_idx
        )
      else
        return dedup_externals_go(
          exts: rest,
          deduped: e :: deduped,
          remaps,
          dedup_idx: dedup_idx + 1
        )
      end
  end
end

/** Concatenate two `FuncEntry` lists; small monomorphic helper that avoids dragging `std:list` polymorphism through the import-table assembly hot path. */
export let append_func_entries = fn (a: [ FuncEntry ], b: [ FuncEntry ]) -> [ FuncEntry ] do
  match a do
    | [] -> return b
    | x :: rest -> return x :: append_func_entries(a: rest, b)
  end
end

/** Build closure table entries: maps table index → function index for __closure_* functions. */
export let build_closure_table = fn (
  funcs: [ LirFunction ],
  internal_func_map: &HashMap,
  table_idx: i64
) -> [ FuncEntry ] throws { CodegenError } do
  return build_closure_table_go(funcs, internal_func_map, table_idx, acc: [])
end
let build_closure_table_go = fn (
  funcs: [ LirFunction ],
  internal_func_map: &HashMap,
  table_idx: i64,
  acc: [ FuncEntry ]
) -> [ FuncEntry ] throws { CodegenError } do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      if wdefs.is_closure_func(name: n) then
        let func_idx = wdefs.lookup_func_fast(name: n, map: internal_func_map)
        return build_closure_table_go(
          funcs: rest,
          internal_func_map,
          table_idx: table_idx + 1,
          acc: FuncEntry(name: n, index: func_idx) :: acc
        )
      end
      return build_closure_table_go(funcs: rest, internal_func_map, table_idx, acc)
  end
end

/** Build a `closure_func_name -> table_position` map from a closure table,
 *  built once at program scope for O(1) `lookup_closure_table_idx`. The
 *  position is the 0-based ordinal the prior linear scan would have returned;
 *  first-occurrence wins so the index matches `build_closure_table`'s order. */
export let build_closure_idx_map = fn (entries: [ FuncEntry ]) -> Map<string, i64> do
  return build_closure_idx_map_go(entries, pos: 0, acc: map.string_map())
end

let build_closure_idx_map_go = fn (
  entries: [ FuncEntry ],
  pos: i64,
  acc: Map<string, i64>
) -> Map<string, i64> do
  match entries do
    | [] -> return acc
    | FuncEntry(name: n, index: _) :: rest ->
      let acc2 = match map.get(m: acc, k: n) do
        | Some(_) -> acc
        | None -> map.insert(m: acc, k: n, v: pos)
      end
      return build_closure_idx_map_go(entries: rest, pos: pos + 1, acc: acc2)
  end
end

/** Insert a value into a sorted i64 list, skipping if already present (set
 *  semantics). Ordered insertion is delegated to `list.insert_sorted_by`. */
let insert_sorted_i64 = fn (val: i64, xs: [ i64 ]) -> [ i64 ] do
  if list.contains(xs, val) then
    return xs
  end
  return list.insert_sorted_by(x: val, xs, lt: fn (a: i64, b: i64) -> bool do return a < b end)
end

/** Get distinct closure arities from __closure_* functions.
 *  Arity = param count - 1 (subtract the __env param).
 *  Builds a sorted+deduped list in a single pass. Seeds arity 0 so
 *  `LirExprCallClosure(args: [])` and `LirExprForce` (lazy thunks) always
 *  resolve their `lookup_closure_type_idx_pairs(arity: 0)` lookup, even
 *  when no `__closure_*` wrapper or sched trampoline carries arity 0.
 */
export let collect_closure_arities = fn (funcs: [ LirFunction ]) -> [ i64 ] throws { CodegenError } do
  return collect_closure_arities_acc(funcs, acc: [ 0 ])
end

let collect_closure_arities_acc = fn (
  funcs: [ LirFunction ],
  acc: [ i64 ]
) -> [ i64 ] throws { CodegenError } do
  match funcs do
    | [] -> return acc
    | LirFunction(name: n, params: ps, ret_type: _, body: _, ret: _, span: _) :: rest ->
      // Only `__closure_*` and `__inject_*` carry the canonical
      // (env: i64, arg0..argN-1) -> i64 closure-call signature whose arity
      // must be registered in the type section. The sched trampoline is
      // `() -> ()` and uses a regular call_indirect against the existing
      // arity-0 closure type — its presence in the elem segment for ref.func
      // does not add a new arity entry, but its body forces arity 0 to be
      // present in the type table. A 0-arity closure call also forces arity
      // 0 even when no __closure_* wrapper carries it (e.g. `let f = pure_fn; f()`
      // where pure_fn is a top-level let bound to `fn () -> T`).
      if wdefs.is_sched_trampoline_func(name: n) then
        return collect_closure_arities_acc(funcs: rest, acc: insert_sorted_i64(val: 0, xs: acc))
      end
      if wdefs.is_closure_func(name: n) then
        let arity = list.length(xs: ps) - 1
        return collect_closure_arities_acc(funcs: rest, acc: insert_sorted_i64(val: arity, xs: acc))
      end
      return collect_closure_arities_acc(funcs: rest, acc)
  end
end

/** Build name subsection entries for external (imported) functions */
let emit_external_name_entries = fn (
  buf: %ByteBuffer,
  exts: [ LirExternal ],
  idx: i64
) -> %ByteBuffer throws { CodegenError } do
  match exts do
    | [] -> return %buf
    | LirExternal(
      name: _,
      wasm_module: _,
      wasm_name: wn,
      params: _,
      ret_type: _,
      throw_row: _
    ) :: rest ->
      let %buf = bb.push_uleb128(%buf, val: idx)
      let %buf = wdefs.emit_name(%buf, name: wn)
      return emit_external_name_entries(%buf, exts: rest, idx: idx + 1)
  end
end

/** Build name subsection entries for internal functions */
let emit_internal_name_entries = fn (
  buf: %ByteBuffer,
  funcs: [ LirFunction ],
  idx: i64
) -> %ByteBuffer throws { CodegenError } do
  match funcs do
    | [] -> return %buf
    | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      let %buf = bb.push_uleb128(%buf, val: idx)
      let %buf = wdefs.emit_name(%buf, name: n)
      return emit_internal_name_entries(%buf, funcs: rest, idx: idx + 1)
  end
end

/** Build the WASM name custom section payload (section name + function subsection) */
export let build_name_section = fn (exts: [ LirExternal ], funcs: [ LirFunction ],
                              has_alloc: bool,
                              n_exts: i64, n_alloc_imports: i64,
                              total_funcs: i64) -> %ByteBuffer throws { CodegenError } do
  let %entries = bb.empty()
  let %entries = bb.push_uleb128(buf: %entries, val: total_funcs)
  let %entries = emit_external_name_entries(buf: %entries, exts, idx: 0)
  let %entries = if has_alloc then
    let %entries = bb.push_uleb128(buf: %entries, val: n_exts)
    let %entries = wdefs.emit_name(buf: %entries, name: "allocate")
    let %entries = bb.push_uleb128(buf: %entries, val: n_exts + 1)
    let %entries = wdefs.emit_name(buf: %entries, name: "__nx_alloc_mark")
    let %entries = bb.push_uleb128(buf: %entries, val: n_exts + 2)
    wdefs.emit_name(buf: %entries, name: "__nx_alloc_reset")
  else %entries end
  let internal_start = n_exts + n_alloc_imports
  let %entries = emit_internal_name_entries(buf: %entries, funcs, idx: internal_start)
  let wasi_idx = total_funcs - 1
  let %entries = bb.push_uleb128(buf: %entries, val: wasi_idx)
  let %entries = wdefs.emit_name(buf: %entries, name: "wasi:cli/run@0.2.0#run")

  let entries_len = bb.length(buf: &entries)
  let %subsec = bb.empty()
  let %subsec = bb.push_byte(buf: %subsec, byte: 1)
  let %subsec = bb.push_uleb128(buf: %subsec, val: entries_len)
  let %subsec = bb.push_buf(dst: %subsec, src: &entries)
  bb.free(buf: %entries)

  let %payload = bb.empty()
  let %payload = wdefs.emit_name(buf: %payload, name: "name")
  let %payload = bb.push_buf(dst: %payload, src: &subsec)
  bb.free(buf: %subsec)
  return %payload
end

// Tool-facing `nx.bt.symbols` custom section mapping every internal function's
// wasm idx → fully-qualified Nexus name. Runtime resolution of `bt_frame(idx)`
// does NOT consult this section — the prologue already stores the packed
// (ptr<<32)|len of each can_throw function's name in the page-18 ring buffer.
// The custom section exists so external disassemblers / sourcemap tooling
// can render frame ids back to names without re-parsing the wasm `name`
// custom section. Format:
//
//     u32 count
//     count × ( u32 func_idx | u32 name_len | name_bytes )
//
// All `LirFunction` entries are emitted (not just can_throw ones) so callers
// don't have to re-derive the EffectMap to decode unknown ids.

let push_u32_le = fn (buf: %ByteBuffer, val: i64) -> %ByteBuffer do
  let %buf = bb.push_byte(%buf, byte: val & 255)
  let %buf = bb.push_byte(%buf, byte: (val >> 8) & 255)
  let %buf = bb.push_byte(%buf, byte: (val >> 16) & 255)
  return bb.push_byte(%buf, byte: (val >> 24) & 255)
end

let emit_bt_symbols_entries = fn (
  buf: %ByteBuffer,
  funcs: [ LirFunction ],
  idx: i64
) -> %ByteBuffer do
  match funcs do
    | [] -> return %buf
    | LirFunction(name: n, _) :: rest ->
      let nlen = str.length(s: n)
      let %buf = push_u32_le(%buf, val: idx)
      let %buf = push_u32_le(%buf, val: nlen)
      let %buf = bb.push_string(%buf, s: n)
      return emit_bt_symbols_entries(%buf, funcs: rest, idx: idx + 1)
  end
end

/** Build the `nx.bt.symbols` custom section payload (section name + body). */
export let build_bt_symbols_section = fn (
  funcs: [ LirFunction ],
  import_count: i64
) -> %ByteBuffer do
  let n = list.length(xs: funcs)
  let %body = bb.empty()
  let %body = push_u32_le(buf: %body, val: n)
  let %body = emit_bt_symbols_entries(buf: %body, funcs, idx: import_count)
  let body_len = bb.length(buf: &body)
  let %payload = bb.empty()
  let %payload = wdefs.emit_name(buf: %payload, name: "nx.bt.symbols")
  let %payload = bb.push_buf(dst: %payload, src: &body)
  bb.free(buf: %body)
  body_len
  return %payload
end

/** Zip `arities` with `type_idxs` (parallel lists in matching positional order) into an `[ArityTypeIdx]` pair list so call sites can resolve `arity → canonical closure-call type index` in O(arities) without re-scanning the type section. */
export let build_closure_type_idx_list = fn (
  arities: [ i64 ],
  type_idxs: [ i64 ]
) -> [ ArityTypeIdx ] throws { CodegenError } do
  return build_closure_type_idx_list_go(arities, type_idxs, acc: [])
end
let build_closure_type_idx_list_go = fn (
  arities: [ i64 ],
  type_idxs: [ i64 ],
  acc: [ ArityTypeIdx ]
) -> [ ArityTypeIdx ] throws { CodegenError } do
  match arities do
    | [] -> return list.reverse(xs: acc)
    | a :: rest_a ->
      match type_idxs do
        | [] -> return list.reverse(xs: acc)
        | ti :: rest_ti ->
          return build_closure_type_idx_list_go(arities: rest_a, type_idxs: rest_ti,
            acc: ArityTypeIdx(arity: a, type_idx: ti) :: acc)
      end
  end
end
