end

// ─── Width-cast intrinsics (cast-to-i32 / cast-to-i64) ─────────────────────
// i32_of(x: i64) -> i32  emits  i32.wrap_i64 ; i64_of(x: i32) -> i64  emits  i64.extend_i32_u

export let emit_cast_to_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      return bb.push_byte(%buf, byte: op_i32_wrap_i64)
    | _ ->
      raise SymbolNotFound(name: "__nx_cast_to_i32", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_cast_to_i64 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_cast_to_i64", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

// ─── Lazy / WASI-threads intrinsics (force-closure / thunk-addr / value-of-i64)

/**
`__nx_thunk_addr(t: @T) -> i64` / `__nx_value_of_i64(x: i64) -> T`: both are
pure type puns at the WASM level (every Nexus value is an i64). Emit the
argument atom and nothing else.
*/
export let emit_lazy_passthrough = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ -> return emit_atom(atom: a, %buf, ctx)
    | _ ->
      raise SymbolNotFound(name: "__nx_lazy_passthrough", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

// ─── Backtrace intrinsics (nexus:runtime/backtrace, now nexus:intrinsic) ────
//
// Real function-name call stacks (issue nexus-i6fj V1). Ring buffer at page
// 18 (wdefs.bt_page_base). Layout in defs.nx:
//   offset 0 : i32 current depth (monotonic; wraps at 2^31 — fine for V1)
//   offset 4 : i32 saved depth at last raise (read by __nx_bt_depth)
//   offset 16..16+64*8 : 64-slot i64 ring of packed (ptr<<32)|len name values
//
// Function prologues emit an atomic-rmw-add increment on `depth` and store
// the packed function-name string at `ring[(old_depth) & 63]` (see
// emit_bt_push_prologue below). Only functions whose EffectMap entry has
// can_throw=true are instrumented (V1 keeps wasm-size growth bounded).
// Pops are NOT emitted: WASM EH unwinds frames without their epilogues
// running, so push-only with a 64-slot wrap-around gives the most-recent
// frames at any raise without needing try-catch-rethrow wrapping. The
// trade-off: monotonic depth growth across calls; under deep stacks the
// oldest frames are overwritten. The fixture (f→g→h, depth=4) never wraps.
//
// emit_raise_snapshot copies `depth` → `saved_depth` immediately before each
// op_throw so the raising frame is visible to bt_depth/bt_frame regardless
// of subsequent execution.

/** `__nx_bt_depth() -> i64`: returns the depth saved at the last raise. */
export let emit_bt_depth = fn (buf: %ByteBuffer) -> %ByteBuffer do
  // i32.const bt_page_base; i32.atomic.load offset=bt_saved_depth_offset; i64.extend_i32_u
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: wdefs.bt_page_base)
  let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_load,
                                       offset: wdefs.bt_saved_depth_offset)
  return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
end

/**
`__nx_bt_frame(idx: i64) -> string`: load packed `(ptr<<32)|len` from
ring slot `(idx & 63)`. Returns 0 (empty string) for slots that were
never written. Caller (`backtrace()` in exn.nx) bounds idx by saved_depth.
*/
export let emit_bt_frame = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      // Stack: idx (i64)
      let %buf = emit_atom(atom: a, %buf, ctx)
      // idx -> i32, mask & 63, shift << 3, add ring base, load i64
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 63)
      let %buf = bb.push_byte(%buf, byte: wdefs.op_i32_and)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 3)
      let %buf = bb.push_byte(%buf, byte: wdefs.op_i32_shl)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: wdefs.bt_page_base + wdefs.bt_ring_offset)
      let %buf = bb.push_byte(%buf, byte: wdefs.op_i32_add)
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      return wdefs.emit_memarg_i64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_bt_frame", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

/**
Emit a function-entry prologue that atomically increments `depth` and
stores `packed_name` (packed `(offset<<32)|len` of the function's name in
the string-literal pool) into `ring[old_depth & 63]`. Called from
compile_function_body when EffectMap.can_throw is true (nexus-i6fj V1).

Sequence (~22 bytes per instrumented function):
  i32.const ring_base
  i32.const bt_page_base
  i32.const 1
  i32.atomic.rmw.add offset=bt_depth_offset
  i32.const 63
  i32.and
  i32.const 3
  i32.shl
  i32.add
  i64.const <packed_name>
  i64.store offset=0
*/
export let emit_bt_push_prologue = fn (buf: %ByteBuffer, packed_name: i64) -> %ByteBuffer do
  // Pre-load ring base (will receive computed offset).
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: wdefs.bt_page_base + wdefs.bt_ring_offset)
  // Atomically increment depth, get old value on stack.
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: wdefs.bt_page_base)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 1)
  let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_rmw_add,
                                       offset: wdefs.bt_depth_offset)
  // old_depth & 63, << 3, + ring_base
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 63)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_i32_and)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: 3)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_i32_shl)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_i32_add)
  // Store packed_name at computed slot.
  let %buf = bb.push_byte(%buf, byte: op_i64_const)
  let %buf = bb.push_sleb128(%buf, val: packed_name)
  let %buf = bb.push_byte(%buf, byte: op_i64_store)
  return wdefs.emit_memarg_i64(%buf, offset: 0)
end

/**
Emit a raise-site snapshot: copy `depth` → `saved_depth` so __nx_bt_depth
and __nx_bt_frame surface the call stack as it was when the raise fired.
Called from LirExprRaise emission BEFORE op_throw (nexus-i6fj V1).

Sequence (~14 bytes):
  i32.const bt_page_base
  i32.const bt_page_base
  i32.atomic.load offset=bt_depth_offset
  i32.atomic.store offset=bt_saved_depth_offset
*/
export let emit_bt_raise_snapshot = fn (buf: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: wdefs.bt_page_base)
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: wdefs.bt_page_base)
  let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_load,
                                       offset: wdefs.bt_depth_offset)
  return wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_store,
                                  offset: wdefs.bt_saved_depth_offset)
end

/**
`capture-backtrace(...) -> unit`: legacy host-side stub from when backtraces
required a wasmtime provider. Now folded into emit_bt_raise_snapshot at the
raise site; this emitter exists only because the external lingers in the
import section (filtered out, but referenced symbolically). Drops args and
emits nothing.
*/
export let emit_capture_backtrace = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  return drop_all_args(args, %buf, ctx)
end

let drop_all_args = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | [] -> return %buf
    | LirCallArg(label: _, value: a) :: rest ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_drop)
      return drop_all_args(args: rest, %buf, ctx)
  end
end

// ─── Array intrinsic (__array_get) ──────────────────────────────────────────
// MirIndex (`arr[idx]`) lowers to LirExprCall("__array_get", arr, idx). Arrays
// are heap records `[tag(i64) | e0(i64) | e1(i64) | ...]` (see MirArray in
// src/ir/lir/lir.nx). The array atom is the canonical packed `(ptr<<32) | len`
// form — pointer in the upper 32 bits, length in the lower 32 bits — so the
// host stub `__nx_array_length(ptr: i32, len: i32) -> i64` and any other
// extern receiving `&[| T |]` can read both fields after a single packed-i64
// argument. `__array_get` is never registered as a real wasm import; emit_call
// detects the symbol and inlines a `(ptr + (idx + 1) * 8) -> i64.load`
// sequence below, extracting `ptr` via `(arr_atom >> 32)`.

export let emit_array_get = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: arr_atom) :: LirCallArg(label: _, value: idx_atom) :: _ ->
      let %buf = emit_atom(atom: arr_atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 32)
      let %buf = bb.push_bytes(%buf, bytes: [op_i64_shr_u, op_i32_wrap_i64])
      let %buf = emit_atom(atom: idx_atom, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_i32_const])
      let %buf = bb.push_sleb128(%buf, val: 8)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_mul, op_i32_const])
      let %buf = bb.push_sleb128(%buf, val: 8)
      let %buf = bb.push_byte(%buf, byte: op_i32_add)
      let %buf = bb.push_byte(%buf, byte: op_i32_add)
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      return wdefs.emit_memarg_i64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__array_get", kind: SkIntrinsicArg, context: "expected (arr, idx)")
      return %buf
  end
end

// `__array_set(arr, idx, val)` is the write counterpart to __array_get.
// Layout matches: `(ptr + (idx + 1) * 8) <- i64.store val`. The intrinsic
// returns unit; emit_stmt's LirStmtLet branch detects expr_type == TyUnit
// and leaves the stack untouched (no drop, no local_set), so emit_array_set
// must NOT push any synthetic value — exactly mirroring how a real
// unit-returning host call (e.g. `__nx_heap_reset`) ends.
export let emit_array_set = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: arr_atom) :: LirCallArg(label: _, value: idx_atom) :: LirCallArg(label: _, value: val_atom) :: _ ->
      // Address: ptr (from `arr_atom >> 32`) + ((idx + 1) * 8). A bare
      // i32_wrap_i64 here would give the LEN low half and land writes in
      // the length cell (nexus-tf49); the shift mirrors emit_array_get.
      let %buf = emit_atom(atom: arr_atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 32)
      let %buf = bb.push_bytes(%buf, bytes: [op_i64_shr_u, op_i32_wrap_i64])
      let %buf = emit_atom(atom: idx_atom, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_i32_const])
      let %buf = bb.push_sleb128(%buf, val: 8)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_mul, op_i32_const])
      let %buf = bb.push_sleb128(%buf, val: 8)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_add, op_i32_add])
      let %buf = emit_atom(atom: val_atom, %buf, ctx)
      // i64.store leaves no stack value (matches TyUnit return).
      let %buf = bb.push_byte(%buf, byte: op_i64_store)
      return wdefs.emit_memarg_i64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__array_set", kind: SkIntrinsicArg, context: "expected (arr, idx, val)")
      return %buf
  end
end

// `array-length(arr: &[| T |]) -> i64` — the `nexus:intrinsic` op behind the
// `__nx_array_length` FFI name (kebab-cased). Array atoms are the canonical
// packed `(ptr<<32) | len` i64, so the count is the low 32 bits: emit the
// atom, then `i64.const 0xFFFFFFFF`, then `i64.and`. Mirrors how
// `emit_array_get` recovers the pointer via `arr >> 32`.
export let emit_array_length = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: arr_atom) :: _ ->
      let %buf = emit_atom(atom: arr_atom, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 4294967295)
      return bb.push_byte(%buf, byte: op_i64_and)
    | _ ->
      raise SymbolNotFound(name: "array-length", kind: SkIntrinsicArg, context: "expected (arr)")
      return %buf
  end
end

// ─── Math intrinsics (f64-sqrt / f64-floor / f64-ceil / f64-abs) ────────────
// Inline-emit f64 unary ops. Each takes a single `val: float` and pushes the
// f64 result; no coercion needed since the FFI types are already f64.

export let emit_f64_unary = fn (opcode: i64, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx, name: string) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      return bb.push_byte(%buf, byte: opcode)
    | _ ->
      raise SymbolNotFound(name, kind: SkIntrinsicArg, context: "f64 unary requires one argument")
      return %buf
  end
end

// ─── SIMD intrinsics (simd-f32x4-add / simd-...-array / ...) ────────────────
// 128-bit fixed-width SIMD primitives — `simd-{lane}x{count}-{op}` for the
// f32x4 / f64x2 / i32x4 / i64x2 lane shapes and add / mul lane-wise ops, plus
// `simd-f32x4-add-array` which expands to a SIMD loop over a contiguous
// quad-aligned region (the autovectorized form of an element-wise scalar
// `dst[i] = a[i] + b[i]` loop).
//
// Argument policy: addresses are i64 across the FFI boundary, truncating to
// i32 for wasm load/store. Lane width is implicit in the wasm_name. A v128
// never escapes a single intrinsic emission — load → op → store stays inside
// one instruction sequence so v128 never becomes a Nexus-visible local type
// (which would require widening type_to_valtype across the compiler).
//
// Verified opcodes (see wasm/defs.nx for the full table):
//   v128.load (sub 0x00) / v128.store (sub 0x0B): memarg align=4 offset=0
//   {i32x4,i64x2,f32x4,f64x2}.add / .mul: no further operand bytes
//
// SIMD extension is part of the WebAssembly 2.0 baseline and is enabled by
// default in wasmtime 13+; bootstrap.sh's launch flags inherit that default
// (no explicit -W simd toggle is required).

/** Emit a single v128 lane-wise binary op: load 16 bytes from each input
 *  address, run the lane-op, store 16 bytes to dst. Address args are in
 *  LirCallArg order `(a_addr, b_addr, dst_addr)`. Caller passes the SIMD
 *  sub-opcode (e.g. `op_simd_f32x4_add`) for the lane operation.
 */
export let emit_simd_binop_one = fn (sub_op: i64, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx, name: string) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: b) :: LirCallArg(label: _, value: d) :: _ ->
      // dst_addr is pushed first so the final store sees its base below v128.
      let %buf = emit_addr_arg(atom: d, %buf, ctx)
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_load)
      let %buf = wdefs.emit_memarg_v128(%buf, offset: 0)
      let %buf = emit_addr_arg(atom: b, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_load)
      let %buf = wdefs.emit_memarg_v128(%buf, offset: 0)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: sub_op)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_store)
      return wdefs.emit_memarg_v128(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name, kind: SkIntrinsicArg, context: "simd lane binop requires (a_addr, b_addr, dst_addr)")
      return %buf
  end
end

/** Emit an autovectorized SIMD loop: for each of `n` quads (16-byte chunks),
 *  load v128 from a, load v128 from b, lane-op, v128.store to dst, advance
 *  each pointer by 16. This is the autovectorized form of:
 *  for i in 0..(n*4): dst[i] = a[i] + b[i]   (when sub_op = f32x4.add)
 *
 *  Arg policy: `(a_addr: i64, b_addr: i64, dst_addr: i64, n_quads: i64)`.
 *  Local-slot layout (drawn from the reserved-temps range that
 *  section.nx::emit_local_decls declares — 2x i64, 2x i32, 2x i64, 7x i32,
 *  then the tcmc pair):
 *  counter at temps_base+0   (i64 slot — quad-remaining countdown)
 *  a_ptr   at temps_base+2   (i32 slot — wasm address)
 *  b_ptr   at temps_base+3   (i32 slot — wasm address; also used by
 *  emit_alloc_object as obj_ptr, but that helper
 *  sets+uses+is-done before any caller, so the
 *  slot is dead when the SIMD intrinsic body runs)
 *  d_ptr   at temps_base+6   (i32 slot — wasm address; shared with the
 *  throw-path retptr which is similarly dead)
 *  Mismatched-type local.set/get would fail wasm validation; the slot
 *  assignments above honour the reserved-type bands.
 *
 *  Loop shape (mirrors emit_memcpy_loop in codegen/atom.nx):
 *  block
 *  loop
 *  local.get counter ; i64.eqz ; br_if 1   ; exit when 0
 *  <SIMD body: load a_ptr; load b_ptr; lane-op; store d_ptr>
 *  a_ptr += 16; b_ptr += 16; d_ptr += 16
 *  counter -= 1
 *  br 0
 *  end
 *  end
 */
export let emit_simd_binop_array = fn (sub_op: i64, args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx, name: string) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: b) :: LirCallArg(label: _, value: d) :: LirCallArg(label: _, value: n) :: _ ->
      let temps = wdefs.ctx_temps_base(ctx)
      let counter = temps        // i64 slot
      let a_ptr = temps + 2      // i32 slot
      let b_ptr = temps + 3      // i32 slot
      let d_ptr = temps + 6      // i32 slot
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: a_ptr)
      let %buf = emit_addr_arg(atom: b, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: b_ptr)
      let %buf = emit_addr_arg(atom: d, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: d_ptr)
      let %buf = emit_atom(atom: n, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_local_set)
      let %buf = bb.push_uleb128(%buf, val: counter)
      let %buf = bb.push_bytes(%buf, bytes: [op_block, bt_void, op_loop, bt_void])
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: counter)
      let %buf = bb.push_byte(%buf, byte: 80)   // i64.eqz
      let %buf = bb.push_byte(%buf, byte: op_br_if)
      let %buf = bb.push_uleb128(%buf, val: 1)
      // dst pointer first so the store's base sits below v128 on the stack.
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: d_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: a_ptr)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_load)
      let %buf = wdefs.emit_memarg_v128(%buf, offset: 0)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: b_ptr)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_load)
      let %buf = wdefs.emit_memarg_v128(%buf, offset: 0)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: sub_op)
      let %buf = bb.push_byte(%buf, byte: op_simd_prefix)
      let %buf = bb.push_uleb128(%buf, val: op_simd_v128_store)
      let %buf = wdefs.emit_memarg_v128(%buf, offset: 0)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: a_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 16)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_add, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: a_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: b_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 16)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_add, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: b_ptr)
      // d_ptr += 16
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: d_ptr)
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: 16)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_add, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: d_ptr)
      // counter -= 1
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: counter)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 1)
      let %buf = bb.push_bytes(%buf, bytes: [op_i64_sub, op_local_set])
      let %buf = bb.push_uleb128(%buf, val: counter)
      // br 0 (loop back)
      let %buf = bb.push_byte(%buf, byte: op_br)
      let %buf = bb.push_uleb128(%buf, val: 0)
      // end loop ; end block
      let %buf = bb.push_bytes(%buf, bytes: [op_end, op_end])
      return %buf
    | _ ->
      raise SymbolNotFound(name, kind: SkIntrinsicArg, context: "simd array binop requires (a_addr, b_addr, dst_addr, n_quads)")
      return %buf
  end
end

// ─── Intrinsic dispatch tag (nexus-8jnq.2) ──────────────────────────────────
// One variant per `nexus:intrinsic` wasm_name handled by `emit_intrinsic`
// (codegen.nx). `parse_intrinsic` is the single point that converts the raw
// kebab-cased wasm_name string into a tagged `Intrinsic`; the dispatcher then
// pattern-matches exhaustively, so a missing arm is a compile error rather
// than a "no such intrinsic" runtime trap. The wire side stays as strings
// (LirExternal.wasm_name); only the dispatch layer is typed.
export type Intrinsic =
    HeapMark
  | HeapReset
  | HeapSwap
  | AllocRaw
  | MemLoadI32
  | MemStoreI32
  | MemLoadU8
  | MemStoreU8
  | MemLoadI64
  | MemStoreI64
  | MemLoadF32
  | MemStoreF32
  | MemLoadF64
  | MemStoreF64
  | MemSize
  | MemGrow
  | AtomicRmwAddI32
  | AtomicLoadI32
  | AtomicStoreI32
  | AtomicCmpxchgI32
  | AtomicWait32
  | AtomicNotify
  | CastToI32
  | CastToI64
  | ForceClosure
  | ThunkAddr
  | ValueOfI64
  | ArrayLength
  | F64Sqrt
  | F64Floor
  | F64Ceil
  | F64Abs
  | SimdF32x4Add
  | SimdF32x4Mul
  | SimdF64x2Add
  | SimdF64x2Mul
  | SimdI32x4Add
  | SimdI32x4Mul
  | SimdI64x2Add
  | SimdI64x2Mul
  | SimdF32x4AddArray
  | SimdF64x2AddArray
  | SimdI32x4AddArray
  | SimdI64x2AddArray
  | SimdF32x4MulArray
  | SimdF64x2MulArray
  | SimdI32x4MulArray
  | SimdI64x2MulArray
  | SimdF32x4SubArray
  | SimdF64x2SubArray
  | SimdI32x4SubArray
  | SimdI64x2SubArray
  | SimdF32x4DivArray
  | SimdF64x2DivArray
  | BtDepth
  | BtFrame
  | CaptureBacktrace
  | UnknownIntrinsic(name: string)

/** Convert a kebab-cased `nexus:intrinsic` wasm_name (e.g. `"heap-mark"`,
 *  `"simd-f32x4-add-array"`) to its `Intrinsic` tag. Unknown names land in
 *  `UnknownIntrinsic(name)` and surface as the same `SymbolNotFound` error
 *  the old string-chain dispatch produced — no fatal parse error here.
 */
export let parse_intrinsic = fn (s: string) -> Intrinsic do
  if s == "heap-mark" then return HeapMark
  else if s == "heap-reset" then return HeapReset
  else if s == "heap-swap" then return HeapSwap
  else if s == "alloc-raw" then return AllocRaw
  else if s == "mem-load-i32" then return MemLoadI32
  else if s == "mem-store-i32" then return MemStoreI32
  else if s == "mem-load-u8" then return MemLoadU8
  else if s == "mem-store-u8" then return MemStoreU8
  else if s == "mem-load-i64" then return MemLoadI64
  else if s == "mem-store-i64" then return MemStoreI64
  else if s == "mem-load-f32" then return MemLoadF32
  else if s == "mem-store-f32" then return MemStoreF32
  else if s == "mem-load-f64" then return MemLoadF64
  else if s == "mem-store-f64" then return MemStoreF64
  else if s == "mem-size" then return MemSize
  else if s == "mem-grow" then return MemGrow
  else if s == "atomic-rmw-add-i32" then return AtomicRmwAddI32
  else if s == "atomic-load-i32" then return AtomicLoadI32
  else if s == "atomic-store-i32" then return AtomicStoreI32
  else if s == "atomic-cmpxchg-i32" then return AtomicCmpxchgI32
  else if s == "atomic-wait32" then return AtomicWait32
  else if s == "atomic-notify" then return AtomicNotify
  else if s == "cast-to-i32" then return CastToI32
  else if s == "cast-to-i64" then return CastToI64
  else if s == "force-closure" then return ForceClosure
  else if s == "thunk-addr" then return ThunkAddr
  else if s == "value-of-i64" then return ValueOfI64
  else if s == "array-length" then return ArrayLength
  else if s == "f64-sqrt" then return F64Sqrt
  else if s == "f64-floor" then return F64Floor
  else if s == "f64-ceil" then return F64Ceil
  else if s == "f64-abs" then return F64Abs
  else if s == "simd-f32x4-add" then return SimdF32x4Add
  else if s == "simd-f32x4-mul" then return SimdF32x4Mul
  else if s == "simd-f64x2-add" then return SimdF64x2Add
  else if s == "simd-f64x2-mul" then return SimdF64x2Mul
  else if s == "simd-i32x4-add" then return SimdI32x4Add
  else if s == "simd-i32x4-mul" then return SimdI32x4Mul
  else if s == "simd-i64x2-add" then return SimdI64x2Add
  else if s == "simd-i64x2-mul" then return SimdI64x2Mul
  else if s == "simd-f32x4-add-array" then return SimdF32x4AddArray
  else if s == "simd-f64x2-add-array" then return SimdF64x2AddArray
  else if s == "simd-i32x4-add-array" then return SimdI32x4AddArray
  else if s == "simd-i64x2-add-array" then return SimdI64x2AddArray
  else if s == "simd-f32x4-mul-array" then return SimdF32x4MulArray
  else if s == "simd-f64x2-mul-array" then return SimdF64x2MulArray
  else if s == "simd-i32x4-mul-array" then return SimdI32x4MulArray
  else if s == "simd-i64x2-mul-array" then return SimdI64x2MulArray
  else if s == "simd-f32x4-sub-array" then return SimdF32x4SubArray
  else if s == "simd-f64x2-sub-array" then return SimdF64x2SubArray
  else if s == "simd-i32x4-sub-array" then return SimdI32x4SubArray
  else if s == "simd-i64x2-sub-array" then return SimdI64x2SubArray
  else if s == "simd-f32x4-div-array" then return SimdF32x4DivArray
  else if s == "simd-f64x2-div-array" then return SimdF64x2DivArray
  else if s == "bt-depth" then return BtDepth
  else if s == "bt-frame" then return BtFrame
  else if s == "capture-backtrace" then return CaptureBacktrace
  else return UnknownIntrinsic(name: s)
  end
end
