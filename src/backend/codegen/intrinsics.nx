/**
 * codegen/intrinsics: inline-emitted compiler intrinsics.
 *
 * Owns:
 * - Memo target list extractors (extract_memo_names / extract_memo_slots),
 *   the parallel-list form used by CodegenCtx
 * - `is_intrinsic_external` / `get_intrinsic_wasm_name` (recognition + dispatch
 *   key for the `nexus:intrinsic` namespace) + `filter_intrinsic_externals`
 *   (the import-section elision filter)
 * - `is_closure_lift` name classifier
 * - `wasi_thread_start_export` (locates the optional `wasi_thread_start`
 *   internal for the export section)
 * - `nexus:intrinsic` op emitters: bump-allocator (mark / reset / swap /
 *   alloc-raw), raw memory load/store (mem-load-* / mem-store-* / mem-size /
 *   mem-grow), atomics (rmw-add-i32 / load-i32 / store-i32 / cmpxchg-i32 /
 *   wait32 / notify), width casts (cast-to-i32 / cast-to-i64), lazy passthrough
 *   (thunk-addr / value-of-i64), backtrace stubs (bt-depth / bt-frame /
 *   capture-backtrace), array intrinsics (__array_get / __array_set /
 *   array-length), f64 unary math (sqrt / floor / ceil / abs), SIMD lane
 *   binops (one-shot + autovectorized array form)
 * - `nexus:runtime/sched` inline intrinsics (sched-set-next, sched-spawn)
 *   and the predicates / lookups that support them
 *
 * Does not own:
 * - `emit_intrinsic` dispatcher itself — stays in codegen.nx because the
 *   `force-closure` arm needs `lookup_closure_type_idx_pairs` from the
 *   closure-helpers band, which is interleaved with the emit_expr chain
 * - `emit_force_closure` — same reason; lives next to the closure helpers
 * - Memo-cache target planning (see src/backend/memo_plan.nx)
 * - Atom emission (see codegen/atom.nx)
 *
 * Every emitter here is reachable from emit_intrinsic / emit_call (codegen.nx)
 * by a name match against the LirExternal wasm_name; none recurse through
 * emit_expr.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { LirFunction, LirExternal, LirCallArg, LirAtom } from "src/ir/lir/types.nx"
import { CodegenCtx, ExportNameIdx,
         heap_global_idx,
         op_call,
         op_ref_func, op_cont_new, op_table_set,
         op_local_get, op_local_set, op_local_tee, op_global_get, op_global_set,
         op_i32_load, op_i64_load, op_f32_load, op_f64_load, op_i32_load8_u,
         op_i32_store, op_i64_store, op_f32_store, op_f64_store, op_i32_store8,
         op_i32_const, op_i64_const,
         op_i32_add, op_i32_mul,
         op_i64_add, op_i64_sub, op_i64_and,
         op_i64_or, op_i64_shl, op_i64_shr_u,
         op_i32_wrap_i64, op_i64_extend_i32_s, op_i64_extend_i32_u,
         op_f64_promote_f32, op_f32_demote_f64,
         op_memory_size, op_memory_grow,
         op_simd_prefix,
         op_simd_v128_load, op_simd_v128_store,
         op_block, op_loop, op_br, op_br_if, op_end, op_drop,
         bt_void }, * as wdefs from "src/backend/wasm/defs.nx"
import { emit_atom, emit_atomic_bump } from "src/backend/codegen/atom.nx"
import { HashMap } from "std:hashmap"
import { MemoTarget } from "src/backend/codegen/memo.nx"
import { Some, None } from "std:option"
import * as str from "std:str"
import { SymbolNotFound, CodegenError, SkIntrinsic, SkIntrinsicArg } from "src/common/error.nx"

// ─── Memo target list extractors (nexus-e6uh) ──────────────────────────────
// CodegenCtx stores name/slot lists in parallel rather than the structured
// MemoTarget type so the per-call lookup stays a tight string compare without
// re-deconstructing a record on every call site. These extractors split the
// MemoTarget list once at module-assembly time.

export let extract_memo_names = fn (targets: [MemoTarget], acc: [string]) -> [string] do
  match targets do
    | [] -> return reverse_str_list(lst: acc, out: [])
    | MemoTarget(name: n, slot: _) :: rest ->
      return extract_memo_names(targets: rest, acc: n :: acc)
  end
end

export let extract_memo_slots = fn (targets: [MemoTarget], acc: [i64]) -> [i64] do
  match targets do
    | [] -> return reverse_i64_list(lst: acc, out: [])
    | MemoTarget(name: _, slot: s) :: rest ->
      return extract_memo_slots(targets: rest, acc: s :: acc)
  end
end

let reverse_str_list = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_str_list(lst: rest, out: x :: out)
  end
end

let reverse_i64_list = fn (lst: [i64], out: [i64]) -> [i64] do
  match lst do
    | [] -> return out
    | x :: rest -> return reverse_i64_list(lst: rest, out: x :: out)
  end
end

// ─── Inline-emitted runtime intrinsics ──────────────────────────────────────
// All compiler intrinsics — raw memory load/store, atomic ops, f64 ops, integer
// width casts, SIMD lane ops, the bump allocator's mark/reset/swap/alloc-raw,
// and the lazy `@`-thunk type-puns — live under one wasm-module name,
// `nexus:intrinsic` (declared by the stdlib's intrinsic decl files via
// `import external "nexus:intrinsic"`). Their externals are emitted as inline
// WASM (load/store, f64 unary, etc.), never as host calls, and are filtered out
// of the import section entirely (`filter_intrinsic_externals`). Recognition,
// the import-filter test, and codegen dispatch all key on the `wasm_name`
// string (the kebab-cased FFI name, e.g. `mem-load-i32`, `heap-mark`,
// `f64-sqrt`, `force-closure`).
export let is_intrinsic_external = fn (ext: LirExternal) -> bool do
  match ext do
    | LirExternal(name: _, wasm_module: m, wasm_name: _, params: _, ret_type: _, throw_row: _) ->
      return m == "nexus:intrinsic"
  end
end

/** Returns the `wasm_name` of `func` if it resolves to a `nexus:intrinsic`
 *  external, `""` otherwise. The returned string is the dispatch key consumed
 *  by `emit_intrinsic` (e.g. `"mem-load-i32"`, `"heap-mark"`, `"f64-sqrt"`,
 *  `"force-closure"`).
 */
export let get_intrinsic_wasm_name = fn (func: string, exts: [LirExternal]) -> string do
  match wdefs.lookup_external(name: func, exts) do
    | None -> ""
    | Some(val: ext) ->
      if !is_intrinsic_external(ext) then return "" end
      match ext do
        | LirExternal(name: _, wasm_module: _, wasm_name: wn, params: _, ret_type: _, throw_row: _) -> wn
      end
  end
end

/** True when name corresponds to a lifted lambda (`__closure_N`). Matches both
 *  the bare form and the canonical-path form (`<sanitized-path>#__closure_N`)
 *  because `lift_lambda` (mir.nx) names lambdas `__closure_N` but downstream
 *  passes may prepend the source-file path to disambiguate cross-module
 *  imports. Distinct from `is_closure_func`, which also matches inject bodies
 *  and the sched trampoline — those need a function-table elem entry for
 *  ref.func but follow their own (non-canonical-closure) signature.
 */
export let is_closure_lift = fn (name: string) -> bool do
  let nlen = str.length(s: name)
  let bare = "__closure_"
  let blen = str.length(s: bare)
  if nlen >= blen then
    if str.substring(s: name, start: 0, len: blen) == bare then return true end
  end
  let infix = "#__closure_"
  let ilen = str.length(s: infix)
  return nlen >= ilen && str.contains(s: name, sub: infix)
end

/** `__nx_sched_set_next(k)` is a compiler intrinsic that compiles to inline
 *  `global.set ss_resume_slot_global_idx`. Routing it through a host call
 *  trips wasmtime's CallThreadState chain when invoked inside a continuation
 *  arm body (after suspend, before resume); inline emission sidesteps the
 *  host-side trap-handler bookkeeping entirely.
 */
export let is_sched_set_next = fn (func: string, exts: [LirExternal]) -> bool do
  match wdefs.lookup_external(name: func, exts) do
    | None -> false
    | Some(val: LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _)) ->
      return m == "nexus:runtime/sched" && wn == "sched-set-next"
  end
end

export let emit_sched_set_next = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_global_set)
      return bb.push_uleb128(%buf, val: wdefs.ss_resume_slot_global_idx)
    | _ ->
      raise SymbolNotFound(name: "__nx_sched_set_next", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

/** `__nx_sched_spawn(thunk)` is a compiler intrinsic that turns a `@unit` thunk
 *  into a fresh fiber: pushes the thunk onto the host's pending-thunk FIFO,
 *  allocates a new cont_table slot, cont.new's the trampoline body for that
 *  slot, and enqueues the slot in the run queue. The spawned fiber actually
 *  starts running when the dispatcher dequeues the slot, resumes the cont,
 *  and the trampoline pops the matching thunk and forces it.
 */
export let is_sched_spawn = fn (func: string, exts: [LirExternal]) -> bool do
  match wdefs.lookup_external(name: func, exts) do
    | None -> false
    | Some(val: LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _)) ->
      return m == "nexus:runtime/sched" && wn == "sched-spawn"
  end
end

/** Look up a function by suffix match (-1 if absent). Used to locate the sched
 *  trampoline regardless of which package path (nxlib/stdlib/sched.nx vs an
 *  alias) the stdlib was imported from. Hot-ish (per intrinsic emission) so
 *  the -1 sentinel form is used per rule 1 of the error-contract in
 *  src/common/error.nx.
 */
let find_func_idx_by_suffix = fn (suffix: string, funcs: [LirFunction], internal_func_map: &HashMap) -> i64 do
  match funcs do
    | [] -> return -1
    | LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) :: rest ->
      let slen = str.length(s: n)
      let suflen = str.length(s: suffix)
      if slen >= suflen then
        if str.substring(s: n, start: slen - suflen, len: suflen) == suffix then
          return wdefs.lookup_func_fast(name: n, map: internal_func_map)
        end
      end
      return find_func_idx_by_suffix(suffix, funcs: rest, internal_func_map)
  end
end

/** Find a function index by source-qualified `#name` suffix match (mirrors */
/**
If the program defines `wasi_thread_start` (pulled in via `std:lazy` /
`std:lazy_host`), it must be exported under exactly that name so wasi-threads
workers can find it; its `(i32, i32) -> ()` signature is produced by the
`lazy.nx` source. Returns a singleton `[ExportNameIdx]` or `[]`.
*/
export let wasi_thread_start_export = fn (funcs: [LirFunction], internal_func_map: &HashMap) -> [ExportNameIdx] throws { CodegenError } do
  let bare = wdefs.lookup_func_fast(name: "wasi_thread_start", map: internal_func_map)
  let idx = if bare >= 0 then bare else find_func_idx_by_suffix(suffix: "#wasi_thread_start", funcs, internal_func_map) end
  if idx < 0 then return [] end
  return [ExportNameIdx(name: "wasi_thread_start", index: idx)]
end

/** Find the import index for a sched runtime function by its wasm_name. Uses
 *  linear scan over the externals list because hash lookup by Nexus FFI name
 *  is fragile when several `nexus:runtime/sched` imports share a prefix.
 *  Skips arena and intrinsic-sched externals to mirror `filter_intrinsic_externals`
 *  — those entries are inlined and thus excluded from the wasm import section,
 *  so they do not occupy index slots in the codegen's pre-merge function space.
 */
export let find_sched_import_idx = fn (wn: string, exts: [LirExternal], idx: i64) -> i64 throws { CodegenError } do
  match exts do
    | [] -> return -1
    | e :: rest ->
      if is_intrinsic_external(ext: e) || is_intrinsic_sched_external(ext: e) then
        return find_sched_import_idx(wn, exts: rest, idx)
      end
      match e do | LirExternal(name: _, wasm_module: m, wasm_name: w, params: _, ret_type: _, throw_row: _) ->
        if m == "nexus:runtime/sched" && w == wn then return idx end
        return find_sched_import_idx(wn, exts: rest, idx: idx + 1)
      end
  end
end

export let emit_sched_spawn = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let CodegenCtx(functions: fns, internal_func_map: ifm, ss_cont_type_idx: cti, _) = ctx
      let exts = wdefs.ctx_externals(ctx)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let push_idx = find_sched_import_idx(wn: "sched-push-pending", exts, idx: 0)
      if push_idx < 0 then
        raise SymbolNotFound(name: "sched-push-pending", kind: SkIntrinsic, context: "spawn requires push_pending external")
      end
      let %buf = bb.push_byte(%buf, byte: op_call)
      let %buf = bb.push_uleb128(%buf, val: push_idx)

      // slot = next_alloc + 1 to skip the cont slot the surrounding
      // InjectResume dispatcher just claimed for its own arm-call bookkeeping;
      // next_alloc = slot + 1 so the dispatcher's post-arm `++` advances to a
      // fresh free slot instead of overwriting our trampoline cont.
      let slot_local = wdefs.ctx_temps_base(ctx) + 4
      let %buf = bb.push_byte(%buf, byte: op_global_get)
      let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 1)
      let %buf = bb.push_bytes(%buf, bytes: [op_i64_add, op_local_tee])
      let %buf = bb.push_uleb128(%buf, val: slot_local)
      let %buf = bb.push_byte(%buf, byte: op_i64_const)
      let %buf = bb.push_sleb128(%buf, val: 1)
      let %buf = bb.push_bytes(%buf, bytes: [op_i64_add, op_global_set])
      let %buf = bb.push_uleb128(%buf, val: wdefs.ss_next_alloc_global_idx)

      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: slot_local)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let tramp_idx = find_func_idx_by_suffix(
        suffix: "__nx_sched_trampoline_body",
        funcs: fns,
        internal_func_map: &ifm)
      if tramp_idx < 0 then
        raise SymbolNotFound(name: "__nx_sched_trampoline_body", kind: SkIntrinsic, context: "spawn requires sched.nx import")
      end
      let %buf = bb.push_byte(%buf, byte: op_ref_func)
      let %buf = bb.push_uleb128(%buf, val: tramp_idx)
      let %buf = bb.push_byte(%buf, byte: op_cont_new)
      let %buf = bb.push_uleb128(%buf, val: cti)
      let %buf = bb.push_byte(%buf, byte: op_table_set)
      let %buf = bb.push_uleb128(%buf, val: wdefs.ss_cont_table_idx)

      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: slot_local)
      let enqueue_idx = find_sched_import_idx(wn: "sched-enqueue", exts, idx: 0)
      if enqueue_idx < 0 then
        raise SymbolNotFound(name: "sched-enqueue", kind: SkIntrinsic, context: "spawn requires enqueue external")
      end
      let %buf = bb.push_byte(%buf, byte: op_call)
      let %buf = bb.push_uleb128(%buf, val: enqueue_idx)
      return %buf
    | _ ->
      raise SymbolNotFound(name: "__nx_sched_spawn", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let filter_intrinsic_externals = fn (exts: [LirExternal]) -> [LirExternal] do
  match exts do
    | [] -> return []
    | e :: rest ->
      if is_intrinsic_external(ext: e) || is_intrinsic_sched_external(ext: e) then
        return filter_intrinsic_externals(exts: rest)
      else
        return e :: filter_intrinsic_externals(exts: rest)
      end
  end
end

/** True if this `nexus:runtime/sched` external is fulfilled inline by a
 *  compiler intrinsic, so the import entry must be elided from the final
 *  import section. `sched-set-next` and `sched-spawn` qualify; the others
 *  (enqueue, dequeue, push/pop_pending, queue-size) still go through the
 *  host linker.
 */
export let is_intrinsic_sched_external = fn (ext: LirExternal) -> bool do
  match ext do
    | LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _) ->
      if m != "nexus:runtime/sched" then return false end
      return wn == "sched-set-next" || wn == "sched-spawn"
  end
end

/** Emit inline WASM for the bump-allocator (arena) intrinsics.
 *
 *  Since the allocator is now a single atomic bump pointer at linear-memory
 *  cell `wdefs.heap_ptr_cell`, a region "mark" *is* the bump-pointer value:
 *  `heap_mark` reads the cell, `heap_reset` stores a previous value back,
 *  and `heap_swap` does both (returning the old). All three operate
 *  atomically; everything that allocates bumps the same cell, so a reset
 *  reclaims it all at once.
 */
export let emit_heap_mark = fn (buf: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(%buf, byte: op_i32_const)
  let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
  let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_load, offset: 0)
  return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
end

export let emit_heap_reset = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      return wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_store, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_heap_reset", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_heap_swap = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = bb.push_byte(%buf, byte: op_i32_const)
      let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_load, offset: 0)
      let %buf = bb.push_bytes(%buf, bytes: [op_i64_extend_i32_u, op_i32_const])
      let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      return wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_store, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_heap_swap", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

/** `alloc-raw : (size: i64) -> i64` — raw byte allocation
 *  off the unified atomic bump cell. Used by stdlib runtime impls. Emits:
 *  wrap the i64 size to i32, atomic-bump (rounds up to 8, grows memory),
 *  zero-extend the resulting i32 base pointer back to i64.
 */
export let emit_alloc_raw = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let obj_ptr = wdefs.ctx_temps_base(ctx) + 3
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = emit_atomic_bump(%buf, ctx, ptr_local: obj_ptr)
      let %buf = bb.push_byte(%buf, byte: op_local_get)
      let %buf = bb.push_uleb128(%buf, val: obj_ptr)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_alloc_raw", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

// ─── Memory intrinsics (mem-load-* / mem-store-* / mem-size / mem-grow) ─────
// Inline-emit raw load/store and memory.size/grow ops. Argument policy
// (kebab-canonical, all i64 across the FFI boundary):
//   mem-load-i32(addr)        : i32.wrap addr → i32.load{align=2,offset=0} → i64.extend_i32_s
//   mem-store-i32(addr, val)  : i32.wrap addr; i32.wrap val; i32.store{align=2,offset=0}
//   mem-load-u8(addr)         : i32.wrap addr → i32.load8_u{align=0,offset=0} → i64.extend_i32_u
//   mem-store-u8(addr, val)   : i32.wrap addr; i32.wrap val; i32.store8{align=0,offset=0}
//   mem-load-i64(addr)        : i32.wrap addr → i64.load{align=3,offset=0}
//   mem-store-i64(addr, val)  : i32.wrap addr; val (already i64); i64.store{align=3,offset=0}
//   mem-size()                : memory.size(mem 0) → i64.extend_i32_u   (returns pages)
//   mem-grow(delta)           : i32.wrap delta → memory.grow(mem 0) → i64.extend_i32_s
//                               (sign-extend so the wasm `-1` failure sentinel surfaces as `-1`)

let emit_addr_arg = fn (atom: LirAtom, buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  let %buf = emit_atom(atom, %buf, ctx)
  return bb.push_byte(%buf, byte: op_i32_wrap_i64)
end

export let emit_mem_load_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_load)
      let %buf = wdefs.emit_memarg_i32(%buf, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_s)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_load_i32", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_mem_store_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_i32_store])
      return wdefs.emit_memarg_i32(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_store_i32", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_mem_load_u8 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_load8_u)
      let %buf = wdefs.emit_memarg_i8(%buf)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_load_u8", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_mem_store_u8 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_i32_store8])
      return wdefs.emit_memarg_i8(%buf)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_store_u8", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_mem_load_i64 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i64_load)
      return wdefs.emit_memarg_i64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_load_i64", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_mem_store_i64 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i64_store)
      return wdefs.emit_memarg_i64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_store_i64", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

// f32 / f64 mem ops (nexus-ybda). Float values cross the FFI as Nexus `float`
// (= wasm f64), so load_f32 promotes (f32 -> f64) on read and store_f32
// demotes (f64 -> f32) on write. Roundtrip is bitwise-stable as long as the
// stored value is exactly representable in f32 (which holds when the value
// originally came from a load_f32 or an f32 SIMD lane).
export let emit_mem_load_f32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_f32_load)
      let %buf = wdefs.emit_memarg_f32(%buf, offset: 0)
      return bb.push_byte(%buf, byte: op_f64_promote_f32)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_load_f32", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_mem_store_f32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_f32_demote_f64, op_f32_store])
      return wdefs.emit_memarg_f32(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_store_f32", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_mem_load_f64 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_f64_load)
      return wdefs.emit_memarg_f64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_load_f64", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_mem_store_f64 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_f64_store)
      return wdefs.emit_memarg_f64(%buf, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_store_f64", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_mem_size = fn (buf: %ByteBuffer) -> %ByteBuffer do
  return bb.push_bytes(%buf, bytes: [op_memory_size, 0, op_i64_extend_i32_u])
end

export let emit_mem_grow = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_atom(atom: a, %buf, ctx)
      let %buf = bb.push_bytes(%buf, bytes: [op_i32_wrap_i64, op_memory_grow, 0])
      // Sign-extend so the wasm `-1` failure sentinel surfaces unchanged at i64.
      return bb.push_byte(%buf, byte: op_i64_extend_i32_s)
    | _ ->
      raise SymbolNotFound(name: "__nx_mem_grow", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

// ─── Atomic intrinsics (atomic-rmw-add-i32 / atomic-load-i32 / ...) ─────────
// Each lowers to a single 0xFE-prefixed wasm instruction (no host call). Like
// the memory intrinsics, addresses/values cross the FFI as Nexus `i64` and are
// wrapped to wasm i32 at the boundary. `wait32` / `notify` trap unless the
// linear memory is `shared`. These externals are filtered from the import
// section (filter_intrinsic_externals).

export let emit_atomic_rmw_add_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_rmw_add, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_rmw_add_i32", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_atomic_load_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_load, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_load_i32", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_atomic_store_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: v) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: v, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      return wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_store, offset: 0)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_store_i32", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_atomic_cmpxchg_i32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: ex) :: LirCallArg(label: _, value: rp) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: ex, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = emit_atom(atom: rp, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_i32_atomic_rmw_cmpxchg, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_cmpxchg_i32", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_atomic_wait32 = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: ex) :: LirCallArg(label: _, value: tmo) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: ex, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = emit_atom(atom: tmo, %buf, ctx)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_atomic_wait32, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_wait32", kind: SkIntrinsicArg, context: "")
      return %buf
  end
end

export let emit_atomic_notify = fn (args: [LirCallArg], buf: %ByteBuffer, ctx: CodegenCtx) -> %ByteBuffer throws { CodegenError } do
  match args do
    | LirCallArg(label: _, value: a) :: LirCallArg(label: _, value: c) :: _ ->
      let %buf = emit_addr_arg(atom: a, %buf, ctx)
      let %buf = emit_atom(atom: c, %buf, ctx)
      let %buf = bb.push_byte(%buf, byte: op_i32_wrap_i64)
      let %buf = wdefs.emit_atomic_op32(%buf, sub_op: wdefs.op_atomic_notify, offset: 0)
      return bb.push_byte(%buf, byte: op_i64_extend_i32_u)
    | _ ->
      raise SymbolNotFound(name: "__nx_atomic_notify", kind: SkIntrinsicArg, context: "")
      return %buf
