/**
 * codegen/intrinsics: inline-emitted compiler intrinsics — dispatcher layer.
 *
 * This file owns ONLY:
 * - Recognition predicates: `is_intrinsic_external`, `get_intrinsic_wasm_name`,
 *   `is_intrinsic_sched_external`, `is_wasi_thread_spawn`
 * - Import-section filters: `filter_intrinsic_externals`, `filter_externals_p3`
 * - `is_closure_lift` name classifier
 * - `Intrinsic` tagged enum + `parse_intrinsic` dispatcher
 *
 * The emitter functions themselves live in family-specific submodules:
 * - intrinsics/memo.nx    — extract_memo_names / extract_memo_slots
 * - intrinsics/sched.nx   — sched-set-next, sched-spawn, find_sched_import_idx,
 *                           wasi_thread_start_export
 * - intrinsics/heap.nx    — heap-mark / heap-reset / heap-swap / alloc-raw
 * - intrinsics/mem.nx     — mem-load-* / mem-store-* / mem-size / mem-grow /
 *                           atomic-* / cast-to-i32 / cast-to-i64
 * - intrinsics/threads.nx — thunk-addr, value-of-i64, bt-*, array-*
 * - intrinsics/math.nx    — f64-sqrt / f64-floor / f64-ceil / f64-abs
 * - intrinsics/simd.nx    — simd-* lane binops + autovectorized array form
 *
 * Does not own:
 * - `emit_intrinsic` dispatcher — stays in codegen.nx (needs closure helpers)
 * - `emit_force_closure` — same reason
 * - Memo-cache target planning (see src/backend/memo_plan.nx)
 */
import { LirExternal } from "src/ir/lir/types.nx"
import * as wdefs from "src/backend/wasm/defs.nx"
import { Some, None } from "std:option"
import * as str from "std:str"

/** True iff `ext.wasm_module == "nexus:intrinsic"` — the wasm-module string under which every inline-emitted compiler intrinsic (mem-load-*, atomic-*, simd-*, f64-sqrt, heap-mark, etc.) is declared. The single recognition predicate driving both `filter_intrinsic_externals` (import-section elision) and `get_intrinsic_wasm_name` (dispatch). */
let is_intrinsic_external = fn (ext: LirExternal) -> bool do
  let LirExternal(name: _, wasm_module: m, wasm_name: _, params: _, ret_type: _, throw_row: _) = ext
  return m == "nexus:intrinsic"
end

/** Returns the `wasm_name` of `func` if it resolves to a `nexus:intrinsic`
 *  external, `""` otherwise. The returned string is the dispatch key consumed
 *  by `emit_intrinsic` (e.g. `"mem-load-i32"`, `"heap-mark"`, `"f64-sqrt"`,
 *  `"force-closure"`).
 */
export let get_intrinsic_wasm_name = fn (func: string, exts: [ LirExternal ]) -> string do
  match wdefs.lookup_external(name: func, exts) do
    | None -> ""
    | Some(val: ext) ->
      if !is_intrinsic_external(ext) then return "" end
      let LirExternal(
          name: _,
          wasm_module: _,
          wasm_name: wn,
          params: _,
          ret_type: _,
          throw_row: _
        ) = ext
      wn
  end
end

/** True iff this external is the `wasi.thread-spawn` import from the
 *  wasi-threads proposal. In WASI p3 mode this import must be elided because
 *  the host does not provide it; the `force_all` parallel path degrades to
 *  sequential execution in p3 builds.
 */
let is_wasi_thread_spawn = fn (ext: LirExternal) -> bool do
  let LirExternal(
    name: _,
    wasm_module: m,
    wasm_name: wn,
    params: _,
    ret_type: _,
    throw_row: _
  ) = ext
  return m == "wasi" && wn == "thread-spawn"
end

/** True if this `nexus:runtime/sched` external is fulfilled inline by a
 *  compiler intrinsic, so the import entry must be elided from the final
 *  import section. `sched-set-next` and `sched-spawn` qualify; the others
 *  (enqueue, dequeue, push/pop_pending, queue-size) still go through the
 *  host linker.
 */
let is_intrinsic_sched_external = fn (ext: LirExternal) -> bool do
  let LirExternal(
    name: _,
    wasm_module: m,
    wasm_name: wn,
    params: _,
    ret_type: _,
    throw_row: _
  ) = ext
  if m != "nexus:runtime/sched" then return false end
      return wn == "sched-set-next" || wn == "sched-spawn"
end

/** Drop every external that's emitted inline — both `nexus:intrinsic` ops and the two inline `nexus:runtime/sched` intrinsics — so the wasm import section only contains imports the host actually needs to resolve. Order-preserving so subsequent positional indexing into the filtered list stays consistent with the original. */
export let filter_intrinsic_externals = fn (exts: [ LirExternal ]) -> [ LirExternal ] do
  match exts do
    | [] -> return []
    | e :: rest ->
      if is_intrinsic_external(ext: e) || is_intrinsic_sched_external(ext: e) then
        return filter_intrinsic_externals(exts: rest)
      else
        return e :: filter_intrinsic_externals(exts: rest)
      end
  end
end

/** Like `filter_intrinsic_externals` but also drops `wasi.thread-spawn` for
 *  WASI p3 builds where wasi-threads is not available.
 */
export let filter_externals_p3 = fn (exts: [ LirExternal ]) -> [ LirExternal ] do
  match exts do
    | [] -> return []
    | e :: rest ->
      if is_intrinsic_external(ext: e) || is_intrinsic_sched_external(ext: e) || is_wasi_thread_spawn(ext: e) then
        return filter_externals_p3(exts: rest)
      else
        return e :: filter_externals_p3(exts: rest)
      end
  end
end

/** True when name corresponds to a lifted lambda (`__closure_N`). Matches both
 *  the bare form and the canonical-path form (`<sanitized-path>#__closure_N`)
 *  because `lift_lambda` (mir.nx) names lambdas `__closure_N` but downstream
 *  passes may prepend the source-file path to disambiguate cross-module
 *  imports. Distinct from `is_closure_func`, which also matches inject bodies
 *  and the sched trampoline — those need a function-table elem entry for
 *  ref.func but follow their own (non-canonical-closure) signature.
 */
export let is_closure_lift = fn (name: string) -> bool do
  let nlen = str.length(s: name)
  let bare = "__closure_"
  let blen = str.length(s: bare)
  if nlen >= blen then
    if str.substring(s: name, start: 0, len: blen) == bare then return true end
  end
  let infix = "#__closure_"
  let ilen = str.length(s: infix)
  return nlen >= ilen && str.contains(s: name, sub: infix)
end

/** True for the lifted inject-body functions (`__inject_N`, possibly
 *  module-prefixed). Their `() -> ()` continuation signature must be kept, so
 *  codegen stores their trailing value into the ss_inject_value global rather
 *  than returning it (nexus-h4v70). */
export let is_inject_lift = fn (name: string) -> bool do
  let nlen = str.length(s: name)
  let bare = "__inject_"
  let blen = str.length(s: bare)
  if nlen >= blen then
    if str.substring(s: name, start: 0, len: blen) == bare then return true end
  end
  let infix = "#__inject_"
  let ilen = str.length(s: infix)
  return nlen >= ilen && str.contains(s: name, sub: infix)
end

// One variant per `nexus:intrinsic` wasm_name handled by `emit_intrinsic`
// (codegen.nx). `parse_intrinsic` is the single point that converts the raw
// kebab-cased wasm_name string into a tagged `Intrinsic`; the dispatcher then
// pattern-matches exhaustively, so a missing arm is a compile error rather
// than a "no such intrinsic" runtime trap.

/** Tagged enumeration of every `nexus:intrinsic` op `emit_intrinsic` (codegen.nx) knows how to handle. Built from the wire-side `wasm_name` string by `parse_intrinsic`; unknown names fall through to `UnknownIntrinsic(name)` so dispatch can keep the surface error as `SymbolNotFound`. */
export type Intrinsic =
    HeapMark
  | HeapReset
  | HeapSwap
  | AllocRaw
  | MemLoadI32
  | MemStoreI32
  | MemLoadU8
  | MemStoreU8
  | MemLoadI64
  | MemStoreI64
  | MemLoadF32
  | MemStoreF32
  | MemLoadF64
  | MemStoreF64
  | MemSize
  | MemGrow
  | AtomicRmwAddI32
  | AtomicLoadI32
  | AtomicStoreI32
  | AtomicCmpxchgI32
  | AtomicWait32
  | AtomicNotify
  | AtomicFence
  | CastToI32
  | CastToI64
  | ForceClosure
  | ThunkAddr
  | ValueOfI64
  | ArrayLength
  | F64Sqrt
  | F64Floor
  | F64Ceil
  | F64Abs
  | SimdF32x4Add
  | SimdF32x4Mul
  | SimdF64x2Add
  | SimdF64x2Mul
  | SimdI32x4Add
  | SimdI32x4Mul
  | SimdI64x2Add
  | SimdI64x2Mul
  | SimdF32x4AddArray
  | SimdF64x2AddArray
  | SimdI32x4AddArray
  | SimdI64x2AddArray
  | SimdF32x4MulArray
  | SimdF64x2MulArray
  | SimdI32x4MulArray
  | SimdI64x2MulArray
  | SimdF32x4SubArray
  | SimdF64x2SubArray
  | SimdI32x4SubArray
  | SimdI64x2SubArray
  | SimdF32x4DivArray
  | SimdF64x2DivArray
  | BtDepth
  | BtFrame
  | CaptureBacktrace
  | UnknownIntrinsic(name: string)

/** Convert a kebab-cased `nexus:intrinsic` wasm_name (e.g. `"heap-mark"`,
 *  `"simd-f32x4-add-array"`) to its `Intrinsic` tag. Unknown names land in
 *  `UnknownIntrinsic(name)` and surface as the same `SymbolNotFound` error
 *  the old string-chain dispatch produced — no fatal parse error here.
 */
export let parse_intrinsic = fn (s: string) -> Intrinsic do
  if s == "heap-mark" then return HeapMark
  else if s == "heap-reset" then return HeapReset
  else if s == "heap-swap" then return HeapSwap
  else if s == "alloc-raw" then return AllocRaw
  else if s == "mem-load-i32" then return MemLoadI32
  else if s == "mem-store-i32" then return MemStoreI32
  else if s == "mem-load-u8" then return MemLoadU8
  else if s == "mem-store-u8" then return MemStoreU8
  else if s == "mem-load-i64" then return MemLoadI64
  else if s == "mem-store-i64" then return MemStoreI64
  else if s == "mem-load-f32" then return MemLoadF32
  else if s == "mem-store-f32" then return MemStoreF32
  else if s == "mem-load-f64" then return MemLoadF64
  else if s == "mem-store-f64" then return MemStoreF64
  else if s == "mem-size" then return MemSize
  else if s == "mem-grow" then return MemGrow
  else if s == "atomic-rmw-add-i32" then return AtomicRmwAddI32
  else if s == "atomic-load-i32" then return AtomicLoadI32
  else if s == "atomic-store-i32" then return AtomicStoreI32
  else if s == "atomic-cmpxchg-i32" then return AtomicCmpxchgI32
  else if s == "atomic-wait32" then return AtomicWait32
  else if s == "atomic-notify" then return AtomicNotify
  else if s == "atomic-fence" then return AtomicFence
  else if s == "cast-to-i32" then return CastToI32
  else if s == "cast-to-i64" then return CastToI64
  else if s == "force-closure" then return ForceClosure
  else if s == "thunk-addr" then return ThunkAddr
  else if s == "value-of-i64" then return ValueOfI64
  else if s == "array-length" then return ArrayLength
  else if s == "f64-sqrt" then return F64Sqrt
  else if s == "f64-floor" then return F64Floor
  else if s == "f64-ceil" then return F64Ceil
  else if s == "f64-abs" then return F64Abs
  else if s == "simd-f32x4-add" then return SimdF32x4Add
  else if s == "simd-f32x4-mul" then return SimdF32x4Mul
  else if s == "simd-f64x2-add" then return SimdF64x2Add
  else if s == "simd-f64x2-mul" then return SimdF64x2Mul
  else if s == "simd-i32x4-add" then return SimdI32x4Add
  else if s == "simd-i32x4-mul" then return SimdI32x4Mul
  else if s == "simd-i64x2-add" then return SimdI64x2Add
  else if s == "simd-i64x2-mul" then return SimdI64x2Mul
  else if s == "simd-f32x4-add-array" then return SimdF32x4AddArray
  else if s == "simd-f64x2-add-array" then return SimdF64x2AddArray
  else if s == "simd-i32x4-add-array" then return SimdI32x4AddArray
  else if s == "simd-i64x2-add-array" then return SimdI64x2AddArray
  else if s == "simd-f32x4-mul-array" then return SimdF32x4MulArray
  else if s == "simd-f64x2-mul-array" then return SimdF64x2MulArray
  else if s == "simd-i32x4-mul-array" then return SimdI32x4MulArray
  else if s == "simd-i64x2-mul-array" then return SimdI64x2MulArray
  else if s == "simd-f32x4-sub-array" then return SimdF32x4SubArray
  else if s == "simd-f64x2-sub-array" then return SimdF64x2SubArray
  else if s == "simd-i32x4-sub-array" then return SimdI32x4SubArray
  else if s == "simd-i64x2-sub-array" then return SimdI64x2SubArray
  else if s == "simd-f32x4-div-array" then return SimdF32x4DivArray
  else if s == "simd-f64x2-div-array" then return SimdF64x2DivArray
  else if s == "bt-depth" then return BtDepth
  else if s == "bt-frame" then return BtFrame
  else if s == "capture-backtrace" then return CaptureBacktrace
  else return UnknownIntrinsic(name: s)
  end
end
