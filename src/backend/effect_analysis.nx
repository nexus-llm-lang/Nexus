/**
 * effect_analysis: Per-function effect summary inference over LIR.
 *
 * Produces an EffectMap keyed by function name that records, for every
 * LirFunction in the program:
 *   - capabilities_used: capability names this function transitively reaches
 *     via stdlib externals (e.g. "Fs", "Console", "Clock").
 *   - can_throw: true when the function (or any transitive callee) executes
 *     a LirExprRaise, calls a closure (dynamic dispatch is conservatively
 *     assumed throwing), or calls an external whose throw_row is non-empty.
 *   - is_pure: true iff capabilities_used is empty, can_throw is false, and
 *     the function never reaches a side-effecting external.
 *
 * Algorithm (two phases):
 *   1. Direct pass — walk each function body once to collect:
 *        * direct callees (LirExprCall / LirExprTailCall / LirExprMakeClosure
 *          target / LirExprContNew func_ref / LirExprInjectResume body and
 *          arm fns)
 *        * direct caps (external calls mapped via wasm_module → capability)
 *        * direct throws (LirExprRaise, LirExprCallClosure, throwing externs)
 *        * direct side-effect (any non-pure external call, any closure call)
 *   2. Fixed-point — propagate caps / throws / side-effect over the static
 *      call graph until no entry changes. Termination: each summary lattice
 *      is monotone (caps grow, can_throw / has_side_effect can only flip
 *      false→true) and the set is bounded, so the loop converges in at
 *      most |functions| iterations of any single edge.
 *
 * is_pure is a derived flag, recomputed after the fixed point converges.
 *
 * Stand-alone: this pass produces an EffectMap value. Driver wires it into
 * the pipeline (see src/main.nx) so consumers can request the summary via
 * `analyze_effects`. No existing pass mutates anything based on the result;
 * effect-directed optimisations are tracked separately (issues 55x0 / e6uh).
 */

import { TypeExpr, TyRow } from "src/common/ast.nx"
import * as list from "std:list"
import { LirProgram, LirFunction, LirExternal, LirExpr, LirStmt } from "src/ir/lir/types.nx"
import { EffectSummary, EffectEntry, EffectMap, EffectBits,
         bit_or, pack_summary, make_effect_map, lookup_bits } from "src/ir/shared/effect_map.nx"
import { StringMap }, * as smap from "std:stringmap"

// The public `EffectMap` / `EffectSummary` / `EffectEntry` / `EffectBits`
// types, the packed-bit helpers (`pack_summary`, `bit_or`), and the read-side
// accessors (`lookup_bits`, `lookup_summary`, `effect_map_size`,
// `free_effect_map`, `classify_effect_map`) now live in
// `src/ir/effect_map.nx` so consumers in the IR layer (e.g. `lir_opt`) can
// import them without crossing into the backend. This file owns the producer
// pipeline (`analyze_effects`) and the LIR-walking metrics
// (`count_raise_sites`) that need both an `EffectMap` and a `LirProgram`.

// Externals carry their wasm_module string (e.g. "nexus:std/fs"). Each
// host-cap module maps 1:1 to a capability surface; the mapping mirrors
// `perm_to_cap_name` in main.nx so downstream consumers compare names
// against the same vocabulary used by `--explain-capabilities`.

let module_to_capability = fn (wasm_module: string) -> [ string ] do
  if wasm_module == "nexus:std/fs" then return ["Fs"] end
  if wasm_module == "nexus:std/network" then return ["Net"] end
  if wasm_module == "nexus:std/stdio" then return ["Console"] end
  if wasm_module == "nexus:std/rand" then return ["Random"] end
  if wasm_module == "nexus:std/clock" then return ["Clock"] end
  if wasm_module == "nexus:std/proc" then return ["Proc"] end
  if wasm_module == "nexus:std/env" then return ["Env"] end
  return []
end

// Capability bitmask layout. The capability vocabulary is
// a fixed 7-element set (Fs, Net, Console, Random, Clock, Proc, Env) that
// tracks the `--explain-capabilities` mapping. Encoding caps as a 7-bit
// integer collapses union from O(|xs|+|ys|) list-allocation to O(1) bitwise
// or, which is the difference between O(N²) and O(N) propagation memory at
// self-host scale. Bit constants are exposed as nullary fns because the
// Nexus self-host slice does not parse top-level scalar `let` bindings.
let cap_bit_fs = 1
let cap_bit_net = 2
let cap_bit_console = 4
let cap_bit_random = 8
let cap_bit_clock = 16
let cap_bit_proc = 32
let cap_bit_env = 64
let module_to_cap_bits = fn (wasm_module: string) -> i64 do
  if wasm_module == "nexus:std/fs" then return cap_bit_fs end
  if wasm_module == "nexus:std/network" then return cap_bit_net end
  if wasm_module == "nexus:std/stdio" then return cap_bit_console end
  if wasm_module == "nexus:std/rand" then return cap_bit_random end
  if wasm_module == "nexus:std/clock" then return cap_bit_clock end
  if wasm_module == "nexus:std/proc" then return cap_bit_proc end
  if wasm_module == "nexus:std/env" then return cap_bit_env end
  return 0
end

// Convert a cap bitmask back to the `[string]` form expected by the public
// EffectSummary surface. Order matches the original `module_to_capability`
// ordering when an external is observed in source order — bit positions are
// fixed so the same input set yields the same output list each run.
let cap_bits_to_strings = fn (bits: i64) -> [ string ] do
  let acc = []
  let acc = if (bits & cap_bit_env) != 0 then "Env" :: acc else acc end
  let acc = if (bits & cap_bit_proc) != 0 then "Proc" :: acc else acc end
  let acc = if (bits & cap_bit_clock) != 0 then "Clock" :: acc else acc end
  let acc = if (bits & cap_bit_random) != 0 then "Random" :: acc else acc end
  let acc = if (bits & cap_bit_console) != 0 then "Console" :: acc else acc end
  let acc = if (bits & cap_bit_net) != 0 then "Net" :: acc else acc end
  let acc = if (bits & cap_bit_fs) != 0 then "Fs" :: acc else acc end
  return acc
end

// Working-state packed encoding (per-function during fixed point):
//   bits 0..6  — capabilities bitmask (see cap_bit_* above)
//   bit  7     — can_throw
//   bit  8     — has_side_effect
//   bit  9     — present (so StringMap.get_or(default: 0) means "no entry")
let ws_caps_mask = 127
let ws_throw_bit = 128
let ws_se_bit = 256
let ws_present_bit = 512
let ws_pack = fn (caps: i64, can_throw: bool, has_side_effect: bool) -> i64 do
  let ct = if can_throw then ws_throw_bit else 0 end
  let se = if has_side_effect then ws_se_bit else 0 end
  // bits (caps_mask), throw_bit, se_bit, present_bit are all disjoint so
  // bit_or reduces to addition, but we keep the helper to make the
  // structural intent (set assembly) explicit.
  let masked = caps & ws_caps_mask
  return bit_or(a: bit_or(a: bit_or(a: masked, b: ct), b: se), b: ws_present_bit)
end

let ws_caps = fn (packed: i64) -> i64 do
  return packed & ws_caps_mask
end

let ws_can_throw = fn (packed: i64) -> bool do
  return (packed & ws_throw_bit) != 0
end

let ws_has_side_effect = fn (packed: i64) -> bool do
  return (packed & ws_se_bit) != 0
end

/** True for externals statically known to be pure (compute-only, no host I/O,
 *  no observable side effect). Conservative: when in doubt, return false so
 *  is_pure stays sound.
 *
 *  The f64 math ops (`f64-sqrt`/`f64-floor`/`f64-ceil`/`f64-abs`) — whether
 *  they arrive under the unified `nexus:intrinsic` module or the legacy
 *  `nexus:runtime/math` one — are codegen-inlined to single wasm ops and never
 *  escape the engine, so their calls are equivalent to LirExprBinary on the
 *  side-effect axis. The other intrinsics (raw mem load/store, atomics,
 *  alloc-raw, casts, the lazy type-puns) stay conservatively side-effecting,
 *  matching the pre-unification behaviour.
 */
let is_pure_external_module = fn (wasm_module: string, wasm_name: string) -> bool do
  if wasm_module == "nexus:runtime/math" then return true end
  if wasm_module == "nexus:intrinsic" then
    return wasm_name == "f64-sqrt" || wasm_name == "f64-floor"
      || wasm_name == "f64-ceil" || wasm_name == "f64-abs"
  end
  return false
end

// LirExternal stores its throw_row as a TypeExpr. An empty row (no types,
// no rest variable) means the external is non-throwing. Anything else is
// treated as throwing — even if the row is just a polymorphic tail, since
// at LIR time we cannot prove the row instantiates to empty.

let throw_row_is_throwing = fn (row: TypeExpr) -> bool do
  if let TyRow(types, rest: r) = row then
    match types do
      | [] ->
        match r do
          | None -> return false
          | _ -> return true
        end
      | _ -> return true
    end
  end
  // Non-row type in throw_row position is unexpected; treat as throwing
  // rather than silently swallowing (no silent fallbacks per project
  // policy — a foreign throw_row shape is signalled as can_throw rather
  // than dropped to false).
  return true
end

let lookup_external = fn (name: string, exts: [ LirExternal ]) -> Option<LirExternal> do
  match exts do
    | [] -> return None
    | e :: rest ->
      let LirExternal(name: en, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) = e
      if en == name then return Some(val: e) end
      return lookup_external(name, exts: rest)
  end
end

// DirectInfo carries the single-function direct walk: callees, externals
// touched, raises, dynamic closure calls. After the direct walk we project
// these into the per-function packed working state, then iterate the
// fixed point over the callee edges.
//
// `capabilities` is a bitmask (see cap_bit_* and module_to_cap_bits) so the
// per-merge union collapses to a bitwise OR — a `[string]` representation
// allocates per-iteration and tips self-host into an OOM cliff.

type DirectInfo = DirectInfo(
  callees: [ string ],          // statically known callee function names
  capabilities: i64,          // caps bitmask observed directly via externals
  has_side_effect: bool,      // direct: non-pure external or closure call
  can_throw: bool             // direct: throw / throwing external / closure
)

let empty_direct = fn () -> DirectInfo do
  return DirectInfo(callees: [], capabilities: 0, has_side_effect: false, can_throw: false)
end

let string_member = fn (s: string, xs: [ string ]) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true end
      return string_member(s, xs: rest)
  end
end

let walk_call_target = fn (
  func: string,
  exts: [ LirExternal ],
  acc: DirectInfo
) -> DirectInfo do
  let DirectInfo(callees, capabilities, has_side_effect, can_throw) = acc
  match lookup_external(name: func, exts) do
    | Some(val: ext) ->
      let LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: tr) = ext
      let new_caps = bit_or(a: capabilities, b: module_to_cap_bits(wasm_module: m))
      let pure_mod = is_pure_external_module(wasm_module: m, wasm_name: wn)
      let new_se = if pure_mod then has_side_effect else true end
      let new_throw = if throw_row_is_throwing(row: tr) then true else can_throw end
      return DirectInfo(callees, capabilities: new_caps, has_side_effect: new_se, can_throw: new_throw)
    | None ->
      // Static call to another LIR function: defer to the fixed point.
      // Record the edge but don't pre-stamp side-effect / throw bits;
      // they propagate transitively in phase 2.
      if string_member(s: func, xs: callees) then
        return acc
      end
      return DirectInfo(callees: func :: callees, capabilities, has_side_effect, can_throw)
  end
end

let walk_expr = fn (expr: LirExpr, exts: [ LirExternal ], acc: DirectInfo) -> DirectInfo do
  match expr do
    | LirExprAtom(_) | LirExprBinary(_)
    | LirExprConstructor(_) | LirExprRecord(_)
    | LirExprObjectTag(_) | LirExprObjectField(_) -> return acc
    | LirExprCall(func, args: _, typ: _) | LirExprTailCall(func, args: _, typ: _) ->
      return walk_call_target(func, exts, acc)
    | LirExprRaise(value: _, typ: _) ->
      let DirectInfo(callees, capabilities, has_side_effect, can_throw: _) = acc
      return DirectInfo(callees, capabilities, has_side_effect, can_throw: true)
    | LirExprForce(_) ->
      // Lazy force evaluates the thunk body, which can perform any effect
      // its closure captures. Mark side-effect / throw as conservative.
      let DirectInfo(callees, capabilities, has_side_effect: _, can_throw: _) = acc
      return DirectInfo(callees, capabilities, has_side_effect: true, can_throw: true)
    | LirExprMakeClosure(func_name, captures: _, typ: _) ->
      // Allocating a closure value is itself pure; the function it points
      // at participates in the call graph because any later CallClosure
      // could invoke it. Treat it as a static callee edge so the fixed
      // point folds the closure body's effects into us if we ever invoke
      // it directly. (If the closure escapes via a record or argument we
      // remain conservative through the closure-call path.)
      return walk_call_target(func: func_name, exts, acc)
    | LirExprCallClosure(_) ->
      // Indirect dispatch: the target is a runtime value. Conservatively
      // assume it can throw and has side effects.
      let DirectInfo(callees, capabilities, has_side_effect: _, can_throw: _) = acc
      return DirectInfo(callees, capabilities, has_side_effect: true, can_throw: true)
    | LirExprSuspend(_) ->
      let DirectInfo(callees, capabilities, has_side_effect: _, can_throw) = acc
      return DirectInfo(callees, capabilities, has_side_effect: true, can_throw)
    | LirExprResume(_) ->
      let DirectInfo(callees, capabilities, has_side_effect: _, can_throw: _) = acc
      return DirectInfo(callees, capabilities, has_side_effect: true, can_throw: true)
    | LirExprContNew(func_ref, typ: _) ->
      // Continuation allocation references a function but does not call it;
      // record the edge so a future resume folds its effects into us.
      return walk_call_target(func: func_ref, exts, acc)
    | LirExprInjectResume(body_fn, arm_fns, arm_tags: _, typ: _) ->
      let acc1 = walk_call_target(func: body_fn, exts, acc)
      return walk_arm_fns(xs: arm_fns, exts, acc: acc1)
  end
end

let walk_arm_fns = fn (xs: [ string ], exts: [ LirExternal ], acc: DirectInfo) -> DirectInfo do
  match xs do
    | [] -> return acc
    | n :: rest ->
      return walk_arm_fns(xs: rest, exts, acc: walk_call_target(func: n, exts, acc))
  end
end

let walk_stmt = fn (stmt: LirStmt, exts: [ LirExternal ], acc: DirectInfo) -> DirectInfo do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) ->
      return walk_expr(expr: e, exts, acc)
    | LirStmtIf(cond: _, then_body: tb, else_body: eb)
    | LirStmtIfReturn(cond: _, then_body: tb, then_ret: _, else_body: eb, else_ret: _, ret_type: _) ->
      let acc1 = walk_stmts(stmts: tb, exts, acc)
      return walk_stmts(stmts: eb, exts, acc: acc1)
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      let acc1 = walk_stmts(stmts: cs, exts, acc)
      return walk_stmts(stmts: b, exts, acc: acc1)
    | LirStmtTryCatch(body: b, body_ret: _, catch_param: _, catch_param_typ: _, catch_body: cb, catch_ret: _) ->
      // T-Try / E-Catch semantics: any exception thrown in the body is caught
      // here. Therefore body.can_throw does NOT propagate to the enclosing
      // scope. Other effects (callees, capabilities, has_side_effect) DO
      // propagate — callee lists feed the fixed-point, and any cap/side-effect
      // the body touches is still visible at this call site.
      // Catch body can re-raise, so its can_throw DOES propagate.
      //
      // Assumption: LIR-time try is treated as exhaustive catch (sound under
      // well-typed Nexus programs where typechecking has already verified
      // exhaustiveness). Row types are discarded at LIR, so we cannot
      // distinguish partial-catch; we assume the body's exception is always
      // caught here.
      let DirectInfo(callees: _, capabilities: _, has_side_effect: _, can_throw: acc_ct) = acc
      let body_acc = walk_stmts(stmts: b, exts, acc)
      let DirectInfo(callees: bc, capabilities: bk, has_side_effect: bs, can_throw: _) = body_acc
      let masked = DirectInfo(callees: bc, capabilities: bk, has_side_effect: bs, can_throw: acc_ct)
      return walk_stmts(stmts: cb, exts, acc: masked)
  end
end

let walk_stmts = fn (stmts: [ LirStmt ], exts: [ LirExternal ], acc: DirectInfo) -> DirectInfo do
  match stmts do
    | [] -> return acc
    | s :: rest ->
      let acc1 = walk_stmt(stmt: s, exts, acc)
      return walk_stmts(stmts: rest, exts, acc: acc1)
  end
end

type DirectEntry = DirectEntry(name: string, info: DirectInfo)

let build_direct_entries = fn (funcs: [ LirFunction ], exts: [ LirExternal ]) -> [ DirectEntry ] do
  return build_direct_entries_go(funcs, exts, acc: [])
end

let build_direct_entries_go = fn (funcs: [ LirFunction ], exts: [ LirExternal ], acc: [ DirectEntry ]) -> [ DirectEntry ] do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      let LirFunction(name, params: _, ret_type: _, body, ret: _, span: _) = f
      let info = walk_stmts(stmts: body, exts, acc: empty_direct())
      return build_direct_entries_go(funcs: rest, exts, acc: DirectEntry(name, info) :: acc)
  end
end

// The summary lattice for one function is (caps: bitmask, can_throw: bool
// ascending false→true, has_side_effect: bool ascending). Per-function
// state is encoded as a single packed i64 (see ws_pack) and stored in a
// linear `%StringMap` keyed by function name. One iteration walks every
// callee list, looks up each callee's current packed state via O(1)
// StringMap.get_or, ORs the bits into the caller's accumulator, and writes
// back if anything changed. We loop until no entry changes; convergence is
// guaranteed by monotonicity over a finite domain.
//
// The StringMap-backed encoding keeps each iteration O(N): a linear-scan
// alternative is O(N²) per pass (each callee triggers a list walk and a
// fresh allocation per merge), which at self-host scale (~2173 functions)
// drives the host's WASM allocator off a cliff. Packing the capability set
// into a single i64 reduces merging to a bitwise OR (cap_bit_*) and
// eliminates per-merge list allocation entirely.

// CalleeEntry: function name + its static callees. Built from DirectInfo
// and held in a list for the per-iteration sweep order. Callees themselves
// are still a list since their count per caller is small (typically <10).
type CalleeEntry = CalleeEntry(name: string, callees: [ string ])

let direct_to_callee_entries = fn (entries: [ DirectEntry ]) -> [ CalleeEntry ] do
  return direct_to_callee_entries_go(entries, acc: [])
end

let direct_to_callee_entries_go = fn (entries: [ DirectEntry ], acc: [ CalleeEntry ]) -> [ CalleeEntry ] do
  match entries do
    | [] -> return list.reverse(xs: acc)
    | DirectEntry(name, info) :: rest ->
      let DirectInfo(callees, capabilities: _, has_side_effect: _, can_throw: _) = info
      return direct_to_callee_entries_go(entries: rest, acc: CalleeEntry(name, callees) :: acc)
  end
end

// Build the initial working state: name → packed direct DirectInfo bits.
// Keys are function names; values are ws_pack(caps, can_throw, has_side_effect).
let build_initial_state = fn (entries: [ DirectEntry ], map: %StringMap) -> %StringMap do
  match entries do
    | [] -> return %map
    | DirectEntry(name, info) :: rest ->
      let DirectInfo(callees: _, capabilities, has_side_effect, can_throw) = info
      let packed = ws_pack(caps: capabilities, can_throw, has_side_effect)
      let %map = smap.put(%map, key: name, value: packed)
      return build_initial_state(entries: rest, %map)
  end
end

// Merge one callee's bits into the running accumulator. Looks up the
// callee's current packed state from the working StringMap; absent callees
// (externals already merged during the direct walk, or stale references)
// contribute zero effects.
let merge_one_callee = fn (callee: string, caps: i64, can_throw: bool, has_side_effect: bool,
                            state: &StringMap) -> i64 do
  // Returns the merged packed state (without the present bit, just the
  // accumulator). The caller wraps this back into ws_pack.
  let cur = smap.get_or(map: state, key: callee, default: 0)
  if (cur & ws_present_bit) == 0 then
    // Absent: contribute nothing.
    return ws_pack(caps, can_throw, has_side_effect)
  end
  let new_caps = bit_or(a: caps, b: ws_caps(packed: cur))
  let new_throw = if ws_can_throw(packed: cur) then true else can_throw end
  let new_se = if ws_has_side_effect(packed: cur) then true else has_side_effect end
  return ws_pack(caps: new_caps, can_throw: new_throw, has_side_effect: new_se)
end

let merge_callees_packed = fn (callees: [ string ], packed: i64, state: &StringMap) -> i64 do
  match callees do
    | [] -> return packed
    | c :: rest ->
      let next_packed = merge_one_callee(callee: c, caps: ws_caps(packed),
                                          can_throw: ws_can_throw(packed),
                                          has_side_effect: ws_has_side_effect(packed),
                                          state)
      return merge_callees_packed(callees: rest, packed: next_packed, state)
  end
end

// One full iteration: step every entry in `callee_entries`, threading the
// `%StringMap` linearly. Returns the updated map and a `changed` flag.
type IterResult = IterResult(state: %StringMap, changed: bool)

let one_iteration_smap = fn (callee_entries: [ CalleeEntry ], state: %StringMap) -> IterResult do
  return one_iteration_smap_go(remaining: callee_entries, %state, changed: false)
end

let one_iteration_smap_go = fn (
  remaining: [ CalleeEntry ],
  state: %StringMap,
  changed: bool
) -> IterResult do
  match remaining do
    | [] -> return IterResult(%state, changed)
    | CalleeEntry(name, callees) :: rest ->
      let cur = smap.get_or(map: &state, key: name, default: 0)
      let merged = merge_callees_packed(callees, packed: cur, &state)
      let now_changed = if cur != merged then true else changed end
      let %state = if cur != merged then
        smap.put(map: %state, key: name, value: merged)
      else %state end
      return one_iteration_smap_go(remaining: rest, %state, changed: now_changed)
  end
end

// Drive the fixed point. `fuel` bounds the iteration count; each function
// summary can change at most |functions| + |caps| times so a generous
// linear bound (4× function count) is sufficient and acts as a safety net
// against unexpected non-monotone behaviour.

let propagate_smap = fn (callee_entries: [ CalleeEntry ], state: %StringMap) -> %StringMap do
  let n = list_length_ce(xs: callee_entries)
  return propagate_smap_go(callee_entries, %state, fuel: 4 * n + 4)
end

let propagate_smap_go = fn (callee_entries: [ CalleeEntry ], state: %StringMap, fuel: i64) -> %StringMap do
  if fuel <= 0 then return %state end
  let IterResult(state, changed) = one_iteration_smap(callee_entries, %state)
  let %next = state
  if changed then
    return propagate_smap_go(callee_entries, state: %next, fuel: fuel - 1)
  end
  return %next
end

let list_length_ce = fn (xs: [ CalleeEntry ]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + list_length_ce(xs: rest)
  end
end

// finalise: walk the function order (preserved via the DirectEntry list)
// and read each function's converged state from the working StringMap.
// Builds the public-facing entries list (with [string] caps for tests/UI)
// and the consumer-facing lookup StringMap (packed (can_throw, is_pure)
// only). The two views are constructed in a single pass so they share the
// allocation.
type FinaliseResult = FinaliseResult(entries: [ EffectEntry ], lookup: %StringMap)

let finalise_smap = fn (direct: [ DirectEntry ], state: %StringMap) -> %EffectMap do
  let %lookup = smap.empty()
  let FinaliseResult(entries: rev, lookup) =
    finalise_smap_go(direct, &state, %lookup, acc: [])
  let %final_lookup = lookup
  let entries = list.reverse(xs: rev)
  smap.free(map: %state)
  return make_effect_map(entries, lookup: %final_lookup)
end

let finalise_smap_go = fn (direct: [ DirectEntry ], state: &StringMap,
                            lookup: %StringMap, acc: [ EffectEntry ]) -> FinaliseResult do
  match direct do
    | [] -> return FinaliseResult(entries: acc, %lookup)
    | DirectEntry(name, info: _) :: rest ->
      let packed = smap.get_or(map: state, key: name, default: 0)
      let caps_bits = ws_caps(packed)
      let ct = ws_can_throw(packed)
      let se = ws_has_side_effect(packed)
      let pure_b = compute_purity_bits(caps: caps_bits, can_throw: ct, has_side_effect: se)
      let caps_list = cap_bits_to_strings(bits: caps_bits)
      let summary = EffectSummary(capabilities_used: caps_list, can_throw: ct, is_pure: pure_b)
      let %lookup = smap.put(map: %lookup, key: name, value: pack_summary(can_throw: ct, is_pure: pure_b))
      return finalise_smap_go(direct: rest, state, %lookup,
                              acc: EffectEntry(name, summary) :: acc)
  end
end

let compute_purity_bits = fn (caps: i64, can_throw: bool, has_side_effect: bool) -> bool do
  if can_throw then return false end
  if has_side_effect then return false end
  return caps == 0
end

/** Compute the per-function effect map for `program`. The returned map
 *  contains one entry per LirFunction; consumers look up by function name
 *  (matching `LirFunction.name`). Linear: caller must `free_effect_map`
 *  once consumers are done with it.
 */
export let analyze_effects = fn (program: LirProgram) -> %EffectMap do
  let LirProgram(functions, externals) = program
  let direct = build_direct_entries(funcs: functions, exts: externals)
  let callee_entries = direct_to_callee_entries(entries: direct)
  let %state = smap.empty()
  let %state = build_initial_state(entries: direct, map: %state)
  let %state = propagate_smap(callee_entries, %state)
  return finalise_smap(direct, %state)
end

// Walk every LirFunction body in `program` and count LirExprRaise sites,
// partitioning them into "emitted" (the enclosing function's EffectMap entry
// has can_throw = true, so codegen will emit a __nx_main_wrap_bt_capture
// call before op_throw) and "elided" (can_throw = false or the function is
// absent from the EffectMap, in which case codegen.resolve_bt_capture_for_func
// would return -1 only on the can_throw=false path; the absent-from-map path
// keeps emission per the conservative fallback). Mirrors the rule in
// codegen.nx::resolve_bt_capture_for_func to keep the metric truthful.
//
// Reported sites count the throw expressions in the source LIR — they are
// the population that codegen would walk during emission. The metric does
// not depend on whether the bt-capture import is actually present in the
// program; that's a binary global property reported separately by the
// driver if relevant.

/** Result of `count_raise_sites`: `emitted` counts raises that the codegen will surround with a `__nx_main_wrap_bt_capture` call, `elided` counts those it will leave bare (per the `EffectMap` rule), and `total = emitted + elided`. Used by the driver to print the per-build backtrace-instrumentation metric. */
export type RaiseSiteCounts = RaiseSiteCounts(
  emitted: i64,
  elided: i64,
  total: i64
)

/** Walk every `LirFunction` body and partition `LirExprRaise` sites into emitted vs elided per the same rule `codegen.resolve_bt_capture_for_func` uses — `can_throw=true` (or absent-from-map fallback) ⇒ emitted, `can_throw=false` ⇒ elided. The returned `RaiseSiteCounts` reflects what the actual code emission will do, so the metric stays truthful as the effect analysis evolves. */
export let count_raise_sites = fn (program: LirProgram, em: &EffectMap) -> RaiseSiteCounts do
  let LirProgram(functions, externals: _) = program
  return count_raise_sites_funcs(funcs: functions, em, emitted: 0, elided: 0)
end

let count_raise_sites_funcs = fn (
  funcs: [ LirFunction ],
  em: &EffectMap,
  emitted: i64,
  elided: i64
) -> RaiseSiteCounts do
  match funcs do
    | [] -> return RaiseSiteCounts(emitted, elided, total: emitted + elided)
    | f :: rest ->
      let LirFunction(name, params: _, ret_type: _, body, ret: _, span: _) = f
      let n_raises = count_raises_in_stmts(stmts: body, acc: 0)
      let func_emits = func_emits_capture(name, em)
      let new_emitted = if func_emits then emitted + n_raises else emitted end
      let new_elided = if func_emits then elided else elided + n_raises end
      return count_raise_sites_funcs(funcs: rest, em,
        emitted: new_emitted, elided: new_elided)
  end
end

/** Mirror codegen.resolve_bt_capture_for_func: a function emits the
 *  capture call when its EffectMap entry has can_throw=true OR when the
 *  function is absent from the map (conservative fallback). Functions
 *  whose entry has can_throw=false are the only ones that elide.
 */
let func_emits_capture = fn (name: string, em: &EffectMap) -> bool do
  match lookup_bits(em, name) do
    | Some(val: EffectBits(can_throw: ct, is_pure: _)) -> return ct
    | None -> return true
  end
end

let count_raises_in_stmts = fn (stmts: [ LirStmt ], acc: i64) -> i64 do
  match stmts do
    | [] -> return acc
    | s :: rest -> return count_raises_in_stmts(stmts: rest, acc: count_raises_in_stmt(stmt: s, acc))
  end
end

let count_raises_in_stmt = fn (stmt: LirStmt, acc: i64) -> i64 do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) -> return count_raises_in_expr(expr: e, acc)
    | LirStmtIf(cond: _, then_body: tb, else_body: eb)
    | LirStmtIfReturn(cond: _, then_body: tb, then_ret: _, else_body: eb, else_ret: _, ret_type: _) ->
      let acc1 = count_raises_in_stmts(stmts: tb, acc)
      return count_raises_in_stmts(stmts: eb, acc: acc1)
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      let acc1 = count_raises_in_stmts(stmts: cs, acc)
      return count_raises_in_stmts(stmts: b, acc: acc1)
    | LirStmtTryCatch(body: b, body_ret: _, catch_param: _, catch_param_typ: _, catch_body: cb, catch_ret: _) ->
      let acc1 = count_raises_in_stmts(stmts: b, acc)
      return count_raises_in_stmts(stmts: cb, acc: acc1)
  end
end

let count_raises_in_expr = fn (expr: LirExpr, acc: i64) -> i64 do
  match expr do
    | LirExprRaise(value: _, typ: _) -> return acc + 1
    | _ -> return acc
  end
end
