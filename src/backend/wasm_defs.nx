export let ctx_externals = fn (ctx: CodegenCtx) -> [LirExternal] do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: e, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> e end
