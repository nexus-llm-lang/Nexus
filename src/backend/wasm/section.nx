/**
 * wasm/section: WASM binary section builders.
 *
 * Builds import, function, memory, global, export, and data sections.
 * Each builder returns a ByteBuffer containing the section content.
 *
 * Type-section deduplication is in section/type_section.nx.
 * Component-model (WASI preview3) wrappers are in section/component_model.nx.
 */

import { ByteBuffer }, * as bb from "std:bytebuffer"
import { LirExternal } from "src/ir/lir/types.nx"
import {
  StringEntry,
  LocalEntry,
  FuncEntry,
  ExportNameIdx
}, * as wdefs from "src/backend/wasm/defs.nx"
import { MemoryMode, MemoryNone, MemoryImported } from "src/backend/wasm/collect.nx"
import * as list from "std:list"

/** Module names are emitted as-is — namespaced names (nexus:std/math) stay
 *  as-is so the bundler can resolve them; file paths stay as file paths.
 */
let import_module_name = fn (module: string) -> string do
  return module
end

let emit_import_entries = fn (
  buf: %ByteBuffer,
  exts: [ LirExternal ],
  type_idxs: [ i64 ]
) -> %ByteBuffer do
  match exts do
    | [] -> return %buf
    | LirExternal(
      name: _,
      wasm_module: m,
      wasm_name: wn,
      params: _,
      ret_type: _,
      throw_row: _
    ) :: rest_exts ->
      match type_idxs do
        | [] -> return %buf  // size invariant: type_idxs matches exts length
        | ti :: rest_tis ->
          let %buf = wdefs.emit_name(%buf, name: import_module_name(module: m))
          let %buf = wdefs.emit_name(%buf, name: wn)
          let %buf = bb.push_byte(%buf, byte: wdefs.desc_func)
          let %buf = bb.push_uleb128(%buf, val: ti)
          return emit_import_entries(%buf, exts: rest_exts, type_idxs: rest_tis)
      end
  end
end

/** Imported linear memory for normal (p1) builds: `(import "<mod>" "memory" (memory 256 65536 shared))`.
 *  Declared `shared` (flags 0x03 = has-max | shared) so WASI-threads workers
 *  share it; `min 256` (16 MiB) comfortably exceeds any program's static data,
 *  so the heap (seeded to `memory.size()*65536` on first alloc) starts above
 *  all of it; `memory.grow` extends from there as needed.
 *  For p2-component builds, emits a non-shared import instead (flags 0x01)
 *  since the component model's canonical ABI requires non-shared memory.
 */
let maybe_emit_mem_import = fn (
  sec: %ByteBuffer,
  mem_mode: MemoryMode,
  p2_component: bool
) -> %ByteBuffer do
  if let MemoryImported(name: m) = mem_mode then
    let %sec = wdefs.emit_name(buf: %sec, name: import_module_name(module: m))
    let %sec = wdefs.emit_name(buf: %sec, name: "memory")
    if p2_component then
      let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.desc_memory, 1 ])
      let %sec = bb.push_uleb128(buf: %sec, val: 256)
      return bb.push_uleb128(buf: %sec, val: 65536)
    end
    let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.desc_memory, 3 ])
    let %sec = bb.push_uleb128(buf: %sec, val: 256)
    return bb.push_uleb128(buf: %sec, val: 65536)
  end
  return %sec
end

/** Build the wasm import section: optional shared-memory import (per `mem_mode`), each external from `exts` with its precomputed type index, and the three stdlib allocator imports (`allocate`, `__nx_alloc_mark`, `__nx_alloc_reset`) when `has_alloc`. Counts are summed and emitted as the section's leading ULEB. */
export let build_import_section = fn (exts: [ LirExternal ], ext_type_idxs: [ i64 ], mem_mode: MemoryMode,
                                      has_alloc: bool, alloc_type_idx: i64,
                                      alloc_mark_type_idx: i64, alloc_reset_type_idx: i64,
                                      alloc_module: string, p2_component: bool) -> %ByteBuffer do
  let n_exts = list.length(xs: exts)
  let has_mem_import = if let MemoryImported(_) = mem_mode then true else false end
  let mem_count = if has_mem_import then 1 else 0 end
  // 3 alloc imports when stdlib allocator is in use: allocate, alloc_mark,
  // alloc_reset. mark/reset wire `arena.heap_reset` through to the routed
  // allocator's LIFO bookkeeping so reset reclaims string concat / format /
  // substring / object allocations alongside the G0 bump pointer.
  let alloc_count = if has_alloc then 3 else 0 end
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: n_exts + mem_count + alloc_count)
  let %sec = maybe_emit_mem_import(%sec, mem_mode, p2_component)
  let %sec = emit_import_entries(buf: %sec, exts, type_idxs: ext_type_idxs)
  let %sec = if has_alloc then
    let %sec = wdefs.emit_name(buf: %sec, name: import_module_name(module: alloc_module))
    let %sec = wdefs.emit_name(buf: %sec, name: "allocate")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
    let %sec = bb.push_uleb128(buf: %sec, val: alloc_type_idx)
    let %sec = wdefs.emit_name(buf: %sec, name: import_module_name(module: alloc_module))
    let %sec = wdefs.emit_name(buf: %sec, name: "__nx_alloc_mark")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
    let %sec = bb.push_uleb128(buf: %sec, val: alloc_mark_type_idx)
    let %sec = wdefs.emit_name(buf: %sec, name: import_module_name(module: alloc_module))
    let %sec = wdefs.emit_name(buf: %sec, name: "__nx_alloc_reset")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
    bb.push_uleb128(buf: %sec, val: alloc_reset_type_idx)
  else %sec end
  return %sec
end

let emit_func_type_indices = fn (buf: %ByteBuffer, idxs: [ i64 ]) -> %ByteBuffer do
  match idxs do
    | [] -> return %buf
    | i :: rest ->
      return emit_func_type_indices(buf: bb.push_uleb128(%buf, val: i), idxs: rest)
  end
end

/** Emit the wasm function section: one ULEB type-index per internal function (in `func_type_idxs` order), the optional `cabi_realloc` entry, and the trailing `wasi:cli/run` wrapper's type index. */
export let build_function_section = fn (func_type_idxs: [ i64 ], wasi_run_type_idx: i64,
                                        has_cabi: bool, cabi_type_idx: i64) -> %ByteBuffer do
  let n_funcs = list.length(xs: func_type_idxs)
  let n_cabi = match has_cabi do | true -> 1 | false -> 0 end
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: n_funcs + n_cabi + 1)
  let %sec = emit_func_type_indices(buf: %sec, idxs: func_type_idxs)
  let %sec = if has_cabi then bb.push_uleb128(buf: %sec, val: cabi_type_idx) else %sec end
  let %sec = bb.push_uleb128(buf: %sec, val: wasi_run_type_idx)
  return %sec
end

/**
One linear memory, declared `shared` with an explicit max of 65536 pages
(the wasm32 4 GiB ceiling). Shared memory is required for `memory.atomic.*`
wait/notify and for the wasi-threads worker instances to share the heap.
Limits flags byte 0x03 = has-max (0x01) | shared (0x02).
*/
export let build_memory_section = fn (min_pages: i64) -> %ByteBuffer do
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: 1)
  let %sec = bb.push_byte(buf: %sec, byte: 3)
  let %sec = bb.push_uleb128(buf: %sec, val: min_pages)
  let %sec = bb.push_uleb128(buf: %sec, val: 65536)
  return %sec
end

/**
One linear memory declared without shared flag (non-shared, for p3 mode).
Limits flags byte 0x01 = has-max only (no shared bit).
Used when WASI preview3 is the target and wasi-threads shared memory is
not available (the module defines its own memory instead of importing it
from `env`).
*/
export let build_memory_section_unshared = fn (min_pages: i64) -> %ByteBuffer do
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: 1)
  let %sec = bb.push_byte(buf: %sec, byte: 1)
  let %sec = bb.push_uleb128(buf: %sec, val: min_pages)
  let %sec = bb.push_uleb128(buf: %sec, val: 65536)
  return %sec
end

/** Build the wasm global section with the fixed three-global prefix (G0 heap_base i32 mut, G1 str_base, G2 placeholder), the optional 7-global stack-switching block (cont-ref, resume-slot, next-alloc, resume-value, inject-value, pending-exn, pending-payload), and one `(valid:i32, key:i64, val:i64)` triple per memoization cache slot. Indices above the prefix encode the SS / memo offsets that downstream modules consume by name. */
export let build_global_section = fn (
  heap_base: i64,
  has_ss: bool,
  ss_cont_type_idx: i64,
  memo_cache_count: i64
) -> %ByteBuffer do
  let %sec = bb.empty()
  // Layout: G0 heap_base (i32 mut), G1 str_base (i32 mut), G2 placeholder (i32 mut),
  // [G3..G9: SS state if has_ss — cont-ref, resume-slot, next-alloc,
  // resume-value, inject-value, pending-exn, pending-payload], then 3 globals
  // per memoization slot (valid:i32 mut, key:i64 mut, val:i64 mut). Any
  // caller-side index above 2 (or 9 with SS) refers to a memo cache slot via
  // memo.memo_*_global_idx. MUST stay in lockstep with memo_globals_base in
  // codegen.nx (both encode the SS block size).
  let n_globals = 3 + (if has_ss then 7 else 0 end) + 3 * memo_cache_count
  let %sec = bb.push_uleb128(buf: %sec, val: n_globals)
  let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.vt_i32, 1, wdefs.op_i32_const ])
  let %sec = bb.push_sleb128(buf: %sec, val: heap_base)
  let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.op_end, wdefs.vt_i32, 1, wdefs.op_i32_const ])
  let %sec = bb.push_sleb128(buf: %sec, val: 0)
  let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.op_end, wdefs.vt_i32, 1, wdefs.op_i32_const ])
  let %sec = bb.push_sleb128(buf: %sec, val: 0)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
  let %sec = if has_ss then
    // global 3: (ref null (cont $type)) — current cont ref
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.vt_ref_null_ht)
    let %sec = bb.push_sleb128(buf: %sec, val: ss_cont_type_idx)
    let %sec = bb.push_bytes(buf: %sec, bytes: [ 1, wdefs.op_ref_null ])
    let %sec = bb.push_sleb128(buf: %sec, val: ss_cont_type_idx)
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
    // global 4: i64 (ss_resume_slot) — which cont table slot to resume next
    let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.vt_i64, 1, wdefs.op_i64_const ])
    let %sec = bb.push_sleb128(buf: %sec, val: 0)
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
    // global 5: i64 (ss_next_alloc) — next free cont table slot
    let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.vt_i64, 1, wdefs.op_i64_const ])
    let %sec = bb.push_sleb128(buf: %sec, val: 1)
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
    // global 6: i64 (ss_resume_value) — value resume passes back to suspend
    let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.vt_i64, 1, wdefs.op_i64_const ])
    let %sec = bb.push_sleb128(buf: %sec, val: 0)
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
    // global 7: i64 (ss_inject_value) — value the inject body yields on completion
    let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.vt_i64, 1, wdefs.op_i64_const ])
    let %sec = bb.push_sleb128(buf: %sec, val: 0)
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
    // global 8: i64 (ss_pending_exn) — 0/1 flag for a throw caught inside a
    // resumed __inject_N continuation, re-thrown by the dispatcher on the
    // parent stack (wasmtime swallows throws across resume; see nexus-uqpe4).
    let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.vt_i64, 1, wdefs.op_i64_const ])
    let %sec = bb.push_sleb128(buf: %sec, val: 0)
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
    // global 9: i64 (ss_pending_payload) — payload of the pending escaped throw.
    let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.vt_i64, 1, wdefs.op_i64_const ])
    let %sec = bb.push_sleb128(buf: %sec, val: 0)
    bb.push_byte(buf: %sec, byte: wdefs.op_end)
  else %sec end
  // Per-memo-target trio: valid:i32 mut, key:i64 mut, val:i64 mut. Each
  // initialises to zero so the validity guard rejects the first lookup.
  return emit_memo_cache_globals(buf: %sec, remaining: memo_cache_count)
end

let emit_memo_cache_globals = fn (buf: %ByteBuffer, remaining: i64) -> %ByteBuffer do
  if remaining <= 0 then return %buf end
  // valid:i32 mut, init 0
  let %buf = bb.push_bytes(%buf, bytes: [ wdefs.vt_i32, 1, wdefs.op_i32_const ])
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_end)
  // key:i64 mut, init 0
  let %buf = bb.push_bytes(%buf, bytes: [ wdefs.vt_i64, 1, wdefs.op_i64_const ])
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_end)
  // val:i64 mut, init 0
  let %buf = bb.push_bytes(%buf, bytes: [ wdefs.vt_i64, 1, wdefs.op_i64_const ])
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_end)
  return emit_memo_cache_globals(%buf, remaining: remaining - 1)
end

let append_mem_export = fn (sec: %ByteBuffer) -> %ByteBuffer do
  let %sec = wdefs.emit_name(buf: %sec, name: "memory")
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_memory)
  let %sec = bb.push_uleb128(buf: %sec, val: 0)
  return %sec
end

/** Build the wasm export section: the `main`/`_start`/`wasi:cli/run` triple (all pointing at the wasi-run wrapper), optional `memory` / `cabi_realloc` / `__indirect_function_table` / SS-cont-table exports keyed off the booleans, plus any `extra_exports` the host needs (e.g. `wasi_thread_start`). */
export let build_export_section = fn (main_idx: i64, wasi_run_idx: i64,
                                      cabi_realloc_idx: i64, has_cabi_realloc: bool,
                                      mem_mode: MemoryMode, has_table: bool, has_ss: bool,
                                      extra_exports: [ ExportNameIdx ]) -> %ByteBuffer do
  let has_mem_export = if let MemoryNone = mem_mode then false else true end
  let mem_count = match has_mem_export do | true -> 1 | false -> 0 end
  let cabi_count = match has_cabi_realloc do | true -> 1 | false -> 0 end
  let table_count = match has_table do | true -> 1 | false -> 0 end
  let ss_count = match has_ss do | true -> 1 | false -> 0 end
  let extra_count = list.length(xs: extra_exports)
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(
    buf: %sec,
    val: 3 + mem_count + cabi_count + table_count + ss_count + extra_count
  )
  // Export "main" and "_start" as wasi_run wrapper (func() -> ()).
  // The wasi_run wrapper calls argv() → main(args) internally.
  let %sec = wdefs.emit_name(buf: %sec, name: "main")
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
  let %sec = bb.push_uleb128(buf: %sec, val: wasi_run_idx)
  let %sec = wdefs.emit_name(buf: %sec, name: "_start")
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
  let %sec = bb.push_uleb128(buf: %sec, val: wasi_run_idx)
  let %sec = wdefs.emit_name(buf: %sec, name: "wasi:cli/run@0.2.6#run")
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
  let %sec = bb.push_uleb128(buf: %sec, val: wasi_run_idx)
  let %sec = if has_cabi_realloc then
    let %sec = wdefs.emit_name(buf: %sec, name: "cabi_realloc")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
    bb.push_uleb128(buf: %sec, val: cabi_realloc_idx)
  else %sec end
  let %sec = if has_mem_export then
    append_mem_export(%sec)
  else %sec end
  let %sec = if has_table then
    let %sec = wdefs.emit_name(buf: %sec, name: "__indirect_function_table")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_table)
    bb.push_uleb128(buf: %sec, val: 0)
  else %sec end
  let %sec = if has_ss then
    let %sec = wdefs.emit_name(buf: %sec, name: "__nx_sched_resume_slot")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_global)
    bb.push_uleb128(buf: %sec, val: wdefs.ss_resume_slot_global_idx)
  else %sec end
  return append_extra_exports(%sec, exports: extra_exports)
end

/** Append extra `(name, func)` entries to the export section
 *  (e.g. `wasi_thread_start`, the WASI-threads worker trampoline).
 */
let append_extra_exports = fn (sec: %ByteBuffer, exports: [ ExportNameIdx ]) -> %ByteBuffer do
  match exports do
    | [] -> return %sec
    | ExportNameIdx(name: n, index: idx) :: rest ->
      let %sec = wdefs.emit_name(buf: %sec, name: n)
      let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
      let %sec = bb.push_uleb128(buf: %sec, val: idx)
      return append_extra_exports(%sec, exports: rest)
  end
end

let emit_data_segments = fn (buf: %ByteBuffer, entries: [ StringEntry ]) -> %ByteBuffer do
  match entries do
    | [] -> %buf
    | StringEntry(value: v, offset: off, slen: sl) :: rest ->
      let %buf = bb.push_bytes(%buf, bytes: [ 0, wdefs.op_i32_const ])
      let %buf = bb.push_sleb128(%buf, val: off)
      let %buf = bb.push_byte(%buf, byte: wdefs.op_end)
      let %buf = bb.push_uleb128(%buf, val: sl)
      let %buf = bb.push_string(%buf, s: v)
      emit_data_segments(%buf, entries: rest)
  end
end

/** Build the data section. String literals get one active segment each. When
 *  `cell_init >= 0`, also emit a 4-byte active segment at offset
 *  `wdefs.heap_ptr_cell` initialising the atomic bump cell to `cell_init`
 *  (little-endian i32). Codegen passes `cell_init = -1` (no such segment):
 *  under WASI threads a per-instance cell-0 data segment would clobber the
 *  shared bump pointer, so the cell is lazily seeded instead.
 */
let emit_cell_init_segment = fn (buf: %ByteBuffer, cell_init: i64) -> %ByteBuffer do
  // active data segment: flags=0x00, i32.const(heap_ptr_cell), end, len=4, <4 LE bytes>
  let %buf = bb.push_bytes(%buf, bytes: [ 0, wdefs.op_i32_const ])
  let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_end)
  let %buf = bb.push_uleb128(%buf, val: 4)
  let %buf = bb.push_byte(%buf, byte: cell_init & 255)
  let b1 = (cell_init >> 8) & 255
  let %buf = bb.push_byte(%buf, byte: b1)
  let b2 = (cell_init >> 16) & 255
  let %buf = bb.push_byte(%buf, byte: b2)
  let b3 = (cell_init >> 24) & 255
  return bb.push_byte(%buf, byte: b3)
end

/** Build the wasm data section: one passive-style active segment per `StringEntry` placing its bytes at the entry's `offset`, plus (when `cell_init >= 0`) a 4-byte init segment for `wdefs.heap_ptr_cell` so the bump pointer starts at the first byte past the string-literal pool. */
export let build_data_section = fn (entries: [ StringEntry ], cell_init: i64) -> %ByteBuffer do
  let %sec = bb.empty()
  let has_cell = cell_init >= 0
  let extra = if has_cell then 1 else 0 end
  let n_segs = list.length(xs: entries) + extra
  let %sec = bb.push_uleb128(buf: %sec, val: n_segs)
  let %sec = if has_cell then emit_cell_init_segment(buf: %sec, cell_init) else %sec end
  let %sec = emit_data_segments(buf: %sec, entries)
  return %sec
end

let count_non_param_locals = fn (locals: [ LocalEntry ], param_count: i64) -> i64 do
  match locals do
    | [] -> return 0
    | LocalEntry(name: _, index: idx, valtype: _) :: rest ->
      return if idx >= param_count then
        1 + count_non_param_locals(locals: rest, param_count)
      else
        count_non_param_locals(locals: rest, param_count)
      end
  end
end

let emit_one_local = fn (buf: %ByteBuffer, idx: i64, vt: i64, param_count: i64) -> %ByteBuffer do
  if idx < param_count then return %buf end
  let %buf = bb.push_uleb128(%buf, val: 1)
  return bb.push_byte(%buf, byte: vt)
end

let emit_local_entries = fn (
  buf: %ByteBuffer,
  locals: [ LocalEntry ],
  param_count: i64
) -> %ByteBuffer do
  match locals do
    | [] -> return %buf
    | LocalEntry(name: _, index: idx, valtype: vt) :: rest ->
      let %buf = emit_one_local(%buf, idx, vt, param_count)
      return emit_local_entries(%buf, locals: rest, param_count)
  end
end

/** Emit the per-function local declaration prefix that goes inside each code-section entry: every non-param `LocalEntry` from `locals` followed by the fixed reserved-temps block (2 i64, 2 i32, 2 i64, 7 i32, 1 i64 tcmc_head, 1 i32 tcmc_prev, 2 i64 memo key/val, 1 i64 inject cur_slot). The indices of those reserved temps are computed by callers as `temps_base + offset`. */
export let emit_local_decls = fn (
  buf: %ByteBuffer,
  locals: [ LocalEntry ],
  param_count: i64
) -> %ByteBuffer do
  let n = count_non_param_locals(locals, param_count)
  let %buf = bb.push_uleb128(%buf, val: n + 9)
  let %buf = emit_local_entries(%buf, locals: list.reverse(xs: locals), param_count)
  // Reserved temps: 2x i64, 2x i32, 2x i64, 7x i32, 1x i64 (tcmc_head),
  // 1x i32 (tcmc_prev), 2x i64 (memo key/val), 1x i64 (inject dispatcher
  // cur_slot, temps_base + 17 — the per-frame "slot being resumed" the inject
  // loop reuses for the suspend reify so a long-running coop loop does not
  // exhaust the cont table). Layout indices are derived from temps_base + offset.
  let %buf = bb.push_uleb128(%buf, val: 2)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  let %buf = bb.push_uleb128(%buf, val: 2)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
  let %buf = bb.push_uleb128(%buf, val: 2)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  let %buf = bb.push_uleb128(%buf, val: 7)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
  let %buf = bb.push_uleb128(%buf, val: 2)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  // inject dispatcher base_alloc (temps_base + 18): the ss_next_alloc high-water
  // captured at THIS inject's setup, reset on @outer exit so the inject's cont
  // slots are reclaimed — sequential injects don't accumulate toward the fixed
  // 64-slot cont table. nexus-kidtq (companion to cur_slot +17).
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  return %buf
end

/** Build table section. Table 0: funcref for closures. Table 1 (when has_ss):
 *  nullable cont ref for stack-switching scheduler.
 */
export let build_table_section = fn (
  n_closures: i64,
  has_ss: bool,
  ss_cont_type_idx: i64
) -> %ByteBuffer do
  let n_tables = 1 + (if has_ss then 1 else 0 end)
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: n_tables)
  // table 0: funcref. Initial size = max(n_closures, 1024). The floor matters
  // when this module is later merged in as the stdlib dep: the stdlib-merge
  // step copies the dep's table verbatim and lays the mergee's closures into
  // slots [0..mergee_closure_count), so the dep's table must be at least that
  // big. 1024 comfortably covers any program's closure count (the compiler
  // itself has ~2). Slots past n_closures stay null and are never accessed.
  let table0_min = if n_closures > 1024 then n_closures else 1024 end
  let %sec = bb.push_bytes(buf: %sec, bytes: [ wdefs.vt_funcref, 0 ])
  let %sec = bb.push_uleb128(buf: %sec, val: table0_min)
  if has_ss then
    // table 1: (ref null (cont $type)), limits min=64 max=64
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.vt_ref_null_ht)
    let %sec = bb.push_sleb128(buf: %sec, val: ss_cont_type_idx)
    let %sec = bb.push_byte(buf: %sec, byte: 1)
    let %sec = bb.push_uleb128(buf: %sec, val: 64)
    let %sec = bb.push_uleb128(buf: %sec, val: 64)
    return %sec
  end
  return %sec
end

let emit_elem_func_indices = fn (buf: %ByteBuffer, entries: [ FuncEntry ]) -> %ByteBuffer do
  match entries do
    | [] -> return %buf
    | FuncEntry(name: _, index: idx) :: rest ->
      return emit_elem_func_indices(buf: bb.push_uleb128(%buf, val: idx), entries: rest)
  end
end

/** Build element section: active segment, table 0, offset 0, func indices. */
export let build_element_section = fn (closure_entries: [ FuncEntry ]) -> %ByteBuffer do
  let n = list.length(xs: closure_entries)
  let %sec = bb.empty()
  // 1 segment
  let %sec = bb.push_uleb128(buf: %sec, val: 1)
  // Active segment: table index 0
  let %sec = bb.push_byte(buf: %sec, byte: 0)
  // Offset expr: i32.const 0; end
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_i32_const)
  let %sec = bb.push_sleb128(buf: %sec, val: 0)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
  // Function indices
  let %sec = bb.push_uleb128(buf: %sec, val: n)
  let %sec = emit_elem_func_indices(buf: %sec, entries: closure_entries)
  return %sec
end

/** Emit the tag section. The exception tag (when has_eh) is at tag-idx 0;
 *  the stack-switching tag (when has_ss) is appended at tag-idx (has_eh ? 1 : 0).
 *  Both share the (i64) -> () func-type signature today.
 */
export let build_tag_section = fn (exn_tag_type_idx: i64, ss_tag_type_idx: i64,
                                    has_eh: bool, n_ss_tags: i64) -> %ByteBuffer do
  let n = (if has_eh then 1 else 0 end) + n_ss_tags
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: n)
  let %sec = if has_eh then
    let %s = bb.push_byte(buf: %sec, byte: 0)
    bb.push_uleb128(buf: %s, val: exn_tag_type_idx)
  else %sec end
  return emit_n_ss_tags(buf: %sec, ss_tag_type_idx, n: n_ss_tags)
end

let emit_n_ss_tags = fn (buf: %ByteBuffer, ss_tag_type_idx: i64, n: i64) -> %ByteBuffer do
  if n <= 0 then return %buf end
  let %buf = bb.push_byte(%buf, byte: 0)
  let %buf = bb.push_uleb128(%buf, val: ss_tag_type_idx)
  return emit_n_ss_tags(%buf, ss_tag_type_idx, n: n - 1)
end
