/**
 * wasm/section: WASM binary section builders.
 *
 * Builds type, import, function, memory, global, export, and data sections.
 * Each builder returns a ByteBuffer containing the section content.
 */

import { ByteBuffer }, * as bb from "std:bytebuffer"
import { StringMap, Found, Missing }, * as sm from "std:stringmap"
import * as str from "std:str"
import { TypeExpr } from "src/common/ast.nx"
import { LirProgram, LirFunction, LirExternal, LirParam } from "src/ir/lir/types.nx"
import { StringEntry, LocalEntry, FuncEntry, ExportNameIdx }, * as wdefs from "src/backend/wasm/defs.nx"
import { MemoryMode, MemoryNone, MemoryDefined, MemoryImported }, * as wcollect from "src/backend/wasm/collect.nx"
import * as list from "std:list"

// ─── Type section ───────────────────────────────────────────────────────────

let emit_ext_param_types = fn (buf: %ByteBuffer, params: [LirParam]) -> %ByteBuffer do
  match params do
    | [] -> %buf
    | LirParam(label: _, name: _, typ: t) :: rest ->
      let %buf = match wdefs.peel_linear(typ: t) do
        | TyString | TyArray(_) ->
          let %b = bb.push_byte(%buf, byte: wdefs.vt_i32)
          bb.push_byte(buf: %b, byte: wdefs.vt_i32)
        | TyChar -> bb.push_byte(%buf, byte: wdefs.vt_i32)
        | _ -> bb.push_byte(%buf, byte: wdefs.type_to_valtype(typ: t))
      end
      emit_ext_param_types(%buf, params: rest)
  end
end

let ext_return_valtype = fn (typ: TypeExpr) -> i64 do
  return if let TyChar = wdefs.peel_linear(typ) then wdefs.vt_i32 else wdefs.type_to_valtype(typ) end
end

let emit_ext_return_type = fn (buf: %ByteBuffer, typ: TypeExpr) -> %ByteBuffer do
  if wdefs.is_unit(typ) then return bb.push_uleb128(%buf, val: 0)
  else
    let %buf = bb.push_uleb128(%buf, val: 1)
    return bb.push_byte(%buf, byte: ext_return_valtype(typ))
  end
end

let emit_internal_param_types = fn (buf: %ByteBuffer, params: [LirParam]) -> %ByteBuffer do
  match params do
    | [] -> %buf
    | LirParam(label: _, name: _, typ: t) :: rest ->
      emit_internal_param_types(buf: bb.push_byte(%buf, byte: wdefs.type_to_valtype(typ: t)), params: rest)
  end
end

/** Check if an external uses canonical string return (retptr convention).
 *  Component-model externals (wasm_module contains ':') that return string
 *  use void return + retptr param instead of packed i64 return.
 */
let ext_uses_canonical_string_return = fn (wasm_module: string, ret_type: TypeExpr) -> bool do
  if str.contains(s: wasm_module, sub: ":") then
    if wasm_module == "nexus:intrinsic" then return false end
    if str.starts_with(s: wasm_module, prefix: "nexus:runtime/") then return false end
    if str.starts_with(s: wasm_module, prefix: "nexus:std/") then return false end
    match wdefs.peel_linear(typ: ret_type) do
      | TyString -> return true
      | _ -> return false
    end
  end
  return false
end

// ─── Single-entry emitters (write one type entry into a scratch buffer) ─────

let emit_one_ext_type = fn (scratch: %ByteBuffer, ext: LirExternal) -> %ByteBuffer do
  let LirExternal(name: _, wasm_module: m, wasm_name: _, params: ps, ret_type: rt, throw_row: _) = ext
  let canonical_str_ret = ext_uses_canonical_string_return(wasm_module: m, ret_type: rt)
  // For canonical string return: add 1 slot for retptr param
  let extra_params = match canonical_str_ret do | true -> 1 | false -> 0 end
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: wcollect.count_ext_param_slots(params: ps) + extra_params)
  let %buf = emit_ext_param_types(%buf, params: ps)
  return if canonical_str_ret then
    // Canonical string return: retptr (i32) as last param, void return
    let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
    bb.push_uleb128(%buf, val: 0)
  else
    emit_ext_return_type(%buf, typ: rt)
  end
end

let emit_one_func_type = fn (scratch: %ByteBuffer, func: LirFunction) -> %ByteBuffer do
  let LirFunction(name: _, params: ps, ret_type: rt, body: _, ret: _, span: _) = func
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: list.length(xs: ps))
  let %buf = emit_internal_param_types(%buf, params: ps)
  return emit_ext_return_type(%buf, typ: rt)
end

let emit_n_i64_params = fn (buf: %ByteBuffer, count: i64) -> %ByteBuffer do
  if count <= 0 then return %buf
  else emit_n_i64_params(buf: bb.push_byte(%buf, byte: wdefs.vt_i64), count: count - 1)
  end
end

/** Emit a closure call type: (N+1 x i64) -> i64 (env + N args → result). */
let emit_one_closure_type = fn (scratch: %ByteBuffer, arity: i64) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: arity + 1)
  let %buf = emit_n_i64_params(%buf, count: arity + 1)
  let %buf = bb.push_uleb128(%buf, val: 1)
  return bb.push_byte(%buf, byte: wdefs.vt_i64)
end

// ─── Dedup builder ──────────────────────────────────────────────────────────
// Deduplicates type entries by their raw byte signature. The section buffer
// accumulates only first-occurrence entries; duplicates reuse an existing
// canonical index.
//
// State is threaded through function calls as three parallel values
// (section, seen, n_unique) rather than a single %TypeDedupBuilder record.
// Reason: Nexus's typechecker does not currently preserve linearity for
// user-type fields when destructuring records — a `%MyRecord` field
// destructured cannot be passed back as a `%MyRecord`. Only opaque
// primitive fields (%ByteBuffer, %StringMap) can be relinearized via a
// round-trip through a typed identity function (launder_buf/launder_smap).

let launder_buf = fn (b: %ByteBuffer) -> %ByteBuffer do return %b end
let launder_smap = fn (m: %StringMap) -> %StringMap do return %m end

// Commit-step result: primitive linear fields + canonical index.
type CommitStep = CommitStep(section: %ByteBuffer, seen: %StringMap, n_unique: i64, idx: i64)
// Commit-list result (for loops over exts/funcs/closures): primitives + the
// per-entity canonical index list (in original order).
type CommitList = CommitList(section: %ByteBuffer, seen: %StringMap, n_unique: i64, idxs: [i64])

/** Encode a byte range as decimal-CSV (e.g., "96,2,127,127,1,127,"). UTF-8 safe
 *  regardless of byte values — every emitted character is ASCII digit or comma.
 */
let buf_range_key_go = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, end_pos: i64) -> %ByteBuffer do
  if pos >= end_pos then return %out end
  let b = bb.get_byte(buf: src, idx: pos)
  let %out = bb.push_string(buf: %out, s: str.from_i64(val: b))
  let %out = bb.push_byte(buf: %out, byte: 44)  // ','
  return buf_range_key_go(%out, src, pos: pos + 1, end_pos)
end

let buf_range_to_key = fn (src: &ByteBuffer, end_pos: i64) -> string do
  let %scratch = bb.empty()
  let %scratch = buf_range_key_go(out: %scratch, src, pos: 0, end_pos)
  let key = bb.to_string(buf: &scratch)
  bb.free(buf: %scratch)
  return key
end

/** Commit a scratch buffer (containing exactly one type entry starting at 0).
 *  Frees scratch. Returns updated (section, seen, n_unique) + the canonical
 *  index for the entry (existing slot if the signature was already seen, else
 *  the newly-assigned slot).
 */
let td_commit = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, scratch: %ByteBuffer) -> %CommitStep do
  let slen = bb.length(buf: &scratch)
  let key = buf_range_to_key(src: &scratch, end_pos: slen)
  match sm.get(map: &seen, key) do
    | Found(value: canonical_idx) ->
      bb.free(buf: %scratch)
      let %r = CommitStep(%section, %seen, n_unique, idx: canonical_idx)
      return %r
    | Missing ->
      let %section = bb.copy_range(dst: %section, src: &scratch, start: 0, end_pos: slen)
      bb.free(buf: %scratch)
      let %seen = sm.put(map: %seen, key, value: n_unique)
      let %r = CommitStep(%section, %seen, n_unique: n_unique + 1, idx: n_unique)
      return %r
  end
end

let commit_exts_go = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, exts: [LirExternal], acc: [i64]) -> %CommitList do
  match exts do
    | [] ->
      let %r = CommitList(%section, %seen, n_unique, idxs: list.reverse(xs: acc))
      return %r
    | e :: rest ->
      let %scratch = bb.empty()
      let %scratch = emit_one_ext_type(%scratch, ext: e)
      let CommitStep(%section, %seen, n_unique: nu, idx: ti) = td_commit(%section, %seen, n_unique, %scratch)
      let %section = launder_buf(b: %section)
      let %seen = launder_smap(m: %seen)
      return commit_exts_go(%section, %seen, n_unique: nu, exts: rest, acc: ti :: acc)
  end
end

let commit_funcs_go = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, funcs: [LirFunction], acc: [i64]) -> %CommitList do
  match funcs do
    | [] ->
      let %r = CommitList(%section, %seen, n_unique, idxs: list.reverse(xs: acc))
      return %r
    | f :: rest ->
      let %scratch = bb.empty()
      let %scratch = emit_one_func_type(%scratch, func: f)
      let CommitStep(%section, %seen, n_unique: nu, idx: ti) = td_commit(%section, %seen, n_unique, %scratch)
      let %section = launder_buf(b: %section)
      let %seen = launder_smap(m: %seen)
      return commit_funcs_go(%section, %seen, n_unique: nu, funcs: rest, acc: ti :: acc)
  end
end

let commit_closures_go = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, arities: [i64], acc: [i64]) -> %CommitList do
  match arities do
    | [] ->
      let %r = CommitList(%section, %seen, n_unique, idxs: list.reverse(xs: acc))
      return %r
    | a :: rest ->
      let %scratch = bb.empty()
      let %scratch = emit_one_closure_type(%scratch, arity: a)
      let CommitStep(%section, %seen, n_unique: nu, idx: ti) = td_commit(%section, %seen, n_unique, %scratch)
      let %section = launder_buf(b: %section)
      let %seen = launder_smap(m: %seen)
      return commit_closures_go(%section, %seen, n_unique: nu, arities: rest, acc: ti :: acc)
  end
end

let emit_wasi_run_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 0)
  return bb.push_uleb128(%buf, val: 0)
end

let emit_eh_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  return bb.push_uleb128(%buf, val: 0)
end

let emit_alloc_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
  let %buf = bb.push_uleb128(%buf, val: 1)
  return bb.push_byte(%buf, byte: wdefs.vt_i32)
end

/** `() -> i32` for `__nx_alloc_mark` — snapshots the routed allocator's
 *  LIFO bookkeeping count.
 */
let emit_alloc_mark_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 0)
  let %buf = bb.push_uleb128(%buf, val: 1)
  return bb.push_byte(%buf, byte: wdefs.vt_i32)
end

/** `(i32) -> ()` for `__nx_alloc_reset(mark)` — pops every routed allocation
 *  past `mark` in LIFO order.
 */
let emit_alloc_reset_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
  return bb.push_uleb128(%buf, val: 0)
end

let emit_cabi_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 4)
  let %buf = bb.push_bytes(%buf, bytes: [wdefs.vt_i32, wdefs.vt_i32, wdefs.vt_i32, wdefs.vt_i32])
  let %buf = bb.push_uleb128(%buf, val: 1)
  return bb.push_byte(%buf, byte: wdefs.vt_i32)
end

/** DedupedTypes carries the built type section payload plus per-entity
 *  canonical type indices. Sentinel -1 for entries not in this module.
 *  `alloc_mark_type_idx` / `alloc_reset_type_idx` index the `() -> i32` and
 *  `(i32) -> ()` shapes used by the routed allocator's mark/reset hooks.
 */
export type DedupedTypes = DedupedTypes(
  section: %ByteBuffer,
  count: i64,
  ext_type_idxs: [i64],
  func_type_idxs: [i64],
  wasi_run_type_idx: i64,
  exn_tag_type_idx: i64,
  ss_tag_type_idx: i64,
  alloc_type_idx: i64,
  alloc_mark_type_idx: i64,
  alloc_reset_type_idx: i64,
  cabi_type_idx: i64,
  closure_type_idxs: [i64],
  ss_cont_type_idx: i64,
  ss_dispatch_block_type_idx: i64
)

// Helper: skip a commit (returning CommitStep with idx = -1).
// Used to pass state through when a feature is not enabled.
let commit_skip = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64) -> %CommitStep do
  let %r = CommitStep(%section, %seen, n_unique, idx: -1)
  return %r
end

let commit_eh_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_eh: bool) -> %CommitStep do
  if has_eh then
    let %scratch = bb.empty()
    let %scratch = emit_eh_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

/** Commit the (i64) -> () func type used by stack-switching tags. If the
 *  program also has EH, this reuses the EH tag type via dedup.
 */
let commit_i64_to_void_type_for_ss = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_ss: bool) -> %CommitStep do
  if has_ss then
    let %scratch = bb.empty()
    let %scratch = emit_eh_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

/** `(cont $body_func_type)` form: byte 0x5d (form_cont = 93), then LEB
 *  of the body's func-type index.
 */
let emit_cont_type_scratch = fn (scratch: %ByteBuffer, body_func_type_idx: i64) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.form_cont)
  return bb.push_sleb128(%buf, val: body_func_type_idx)
end

/** Commit a fresh () -> () func type for the cont's body, bypassing dedup.
 *  Reusing wasi_run_idx is unreliable because the dedup map's behaviour for
 *  shared signatures is inconsistent for our use-case.
 */
let commit_ss_body_fn_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_ss: bool) -> %CommitStep do
  // PROBE: ALWAYS commit, ignore has_ss
  let %scratch = bb.empty()
  let %scratch = emit_wasi_run_type_scratch(%scratch)
  let slen = bb.length(buf: &scratch)
  let %section = bb.copy_range(dst: %section, src: &scratch, start: 0, end_pos: slen)
  bb.free(buf: %scratch)
  let %r = CommitStep(%section, %seen, n_unique: n_unique + 1, idx: n_unique)
  return %r
end

let commit_ss_cont_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_ss: bool, body_func_type_idx: i64) -> %CommitStep do
  if !has_ss then return commit_skip(%section, %seen, n_unique) end
  if body_func_type_idx < 0 then return commit_skip(%section, %seen, n_unique) end
  let %scratch = bb.empty()
  let %scratch = emit_cont_type_scratch(%scratch, body_func_type_idx)
  let slen = bb.length(buf: &scratch)
  let %section = bb.copy_range(dst: %section, src: &scratch, start: 0, end_pos: slen)
  bb.free(buf: %scratch)
  let %r = CommitStep(%section, %seen, n_unique: n_unique + 1, idx: n_unique)
  return %r
end

/** On-clause block type: returns (i64, ref null $cont_t). When `resume`'s
 *  on-clause fires, control transfers to the labeled block's end, pushing
 *  (payload, new-cont) onto the block's result stack.
 *  Encoding: 0x60 (func form) + 0 params + 2 results + i64 (0x7e) + ref-null
 *  heap (0x63 + signed-LEB cont_type_idx).
 */
let emit_ss_dispatch_block_type_scratch = fn (scratch: %ByteBuffer, cont_type_idx: i64) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 0)
  let %buf = bb.push_uleb128(%buf, val: 2)
  let %buf = bb.push_bytes(%buf, bytes: [wdefs.vt_i64, wdefs.vt_ref_null_ht])
  return bb.push_sleb128(%buf, val: cont_type_idx)
end

let commit_ss_dispatch_block_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_ss: bool, cont_type_idx: i64) -> %CommitStep do
  if !has_ss then return commit_skip(%section, %seen, n_unique) end
  if cont_type_idx < 0 then return commit_skip(%section, %seen, n_unique) end
  let %scratch = bb.empty()
  let %scratch = emit_ss_dispatch_block_type_scratch(%scratch, cont_type_idx)
  let slen = bb.length(buf: &scratch)
  let %section = bb.copy_range(dst: %section, src: &scratch, start: 0, end_pos: slen)
  bb.free(buf: %scratch)
  let %r = CommitStep(%section, %seen, n_unique: n_unique + 1, idx: n_unique)
  return %r
end

let commit_alloc_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_alloc: bool) -> %CommitStep do
  if has_alloc then
    let %scratch = bb.empty()
    let %scratch = emit_alloc_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

let commit_alloc_mark_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_alloc: bool) -> %CommitStep do
  if has_alloc then
    let %scratch = bb.empty()
    let %scratch = emit_alloc_mark_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

let commit_alloc_reset_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_alloc: bool) -> %CommitStep do
  if has_alloc then
    let %scratch = bb.empty()
    let %scratch = emit_alloc_reset_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

let commit_cabi_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_cabi: bool) -> %CommitStep do
  if has_cabi then
    let %scratch = bb.empty()
    let %scratch = emit_cabi_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

let commit_wasi_run_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64) -> %CommitStep do
  let %scratch = bb.empty()
  let %scratch = emit_wasi_run_type_scratch(%scratch)
  return td_commit(%section, %seen, n_unique, %scratch)
end

/** Build the type section with duplicate-signature deduplication.
 *  Returns the vector-count-prefixed payload + per-entity canonical type indices.
 *  The cont-type wrapping the lifted inject body reuses wasi_run_type's
 *  `() -> ()` signature today (all lifted bodies are unit-returning at MVP);
 *  extension to varied signatures is future work.
 */
export let build_type_section_dedup = fn (program: LirProgram, has_eh: bool, has_ss: bool,
                                          has_alloc: bool,
                                          has_cabi_realloc: bool, closure_arities: [i64]) -> %DedupedTypes do
  let LirProgram(functions: funcs, externals: exts) = program
  let %section = bb.empty()
  let %seen = sm.empty()

  let CommitList(%section, %seen, n_unique: nu_a, idxs: ext_idxs) =
    commit_exts_go(%section, %seen, n_unique: 0, exts, acc: [])
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)
  let CommitList(%section, %seen, n_unique: nu_b, idxs: func_idxs) =
    commit_funcs_go(%section, %seen, n_unique: nu_a, funcs, acc: [])
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu_c, idx: wasi_run_idx_raw) =
    commit_wasi_run_type(%section, %seen, n_unique: nu_b)
  let wasi_run_idx = wasi_run_idx_raw
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu_d, idx: exn_tag_idx) =
    commit_eh_type(%section, %seen, n_unique: nu_c, has_eh)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu_e, idx: ss_tag_idx) =
    commit_i64_to_void_type_for_ss(%section, %seen, n_unique: nu_d, has_ss)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu, idx: alloc_idx) =
    commit_alloc_type(%section, %seen, n_unique: nu_e, has_alloc)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu, idx: alloc_mark_idx) =
    commit_alloc_mark_type(%section, %seen, n_unique: nu, has_alloc)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu, idx: alloc_reset_idx) =
    commit_alloc_reset_type(%section, %seen, n_unique: nu, has_alloc)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu, idx: cabi_idx) =
    commit_cabi_type(%section, %seen, n_unique: nu, has_cabi: has_cabi_realloc)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitList(%section, %seen, n_unique: n_after_closures, idxs: closure_idxs) =
    commit_closures_go(%section, %seen, n_unique: nu, arities: closure_arities, acc: [])
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  // Stack-switching types committed AT THE END so their slot indices match
  // n_unique-after-closures. body_fn, cont, dispatch in that order.
  let CommitStep(%section, %seen, n_unique: n_after_body_fn, idx: ss_body_fn_idx) =
    commit_ss_body_fn_type(%section, %seen, n_unique: n_after_closures, has_ss)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: n_after_cont, idx: ss_cont_idx) =
    commit_ss_cont_type(%section, %seen, n_unique: n_after_body_fn, has_ss, body_func_type_idx: ss_body_fn_idx)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: n, idx: ss_dispatch_idx) =
    commit_ss_dispatch_block_type(%section, %seen, n_unique: n_after_cont, has_ss, cont_type_idx: ss_cont_idx)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)
  sm.free(map: %seen)

  // Finalize: prepend vector-count to section bytes.
  let %final = bb.empty()
  let %final = bb.push_uleb128(buf: %final, val: n)
  let %final = bb.push_buf(dst: %final, src: &section)
  bb.free(buf: %section)
  let %r = DedupedTypes(
    section: %final,
    count: n,
    ext_type_idxs: ext_idxs,
    func_type_idxs: func_idxs,
    wasi_run_type_idx: wasi_run_idx,
    exn_tag_type_idx: exn_tag_idx,
    ss_tag_type_idx: ss_tag_idx,
    alloc_type_idx: alloc_idx,
    alloc_mark_type_idx: alloc_mark_idx,
    alloc_reset_type_idx: alloc_reset_idx,
    cabi_type_idx: cabi_idx,
    closure_type_idxs: closure_idxs,
    ss_cont_type_idx: ss_cont_idx,
    ss_dispatch_block_type_idx: ss_dispatch_idx
  )
  return %r
end

// ─── Import section ─────────────────────────────────────────────────────────

/** Module names are emitted as-is — namespaced names (nexus:std/math) stay
 *  as-is so the bundler can resolve them; file paths stay as file paths.
 */
let import_module_name = fn (module: string) -> string do
  return module
end

let emit_import_entries = fn (buf: %ByteBuffer, exts: [LirExternal], type_idxs: [i64]) -> %ByteBuffer do
  match exts do
    | [] -> %buf
    | LirExternal(name: _, wasm_module: m, wasm_name: wn, params: _, ret_type: _, throw_row: _) :: rest_exts ->
      match type_idxs do
        | [] -> %buf  // size invariant: type_idxs matches exts length
        | ti :: rest_tis ->
          let %buf = wdefs.emit_name(%buf, name: import_module_name(module: m))
          let %buf = wdefs.emit_name(%buf, name: wn)
          let %buf = bb.push_byte(%buf, byte: wdefs.desc_func)
          let %buf = bb.push_uleb128(%buf, val: ti)
          emit_import_entries(%buf, exts: rest_exts, type_idxs: rest_tis)
      end
  end
end

/** Imported linear memory: `(import "<mod>" "memory" (memory 256 65536 shared))`.
 *  Declared `shared` (flags 0x03 = has-max | shared) so WASI-threads workers
 *  share it; `min 256` (16 MiB) comfortably exceeds any program's static data,
 *  so the heap (seeded to `memory.size()*65536` on first alloc) starts above
 *  all of it; `memory.grow` extends from there as needed.
 */
let maybe_emit_mem_import = fn (sec: %ByteBuffer, mem_mode: MemoryMode) -> %ByteBuffer do
  if let MemoryImported(name: m) = mem_mode then
    let %sec = wdefs.emit_name(buf: %sec, name: import_module_name(module: m))
    let %sec = wdefs.emit_name(buf: %sec, name: "memory")
    let %sec = bb.push_bytes(buf: %sec, bytes: [wdefs.desc_memory, 3])
    let %sec = bb.push_uleb128(buf: %sec, val: 256)
    return bb.push_uleb128(buf: %sec, val: 65536)
  end
  return %sec
end

/** Build the wasm import section: optional shared-memory import (per `mem_mode`), each external from `exts` with its precomputed type index, and the three stdlib allocator imports (`allocate`, `__nx_alloc_mark`, `__nx_alloc_reset`) when `has_alloc`. Counts are summed and emitted as the section's leading ULEB. */
export let build_import_section = fn (exts: [LirExternal], ext_type_idxs: [i64], mem_mode: MemoryMode,
                                      has_alloc: bool, alloc_type_idx: i64,
                                      alloc_mark_type_idx: i64, alloc_reset_type_idx: i64,
                                      alloc_module: string) -> %ByteBuffer do
  let n_exts = list.length(xs: exts)
  let has_mem_import = if let MemoryImported(_) = mem_mode then true else false end
  let mem_count = if has_mem_import then 1 else 0 end
  // 3 alloc imports when stdlib allocator is in use: allocate, alloc_mark,
  // alloc_reset. mark/reset wire `arena.heap_reset` through to the routed
  // allocator's LIFO bookkeeping so reset reclaims string concat / format /
  // substring / object allocations alongside the G0 bump pointer.
  let alloc_count = if has_alloc then 3 else 0 end
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: n_exts + mem_count + alloc_count)
  let %sec = maybe_emit_mem_import(%sec, mem_mode)
  let %sec = emit_import_entries(buf: %sec, exts, type_idxs: ext_type_idxs)
  let %sec = if has_alloc then
    let %sec = wdefs.emit_name(buf: %sec, name: import_module_name(module: alloc_module))
    let %sec = wdefs.emit_name(buf: %sec, name: "allocate")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
    let %sec = bb.push_uleb128(buf: %sec, val: alloc_type_idx)
    let %sec = wdefs.emit_name(buf: %sec, name: import_module_name(module: alloc_module))
    let %sec = wdefs.emit_name(buf: %sec, name: "__nx_alloc_mark")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
    let %sec = bb.push_uleb128(buf: %sec, val: alloc_mark_type_idx)
    let %sec = wdefs.emit_name(buf: %sec, name: import_module_name(module: alloc_module))
    let %sec = wdefs.emit_name(buf: %sec, name: "__nx_alloc_reset")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
    bb.push_uleb128(buf: %sec, val: alloc_reset_type_idx)
  else %sec end
  return %sec
end

// ─── Function section ───────────────────────────────────────────────────────

let emit_func_type_indices = fn (buf: %ByteBuffer, idxs: [i64]) -> %ByteBuffer do
  match idxs do
    | [] -> %buf
    | i :: rest ->
      emit_func_type_indices(buf: bb.push_uleb128(%buf, val: i), idxs: rest)
  end
end

/** Emit the wasm function section: one ULEB type-index per internal function (in `func_type_idxs` order), the optional `cabi_realloc` entry, and the trailing `wasi:cli/run` wrapper's type index. */
export let build_function_section = fn (func_type_idxs: [i64], wasi_run_type_idx: i64,
                                        has_cabi: bool, cabi_type_idx: i64) -> %ByteBuffer do
  let n_funcs = list.length(xs: func_type_idxs)
  let n_cabi = match has_cabi do | true -> 1 | false -> 0 end
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: n_funcs + n_cabi + 1)
  let %sec = emit_func_type_indices(buf: %sec, idxs: func_type_idxs)
  let %sec = if has_cabi then bb.push_uleb128(buf: %sec, val: cabi_type_idx) else %sec end
  let %sec = bb.push_uleb128(buf: %sec, val: wasi_run_type_idx)
  return %sec
end

// ─── Memory section ─────────────────────────────────────────────────────────

/**
One linear memory, declared `shared` with an explicit max of 65536 pages
(the wasm32 4 GiB ceiling). Shared memory is required for `memory.atomic.*`
wait/notify and for the wasi-threads worker instances to share the heap.
Limits flags byte 0x03 = has-max (0x01) | shared (0x02).
*/
export let build_memory_section = fn (min_pages: i64) -> %ByteBuffer do
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: 1)
  let %sec = bb.push_byte(buf: %sec, byte: 3)
  let %sec = bb.push_uleb128(buf: %sec, val: min_pages)
  let %sec = bb.push_uleb128(buf: %sec, val: 65536)
  return %sec
end

/**
One linear memory declared without shared flag (non-shared, for p3 mode).
Limits flags byte 0x01 = has-max only (no shared bit).
Used when WASI preview3 is the target and wasi-threads shared memory is
not available (the module defines its own memory instead of importing it
from `env`).
*/
export let build_memory_section_unshared = fn (min_pages: i64) -> %ByteBuffer do
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: 1)
  let %sec = bb.push_byte(buf: %sec, byte: 1)
  let %sec = bb.push_uleb128(buf: %sec, val: min_pages)
  let %sec = bb.push_uleb128(buf: %sec, val: 65536)
  return %sec
end

// ─── Global section ─────────────────────────────────────────────────────────

/** Build the wasm global section with the fixed three-global prefix (G0 heap_base i32 mut, G1 str_base, G2 placeholder), the optional 3-global stack-switching block (cont-ref + resume slot + next-alloc), and one `(valid:i32, key:i64, val:i64)` triple per memoization cache slot. Indices above the prefix encode the SS / memo offsets that downstream modules consume by name. */
export let build_global_section = fn (heap_base: i64, has_ss: bool, ss_cont_type_idx: i64, memo_cache_count: i64) -> %ByteBuffer do
  let %sec = bb.empty()
  // Layout: G0 heap_base (i32 mut), G1 str_base (i32 mut), G2 placeholder (i32 mut),
  // [G3..G5: SS state if has_ss], then 3 globals per memoization slot
  // (valid:i32 mut, key:i64 mut, val:i64 mut). Any caller-side index above 2
  // (or 5 with SS) refers to a memo cache slot via memo.memo_*_global_idx.
  let n_globals = 3 + (if has_ss then 3 else 0 end) + 3 * memo_cache_count
  let %sec = bb.push_uleb128(buf: %sec, val: n_globals)
  let %sec = bb.push_bytes(buf: %sec, bytes: [wdefs.vt_i32, 1, wdefs.op_i32_const])
  let %sec = bb.push_sleb128(buf: %sec, val: heap_base)
  let %sec = bb.push_bytes(buf: %sec, bytes: [wdefs.op_end, wdefs.vt_i32, 1, wdefs.op_i32_const])
  let %sec = bb.push_sleb128(buf: %sec, val: 0)
  let %sec = bb.push_bytes(buf: %sec, bytes: [wdefs.op_end, wdefs.vt_i32, 1, wdefs.op_i32_const])
  let %sec = bb.push_sleb128(buf: %sec, val: 0)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
  let %sec = if has_ss then
    // global 3: (ref null (cont $type)) — current cont ref
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.vt_ref_null_ht)
    let %sec = bb.push_sleb128(buf: %sec, val: ss_cont_type_idx)
    let %sec = bb.push_bytes(buf: %sec, bytes: [1, wdefs.op_ref_null])
    let %sec = bb.push_sleb128(buf: %sec, val: ss_cont_type_idx)
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
    // global 4: i64 (ss_resume_slot) — which cont table slot to resume next
    let %sec = bb.push_bytes(buf: %sec, bytes: [wdefs.vt_i64, 1, wdefs.op_i64_const])
    let %sec = bb.push_sleb128(buf: %sec, val: 0)
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
    // global 5: i64 (ss_next_alloc) — next free cont table slot
    let %sec = bb.push_bytes(buf: %sec, bytes: [wdefs.vt_i64, 1, wdefs.op_i64_const])
    let %sec = bb.push_sleb128(buf: %sec, val: 1)
    bb.push_byte(buf: %sec, byte: wdefs.op_end)
  else %sec end
  // Per-memo-target trio: valid:i32 mut, key:i64 mut, val:i64 mut. Each
  // initialises to zero so the validity guard rejects the first lookup.
  return emit_memo_cache_globals(buf: %sec, remaining: memo_cache_count)
end

let emit_memo_cache_globals = fn (buf: %ByteBuffer, remaining: i64) -> %ByteBuffer do
  if remaining <= 0 then return %buf end
  // valid:i32 mut, init 0
  let %buf = bb.push_bytes(%buf, bytes: [wdefs.vt_i32, 1, wdefs.op_i32_const])
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_end)
  // key:i64 mut, init 0
  let %buf = bb.push_bytes(%buf, bytes: [wdefs.vt_i64, 1, wdefs.op_i64_const])
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_end)
  // val:i64 mut, init 0
  let %buf = bb.push_bytes(%buf, bytes: [wdefs.vt_i64, 1, wdefs.op_i64_const])
  let %buf = bb.push_sleb128(%buf, val: 0)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_end)
  return emit_memo_cache_globals(%buf, remaining: remaining - 1)
end

// ─── Export section ─────────────────────────────────────────────────────────

let append_mem_export = fn (sec: %ByteBuffer) -> %ByteBuffer do
  let %sec = wdefs.emit_name(buf: %sec, name: "memory")
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_memory)
  let %sec = bb.push_uleb128(buf: %sec, val: 0)
  return %sec
end

/** Build the wasm export section: the `main`/`_start`/`wasi:cli/run` triple (all pointing at the wasi-run wrapper), optional `memory` / `cabi_realloc` / `__indirect_function_table` / SS-cont-table exports keyed off the booleans, plus any `extra_exports` the host needs (e.g. `wasi_thread_start`). */
export let build_export_section = fn (main_idx: i64, wasi_run_idx: i64,
                                      cabi_realloc_idx: i64, has_cabi_realloc: bool,
                                      mem_mode: MemoryMode, has_table: bool, has_ss: bool,
                                      extra_exports: [ExportNameIdx]) -> %ByteBuffer do
  let has_mem_export = if let MemoryNone = mem_mode then false else true end
  let mem_count = match has_mem_export do | true -> 1 | false -> 0 end
  let cabi_count = match has_cabi_realloc do | true -> 1 | false -> 0 end
  let table_count = match has_table do | true -> 1 | false -> 0 end
  let ss_count = match has_ss do | true -> 1 | false -> 0 end
  let extra_count = list.length(xs: extra_exports)
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: 3 + mem_count + cabi_count + table_count + ss_count + extra_count)
  // Export "main" and "_start" as wasi_run wrapper (func() -> ()).
  // The wasi_run wrapper calls argv() → main(args) internally.
  let %sec = wdefs.emit_name(buf: %sec, name: "main")
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
  let %sec = bb.push_uleb128(buf: %sec, val: wasi_run_idx)
  let %sec = wdefs.emit_name(buf: %sec, name: "_start")
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
  let %sec = bb.push_uleb128(buf: %sec, val: wasi_run_idx)
  let %sec = wdefs.emit_name(buf: %sec, name: "wasi:cli/run@0.2.6#run")
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
  let %sec = bb.push_uleb128(buf: %sec, val: wasi_run_idx)
  let %sec = if has_cabi_realloc then
    let %sec = wdefs.emit_name(buf: %sec, name: "cabi_realloc")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
    bb.push_uleb128(buf: %sec, val: cabi_realloc_idx)
  else %sec end
  let %sec = if has_mem_export then
    append_mem_export(%sec)
  else %sec end
  let %sec = if has_table then
    let %sec = wdefs.emit_name(buf: %sec, name: "__indirect_function_table")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_table)
    bb.push_uleb128(buf: %sec, val: 0)
  else %sec end
  let %sec = if has_ss then
    let %sec = wdefs.emit_name(buf: %sec, name: "__nx_sched_resume_slot")
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_global)
    bb.push_uleb128(buf: %sec, val: wdefs.ss_resume_slot_global_idx)
  else %sec end
  return append_extra_exports(%sec, exports: extra_exports)
end

/** Append extra `(name, func)` entries to the export section (currently
 *  only `wasi_thread_start`, the WASI-threads worker trampoline).
 */
let append_extra_exports = fn (sec: %ByteBuffer, exports: [ExportNameIdx]) -> %ByteBuffer do
  match exports do
    | [] -> return %sec
    | ExportNameIdx(name: n, index: idx) :: rest ->
      let %sec = wdefs.emit_name(buf: %sec, name: n)
      let %sec = bb.push_byte(buf: %sec, byte: wdefs.desc_func)
      let %sec = bb.push_uleb128(buf: %sec, val: idx)
      return append_extra_exports(%sec, exports: rest)
  end
end

// ─── Data section ───────────────────────────────────────────────────────────

let emit_data_segments = fn (buf: %ByteBuffer, entries: [StringEntry]) -> %ByteBuffer do
  match entries do
    | [] -> %buf
    | StringEntry(value: v, offset: off, slen: sl) :: rest ->
      let %buf = bb.push_bytes(%buf, bytes: [0, wdefs.op_i32_const])
      let %buf = bb.push_sleb128(%buf, val: off)
      let %buf = bb.push_byte(%buf, byte: wdefs.op_end)
      let %buf = bb.push_uleb128(%buf, val: sl)
      let %buf = bb.push_string(%buf, s: v)
      emit_data_segments(%buf, entries: rest)
  end
end

/** Build the data section. String literals get one active segment each. When
 *  `cell_init >= 0`, also emit a 4-byte active segment at offset
 *  `wdefs.heap_ptr_cell` initialising the atomic bump cell to `cell_init`
 *  (little-endian i32). Codegen currently passes `cell_init = -1` (no such
 *  segment): under WASI threads a per-instance cell-0 data segment would
 *  clobber the shared bump pointer, so the cell is lazily seeded instead.
 */
let emit_cell_init_segment = fn (buf: %ByteBuffer, cell_init: i64) -> %ByteBuffer do
  // active data segment: flags=0x00, i32.const(heap_ptr_cell), end, len=4, <4 LE bytes>
  let %buf = bb.push_bytes(%buf, bytes: [0, wdefs.op_i32_const])
  let %buf = bb.push_sleb128(%buf, val: wdefs.heap_ptr_cell)
  let %buf = bb.push_byte(%buf, byte: wdefs.op_end)
  let %buf = bb.push_uleb128(%buf, val: 4)
  let %buf = bb.push_byte(%buf, byte: cell_init & 255)
  let b1 = (cell_init >> 8) & 255
  let %buf = bb.push_byte(%buf, byte: b1)
  let b2 = (cell_init >> 16) & 255
  let %buf = bb.push_byte(%buf, byte: b2)
  let b3 = (cell_init >> 24) & 255
  return bb.push_byte(%buf, byte: b3)
end

/** Build the wasm data section: one passive-style active segment per `StringEntry` placing its bytes at the entry's `offset`, plus (when `cell_init >= 0`) a 4-byte init segment for `wdefs.heap_ptr_cell` so the bump pointer starts at the first byte past the string-literal pool. */
export let build_data_section = fn (entries: [StringEntry], cell_init: i64) -> %ByteBuffer do
  let %sec = bb.empty()
  let has_cell = cell_init >= 0
  let extra = if has_cell then 1 else 0 end
  let n_segs = list.length(xs: entries) + extra
  let %sec = bb.push_uleb128(buf: %sec, val: n_segs)
  let %sec = if has_cell then emit_cell_init_segment(buf: %sec, cell_init) else %sec end
  let %sec = emit_data_segments(buf: %sec, entries)
  return %sec
end

// ─── Local declaration emission ─────────────────────────────────────────────

let count_non_param_locals = fn (locals: [LocalEntry], param_count: i64) -> i64 do
  match locals do
    | [] -> 0
    | LocalEntry(name: _, index: idx, valtype: _) :: rest ->
      return if idx >= param_count then
        1 + count_non_param_locals(locals: rest, param_count)
      else
        count_non_param_locals(locals: rest, param_count)
      end
  end
end

let emit_one_local = fn (buf: %ByteBuffer, idx: i64, vt: i64, param_count: i64) -> %ByteBuffer do
  if idx < param_count then return %buf end
  let %buf = bb.push_uleb128(%buf, val: 1)
  return bb.push_byte(%buf, byte: vt)
end

let emit_local_entries = fn (buf: %ByteBuffer, locals: [LocalEntry], param_count: i64) -> %ByteBuffer do
  match locals do
    | [] -> %buf
    | LocalEntry(name: _, index: idx, valtype: vt) :: rest ->
      let %buf = emit_one_local(%buf, idx, vt, param_count)
      emit_local_entries(%buf, locals: rest, param_count)
  end
end

/** Emit the per-function local declaration prefix that goes inside each code-section entry: every non-param `LocalEntry` from `locals` followed by the fixed reserved-temps block (2 i64, 2 i32, 2 i64, 7 i32, 1 i64 tcmc_head, 1 i32 tcmc_prev, 2 i64 memo key/val). The indices of those reserved temps are computed by callers as `temps_base + offset`. */
export let emit_local_decls = fn (buf: %ByteBuffer, locals: [LocalEntry], param_count: i64) -> %ByteBuffer do
  let n = count_non_param_locals(locals, param_count)
  let %buf = bb.push_uleb128(%buf, val: n + 7)
  let %buf = emit_local_entries(%buf, locals: list.reverse(xs: locals), param_count)
  // Reserved temps: 2x i64, 2x i32, 2x i64, 7x i32, 1x i64 (tcmc_head),
  // 1x i32 (tcmc_prev), 2x i64 (memo key/val).
  // Layout indices used elsewhere are derived from temps_base + offset.
  let %buf = bb.push_uleb128(%buf, val: 2)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  let %buf = bb.push_uleb128(%buf, val: 2)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
  let %buf = bb.push_uleb128(%buf, val: 2)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  let %buf = bb.push_uleb128(%buf, val: 7)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
  let %buf = bb.push_uleb128(%buf, val: 2)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  return %buf
end

// ─── Table section ─────────────────────────────────────────────────────────

/** Build table section. Table 0: funcref for closures. Table 1 (when has_ss):
 *  nullable cont ref for stack-switching scheduler.
 */
export let build_table_section = fn (n_closures: i64, has_ss: bool, ss_cont_type_idx: i64) -> %ByteBuffer do
  let n_tables = 1 + (if has_ss then 1 else 0 end)
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: n_tables)
  // table 0: funcref. Initial size = max(n_closures, 1024). The floor matters
  // when this module is later merged in as the stdlib dep: the stdlib-merge
  // step copies the dep's table verbatim and lays the mergee's closures into
  // slots [0..mergee_closure_count), so the dep's table must be at least that
  // big. 1024 comfortably covers any program's closure count (the compiler
  // itself has ~2). Slots past n_closures stay null and are never accessed.
  let table0_min = if n_closures > 1024 then n_closures else 1024 end
  let %sec = bb.push_bytes(buf: %sec, bytes: [wdefs.vt_funcref, 0])
  let %sec = bb.push_uleb128(buf: %sec, val: table0_min)
  if has_ss then
    // table 1: (ref null (cont $type)), limits min=64 max=64
    let %sec = bb.push_byte(buf: %sec, byte: wdefs.vt_ref_null_ht)
    let %sec = bb.push_sleb128(buf: %sec, val: ss_cont_type_idx)
    let %sec = bb.push_byte(buf: %sec, byte: 1)
    let %sec = bb.push_uleb128(buf: %sec, val: 64)
    let %sec = bb.push_uleb128(buf: %sec, val: 64)
    return %sec
  end
  return %sec
end

// ─── Element section ───────────────────────────────────────────────────────

let emit_elem_func_indices = fn (buf: %ByteBuffer, entries: [FuncEntry]) -> %ByteBuffer do
  match entries do
    | [] -> %buf
    | FuncEntry(name: _, index: idx) :: rest ->
      emit_elem_func_indices(buf: bb.push_uleb128(%buf, val: idx), entries: rest)
  end
end

/** Build element section: active segment, table 0, offset 0, func indices. */
export let build_element_section = fn (closure_entries: [FuncEntry]) -> %ByteBuffer do
  let n = list.length(xs: closure_entries)
  let %sec = bb.empty()
  // 1 segment
  let %sec = bb.push_uleb128(buf: %sec, val: 1)
  // Active segment: table index 0
  let %sec = bb.push_byte(buf: %sec, byte: 0)
  // Offset expr: i32.const 0; end
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_i32_const)
  let %sec = bb.push_sleb128(buf: %sec, val: 0)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.op_end)
  // Function indices
  let %sec = bb.push_uleb128(buf: %sec, val: n)
  let %sec = emit_elem_func_indices(buf: %sec, entries: closure_entries)
  return %sec
end

// ─── Tag section ────────────────────────────────────────────────────────────

/** Emit the tag section. The exception tag (when has_eh) is at tag-idx 0;
 *  the stack-switching tag (when has_ss) is appended at tag-idx (has_eh ? 1 : 0).
 *  Both share the (i64) -> () func-type signature today.
 */
export let build_tag_section = fn (exn_tag_type_idx: i64, ss_tag_type_idx: i64,
                                    has_eh: bool, n_ss_tags: i64) -> %ByteBuffer do
  let n = (if has_eh then 1 else 0 end) + n_ss_tags
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: n)
  let %sec = if has_eh then
    let %s = bb.push_byte(buf: %sec, byte: 0)
    bb.push_uleb128(buf: %s, val: exn_tag_type_idx)
  else %sec end
  return emit_n_ss_tags(buf: %sec, ss_tag_type_idx, n: n_ss_tags)
end

let emit_n_ss_tags = fn (buf: %ByteBuffer, ss_tag_type_idx: i64, n: i64) -> %ByteBuffer do
  if n <= 0 then return %buf end
  let %buf = bb.push_byte(%buf, byte: 0)
  let %buf = bb.push_uleb128(%buf, val: ss_tag_type_idx)
  return emit_n_ss_tags(%buf, ss_tag_type_idx, n: n - 1)
end

// ─── Component model binary emit (WASI preview3 / component-model-async) ────
//
// These functions build the additional wrapper bytes that convert a core wasm
// module into a WebAssembly component that can use canonical ABI `future<T>`.
//
// The structure emitted by `build_p3_component_wrapper` is:
//
//   component header  (magic + cm_version)
//   component type section
//     [type 0] future<u64>
//   [core module 0] = the nexus-generated core wasm (inline)
//   [core module 1] = stub module (just a memory export for memory aliasing)
//   core instance section: instantiate stub -> stub_inst (core instance 0)
//   canonical function section: future.new (core func 0)
//   alias section: stub_inst.memory -> core memory 0
//   canonical function section: future.write (core func 1)
//   alias section: stub_inst.memory -> core memory 1
//   canonical function section: future.read + drop-writable + drop-readable
//                                + task.return + waitable-set.new (core funcs 2-6)
//   alias section: stub_inst.memory -> core memory 2
//   canonical function section: waitable-set.wait + waitable-set.drop (core funcs 7-8)
//   core instance section:
//     core instance 1 = FromExports { future.new=0, ..., waitable-set.drop=8 }
//     core instance 2 = Instantiate(module 0, with "canon" = instance 1)
//
// The stub module exists solely to provide a memory that the canon memory
// options can reference before the main module is instantiated. This mirrors
// the two-module pattern required by the component model's forward-reference rules.

/** Build the stub core module — a minimal core wasm with only a memory export.
 *  Used as a memory-source for canon functions that need a `(memory ...)` option
 *  before the main module is instantiated.
 */
export let build_p3_stub_module = fn () -> %ByteBuffer do
  // Minimal core wasm:
  //   magic + version
  //   type section: 1 type: () -> ()
  //   func section: 1 func of type 0
  //   memory section: 1 memory (min=1, no max)
  //   export section: 2 exports ("memory" mem 0, "_start" func 0)
  //   code section: 1 body (empty)
  let %buf = bb.empty()
  // magic
  let %buf = bb.push_bytes(%buf, bytes: [0, 97, 115, 109])
  // version (core wasm)
  let %buf = bb.push_bytes(%buf, bytes: [1, 0, 0, 0])
  // type section: id=1, size=4, count=1, (func () -> ())
  let %buf = bb.push_bytes(%buf, bytes: [1, 4, 1, 96, 0, 0])
  // func section: id=3, size=2, count=1, type_idx=0
  let %buf = bb.push_bytes(%buf, bytes: [3, 2, 1, 0])
  // memory section: id=5, size=3, count=1, flags=0 (no max), min=1
  let %buf = bb.push_bytes(%buf, bytes: [5, 3, 1, 0, 1])
  // export section: id=7, count=2
  //   "memory" (len=6) mem_kind=2 idx=0
  //   "_start" (len=6) func_kind=0 idx=0
  let %buf = bb.push_bytes(%buf, bytes: [7, 19, 2])
  let %buf = bb.push_bytes(%buf, bytes: [6, 109, 101, 109, 111, 114, 121, 2, 0])
  let %buf = bb.push_bytes(%buf, bytes: [6, 95, 115, 116, 97, 114, 116, 0, 0])
  // code section: id=10, size=4, count=1, func_size=2, 0 locals, end
  let %buf = bb.push_bytes(%buf, bytes: [10, 4, 1, 2, 0, 11])
  return %buf
end

/** Build the component type section containing a single `future<u64>` type.
 *  Encoding: count=1, cm_type_defined(0x65), future(0x01), u64(0x77).
 */
export let build_cm_type_section_future_u64 = fn () -> %ByteBuffer do
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: 1)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_type_defined)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_type_future)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_prim_u64)
  return %sec
end

/** Build a canonical function section entry for `canon future.new` (type 0).
 *  Encoding: count=1, `15 00` = FutureNew { ty: 0 }.
 */
export let build_cm_canon_future_new = fn () -> %ByteBuffer do
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: 1)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_canon_future_new)
  let %sec = bb.push_uleb128(buf: %sec, val: 0)
  return %sec
end

/** Build a canonical function section containing `future.write` (async).
 *  The memory index refers to the core memory aliased from the stub instance.
 *  Encoding: count=1, `17 00 02 06 03 memory_idx`.
 */
export let build_cm_canon_future_write_async = fn (mem_idx: i64) -> %ByteBuffer do
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: 1)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_canon_future_write)
  let %sec = bb.push_uleb128(buf: %sec, val: 0)
  let %sec = bb.push_uleb128(buf: %sec, val: 2)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_opt_async)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_opt_memory)
  let %sec = bb.push_uleb128(buf: %sec, val: mem_idx)
  return %sec
end

/** Build a canonical function section containing five entries (read, drop-write,
 *  drop-read, task.return, waitable-set.new). The memory index is used by
 *  `future.read`.
 */
export let build_cm_canon_read_drop_task_ws = fn (mem_idx: i64) -> %ByteBuffer do
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: 5)
  // future.read (async, memory)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_canon_future_read)
  let %sec = bb.push_uleb128(buf: %sec, val: 0)
  let %sec = bb.push_uleb128(buf: %sec, val: 2)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_opt_async)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_opt_memory)
  let %sec = bb.push_uleb128(buf: %sec, val: mem_idx)
  // future.drop-writable
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_canon_future_drop_writable)
  let %sec = bb.push_uleb128(buf: %sec, val: 0)
  // future.drop-readable
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_canon_future_drop_readable)
  let %sec = bb.push_uleb128(buf: %sec, val: 0)
  // task.return (no result, no options): 09 01 00 00
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_canon_task_return)
  let %sec = bb.push_bytes(buf: %sec, bytes: [1, 0, 0])
  // waitable-set.new
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_canon_ws_new)
  return %sec
end

/** Build a canonical function section containing two entries: waitable-set.wait
 *  and waitable-set.drop.
 */
export let build_cm_canon_ws_wait_drop = fn (mem_idx: i64) -> %ByteBuffer do
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(buf: %sec, val: 2)
  // waitable-set.wait (cancellable=0, 1 opt: Memory)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_canon_ws_wait)
  let %sec = bb.push_uleb128(buf: %sec, val: 0)
  let %sec = bb.push_uleb128(buf: %sec, val: 1)
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_opt_memory)
  let %sec = bb.push_uleb128(buf: %sec, val: mem_idx)
  // waitable-set.drop
  let %sec = bb.push_byte(buf: %sec, byte: wdefs.cm_canon_ws_drop)
  return %sec
end

/** Push a length-prefixed name string into buf (ULEB byte_length + UTF-8 bytes). */
let cm_push_name = fn (buf: %ByteBuffer, name: string) -> %ByteBuffer do
  let %buf = bb.push_uleb128(%buf, val: str.byte_length(s: name))
  return bb.push_string(%buf, s: name)
end

/** Emit one export entry for a core function in a FromExports instance. */
let cm_emit_func_export_entry = fn (buf: %ByteBuffer, name: string, idx: i64) -> %ByteBuffer do
  let %buf = cm_push_name(%buf, name)
  let %buf = bb.push_byte(%buf, byte: 0)
  return bb.push_uleb128(%buf, val: idx)
end

/** Build the core instance section containing:
 *  instance 1 = FromExports { future.new=0, ..., waitable-set.drop=8 }
 *  instance 2 = Instantiate(module_idx=main_module_idx, with "canon"=instance 1)
 */
export let build_cm_core_instance_section_final = fn (main_module_idx: i64) -> %ByteBuffer do
  // Build the FromExports exports body (9 canon builtins)
  let %exports_body = bb.empty()
  let %exports_body = bb.push_uleb128(%exports_body, val: 9)
  let %exports_body = cm_emit_func_export_entry(buf: %exports_body, name: "future.new", idx: 0)
  let %exports_body = cm_emit_func_export_entry(buf: %exports_body, name: "future.write", idx: 1)
  let %exports_body = cm_emit_func_export_entry(buf: %exports_body, name: "future.read", idx: 2)
  let %exports_body = cm_emit_func_export_entry(buf: %exports_body, name: "future.drop-writable", idx: 3)
  let %exports_body = cm_emit_func_export_entry(buf: %exports_body, name: "future.drop-readable", idx: 4)
  let %exports_body = cm_emit_func_export_entry(buf: %exports_body, name: "task.return", idx: 5)
  let %exports_body = cm_emit_func_export_entry(buf: %exports_body, name: "waitable-set.new", idx: 6)
  let %exports_body = cm_emit_func_export_entry(buf: %exports_body, name: "waitable-set.wait", idx: 7)
  let %exports_body = cm_emit_func_export_entry(buf: %exports_body, name: "waitable-set.drop", idx: 8)
  // instance 1 entry: kind=0x01 (FromExports) + 9 exports
  let %inst1 = bb.empty()
  let %inst1 = bb.push_byte(%inst1, byte: 1)
  let %inst1 = bb.push_buf(%inst1, src: &exports_body)
  bb.free(buf: %exports_body)
  // instance 2 entry: kind=0x00 (Instantiate), module_idx, 1 arg ("canon" -> instance 1)
  let %inst2 = bb.empty()
  let %inst2 = bb.push_byte(%inst2, byte: 0)
  let %inst2 = bb.push_uleb128(%inst2, val: main_module_idx)
  let %inst2 = bb.push_uleb128(%inst2, val: 1)
  let %inst2 = cm_push_name(buf: %inst2, name: "canon")
  // arg kind = 0x12 (core instance)
  let %inst2 = bb.push_byte(%inst2, byte: 18)
  // arg index = 1 (the FromExports instance)
  let %inst2 = bb.push_uleb128(%inst2, val: 1)
  // section body = count=2 + inst1 + inst2
  let %body = bb.empty()
  let %body = bb.push_uleb128(%body, val: 2)
  let %body = bb.push_buf(%body, src: &inst1)
  bb.free(buf: %inst1)
  let %body = bb.push_buf(%body, src: &inst2)
  bb.free(buf: %inst2)
  return %body
end

/** Wrap content bytes with a size-prefixed section header.
 *  Returns bytes: ULEB(section_id) + ULEB(size_of_content) + content.
 */
export let cm_wrap_section = fn (section_id: i64, content: %ByteBuffer) -> %ByteBuffer do
  let %hdr = bb.empty()
  let %hdr = bb.push_uleb128(%hdr, val: section_id)
  let %hdr = bb.push_uleb128(%hdr, val: bb.length(buf: &content))
  let %hdr = bb.push_buf(buf: %hdr, src: &content)
  bb.free(buf: %content)
  return %hdr
end

/** Build one alias section entry: a core memory export from a given instance.
 *  Encoding: `00 02 instance_idx "memory"` (kind=CoreInstanceExport, Memory).
 */
let cm_build_alias_memory_entry = fn (instance_idx: i64) -> %ByteBuffer do
  let %e = bb.empty()
  let %e = bb.push_byte(%e, byte: 0)
  let %e = bb.push_byte(%e, byte: 2)
  let %e = bb.push_uleb128(%e, val: instance_idx)
  let %e = bb.push_bytes(%e, bytes: [6, 109, 101, 109, 111, 114, 121])
  return %e
end

/** Build an alias section with a single memory alias from a given core instance. */
export let build_cm_alias_section_one_memory = fn (instance_idx: i64) -> %ByteBuffer do
  let %entry = cm_build_alias_memory_entry(instance_idx)
  let %sec = bb.empty()
  let %sec = bb.push_uleb128(%sec, val: 1)
  let %sec = bb.push_buf(buf: %sec, src: &entry)
  bb.free(buf: %entry)
  return %sec
end

/** Build the complete component model wrapper for a core wasm module that
 *  uses `canon future.new/read/write` etc. The `core_wasm` bytes are the
 *  nexus-generated core wasm module (already fully assembled). The wrapper
 *  inserts the component header, component type section, stub module, canon
 *  function sections, alias sections, and instantiation section around it.
 *
 *  The resulting binary is a valid WebAssembly component that can be run with:
 *    wasmtime run -W component-model=y,component-model-async=y -S p3=y <file>
 *
 *  The core wasm must declare all canon builtins as imports from the "canon"
 *  module (e.g. `import "canon" "future.new" (func ...)`) and must export its
 *  memory as "memory". The lazy.nx --p3-component path ensures these conventions.
 */
export let build_p3_component = fn (core_wasm: %ByteBuffer) -> %ByteBuffer do
  // Component magic + version
  let %out = bb.empty()
  let %out = bb.push_bytes(%out, bytes: [0, 97, 115, 109])
  let %out = bb.push_bytes(%out, bytes: [wdefs.cm_version_byte0, wdefs.cm_version_byte1,
                                          wdefs.cm_version_byte2, wdefs.cm_version_byte3])

  // Component type section: [type 0] future<u64>
  let %type_sec = cm_wrap_section(section_id: wdefs.cm_sec_type, content: build_cm_type_section_future_u64())
  let %out = bb.push_buf(%out, src: &type_sec)
  bb.free(buf: %type_sec)

  // Core module 0 (main): inline the nexus-generated core wasm
  let %out = bb.push_uleb128(%out, val: wdefs.cm_sec_core_module)
  let %out = bb.push_uleb128(%out, val: bb.length(buf: &core_wasm))
  let %out = bb.push_buf(%out, src: &core_wasm)
  bb.free(buf: %core_wasm)

  // Core module 1 (stub): minimal module providing a memory export
  let %stub_bytes = build_p3_stub_module()
  let %out = bb.push_uleb128(%out, val: wdefs.cm_sec_core_module)
  let %out = bb.push_uleb128(%out, val: bb.length(buf: &stub_bytes))
  let %out = bb.push_buf(%out, src: &stub_bytes)
  bb.free(buf: %stub_bytes)

  // Core instance 0: instantiate stub (module 1) with no args
  let %stub_inst_body = bb.empty()
  let %stub_inst_body = bb.push_uleb128(%stub_inst_body, val: 1)
  let %stub_inst_body = bb.push_bytes(%stub_inst_body, bytes: [0, 1, 0])
  let %stub_inst_sec = cm_wrap_section(section_id: wdefs.cm_sec_core_instance, content: %stub_inst_body)
  let %out = bb.push_buf(%out, src: &stub_inst_sec)
  bb.free(buf: %stub_inst_sec)

  // Canon section: future.new (core func 0)
  let %fn_sec = cm_wrap_section(section_id: wdefs.cm_sec_canon, content: build_cm_canon_future_new())
  let %out = bb.push_buf(%out, src: &fn_sec)
  bb.free(buf: %fn_sec)

  // Alias section: stub_inst(0).memory -> core memory 0
  let %alias0_sec = cm_wrap_section(section_id: wdefs.cm_sec_alias,
                                     content: build_cm_alias_section_one_memory(instance_idx: 0))
  let %out = bb.push_buf(%out, src: &alias0_sec)
  bb.free(buf: %alias0_sec)

  // Canon section: future.write async (memory 0) (core func 1)
  let %fw_sec = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                 content: build_cm_canon_future_write_async(mem_idx: 0))
  let %out = bb.push_buf(%out, src: &fw_sec)
  bb.free(buf: %fw_sec)

  // Alias section: stub_inst(0).memory -> core memory 1
  let %alias1_sec = cm_wrap_section(section_id: wdefs.cm_sec_alias,
                                     content: build_cm_alias_section_one_memory(instance_idx: 0))
  let %out = bb.push_buf(%out, src: &alias1_sec)
  bb.free(buf: %alias1_sec)

  // Canon section: future.read + drop-writable + drop-readable + task.return + ws.new (core funcs 2-6)
  let %rdtws_sec = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                    content: build_cm_canon_read_drop_task_ws(mem_idx: 1))
  let %out = bb.push_buf(%out, src: &rdtws_sec)
  bb.free(buf: %rdtws_sec)

  // Alias section: stub_inst(0).memory -> core memory 2
  let %alias2_sec = cm_wrap_section(section_id: wdefs.cm_sec_alias,
                                     content: build_cm_alias_section_one_memory(instance_idx: 0))
  let %out = bb.push_buf(%out, src: &alias2_sec)
  bb.free(buf: %alias2_sec)

  // Canon section: ws.wait + ws.drop (core funcs 7-8)
  let %wswd_sec = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                   content: build_cm_canon_ws_wait_drop(mem_idx: 2))
  let %out = bb.push_buf(%out, src: &wswd_sec)
  bb.free(buf: %wswd_sec)

  // Final core instance section: FromExports + Instantiate main (module 0)
  let %final_body = build_cm_core_instance_section_final(main_module_idx: 0)
  let %final_sec = cm_wrap_section(section_id: wdefs.cm_sec_core_instance, content: %final_body)
  let %out = bb.push_buf(%out, src: &final_sec)
  bb.free(buf: %final_sec)

  return %out
end
