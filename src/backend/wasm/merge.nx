/**
 * wasm/merge: stdlib-merge phase — links the compiler-emitted core WASM with
 * the precompiled stdlib.wasm and the runtime layer to produce a self-contained
 * module.
 *
 * Owns:
 * - Section scanning + extraction (scan_secs, intarr-based indexing)
 * - Function/type/table/global/memory import resolution
 * - Instruction rewriting (rw_instrs) for remapped indices
 * - Active data/element segment copy with offset relocation
 * - Resolve → emit loop that walks the compiled core and the dep module in
 *   parallel to produce one merged output
 *
 * Does not own:
 * - Generic WASM binary decode (ULEB/SLEB) — see src/backend/wasm/read.nx
 * - Section-layout constants / opcodes — see src/backend/wasm/defs.nx
 * - Individual section emission primitives — see src/backend/wasm/section.nx
 *
 * Consumers: src/driver.nx calls merge_with_stdlib at the end of the pipeline.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { StringMap }, * as sm from "std:stringmap"
import * as str from "std:str"
import { SlebRes, pack, pval, ppos, rd_uleb, rd_sleb, scan_sleb_end, uleb_size } from "src/backend/wasm/read.nx"
import { op_unreachable,
         op_block, op_loop, op_if, op_legacy_try, op_throw, op_br, op_br_if, op_br_table,
         op_call, op_call_indirect, op_return_call, op_drop,
         op_local_get, op_local_set, op_local_tee,
         op_global_get, op_global_set, op_table_get, op_table_set,
         op_memory_size, op_memory_grow,
         op_i32_const, op_i64_const, op_f64_const,
         op_i32_load, op_i64_store32,
         op_ref_null, op_ref_func, op_fc_prefix,
         op_cont_new, op_cont_bind, op_suspend, op_resume,
         op_end, bt_void, wasm_form_func, form_cont,
         op_fc_memory_init, op_fc_memory_copy, op_fc_memory_fill,
         op_fc_table_init, op_fc_table_copy,
         op_simd_prefix,
         op_simd_v128_load, op_simd_v128_store,
         op_simd_i32x4_splat, op_simd_i64x2_splat,
         op_simd_f32x4_splat, op_simd_f64x2_splat,
         op_simd_i32x4_add, op_simd_i32x4_mul,
         op_simd_i64x2_add, op_simd_i64x2_mul,
         op_simd_f32x4_add, op_simd_f32x4_mul,
         op_simd_f64x2_add, op_simd_f64x2_mul,
         vt_ref_null_ht, vt_ref_ht } from "src/backend/wasm/defs.nx"

// ─── Operand-decode classes (rw_instrs) ──────────────────────────────────
// Each opcode maps to one of these classes; the class then drives how
// rw_instrs reads/copies the operand bytes after the opcode byte.
let cls_no_operand   = 0   // already-pushed opcode byte; no operand to copy
let cls_uleb         = 1   // single ULEB (no remap needed)
let cls_call_indirect = 2   // type_idx (+ type_off), table_idx (+ tbl_off)
let cls_blocktype    = 3   // blocktype byte or sleb heaptype
let cls_sleb         = 4   // single SLEB128 (i32/i64 const)
let cls_f64          = 5   // 8 raw bytes (f64.const)
let cls_memarg       = 6   // 2 ULEBs (load/store: align, offset)
let cls_mem_idx_byte = 7   // single byte (memory.size/grow memory index)
let cls_br_table     = 8   // ULEB count + (count+1) ULEB labels
let cls_legacy_try   = 9   // blocktype + ULEB count + (ULEB,ULEB) handlers
let cls_fc_prefix    = 10  // 0xFC sub-opcode dispatch
let cls_call         = 11  // call/return_call (remap func idx)
let cls_global       = 12  // global.get/set (add glo_off)
let cls_ref_func     = 13  // ref.func (remap func idx)
let cls_cont_new     = 14
let cls_cont_bind    = 15
let cls_resume       = 16
let cls_table        = 17  // table.get/set (add tbl_off)
let cls_simd_prefix  = 18  // 0xFD sub-opcode dispatch (no func/type/global remap)

// ─── Dense i32 array (int→int table) ─────────────────────────────────────
// Thin wrapper over stdlib ByteBuffer — avoids the from_i64 string allocation
// that a StringMap lookup would do on every hot-path func-index remap (happens
// thousands of times per merge).
// Uses push_i32_le for writes and a 4-byte little-endian reassembly for reads.
let intarr_new = fn () -> %ByteBuffer do return bb.empty() end
let intarr_push = fn (arr: %ByteBuffer, val: i64) -> %ByteBuffer do
  return bb.push_i32_le(buf: %arr, val)
end
let intarr_get = fn (arr: &ByteBuffer, idx: i64) -> i64 do
  let pos = idx * 4
  let b0 = bb.get_byte(buf: arr, idx: pos)
  let b1 = bb.get_byte(buf: arr, idx: pos + 1)
  let b2 = bb.get_byte(buf: arr, idx: pos + 2)
  let b3 = bb.get_byte(buf: arr, idx: pos + 3)
  return b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
end

// Multi-return records for readers that advance position.
// StrPos: rd_str returns parsed string + position after string bytes.
// SlebRes (imported from wasm/read.nx): rd_sleb returns decoded signed value + position after terminal byte.
// BufPos: sub-emitters that consume src bytes return new buf + new src position.
// RwCtx: type / table / global offsets applied during instruction rewriting.
//        The remap intarr is passed as a separate &ByteBuffer borrow (rw_instrs
//        only reads the remap, no linear threading needed).
// ResolveCtx: import-resolution state. Owns the remap intarr as %ByteBuffer
//        because resolve_main_go mutates (intarr_push) during traversal —
//        ctx must be threaded linearly through the recursion.
// ResolveState: dynamic counters (fidx, m_kept_idx) threaded alongside the ctx.
type StrPos = StrPos(s: string, pos: i64)
type BufPos = BufPos(buf: %ByteBuffer, pos: i64)
type RwCtx = RwCtx(type_off: i64, tbl_off: i64, glo_off: i64)
type ResolveCtx = ResolveCtx(remap: %ByteBuffer, kept_fimp: i64, n_stubs: i64, dep_fimp: i64, m_imp_base: i64)
type ResolveState = ResolveState(fidx: i64, m_kept_idx: i64)

// ─── Section scanning ─────────────────────────────────────────────────────
// Scan WASM module sections into an smap: section_id -> pack(content_offset, size)
let scan_secs = fn (buf: &ByteBuffer) -> %StringMap do
  let %map = sm.empty()
  return scan_secs_go(buf, pos: 8, end_pos: bb.length(buf), %map)
end
let scan_secs_go = fn (buf: &ByteBuffer, pos: i64, end_pos: i64, map: %StringMap) -> %StringMap do
  if pos < end_pos then
    let sec_id = bb.get_byte(buf, idx: pos)
    let pk = rd_uleb(buf, pos: pos + 1)
    let sec_size = pval(pk)
    let content_start = ppos(pk)
    let %map = sm.put(%map, key: str.from_i64(val: sec_id), value: pack(val: content_start, p: sec_size))
    return scan_secs_go(buf, pos: content_start + sec_size, end_pos, %map)
  end
  return %map
end

// Get packed section info (0 if section not present)
let get_sec = fn (map: &StringMap, sec: i64) -> i64 do
  return sm.get_or(map, key: str.from_i64(val: sec), default: 0)
end
// Extract content offset from packed section info
let sec_off = fn (pk: i64) -> i64 do return pval(pk) end
// Extract section size from packed section info
let sec_sz = fn (pk: i64) -> i64 do return ppos(pk) end

// Read the ULEB count at the start of a section (0 if section absent)
let count_sec = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  return pval(pk: rd_uleb(buf, pos: sec_off(pk: sec_pk)))
end

// Position right after the section count ULEB
let sec_body = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  return ppos(pk: rd_uleb(buf, pos: sec_off(pk: sec_pk)))
end

// ─── String reading ───────────────────────────────────────────────────────
// Read a WASM string (ULEB length + bytes). Returns parsed string + position
// immediately after the string bytes.
let rd_str = fn (buf: &ByteBuffer, pos: i64) -> StrPos do
  let pk = rd_uleb(buf, pos)
  let len = pval(pk)
  let start = ppos(pk)
  let %tmp = bb.empty()
  let %tmp = bb.copy_range(dst: %tmp, src: buf, start, end_pos: start + len)
  let s = bb.to_string(buf: &tmp)
  bb.free(buf: %tmp)
  return StrPos(s, pos: start + len)
end

// ─── Import descriptor skipping ───────────────────────────────────────────
// Skip limits encoding (flags + min [+ max])
let skip_limits = fn (buf: &ByteBuffer, pos: i64) -> i64 do
  let flags = bb.get_byte(buf, idx: pos)
  let pk = rd_uleb(buf, pos: pos + 1)
  if flags == 0 then return ppos(pk) end
  return ppos(pk: rd_uleb(buf, pos: ppos(pk)))
end

let skip_table_entry = fn (buf: &ByteBuffer, pos: i64) -> i64 do
  let rt = bb.get_byte(buf, idx: pos)
  if rt == 112 || rt == 111 then return skip_limits(buf, pos: pos + 1) end
  let SlebRes(val: _, pos: after_tidx) = rd_sleb(buf, pos: pos + 1)
  return skip_limits(buf, pos: after_tidx)
end

let copy_table_entries_with_type_off = fn (buf: %ByteBuffer, src: &ByteBuffer, pos: i64, end_pos: i64, off: i64) -> %ByteBuffer do
  if pos >= end_pos then return %buf end
  let rt = bb.get_byte(buf: src, idx: pos)
  let %buf = bb.push_byte(%buf, byte: rt)
  if rt == 112 || rt == 111 then
    let lim_end = skip_limits(buf: src, pos: pos + 1)
    let %buf = bb.copy_range(dst: %buf, src, start: pos + 1, end_pos: lim_end)
    return copy_table_entries_with_type_off(%buf, src, pos: lim_end, end_pos, off)
  end
  let SlebRes(val: tidx, pos: after_tidx) = rd_sleb(buf: src, pos: pos + 1)
  let %buf = bb.push_sleb128(%buf, val: tidx + off)
  let lim_end = skip_limits(buf: src, pos: after_tidx)
  let %buf = bb.copy_range(dst: %buf, src, start: after_tidx, end_pos: lim_end)
  return copy_table_entries_with_type_off(%buf, src, pos: lim_end, end_pos, off)
end

// Skip an import descriptor; returns position after it
let skip_imp_desc = fn (buf: &ByteBuffer, pos: i64) -> i64 do
  let kind = bb.get_byte(buf, idx: pos)
  if kind == 0 then
    // func: skip type index ULEB
    return ppos(pk: rd_uleb(buf, pos: pos + 1))
  end
  if kind == 1 then
    // table: reftype byte + limits
    return skip_limits(buf, pos: pos + 2)
  end
  if kind == 2 then
    // memory: limits
    return skip_limits(buf, pos: pos + 1)
  end
  if kind == 3 then
    // global: valtype + mutability = 2 bytes
    return pos + 3
  end
  // tag: attribute ULEB + type index ULEB
  let pk = rd_uleb(buf, pos: pos + 1)
  return ppos(pk: rd_uleb(buf, pos: ppos(pk)))
end

// ─── WIT name conversion ─────────────────────────────────────────────────
// Convert WIT function name to stdlib export name:
//   "smap-new" → "__nx_smap_new" (prepend __nx_, replace - with _)
let wit_to_export = fn (wit_name: string) -> string do
  let %buf = bb.empty()
  let %buf = bb.push_string(%buf, s: "__nx_")
  let %buf = wit_to_export_go(%buf, name: wit_name, pos: 0, len: str.byte_length(s: wit_name))
  let s = bb.to_string(&buf)
  bb.free(%buf)
  return s
end
let wit_to_export_go = fn (buf: %ByteBuffer, name: string, pos: i64, len: i64) -> %ByteBuffer do
  if pos >= len then return %buf end
  let ch = str.char_code(s: name, idx: pos)
  let b = match ch == 45 do | true -> 95 | false -> ch end
  let %buf = bb.push_byte(%buf, byte: b)
  return wit_to_export_go(%buf, name, pos: pos + 1, len)
end

// ─── Import scanning ──────────────────────────────────────────────────────
// Parse dep (stdlib) exports into smap: export_name -> func_idx+1 (0=not found)
let parse_dep_exports = fn (buf: &ByteBuffer, sec_pk: i64) -> %StringMap do
  let %map = sm.empty()
  if sec_pk == 0 then return %map end
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  let count = pval(pk)
  return parse_dep_exports_go(buf, pos: ppos(pk), remaining: count, %map)
end
let parse_dep_exports_go = fn (buf: &ByteBuffer, pos: i64, remaining: i64, map: %StringMap) -> %StringMap do
  if remaining <= 0 then return %map end
  let StrPos(s: name, pos: pos2) = rd_str(buf, pos)
  let kind = bb.get_byte(buf, idx: pos2)
  let pk = rd_uleb(buf, pos: pos2 + 1)
  let idx = pval(pk)
  if kind == 0 then
    let %map = sm.put(%map, key: name, value: idx + 1)
    return parse_dep_exports_go(buf, pos: ppos(pk), remaining: remaining - 1, %map)
  end
  return parse_dep_exports_go(buf, pos: ppos(pk), remaining: remaining - 1, %map)
end

// Count function imports in a module (kind == 0x00)
let count_func_imps = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  return count_func_imps_go(buf, pos: ppos(pk), remaining: pval(pk), acc: 0)
end
let count_func_imps_go = fn (buf: &ByteBuffer, pos: i64, remaining: i64, acc: i64) -> i64 do
  if remaining <= 0 then return acc end
  let StrPos(s: _mod, pos: pos2) = rd_str(buf, pos)
  let StrPos(s: _name, pos: pos3) = rd_str(buf, pos: pos2)
  let kind = bb.get_byte(buf, idx: pos3)
  let pos4 = skip_imp_desc(buf, pos: pos3)
  let inc = match kind == 0 do | true -> 1 | false -> 0 end
  return count_func_imps_go(buf, pos: pos4, remaining: remaining - 1, acc: acc + inc)
end

// ─── Main non-stdlib import counting ─────────────────────────────────────
// Count ALL main imports that are NOT from nexus:std/* (for import section entry count)
let count_main_kept_imps = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  return count_main_kept_go(buf, pos: ppos(pk), remaining: pval(pk), acc: 0)
end
let count_main_kept_go = fn (buf: &ByteBuffer, pos: i64, remaining: i64, acc: i64) -> i64 do
  if remaining <= 0 then return acc end
  let StrPos(s: mod_name, pos: pos2) = rd_str(buf, pos)
  let StrPos(s: _name, pos: pos3) = rd_str(buf, pos: pos2)
  let kind = bb.get_byte(buf, idx: pos3)
  let pos4 = skip_imp_desc(buf, pos: pos3)
  if str.starts_with(s: mod_name, prefix: "nexus:std/") then
    return count_main_kept_go(buf, pos: pos4, remaining: remaining - 1, acc)
  end
  if str.byte_length(s: mod_name) == 0 then
    return count_main_kept_go(buf, pos: pos4, remaining: remaining - 1, acc)
  end
  if kind == 2 then
    return count_main_kept_go(buf, pos: pos4, remaining: remaining - 1, acc)
  end
  return count_main_kept_go(buf, pos: pos4, remaining: remaining - 1, acc: acc + 1)
end

// Count main FUNCTION imports that are NOT from nexus:std/* (for function index layout)
let count_main_kept_func_imps = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  return count_main_kept_func_go(buf, pos: ppos(pk), remaining: pval(pk), acc: 0)
end
let count_main_kept_func_go = fn (buf: &ByteBuffer, pos: i64, remaining: i64, acc: i64) -> i64 do
  if remaining <= 0 then return acc end
  let StrPos(s: mod_name, pos: pos2) = rd_str(buf, pos)
  let StrPos(s: _name, pos: pos3) = rd_str(buf, pos: pos2)
  let kind = bb.get_byte(buf, idx: pos3)
  let pos4 = skip_imp_desc(buf, pos: pos3)
  if kind == 0 then
    if str.starts_with(s: mod_name, prefix: "nexus:std/") then
      return count_main_kept_func_go(buf, pos: pos4, remaining: remaining - 1, acc)
    end
    if str.byte_length(s: mod_name) == 0 then
      return count_main_kept_func_go(buf, pos: pos4, remaining: remaining - 1, acc)
    end
    return count_main_kept_func_go(buf, pos: pos4, remaining: remaining - 1, acc: acc + 1)
  end
  return count_main_kept_func_go(buf, pos: pos4, remaining: remaining - 1, acc)
end

// ─── Main non-stdlib import copying ──────────────────────────────────────
// Copy main's non-stdlib function imports to output (no type offset needed — main types first)
let copy_main_kept_imps = fn (out: %ByteBuffer, buf: &ByteBuffer, sec_pk: i64, type_off: i64) -> %ByteBuffer do
  if sec_pk == 0 then return %out end
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  return copy_main_kept_go(%out, buf, pos: ppos(pk), remaining: pval(pk), type_off)
end
// A main import is satisfied by dep (and dropped from merged imports) if:
//   - module is "nexus:std/*" (function, resolved to dep export), OR
//   - module is "" (anonymous .memory/.allocate bound to dep-provided ones), OR
//   - import kind is memory (merged declares its own memory).
// Keeping main imports intact would require shifting dep's function indices by
// m_kept, but remap_dep_func is identity (see remap_dep_func comment), so any
// kept main import breaks dep internal calls.
let copy_main_kept_go = fn (out: %ByteBuffer, buf: &ByteBuffer, pos: i64, remaining: i64, type_off: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let start = pos
  let StrPos(s: mod_name, pos: pos2) = rd_str(buf, pos)
  let StrPos(s: _name, pos: pos3) = rd_str(buf, pos: pos2)
  let kind = bb.get_byte(buf, idx: pos3)
  let pos4 = skip_imp_desc(buf, pos: pos3)
  if str.starts_with(s: mod_name, prefix: "nexus:std/") then
    return copy_main_kept_go(%out, buf, pos: pos4, remaining: remaining - 1, type_off)
  end
  if str.byte_length(s: mod_name) == 0 then
    return copy_main_kept_go(%out, buf, pos: pos4, remaining: remaining - 1, type_off)
  end
  if kind == 2 then
    return copy_main_kept_go(%out, buf, pos: pos4, remaining: remaining - 1, type_off)
  end
  if kind == 0 then
    let %out = bb.copy_range(dst: %out, src: buf, start, end_pos: pos3 + 1)
    let pk = rd_uleb(buf, pos: pos3 + 1)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk) + type_off)
    return copy_main_kept_go(%out, buf, pos: pos4, remaining: remaining - 1, type_off)
  end
  let %out = bb.copy_range(dst: %out, src: buf, start, end_pos: pos4)
  return copy_main_kept_go(%out, buf, pos: pos4, remaining: remaining - 1, type_off)
end

// ─── Main import resolution ───────────────────────────────────────────────
// Populates remap_m intarr (dense i32 array, indexed by fidx) with the merged
// function index for each main function import. Iterates import section
// sequentially; fidx increments only for function-kind imports, matching
// the array index.
let resolve_main_imports = fn (ctx: %ResolveCtx, dep_exports: &StringMap, buf: &ByteBuffer, sec_pk: i64) -> %ResolveCtx do
  if sec_pk > 0 then
    let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
    return resolve_main_go(%ctx, dep_exports, buf, pos: ppos(pk), remaining: pval(pk), state: ResolveState(fidx: 0, m_kept_idx: 0))
  end
  return %ctx
end
let resolve_main_go = fn (ctx: %ResolveCtx, dep_exports: &StringMap, buf: &ByteBuffer, pos: i64, remaining: i64, state: ResolveState) -> %ResolveCtx do
  if remaining <= 0 then return %ctx end
  let StrPos(s: mod_name, pos: pos2) = rd_str(buf, pos)
  let StrPos(s: func_name, pos: pos3) = rd_str(buf, pos: pos2)
  let kind = bb.get_byte(buf, idx: pos3)
  let pos4 = skip_imp_desc(buf, pos: pos3)
  if kind == 0 then
    let ResolveCtx(%remap, kept_fimp, n_stubs, dep_fimp, m_imp_base) = ctx
    let ResolveState(fidx, m_kept_idx) = state
    // stdlib/* and empty-module function imports resolve to dep exports.
    let is_dep = if str.starts_with(s: mod_name, prefix: "nexus:std/") then true
                 else str.byte_length(s: mod_name) == 0 end
    let new_kept_idx = if is_dep then m_kept_idx else m_kept_idx + 1 end
    let new_idx = if is_dep then
      let raw_lookup = sm.get_or(map: dep_exports, key: func_name, default: 0)
      let dep_raw = if raw_lookup > 0 then raw_lookup
      else
        let exp_name = wit_to_export(wit_name: func_name)
        sm.get_or(map: dep_exports, key: exp_name, default: 0)
      end
      if dep_raw > 0 then
        remap_dep_func(dep_fidx: dep_raw - 1, kept_fimp,
                       n_stubs, dep_fimp)
      else fidx end
    else
      m_imp_base + m_kept_idx
    end
    let %remap = intarr_push(arr: %remap, val: new_idx)
    let %ctx = ResolveCtx(%remap, kept_fimp, n_stubs, dep_fimp, m_imp_base)
    return resolve_main_go(%ctx, dep_exports, buf, pos: pos4, remaining: remaining - 1, state: ResolveState(fidx: fidx + 1, m_kept_idx: new_kept_idx))
  end
  return resolve_main_go(%ctx, dep_exports, buf, pos: pos4, remaining: remaining - 1, state)
end

let remap_dep_func = fn (dep_fidx: i64, kept_fimp: i64, n_stubs: i64, dep_fimp: i64) -> i64 do
  if dep_fidx < dep_fimp then return dep_fidx end
  return dep_fidx + kept_fimp + n_stubs - dep_fimp
end

// ─── Populate remap intarrs ──────────────────────────────────────────────
// Each remap array holds a dense i32 table indexed by original fidx.
// push_identity(arr, 0..n): arr[i] = i. Used for dep WASI imports (preserved).
// push_offset(arr, n, off): arr[len..len+n] = [len+off, len+1+off, ...].
// Arrays must be populated in order matching their index space.
let push_identity = fn (arr: %ByteBuffer, i: i64, n: i64) -> %ByteBuffer do
  if i < n then
    let %arr = intarr_push(%arr, val: i)
    return push_identity(%arr, i: i + 1, n)
  end
  return %arr
end
let push_offset = fn (arr: %ByteBuffer, i: i64, n: i64, off: i64) -> %ByteBuffer do
  if i < n then
    let %arr = intarr_push(%arr, val: i + off)
    return push_offset(%arr, i: i + 1, n, off)
  end
  return %arr
end

let remap_main_locals = fn (remap: %ByteBuffer, m_fimp: i64, m_loc: i64,
    kept_fimp: i64, n_stubs: i64, d_loc: i64) -> %ByteBuffer do
  // Main locals sit at merged idx = (kept_fimp + n_stubs + d_loc) + (i - m_fimp).
  // Entries m_fimp..m_fimp+m_loc append after main-import entries.
  return push_offset(arr: %remap, i: m_fimp, n: m_fimp + m_loc,
    off: kept_fimp + n_stubs + d_loc - m_fimp)
end

let remap_dep_locals = fn (remap: %ByteBuffer, dep_fimp: i64, d_loc: i64,
    kept_fimp: i64, n_stubs: i64) -> %ByteBuffer do
  // Dep locals sit at merged idx = (kept_fimp + n_stubs) + (i - dep_fimp).
  return push_offset(arr: %remap, i: dep_fimp, n: dep_fimp + d_loc,
    off: kept_fimp + n_stubs - dep_fimp)
end

// ─── Instruction rewriter ─────────────────────────────────────────────────

let rw_body = fn (ctx: RwCtx, remap: &ByteBuffer, out: %ByteBuffer, src: &ByteBuffer,
    body_start: i64, body_end: i64) -> %ByteBuffer do
  let pk = rd_uleb(buf: src, pos: body_start)
  let n_local_groups = pval(pk)
  let locals_end = skip_local_decls(buf: src, pos: ppos(pk), remaining: n_local_groups)
  let %out = bb.copy_range(dst: %out, src, start: body_start, end_pos: locals_end)
  return rw_instrs(ctx, remap, %out, src, pos: locals_end, end_pos: body_end)
end

let skip_local_decls = fn (buf: &ByteBuffer, pos: i64, remaining: i64) -> i64 do
  if remaining <= 0 then return pos end
  let pk = rd_uleb(buf, pos)
  return skip_local_decls(buf, pos: ppos(pk) + 1, remaining: remaining - 1)
end

// Scan forward past `n` LEB128 values, returning the position after the last.
// `scan_sleb_end` works for both ULEB and SLEB (terminator detection is shared).
// Used by span-copy paths that avoid re-encoding index-free operands.
let scan_lebs = fn (buf: &ByteBuffer, pos: i64, n: i64) -> i64 do
  if n <= 0 then return pos end
  return scan_lebs(buf, pos: scan_sleb_end(buf, pos), n: n - 1)
end

let rw_instrs = fn (ctx: RwCtx, remap: &ByteBuffer, out: %ByteBuffer, src: &ByteBuffer, pos: i64, end_pos: i64) -> %ByteBuffer do
  if pos >= end_pos then return %out end
  let op = bb.get_byte(buf: src, idx: pos)
  let pos = pos + 1

  // Classify opcode into one of cls_* handling groups (see definitions above).
  // Single flat else-if chain: Nexus's parser collapses `else if` into one
  // chain, so two separate if-trees stitched with an outer `else (newline) if`
  // double-nest beyond what the chain-collapsing logic can close. Keep flat.
  let cls = if op_i32_load <= op && op <= op_i64_store32 then cls_memarg
    else if op == op_memory_size then cls_mem_idx_byte
    else if op == op_memory_grow then cls_mem_idx_byte
    else if op == op_i32_const then cls_sleb
    else if op == op_i64_const then cls_sleb
    else if op == op_f64_const then cls_f64
    else if op == op_ref_func then cls_ref_func
    else if op == op_cont_new then cls_cont_new
    else if op == op_cont_bind then cls_cont_bind
    else if op == op_suspend then cls_uleb
    else if op == op_resume then cls_resume
    else if op == op_fc_prefix then cls_fc_prefix
    else if op == op_simd_prefix then cls_simd_prefix
    else if op == op_block then cls_blocktype
    else if op == op_loop then cls_blocktype
    else if op == op_if then cls_blocktype
    else if op == op_legacy_try then cls_legacy_try
    else if op == op_throw then cls_uleb
    else if op == op_br then cls_uleb
    else if op == op_br_if then cls_uleb
    else if op == op_br_table then cls_br_table
    else if op == op_call then cls_call
    else if op == op_call_indirect then cls_call_indirect
    else if op == op_return_call then cls_call
    else if op == op_local_get then cls_uleb
    else if op == op_local_set then cls_uleb
    else if op == op_local_tee then cls_uleb
    else if op == op_global_get then cls_global
    else if op == op_global_set then cls_global
    else if op == op_table_get then cls_table
    else if op == op_table_set then cls_table
    else cls_no_operand
    end

  let RwCtx(type_off, tbl_off, glo_off) = ctx

  // Handle each class — flat if-return-end pattern for TCO + typechecker compat
  let %out = bb.push_byte(buf: %out, byte: op)

  if cls == cls_uleb then
    // Single ULEB (local.get/set/tee, br, br_if, etc.) — no remap needed.
    // Span-copy avoids rd_uleb (recursive shl arithmetic) + push_uleb128 re-encoding.
    let end1 = scan_sleb_end(buf: src, pos)
    let %out = bb.copy_range(dst: %out, src, start: pos, end_pos: end1)
    return rw_instrs(ctx, remap, %out, src, pos: end1, end_pos)
  end
  if cls == cls_call_indirect then
    let pk = rd_uleb(buf: src, pos)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk) + type_off)
    let pk2 = rd_uleb(buf: src, pos: ppos(pk))
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk2) + tbl_off)
    return rw_instrs(ctx, remap, %out, src, pos: ppos(pk: pk2), end_pos)
  end
  if cls == cls_blocktype then
    let BufPos(buf: %out, pos) = rw_blocktype_operand(%out, src, pos, type_off)
    return rw_instrs(ctx, remap, %out, src, pos, end_pos)
  end
  if cls == cls_sleb then
    // SLEB operand: no remap needed, just copy bytes verbatim.
    // Find terminal byte (first byte < 128 or >= 128 flipped — i.e., high bit clear)
    // and bulk-copy. Avoids rd_sleb entirely (which was hitting a codegen quirk).
    let end_sleb = scan_sleb_end(buf: src, pos)
    let %out = bb.copy_range(dst: %out, src, start: pos, end_pos: end_sleb)
    return rw_instrs(ctx, remap, %out, src, pos: end_sleb, end_pos)
  end
  if cls == cls_f64 then
    let %out = bb.copy_range(dst: %out, src, start: pos, end_pos: pos + 8)
    return rw_instrs(ctx, remap, %out, src, pos: pos + 8, end_pos)
  end
  if cls == cls_memarg then
    // Memarg (align + offset) on load/store — 2 ULEBs, no remap. Span-copy.
    let end1 = scan_sleb_end(buf: src, pos)
    let end2 = scan_sleb_end(buf: src, pos: end1)
    let %out = bb.copy_range(dst: %out, src, start: pos, end_pos: end2)
    return rw_instrs(ctx, remap, %out, src, pos: end2, end_pos)
  end
  if cls == cls_mem_idx_byte then
    let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos))
    return rw_instrs(ctx, remap, %out, src, pos: pos + 1, end_pos)
  end
  if cls == cls_br_table then
    // br_table: ULEB count + (count+1) ULEB labels — no remap. Span-copy the whole run.
    let pk = rd_uleb(buf: src, pos)
    let count = pval(pk)
    let all_end = scan_lebs(buf: src, pos: ppos(pk), n: count + 1)
    let %out = bb.copy_range(dst: %out, src, start: pos, end_pos: all_end)
    return rw_instrs(ctx, remap, %out, src, pos: all_end, end_pos)
  end
  if cls == cls_legacy_try then
    let BufPos(buf: %out, pos) = rw_blocktype_operand(%out, src, pos, type_off)
    let pk = rd_uleb(buf: src, pos)
    let n_handlers = pval(pk)
    let %out = bb.push_uleb128(buf: %out, val: n_handlers)
    let BufPos(buf: %out, pos) = copy_try_handlers(%out, src, pos: ppos(pk), remaining: n_handlers)
    return rw_instrs(ctx, remap, %out, src, pos, end_pos)
  end
  if cls == cls_fc_prefix then
    let pk = rd_uleb(buf: src, pos)
    let sub_op = pval(pk)
    let %out = bb.push_uleb128(buf: %out, val: sub_op)
    let BufPos(buf: %out, pos) = rw_fc_prefix(%out, src, pos: ppos(pk), sub_op)
    return rw_instrs(ctx, remap, %out, src, pos, end_pos)
  end
  if cls == cls_simd_prefix then
    let pk = rd_uleb(buf: src, pos)
    let sub_op = pval(pk)
    let %out = bb.push_uleb128(buf: %out, val: sub_op)
    let BufPos(buf: %out, pos) = rw_simd_prefix(%out, src, pos: ppos(pk), sub_op)
    return rw_instrs(ctx, remap, %out, src, pos, end_pos)
  end
  if cls == cls_call then
    // call / return_call: remap function index via intarr (dense i32 lookup)
    let pk = rd_uleb(buf: src, pos)
    let old_idx = pval(pk)
    let new_idx = intarr_get(arr: remap, idx: old_idx)
    let %out = bb.push_uleb128(buf: %out, val: new_idx)
    return rw_instrs(ctx, remap, %out, src, pos: ppos(pk), end_pos)
  end
  if cls == cls_global then
    // global.get / global.set: add glo_off to index
    let pk = rd_uleb(buf: src, pos)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk) + glo_off)
    return rw_instrs(ctx, remap, %out, src, pos: ppos(pk), end_pos)
  end
  if cls == cls_ref_func then
    // ref.func: remap function index via intarr
    let pk = rd_uleb(buf: src, pos)
    let old_idx = pval(pk)
    let new_idx = intarr_get(arr: remap, idx: old_idx)
    let %out = bb.push_uleb128(buf: %out, val: new_idx)
    return rw_instrs(ctx, remap, %out, src, pos: ppos(pk), end_pos)
  end
  if cls == cls_cont_new then
    // cont.new / cont.bind-single: type index + type_off
    let pk = rd_uleb(buf: src, pos)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk) + type_off)
    return rw_instrs(ctx, remap, %out, src, pos: ppos(pk), end_pos)
  end
  if cls == cls_cont_bind then
    // cont.bind: two type indices, both + type_off
    let pk1 = rd_uleb(buf: src, pos)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk1) + type_off)
    let pk2 = rd_uleb(buf: src, pos: ppos(pk: pk1))
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk2) + type_off)
    return rw_instrs(ctx, remap, %out, src, pos: ppos(pk: pk2), end_pos)
  end
  if cls == cls_resume then
    // resume: cont type index + type_off, then handler table (pass-through)
    let pk = rd_uleb(buf: src, pos)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk) + type_off)
    let pk2 = rd_uleb(buf: src, pos: ppos(pk))
    let n_ht = pval(pk: pk2)
    let %out = bb.push_uleb128(buf: %out, val: n_ht)
    let BufPos(buf: %out, pos: after_ht) = copy_resume_handlers(%out, src, pos: ppos(pk: pk2), remaining: n_ht)
    return rw_instrs(ctx, remap, %out, src, pos: after_ht, end_pos)
  end
  if cls == cls_table then
    let pk = rd_uleb(buf: src, pos)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk) + tbl_off)
    return rw_instrs(ctx, remap, %out, src, pos: ppos(pk), end_pos)
  end
  // cls_no_operand: no operand, already pushed byte
  return rw_instrs(ctx, remap, %out, src, pos, end_pos)
end

// Handle 0xFC prefix sub-opcodes (extracted to avoid deep nesting)
let rw_fc_prefix = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, sub_op: i64) -> BufPos do
  if sub_op <= 7 then return BufPos(buf: %out, pos) end
  if sub_op == op_fc_memory_copy then
    let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos))
    let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos + 1))
    return BufPos(buf: %out, pos: pos + 2)
  end
  if sub_op == op_fc_memory_fill then
    let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos))
    return BufPos(buf: %out, pos: pos + 1)
  end
  if sub_op >= op_fc_memory_init then
    let pk2 = rd_uleb(buf: src, pos)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk2))
    if sub_op == op_fc_memory_init then
      let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: ppos(pk: pk2)))
      return BufPos(buf: %out, pos: ppos(pk: pk2) + 1)
    end
    if sub_op == op_fc_table_init then
      let pk3 = rd_uleb(buf: src, pos: ppos(pk: pk2))
      let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk3))
      return BufPos(buf: %out, pos: ppos(pk: pk3))
    end
    if sub_op == op_fc_table_copy then
      let pk3 = rd_uleb(buf: src, pos: ppos(pk: pk2))
      let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk3))
      return BufPos(buf: %out, pos: ppos(pk: pk3))
    end
    return BufPos(buf: %out, pos: ppos(pk: pk2))
  end
  return BufPos(buf: %out, pos)
end

// Handle 0xFD prefix sub-opcodes (SIMD / fixed-width 128-bit). Subset coverage
// matches the SIMD ops emitted by codegen.nx — load/store carry a memarg
// (two ULEBs, no remap), splat / lane-arithmetic carry no further operands.
// SIMD instructions never embed a func/type/global index, so no remap path
// is exercised here.
let rw_simd_prefix = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, sub_op: i64) -> BufPos do
  if sub_op == op_simd_v128_load || sub_op == op_simd_v128_store then
    // memarg: 2 ULEBs (align, offset). Span-copy verbatim.
    let end1 = scan_sleb_end(buf: src, pos)
    let end2 = scan_sleb_end(buf: src, pos: end1)
    let %out = bb.copy_range(dst: %out, src, start: pos, end_pos: end2)
    return BufPos(buf: %out, pos: end2)
  end
  if sub_op == op_simd_i32x4_splat || sub_op == op_simd_i64x2_splat
      || sub_op == op_simd_f32x4_splat || sub_op == op_simd_f64x2_splat
      || sub_op == op_simd_i32x4_add || sub_op == op_simd_i32x4_mul
      || sub_op == op_simd_i64x2_add || sub_op == op_simd_i64x2_mul
      || sub_op == op_simd_f32x4_add || sub_op == op_simd_f32x4_mul
      || sub_op == op_simd_f64x2_add || sub_op == op_simd_f64x2_mul then
    // No further operand bytes.
    return BufPos(buf: %out, pos)
  end
  // Unhandled SIMD sub-opcode. Emission is gated by codegen.nx's emit_simd_*
  // dispatch — only sub-ops listed above can appear in well-formed input.
  // Reaching here means a new emit_simd_* path was added without a matching
  // operand-decode case here. Splice an `unreachable` byte into the output so
  // wasmtime traps at runtime instead of returning misdecoded SIMD as garbage,
  // and hold `pos` steady so the next byte gets re-classified by rw_instrs's
  // top-level dispatch — yielding a malformed wasm that the validator rejects
  // at the outer merge_with_stdlib boundary, not silent corruption.
  let %out = bb.push_byte(buf: %out, byte: op_unreachable)
  return BufPos(buf: %out, pos)
end


let rw_blocktype_operand = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, type_off: i64) -> BufPos do
  let b = bb.get_byte(buf: src, idx: pos)
  // void blocktype (0x40) or valtype (>= 0x60)
  if b == bt_void then
    return BufPos(buf: bb.push_byte(buf: %out, byte: bt_void), pos: pos + 1)
  end
  // Blocktype encoded as a single valtype byte (0x60+ — covers vt_* and ref-tags).
  if b >= wasm_form_func then
    return BufPos(buf: bb.push_byte(buf: %out, byte: b), pos: pos + 1)
  end
  // Type index as sleb
  let SlebRes(val: type_idx, pos: end2) = rd_sleb(buf: src, pos)
  return BufPos(buf: bb.push_sleb128(buf: %out, val: type_idx + type_off), pos: end2)
end

let copy_try_handlers = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, remaining: i64) -> BufPos do
  if remaining <= 0 then return BufPos(buf: %out, pos) end
  let catch_kind = bb.get_byte(buf: src, idx: pos)
  let %out = bb.push_byte(buf: %out, byte: catch_kind)
  if catch_kind <= 1 then
    let pk = rd_uleb(buf: src, pos: pos + 1)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk))
    let pk2 = rd_uleb(buf: src, pos: ppos(pk))
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk2))
    return copy_try_handlers(%out, src, pos: ppos(pk: pk2), remaining: remaining - 1)
  end
  let pk = rd_uleb(buf: src, pos: pos + 1)
  let %out = bb.push_uleb128(buf: %out, val: pval(pk))
  return copy_try_handlers(%out, src, pos: ppos(pk), remaining: remaining - 1)
end

let copy_resume_handlers = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, remaining: i64) -> BufPos do
  if remaining <= 0 then return BufPos(buf: %out, pos) end
  let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos))
  let end2 = scan_lebs(buf: src, pos: pos + 1, n: 2)
  let %out = bb.copy_range(dst: %out, src, start: pos + 1, end_pos: end2)
  return copy_resume_handlers(%out, src, pos: end2, remaining: remaining - 1)
end

// ─── Section emitters ─────────────────────────────────────────────────────

let emit_sec = fn (out: %ByteBuffer, sec_id: i64, content: &ByteBuffer) -> %ByteBuffer do
  let %out = bb.push_byte(buf: %out, byte: sec_id)
  let %out = bb.push_uleb128(buf: %out, val: bb.length(buf: content))
  return bb.push_buf(dst: %out, src: content)
end

let emit_sec_and_free = fn (out: %ByteBuffer, sec_id: i64, tmp: %ByteBuffer) -> %ByteBuffer do
  let %out = emit_sec(%out, sec_id, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let copy_raw_sec = fn (out: %ByteBuffer, src: &ByteBuffer, sec_pk: i64, sec_id: i64) -> %ByteBuffer do
  if sec_pk == 0 then return %out end
  let off = sec_off(pk: sec_pk)
  let sz = sec_sz(pk: sec_pk)
  let %tmp = bb.empty()
  let %tmp = bb.copy_range(dst: %tmp, src, start: off, end_pos: off + sz)
  let %out = emit_sec(%out, sec_id, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let copy_sec_body = fn (buf: %ByteBuffer, src: &ByteBuffer, sec_pk: i64) -> %ByteBuffer do
  if sec_pk > 0 then
    let body = sec_body(buf: src, sec_pk)
    return bb.copy_range(dst: %buf, src, start: body, end_pos: sec_off(pk: sec_pk) + sec_sz(pk: sec_pk))
  end
  return %buf
end

let skip_n_valtypes = fn (src: &ByteBuffer, pos: i64, remaining: i64) -> i64 do
  if remaining <= 0 then return pos end
  let b = bb.get_byte(buf: src, idx: pos)
  if b == vt_ref_null_ht then return skip_n_valtypes(src, pos: scan_sleb_end(buf: src, pos: pos + 1), remaining: remaining - 1) end
  if b == vt_ref_ht then return skip_n_valtypes(src, pos: scan_sleb_end(buf: src, pos: pos + 1), remaining: remaining - 1) end
  return skip_n_valtypes(src, pos: pos + 1, remaining: remaining - 1)
end

let emit_valtypes_off = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, remaining: i64, off: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let b = bb.get_byte(buf: src, idx: pos)
  if b == vt_ref_null_ht then
    let %out = bb.push_byte(buf: %out, byte: vt_ref_null_ht)
    let SlebRes(val: heap_idx, pos: next) = rd_sleb(buf: src, pos: pos + 1)
    let %out = bb.push_sleb128(buf: %out, val: heap_idx + off)
    return emit_valtypes_off(%out, src, pos: next, remaining: remaining - 1, off)
  end
  if b == vt_ref_ht then
    let %out = bb.push_byte(buf: %out, byte: vt_ref_ht)
    let SlebRes(val: heap_idx, pos: next) = rd_sleb(buf: src, pos: pos + 1)
    let %out = bb.push_sleb128(buf: %out, val: heap_idx + off)
    return emit_valtypes_off(%out, src, pos: next, remaining: remaining - 1, off)
  end
  let %out = bb.push_byte(buf: %out, byte: b)
  return emit_valtypes_off(%out, src, pos: pos + 1, remaining: remaining - 1, off)
end

let skip_one_type_entry = fn (src: &ByteBuffer, pos: i64) -> i64 do
  let form = bb.get_byte(buf: src, idx: pos)
  if form == form_cont then
    let SlebRes(val: _, pos: next) = rd_sleb(buf: src, pos: pos + 1)
    return next
  end
  let pk_p = rd_uleb(buf: src, pos: pos + 1)
  let after_p = skip_n_valtypes(src, pos: ppos(pk: pk_p), remaining: pval(pk: pk_p))
  let pk_r = rd_uleb(buf: src, pos: after_p)
  return skip_n_valtypes(src, pos: ppos(pk: pk_r), remaining: pval(pk: pk_r))
end

let copy_one_type_entry_off = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, off: i64) -> %ByteBuffer do
  let form = bb.get_byte(buf: src, idx: pos)
  if form == form_cont then
    let %out = bb.push_byte(buf: %out, byte: form_cont)
    let SlebRes(val: tidx, pos: _) = rd_sleb(buf: src, pos: pos + 1)
    return bb.push_sleb128(buf: %out, val: tidx + off)
  end
  let %out = bb.push_byte(buf: %out, byte: form)
  let pk_p = rd_uleb(buf: src, pos: pos + 1)
  let n_params = pval(pk: pk_p)
  let params_start = ppos(pk: pk_p)
  let %out = bb.push_uleb128(buf: %out, val: n_params)
  let %out = emit_valtypes_off(%out, src, pos: params_start, remaining: n_params, off)
  let after_p = skip_n_valtypes(src, pos: params_start, remaining: n_params)
  let pk_r = rd_uleb(buf: src, pos: after_p)
  let n_results = pval(pk: pk_r)
  let results_start = ppos(pk: pk_r)
  let %out = bb.push_uleb128(buf: %out, val: n_results)
  return emit_valtypes_off(%out, src, pos: results_start, remaining: n_results, off)
end

let copy_type_entries_with_off = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, remaining: i64, off: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let next = skip_one_type_entry(src, pos)
  let %out = copy_one_type_entry_off(%out, src, pos, off)
  return copy_type_entries_with_off(%out, src, pos: next, remaining: remaining - 1, off)
end

let emit_merged_types_inline = fn (d_buf: &ByteBuffer, d_sec: i64, m_buf: &ByteBuffer, m_sec: i64, out: %ByteBuffer) -> %ByteBuffer do
  let %tmp = bb.empty()
  let m_count = count_sec(buf: m_buf, sec_pk: m_sec)
  let d_count = count_sec(buf: d_buf, sec_pk: d_sec)
  let %tmp = bb.push_uleb128(buf: %tmp, val: m_count + d_count)
  let %tmp = copy_sec_body(buf: %tmp, src: m_buf, sec_pk: m_sec)
  let %tmp = if d_sec > 0 then
    copy_type_entries_with_off(out: %tmp, src: d_buf, pos: sec_body(buf: d_buf, sec_pk: d_sec), remaining: d_count, off: m_count)
  else %tmp end
  let %out = emit_sec(%out, sec_id: 1, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let copy_imports_with_type_off = fn (out: %ByteBuffer, buf: &ByteBuffer,
    pos: i64, remaining: i64, type_off: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let start = pos
  let StrPos(s: _mod, pos: pos2) = rd_str(buf, pos)
  let StrPos(s: _name, pos: pos3) = rd_str(buf, pos: pos2)
  let kind = bb.get_byte(buf, idx: pos3)
  if kind == 0 then
    // Function import: copy name bytes, then offset type index
    let %out = bb.copy_range(dst: %out, src: buf, start, end_pos: pos3 + 1)
    let pk = rd_uleb(buf, pos: pos3 + 1)
    let type_idx = pval(pk)
    let %out = bb.push_uleb128(buf: %out, val: type_idx + type_off)
    return copy_imports_with_type_off(%out, buf,
      pos: ppos(pk), remaining: remaining - 1, type_off)
  end
  // Non-function import: copy everything as-is
  let pos4 = skip_imp_desc(buf, pos: pos3)
  let %out = bb.copy_range(dst: %out, src: buf, start, end_pos: pos4)
  return copy_imports_with_type_off(%out, buf,
    pos: pos4, remaining: remaining - 1, type_off)
end

let copy_func_types_with_off = fn (out: %ByteBuffer, buf: &ByteBuffer, sec_pk: i64, off: i64) -> %ByteBuffer do
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  let count = pval(pk)
  return copy_func_types_go(%out, buf, pos: ppos(pk), remaining: count, off)
end
let copy_func_types_go = fn (out: %ByteBuffer, buf: &ByteBuffer, pos: i64, remaining: i64, off: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let pk = rd_uleb(buf, pos)
  let %out = bb.push_uleb128(buf: %out, val: pval(pk) + off)
  return copy_func_types_go(%out, buf, pos: ppos(pk), remaining: remaining - 1, off)
end

let emit_merged_globals = fn (out: %ByteBuffer, m_buf: &ByteBuffer, m_sec: i64,
    d_buf: &ByteBuffer, d_sec: i64, type_off: i64) -> %ByteBuffer do
  let m_count = count_sec(buf: m_buf, sec_pk: m_sec)
  let d_count = count_sec(buf: d_buf, sec_pk: d_sec)
  if m_count + d_count == 0 then return %out end
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: d_count + m_count)
  let %tmp = copy_sec_body(buf: %tmp, src: d_buf, sec_pk: d_sec)
  let %tmp = copy_globals_with_type_off(out: %tmp, buf: m_buf, pos: sec_body(buf: m_buf, sec_pk: m_sec), remaining: m_count, off: type_off)
  let %out = emit_sec(%out, sec_id: 6, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let copy_globals_with_type_off = fn (out: %ByteBuffer, buf: &ByteBuffer, pos: i64, remaining: i64, off: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let vt = bb.get_byte(buf, idx: pos)
  if vt == vt_ref_null_ht || vt == vt_ref_ht then
    let %out = bb.push_byte(buf: %out, byte: vt)
    let SlebRes(val: tv, pos: tp) = rd_sleb(buf, pos: pos + 1)
    let %out = bb.push_sleb128(buf: %out, val: tv + off)
    let mut_byte = bb.get_byte(buf, idx: tp)
    let %out = bb.push_byte(buf: %out, byte: mut_byte)
    let init_start = tp + 1
    let init_op = bb.get_byte(buf, idx: init_start)
    if init_op == op_ref_null then
      let %out = bb.push_byte(buf: %out, byte: op_ref_null)
      let SlebRes(val: tv2, pos: tp2) = rd_sleb(buf, pos: init_start + 1)
      let %out = bb.push_sleb128(buf: %out, val: tv2 + off)
      let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf, idx: tp2))
      return copy_globals_with_type_off(out: %out, buf, pos: tp2 + 1, remaining: remaining - 1, off)
    end
    let end2 = scan_to_end(buf, pos: init_start)
    let %out = bb.copy_range(dst: %out, src: buf, start: init_start, end_pos: end2)
    return copy_globals_with_type_off(out: %out, buf, pos: end2, remaining: remaining - 1, off)
  end
  let %out = bb.push_byte(buf: %out, byte: vt)
  let mut_byte = bb.get_byte(buf, idx: pos + 1)
  let %out = bb.push_byte(buf: %out, byte: mut_byte)
  let init_start = pos + 2
  let end2 = scan_to_end(buf, pos: init_start)
  let %out = bb.copy_range(dst: %out, src: buf, start: init_start, end_pos: end2)
  return copy_globals_with_type_off(out: %out, buf, pos: end2, remaining: remaining - 1, off)
end

let scan_to_end = fn (buf: &ByteBuffer, pos: i64) -> i64 do
  let b = bb.get_byte(buf, idx: pos)
  if b == op_end then return pos + 1 end
  return scan_to_end(buf, pos: pos + 1)
end

// Like emit_merged_globals but patches main G0 (heap_base += reloc) and G1 (str_base = reloc).
// Main globals are: G0 (heap_base), G1 (str_base=0→patched), G2 (placeholder).
// Each global: valtype(1) + mut(1) + i32.const(1) + sleb128(value) + end(1).
let emit_remapped_exports = fn (out: %ByteBuffer, m_buf: &ByteBuffer, m_sec: i64,
    remap: &ByteBuffer) -> %ByteBuffer do
  if m_sec == 0 then return %out end
  let %tmp = bb.empty()
  let pk = rd_uleb(buf: m_buf, pos: sec_off(pk: m_sec))
  let count = pval(pk)
  let %tmp = bb.push_uleb128(buf: %tmp, val: count)
  let %tmp = remap_export_entries(out: %tmp, buf: m_buf, pos: ppos(pk),
    remaining: count, remap)
  let %out = emit_sec(%out, sec_id: 7, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let remap_export_entries = fn (out: %ByteBuffer, buf: &ByteBuffer, pos: i64,
    remaining: i64, remap: &ByteBuffer) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let name_start = pos
  let StrPos(s: _name, pos: pos2) = rd_str(buf, pos)
  let kind = bb.get_byte(buf, idx: pos2)
  let pk = rd_uleb(buf, pos: pos2 + 1)
  let old_idx = pval(pk)
  let pos3 = ppos(pk)
  let %out = bb.copy_range(dst: %out, src: buf, start: name_start, end_pos: pos2)
  let %out = bb.push_byte(buf: %out, byte: kind)
  if kind == 0 then
    let new_idx = intarr_get(arr: remap, idx: old_idx)
    let %out = bb.push_uleb128(buf: %out, val: new_idx)
    return remap_export_entries(%out, buf, pos: pos3, remaining: remaining - 1, remap)
  end
  let %out = bb.push_uleb128(buf: %out, val: old_idx)
  return remap_export_entries(%out, buf, pos: pos3, remaining: remaining - 1, remap)
end

let maybe_rewrite_bodies = fn (ctx: RwCtx, remap: &ByteBuffer, buf: %ByteBuffer, src: &ByteBuffer, sec_pk: i64) -> %ByteBuffer do
  if sec_pk > 0 then
    return rewrite_code_bodies(ctx, remap, out: %buf, src, sec_pk)
  end
  return %buf
end

let emit_stub_bodies = fn (out: %ByteBuffer, i: i64, n: i64) -> %ByteBuffer do
  if i >= n then return %out end
  let %out = bb.push_uleb128(buf: %out, val: 3)
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_byte(buf: %out, byte: op_end)
  return emit_stub_bodies(%out, i: i + 1, n)
end

let rewrite_code_bodies = fn (ctx: RwCtx, remap: &ByteBuffer, out: %ByteBuffer, src: &ByteBuffer, sec_pk: i64) -> %ByteBuffer do
  let pk = rd_uleb(buf: src, pos: sec_off(pk: sec_pk))
  let count = pval(pk)
  let %body_buf = bb.empty()
  let %out = rewrite_code_go(ctx, remap, %out, src, pos: ppos(pk), remaining: count, %body_buf)
  return %out
end
let rewrite_code_go = fn (ctx: RwCtx, remap: &ByteBuffer, out: %ByteBuffer, src: &ByteBuffer, pos: i64, remaining: i64, body_buf: %ByteBuffer) -> %ByteBuffer do
  if remaining <= 0 then
    bb.free(buf: %body_buf)
    return %out
  end
  let pk = rd_uleb(buf: src, pos)
  let body_size = pval(pk)
  let body_start = ppos(pk)
  let body_end = body_start + body_size
  let %body_buf = bb.truncate(buf: %body_buf, len: 0)
  let %body_buf = rw_body(ctx, remap, out: %body_buf, src, body_start, body_end)
  let new_size = bb.length(buf: &body_buf)
  let %out = bb.push_uleb128(buf: %out, val: new_size)
  let %out = bb.push_buf(dst: %out, src: &body_buf)
  return rewrite_code_go(ctx, remap, %out, src, pos: body_end, remaining: remaining - 1, %body_buf)
end

// Find the highest data-segment end (offset + length) in a data section.
// Returns 0 if no data segments.
let find_data_end = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  return find_data_end_go(buf, pos: ppos(pk), remaining: pval(pk), max_end: 0)
end
let find_data_end_go = fn (buf: &ByteBuffer, pos: i64, remaining: i64, max_end: i64) -> i64 do
  if remaining <= 0 then return max_end end
  // Active segment: flags=0x00, i32.const(0x41), uleb128(offset), end(0x0B), uleb128(len), data
  let _flags = bb.get_byte(buf, idx: pos)
  let _opcode = bb.get_byte(buf, idx: pos + 1)
  let pk_off = rd_uleb(buf, pos: pos + 2)
  let offset = pval(pk: pk_off)
  let end_expr = ppos(pk: pk_off) + 1
  let pk_len = rd_uleb(buf, pos: end_expr)
  let data_len = pval(pk: pk_len)
  let data_start = ppos(pk: pk_len)
  let seg_end = offset + data_len
  let new_max = if seg_end > max_end then seg_end else max_end end
  return find_data_end_go(buf, pos: data_start + data_len, remaining: remaining - 1, max_end: new_max)
end

// Copy main data segments with offset relocation: each segment's i32.const offset += reloc.
let copy_data_relocated = fn (out: %ByteBuffer, src: &ByteBuffer, sec_pk: i64, reloc: i64) -> %ByteBuffer do
  if sec_pk == 0 then return %out end
  let pk = rd_uleb(buf: src, pos: sec_off(pk: sec_pk))
  return copy_data_relocated_go(%out, src, pos: ppos(pk), remaining: pval(pk), reloc)
end
let copy_data_relocated_go = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, remaining: i64, reloc: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  // Emit flags + opcode
  let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos))
  let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos + 1))
  // Read original offset, add reloc, emit new offset
  let pk_off = rd_uleb(buf: src, pos: pos + 2)
  let new_offset = pval(pk: pk_off) + reloc
  let %out = bb.push_sleb128(buf: %out, val: new_offset)
  // Emit end opcode
  let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: ppos(pk: pk_off)))
  // Copy data length + data bytes
  let end_expr = ppos(pk: pk_off) + 1
  let pk_len = rd_uleb(buf: src, pos: end_expr)
  let data_len = pval(pk: pk_len)
  let data_start = ppos(pk: pk_len)
  let %out = bb.push_uleb128(buf: %out, val: data_len)
  let %out = bb.copy_range(dst: %out, src, start: data_start, end_pos: data_start + data_len)
  return copy_data_relocated_go(%out, src, pos: data_start + data_len, remaining: remaining - 1, reloc)
end

let emit_merged_data = fn (out: %ByteBuffer, m_buf: &ByteBuffer, m_sec: i64,
    d_buf: &ByteBuffer, d_sec: i64, reloc: i64) -> %ByteBuffer do
  let m_count = count_sec(buf: m_buf, sec_pk: m_sec)
  let d_count = count_sec(buf: d_buf, sec_pk: d_sec)
  if m_count + d_count == 0 then return %out end
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: d_count + m_count)
  let %tmp = copy_sec_body(buf: %tmp, src: d_buf, sec_pk: d_sec)
  let %tmp = copy_data_relocated(out: %tmp, src: m_buf, sec_pk: m_sec, reloc)
  let %out = emit_sec(%out, sec_id: 11, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let maybe_remap_elem = fn (buf: %ByteBuffer, src: &ByteBuffer, sec_pk: i64, remap: &ByteBuffer) -> %ByteBuffer do
  if sec_pk > 0 then
    return remap_elem_segments(out: %buf, buf: src, sec_pk, remap)
  end
  return %buf
end

let emit_merged_elements = fn (out: %ByteBuffer,
    d_buf: &ByteBuffer, d_sec: i64, remap_d: &ByteBuffer,
    m_buf: &ByteBuffer, m_sec: i64, remap_m: &ByteBuffer) -> %ByteBuffer do
  let d_count = count_sec(buf: d_buf, sec_pk: d_sec)
  let m_count = count_sec(buf: m_buf, sec_pk: m_sec)
  if d_count + m_count == 0 then return %out end
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: d_count + m_count)
  let %tmp = maybe_remap_elem(buf: %tmp, src: d_buf, sec_pk: d_sec, remap: remap_d)
  let %tmp = maybe_remap_elem(buf: %tmp, src: m_buf, sec_pk: m_sec, remap: remap_m)
  let %out = emit_sec(%out, sec_id: 9, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let remap_elem_segments = fn (out: %ByteBuffer, buf: &ByteBuffer, sec_pk: i64, remap: &ByteBuffer) -> %ByteBuffer do
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  return remap_elem_go(%out, buf, pos: ppos(pk), remaining: pval(pk), remap)
end
let remap_elem_go = fn (out: %ByteBuffer, buf: &ByteBuffer, pos: i64, remaining: i64, remap: &ByteBuffer) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let kind = bb.get_byte(buf, idx: pos)
  let %out = bb.push_byte(buf: %out, byte: kind)
  if kind == 0 then
    // Init expression: i32.const <sleb-offset> end — no remap needed.
    // Bulk-copy the opcode + SLEB + end byte (scan_sleb_end finds terminal).
    let sleb_start = pos + 2
    let sleb_end = scan_sleb_end(buf, pos: sleb_start)
    // Copy [pos+1 .. sleb_end+1) — opcode + SLEB + end byte
    let %out = bb.copy_range(dst: %out, src: buf, start: pos + 1, end_pos: sleb_end + 1)
    let pk = rd_uleb(buf, pos: sleb_end + 1)
    let n_funcs = pval(pk)
    let %out = bb.push_uleb128(buf: %out, val: n_funcs)
    let BufPos(buf: %out, pos: next_pos) = remap_elem_funcs(%out, buf, pos: ppos(pk), remaining: n_funcs, remap)
    return remap_elem_go(%out, buf, pos: next_pos, remaining: remaining - 1, remap)
  end
  return %out
end

let remap_elem_funcs = fn (out: %ByteBuffer, buf: &ByteBuffer, pos: i64, remaining: i64, remap: &ByteBuffer) -> BufPos do
  if remaining <= 0 then return BufPos(buf: %out, pos) end
  let pk = rd_uleb(buf, pos)
  let old_idx = pval(pk)
  let new_idx = intarr_get(arr: remap, idx: old_idx)
  let %out = bb.push_uleb128(buf: %out, val: new_idx)
  return remap_elem_funcs(%out, buf, pos: ppos(pk), remaining: remaining - 1, remap)
end

// ─── Full merge assembler ─────────────────────────────────────────────────
let emit_tag_sec_with_off = fn (out: %ByteBuffer, buf: &ByteBuffer, sec_pk: i64, off: i64) -> %ByteBuffer do
  if sec_pk == 0 then return %out end
  let tag_count = count_sec(buf, sec_pk)
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: tag_count)
  let %tmp = offset_tag_types(out: %tmp, buf, pos: sec_body(buf, sec_pk), remaining: tag_count, off)
  let %out = emit_sec(%out, sec_id: 13, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end
let offset_tag_types = fn (out: %ByteBuffer, buf: &ByteBuffer, pos: i64, remaining: i64, off: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let pk1 = rd_uleb(buf, pos)
  let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk1))
  let pk2 = rd_uleb(buf, pos: ppos(pk: pk1))
  let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk2) + off)
  return offset_tag_types(%out, buf, pos: ppos(pk: pk2), remaining: remaining - 1, off)
end

// ─── Custom section preservation ──────────────────────────────────────────
// Scan all custom sections (id=0) in buf. Returns an smap keyed by sequential
// index ("0", "1", …) -> pack(content_start, sec_size). The special key
// "__count" holds the total number of custom sections discovered.
// `scan_secs` collapses all customs onto key="0", which is why we need this.
let scan_custom_secs = fn (buf: &ByteBuffer) -> %StringMap do
  let %map = sm.empty()
  return scan_custom_go(buf, pos: 8, end_pos: bb.length(buf), %map, idx: 0)
end
let scan_custom_go = fn (buf: &ByteBuffer, pos: i64, end_pos: i64, map: %StringMap, idx: i64) -> %StringMap do
  if pos >= end_pos then
    return sm.put(%map, key: "__count", value: idx)
  end
  let sec_id = bb.get_byte(buf, idx: pos)
  let pk = rd_uleb(buf, pos: pos + 1)
  let sec_size = pval(pk)
  let content_start = ppos(pk)
  if sec_id == 0 then
    let %map = sm.put(%map, key: str.from_i64(val: idx), value: pack(val: content_start, p: sec_size))
    return scan_custom_go(buf, pos: content_start + sec_size, end_pos, %map, idx: idx + 1)
  end
  return scan_custom_go(buf, pos: content_start + sec_size, end_pos, %map, idx)
end

// Compare the ULEB-prefixed section name at `content_start` to `target`.
let custom_name_equals = fn (buf: &ByteBuffer, content_start: i64, target: string) -> bool do
  let pk = rd_uleb(buf, pos: content_start)
  let len = pval(pk)
  let name_start = ppos(pk)
  let tlen = str.byte_length(s: target)
  if len != tlen then return false end
  return name_eq_go(buf, start: name_start, target, i: 0, n: tlen)
end
let name_eq_go = fn (buf: &ByteBuffer, start: i64, target: string, i: i64, n: i64) -> bool do
  if i >= n then return true end
  if bb.get_byte(buf, idx: start + i) != str.char_code(s: target, idx: i) then return false end
  return name_eq_go(buf, start, target, i: i + 1, n)
end

// Emit a custom section verbatim: id=0, ULEB(size), content bytes.
let emit_custom_raw = fn (out: %ByteBuffer, src: &ByteBuffer, content_start: i64, sec_size: i64) -> %ByteBuffer do
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_uleb128(buf: %out, val: sec_size)
  return bb.copy_range(dst: %out, src, start: content_start, end_pos: content_start + sec_size)
end

// Iterate name-section subsections; dispatch on subsec id.
// Subsec 1 (func names) and 2 (local names) get func_idx remapped.
// All other subsecs are pass-through.
let emit_name_subsecs_go = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64,
                                 end_pos: i64, remap: &ByteBuffer, remap_size: i64) -> %ByteBuffer do
  if pos >= end_pos then return %out end
  let sub_id = bb.get_byte(buf: src, idx: pos)
  let pk = rd_uleb(buf: src, pos: pos + 1)
  let sub_size = pval(pk)
  let sub_start = ppos(pk)
  let sub_end = sub_start + sub_size
  let %out = if sub_id == 1 then
      emit_name_funcsubsec(%out, src, sub_start, remap, remap_size)
    else if sub_id == 2 then
      emit_name_localsubsec(%out, src, sub_start, sub_size, remap, remap_size)
    else
      bb.copy_range(dst: %out, src, start: pos, end_pos: sub_end)
    end
  return emit_name_subsecs_go(%out, src, pos: sub_end, end_pos, remap, remap_size)
end

// Re-emit subsec 1 (function names): vec<(func_idx:ULEB, name:ULEB+bytes)>.
// Build into tmp buf so we can prefix with ULEB(payload_len).
let emit_name_funcsubsec = fn (out: %ByteBuffer, src: &ByteBuffer, sub_start: i64,
                                 remap: &ByteBuffer, remap_size: i64) -> %ByteBuffer do
  let pk = rd_uleb(buf: src, pos: sub_start)
  let count = pval(pk)
  let entries_start = ppos(pk)
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: count)
  let %tmp = emit_name_func_entries(out: %tmp, src, pos: entries_start,
                                      remaining: count, remap, remap_size)
  let tmp_len = bb.length(buf: &tmp)
  let %out = bb.push_byte(buf: %out, byte: 1)
  let %out = bb.push_uleb128(buf: %out, val: tmp_len)
  let %out = bb.push_buf(dst: %out, src: &tmp)
  bb.free(buf: %tmp)
  return %out
end
let emit_name_func_entries = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64,
                                   remaining: i64, remap: &ByteBuffer, remap_size: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let pk1 = rd_uleb(buf: src, pos)
  let old_idx = pval(pk: pk1)
  let after_idx = ppos(pk: pk1)
  let pk2 = rd_uleb(buf: src, pos: after_idx)
  let n_len = pval(pk: pk2)
  let n_end = ppos(pk: pk2) + n_len
  let new_idx = if old_idx < remap_size then intarr_get(arr: remap, idx: old_idx) else old_idx end
  let %out = bb.push_uleb128(buf: %out, val: new_idx)
  let %out = bb.copy_range(dst: %out, src, start: after_idx, end_pos: n_end)
  return emit_name_func_entries(%out, src, pos: n_end, remaining: remaining - 1, remap, remap_size)
end

// Re-emit subsec 2 (local names): vec<(func_idx:ULEB, vec<(local_idx, name)>)>.
// Only the outer func_idx is remapped; inner local vec is copied verbatim.
let emit_name_localsubsec = fn (out: %ByteBuffer, src: &ByteBuffer, sub_start: i64, sub_size: i64,
                                  remap: &ByteBuffer, remap_size: i64) -> %ByteBuffer do
  let pk = rd_uleb(buf: src, pos: sub_start)
  let count = pval(pk)
  let entries_start = ppos(pk)
  let sub_end = sub_start + sub_size
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: count)
  let %tmp = emit_name_local_entries(out: %tmp, src, pos: entries_start, end_pos: sub_end,
                                       remaining: count, remap, remap_size)
  let tmp_len = bb.length(buf: &tmp)
  let %out = bb.push_byte(buf: %out, byte: 2)
  let %out = bb.push_uleb128(buf: %out, val: tmp_len)
  let %out = bb.push_buf(dst: %out, src: &tmp)
  bb.free(buf: %tmp)
  return %out
end
let emit_name_local_entries = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, end_pos: i64,
                                    remaining: i64, remap: &ByteBuffer, remap_size: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let pk1 = rd_uleb(buf: src, pos)
  let old_idx = pval(pk: pk1)
  let after_idx = ppos(pk: pk1)
  let pk2 = rd_uleb(buf: src, pos: after_idx)
  let inner_count = pval(pk: pk2)
  let inner_start = ppos(pk: pk2)
  let inner_end = skip_local_inner(src, pos: inner_start, remaining: inner_count)
  let new_idx = if old_idx < remap_size then intarr_get(arr: remap, idx: old_idx) else old_idx end
  let %out = bb.push_uleb128(buf: %out, val: new_idx)
  let %out = bb.copy_range(dst: %out, src, start: after_idx, end_pos: inner_end)
  return emit_name_local_entries(%out, src, pos: inner_end, end_pos,
                                   remaining: remaining - 1, remap, remap_size)
end
let skip_local_inner = fn (src: &ByteBuffer, pos: i64, remaining: i64) -> i64 do
  if remaining <= 0 then return pos end
  let pk1 = rd_uleb(buf: src, pos)
  let pk2 = rd_uleb(buf: src, pos: ppos(pk: pk1))
  let name_end = ppos(pk: pk2) + pval(pk: pk2)
  return skip_local_inner(src, pos: name_end, remaining: remaining - 1)
end

// Emit a "name" custom section with function indices remapped via `remap`.
// The section-name ULEB-string is copied verbatim; subsections are walked.
let emit_name_remapped = fn (out: %ByteBuffer, src: &ByteBuffer,
                              content_start: i64, sec_size: i64,
                              remap: &ByteBuffer, remap_size: i64) -> %ByteBuffer do
  let sec_end = content_start + sec_size
  let pk = rd_uleb(buf: src, pos: content_start)
  let name_len = pval(pk)
  let name_end = ppos(pk) + name_len
  let %payload = bb.empty()
  let %payload = bb.copy_range(dst: %payload, src, start: content_start, end_pos: name_end)
  let %payload = emit_name_subsecs_go(out: %payload, src, pos: name_end, end_pos: sec_end,
                                        remap, remap_size)
  let payload_len = bb.length(buf: &payload)
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_uleb128(buf: %out, val: payload_len)
  let %out = bb.push_buf(dst: %out, src: &payload)
  bb.free(buf: %payload)
  return %out
end

// Emit all preserved custom sections from `buf`:
//   * "name"  → rewritten via `remap` (func indices remapped per merge).
//   * others  → passed through byte-for-byte (DWARF, producers, target_features,
//     etc.). For .debug_* this is a placeholder — PC-offset rewriting is only
//     needed when nxc codegen starts emitting DWARF (currently it does not).
let emit_preserved_customs = fn (out: %ByteBuffer, buf: &ByteBuffer, customs: &StringMap,
                                   remap: &ByteBuffer, remap_size: i64) -> %ByteBuffer do
  let total = sm.get_or(map: customs, key: "__count", default: 0)
  return emit_custom_each(%out, buf, customs, idx: 0, total,
                            remap, remap_size)
end
let emit_custom_each = fn (out: %ByteBuffer, buf: &ByteBuffer, customs: &StringMap, idx: i64, total: i64,
                             remap: &ByteBuffer, remap_size: i64) -> %ByteBuffer do
  if idx >= total then return %out end
  let pk = sm.get_or(map: customs, key: str.from_i64(val: idx), default: 0)
  let content_start = pval(pk)
  let sec_size = ppos(pk)
  let %out = if custom_name_equals(buf, content_start, target: "name") then
      emit_name_remapped(%out, src: buf, content_start, sec_size,
                          remap, remap_size)
    else
      emit_custom_raw(%out, src: buf, content_start, sec_size)
    end
  return emit_custom_each(%out, buf, customs, idx: idx + 1, total,
                            remap, remap_size)
end

export let merge_with_stdlib = fn (core_wasm: %ByteBuffer, stdlib_path: string) -> %ByteBuffer throws { Exn } do
  let %dep = bb.read_binary_file(path: stdlib_path)

  let %m_secs = scan_secs(buf: &core_wasm)
  let %d_secs = scan_secs(buf: &dep)

  // Dep types first → dep type indices unchanged, main types offset by dep count
  let d_type_off = 0
  let m_type_off = count_sec(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 1))

  let %dep_exports = parse_dep_exports(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 7))

  let dep_fimp = count_func_imps(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 2))
  let kept_fimp = dep_fimp
  let n_stubs = 0

  let d_loc = count_sec(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 3))
  let m_fimp = count_func_imps(buf: &core_wasm, sec_pk: get_sec(map: &m_secs, sec: 2))
  let m_loc = count_sec(buf: &core_wasm, sec_pk: get_sec(map: &m_secs, sec: 3))

  // Count main's non-stdlib imports
  let m_imp_sec_pk = get_sec(map: &m_secs, sec: 2)
  // m_kept_all = ALL non-stdlib imports (for import section entry count)
  let m_kept_all = count_main_kept_imps(buf: &core_wasm, sec_pk: m_imp_sec_pk)
  // m_kept = non-stdlib FUNCTION imports only (for function index layout)
  let m_kept = count_main_kept_func_imps(buf: &core_wasm, sec_pk: m_imp_sec_pk)

  // Dep remap intarr: identity for WASI imports, then offset for dep locals.
  // All stdlib imports are WASI (indices preserved); only used by element-segment remap.
  let %remap_d = intarr_new()
  let %remap_d = push_identity(arr: %remap_d, i: 0, n: dep_fimp)
  let %remap_d = remap_dep_locals(remap: %remap_d, dep_fimp, d_loc,
    kept_fimp: kept_fimp + m_kept, n_stubs)

  let %remap_m = intarr_new()
  // kept_fimp+m_kept = base for remap_dep_func (dep locals start after all func imports)
  // m_imp_base = kept_fimp (base for non-stdlib main func imports, right after dep WASI imports)
  let %resolve_ctx = ResolveCtx(
    remap: %remap_m,
    kept_fimp: kept_fimp + m_kept,
    n_stubs,
    dep_fimp,
    m_imp_base: kept_fimp)
  let %resolve_ctx = resolve_main_imports(ctx: %resolve_ctx, &dep_exports, buf: &core_wasm, sec_pk: m_imp_sec_pk)
  let ResolveCtx(remap: %remap_m, kept_fimp: _, n_stubs: _, dep_fimp: _, m_imp_base: _) = resolve_ctx

  // Main locals start after: dep WASI imports + main non-stdlib func imports + stubs + dep locals
  let %remap_m = remap_main_locals(remap: %remap_m, m_fimp, m_loc,
    kept_fimp: kept_fimp + m_kept, n_stubs, d_loc)

  let d_glo = count_sec(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 6))
  let d_tbl_count = count_sec(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 4))

  // Assemble output — all section emission inlined to avoid parameter-passing bugs
  // in Nexus functions with many params (param sorting causes confusion)
  let %out = assemble_header()

  // Section 1: merged types (DEP first, then main)
  let %out = emit_merged_types_inline(%out,
    m_buf: &dep, m_sec: get_sec(map: &d_secs, sec: 1),
    d_buf: &core_wasm, d_sec: get_sec(map: &m_secs, sec: 1))

  // Section 2: merged imports (dep WASI imports + main non-stdlib imports)
  let d_imp_pk = get_sec(map: &d_secs, sec: 2)
  let dep_imp_count = count_sec(buf: &dep, sec_pk: d_imp_pk)
  let total_imp_count = dep_imp_count + m_kept_all
  let %tmp_i = bb.empty()
  let %tmp_i = bb.push_uleb128(buf: %tmp_i, val: total_imp_count)
  // Copy dep imports with type offset
  let %tmp_i = if d_imp_pk > 0 then
    copy_imports_with_type_off(out: %tmp_i, buf: &dep,
      pos: sec_body(buf: &dep, sec_pk: d_imp_pk), remaining: dep_imp_count, type_off: d_type_off)
  else %tmp_i end
  let %tmp_i = copy_main_kept_imps(out: %tmp_i, buf: &core_wasm, sec_pk: m_imp_sec_pk, type_off: m_type_off)
  let %out = emit_sec(%out, sec_id: 2, content: &tmp_i)
  bb.free(buf: %tmp_i)

  // Section 3: merged func types (count + dep with type offset + main)
  let d_func_sec_pk = get_sec(map: &d_secs, sec: 3)
  let m_func_sec_pk = get_sec(map: &m_secs, sec: 3)
  let %tmp_f = bb.empty()
  // Use code section counts (rewrite_code_bodies determines the actual body count)
  let d_code_cnt = count_sec(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 10))
  let m_code_cnt = count_sec(buf: &core_wasm, sec_pk: get_sec(map: &m_secs, sec: 10))
  // TODO: m_code_cnt != m_loc (23 vs 28 for simple program). Need to investigate.
  // Use d_code_cnt + m_code_cnt to match code section bodies
  let n_total_funcs = n_stubs + d_code_cnt + m_code_cnt
  let %tmp_f = bb.push_uleb128(buf: %tmp_f, val: n_total_funcs)
  // Dep func types: NO offset (dep types first)
  let %tmp_f = copy_sec_body(buf: %tmp_f, src: &dep, sec_pk: d_func_sec_pk)
  // Main func types: offset by m_type_off
  let %tmp_f = if m_func_sec_pk > 0 then
    copy_func_types_with_off(out: %tmp_f, buf: &core_wasm, sec_pk: m_func_sec_pk, off: m_type_off)
  else %tmp_f end
  let %out = emit_sec(%out, sec_id: 3, content: &tmp_f)
  bb.free(buf: %tmp_f)

  // Section 4: table (dep tables + main's extra tables if any)
  let d_tbl_pk = get_sec(map: &d_secs, sec: 4)
  let m_tbl_pk = get_sec(map: &m_secs, sec: 4)
  let m_tbl_total = count_sec(buf: &core_wasm, sec_pk: m_tbl_pk)
  let %out = if m_tbl_total > 1 then
    let %tmp_t = bb.empty()
    let %tmp_t = bb.push_uleb128(buf: %tmp_t, val: d_tbl_count + m_tbl_total - 1)
    let %tmp_t = if d_tbl_pk > 0 then
      let d_off = sec_off(pk: d_tbl_pk)
      let d_sz = sec_sz(pk: d_tbl_pk)
      let d_cnt_pk = rd_uleb(buf: &dep, pos: d_off)
      bb.copy_range(dst: %tmp_t, src: &dep, start: ppos(pk: d_cnt_pk), end_pos: d_off + d_sz)
    else %tmp_t end
    let m_off = sec_off(pk: m_tbl_pk)
    let m_sz = sec_sz(pk: m_tbl_pk)
    let m_cnt_pk = rd_uleb(buf: &core_wasm, pos: m_off)
    let after_first = skip_table_entry(buf: &core_wasm, pos: ppos(pk: m_cnt_pk))
    let %tmp_t = copy_table_entries_with_type_off(buf: %tmp_t, src: &core_wasm, pos: after_first, end_pos: m_off + m_sz, off: m_type_off)
    emit_sec_and_free(%out, sec_id: 4, tmp: %tmp_t)
  else
    copy_raw_sec(%out, src: &dep, sec_pk: d_tbl_pk, sec_id: 4)
  end
  // Compute relocation base: dep_initial_pages * 65536 (above dep's entire memory region)
  // This ensures main data doesn't overlap with dep's stack, data, or heap.
  // Size memory to cover both dep and main data (main already at absolute offsets)
  let d_data_end = find_data_end(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 11))
  let m_data_end = find_data_end(buf: &core_wasm, sec_pk: get_sec(map: &m_secs, sec: 11))
  let max_data = if d_data_end > m_data_end then d_data_end else m_data_end end
  let min_pages = (max_data + 65535) / 65536
  let dep_pages = if get_sec(map: &d_secs, sec: 5) > 0 then
    let pk_mem = rd_uleb(buf: &dep, pos: sec_off(pk: get_sec(map: &d_secs, sec: 5)))
    let pk_min = rd_uleb(buf: &dep, pos: ppos(pk: pk_mem) + 1)
    pval(pk: pk_min)
  else 0 end
  let pages_raw = if dep_pages > min_pages then dep_pages else min_pages end
  // Reserve ≥256 initial pages (16MB) for merged modules. The compiler loads
  // stdlib (~300KB) + main code + allocates Vec<u8>-backed buffers; dlmalloc
  // fragmentation under doubling-growth patterns exhausts a 1.2MB heap well
  // before memory.grow proves out. 16MB suffices for stage2.
  let pages = if pages_raw < 256 then 256 else pages_raw end
  let %tmp_mem = bb.empty()
  let %tmp_mem = bb.push_uleb128(buf: %tmp_mem, val: 1)
  let %tmp_mem = bb.push_byte(buf: %tmp_mem, byte: 0)
  let %tmp_mem = bb.push_uleb128(buf: %tmp_mem, val: pages)
  let %out = emit_sec(%out, sec_id: 5, content: &tmp_mem)
  bb.free(buf: %tmp_mem)
  // Section 13: tag (from main, type indices offset by m_type_off)
  let %out = emit_tag_sec_with_off(%out, buf: &core_wasm, sec_pk: get_sec(map: &m_secs, sec: 13), off: m_type_off)

  // Section 6: merged globals (dep first, then main)
  let m_glo_pk = get_sec(map: &m_secs, sec: 6)
  let d_glo_pk = get_sec(map: &d_secs, sec: 6)
  let %out = emit_merged_globals(%out,
    m_buf: &core_wasm, m_sec: m_glo_pk,
    d_buf: &dep, d_sec: d_glo_pk, type_off: m_type_off)

  // Section 7: remapped exports (main exports with func idx remap)
  let %out = emit_remapped_exports(%out,
    m_buf: &core_wasm, m_sec: get_sec(map: &m_secs, sec: 7), remap: &remap_m)

  // Section 9: merged elements (dep + main, both remapped)
  let %out = emit_merged_elements(%out,
    d_buf: &dep, d_sec: get_sec(map: &d_secs, sec: 9), &remap_d,
    m_buf: &core_wasm, m_sec: get_sec(map: &m_secs, sec: 9), &remap_m)

  // Section 10: merged code (stubs + dep bodies rewritten + main bodies rewritten) — inlined
  let d_code_sec_pk = get_sec(map: &d_secs, sec: 10)
  let m_code_sec_pk = get_sec(map: &m_secs, sec: 10)
  // Use actual code section counts (must match bodies written by rewrite_code_bodies)
  let d_code_count = count_sec(buf: &dep, sec_pk: d_code_sec_pk)
  let m_code_count = count_sec(buf: &core_wasm, sec_pk: m_code_sec_pk)
  let %tmp_c = bb.empty()
  let %tmp_c = bb.push_uleb128(buf: %tmp_c, val: d_code_count + m_code_count)
  let %tmp_c = emit_stub_bodies(out: %tmp_c, i: 0, n: n_stubs)
  let dep_rw_ctx = RwCtx(type_off: 0, tbl_off: 0, glo_off: 0)
  let %tmp_c = maybe_rewrite_bodies(ctx: dep_rw_ctx, remap: &remap_d, buf: %tmp_c, src: &dep, sec_pk: d_code_sec_pk)
  // Main code bodies — rewrite with intarr-backed func remap (remap_m covers
  // all main fidxs: imports 0..m_fimp, locals m_fimp..m_fimp+m_loc)
  let rw_ctx = RwCtx(type_off: m_type_off, tbl_off: d_tbl_count - 1, glo_off: d_glo)
  let %tmp_c = maybe_rewrite_bodies(ctx: rw_ctx, remap: &remap_m, buf: %tmp_c, src: &core_wasm, sec_pk: m_code_sec_pk)
  let %out = emit_sec(%out, sec_id: 10, content: &tmp_c)
  bb.free(buf: %tmp_c)

  // Section 11: merged data (dep + main, both verbatim — codegen already used correct offsets)
  let %out = emit_merged_data(%out,
    m_buf: &core_wasm, m_sec: get_sec(map: &m_secs, sec: 11),
    d_buf: &dep, d_sec: get_sec(map: &d_secs, sec: 11), reloc: 0)

  // Preserve custom sections from both inputs. `name` sections are rewritten
  // with func indices remapped; other customs (producers, target_features,
  // future .debug_*) pass through verbatim. Must run before the remap intarrs
  // are freed.
  let %m_customs = scan_custom_secs(buf: &core_wasm)
  let %d_customs = scan_custom_secs(buf: &dep)
  let %out = emit_preserved_customs(%out, buf: &core_wasm, customs: &m_customs,
                                      remap: &remap_m, remap_size: m_fimp + m_loc)
  let %out = emit_preserved_customs(%out, buf: &dep, customs: &d_customs,
                                      remap: &remap_d, remap_size: dep_fimp + d_loc)
  sm.free(map: %m_customs)
  sm.free(map: %d_customs)

  sm.free(map: %m_secs)
  sm.free(map: %d_secs)
  sm.free(map: %dep_exports)
  bb.free(buf: %remap_d)
  bb.free(buf: %remap_m)
  bb.free(buf: %dep)
  bb.free(buf: %core_wasm)

  return %out
end

let assemble_header = fn () -> %ByteBuffer do
  let %out = bb.empty()
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_string(buf: %out, s: "asm")
  let %out = bb.push_byte(buf: %out, byte: 1)
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_byte(buf: %out, byte: 0)
  return %out
end

