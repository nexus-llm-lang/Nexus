/**
 * wasm/merge: stdlib-merge phase — links the compiler-emitted core WASM with
 * the precompiled stdlib.wasm and the runtime layer to produce a self-contained
 * module.
 *
 * Owns:
 * - Top-level orchestration (merge_with_stdlib)
 * - Section scanning (scan_secs)
 * - Main import resolution + remap intarr population (resolve_main_imports,
 *   push_identity / push_offset, remap_main_locals / remap_dep_locals)
 * - Main non-stdlib import counting and copying
 *
 * Does not own:
 * - Generic WASM binary decode (ULEB/SLEB) — see src/backend/wasm/read.nx
 * - Section-layout constants / opcodes — see src/backend/wasm/defs.nx
 * - Instruction rewriting — see src/backend/wasm/merge/instruction_rewrite.nx
 * - Per-section emitters / scanning helpers (rd_str, skip_imp_desc, …) —
 *   see src/backend/wasm/merge/section_emit.nx
 *
 * Consumers: src/main.nx calls merge_with_stdlib at the end of the pipeline.
 */
import { ByteBuffer }, * as bb from "std:bytebuffer"
import { StringMap }, * as sm from "std:stringmap"
import * as str from "std:str"
import { FileNotFound } from "std:fs"
import { pack, pval, ppos, rd_uleb } from "src/backend/wasm/read.nx"
import { wasm_page_size, wasm_page_mask, default_initial_pages } from "src/backend/wasm/defs.nx"
import { RwCtx, intarr_new, intarr_push } from "src/backend/wasm/merge/instruction_rewrite.nx"
import { StrPos, rd_str, get_sec, sec_off, sec_sz, count_sec, sec_body,
         skip_imp_desc, skip_table_entry, copy_table_entries_with_type_off,
         emit_sec, emit_sec_and_free, copy_raw_sec, copy_sec_body, copy_imports_with_type_off,
         copy_func_types_with_off, emit_merged_types_inline, emit_merged_globals,
         emit_remapped_exports, emit_merged_elements, emit_merged_data,
         emit_merged_tag_sec, emit_stub_bodies, maybe_rewrite_bodies,
         find_data_end, scan_custom_secs, emit_preserved_customs }
       from "src/backend/wasm/merge/section_emit.nx"

// Multi-return / state records for import resolution.
// ResolveCtx: import-resolution state. Owns the remap intarr as %ByteBuffer
//        because resolve_main_go mutates (intarr_push) during traversal —
//        ctx must be threaded linearly through the recursion.
// ResolveState: dynamic counters (fidx, m_kept_idx) threaded alongside the ctx.
type ResolveCtx = ResolveCtx(remap: %ByteBuffer, kept_fimp: i64, n_stubs: i64, dep_fimp: i64, m_imp_base: i64)
type ResolveState = ResolveState(fidx: i64, m_kept_idx: i64)

// Scan WASM module sections into an smap: section_id -> pack(content_offset, size)
let scan_secs = fn (buf: &ByteBuffer) -> %StringMap do
  let %map = sm.empty()
  return scan_secs_go(buf, pos: 8, end_pos: bb.length(buf), %map)
end
let scan_secs_go = fn (buf: &ByteBuffer, pos: i64, end_pos: i64, map: %StringMap) -> %StringMap do
  if pos < end_pos then
    let sec_id = bb.get_byte(buf, idx: pos)
    let pk = rd_uleb(buf, pos: pos + 1)
    let sec_size = pval(pk)
    let content_start = ppos(pk)
    let %map = sm.put(%map, key: str.from_i64(val: sec_id), value: pack(val: content_start, p: sec_size))
    return scan_secs_go(buf, pos: content_start + sec_size, end_pos, %map)
  end
  return %map
end

// Convert kebab-cased import name to stdlib export name:
//   "smap-new" → "__nx_smap_new" (prepend __nx_, replace - with _)
let wit_to_export = fn (wit_name: string) -> string do
  let %buf = bb.empty()
  let %buf = bb.push_string(%buf, s: "__nx_")
  let %buf = wit_to_export_go(%buf, name: wit_name, pos: 0, len: str.byte_length(s: wit_name))
  let s = bb.to_string(&buf)
  bb.free(%buf)
  return s
end
let wit_to_export_go = fn (buf: %ByteBuffer, name: string, pos: i64, len: i64) -> %ByteBuffer do
  if pos >= len then return %buf end
  let ch = str.char_code(s: name, idx: pos)
  let b = match ch == 45 do | true -> 95 | false -> ch end
  let %buf = bb.push_byte(%buf, byte: b)
  return wit_to_export_go(%buf, name, pos: pos + 1, len)
end

// Parse dep (stdlib) exports into smap: export_name -> func_idx+1 (0=not found)
let parse_dep_exports = fn (buf: &ByteBuffer, sec_pk: i64) -> %StringMap do
  let %map = sm.empty()
  if sec_pk == 0 then return %map end
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  let count = pval(pk)
  return parse_dep_exports_go(buf, pos: ppos(pk), remaining: count, %map)
end
let parse_dep_exports_go = fn (buf: &ByteBuffer, pos: i64, remaining: i64, map: %StringMap) -> %StringMap do
  if remaining <= 0 then return %map end
  let StrPos(s: name, pos: pos2) = rd_str(buf, pos)
  let kind = bb.get_byte(buf, idx: pos2)
  let pk = rd_uleb(buf, pos: pos2 + 1)
  let idx = pval(pk)
  if kind == 0 then
    let %map = sm.put(%map, key: name, value: idx + 1)
    return parse_dep_exports_go(buf, pos: ppos(pk), remaining: remaining - 1, %map)
  end
  return parse_dep_exports_go(buf, pos: ppos(pk), remaining: remaining - 1, %map)
end

// Count function imports in a module (kind == 0x00)
let count_func_imps = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  return count_func_imps_go(buf, pos: ppos(pk), remaining: pval(pk), acc: 0)
end
let count_func_imps_go = fn (buf: &ByteBuffer, pos: i64, remaining: i64, acc: i64) -> i64 do
  if remaining <= 0 then return acc end
  let StrPos(s: _mod, pos: pos2) = rd_str(buf, pos)
  let StrPos(s: _name, pos: pos3) = rd_str(buf, pos: pos2)
  let kind = bb.get_byte(buf, idx: pos3)
  let pos4 = skip_imp_desc(buf, pos: pos3)
  let inc = match kind == 0 do | true -> 1 | false -> 0 end
  return count_func_imps_go(buf, pos: pos4, remaining: remaining - 1, acc: acc + inc)
end

// Count ALL main imports that are NOT from nexus:std/* (for import section entry count)
let count_main_kept_imps = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  return count_main_kept_go(buf, pos: ppos(pk), remaining: pval(pk), acc: 0)
end
let count_main_kept_go = fn (buf: &ByteBuffer, pos: i64, remaining: i64, acc: i64) -> i64 do
  if remaining <= 0 then return acc end
  let StrPos(s: mod_name, pos: pos2) = rd_str(buf, pos)
  let StrPos(s: _name, pos: pos3) = rd_str(buf, pos: pos2)
  let kind = bb.get_byte(buf, idx: pos3)
  let pos4 = skip_imp_desc(buf, pos: pos3)
  if str.starts_with(s: mod_name, prefix: "nexus:std/") then
    return count_main_kept_go(buf, pos: pos4, remaining: remaining - 1, acc)
  end
  if str.byte_length(s: mod_name) == 0 then
    return count_main_kept_go(buf, pos: pos4, remaining: remaining - 1, acc)
  end
  if kind == 2 then
    return count_main_kept_go(buf, pos: pos4, remaining: remaining - 1, acc)
  end
  return count_main_kept_go(buf, pos: pos4, remaining: remaining - 1, acc: acc + 1)
end

// Count main FUNCTION imports that are NOT from nexus:std/* (for function index layout)
let count_main_kept_func_imps = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  return count_main_kept_func_go(buf, pos: ppos(pk), remaining: pval(pk), acc: 0)
end
let count_main_kept_func_go = fn (buf: &ByteBuffer, pos: i64, remaining: i64, acc: i64) -> i64 do
  if remaining <= 0 then return acc end
  let StrPos(s: mod_name, pos: pos2) = rd_str(buf, pos)
  let StrPos(s: _name, pos: pos3) = rd_str(buf, pos: pos2)
  let kind = bb.get_byte(buf, idx: pos3)
  let pos4 = skip_imp_desc(buf, pos: pos3)
  if kind == 0 then
    if str.starts_with(s: mod_name, prefix: "nexus:std/") then
      return count_main_kept_func_go(buf, pos: pos4, remaining: remaining - 1, acc)
    end
    if str.byte_length(s: mod_name) == 0 then
      return count_main_kept_func_go(buf, pos: pos4, remaining: remaining - 1, acc)
    end
    return count_main_kept_func_go(buf, pos: pos4, remaining: remaining - 1, acc: acc + 1)
  end
  return count_main_kept_func_go(buf, pos: pos4, remaining: remaining - 1, acc)
end

// Copy main's non-stdlib function imports to output (no type offset needed — main types first)
let copy_main_kept_imps = fn (out: %ByteBuffer, buf: &ByteBuffer, sec_pk: i64, type_off: i64) -> %ByteBuffer do
  if sec_pk == 0 then return %out end
  let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
  return copy_main_kept_go(%out, buf, pos: ppos(pk), remaining: pval(pk), type_off)
end
// A main import is satisfied by dep (and dropped from merged imports) if:
//   - module is "nexus:std/*" (function, resolved to dep export), OR
//   - module is "" (anonymous .memory/.allocate bound to dep-provided ones), OR
//   - import kind is memory (merged declares its own memory).
// Keeping main imports intact would require shifting dep's function indices by
// m_kept, but remap_dep_func is identity (see remap_dep_func comment), so any
// kept main import breaks dep internal calls.
let copy_main_kept_go = fn (out: %ByteBuffer, buf: &ByteBuffer, pos: i64, remaining: i64, type_off: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let start = pos
  let StrPos(s: mod_name, pos: pos2) = rd_str(buf, pos)
  let StrPos(s: _name, pos: pos3) = rd_str(buf, pos: pos2)
  let kind = bb.get_byte(buf, idx: pos3)
  let pos4 = skip_imp_desc(buf, pos: pos3)
  if str.starts_with(s: mod_name, prefix: "nexus:std/") then
    return copy_main_kept_go(%out, buf, pos: pos4, remaining: remaining - 1, type_off)
  end
  if str.byte_length(s: mod_name) == 0 then
    return copy_main_kept_go(%out, buf, pos: pos4, remaining: remaining - 1, type_off)
  end
  if kind == 2 then
    return copy_main_kept_go(%out, buf, pos: pos4, remaining: remaining - 1, type_off)
  end
  if kind == 0 then
    let %out = bb.copy_range(dst: %out, src: buf, start, end_pos: pos3 + 1)
    let pk = rd_uleb(buf, pos: pos3 + 1)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk) + type_off)
    return copy_main_kept_go(%out, buf, pos: pos4, remaining: remaining - 1, type_off)
  end
  let %out = bb.copy_range(dst: %out, src: buf, start, end_pos: pos4)
  return copy_main_kept_go(%out, buf, pos: pos4, remaining: remaining - 1, type_off)
end

// Populates remap_m intarr (dense i32 array, indexed by fidx) with the merged
// function index for each main function import. Iterates import section
// sequentially; fidx increments only for function-kind imports, matching
// the array index.
let resolve_main_imports = fn (ctx: %ResolveCtx, dep_exports: &StringMap, buf: &ByteBuffer, sec_pk: i64) -> %ResolveCtx do
  if sec_pk > 0 then
    let pk = rd_uleb(buf, pos: sec_off(pk: sec_pk))
    return resolve_main_go(%ctx, dep_exports, buf, pos: ppos(pk), remaining: pval(pk), state: ResolveState(fidx: 0, m_kept_idx: 0))
  end
  return %ctx
end
let resolve_main_go = fn (ctx: %ResolveCtx, dep_exports: &StringMap, buf: &ByteBuffer, pos: i64, remaining: i64, state: ResolveState) -> %ResolveCtx do
  if remaining <= 0 then return %ctx end
  let StrPos(s: mod_name, pos: pos2) = rd_str(buf, pos)
  let StrPos(s: func_name, pos: pos3) = rd_str(buf, pos: pos2)
  let kind = bb.get_byte(buf, idx: pos3)
  let pos4 = skip_imp_desc(buf, pos: pos3)
  if kind == 0 then
    let ResolveCtx(%remap, kept_fimp, n_stubs, dep_fimp, m_imp_base) = ctx
    let ResolveState(fidx, m_kept_idx) = state
    // stdlib/* and empty-module function imports resolve to dep exports.
    let is_dep = if str.starts_with(s: mod_name, prefix: "nexus:std/") then true
                 else str.byte_length(s: mod_name) == 0 end
    let new_kept_idx = if is_dep then m_kept_idx else m_kept_idx + 1 end
    let new_idx = if is_dep then
      let raw_lookup = sm.get_or(map: dep_exports, key: func_name, default: 0)
      let dep_raw = if raw_lookup > 0 then raw_lookup
      else
        let exp_name = wit_to_export(wit_name: func_name)
        sm.get_or(map: dep_exports, key: exp_name, default: 0)
      end
      if dep_raw > 0 then
        remap_dep_func(dep_fidx: dep_raw - 1, kept_fimp,
                       n_stubs, dep_fimp)
      else fidx end
    else
      m_imp_base + m_kept_idx
    end
    let %remap = intarr_push(arr: %remap, val: new_idx)
    let %ctx = ResolveCtx(%remap, kept_fimp, n_stubs, dep_fimp, m_imp_base)
    return resolve_main_go(%ctx, dep_exports, buf, pos: pos4, remaining: remaining - 1, state: ResolveState(fidx: fidx + 1, m_kept_idx: new_kept_idx))
  end
  return resolve_main_go(%ctx, dep_exports, buf, pos: pos4, remaining: remaining - 1, state)
end

let remap_dep_func = fn (dep_fidx: i64, kept_fimp: i64, n_stubs: i64, dep_fimp: i64) -> i64 do
  if dep_fidx < dep_fimp then return dep_fidx end
  return dep_fidx + kept_fimp + n_stubs - dep_fimp
end

// Each remap array holds a dense i32 table indexed by original fidx.
// push_identity(arr, 0..n): arr[i] = i. Used for dep WASI imports (preserved).
// push_offset(arr, n, off): arr[len..len+n] = [len+off, len+1+off, ...].
// Arrays must be populated in order matching their index space.
let push_identity = fn (arr: %ByteBuffer, i: i64, n: i64) -> %ByteBuffer do
  if i < n then
    let %arr = intarr_push(%arr, val: i)
    return push_identity(%arr, i: i + 1, n)
  end
  return %arr
end
let push_offset = fn (arr: %ByteBuffer, i: i64, n: i64, off: i64) -> %ByteBuffer do
  if i < n then
    let %arr = intarr_push(%arr, val: i + off)
    return push_offset(%arr, i: i + 1, n, off)
  end
  return %arr
end

let remap_main_locals = fn (remap: %ByteBuffer, m_fimp: i64, m_loc: i64,
    kept_fimp: i64, n_stubs: i64, d_loc: i64) -> %ByteBuffer do
  // Main locals sit at merged idx = (kept_fimp + n_stubs + d_loc) + (i - m_fimp).
  // Entries m_fimp..m_fimp+m_loc append after main-import entries.
  return push_offset(arr: %remap, i: m_fimp, n: m_fimp + m_loc,
    off: kept_fimp + n_stubs + d_loc - m_fimp)
end

let remap_dep_locals = fn (remap: %ByteBuffer, dep_fimp: i64, d_loc: i64,
    kept_fimp: i64, n_stubs: i64) -> %ByteBuffer do
  // Dep locals sit at merged idx = (kept_fimp + n_stubs) + (i - dep_fimp).
  return push_offset(arr: %remap, i: dep_fimp, n: dep_fimp + d_loc,
    off: kept_fimp + n_stubs - dep_fimp)
end

// Extracted from merge_with_stdlib's inline section emission. Each owns one
// of WASM's structurally distinct sections in the merged output. Keeping the
// per-section logic self-contained makes the orchestrator readable as a
// sequence of "emit section N" steps rather than a 230-line straight-line
// assembler. All helpers thread %out linearly and free their temp buffers
// before returning.

/** Section 2 (imports): env.memory + dep imports (type-offset) + main
 *  non-stdlib imports. `pages` is the chosen initial-page count for the
 *  shared memory import; `dep_imp_count` counts dep import entries.
 */
let emit_merged_imports = fn (out: %ByteBuffer, dep: &ByteBuffer, core_wasm: &ByteBuffer,
                              d_imp_pk: i64, m_imp_sec_pk: i64,
                              dep_imp_count: i64, m_kept_all: i64,
                              pages: i64, d_type_off: i64, m_type_off: i64) -> %ByteBuffer do
  let total_imp_count = dep_imp_count + m_kept_all + 1
  let %tmp_i = bb.empty()
  let %tmp_i = bb.push_uleb128(buf: %tmp_i, val: total_imp_count)
  // env.memory import (memory 0)
  let %tmp_i = bb.push_uleb128(buf: %tmp_i, val: 3)
  let %tmp_i = bb.push_byte(buf: %tmp_i, byte: 101)  // 'e'
  let %tmp_i = bb.push_byte(buf: %tmp_i, byte: 110)  // 'n'
  let %tmp_i = bb.push_byte(buf: %tmp_i, byte: 118)  // 'v'
  let %tmp_i = bb.push_uleb128(buf: %tmp_i, val: 6)
  let %tmp_i = bb.push_byte(buf: %tmp_i, byte: 109)  // 'm'
  let %tmp_i = bb.push_byte(buf: %tmp_i, byte: 101)  // 'e'
  let %tmp_i = bb.push_byte(buf: %tmp_i, byte: 109)  // 'm'
  let %tmp_i = bb.push_byte(buf: %tmp_i, byte: 111)  // 'o'
  let %tmp_i = bb.push_byte(buf: %tmp_i, byte: 114)  // 'r'
  let %tmp_i = bb.push_byte(buf: %tmp_i, byte: 121)  // 'y'
  let %tmp_i = bb.push_byte(buf: %tmp_i, byte: 2)    // import desc: memory
  let %tmp_i = bb.push_byte(buf: %tmp_i, byte: 3)    // limits flags: has-max | shared
  let %tmp_i = bb.push_uleb128(buf: %tmp_i, val: pages)
  let %tmp_i = bb.push_uleb128(buf: %tmp_i, val: 65536)
  // Copy dep imports with type offset
  let %tmp_i = if d_imp_pk > 0 then
    copy_imports_with_type_off(out: %tmp_i, buf: dep,
      pos: sec_body(buf: dep, sec_pk: d_imp_pk), remaining: dep_imp_count, type_off: d_type_off)
  else %tmp_i end
  let %tmp_i = copy_main_kept_imps(out: %tmp_i, buf: core_wasm, sec_pk: m_imp_sec_pk, type_off: m_type_off)
  let %out = emit_sec(%out, sec_id: 2, content: &tmp_i)
  bb.free(buf: %tmp_i)
  return %out
end

/** Section 3 (function types): count header followed by dep entries verbatim
 *  and main entries with type-offset applied. Function-section count must
 *  equal code-section count (WASM §5.5.6/§5.5.10), so we key off the code
 *  sections to keep the two in lock-step.
 */
let emit_merged_func_types = fn (out: %ByteBuffer, dep: &ByteBuffer, core_wasm: &ByteBuffer,
                                 d_func_sec_pk: i64, m_func_sec_pk: i64,
                                 d_code_cnt: i64, m_code_cnt: i64,
                                 n_stubs: i64, m_type_off: i64) -> %ByteBuffer do
  let %tmp_f = bb.empty()
  let n_total_funcs = n_stubs + d_code_cnt + m_code_cnt
  let %tmp_f = bb.push_uleb128(buf: %tmp_f, val: n_total_funcs)
  // Dep func types: NO offset (dep types first)
  let %tmp_f = copy_sec_body(buf: %tmp_f, src: dep, sec_pk: d_func_sec_pk)
  // Main func types: offset by m_type_off
  let %tmp_f = if m_func_sec_pk > 0 then
    copy_func_types_with_off(out: %tmp_f, buf: core_wasm, sec_pk: m_func_sec_pk, off: m_type_off)
  else %tmp_f end
  let %out = emit_sec(%out, sec_id: 3, content: &tmp_f)
  bb.free(buf: %tmp_f)
  return %out
end

/** Section 4 (tables): dep tables + main's extra tables (skipping main's
 *  first table — that one is replaced by dep's). When main has only its
 *  default table, falls through to a raw copy of dep's section.
 */
let emit_merged_tables = fn (out: %ByteBuffer, dep: &ByteBuffer, core_wasm: &ByteBuffer,
                             d_tbl_pk: i64, m_tbl_pk: i64,
                             d_tbl_count: i64, m_tbl_total: i64, m_type_off: i64) -> %ByteBuffer do
  if m_tbl_total > 1 then
    let %tmp_t = bb.empty()
    let %tmp_t = bb.push_uleb128(buf: %tmp_t, val: d_tbl_count + m_tbl_total - 1)
    let %tmp_t = if d_tbl_pk > 0 then
      let d_off = sec_off(pk: d_tbl_pk)
      let d_sz = sec_sz(pk: d_tbl_pk)
      let d_cnt_pk = rd_uleb(buf: dep, pos: d_off)
      bb.copy_range(dst: %tmp_t, src: dep, start: ppos(pk: d_cnt_pk), end_pos: d_off + d_sz)
    else %tmp_t end
    let m_off = sec_off(pk: m_tbl_pk)
    let m_sz = sec_sz(pk: m_tbl_pk)
    let m_cnt_pk = rd_uleb(buf: core_wasm, pos: m_off)
    let after_first = skip_table_entry(buf: core_wasm, pos: ppos(pk: m_cnt_pk))
    let %tmp_t = copy_table_entries_with_type_off(buf: %tmp_t, src: core_wasm, pos: after_first, end_pos: m_off + m_sz, off: m_type_off)
    return emit_sec_and_free(%out, sec_id: 4, tmp: %tmp_t)
  end
  return copy_raw_sec(%out, src: dep, sec_pk: d_tbl_pk, sec_id: 4)
end

/** Section 10 (code): n_stubs stub bodies + dep bodies (rewritten) + main
 *  bodies (rewritten). Use actual code-section counts so the header matches
 *  the bodies written by rewrite_code_bodies.
 */
let emit_merged_code = fn (out: %ByteBuffer, dep: &ByteBuffer, core_wasm: &ByteBuffer,
                           remap_d: &ByteBuffer, remap_m: &ByteBuffer,
                           d_code_sec_pk: i64, m_code_sec_pk: i64,
                           d_code_count: i64, m_code_count: i64,
                           n_stubs: i64, m_type_off: i64,
                           d_tbl_count: i64, d_glo: i64) -> %ByteBuffer do
  let %tmp_c = bb.empty()
  let %tmp_c = bb.push_uleb128(buf: %tmp_c, val: d_code_count + m_code_count)
  let %tmp_c = emit_stub_bodies(out: %tmp_c, i: 0, n: n_stubs)
  let dep_rw_ctx = RwCtx(type_off: 0, tbl_off: 0, glo_off: 0)
  let %tmp_c = maybe_rewrite_bodies(ctx: dep_rw_ctx, remap: remap_d, buf: %tmp_c, src: dep, sec_pk: d_code_sec_pk)
  // Main code bodies — rewrite with intarr-backed func remap (remap_m covers
  // all main fidxs: imports 0..m_fimp, locals m_fimp..m_fimp+m_loc)
  let rw_ctx = RwCtx(type_off: m_type_off, tbl_off: d_tbl_count - 1, glo_off: d_glo)
  let %tmp_c = maybe_rewrite_bodies(ctx: rw_ctx, remap: remap_m, buf: %tmp_c, src: core_wasm, sec_pk: m_code_sec_pk)
  let %out = emit_sec(%out, sec_id: 10, content: &tmp_c)
  bb.free(buf: %tmp_c)
  return %out
end

/** Merge `core_wasm` against the prebuilt stdlib wasm at `stdlib_path` into a single self-contained module: scans both inputs, allocates a flat type/func/global/table index space (dep first, then core with appropriate offsets), wires stub funcs for every dep export the core imported, and emits each wasm section concatenated with the rewritten bodies. The single user-facing entry point for the stage-2 self-contained linker. */
export let merge_with_stdlib = fn (core_wasm: %ByteBuffer, stdlib_path: string) -> %ByteBuffer throws { FileNotFound } do
  let %dep = bb.read_binary_file(path: stdlib_path)

  let %m_secs = scan_secs(buf: &core_wasm)
  let %d_secs = scan_secs(buf: &dep)

  // Dep types first → dep type indices unchanged, main types offset by dep count
  let d_type_off = 0
  let m_type_off = count_sec(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 1))

  let %dep_exports = parse_dep_exports(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 7))

  let dep_fimp = count_func_imps(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 2))
  let kept_fimp = dep_fimp
  let n_stubs = 0

  let d_loc = count_sec(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 3))
  let m_fimp = count_func_imps(buf: &core_wasm, sec_pk: get_sec(map: &m_secs, sec: 2))
  let m_loc = count_sec(buf: &core_wasm, sec_pk: get_sec(map: &m_secs, sec: 3))

  // Count main's non-stdlib imports
  let m_imp_sec_pk = get_sec(map: &m_secs, sec: 2)
  // m_kept_all = ALL non-stdlib imports (for import section entry count)
  let m_kept_all = count_main_kept_imps(buf: &core_wasm, sec_pk: m_imp_sec_pk)
  // m_kept = non-stdlib FUNCTION imports only (for function index layout)
  let m_kept = count_main_kept_func_imps(buf: &core_wasm, sec_pk: m_imp_sec_pk)

  // Dep remap intarr: identity for WASI imports, then offset for dep locals.
  // All stdlib imports are WASI (indices preserved); only used by element-segment remap.
  let %remap_d = intarr_new()
  let %remap_d = push_identity(arr: %remap_d, i: 0, n: dep_fimp)
  let %remap_d = remap_dep_locals(remap: %remap_d, dep_fimp, d_loc,
    kept_fimp: kept_fimp + m_kept, n_stubs)

  let %remap_m = intarr_new()
  // kept_fimp+m_kept = base for remap_dep_func (dep locals start after all func imports)
  // m_imp_base = kept_fimp (base for non-stdlib main func imports, right after dep WASI imports)
  let %resolve_ctx = ResolveCtx(
    remap: %remap_m,
    kept_fimp: kept_fimp + m_kept,
    n_stubs,
    dep_fimp,
    m_imp_base: kept_fimp)
  let %resolve_ctx = resolve_main_imports(ctx: %resolve_ctx, &dep_exports, buf: &core_wasm, sec_pk: m_imp_sec_pk)
  let ResolveCtx(remap: %remap_m, kept_fimp: _, n_stubs: _, dep_fimp: _, m_imp_base: _) = resolve_ctx

  // Main locals start after: dep WASI imports + main non-stdlib func imports + stubs + dep locals
  let %remap_m = remap_main_locals(remap: %remap_m, m_fimp, m_loc,
    kept_fimp: kept_fimp + m_kept, n_stubs, d_loc)

  let d_glo = count_sec(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 6))
  let d_tbl_count = count_sec(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 4))

  // Assemble output — section emission is split into per-section helpers
  // above. Orchestrator stays a straight sequence of "emit section N" steps.
  let %out = assemble_header()

  // Section 1: merged types (DEP first, then main)
  let %out = emit_merged_types_inline(%out,
    m_buf: &dep, m_sec: get_sec(map: &d_secs, sec: 1),
    d_buf: &core_wasm, d_sec: get_sec(map: &m_secs, sec: 1))

  // Initial-page count for the merged memory — cover both dep and main static
  // data; floor at 256 pages (16 MiB). Computed early because the memory is
  // emitted as an import in section 2 (see below).
  let d_data_end = find_data_end(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 11))
  let m_data_end = find_data_end(buf: &core_wasm, sec_pk: get_sec(map: &m_secs, sec: 11))
  let max_data = if d_data_end > m_data_end then d_data_end else m_data_end end
  let min_pages = (max_data + wasm_page_mask) / wasm_page_size
  let dep_pages = if get_sec(map: &d_secs, sec: 5) > 0 then
    let pk_mem = rd_uleb(buf: &dep, pos: sec_off(pk: get_sec(map: &d_secs, sec: 5)))
    let pk_min = rd_uleb(buf: &dep, pos: ppos(pk: pk_mem) + 1)
    pval(pk: pk_min)
  else 0 end
  let pages_raw = if dep_pages > min_pages then dep_pages else min_pages end
  let pages = if pages_raw < default_initial_pages then default_initial_pages else pages_raw end

  // Section 2: merged imports (env.memory + dep WASI imports + main non-stdlib).
  // The merged module imports its (shared) linear memory from "env" rather than
  // defining it, so the WASI-threads host hands every worker instance the SAME
  // backing — a *defined* `shared` memory is per-instance under `-S threads`,
  // which would silently un-share the heap. The memory index space is separate
  // from the function index space, so prepending this import does not shift any
  // function index. The defined memory section (5) is skipped below; "memory"
  // is still exported (now pointing at the imported memory 0). Limits flags
  // byte 0x03 = has-max (0x01) | shared (0x02); max = 65536 pages (4 GiB).
  let d_imp_pk = get_sec(map: &d_secs, sec: 2)
  let dep_imp_count = count_sec(buf: &dep, sec_pk: d_imp_pk)
  let %out = emit_merged_imports(%out, dep: &dep, core_wasm: &core_wasm,
    d_imp_pk, m_imp_sec_pk,
    dep_imp_count, m_kept_all,
    pages, d_type_off, m_type_off)

  // Section 3: merged func types (count + dep with type offset + main)
  // Invariant (WASM spec §5.5.6/§5.5.10): function-section count must equal
  // code-section count for any valid module, so for our inputs
  //   d_code_cnt == d_loc   and   m_code_cnt == m_loc.
  // Both codegen.nx (`build_function_section` / code-body emission) and the
  // rust bootstrap emit each side from the same `n_funcs + n_cabi + 1`
  // formula, so the invariant holds by construction. We use the *code*-side
  // counts here because rewrite_code_bodies walks section 10 to determine how
  // many bodies it actually writes — keying the function section header off
  // section 10 keeps the two counts in lock-step even if a future input ever
  // drifted (validation would reject the module either way, but the merge
  // would emit consistent header/body byte counts).
  let d_func_sec_pk = get_sec(map: &d_secs, sec: 3)
  let m_func_sec_pk = get_sec(map: &m_secs, sec: 3)
  let d_code_cnt = count_sec(buf: &dep, sec_pk: get_sec(map: &d_secs, sec: 10))
  let m_code_cnt = count_sec(buf: &core_wasm, sec_pk: get_sec(map: &m_secs, sec: 10))
  let %out = emit_merged_func_types(%out, dep: &dep, core_wasm: &core_wasm,
    d_func_sec_pk, m_func_sec_pk,
    d_code_cnt, m_code_cnt, n_stubs, m_type_off)

  // Section 4: table (dep tables + main's extra tables if any)
  let d_tbl_pk = get_sec(map: &d_secs, sec: 4)
  let m_tbl_pk = get_sec(map: &m_secs, sec: 4)
  let m_tbl_total = count_sec(buf: &core_wasm, sec_pk: m_tbl_pk)
  let %out = emit_merged_tables(%out, dep: &dep, core_wasm: &core_wasm,
    d_tbl_pk, m_tbl_pk, d_tbl_count, m_tbl_total, m_type_off)
  // Section 5 (defined memory) is intentionally omitted — the merged module's
  // memory is the `env.memory` import declared in section 2 above (shared, so
  // WASI-threads workers see the same backing).
  // Section 13: merged tags (dep tags offset by d_type_off=0, main tags offset by m_type_off)
  let %out = emit_merged_tag_sec(%out,
    d_buf: &dep, d_sec: get_sec(map: &d_secs, sec: 13), d_off: d_type_off,
    m_buf: &core_wasm, m_sec: get_sec(map: &m_secs, sec: 13), m_off: m_type_off)

  // Section 6: merged globals (dep first, then main)
  let m_glo_pk = get_sec(map: &m_secs, sec: 6)
  let d_glo_pk = get_sec(map: &d_secs, sec: 6)
  let %out = emit_merged_globals(%out,
    m_buf: &core_wasm, m_sec: m_glo_pk,
    d_buf: &dep, d_sec: d_glo_pk, type_off: m_type_off)

  // Section 7: remapped exports (main exports with func idx remap)
  let %out = emit_remapped_exports(%out,
    m_buf: &core_wasm, m_sec: get_sec(map: &m_secs, sec: 7), remap: &remap_m)

  // Section 9: merged elements (dep + main, both remapped)
  let %out = emit_merged_elements(%out,
    d_buf: &dep, d_sec: get_sec(map: &d_secs, sec: 9), &remap_d,
    m_buf: &core_wasm, m_sec: get_sec(map: &m_secs, sec: 9), &remap_m)

  // Section 10: merged code (stubs + dep bodies rewritten + main bodies rewritten)
  // Use actual code section counts (must match bodies written by rewrite_code_bodies)
  let d_code_sec_pk = get_sec(map: &d_secs, sec: 10)
  let m_code_sec_pk = get_sec(map: &m_secs, sec: 10)
  let d_code_count = count_sec(buf: &dep, sec_pk: d_code_sec_pk)
  let m_code_count = count_sec(buf: &core_wasm, sec_pk: m_code_sec_pk)
  let %out = emit_merged_code(%out, dep: &dep, core_wasm: &core_wasm,
    remap_d: &remap_d, remap_m: &remap_m,
    d_code_sec_pk, m_code_sec_pk,
    d_code_count, m_code_count,
    n_stubs, m_type_off,
    d_tbl_count, d_glo)

  // Section 11: merged data (dep + main, both verbatim — codegen already used correct offsets)
  let %out = emit_merged_data(%out,
    m_buf: &core_wasm, m_sec: get_sec(map: &m_secs, sec: 11),
    d_buf: &dep, d_sec: get_sec(map: &d_secs, sec: 11), reloc: 0)

  // Preserve custom sections from both inputs. `name` sections are rewritten
  // with func indices remapped; other customs (producers, target_features,
  // future .debug_*) pass through verbatim. Must run before the remap intarrs
  // are freed.
  let %m_customs = scan_custom_secs(buf: &core_wasm)
  let %d_customs = scan_custom_secs(buf: &dep)
  let %out = emit_preserved_customs(%out, buf: &core_wasm, customs: &m_customs,
                                      remap: &remap_m, remap_size: m_fimp + m_loc)
  let %out = emit_preserved_customs(%out, buf: &dep, customs: &d_customs,
                                      remap: &remap_d, remap_size: dep_fimp + d_loc)
  sm.free(map: %m_customs)
  sm.free(map: %d_customs)

  sm.free(map: %m_secs)
  sm.free(map: %d_secs)
  sm.free(map: %dep_exports)
  bb.free(buf: %remap_d)
  bb.free(buf: %remap_m)
  bb.free(buf: %dep)
  bb.free(buf: %core_wasm)

  return %out
end

let assemble_header = fn () -> %ByteBuffer do
  let %out = bb.empty()
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_string(buf: %out, s: "asm")
  let %out = bb.push_bytes(buf: %out, bytes: [1, 0, 0, 0])
  return %out
end
