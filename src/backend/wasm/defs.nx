export let op_i32_shr_u = fn () -> Opcode do return Opcode(op_byte: 118) end

export let catch_kind_one = 0
export let tag_kind_exception = 0

// ─── Stack-switching proposal (nexus-x7w / hs25 / apbn) ─────────────────────
// Opcodes verified against wasm-tools 1.x output of hand-written WAT.
// Followed in the binary stream by the indicated LEB128-encoded operands.

// Type-section form indicator for `(cont $func_type_idx)`. After the byte,
// emit the LEB128 func-type index that the continuation runs.
export let form_cont = fn () -> WasmForm do return WasmForm(form_byte_v: 93) end      // 0x5d

// `cont.new $cont_type` — pop (ref null $func_type), push (ref $cont_type).
// Followed by LEB128 cont type index.
export let op_cont_new = fn () -> Opcode do return Opcode(op_byte: 224) end       // 0xe0

// `cont.bind $arg_cont $res_cont` — partially applies a cont. Followed by
// LEB128 argument-cont type index, then LEB128 result-cont type index.
export let op_cont_bind = fn () -> Opcode do return Opcode(op_byte: 225) end      // 0xe1

// `suspend $tag` — captures the current stack up to the nearest matching
// resume frame and transfers the payload into that frame's `on $tag`
// handler. Followed by LEB128 tag index.
export let op_suspend = fn () -> Opcode do return Opcode(op_byte: 226) end        // 0xe2

// `resume $cont_type (handler_table)` — reify a cont and run it; on
// suspend, dispatch via the handler table. Followed by LEB128 cont type
// index, then LEB128 handler-table count, then for each handler:
// resume_handler_kind (1 byte) + LEB128 tag + LEB128 label.
export let op_resume = fn () -> Opcode do return Opcode(op_byte: 227) end         // 0xe3

// Resume handler-entry kind: `on $tag $label` — the handler branches to
// `$label` carrying the payload + a fresh cont reference.
export let resume_handler_on = 0

export let op_ref_null = fn () -> Opcode do return Opcode(op_byte: 208) end       // 0xD0
export let op_ref_func = fn () -> Opcode do return Opcode(op_byte: 210) end       // 0xD2

// Legacy exception-handling `try` opcode (pre-`try_table` proposal). Encoded
// like `block`/`loop`/`if` but followed by handler entries — see
// rw_instrs in wasm/merge.nx for the operand-decode strategy.
export let op_legacy_try = fn () -> Opcode do return Opcode(op_byte: 6) end       // 0x06

export let op_table_get = fn () -> Opcode do return Opcode(op_byte: 37) end       // 0x25
export let op_table_set = fn () -> Opcode do return Opcode(op_byte: 38) end       // 0x26

// 0xFC-prefixed (saturating-truncation / bulk-memory / table) family.
// The next byte is a ULEB sub-opcode selecting the actual instruction.
export let op_fc_prefix = fn () -> Opcode do return Opcode(op_byte: 252) end      // 0xFC

// 0xFC sub-opcodes (bulk-memory / table proposals).
export let op_fc_memory_init = fn () -> Opcode do return Opcode(op_byte: 8) end
export let op_fc_memory_copy = fn () -> Opcode do return Opcode(op_byte: 10) end
export let op_fc_memory_fill = fn () -> Opcode do return Opcode(op_byte: 11) end
export let op_fc_table_init = fn () -> Opcode do return Opcode(op_byte: 12) end
export let op_fc_table_copy = fn () -> Opcode do return Opcode(op_byte: 14) end

export let heap_global_idx = 0
export let ss_cont_global_idx = 3
export let ss_resume_slot_global_idx = 4
export let ss_next_alloc_global_idx = 5
export let ss_cont_table_idx = 1

// ─── Helper types ───────────────────────────────────────────────────────────

export type LocalEntry = LocalEntry(name: string, index: i64, valtype: Valtype)
export type FuncEntry = FuncEntry(name: string, index: i64)
export type StringEntry = StringEntry(value: string, offset: i64, slen: i64)
export type ArityTypeIdx = ArityTypeIdx(arity: i64, type_idx: i64)

// ─── CodegenCtx ─────────────────────────────────────────────────────────────

export type CodegenCtx = CodegenCtx(
  locals: [LocalEntry],
  internal_funcs: [FuncEntry],
  external_funcs: [FuncEntry],
  string_lits: [StringEntry],
  alloc_mode: i64,
  temps_base: i64,
  func_ret_type: TypeExpr,
  functions: [LirFunction],
  externals: [LirExternal],
  closure_table: [FuncEntry],
  closure_type_indices: [ArityTypeIdx],
  internal_func_map: &HashMap,
  external_func_map: &HashMap,
  func_name: string,
  ss_tag_idx: i64,
  ss_cont_type_idx: i64,
  ss_dispatch_block_type_idx: i64,
  ss_tag_names: [string]
)

export let ctx_ss_tag_names = fn (ctx: CodegenCtx) -> [string] do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: tns) -> tns end
end

export let ctx_locals = fn (ctx: CodegenCtx) -> [LocalEntry] do
  match ctx do | CodegenCtx(locals: l, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> l end
end

export let ctx_string_lits = fn (ctx: CodegenCtx) -> [StringEntry] do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: s, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> s end
end

export let ctx_alloc_mode = fn (ctx: CodegenCtx) -> i64 do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: m, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> m end
end

export let ctx_temps_base = fn (ctx: CodegenCtx) -> i64 do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: t, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> t end
end

export let ctx_func_ret_type = fn (ctx: CodegenCtx) -> TypeExpr do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: r, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> r end
end

export let ctx_functions = fn (ctx: CodegenCtx) -> [LirFunction] do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: f, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> f end
end

export let ctx_externals = fn (ctx: CodegenCtx) -> [LirExternal] do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: e, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> e end
end

export let ctx_closure_table = fn (ctx: CodegenCtx) -> [FuncEntry] do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: ct, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> ct end
end

export let ctx_closure_type_indices = fn (ctx: CodegenCtx) -> [ArityTypeIdx] do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: cti, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> cti end
end

export let ctx_internal_func_map = fn (ctx: CodegenCtx) -> &HashMap do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: m, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> return &m end
end

export let ctx_external_func_map = fn (ctx: CodegenCtx) -> &HashMap do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: m, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> return &m end
end

export let ctx_ss_tag_idx = fn (ctx: CodegenCtx) -> i64 do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: i, ss_cont_type_idx: _, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> i end
end

export let ctx_ss_cont_type_idx = fn (ctx: CodegenCtx) -> i64 do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: i, ss_dispatch_block_type_idx: _, ss_tag_names: _) -> i end
end

export let ctx_ss_dispatch_block_type_idx = fn (ctx: CodegenCtx) -> i64 do
  match ctx do | CodegenCtx(locals: _, internal_funcs: _, external_funcs: _, string_lits: _, alloc_mode: _, temps_base: _, func_ret_type: _, functions: _, externals: _, closure_table: _, closure_type_indices: _, internal_func_map: _, external_func_map: _, func_name: _, ss_tag_idx: _, ss_cont_type_idx: _, ss_dispatch_block_type_idx: i, ss_tag_names: _) -> i end
end

export let peel_linear = fn (typ: TypeExpr) -> TypeExpr do
  match typ do
    | TyLinear(inner: t) -> return peel_linear(typ: t)
    | TyLazy(inner: t) -> return peel_linear(typ: t)
    | TyBorrow(inner: t) -> return peel_linear(typ: t)
    | _ -> return typ
  end
end

export let type_to_valtype = fn (typ: TypeExpr) -> Valtype do
  match peel_linear(typ) do
    | TyI32 -> vt_i32()
    | TyBool -> vt_i32()
    | TyChar -> vt_i32()
    | TyI64 -> vt_i64()
    | TyIntLit -> vt_i64()
    | TyF32 -> vt_f32()
    | TyF64 -> vt_f64()
    | TyFloatLit -> vt_f64()
    | _ -> vt_i64()
  end
end

export let is_unit = fn (typ: TypeExpr) -> bool do
  match typ do
    | TyUnit -> return true
    | _ -> return false
  end
end

let fnv_hash_byte = fn (hash: i64, byte: i64) -> i64 do
  return (hash ^ byte) * 1099511628211
end

let fnv_hash_string_go = fn (s: string, idx: i64, slen: i64, hash: i64) -> i64 do
  if idx >= slen then return hash
  else return fnv_hash_string_go(s, idx: idx + 1, slen,
                                  hash: fnv_hash_byte(hash, byte: str.char_code(s, idx)))
  end
end

export let fnv_hash_string = fn (s: string, hash: i64) -> i64 do
  return fnv_hash_string_go(s, idx: 0, slen: str.length(s), hash)
end

export let fnv_basis = -3750763034362895579

export let constructor_tag = fn (name: string, arity: i64) -> i64 do
  return fnv_hash_byte(hash: fnv_hash_string(s: name, hash: fnv_basis), byte: arity)
end

export let record_tag = fn (sorted_names: [string]) -> i64 do
  let shape = str.join(xs: sorted_names, sep: ",")
  let h = fnv_hash_string(s: shape, hash: fnv_hash_string(s: "rec", hash: fnv_basis))
  return fnv_hash_byte(hash: h, byte: list.length(xs: sorted_names))
end

// ─── Atom/expr type accessors ───────────────────────────────────────────────

export let atom_type = fn (atom: LirAtom) -> TypeExpr do
  match atom do
    | LirAtomVar(name: _, typ: t) -> t
    | LirAtomInt(_) -> TyI64
    | LirAtomFloat(_) -> TyF64
    | LirAtomBool(_) -> TyBool
    | LirAtomChar(_) -> TyChar
    | LirAtomString(_) -> TyString
    | LirAtomUnit -> TyUnit
  end
end

export let expr_type = fn (expr: LirExpr) -> TypeExpr do
  match expr do
    | LirExprAtom(atom: a) -> atom_type(atom: a)
    | LirExprBinary(op: _, lhs: _, rhs: _, typ: t) -> t
    | LirExprCall(func: _, args: _, typ: t) -> t
    | LirExprTailCall(func: _, args: _, typ: t) -> t
    | LirExprConstructor(name: _, args: _, typ: t) -> t
    | LirExprRecord(fields: _, typ: t) -> t
    | LirExprObjectTag(value: _, typ: t) -> t
    | LirExprObjectField(value: _, index: _, typ: t) -> t
    | LirExprRaise(value: _, typ: t) -> t
    | LirExprForce(value: _, typ: t) -> t
    | LirExprMakeClosure(func_name: _, captures: _, typ: t) -> t
    | LirExprCallClosure(closure: _, args: _, typ: t) -> t
    | LirExprSuspend(tag_name: _, payload: _, typ: t) -> t
    | LirExprResume(cont: _, value: _, typ: t) -> t
    | LirExprContNew(func_ref: _, typ: t) -> t
    | LirExprInjectResume(body_fn: _, arm_fns: _, arm_tags: _, typ: t) -> t
  end
end

// ─── Lookup helpers ─────────────────────────────────────────────────────────

export let lookup_local = fn (name: string, entries: [LocalEntry]) -> i64 do
  match entries do
    | [] -> return -1
    | LocalEntry(name: n, index: idx, valtype: _) :: rest ->
      if n == name then return idx end
      return lookup_local(name, entries: rest)
  end
end

export let lookup_local_valtype = fn (name: string, entries: [LocalEntry]) -> Valtype do
  match entries do
    | [] -> return vt_unknown()
    | LocalEntry(name: n, index: _, valtype: vt) :: rest ->
      if n == name then return vt end
      return lookup_local_valtype(name, entries: rest)
  end
end

// Replace valtype for an existing local entry (widen i32 → i64 on conflict)
export let widen_local = fn (name: string, new_vt: Valtype, entries: [LocalEntry]) -> [LocalEntry] do
  return widen_local_go(name, new_vt, entries, acc: [])
end

let widen_local_go = fn (name: string, new_vt: Valtype, entries: [LocalEntry], acc: [LocalEntry]) -> [LocalEntry] do
  match entries do
    | [] -> return rev_local_entries(lst: acc, out: [])
    | LocalEntry(name: n, index: idx, valtype: vt) :: rest ->
      if n == name then
        return rev_local_entries(lst: acc, out: LocalEntry(name: n, index: idx, valtype: new_vt) :: rest)
      end
      return widen_local_go(name, new_vt, entries: rest, acc: LocalEntry(name: n, index: idx, valtype: vt) :: acc)
  end
end

let rev_local_entries = fn (lst: [LocalEntry], out: [LocalEntry]) -> [LocalEntry] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_local_entries(lst: rest, out: x :: out)
  end
end

export let lookup_string = fn (value: string, entries: [StringEntry]) -> i64 do
  match entries do
    | [] -> return -1
    | StringEntry(value: v, offset: off, slen: sl) :: rest ->
      if v == value then return (off * 4294967296) + sl end
      return lookup_string(value, entries: rest)
  end
end

export let find_function = fn (name: string, funcs: [LirFunction]) -> Option<LirFunction> do
  match funcs do
    | [] -> return None
    | f :: rest ->
      let LirFunction(name: n, params: _, ret_type: _, body: _, ret: _, span: _) = f
      if n == name then return Some(val: f) end
      return find_function(name, funcs: rest)
  end
end

export let find_external = fn (name: string, exts: [LirExternal]) -> Option<LirExternal> do
  match exts do
    | [] -> return None
    | e :: rest ->
      let LirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) = e
      if n == name then return Some(val: e) end
      return find_external(name, exts: rest)
  end
end

// ─── WASM encoding helpers ──────────────────────────────────────────────────

export let emit_name = fn (buf: %ByteBuffer, name: string) -> %ByteBuffer do
  let slen = str.length(s: name)
  let %buf = bb.push_uleb128(%buf, val: slen)
  let %buf = bb.push_string(%buf, s: name)
  return %buf
end

export let emit_section = fn (buf: %ByteBuffer, id: SectionId, content: %ByteBuffer) -> %ByteBuffer do
  let content_len = bb.length(buf: &content)
  let %buf = bb.push_byte(%buf, byte: section_id_byte(s: id))
  let %buf = bb.push_uleb128(%buf, val: content_len)
  let %buf = bb.push_buf(dst: %buf, src: &content)
  bb.free(buf: %content)
  return %buf
end

export let emit_memarg = fn (buf: %ByteBuffer, align: i64, offset: i64) -> %ByteBuffer do
  let %buf = bb.push_uleb128(%buf, val: align)
  let %buf = bb.push_uleb128(%buf, val: offset)
  return %buf
end

export let emit_memarg_i32 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return emit_memarg(%buf, align: 2, offset)
end

export let emit_memarg_i64 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return emit_memarg(%buf, align: 3, offset)
end

export let emit_memarg_i8 = fn (buf: %ByteBuffer) -> %ByteBuffer do
  return emit_memarg(%buf, align: 0, offset: 0)
end

/// Check if name starts with "__closure_" (10 chars: _ _ c l o s u r e _)
/// or "__inject_" (9 chars: _ _ i n j e c t _) — both are lifted functions
/// that need to be declared in the function table so ref.func can target them.
/// Also recognises the sched trampoline body, which the spawn intrinsic
/// `ref.func`s into cont.new for each spawned fiber.
export let is_closure_func = fn (name: string) -> bool do
  if is_inject_func(name) then return true end
  if is_sched_trampoline_func(name) then return true end
  if str.length(s: name) < 10 then return false end
  return str.char_code(s: name, idx: 0) == 95
      && str.char_code(s: name, idx: 1) == 95
      && str.char_code(s: name, idx: 2) == 99
      && str.char_code(s: name, idx: 3) == 108
      && str.char_code(s: name, idx: 4) == 111
      && str.char_code(s: name, idx: 5) == 115
      && str.char_code(s: name, idx: 6) == 117
      && str.char_code(s: name, idx: 7) == 114
      && str.char_code(s: name, idx: 8) == 101
      && str.char_code(s: name, idx: 9) == 95
end

export let is_sched_trampoline_func = fn (name: string) -> bool do
  let suffix = "__nx_sched_trampoline_body"
  let slen = str.length(s: name)
  let suflen = str.length(s: suffix)
  if slen < suflen then return false end
  return str.substring(s: name, start: slen - suflen, len: suflen) == suffix
end

/// Check if name starts with "__inject_" (9 chars: _ _ i n j e c t _).
export let is_inject_func = fn (name: string) -> bool do
  if str.length(s: name) < 9 then return false end
  return str.char_code(s: name, idx: 0) == 95
      && str.char_code(s: name, idx: 1) == 95
      && str.char_code(s: name, idx: 2) == 105
      && str.char_code(s: name, idx: 3) == 110
      && str.char_code(s: name, idx: 4) == 106
      && str.char_code(s: name, idx: 5) == 101
      && str.char_code(s: name, idx: 6) == 99
      && str.char_code(s: name, idx: 7) == 116
      && str.char_code(s: name, idx: 8) == 95
end

// ─── HashMap-backed function index lookup ───────────────────────────────────

export let hash_name = fn (name: string) -> i64 do
  return fnv_hash_string(s: name, hash: fnv_basis)
end

export let build_func_map = fn (entries: [FuncEntry]) -> %HashMap do
  let %m = hmap.empty()
  return build_func_map_go(entries, map: %m)
end

let build_func_map_go = fn (entries: [FuncEntry], map: %HashMap) -> %HashMap do
  match entries do
    | [] -> return %map
    | FuncEntry(name: n, index: idx) :: rest ->
      // Preserve first-wins semantics (matches linear lookup_func behavior)
      let key = hash_name(name: n)
      let existing = hmap.get_or(&map, key, default: -1)
      let %map = if existing < 0 then
        hmap.put(%map, key, value: idx)
      else %map end
      return build_func_map_go(entries: rest, %map)
  end
end

export let free_func_map = fn (map: %HashMap) -> unit do
  hmap.free(%map)
  return ()
end

export let lookup_func_fast = fn (name: string, map: &HashMap) -> i64 do
  return hmap.get_or(map, key: hash_name(name), default: -1)
end

export let build_local_map = fn (entries: [LocalEntry]) -> %HashMap do
  let %m = hmap.empty()
  return build_local_map_go(entries, map: %m)
end

let build_local_map_go = fn (entries: [LocalEntry], map: %HashMap) -> %HashMap do
  match entries do
    | [] -> return %map
    | LocalEntry(name: n, index: _, valtype: vt) :: rest ->
      let %map = hmap.put(%map, key: hash_name(name: n), value: valtype_byte(vt))
      return build_local_map_go(entries: rest, %map)
  end
end
