export let op_br_table = fn () -> Opcode do return Opcode(op_byte: 14) end
export let op_return = fn () -> Opcode do return Opcode(op_byte: 15) end
export let op_call = fn () -> Opcode do return Opcode(op_byte: 16) end
export let op_call_indirect = fn () -> Opcode do return Opcode(op_byte: 17) end
export let op_return_call = fn () -> Opcode do return Opcode(op_byte: 18) end
export let op_drop = fn () -> Opcode do return Opcode(op_byte: 26) end
export let op_local_get = fn () -> Opcode do return Opcode(op_byte: 32) end
export let op_local_set = fn () -> Opcode do return Opcode(op_byte: 33) end
