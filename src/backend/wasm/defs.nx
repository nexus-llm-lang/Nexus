/**
 * wasm/defs: WASM constants, helper types, and core utilities for codegen.
 *
 * Contains section IDs, value types, opcodes, CodegenCtx, type utilities,
 * FNV-1a hashing, lookup helpers, and WASM encoding primitives.
 */

import { ByteBuffer }, * as bb from "std:bytebuffer"
import { TypeExpr } from "src/common/ast.nx"
import { LirFunction, LirExpr, LirAtom, LirExternal } from "src/ir/lir_types.nx"
import * as str from "std:str"
import * as list from "std:list"

import { HashMap }, * as hmap from "std:hashmap"

// ─── Opaque byte-classifier types ───────────────────────────────────────────
//
// Each WASM byte category (section ID, value type, opcode, etc.) is wrapped
// in a distinct opaque type so the type system rejects accidental arithmetic
// or cross-category mix-ups (e.g. `op_block + 1`, `bt_void * vt_i64`). Raw
// bytes only escape via the explicit `*_byte` accessors or the `emit_*`
// encoder helpers below.
//
// The constructors stay private to this module: from any other module the
// type is fully abstract, so `let x: i64 = op_block()` and
// `op_block() + 1` both fail typecheck.
//
// Constants are exposed as zero-arg `() -> Opcode` (etc.) functions because
// the bootstrap (Rust) HIR builder restricts top-level `let` initializers to
// literals/lambdas/externals/handlers — a top-level `let X = Opcode(op_byte: 2)`
// would be rejected as an unsupported initializer.

export opaque type SectionId = SectionId(sec_byte: i64)
export opaque type Valtype = Valtype(vt_byte: i64)
export opaque type Blocktype = Blocktype(bt_byte: i64)
export opaque type DescriptorKind = DescriptorKind(desc_byte: i64)
export opaque type Opcode = Opcode(op_byte: i64)
export opaque type WasmForm = WasmForm(form_byte_v: i64)

// ─── Accessors: opaque byte-classifier types -> raw i64 byte ────────────────

export let opcode_byte = fn (op: Opcode) -> i64 do
  let Opcode(op_byte: b) = op
  return b
end

export let valtype_byte = fn (vt: Valtype) -> i64 do
  let Valtype(vt_byte: b) = vt
  return b
end

export let blocktype_byte = fn (bt: Blocktype) -> i64 do
  let Blocktype(bt_byte: b) = bt
  return b
end

export let section_id_byte = fn (s: SectionId) -> i64 do
  let SectionId(sec_byte: b) = s
  return b
end

export let descriptor_kind_byte = fn (d: DescriptorKind) -> i64 do
  let DescriptorKind(desc_byte: b) = d
  return b
end

export let form_byte = fn (f: WasmForm) -> i64 do
  let WasmForm(form_byte_v: b) = f
  return b
end

// Wrap a raw byte (e.g. one freshly read from a &ByteBuffer) back into an
// Opcode. Provided so decoders such as rw_instrs in wasm/merge.nx can
// compare a stream byte against named opcode constants without round-
// tripping through opcode_byte on every constant.
export let byte_to_opcode = fn (b: i64) -> Opcode do
  return Opcode(op_byte: b)
end

// ─── Encoder helpers: emit an opaque classifier directly into a buffer ──────

export let emit_op = fn (buf: %ByteBuffer, op: Opcode) -> %ByteBuffer do
  return bb.push_byte(%buf, byte: opcode_byte(op))
end

export let emit_ops = fn (buf: %ByteBuffer, ops: [Opcode]) -> %ByteBuffer do
  match ops do
    | [] -> return %buf
    | op :: rest ->
      let %buf = emit_op(%buf, op)
      return emit_ops(%buf, ops: rest)
  end
end

export let emit_valtype = fn (buf: %ByteBuffer, vt: Valtype) -> %ByteBuffer do
  return bb.push_byte(%buf, byte: valtype_byte(vt))
end

export let emit_blocktype = fn (buf: %ByteBuffer, bt: Blocktype) -> %ByteBuffer do
  return bb.push_byte(%buf, byte: blocktype_byte(bt))
end

export let emit_section_id = fn (buf: %ByteBuffer, s: SectionId) -> %ByteBuffer do
  return bb.push_byte(%buf, byte: section_id_byte(s: s))
end

export let emit_descriptor_kind = fn (buf: %ByteBuffer, d: DescriptorKind) -> %ByteBuffer do
  return bb.push_byte(%buf, byte: descriptor_kind_byte(d: d))
end

export let emit_form = fn (buf: %ByteBuffer, f: WasmForm) -> %ByteBuffer do
  return bb.push_byte(%buf, byte: form_byte(f: f))
end

// ─── Section IDs ────────────────────────────────────────────────────────────

export let sec_type = fn () -> SectionId do return SectionId(sec_byte: 1) end
export let sec_import = fn () -> SectionId do return SectionId(sec_byte: 2) end
export let sec_function = fn () -> SectionId do return SectionId(sec_byte: 3) end
export let sec_memory = fn () -> SectionId do return SectionId(sec_byte: 5) end
export let sec_global = fn () -> SectionId do return SectionId(sec_byte: 6) end
export let sec_export = fn () -> SectionId do return SectionId(sec_byte: 7) end
export let sec_code = fn () -> SectionId do return SectionId(sec_byte: 10) end
export let sec_data = fn () -> SectionId do return SectionId(sec_byte: 11) end
export let sec_table = fn () -> SectionId do return SectionId(sec_byte: 4) end
export let sec_element = fn () -> SectionId do return SectionId(sec_byte: 9) end
export let sec_tag = fn () -> SectionId do return SectionId(sec_byte: 13) end
export let sec_custom = fn () -> SectionId do return SectionId(sec_byte: 0) end

// ─── Value types ────────────────────────────────────────────────────────────

export let vt_i32 = fn () -> Valtype do return Valtype(vt_byte: 127) end
export let vt_i64 = fn () -> Valtype do return Valtype(vt_byte: 126) end
export let vt_f32 = fn () -> Valtype do return Valtype(vt_byte: 125) end
export let vt_f64 = fn () -> Valtype do return Valtype(vt_byte: 124) end
export let vt_funcref = fn () -> Valtype do return Valtype(vt_byte: 112) end

// Typed-reference valtype prefixes (typed function references / GC proposal).
// Followed by an SLEB-encoded heaptype index.
export let vt_ref_null_ht = fn () -> Valtype do return Valtype(vt_byte: 99) end   // 0x63
export let vt_ref_ht = fn () -> Valtype do return Valtype(vt_byte: 100) end       // 0x64

// Sentinel valtype returned by `lookup_local_valtype` when the name is not
// in the entry list. The byte value -1 is outside the valid valtype range
// (single-byte vt_*) so equality with any real valtype constant is
// guaranteed false.
export let vt_unknown = fn () -> Valtype do return Valtype(vt_byte: -1) end

// ─── Type-section forms ─────────────────────────────────────────────────────

// Functype tag — leads each entry of the type section that encodes a
// `(func (param ...) (result ...))`. Followed by ULEB params/results.
export let wasm_form_func = fn () -> WasmForm do return WasmForm(form_byte_v: 96) end // 0x60

// ─── Block types ────────────────────────────────────────────────────────────

export let bt_void = fn () -> Blocktype do return Blocktype(bt_byte: 64) end
export let bt_i32 = fn () -> Blocktype do return Blocktype(bt_byte: 127) end
export let bt_i64 = fn () -> Blocktype do return Blocktype(bt_byte: 126) end

// ─── Import/export descriptor kinds ─────────────────────────────────────────

export let desc_func = fn () -> DescriptorKind do return DescriptorKind(desc_byte: 0) end
export let desc_table = fn () -> DescriptorKind do return DescriptorKind(desc_byte: 1) end
export let desc_memory = fn () -> DescriptorKind do return DescriptorKind(desc_byte: 2) end
export let desc_global = fn () -> DescriptorKind do return DescriptorKind(desc_byte: 3) end

// ─── Opcodes ────────────────────────────────────────────────────────────────

