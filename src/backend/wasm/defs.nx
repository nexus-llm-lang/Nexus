/**
 * wasm/defs: WASM constants, helper types, and core utilities for codegen.
 *
 * Contains section IDs, value types, opcodes, CodegenCtx, type utilities,
 * FNV-1a hashing, lookup helpers, and WASM encoding primitives.
 */

import { ByteBuffer }, * as bb from "std:bytebuffer"
import { TypeExpr } from "src/common/ast.nx"
import { LirFunction, LirExpr, LirAtom, LirExternal } from "src/ir/lir/types.nx"
import * as str from "std:str"
import * as list from "std:list"

import { HashMap }, * as hmap from "std:hashmap"
import { StrMap } from "src/common/strmap.nx"

// ─── Section IDs ────────────────────────────────────────────────────────────

/** Type-section id (wasm spec table 5.5.2). */
export let sec_type = 1
/** Import-section id (wasm spec table 5.5.2). */
export let sec_import = 2
/** Function-section id (wasm spec table 5.5.2). */
export let sec_function = 3
/** Memory-section id (wasm spec table 5.5.2). */
export let sec_memory = 5
/** Global-section id (wasm spec table 5.5.2). */
export let sec_global = 6
/** Export-section id (wasm spec table 5.5.2). */
export let sec_export = 7
/** Code-section id (wasm spec table 5.5.2). */
export let sec_code = 10
/** Data-section id (wasm spec table 5.5.2). */
export let sec_data = 11
/** Table-section id (wasm spec table 5.5.2). */
export let sec_table = 4
/** Element-section id (wasm spec table 5.5.2). */
export let sec_element = 9
/** Tag-section id (exception-handling proposal). */
export let sec_tag = 13
/** Custom-section id (0); also `name`, DWARF, target_features. */
export let sec_custom = 0

// ─── Numeric magic constants ────────────────────────────────────────────────

/** WASM linear-memory page size (64 KiB) — the unit `memory.grow`/`memory.size`
 *  count in.
 */
export let wasm_page_size = 65536
/** `wasm_page_size - 1`; the mask used to round a byte count UP to a page
 *  count via `(bytes + wasm_page_mask) / wasm_page_size`.
 */
export let wasm_page_mask = 65535
/** Floor on the merged module's initial memory pages (16 MiB) — exceeds any
 *  program's static data so the heap bump pointer starts above it.
 */
export let default_initial_pages = 256
/** 2^32: the radix used to pack two i32 fields into a single i64 (val<<32|pos
 *  for ULEB return-encoding, idx<<32|valtype for local-name maps, etc.).
 */
export let u32_radix = 4294967296
/** FNV-1a 64-bit prime (mirrors `fnv_basis` below); multiplier used after
 *  each XOR step in `fnv_hash_byte`.
 */
export let fnv_prime = 1099511628211
/** ULEB128 continuation-bit threshold (0x80). A byte with this bit clear is
 *  the terminal byte; `byte % 128` extracts the 7 payload bits.
 */
export let uleb_continuation_bit = 128

// ─── Value types ────────────────────────────────────────────────────────────

/** Number valtype `i32` (0x7F). */
export let vt_i32 = 127
/** Number valtype `i64` (0x7E). */
export let vt_i64 = 126
/** Number valtype `f32` (0x7D). */
export let vt_f32 = 125
/** Number valtype `f64` (0x7C). */
export let vt_f64 = 124
/** Heap-type valtype `funcref` (0x70); legacy reference encoding. */
export let vt_funcref = 112

/** Typed-reference valtype prefixes (typed function references / GC proposal).
 *  Followed by an SLEB-encoded heaptype index.
 */
export let vt_ref_null_ht = 99               // 0x63
/** Non-null typed reference prefix (0x64); followed by an SLEB heaptype index. */
export let vt_ref_ht = 100                   // 0x64

// ─── Type-section forms ─────────────────────────────────────────────────────

/** Functype tag — leads each entry of the type section that encodes a
 *  `(func (param ...) (result ...))`. Followed by ULEB params/results.
 */
export let wasm_form_func = 96               // 0x60

// ─── Block types ────────────────────────────────────────────────────────────

/** Empty block type `void` (0x40) for blocks/loops/ifs with no result. */
export let bt_void = 64
/** Block type returning a single `i32` value (0x7F). */
export let bt_i32 = 127
/** Block type returning a single `i64` value (0x7E). */
export let bt_i64 = 126

// ─── Import/export descriptor kinds ─────────────────────────────────────────

/** Import/export descriptor kind: function (0x00). */
export let desc_func = 0
/** Import/export descriptor kind: table (0x01). */
export let desc_table = 1
/** Import/export descriptor kind: memory (0x02). */
export let desc_memory = 2
/** Import/export descriptor kind: global (0x03). */
export let desc_global = 3

// ─── Opcodes ────────────────────────────────────────────────────────────────

/** `unreachable` opcode (0x00); always traps. */
export let op_unreachable = 0
/** `block` opcode (0x02); followed by a blocktype. */
export let op_block = 2
/** `loop` opcode (0x03); followed by a blocktype. */
export let op_loop = 3
/** `if` opcode (0x04); followed by blocktype + then-instrs (+ `else` + else-instrs) + `end`. */
export let op_if = 4
/** `else` opcode (0x05); separator inside an `if` block. */
export let op_else = 5
/** `end` opcode (0x0B); terminator for blocks/loops/ifs/init exprs. */
export let op_end = 11
/** `br` opcode (0x0C); followed by a label index. */
export let op_br = 12
/** `br_if` opcode (0x0D); followed by a label index, branches if the i32 on top of stack is non-zero. */
export let op_br_if = 13
/** `br_table` opcode (0x0E); followed by a vec of label indices + default label. */
export let op_br_table = 14
/** `return` opcode (0x0F); returns from the enclosing function. */
export let op_return = 15
/** `call` opcode (0x10); followed by a function index. */
export let op_call = 16
/** `call_indirect` opcode (0x11); followed by a type index + table index. */
export let op_call_indirect = 17
/** `return_call` opcode (0x12); tail-call optimisation proposal. */
export let op_return_call = 18
/** `drop` opcode (0x1A); discard the top stack value. */
export let op_drop = 26
/** `local.get` opcode (0x20); followed by a local index. */
export let op_local_get = 32
/** `local.set` opcode (0x21); followed by a local index. */
export let op_local_set = 33
/** `local.tee` opcode (0x22); followed by a local index — stores and re-pushes. */
export let op_local_tee = 34
/** `global.get` opcode (0x23); followed by a global index. */
export let op_global_get = 35
/** `global.set` opcode (0x24); followed by a global index. */
export let op_global_set = 36
/** `i32.load` opcode (0x28); followed by a memarg. */
export let op_i32_load = 40
/** `i64.load` opcode (0x29); followed by a memarg. */
export let op_i64_load = 41
/** `f32.load` opcode (0x2A); followed by a memarg. */
export let op_f32_load = 42
/** `f64.load` opcode (0x2B); followed by a memarg. */
export let op_f64_load = 43
/** `i32.load8_u` opcode (0x2D); followed by a memarg. */
export let op_i32_load8_u = 45
/** `i32.store` opcode (0x36); followed by a memarg. */
export let op_i32_store = 54
/** `i64.store` opcode (0x37); followed by a memarg. */
export let op_i64_store = 55
/** `f32.store` opcode (0x38); followed by a memarg. */
export let op_f32_store = 56
/** `f64.store` opcode (0x39); followed by a memarg. */
export let op_f64_store = 57
/** `i32.store8` opcode (0x3A); followed by a memarg. */
export let op_i32_store8 = 58

/** Last opcode in the load/store family (0x3E = i64.store32). Marks the
 *  upper bound of the memarg-operand range used by rw_instrs's classifier.
 */
export let op_i64_store32 = 62
/** `i32.const` opcode (0x41); followed by an SLEB128 constant. */
export let op_i32_const = 65
/** `i64.const` opcode (0x42); followed by an SLEB128 constant. */
export let op_i64_const = 66
/** `f64.const` opcode (0x44); followed by 8 little-endian bytes. */
export let op_f64_const = 68
/** `i32.eqz` opcode (0x45); pop i32, push i32 (1 if zero, else 0). */
export let op_i32_eqz = 69
/** `i32.eq` opcode (0x46). */
export let op_i32_eq = 70
/** `i32.ne` opcode (0x47). */
export let op_i32_ne = 71
/** `i32.lt_s` opcode (0x48); signed less-than. */
export let op_i32_lt_s = 72
/** `i32.gt_s` opcode (0x4A); signed greater-than. */
export let op_i32_gt_s = 74
/** `i32.le_s` opcode (0x4C); signed less-or-equal. */
export let op_i32_le_s = 76
/** `i32.ge_s` opcode (0x4E); signed greater-or-equal. */
export let op_i32_ge_s = 78
/** `i32.ge_u` opcode (0x4F); unsigned greater-or-equal. */
export let op_i32_ge_u = 79
/** `i64.eq` opcode (0x51). */
export let op_i64_eq = 81
/** `i64.ne` opcode (0x52). */
export let op_i64_ne = 82
/** `i64.lt_s` opcode (0x53); signed less-than. */
export let op_i64_lt_s = 83
/** `i64.gt_s` opcode (0x55); signed greater-than. */
export let op_i64_gt_s = 85
/** `i64.le_s` opcode (0x57); signed less-or-equal. */
export let op_i64_le_s = 87
/** `i64.ge_s` opcode (0x59); signed greater-or-equal. */
export let op_i64_ge_s = 89
/** `f64.eq` opcode (0x61). */
export let op_f64_eq = 97
/** `f64.ne` opcode (0x62). */
export let op_f64_ne = 98
/** `f64.lt` opcode (0x63). */
export let op_f64_lt = 99
/** `f64.gt` opcode (0x64). */
export let op_f64_gt = 100
/** `f64.le` opcode (0x65). */
export let op_f64_le = 101
/** `f64.ge` opcode (0x66). */
export let op_f64_ge = 102
/** `i32.add` opcode (0x6A); wraps on overflow. */
export let op_i32_add = 106
/** `i32.sub` opcode (0x6B); wraps on overflow. */
export let op_i32_sub = 107
/** `i32.mul` opcode (0x6C); wraps on overflow. */
export let op_i32_mul = 108
/** `i32.and` opcode (0x71). */
export let op_i32_and = 113
/** `i32.or` opcode (0x72). */
export let op_i32_or = 114
/** `i32.xor` opcode (0x73). */
export let op_i32_xor = 115
/** `i64.add` opcode (0x7C); wraps on overflow. */
export let op_i64_add = 124
/** `i64.sub` opcode (0x7D); wraps on overflow. */
export let op_i64_sub = 125
/** `i64.mul` opcode (0x7E); wraps on overflow. */
export let op_i64_mul = 126
/** `i64.div_s` opcode (0x7F); signed; traps on div-by-zero or `INT_MIN / -1`. */
export let op_i64_div_s = 127
/** `i64.rem_s` opcode (0x81); signed remainder; traps on rem-by-zero. */
export let op_i64_rem_s = 129
/** `i64.and` opcode (0x83). */
export let op_i64_and = 131
/** `i64.or` opcode (0x84). */
export let op_i64_or = 132
/** `i64.xor` opcode (0x85). */
export let op_i64_xor = 133
/** `i64.shl` opcode (0x86); shift-left, masked to 6 bits. */
export let op_i64_shl = 134
/** `i64.shr_s` opcode (0x87); arithmetic shift-right. */
export let op_i64_shr_s = 135
/** `i64.shr_u` opcode (0x88); logical shift-right. */
export let op_i64_shr_u = 136
/** `f64.abs` opcode (0x99). */
export let op_f64_abs = 153                 // 0x99
/** `f64.ceil` opcode (0x9B). */
export let op_f64_ceil = 155                // 0x9B
/** `f64.floor` opcode (0x9C). */
export let op_f64_floor = 156               // 0x9C
/** `f64.sqrt` opcode (0x9F). */
export let op_f64_sqrt = 159                // 0x9F
/** `f64.add` opcode (0xA0). */
export let op_f64_add = 160
/** `f64.sub` opcode (0xA1). */
export let op_f64_sub = 161
/** `f64.mul` opcode (0xA2). */
export let op_f64_mul = 162
/** `f64.div` opcode (0xA3). */
export let op_f64_div = 163
/** `i32.wrap_i64` opcode (0xA7); truncate i64 to i32. */
export let op_i32_wrap_i64 = 167
/** `i64.extend_i32_s` opcode (0xAC); sign-extend i32 to i64. */
export let op_i64_extend_i32_s = 172
/** `i64.extend_i32_u` opcode (0xAD); zero-extend i32 to i64. */
export let op_i64_extend_i32_u = 173
/** `throw` opcode (0x08); throw an exception via the given tag (EH proposal). */
export let op_throw = 8
/** `try_table` opcode (0x1F); modern try with inline catch handlers (EH proposal). */
export let op_try_table = 31
/** `i64.reinterpret_f64` opcode (0xBD); bitwise reinterpretation, no rounding. */
export let op_i64_reinterpret_f64 = 189

// f32 ops (parallel to f64 set above)
/** `f32.eq` opcode (0x5B). */
export let op_f32_eq = 91                   // 0x5b
/** `f32.ne` opcode (0x5C). */
export let op_f32_ne = 92                   // 0x5c
/** `f32.lt` opcode (0x5D). */
export let op_f32_lt = 93                   // 0x5d
/** `f32.gt` opcode (0x5E). */
export let op_f32_gt = 94                   // 0x5e
/** `f32.le` opcode (0x5F). */
export let op_f32_le = 95                   // 0x5f
/** `f32.ge` opcode (0x60). */
export let op_f32_ge = 96                   // 0x60
/** `f32.add` opcode (0x92). */
export let op_f32_add = 146                 // 0x92
/** `f32.sub` opcode (0x93). */
export let op_f32_sub = 147                 // 0x93
/** `f32.mul` opcode (0x94). */
export let op_f32_mul = 148                 // 0x94
/** `f32.div` opcode (0x95). */
export let op_f32_div = 149                 // 0x95
/** `f32.demote_f64` opcode (0xB6); narrow f64 to f32. */
export let op_f32_demote_f64 = 182          // 0xb6
/** `f64.promote_f32` opcode (0xBB); widen f32 to f64 exactly. */
export let op_f64_promote_f32 = 187         // 0xbb
/** `memory.size` opcode (0x3F); followed by a memory-index byte. */
export let op_memory_size = 63
/** `memory.grow` opcode (0x40); followed by a memory-index byte. */
export let op_memory_grow = 64
/** `i32.gt_u` opcode (0x4B); unsigned greater-than. */
export let op_i32_gt_u = 75
/** `i32.shl` opcode (0x74); shift-left, masked to 5 bits. */
export let op_i32_shl = 116
/** `i32.shr_u` opcode (0x76); logical shift-right. */
export let op_i32_shr_u = 118

/** Catch-kind byte 0 inside `try_table`: catch a tag, push payload, branch to label. */
export let catch_kind_one = 0

// ─── Stack-switching proposal (nexus-x7w / hs25 / apbn) ─────────────────────
// Opcodes verified against wasm-tools 1.x output of hand-written WAT.
// Followed in the binary stream by the indicated LEB128-encoded operands.

/** Type-section form indicator for `(cont $func_type_idx)`. After the byte,
 *  emit the LEB128 func-type index that the continuation runs.
 */
export let form_cont = 93                   // 0x5d

/** `cont.new $cont_type` — pop (ref null $func_type), push (ref $cont_type).
 *  Followed by LEB128 cont type index.
 */
export let op_cont_new = 224                // 0xe0

/** `cont.bind $arg_cont $res_cont` — partially applies a cont. Followed by
 *  LEB128 argument-cont type index, then LEB128 result-cont type index.
 */
export let op_cont_bind = 225               // 0xe1

/** `suspend $tag` — captures the current stack up to the nearest matching
 *  resume frame and transfers the payload into that frame's `on $tag`
 *  handler. Followed by LEB128 tag index.
 */
export let op_suspend = 226                 // 0xe2

/** `resume $cont_type (handler_table)` — reify a cont and run it; on
 *  suspend, dispatch via the handler table. Followed by LEB128 cont type
 *  index, then LEB128 handler-table count, then for each handler:
 *  resume_handler_kind (1 byte) + LEB128 tag + LEB128 label.
 */
export let op_resume = 227                  // 0xe3

/** `ref.null` opcode (0xD0); followed by a heaptype byte/index. */
export let op_ref_null = 208                 // 0xD0
/** `ref.func` opcode (0xD2); followed by a function index — produces a typed funcref. */
export let op_ref_func = 210                 // 0xD2

/** Legacy exception-handling `try` opcode (pre-`try_table` proposal). Encoded
 *  like `block`/`loop`/`if` but followed by handler entries — see
 *  rw_instrs in wasm/merge.nx for the operand-decode strategy.
 */
export let op_legacy_try = 6                  // 0x06

/** `table.get` opcode (0x25); followed by a table index. */
export let op_table_get = 37                 // 0x25
/** `table.set` opcode (0x26); followed by a table index. */
export let op_table_set = 38                 // 0x26

/** 0xFC-prefixed (saturating-truncation / bulk-memory / table) family.
 *  The next byte is a ULEB sub-opcode selecting the actual instruction.
 */
export let op_fc_prefix = 252                // 0xFC

/** 0xFC sub-opcodes (bulk-memory / table proposals). */
/** `memory.init` sub-opcode (0xFC 0x08); bulk-memory: copy from a passive data segment. */
export let op_fc_memory_init = 8
/** `memory.copy` sub-opcode (0xFC 0x0A); bulk-memory copy within linear memory. */
export let op_fc_memory_copy = 10
/** `memory.fill` sub-opcode (0xFC 0x0B); bulk-memory fill with a single byte. */
export let op_fc_memory_fill = 11
/** `table.init` sub-opcode (0xFC 0x0C); copy from a passive element segment into a table. */
export let op_fc_table_init = 12
/** `table.copy` sub-opcode (0xFC 0x0E); copy between tables. */
export let op_fc_table_copy = 14

/** 0xFD-prefixed (SIMD / fixed-width 128-bit) family. The next operand is a
 *  ULEB128-encoded sub-opcode selecting the actual SIMD instruction. Sub-opcodes
 *  >= 128 require two ULEB bytes (e.g. f32x4.add = 228 → 0xe4 0x01), which is
 *  why dispatchers must use `bb.push_uleb128`, not `bb.push_byte`.
 *
 *  Verified against wasm-tools 1.247.0 disassembly of a hand-written WAT
 *  covering load / store / splat / arithmetic for every lane shape used here.
 */
export let op_simd_prefix = 253               // 0xFD

/** 0xFD sub-opcodes (subset — fixed-width SIMD proposal). Memory-arg layout
 *  mirrors scalar load/store: ULEB128 align (log2 byte-alignment) followed by
 *  ULEB128 offset. v128 is naturally 16-byte aligned (align = 4).
 */
/** v128 load sub-opcode under the SIMD prefix; followed by a memarg. */
export let op_simd_v128_load = 0              // (sub) 0x00
/** v128 store sub-opcode under the SIMD prefix; followed by a memarg. */
export let op_simd_v128_store = 11            // (sub) 0x0B
/** `i32x4.splat` / `i64x2.splat` / `f32x4.splat` / `f64x2.splat` consume one
 *  scalar from the operand stack and broadcast to every lane of a v128.
 */
export let op_simd_i32x4_splat = 17           // (sub) 0x11
/** `i64x2.splat` SIMD sub-opcode. */
export let op_simd_i64x2_splat = 18           // (sub) 0x12
/** `f32x4.splat` SIMD sub-opcode. */
export let op_simd_f32x4_splat = 19           // (sub) 0x13
/** `f64x2.splat` SIMD sub-opcode. */
export let op_simd_f64x2_splat = 20           // (sub) 0x14
/** Lane-wise arithmetic — pop two v128, push one v128. Wraparound semantics
 *  for integer ops; IEEE 754 semantics for float ops (no FMA fusion).
 *  `div` is float-only: WebAssembly SIMD has no lane-wise integer division
 *  (an `i32x4.div_*` opcode does not exist in the proposal); callers needing
 *  integer per-lane division must scalarize.
 */
export let op_simd_i32x4_add = 174            // (sub) 0xAE
/** `i32x4.sub` SIMD lane-wise integer subtraction. */
export let op_simd_i32x4_sub = 177            // (sub) 0xB1
/** `i32x4.mul` SIMD lane-wise integer multiplication (low 32 bits). */
export let op_simd_i32x4_mul = 181            // (sub) 0xB5
/** `i64x2.add` SIMD lane-wise integer addition. */
export let op_simd_i64x2_add = 206            // (sub) 0xCE
/** `i64x2.sub` SIMD lane-wise integer subtraction. */
export let op_simd_i64x2_sub = 209            // (sub) 0xD1
/** `i64x2.mul` SIMD lane-wise integer multiplication (low 64 bits). */
export let op_simd_i64x2_mul = 213            // (sub) 0xD5
/** `f32x4.add` SIMD lane-wise float addition. */
export let op_simd_f32x4_add = 228            // (sub) 0xE4
/** `f32x4.sub` SIMD lane-wise float subtraction. */
export let op_simd_f32x4_sub = 229            // (sub) 0xE5
/** `f32x4.mul` SIMD lane-wise float multiplication. */
export let op_simd_f32x4_mul = 230            // (sub) 0xE6
/** `f32x4.div` SIMD lane-wise float division. */
export let op_simd_f32x4_div = 231            // (sub) 0xE7
/** `f64x2.add` SIMD lane-wise float addition. */
export let op_simd_f64x2_add = 240            // (sub) 0xF0
/** `f64x2.sub` SIMD lane-wise float subtraction. */
export let op_simd_f64x2_sub = 241            // (sub) 0xF1
/** `f64x2.mul` SIMD lane-wise float multiplication. */
export let op_simd_f64x2_mul = 242            // (sub) 0xF2
/** `f64x2.div` SIMD lane-wise float division. */
export let op_simd_f64x2_div = 243            // (sub) 0xF3

// ─── Threads / atomics proposal (0xFE prefix) ───────────────────────────────
// Verified against wasm-tools disassembly of hand-written WAT. Each 0xFE op is
// followed by a ULEB sub-opcode, then (for the memory-accessing ops) a memarg:
// ULEB align (log2 of natural alignment — atomics REQUIRE exact natural
// alignment, unlike plain load/store) followed by ULEB offset. The sole
// exception is `atomic.fence` (sub-op 0x03), which is followed by a single
// reserved memidx byte (0x00) instead of a memarg. wait32 / notify trap at
// runtime unless the linear memory is `shared`; the rmw / load / store ops
// also work on non-shared memory (without cross-thread ordering guarantees).
/** 0xFE prefix byte for the threads/atomics proposal; followed by a ULEB sub-opcode. */
export let op_atomic_prefix = 254              // 0xFE

/** 0xFE sub-opcodes (subset — threads proposal). */
export let op_atomic_notify = 0                // (sub) 0x00 — memory.atomic.notify : [addr i32, count i32] -> i32 (n woken)
/** `memory.atomic.wait32` sub-op (0xFE 0x01); block until `*addr != expected` or timeout. */
export let op_atomic_wait32 = 1                // (sub) 0x01 — memory.atomic.wait32 : [addr i32, expected i32, timeout i64] -> i32
/** `atomic.fence` sub-op (0xFE 0x03); followed by a single reserved 0x00 byte (not a memarg). */
export let op_atomic_fence = 3                 // (sub) 0x03 — atomic.fence ; followed by one reserved 0x00 byte, not a memarg
/** `i32.atomic.load` sub-op (0xFE 0x10); sequentially-consistent i32 load. */
export let op_i32_atomic_load = 16             // (sub) 0x10 — i32.atomic.load : [addr i32] -> i32
/** `i32.atomic.store` sub-op (0xFE 0x17); sequentially-consistent i32 store. */
export let op_i32_atomic_store = 23            // (sub) 0x17 — i32.atomic.store : [addr i32, val i32] -> []
/** `i32.atomic.rmw.add` sub-op (0xFE 0x1E); atomic fetch-and-add returning the pre-update value. */
export let op_i32_atomic_rmw_add = 30          // (sub) 0x1E — i32.atomic.rmw.add : [addr i32, val i32] -> i32 (old)
/** `i32.atomic.rmw.cmpxchg` sub-op (0xFE 0x48); compare-and-swap returning the observed value. */
export let op_i32_atomic_rmw_cmpxchg = 72      // (sub) 0x48 — i32.atomic.rmw.cmpxchg : [addr i32, expected i32, repl i32] -> i32 (old)

/** Emit `0xFE <sub_op> <align> <offset>` for an i32-width atomic memory op
 *  (align fixed at 2 = 4-byte natural alignment, which the validator requires).
 */
export let emit_atomic_op32 = fn (buf: %ByteBuffer, sub_op: i64, offset: i64) -> %ByteBuffer do
  let %buf = bb.push_byte(%buf, byte: op_atomic_prefix)
  let %buf = bb.push_uleb128(%buf, val: sub_op)
  return emit_memarg(%buf, align: 2, offset)
end

/** Emit `0xFE <sub_op> <align> <offset>` for an i64-width atomic memory op
 *  (align fixed at 3 = 8-byte natural alignment).
 */
let emit_atomic_op64 = fn (buf: %ByteBuffer, sub_op: i64, offset: i64) -> %ByteBuffer do
  let %buf = bb.push_byte(%buf, byte: op_atomic_prefix)
  let %buf = bb.push_uleb128(%buf, val: sub_op)
  return emit_memarg(%buf, align: 3, offset)
end

// ─── Coverage instrumentation ──────────────────────────────────
// When `--coverage` is on, codegen reserves linear-memory page 17 for an
// i32 atomic counter array — one cell per LIR function in emission order.
// The cell's byte offset is `cov_counter_base + 4 * func_id`. To keep page
// 17 from clashing with the heap (whose bump pointer seeds to
// memory.size()*65536), the memory section's `min` is bumped from 17 to 18
// pages when coverage is on, so the heap starts at byte 1179648.
//
// 16384 i32 cells fit in one page (65536 / 4), comfortably above the
// function count of any program we expect to compile.

/** Byte offset of the first coverage counter cell (= 17 * 65536). */
export let cov_counter_base = 1114112
/** Default initial memory min pages without coverage. Matches the constant
 *  in `build_memory_section`. Bumped by `cov_extra_pages` under `--coverage`.
 */
export let cov_base_pages = 17
/** Extra memory pages reserved for coverage when `--coverage` is on. */
export let cov_extra_pages = 1

/** Wasm-global index used as the legacy heap-base global (G0); kept stable so codegen-and-merge agree on its slot. */
export let heap_global_idx = 0

/** Linear-memory byte offset of the unified bump-pointer cell. The cell holds
 *  the current heap top as an i32. `[0, 8)` is reserved for it (only 4 bytes
 *  are live; the extra 4 are alignment headroom; `[8, 16)` is the
 *  std:runtime/sysio lazy-scratch-pointer slot). The cell is lazily
 *  seeded to `memory.size()*65536` on the first allocation (it is NOT
 *  data-segment initialised — a per-instance segment would clobber the shared
 *  bump pointer under WASI threads). Both codegen-emitted allocations
 *  (`emit_alloc_object`, string concat, FFI retptrs, `cabi_realloc`) and the
 *  `nexus:runtime/arena.alloc-raw` intrinsic atomically bump it via
 *  `i32.atomic.rmw.add`.
 */
export let heap_ptr_cell = 0

/** Backtrace ring-buffer base address (page 18 = 18 * 65536 = 1179648).
 * Layout (V1):
 *  offset  0..7  : i64 current depth (live counter, monotonic).
 *  offset  8..15 : i64 saved depth at last throw (snapshot for backtrace()).
 *  offset 16..(16+64*8) : 64-slot i64 ring buffer of packed `(ptr<<32)|len`
 *  string values, indexed by (depth & 63).
 *  Pages 15 = rand (983040), 16 = log (1048576), 17 = reserved for coverage,
 *  18 = backtrace; codegen-emitted prologues push at `(depth & 63)` and never
 *  pop (V1 monotonic depth + wrap-around — pops would require try-catch
 *  wrapping every function body to stay balanced across unwinds).
 */
export let bt_page_base = 1179648
/** Byte offset within `bt_page_base` where the live monotonic depth counter lives (i64). */
export let bt_depth_offset = 0
/** Byte offset where the at-throw snapshot of the depth lives (i64); read by `__nx_bt_depth`. */
export let bt_saved_depth_offset = 8
/** Byte offset where the 64-slot frame-name ring starts (i64 packed `(ptr<<32)|len` per slot). */
export let bt_ring_offset = 16
/** Capacity of the backtrace ring buffer in slots (64). */
export let bt_ring_capacity = 64
/** Minimum initial memory pages for WASI preview3 (non-shared) mode.
 *  Must cover through the backtrace ring (page 18) since the BT prologue
 *  writes to bt_page_base without a grow-check. 19 pages = pages 0..18.
 *  Under preview1 the memory is imported as shared (min 256) so this is
 *  only relevant for the p3 defined-memory path.
 */
export let p3_base_pages = 19

// ─── Component model section IDs (WASI preview3 / component-model-async) ────
// Binary encoding constants for the WebAssembly component model.
// These are the component-level section discriminants, distinct from the
// core-module section IDs above (which share the 0x01..0x0B range).
// Reference: WebAssembly component model binary format, 2024 spec draft.

/** Component-level type section id (0x07). Encodes component/defined types,
 *  including `future<T>`, `stream<T>`, and resource types.
 */
export let cm_sec_type = 7

/** Component-level canonical function section id (0x08). Encodes
 *  `canon future.new`, `canon future.write`, `task.return`, etc.
 */
export let cm_sec_canon = 8

/** Component-level core-instance section id (0x02). Used to instantiate a
 *  core module or collect a FromExports instance.
 */
export let cm_sec_core_instance = 2

/** Component-level alias section id (0x06). Aliases core instance exports
 *  (e.g. memory exports) into the component index space.
 */
export let cm_sec_alias = 6

/** Component instance section id (0x05). Collects a component instance
 *  from exports (FromExports). Used to bundle lifted functions into
 *  a WASI interface instance.
 */
export let cm_sec_instance = 5

/** Component export section id (0x0B = 11). Declares the component's
 *  public exports (e.g. `wasi:cli/run@0.2.6`).
 */
export let cm_sec_export = 11

// ─── Component type opcodes ──────────────────────────────────────────────────

/** Component defined-type marker (0x65 = 101). Leads each entry in the component
 *  type section. Followed by the type-specific encoding.
 */
export let cm_type_defined = 101             // 0x65

/** `future<T>` type opcode (0x01 = 1) within a component defined-type entry.
 *  Followed by the payload-type encoding (a primitive or type index).
 */
export let cm_type_future = 1               // 0x01

/** Component primitive type `u64` (0x77 = 119). Used as the payload of
 *  `future<u64>` since Nexus thunk results are i64 at the wasm level.
 */
export let cm_prim_u64 = 119               // 0x77

// ─── Canonical ABI opcode bytes ─────────────────────────────────────────────
// These are the single-byte discriminants inside the canonical function section.
// Each creates a core-level function that wraps the specified canonical built-in.

/** `canon future.new` opcode (0x15 = 21). Takes: type_idx. Creates a core func
 *  `() -> i64` (packed read+write handles).
 */
export let cm_canon_future_new = 21          // 0x15

/** `canon future.read` opcode (0x16 = 22). Takes: type_idx + options.
 *  Async form creates `(read_handle: i32, ptr: i32) -> i32`.
 */
export let cm_canon_future_read = 22         // 0x16

/** `canon future.write` opcode (0x17 = 23). Takes: type_idx + options.
 *  Async form creates `(write_handle: i32, ptr: i32) -> i32`.
 */
export let cm_canon_future_write = 23        // 0x17

/** `canon future.drop-readable` opcode (0x1A = 26). Takes: type_idx.
 *  Creates `(read_handle: i32) -> ()`.
 */
export let cm_canon_future_drop_readable = 26  // 0x1A

/** `canon future.drop-writable` opcode (0x1B = 27). Takes: type_idx.
 *  Creates `(write_handle: i32) -> ()`.
 */
export let cm_canon_future_drop_writable = 27  // 0x1B

/** `canon task.return` opcode (0x09 = 9). Takes: result_count + options.
 *  With no result and no options encodes as `09 01 00 00`.
 *  Creates `() -> ()`.
 */
export let cm_canon_task_return = 9          // 0x09

/** `canon waitable-set.new` opcode (0x1F = 31). Takes no arguments.
 *  Creates `() -> i32` (waitable-set handle).
 */
export let cm_canon_ws_new = 31              // 0x1F

/** `canon waitable-set.wait` opcode (0x20 = 32). Takes: cancellable_byte + options.
 *  With cancellable=false and memory option: `20 00 01 03 memory_idx`.
 *  Creates `(ws_handle: i32, ptr: i32) -> i32`.
 */
export let cm_canon_ws_wait = 32             // 0x20

/** `canon waitable-set.drop` opcode (0x22 = 34). No arguments.
 *  Creates `(ws_handle: i32) -> ()`.
 */
export let cm_canon_ws_drop = 34             // 0x22

// ─── Canonical option bytes ──────────────────────────────────────────────────

/** Canonical option `async` (0x06 = 6). Selects the async-lowering variant of
 *  `future.read`/`future.write`; required for non-blocking semantics.
 */
export let cm_opt_async = 6                  // 0x06

/** Canonical option `memory` (0x03 = 3). Followed by ULEB memory index.
 *  Required for canon functions that access linear memory (e.g. future.write).
 */
export let cm_opt_memory = 3                 // 0x03

// ─── Component magic ─────────────────────────────────────────────────────────

/** Component model version byte 0: 0x0D = 13 (component model version word). */
export let cm_version_byte0 = 13             // 0x0D
/** Component model version byte 1: 0x00 = 0. */
export let cm_version_byte1 = 0              // 0x00
/** Component model version byte 2: 0x01 = 1. */
export let cm_version_byte2 = 1              // 0x01
/** Component model version byte 3: 0x00 = 0. */
export let cm_version_byte3 = 0              // 0x00

/** Core module section discriminant within a component binary (0x01 = 1).
 *  Precedes the inline core module bytes.
 */
export let cm_sec_core_module = 1            // 0x01

/** Global slot holding the current `(ref null cont)` for stack-switching dispatch. */
export let ss_cont_global_idx = 3
/** Global slot holding the cont-table index of the cont to resume next. */
export let ss_resume_slot_global_idx = 4
/** Global slot holding the next free cont-table slot to allocate from. */
export let ss_next_alloc_global_idx = 5
/** Wasm table index reserved for the cont table (table 1, while table 0 is the funcref table). */
export let ss_cont_table_idx = 1

// ─── Helper types ───────────────────────────────────────────────────────────

/** `(name, wasm_index, valtype)` for one wasm local; first-occurrence order, with `widen_local` overwriting `valtype` on conflict. */
export type LocalEntry = LocalEntry(name: string, index: i64, valtype: i64)
/** `(nexus_name, wasm_function_index)` for one entry in the internal- or external-func list; built by `build_*_func_entries`. */
export type FuncEntry = FuncEntry(name: string, index: i64)
/** A `(wasm export name, function index)` pair for extra module exports
 *  (currently only `wasi_thread_start`, the WASI-threads worker trampoline).
 */
export type ExportNameIdx = ExportNameIdx(name: string, index: i64)
/** `(value, byte_offset, byte_length)` for one entry in the wasm data segment laid out by `build_string_entries`. */
export type StringEntry = StringEntry(value: string, offset: i64, slen: i64)
/** `(arity, type_index)` pair from `build_closure_type_idx_list` — answers `arity -> canonical-closure-type-idx` in O(arities). */
export type ArityTypeIdx = ArityTypeIdx(arity: i64, type_idx: i64)

// ─── CodegenCtx ─────────────────────────────────────────────────────────────

/** Threaded codegen-time context: every local/func/external map, the active function's name, stack-switching slots, memo cache, and the bt-capture import slot. Linear in `internal_func_map`/`external_func_map`/`local_map` so consumers must thread the carrier. */
export type CodegenCtx = CodegenCtx(
  locals: [LocalEntry],
  internal_funcs: [FuncEntry],
  external_funcs: [FuncEntry],
  string_lits: [StringEntry],
  alloc_mode: i64,
  temps_base: i64,
  func_ret_type: TypeExpr,
  functions: [LirFunction],
  externals: [LirExternal],
  closure_table: [FuncEntry],
  closure_type_indices: [ArityTypeIdx],
  internal_func_map: &HashMap,
  external_func_map: &HashMap,
  func_name: string,
  ss_tag_idx: i64,
  ss_cont_type_idx: i64,
  ss_dispatch_block_type_idx: i64,
  ss_tag_names: [string],
  /** O(1) lookup parallel to `ss_tag_names`: `tag_name -> position`. Built
   *  once at program scope from `ss_tag_names` and threaded through codegen.
   */
  ss_tag_idx_map: StrMap<i64>,
  // Wasm function index of the imported `__nx_main_wrap_bt_capture` (a.k.a.
  // `nexus:intrinsic.capture-backtrace`) call target for this function's
  // throw sites, or -1 when capture should be skipped. Set per-function from
  // EffectMap.can_throw: functions whose transitive
  // callees never throw skip the call entirely; functions that may throw
  // receive the program-wide capture import index. -1 also covers the case
  // where the program does not import the capture external at all — which,
  // post the runtime/backtrace -> intrinsic move, is now ALWAYS the case:
  // `capture-backtrace` is filtered out of the import section so the throw-
  // site `call` is elided unconditionally.
  bt_capture_idx: i64,
  // Eligible memoization-target function names paired
  // with their cache slot. Codegen reads this to decide whether emit_call
  // wraps an internal call site in a single-slot last-call cache. The slot
  // address-translates to globals (memo_globals_base + 3*slot + offset).
  memo_target_names: [string],
  memo_target_slots: [i64],
  memo_globals_base: i64,
  import_count: i64,
  // Per-function packed local-name map for O(1) Variable-atom
  // emission. Each value is `(local_index << 32) | valtype`; -1 = absent.
  // Owned at `emit_one_body` scope, borrowed here, freed after each function
  // body finishes (locals don't survive across functions).
  local_map: &HashMap
)

/** Read `temps_base` (the first reserved-temp local index) out of the codegen context. */
export let ctx_temps_base = fn (ctx: CodegenCtx) -> i64 do
  let CodegenCtx(temps_base: t, _) = ctx
  return t
end

/** Read the program's external import list out of the codegen context. */
export let ctx_externals = fn (ctx: CodegenCtx) -> [LirExternal] do
  let CodegenCtx(externals: e, _) = ctx
  return e
end

/** Look up an internal `LirFunction` by name via the per-function index hashmap; `None` if absent. */
export let ctx_lookup_function = fn (ctx: CodegenCtx, name: string) -> Option<LirFunction> do
  let CodegenCtx(functions: fs, internal_func_map: m, import_count: ic, _) = ctx
  return lookup_function_fast(name, funcs: fs, map: &m, import_count: ic)
end

/** O(1) per-Variable-atom lookup over the function's local table.
 *  Returns `(index << 32) | valtype` or -1 when `name` is absent.
 */
export let ctx_lookup_local = fn (ctx: CodegenCtx, name: string) -> i64 do
  let CodegenCtx(local_map: lm, _) = ctx
  return hmap.get_or(map: lm, key: hash_name(name), default: -1)
end

/** Strip outer `TyLinear` / `TyLazy` / `TyBorrow` wrappers and return the inner type; idempotent on already-bare types. */
export let peel_linear = fn (typ: TypeExpr) -> TypeExpr do
  match typ do
    | TyLinear(inner: t) | TyLazy(inner: t) | TyBorrow(inner: t) -> return peel_linear(typ: t)
    | _ -> return typ
  end
end

/** Map a Nexus type to its wasm valtype byte: bool/char/i32 → `vt_i32`, intlit/i64 → `vt_i64`, f32 → `vt_f32`, f64 → `vt_f64`, everything else → `vt_i64`. */
export let type_to_valtype = fn (typ: TypeExpr) -> i64 do
  match peel_linear(typ) do
    | TyI32 | TyBool | TyChar -> vt_i32
    | TyI64 | TyIntLit -> vt_i64
    | TyF32 -> vt_f32
    | TyF64 | TyFloatLit -> vt_f64
    | _ -> vt_i64
  end
end

/** True iff `typ` is exactly `TyUnit` (no `peel_linear` — linear `unit` still allocates a slot). */
export let is_unit = fn (typ: TypeExpr) -> bool do
  match typ do
    | TyUnit -> return true
    | _ -> return false
  end
end

let fnv_hash_byte = fn (hash: i64, byte: i64) -> i64 do
  return (hash ^ byte) * fnv_prime
end

let fnv_hash_string_go = fn (s: string, idx: i64, slen: i64, hash: i64) -> i64 do
  if idx >= slen then return hash
  else return fnv_hash_string_go(s, idx: idx + 1, slen,
                                  hash: fnv_hash_byte(hash, byte: str.char_code(s, idx)))
  end
end

let fnv_hash_string = fn (s: string, hash: i64) -> i64 do
  return fnv_hash_string_go(s, idx: 0, slen: str.length(s), hash)
end

/** FNV-1a 64-bit basis; seed value mixed against each byte by `fnv_hash_byte`. */
export let fnv_basis = -3750763034362895579

/** Hash a constructor's `(name, arity)` pair into the i64 tag the codegen writes into the object header so pattern matches can compare tags directly. */
export let constructor_tag = fn (name: string, arity: i64) -> i64 do
  return fnv_hash_byte(hash: fnv_hash_string(s: name, hash: fnv_basis), byte: arity)
end

/** Hash a record's sorted-field-names list into the i64 tag the codegen writes into the record header; deterministic across modules so structurally-equal records share a tag. */
export let record_tag = fn (sorted_names: [string]) -> i64 do
  let shape = str.join(xs: sorted_names, sep: ",")
  let h = fnv_hash_string(s: shape, hash: fnv_hash_string(s: "rec", hash: fnv_basis))
  return fnv_hash_byte(hash: h, byte: list.length(xs: sorted_names))
end

// ─── Atom/expr type accessors ───────────────────────────────────────────────

/** Recover the static type of a `LirAtom`: variables carry their type explicitly; literals project to their canonical Nexus type. */
export let atom_type = fn (atom: LirAtom) -> TypeExpr do
  match atom do
    | LirAtomVar(name: _, typ: t) -> t
    | LirAtomInt(_) -> TyI64
    | LirAtomFloat(_) -> TyF64
    | LirAtomBool(_) -> TyBool
    | LirAtomChar(_) -> TyChar
    | LirAtomString(_) -> TyString
    | LirAtomUnit -> TyUnit
  end
end

/** Recover the static type of a `LirExpr` by reading the `typ:` field from whichever variant constructed it. */
export let expr_type = fn (expr: LirExpr) -> TypeExpr do
  match expr do
    | LirExprAtom(atom: a) -> atom_type(atom: a)
    | LirExprBinary(op: _, lhs: _, rhs: _, typ: t)
    | LirExprCall(func: _, args: _, typ: t)
    | LirExprTailCall(func: _, args: _, typ: t)
    | LirExprConstructor(name: _, args: _, typ: t)
    | LirExprRecord(fields: _, typ: t)
    | LirExprObjectTag(value: _, typ: t)
    | LirExprObjectField(value: _, index: _, typ: t)
    | LirExprRaise(value: _, typ: t)
    | LirExprForce(value: _, typ: t)
    | LirExprMakeClosure(func_name: _, captures: _, typ: t)
    | LirExprCallClosure(closure: _, args: _, typ: t)
    | LirExprSuspend(tag_name: _, payload: _, typ: t)
    | LirExprResume(cont: _, value: _, typ: t)
    | LirExprContNew(func_ref: _, typ: t)
    | LirExprInjectResume(body_fn: _, arm_fns: _, arm_tags: _, typ: t) -> t
  end
end

// ─── Lookup helpers ─────────────────────────────────────────────────────────
// Per-function name → packed (index<<32 | valtype) lookups are done in O(1)
// via `ctx_lookup_local` (HashMap built once in build_func_locals). The
// linear-scan `lookup_local*` helpers that previously walked `[LocalEntry]`
// were removed.

// Replace valtype for an existing local entry (widen i32 → i64 on conflict)
/** Replace the `valtype` of the entry named `name` in `entries` with `new_vt`; identity when `name` is absent. Used when a later `register_local` finds a name already bound to a narrower valtype. */
export let widen_local = fn (name: string, new_vt: i64, entries: [LocalEntry]) -> [LocalEntry] do
  return widen_local_go(name, new_vt, entries, acc: [])
end

let widen_local_go = fn (name: string, new_vt: i64, entries: [LocalEntry], acc: [LocalEntry]) -> [LocalEntry] do
  match entries do
    | [] -> return rev_local_entries(lst: acc, out: [])
    | LocalEntry(name: n, index: idx, valtype: vt) :: rest ->
      if n == name then
        return rev_local_entries(lst: acc, out: LocalEntry(name: n, index: idx, valtype: new_vt) :: rest)
      end
      return widen_local_go(name, new_vt, entries: rest, acc: LocalEntry(name: n, index: idx, valtype: vt) :: acc)
  end
end

let rev_local_entries = fn (lst: [LocalEntry], out: [LocalEntry]) -> [LocalEntry] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_local_entries(lst: rest, out: x :: out)
  end
end

/** Find the data-segment offset+len for a string literal in the dedup-keyed `[StringEntry]` table; returns the packed `(offset << 32) | len` form, -1 if absent. */
export let lookup_string = fn (value: string, entries: [StringEntry]) -> i64 do
  match entries do
    | [] -> return -1
    | StringEntry(value: v, offset: off, slen: sl) :: rest ->
      if v == value then return (off * u32_radix) + sl end
      return lookup_string(value, entries: rest)
  end
end

/** O(1)-ish LirFunction lookup via internal_func_map.
 *  wasm-idx = import_count + pos.
 */
export let lookup_function_fast = fn (name: string, funcs: [LirFunction],
                                       map: &HashMap, import_count: i64) -> Option<LirFunction> do
  let widx = hmap.get_or(map, key: hash_name(name), default: -1)
  let pos = widx - import_count
  if pos < 0 then return None end
  match list.drop_n(xs: funcs, n: pos) do
    | [] -> return None
    | f :: _ -> return Some(val: f)
  end
end

/** Look up a `LirExternal` by Nexus-side name via linear scan over `exts`; `None` if absent. Used by intrinsic recognition where the externals list is short and a hashmap would overspecialize. */
export let lookup_external = fn (name: string, exts: [LirExternal]) -> Option<LirExternal> do
  match exts do
    | [] -> return None
    | e :: rest ->
      let LirExternal(name: n, wasm_module: _, wasm_name: _, params: _, ret_type: _, throw_row: _) = e
      if n == name then return Some(val: e) end
      return lookup_external(name, exts: rest)
  end
end

// ─── WASM encoding helpers ──────────────────────────────────────────────────

/** Emit a wasm name: ULEB length prefix followed by the UTF-8 bytes. */
export let emit_name = fn (buf: %ByteBuffer, name: string) -> %ByteBuffer do
  let slen = str.length(s: name)
  let %buf = bb.push_uleb128(%buf, val: slen)
  let %buf = bb.push_string(%buf, s: name)
  return %buf
end

/** Emit a wasm section: id byte, ULEB content-length, then the bytes of `content`. Frees `content` to keep the linear plumbing simple at every call site. */
export let emit_section = fn (buf: %ByteBuffer, id: i64, content: %ByteBuffer) -> %ByteBuffer do
  let content_len = bb.length(buf: &content)
  let %buf = bb.push_byte(%buf, byte: id)
  let %buf = bb.push_uleb128(%buf, val: content_len)
  let %buf = bb.push_buf(dst: %buf, src: &content)
  bb.free(buf: %content)
  return %buf
end

let emit_memarg = fn (buf: %ByteBuffer, align: i64, offset: i64) -> %ByteBuffer do
  let %buf = bb.push_uleb128(%buf, val: align)
  let %buf = bb.push_uleb128(%buf, val: offset)
  return %buf
end

/** Memarg for an i32 load/store: align = 2 (log2 of 4-byte natural alignment) + the caller-supplied offset. */
export let emit_memarg_i32 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return emit_memarg(%buf, align: 2, offset)
end

/** Memarg for an i64 load/store: align = 3 (log2 of 8-byte natural alignment). */
export let emit_memarg_i64 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return emit_memarg(%buf, align: 3, offset)
end

/** Memarg for a byte (i32.load8_u / i32.store8): align = 0, offset = 0. */
export let emit_memarg_i8 = fn (buf: %ByteBuffer) -> %ByteBuffer do
  return emit_memarg(%buf, align: 0, offset: 0)
end

/** Memarg for an f32 load/store: align = 2 (log2 of 4-byte natural alignment). */
export let emit_memarg_f32 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return emit_memarg(%buf, align: 2, offset)
end

/** Memarg for an f64 load/store: align = 3 (log2 of 8-byte natural alignment). */
export let emit_memarg_f64 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return emit_memarg(%buf, align: 3, offset)
end

/** v128 load/store memarg — 16-byte alignment expressed as log2 (= 4). The
 *  SIMD spec permits unaligned access (interpreted as a hint, not a trap), but
 *  emitting align=4 lets engines fast-path aligned cases.
 */
export let emit_memarg_v128 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return emit_memarg(%buf, align: 4, offset)
end

/** Check if name starts with "__closure_" (10 chars: _ _ c l o s u r e _)
 *  or "__inject_" (9 chars: _ _ i n j e c t _) — both are lifted functions
 *  that need to be declared in the function table so ref.func can target them.
 *  Also recognises the sched trampoline body, which the spawn intrinsic
 *  `ref.func`s into cont.new for each spawned fiber.
 */
export let is_closure_func = fn (name: string) -> bool do
  if is_inject_func(name) then return true end
  if is_sched_trampoline_func(name) then return true end
  if str.length(s: name) < 10 then return false end
  return str.char_code(s: name, idx: 0) == 95
      && str.char_code(s: name, idx: 1) == 95
      && str.char_code(s: name, idx: 2) == 99
      && str.char_code(s: name, idx: 3) == 108
      && str.char_code(s: name, idx: 4) == 111
      && str.char_code(s: name, idx: 5) == 115
      && str.char_code(s: name, idx: 6) == 117
      && str.char_code(s: name, idx: 7) == 114
      && str.char_code(s: name, idx: 8) == 101
      && str.char_code(s: name, idx: 9) == 95
end

/** True iff `name` ends with the sched-trampoline-body suffix; used by `collect_closure_arities` to force the arity-0 closure type into the type section. */
export let is_sched_trampoline_func = fn (name: string) -> bool do
  let suffix = "__nx_sched_trampoline_body"
  let slen = str.length(s: name)
  let suflen = str.length(s: suffix)
  if slen < suflen then return false end
  return str.substring(s: name, start: slen - suflen, len: suflen) == suffix
end

/** Check if name starts with "__inject_" (9 chars: _ _ i n j e c t _). */
let is_inject_func = fn (name: string) -> bool do
  if str.length(s: name) < 9 then return false end
  return str.char_code(s: name, idx: 0) == 95
      && str.char_code(s: name, idx: 1) == 95
      && str.char_code(s: name, idx: 2) == 105
      && str.char_code(s: name, idx: 3) == 110
      && str.char_code(s: name, idx: 4) == 106
      && str.char_code(s: name, idx: 5) == 101
      && str.char_code(s: name, idx: 6) == 99
      && str.char_code(s: name, idx: 7) == 116
      && str.char_code(s: name, idx: 8) == 95
end

// ─── HashMap-backed function index lookup ───────────────────────────────────

/** Compute the FNV-1a 64-bit hash of a name; the canonical key used by the function and local hashmaps. */
export let hash_name = fn (name: string) -> i64 do
  return fnv_hash_string(s: name, hash: fnv_basis)
end

/** Build a `name_hash -> wasm_func_index` hashmap from `entries`, preserving first-wins semantics that match the legacy linear `lookup_func` scan. */
export let build_func_map = fn (entries: [FuncEntry]) -> %HashMap do
  let %m = hmap.empty()
  return build_func_map_go(entries, map: %m)
end

let build_func_map_go = fn (entries: [FuncEntry], map: %HashMap) -> %HashMap do
  match entries do
    | [] -> return %map
    | FuncEntry(name: n, index: idx) :: rest ->
      // Preserve first-wins semantics (matches linear lookup_func behavior)
      let key = hash_name(name: n)
      let existing = hmap.get_or(&map, key, default: -1)
      let %map = if existing < 0 then
        hmap.put(%map, key, value: idx)
      else %map end
      return build_func_map_go(entries: rest, %map)
  end
end

/** Free a function-index hashmap built by `build_func_map`. Owns the linear handle, so calling it twice on the same map is a use-after-free. */
export let free_func_map = fn (map: %HashMap) -> unit do
  hmap.free(%map)
  return ()
end

/** O(1) function-name lookup via the hashmap from `build_func_map`; returns the wasm function index or -1 when absent. */
export let lookup_func_fast = fn (name: string, map: &HashMap) -> i64 do
  return hmap.get_or(map, key: hash_name(name), default: -1)
end

/** Per-function local-name map. Stores `(index << 32) | valtype` packed into
 *  one i64 so `ctx_lookup_local` returns both fields in a single hashmap
 *  fetch — replacing the previous double linear scan over `CodegenCtx.locals`
 * (mirrors the same EffectMap packing).
 */
export let build_local_map = fn (entries: [LocalEntry]) -> %HashMap do
  let %m = hmap.empty()
  return build_local_map_go(entries, map: %m)
end

let build_local_map_go = fn (entries: [LocalEntry], map: %HashMap) -> %HashMap do
  match entries do
    | [] -> return %map
    | LocalEntry(name: n, index: idx, valtype: vt) :: rest ->
      let %map = hmap.put(%map, key: hash_name(name: n), value: (idx * u32_radix) + vt)
      return build_local_map_go(entries: rest, %map)
  end
end
