/**
 * wasm/defs: WASM constants, helper types, and core utilities for codegen.
 *
 * Contains section IDs, value types, opcodes, type utilities,
 * FNV-1a hashing, lookup helpers, and WASM encoding primitives.
 * CodegenCtx and its ctx_* accessors live in src/backend/codegen/ctx/context.nx.
 */

import { ByteBuffer }, * as bb from "std:bytebuffer"
import { TypeExpr } from "src/types/type_expr.nx"
import { LirFunction, LirExpr, LirAtom, LirExternal } from "src/ir/lir/types.nx"
import * as str from "std:str"
import * as list from "std:list"

import { HashMap }, * as hmap from "std:hashmap"

import * as sections from "src/backend/wasm/defs/sections.nx"
import * as layout from "src/backend/wasm/defs/layout.nx"
import * as opcodes from "src/backend/wasm/defs/opcodes.nx"

// ─── Section IDs (re-exported from defs/sections.nx) ─────────────────────────

/** Type-section id (wasm spec table 5.5.2). */
export let sec_type = sections.sec_type
/** Import-section id (wasm spec table 5.5.2). */
export let sec_import = sections.sec_import
/** Function-section id (wasm spec table 5.5.2). */
export let sec_function = sections.sec_function
/** Memory-section id (wasm spec table 5.5.2). */
export let sec_memory = sections.sec_memory
/** Global-section id (wasm spec table 5.5.2). */
export let sec_global = sections.sec_global
/** Export-section id (wasm spec table 5.5.2). */
export let sec_export = sections.sec_export
/** Code-section id (wasm spec table 5.5.2). */
export let sec_code = sections.sec_code
/** Data-section id (wasm spec table 5.5.2). */
export let sec_data = sections.sec_data
/** Table-section id (wasm spec table 5.5.2). */
export let sec_table = sections.sec_table
/** Element-section id (wasm spec table 5.5.2). */
export let sec_element = sections.sec_element
/** Tag-section id (exception-handling proposal). */
export let sec_tag = sections.sec_tag
/** Custom-section id (0); also `name`, DWARF, target_features. */
export let sec_custom = sections.sec_custom

// ─── Memory layout constants (re-exported from defs/layout.nx) ───────────────

/** WASM linear-memory page size (64 KiB). */
export let wasm_page_size = layout.wasm_page_size
/** `wasm_page_size - 1`; page-rounding mask. */
export let wasm_page_mask = layout.wasm_page_mask
/** Floor on the merged module's initial memory pages (16 MiB). */
export let default_initial_pages = layout.default_initial_pages
/** 2^32: radix for packing two i32 fields into one i64. */
export let u32_radix = layout.u32_radix
/** FNV-1a 64-bit prime. */
export let fnv_prime = layout.fnv_prime
/** ULEB128 continuation-bit threshold (0x80). */
export let uleb_continuation_bit = layout.uleb_continuation_bit
/** Byte offset of the first coverage counter cell (= 17 * 65536). */
export let cov_counter_base = layout.cov_counter_base
/** Default initial memory min pages without coverage. */
export let cov_base_pages = layout.cov_base_pages
/** Extra memory pages reserved for coverage when `--coverage` is on. */
export let cov_extra_pages = layout.cov_extra_pages
/** Wasm-global index used as the legacy heap-base global (G0). */
export let heap_global_idx = layout.heap_global_idx
/** Linear-memory byte offset of the unified bump-pointer cell. */
export let heap_ptr_cell = layout.heap_ptr_cell
/** Backtrace ring-buffer base address (page 18 = 18 * 65536 = 1179648). */
export let bt_page_base = layout.bt_page_base
/** Byte offset within `bt_page_base` where the live monotonic depth counter lives (i64). */
export let bt_depth_offset = layout.bt_depth_offset
/** Byte offset where the at-throw snapshot of the depth lives (i64). */
export let bt_saved_depth_offset = layout.bt_saved_depth_offset
/** Byte offset where the 64-slot frame-name ring starts. */
export let bt_ring_offset = layout.bt_ring_offset
/** Capacity of the backtrace ring buffer in slots (64). */
export let bt_ring_capacity = layout.bt_ring_capacity
/** Inject-env hand-off cell (i64) for `with @k` lifted bodies; see layout.nx. */
export let inject_env_cell = layout.inject_env_cell
/** Handler-register base address: fixed i64 array of runtime-active handler
 *  ids, indexed by cap-index (slot byte offset = hreg_page_base + cap_idx*8). */
export let hreg_page_base = layout.hreg_page_base
/** Minimum initial memory pages for WASI preview3 (non-shared) mode. */
export let p3_base_pages = layout.p3_base_pages
/** FNV-1a 64-bit basis; seed value mixed against each byte. */
export let fnv_basis = layout.fnv_basis

