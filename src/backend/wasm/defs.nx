// ─── Emit helpers (re-exported from defs/opcodes.nx) ─────────────────────────

/** Emit `0xFE <sub_op> <align> <offset>` for an i32-width atomic memory op. */
export let emit_atomic_op32 = fn (buf: %ByteBuffer, sub_op: i64, offset: i64) -> %ByteBuffer do
  return opcodes.emit_atomic_op32(%buf, sub_op, offset)
end

/** Memarg for an i32 load/store: align = 2 + the caller-supplied offset. */
export let emit_memarg_i32 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return opcodes.emit_memarg_i32(%buf, offset)
end

/** Memarg for an i64 load/store: align = 3 (log2 of 8-byte natural alignment). */
export let emit_memarg_i64 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return opcodes.emit_memarg_i64(%buf, offset)
end

/** Memarg for a byte (i32.load8_u / i32.store8): align = 0, offset = 0. */
export let emit_memarg_i8 = fn (buf: %ByteBuffer) -> %ByteBuffer do
  return opcodes.emit_memarg_i8(%buf)
end

/** Memarg for an f32 load/store: align = 2 (log2 of 4-byte natural alignment). */
export let emit_memarg_f32 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return opcodes.emit_memarg_f32(%buf, offset)
end

/** Memarg for an f64 load/store: align = 3 (log2 of 8-byte natural alignment). */
export let emit_memarg_f64 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return opcodes.emit_memarg_f64(%buf, offset)
end

/** v128 load/store memarg — 16-byte alignment expressed as log2 (= 4). */
export let emit_memarg_v128 = fn (buf: %ByteBuffer, offset: i64) -> %ByteBuffer do
  return opcodes.emit_memarg_v128(%buf, offset)
end

