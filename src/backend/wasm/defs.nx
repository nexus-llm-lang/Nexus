// ─── Types ────────────────────────────────────────────────────────────────────

/** `(name, wasm_index, valtype)` for one wasm local; first-occurrence order, with `widen_local` overwriting `valtype` on conflict. */
export type LocalEntry = LocalEntry(name: string, index: i64, valtype: i64)
/** `(nexus_name, wasm_function_index)` for one entry in the internal- or external-func list; built by `build_*_func_entries`. */
export type FuncEntry = FuncEntry(name: string, index: i64)
/** A `(wasm export name, function index)` pair for extra module exports
 *  (currently only `wasi_thread_start`, the WASI-threads worker trampoline).
 */
export type ExportNameIdx = ExportNameIdx(name: string, index: i64)
/** `(value, byte_offset, byte_length)` for one entry in the wasm data segment laid out by `build_string_entries`. */
export type StringEntry = StringEntry(value: string, offset: i64, slen: i64)
/** `(arity, type_index)` pair from `build_closure_type_idx_list` — answers `arity -> canonical-closure-type-idx` in O(arities). */
export type ArityTypeIdx = ArityTypeIdx(arity: i64, type_idx: i64)

// ─── Type utilities ───────────────────────────────────────────────────────────

/** Strip outer `TyLinear` / `TyLazy` / `TyBorrow` wrappers and return the inner type; idempotent on already-bare types. */
export let peel_linear = fn (typ: TypeExpr) -> TypeExpr do
  match typ do
    | TyLinear(inner: t) | TyLazy(
      inner: t,
      require_row: _,
      throw_row: _
    ) | TyBorrow(inner: t) -> return peel_linear(typ: t)
    | _ -> return typ
  end
end

/** Map a Nexus type to its wasm valtype byte: bool/char/i32 → `vt_i32`, intlit/i64 → `vt_i64`, f32 → `vt_f32`, f64 → `vt_f64`, everything else → `vt_i64`. */
export let type_to_valtype = fn (typ: TypeExpr) -> i64 do
  match peel_linear(typ) do
    | TyI32 | TyBool | TyChar -> vt_i32
    | TyI64 | TyIntLit -> vt_i64
    | TyF32 -> vt_f32
    | TyF64 | TyFloatLit -> vt_f64
    | _ -> vt_i64
  end
end

/** True iff `typ` is exactly `TyUnit` (no `peel_linear` — linear `unit` still allocates a slot). */
export let is_unit = fn (typ: TypeExpr) -> bool do
  match typ do
    | TyUnit -> return true
    | _ -> return false
  end
end

// ─── FNV-1a hashing ───────────────────────────────────────────────────────────

let fnv_hash_byte = fn (hash: i64, byte: i64) -> i64 do
  return (hash ^ byte) * fnv_prime
end

let fnv_hash_string_go = fn (s: string, idx: i64, slen: i64, hash: i64) -> i64 do
  if idx >= slen then return hash
  else return fnv_hash_string_go(s, idx: idx + 1, slen,
                                  hash: fnv_hash_byte(hash, byte: str.char_code(s, idx)))
  end
end

let fnv_hash_string = fn (s: string, hash: i64) -> i64 do
  return fnv_hash_string_go(s, idx: 0, slen: str.length(s), hash)
end

/** Hash a constructor's `(name, arity)` pair into the i64 tag the codegen writes into the object header so pattern matches can compare tags directly. */
export let constructor_tag = fn (name: string, arity: i64) -> i64 do
  return fnv_hash_byte(hash: fnv_hash_string(s: name, hash: fnv_basis), byte: arity)
end

/** Hash a record's sorted-field-names list into the i64 tag the codegen writes into the record header; deterministic across modules so structurally-equal records share a tag. */
export let record_tag = fn (sorted_names: [ string ]) -> i64 do
  let shape = str.join(xs: sorted_names, sep: ",")
  let h = fnv_hash_string(s: shape, hash: fnv_hash_string(s: "rec", hash: fnv_basis))
  return fnv_hash_byte(hash: h, byte: list.length(xs: sorted_names))
end

// ─── LIR type projection ─────────────────────────────────────────────────────

/** Recover the static type of a `LirAtom`: variables carry their type explicitly; literals project to their canonical Nexus type. */
export let atom_type = fn (atom: LirAtom) -> TypeExpr do
  match atom do
    | LirAtomVar(name: _, typ: t) -> t
    | LirAtomInt(_) -> TyI64
    | LirAtomFloat(_) -> TyF64
    | LirAtomBool(_) -> TyBool
    | LirAtomChar(_) -> TyChar
    | LirAtomString(_) -> TyString
    | LirAtomUnit -> TyUnit
  end
end

/** Recover the static type of a `LirExpr` by reading the `typ:` field from whichever variant constructed it. */
export let expr_type = fn (expr: LirExpr) -> TypeExpr do
  match expr do
    | LirExprAtom(atom: a) -> atom_type(atom: a)
    | LirExprBinary(op: _, lhs: _, rhs: _, typ: t)
    | LirExprCall(func: _, args: _, typ: t)
    | LirExprTailCall(func: _, args: _, typ: t)
    | LirExprConstructor(name: _, args: _, typ: t)
    | LirExprRecord(fields: _, typ: t)
    | LirExprObjectTag(value: _, typ: t)
    | LirExprObjectField(value: _, index: _, typ: t)
    | LirExprRaise(value: _, typ: t)
    | LirExprForce(value: _, typ: t)
    | LirExprMakeClosure(func_name: _, captures: _, typ: t)
    | LirExprCallClosure(closure: _, args: _, typ: t)
    | LirExprSuspend(tag_name: _, payload: _, typ: t)
    | LirExprResume(cont: _, value: _, typ: t)
    | LirExprContNew(func_ref: _, typ: t)
    | LirExprInjectResume(body_fn: _, arm_fns: _, arm_tags: _, typ: t) -> t
  end
end

// ─── Local-entry helpers ──────────────────────────────────────────────────────

// Per-function name → packed (index<<32 | valtype) lookups are done in O(1)
// via `ctx_lookup_local` (HashMap built once in build_func_locals). The
// linear-scan `lookup_local*` helpers that previously walked `[LocalEntry]`
// were removed.

// Replace valtype for an existing local entry (widen i32 → i64 on conflict)
/** Replace the `valtype` of the entry named `name` in `entries` with `new_vt`; identity when `name` is absent. Used when a later `register_local` finds a name already bound to a narrower valtype. */
export let widen_local = fn (
  name: string,
  new_vt: i64,
  entries: [ LocalEntry ]
) -> [ LocalEntry ] do
  return widen_local_go(name, new_vt, entries, acc: [])
end

let widen_local_go = fn (
  name: string,
  new_vt: i64,
  entries: [ LocalEntry ],
  acc: [ LocalEntry ]
) -> [ LocalEntry ] do
  match entries do
    | [] -> return list.reverse(xs: acc)
    | LocalEntry(name: n, index: idx, valtype: vt) :: rest ->
      if n == name then
        return list.concat(
          xs: list.reverse(xs: acc),
          ys: LocalEntry(name: n, index: idx, valtype: new_vt) :: rest
        )
      end
      return widen_local_go(
        name,
        new_vt,
        entries: rest,
        acc: LocalEntry(name: n, index: idx, valtype: vt) :: acc
      )
  end
end

/** Find the data-segment offset+len for a string literal in the dedup-keyed `[StringEntry]` table; returns the packed `(offset << 32) | len` form, -1 if absent. */
export let lookup_string = fn (value: string, entries: [ StringEntry ]) -> i64 do
  match entries do
    | [] -> return -1
    | StringEntry(value: v, offset: off, slen: sl) :: rest ->
      if v == value then return (off * u32_radix) + sl end
      return lookup_string(value, entries: rest)
  end
end

/** O(1)-ish LirFunction lookup via internal_func_map.
 *  wasm-idx = import_count + pos.
 */
export let lookup_function_fast = fn (name: string, funcs: [ LirFunction ],
                                       map: &HashMap, import_count: i64) -> Option<LirFunction> do
  let widx = hmap.get_or(map, key: hash_name(name), default: -1)
  let pos = widx - import_count
  if pos < 0 then return None end
  match list.drop_n(xs: funcs, n: pos) do
    | [] -> return None
    | f :: _ -> return Some(val: f)
  end
end

/** Look up a `LirExternal` by Nexus-side name via linear scan over `exts`; `None` if absent. Used by intrinsic recognition where the externals list is short and a hashmap would overspecialize. */
export let lookup_external = fn (name: string, exts: [ LirExternal ]) -> Option<LirExternal> do
  match exts do
    | [] -> return None
    | e :: rest ->
      let LirExternal(
        name: n,
        wasm_module: _,
        wasm_name: _,
        params: _,
        ret_type: _,
        throw_row: _
      ) = e
      if n == name then return Some(val: e) end
      return lookup_external(name, exts: rest)
  end
end

// ─── ByteBuffer emit helpers ──────────────────────────────────────────────────

/** Emit a wasm name: ULEB length prefix followed by the UTF-8 bytes. */
export let emit_name = fn (buf: %ByteBuffer, name: string) -> %ByteBuffer do
  let slen = str.length(s: name)
  let %buf = bb.push_uleb128(%buf, val: slen)
  let %buf = bb.push_string(%buf, s: name)
  return %buf
end

/** Emit a wasm section: id byte, ULEB content-length, then the bytes of `content`. Frees `content` to keep the linear plumbing simple at every call site. */
export let emit_section = fn (buf: %ByteBuffer, id: i64, content: %ByteBuffer) -> %ByteBuffer do
  let content_len = bb.length(buf: &content)
  let %buf = bb.push_byte(%buf, byte: id)
  let %buf = bb.push_uleb128(%buf, val: content_len)
  let %buf = bb.push_buf(dst: %buf, src: &content)
  bb.free(buf: %content)
  return %buf
end

// ─── Name hashing and function/local maps ────────────────────────────────────

/** Compute the FNV-1a 64-bit hash of a name; the canonical key used by the function and local hashmaps. */
export let hash_name = fn (name: string) -> i64 do
  return fnv_hash_string(s: name, hash: fnv_basis)
end

/** Build a `name_hash -> wasm_func_index` hashmap from `entries`, preserving first-wins semantics that match the legacy linear `lookup_func` scan. */
export let build_func_map = fn (entries: [ FuncEntry ]) -> %HashMap do
  let %m = hmap.empty()
  return build_func_map_go(entries, map: %m)
end

let build_func_map_go = fn (entries: [ FuncEntry ], map: %HashMap) -> %HashMap do
  match entries do
    | [] -> return %map
    | FuncEntry(name: n, index: idx) :: rest ->
      // Preserve first-wins semantics (matches linear lookup_func behavior)
      let key = hash_name(name: n)
      let existing = hmap.get_or(&map, key, default: -1)
      let %map = if existing < 0 then
        hmap.put(%map, key, value: idx)
      else %map end
      return build_func_map_go(entries: rest, %map)
  end
end

/** Free a function-index hashmap built by `build_func_map`. Owns the linear handle, so calling it twice on the same map is a use-after-free. */
export let free_func_map = fn (map: %HashMap) -> unit do
  hmap.free(%map)
  return ()
end

/** O(1) function-name lookup via the hashmap from `build_func_map`; returns the wasm function index or -1 when absent. */
export let lookup_func_fast = fn (name: string, map: &HashMap) -> i64 do
  return hmap.get_or(map, key: hash_name(name), default: -1)
end

/** Per-function local-name map. Stores `(index << 32) | valtype` packed into
 *  one i64 so `ctx_lookup_local` returns both fields in a single hashmap
 *  fetch — replacing the previous double linear scan over `CodegenCtx.locals`
 * (mirrors the same EffectMap packing).
 */
export let build_local_map = fn (entries: [ LocalEntry ]) -> %HashMap do
  let %m = hmap.empty()
  return build_local_map_go(entries, map: %m)
end

let build_local_map_go = fn (entries: [ LocalEntry ], map: %HashMap) -> %HashMap do
  match entries do
    | [] -> return %map
    | LocalEntry(name: n, index: idx, valtype: vt) :: rest ->
      let %map = hmap.put(%map, key: hash_name(name: n), value: (idx * u32_radix) + vt)
      return build_local_map_go(entries: rest, %map)
  end
end

// ─── Closure/inject function name predicates ──────────────────────────────────

/** Check if name starts with "__closure_" (10 chars: _ _ c l o s u r e _)
 *  or "__inject_" (9 chars: _ _ i n j e c t _) — both are lifted functions
 *  that need to be declared in the function table so ref.func can target them.
 *  Also recognises the sched trampoline body, which the spawn intrinsic
 *  `ref.func`s into cont.new for each spawned fiber.
 */
export let is_closure_func = fn (name: string) -> bool do
  if is_inject_func(name) then return true end
  if is_sched_trampoline_func(name) then return true end
  if str.length(s: name) < 10 then return false end
  return str.char_code(s: name, idx: 0) == 95
      && str.char_code(s: name, idx: 1) == 95
      && str.char_code(s: name, idx: 2) == 99
      && str.char_code(s: name, idx: 3) == 108
      && str.char_code(s: name, idx: 4) == 111
      && str.char_code(s: name, idx: 5) == 115
      && str.char_code(s: name, idx: 6) == 117
      && str.char_code(s: name, idx: 7) == 114
      && str.char_code(s: name, idx: 8) == 101
      && str.char_code(s: name, idx: 9) == 95
end

/** True iff `name` ends with the sched-trampoline-body suffix; used by `collect_closure_arities` to force the arity-0 closure type into the type section. */
export let is_sched_trampoline_func = fn (name: string) -> bool do
  let suffix = "__nx_sched_trampoline_body"
  let slen = str.length(s: name)
  let suflen = str.length(s: suffix)
  if slen < suflen then return false end
  return str.substring(s: name, start: slen - suflen, len: suflen) == suffix
end

/** Check if name starts with "__inject_" (9 chars: _ _ i n j e c t _). */
let is_inject_func = fn (name: string) -> bool do
  if str.length(s: name) < 9 then return false end
  return str.char_code(s: name, idx: 0) == 95
      && str.char_code(s: name, idx: 1) == 95
      && str.char_code(s: name, idx: 2) == 105
      && str.char_code(s: name, idx: 3) == 110
      && str.char_code(s: name, idx: 4) == 106
      && str.char_code(s: name, idx: 5) == 101
      && str.char_code(s: name, idx: 6) == 99
      && str.char_code(s: name, idx: 7) == 116
      && str.char_code(s: name, idx: 8) == 95
end
