export let p2_build_fs_canon_lower = fn (has_fs: bool, base: %ByteBuffer) -> %ByteBuffer do
  if has_fs then
    // Sec 38d: cf9=open-at → core func 10
    let %s38d = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(
                                  buf: bb.empty(),
                                  bytes: [ 1, 1, 0, 9, 2, 3, 0, 4, 4 ]
                                ))
    let %o = bb.push_buf(dst: %base, src: &s38d)
    bb.free(buf: %s38d)
    // Sec 38e: cf10=read → core func 11
    let %s38e = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(
                                  buf: bb.empty(),
                                  bytes: [ 1, 1, 0, 10, 2, 3, 0, 4, 4 ]
                                ))
    let %o = bb.push_buf(dst: %o, src: &s38e)
    bb.free(buf: %s38e)
    // Sec 38f: cf11=write → core func 12
    let %s38f = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(
                                  buf: bb.empty(),
                                  bytes: [ 1, 1, 0, 11, 2, 3, 0, 4, 4 ]
                                ))
    let %o = bb.push_buf(dst: %o, src: &s38f)
    bb.free(buf: %s38f)
    // Sec 38g: cf12=create-directory-at → core func 13
    let %s38g = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(
                                  buf: bb.empty(),
                                  bytes: [ 1, 1, 0, 12, 2, 3, 0, 4, 4 ]
                                ))
    let %o = bb.push_buf(dst: %o, src: &s38g)
    bb.free(buf: %s38g)
    // Sec 38h: cf13=unlink-file-at → core func 14
    let %s38h = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(
                                  buf: bb.empty(),
                                  bytes: [ 1, 1, 0, 13, 2, 3, 0, 4, 4 ]
                                ))
    let %o = bb.push_buf(dst: %o, src: &s38h)
    bb.free(buf: %s38h)
    // Sec 38i: cf16=get-directories → core func 15
    let %s38i = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(
                                  buf: bb.empty(),
                                  bytes: [ 1, 1, 0, 16, 2, 3, 0, 4, 4 ]
                                ))
    let %o = bb.push_buf(dst: %o, src: &s38i)
    bb.free(buf: %s38i)
    // Sec 38j: cf14=read-directory → core func 16 (memory only)
    let %s38j = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(
                                  buf: bb.empty(),
                                  bytes: [ 1, 1, 0, 14, 1, 3, 0 ]
                                ))
    let %o = bb.push_buf(dst: %o, src: &s38j)
    bb.free(buf: %s38j)
    // Sec 38k: cf15=read-directory-entry → core func 17 (memory + realloc for string output)
    let %s38k = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(
                                  buf: bb.empty(),
                                  bytes: [ 1, 1, 0, 15, 2, 3, 0, 4, 4 ]
                                ))
    let %o = bb.push_buf(dst: %o, src: &s38k)
    bb.free(buf: %s38k)
    return %o
  end
  return %base
end
