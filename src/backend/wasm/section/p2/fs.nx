/**
 * wasm/section/p2/fs: WASI preview2 filesystem component sections.
 *
 * Builds the wasi:filesystem component import sections, the p2fs core module
 * (wasi-shim bridge for filesystem operations), and the canon-lower wrappers
 * for the filesystem host functions.
 */

import { ByteBuffer }, * as bb from "std:bytebuffer"
