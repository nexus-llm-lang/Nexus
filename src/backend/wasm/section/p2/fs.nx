import { cm_wrap_section } from "src/backend/wasm/section/cm_common.nx"

export let p2_build_fs_sections = fn (has_fs: bool) -> %ByteBuffer do
  let %base = bb.empty()
  let %out = p2_build_fs_sections_inner(has_fs: has_fs, base: %base)
  return %out
end

