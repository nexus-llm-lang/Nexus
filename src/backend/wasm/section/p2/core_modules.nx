/**
 * wasm/section/p2/core_modules: WASI preview2 core module assembly.
 *
 * Assembles all core modules (stub, adapter, p2ext, nexus, optionally p2fs/p2net/p2sock)
 * into the component binary.  Delegates to per-subsystem builders.
 */

import { ByteBuffer }, * as bb from "std:bytebuffer"
import * as wdefs from "src/backend/wasm/defs.nx"
import { cm_wrap_section } from "src/backend/wasm/section/cm_common.nx"
import { p2_build_adapter_module } from "src/backend/wasm/section/p2/adapter.nx"
import { p2_build_p2net_module } from "src/backend/wasm/section/p2/http.nx"
import { p2_build_p2fs_module } from "src/backend/wasm/section/p2/fs.nx"
import { p2_build_p2sock_module } from "src/backend/wasm/section/p2/socket.nx"

export let p2_build_core_modules = fn (
  core_wasm: %ByteBuffer,
  has_fs: bool,
  has_net: bool,
  has_server: bool
) -> %ByteBuffer do
  let %out = bb.empty()

  // Sec 22: core module 0 = stub (exports non-shared memory 256/65536 and cabi_realloc bump allocator).
  // Non-shared memory is required for canon lower (component model canonical ABI rejects shared
  // memory). cabi_realloc is a bump allocator used by canon lower of get-random-bytes and
  // [method]input-stream.blocking-read which return list<u8> via retptr.
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_core_module, content: bb.push_bytes(buf: bb.empty(), bytes: [
    0, 97, 115, 109, 1, 0, 0, 0, 1, 12, 2, 96, 4, 127, 127, 127, 127, 1, 127, 96, 0, 0, 3, 3, 2,
    0, 1, 5, 7, 1, 1, 128, 2, 128, 128, 4, 6, 8, 1, 127, 1, 65, 128, 128, 4, 11, 7, 34, 3, 6, 109,
    101, 109, 111, 114, 121, 2, 0, 12, 99, 97, 98, 105, 95, 114, 101, 97, 108, 108, 111, 99, 0, 0,
    6, 95, 115, 116, 97, 114, 116, 0, 1, 10, 80, 2, 75, 1, 2, 127, 32, 3, 69, 4, 64, 65, 0, 15,
    11, 35, 0, 32, 2, 65, 1, 107, 106, 32, 2, 65, 1, 107, 65, 127, 115, 113, 34, 4, 32, 3, 106,
    36, 0, 32, 0, 65, 0, 71, 32, 1, 65, 0, 75, 113, 4, 64, 32, 1, 32, 3, 32, 1, 32, 3, 73, 27,
    33, 5, 32, 4, 32, 0, 32, 5, 252, 10, 0, 0, 11, 32, 4, 11, 2, 0, 11 ]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 23: core module 1 = adapter (wasi_snapshot_preview1 shim).
  // has_fs=true: 19 imports (p2fs.prestat-get/prestat-dir-name/fs-open-at/fs-read/fs-close).
  // has_fs=false: 14 imports, filesystem ops return EBADF.
  let %out = p2_build_adapter_module(
    has_fs: has_fs,
    has_net: has_net,
    has_server: has_server,
    base: %out
  )

  // Sec 27: core module 2 = p2ext (bridges canon-lowered p2 funcs to preview1 adapter).
  // Imports: env.memory, env.cabi_realloc, p2ext_raw.exit, p2ext_raw.now,
  //          p2rand.get-random-bytes, p2stdin.get-stdin, p2stdin.blocking-read,
  //          p2env.get-environment, p2env.get-arguments.
  // Exports: proc-exit, now, get-random-bytes (real; copies from list<u8> retptr),
  //          env-get-count, env-get-sizes, env-get (real; marshals from list<tuple<str,str>>),
  //          args-get-count, args-get-sizes, args-get (real; marshals from list<string>),
  //          get-stdin, stdin-read (real blocking-read).
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_core_module, content: bb.push_bytes(buf: bb.empty(), bytes: [
    0, 97, 115, 109, 1, 0, 0, 0, 1, 38, 7, 96, 4, 127, 127, 127, 127, 1, 127, 96,
    1, 127, 0, 96, 0, 1, 126, 96, 2, 126, 127, 0, 96, 0, 1, 127, 96, 3, 127, 126,
    127, 0, 96, 2, 127, 127, 1, 127, 2, 183, 1, 9, 3, 101, 110, 118, 6, 109, 101, 109,
    111, 114, 121, 2, 0, 1, 3, 101, 110, 118, 12, 99, 97, 98, 105, 95, 114, 101, 97, 108,
    108, 111, 99, 0, 0, 9, 112, 50, 101, 120, 116, 95, 114, 97, 119, 4, 101, 120, 105, 116,
    0, 1, 9, 112, 50, 101, 120, 116, 95, 114, 97, 119, 3, 110, 111, 119, 0, 2, 6, 112,
    50, 114, 97, 110, 100, 16, 103, 101, 116, 45, 114, 97, 110, 100, 111, 109, 45, 98, 121, 116,
    101, 115, 0, 3, 7, 112, 50, 115, 116, 100, 105, 110, 9, 103, 101, 116, 45, 115, 116, 100,
    105, 110, 0, 4, 7, 112, 50, 115, 116, 100, 105, 110, 13, 98, 108, 111, 99, 107, 105, 110,
    103, 45, 114, 101, 97, 100, 0, 5, 5, 112, 50, 101, 110, 118, 15, 103, 101, 116, 45, 101,
    110, 118, 105, 114, 111, 110, 109, 101, 110, 116, 0, 1, 5, 112, 50, 101, 110, 118, 13, 103,
    101, 116, 45, 97, 114, 103, 117, 109, 101, 110, 116, 115, 0, 1, 3, 12, 11, 1, 2, 6,
    4, 6, 6, 4, 6, 6, 4, 6, 7, 150, 1, 11, 9, 112, 114, 111, 99, 45, 101, 120,
    105, 116, 0, 8, 3, 110, 111, 119, 0, 9, 16, 103, 101, 116, 45, 114, 97, 110, 100, 111,
    109, 45, 98, 121, 116, 101, 115, 0, 10, 13, 101, 110, 118, 45, 103, 101, 116, 45, 99, 111,
    117, 110, 116, 0, 11, 13, 101, 110, 118, 45, 103, 101, 116, 45, 115, 105, 122, 101, 115, 0,
    12, 7, 101, 110, 118, 45, 103, 101, 116, 0, 13, 14, 97, 114, 103, 115, 45, 103, 101, 116,
    45, 99, 111, 117, 110, 116, 0, 14, 14, 97, 114, 103, 115, 45, 103, 101, 116, 45, 115, 105,
    122, 101, 115, 0, 15, 8, 97, 114, 103, 115, 45, 103, 101, 116, 0, 16, 9, 103, 101, 116,
    45, 115, 116, 100, 105, 110, 0, 17, 10, 115, 116, 100, 105, 110, 45, 114, 101, 97, 100, 0,
    18, 10, 199, 6, 11, 9, 0, 32, 0, 65, 0, 71, 16, 1, 11, 4, 0, 16, 2, 11,
    66, 1, 4, 127, 65, 0, 65, 0, 65, 4, 65, 8, 16, 0, 33, 2, 32, 1, 173, 32,
    2, 16, 3, 32, 2, 40, 2, 0, 33, 3, 32, 2, 65, 4, 106, 40, 2, 0, 33, 4,
    32, 4, 32, 1, 34, 5, 32, 4, 32, 5, 73, 27, 33, 5, 32, 0, 32, 3, 32, 5,
    252, 10, 0, 0, 65, 0, 11, 26, 1, 1, 127, 65, 0, 65, 0, 65, 4, 65, 8, 16,
    0, 34, 0, 16, 6, 32, 0, 65, 4, 106, 40, 2, 0, 11, 121, 1, 6, 127, 65, 0,
    65, 0, 65, 4, 65, 8, 16, 0, 33, 2, 32, 2, 16, 6, 32, 2, 40, 2, 0, 33,
    3, 32, 2, 65, 4, 106, 40, 2, 0, 33, 4, 32, 0, 32, 4, 54, 2, 0, 65, 0,
    33, 6, 65, 0, 33, 5, 2, 64, 3, 64, 32, 5, 32, 4, 79, 13, 1, 32, 3, 32,
    5, 65, 16, 108, 106, 33, 7, 32, 6, 32, 7, 65, 4, 106, 40, 2, 0, 106, 65, 1,
    106, 32, 7, 65, 12, 106, 40, 2, 0, 106, 65, 1, 106, 33, 6, 32, 5, 65, 1, 106,
    33, 5, 12, 0, 11, 11, 32, 1, 32, 6, 54, 2, 0, 65, 0, 11, 196, 1, 1, 11,
    127, 65, 0, 65, 0, 65, 4, 65, 8, 16, 0, 33, 2, 32, 2, 16, 6, 32, 2, 40,
    2, 0, 33, 3, 32, 2, 65, 4, 106, 40, 2, 0, 33, 4, 32, 1, 33, 6, 32, 0,
    33, 7, 65, 0, 33, 5, 2, 64, 3, 64, 32, 5, 32, 4, 79, 13, 1, 32, 3, 32,
    5, 65, 16, 108, 106, 33, 8, 32, 8, 40, 2, 0, 33, 9, 32, 8, 65, 4, 106, 40,
    2, 0, 33, 10, 32, 8, 65, 8, 106, 40, 2, 0, 33, 11, 32, 8, 65, 12, 106, 40,
    2, 0, 33, 12, 32, 7, 32, 6, 54, 2, 0, 32, 7, 65, 4, 106, 33, 7, 32, 6,
    32, 9, 32, 10, 252, 10, 0, 0, 32, 6, 32, 10, 106, 33, 6, 32, 6, 65, 61, 58,
    0, 0, 32, 6, 65, 1, 106, 33, 6, 32, 6, 32, 11, 32, 12, 252, 10, 0, 0, 32,
    6, 32, 12, 106, 33, 6, 32, 6, 65, 0, 58, 0, 0, 32, 6, 65, 1, 106, 33, 6,
    32, 5, 65, 1, 106, 33, 5, 12, 0, 11, 11, 65, 0, 11, 26, 1, 1, 127, 65, 0,
    65, 0, 65, 4, 65, 8, 16, 0, 34, 0, 16, 7, 32, 0, 65, 4, 106, 40, 2, 0,
    11, 109, 1, 6, 127, 65, 0, 65, 0, 65, 4, 65, 8, 16, 0, 33, 2, 32, 2, 16,
    7, 32, 2, 40, 2, 0, 33, 3, 32, 2, 65, 4, 106, 40, 2, 0, 33, 4, 32, 0,
    32, 4, 54, 2, 0, 65, 0, 33, 6, 65, 0, 33, 5, 2, 64, 3, 64, 32, 5, 32,
    4, 79, 13, 1, 32, 3, 32, 5, 65, 8, 108, 106, 33, 7, 32, 6, 32, 7, 65, 4,
    106, 40, 2, 0, 106, 65, 1, 106, 33, 6, 32, 5, 65, 1, 106, 33, 5, 12, 0, 11,
    11, 32, 1, 32, 6, 54, 2, 0, 65, 0, 11, 145, 1, 1, 9, 127, 65, 0, 65, 0,
    65, 4, 65, 8, 16, 0, 33, 2, 32, 2, 16, 7, 32, 2, 40, 2, 0, 33, 3, 32,
    2, 65, 4, 106, 40, 2, 0, 33, 4, 32, 1, 33, 6, 32, 0, 33, 7, 65, 0, 33,
    5, 2, 64, 3, 64, 32, 5, 32, 4, 79, 13, 1, 32, 3, 32, 5, 65, 8, 108, 106,
    33, 8, 32, 8, 40, 2, 0, 33, 9, 32, 8, 65, 4, 106, 40, 2, 0, 33, 10, 32,
    7, 32, 6, 54, 2, 0, 32, 7, 65, 4, 106, 33, 7, 32, 6, 32, 9, 32, 10, 252,
    10, 0, 0, 32, 6, 32, 10, 106, 33, 6, 32, 6, 65, 0, 58, 0, 0, 32, 6, 65,
    1, 106, 33, 6, 32, 5, 65, 1, 106, 33, 5, 12, 0, 11, 11, 65, 0, 11, 4, 0,
    16, 4, 11, 119, 1, 6, 127, 16, 4, 33, 2, 65, 0, 65, 0, 65, 4, 65, 12, 16,
    0, 33, 3, 32, 2, 32, 1, 173, 32, 3, 16, 5, 32, 3, 40, 2, 0, 33, 4, 32,
    4, 69, 4, 64, 32, 3, 65, 4, 106, 40, 2, 0, 33, 5, 32, 3, 65, 8, 106, 40,
    2, 0, 33, 6, 32, 6, 32, 1, 34, 7, 32, 6, 32, 7, 73, 27, 33, 7, 32, 0,
    32, 5, 32, 7, 252, 10, 0, 0, 32, 5, 32, 6, 65, 1, 65, 0, 16, 0, 26, 11,
    32, 3, 65, 12, 65, 4, 65, 0, 16, 0, 26, 32, 4, 69, 4, 127, 32, 7, 5, 65,
    0, 11, 11 ]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 28: core module 3 = nexus core_wasm (dynamic)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_core_module, content: %core_wasm)
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 28b: core module 4 = p2fs (fd→descriptor handle table) — only when has_fs.
  let %out = p2_build_p2fs_module(has_fs: has_fs, base: %out)
  // Sec 28c: core module 4 (no-fs) or 5 (has-fs) = p2net — only when has_net.
  let %out = p2_build_p2net_module(has_net: has_net, base: %out)
  // Sec 28d: core module 5 (no-fs) or 6 (has-fs) = p2sock_bridge — only when has_server.
  let %out = p2_build_p2sock_module(has_server: has_server, base: %out)
  return %out
end
