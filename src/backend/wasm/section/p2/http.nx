  let %o = bb.push_buf(buf: %o, src: &s6)
  bb.free(buf: %s6)
  // cf24: inbody.stream-it → 2 opts mem0+realloc4 (result error-code has Option<String>)
  let %s7 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(
                               buf: bb.empty(),
                               bytes: [ 1, 1, 0, 24, 2, 3, 0, 4, 4 ]
                             ))
  let %o = bb.push_buf(buf: %o, src: &s7)
  bb.free(buf: %s7)
  // cf25: handle → 2 opts mem0+realloc4 (result err-code has Option<String>)
  let %s8 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
