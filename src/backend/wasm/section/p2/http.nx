export let p2_build_p2net_module = fn (has_net: bool, base: %ByteBuffer) -> %ByteBuffer do
  if has_net then
    // Sec 28c: core module 4 (no-fs) or 5 (has-fs) = p2net bridge.
    // Imports: env.memory, env.cabi_realloc, p2http.* (13 http funcs).
    // Exports: http-request (i32x8->i64) for wasi_snapshot_preview1 shim.
    // Canonical ABI types (derived from wasm-tools validation):
    //   cabi_realloc(i32,i32,i32,i32)->(i32)
    //   pollable-block(i32)->()
    //   set-method/authority/path-with-query(i32,i32,i32,i32,i32)->() [self, disc/has, ptr, len, retptr]
    //   set-scheme(i32,i32,i32,i32,i32,i32)->() [self, disc, has_str, ptr, len, retptr]
    //   future-inresp-get/inresp-consume/inbody-stream-it(i32,i32)->() [self, retptr]
    //   handle(i32,i32,i32,i32)->() [req, has_opts, opts, retptr]
    //   future-subscribe(i32)->(i32)
    //   http-request(i32x8)->(i64) [method*2, url*2, headers*2, body*2]
    //   ctor-fields()->(i32)
    //   ctor-outreq(i32)->(i32) [fields = own<wasi:http/types.fields>]
    //   blocking-read(i32,i64,i32)->() [stream, len:u64, retptr]
    let %snet = cm_wrap_section(section_id: wdefs.cm_sec_core_module, content: bb.push_bytes(buf: bb.empty(), bytes: [
      0, 97, 115, 109, 1, 0, 0, 0, 1, 74, 11, 96, 4, 127, 127, 127,
      127, 1, 127, 96, 1, 127, 0, 96, 4, 127, 127, 127, 127, 1, 127, 96,
      5, 127, 127, 127, 127, 127, 1, 127, 96, 2, 127, 127, 0, 96, 4, 127,
      127, 127, 127, 0, 96, 1, 127, 1, 127, 96, 8, 127, 127, 127, 127, 127,
      127, 127, 127, 1, 126, 96, 0, 1, 127, 96, 1, 127, 1, 127, 96, 3,
      127, 126, 127, 0, 2, 207, 2, 15, 3, 101, 110, 118, 6, 109, 101, 109,
      111, 114, 121, 2, 0, 128, 2, 3, 101, 110, 118, 12, 99, 97, 98, 105,
      95, 114, 101, 97, 108, 108, 111, 99, 0, 0, 6, 112, 50, 104, 116, 116,
      112, 14, 112, 111, 108, 108, 97, 98, 108, 101, 45, 98, 108, 111, 99, 107,
      0, 1, 6, 112, 50, 104, 116, 116, 112, 10, 115, 101, 116, 45, 109, 101,
