/**
 * wasm/section/p2/http: WASI preview2 HTTP component sections and canon lower.
 *
 * Builds the wasi:http/outgoing-handler component import sections and the
 * canon-lower wrappers for the HTTP host functions.
 */

import { ByteBuffer }, * as bb from "std:bytebuffer"
import * as wdefs from "src/backend/wasm/defs.nx"
import { cm_wrap_section, cm_emit_func_export_entry } from "src/backend/wasm/section/cm_common.nx"

/** Build p2http FromExports core instance for has_net builds.
 *  Maps canonical-lowered http core funcs to p2net-expected import names.
 *  For no-fs: core funcs cf10..21, cf6 (blocking-read reuse).
 *  For has-fs: core funcs cf16..27, cf6.
 */
export let build_p2http_from_exports = fn (has_fs: bool) -> %ByteBuffer do
  // Base offsets: no_fs_base=10, has_fs_base=18
  // (fs adds 8 comp funcs 9-16, so http starts at core 18 in hasfs)
  // Mapping (short names matching p2net module imports, by offset from base):
  // base+0 = pollable-block   (cf: pollable.block)
  // base+1 = set-method       (cf: outgoing-request.set-method)
  // base+2 = set-scheme       (cf: outgoing-request.set-scheme)
  // base+3 = set-authority    (cf: outgoing-request.set-authority)
  // base+4 = set-path-with-query (cf: outgoing-request.set-path-with-query)
  // base+5 = future-inresp-get   (cf: future-incoming-response.get)
  // base+6 = inresp-consume   (cf: incoming-response.consume)
  // base+7 = inbody-stream-it (cf: incoming-body.stream-it)
  // base+8 = handle           (cf: handle)
  // base+9 = ctor-fields      (cf: [constructor]fields)
  // base+10 = ctor-outreq     (cf: [constructor]outgoing-request)
  // base+11 = future-subscribe (cf: future-incoming-response.subscribe)
  // cf6 = blocking-read (always core func 6, same in both no-fs and has-fs)
  let base = if has_fs then 18 else 10 end
  let %out = bb.push_bytes(buf: bb.empty(), bytes: [ 1, 13 ])
  let %out = cm_emit_func_export_entry(buf: %out, name: "pollable-block", idx: base + 0)
  let %out = cm_emit_func_export_entry(buf: %out, name: "set-method", idx: base + 1)
  let %out = cm_emit_func_export_entry(buf: %out, name: "set-scheme", idx: base + 2)
  let %out = cm_emit_func_export_entry(buf: %out, name: "set-authority", idx: base + 3)
  let %out = cm_emit_func_export_entry(buf: %out, name: "set-path-with-query", idx: base + 4)
  let %out = cm_emit_func_export_entry(buf: %out, name: "future-inresp-get", idx: base + 5)
  let %out = cm_emit_func_export_entry(buf: %out, name: "inresp-consume", idx: base + 6)
  let %out = cm_emit_func_export_entry(buf: %out, name: "inbody-stream-it", idx: base + 7)
  let %out = cm_emit_func_export_entry(buf: %out, name: "handle", idx: base + 8)
  let %out = cm_emit_func_export_entry(buf: %out, name: "ctor-fields", idx: base + 9)
  let %out = cm_emit_func_export_entry(buf: %out, name: "ctor-outreq", idx: base + 10)
  let %out = cm_emit_func_export_entry(buf: %out, name: "future-subscribe", idx: base + 11)
  return cm_emit_func_export_entry(buf: %out, name: "blocking-read", idx: 6)
end

/** Build wasi:io/poll + wasi:http/types + wasi:http/outgoing-handler component sections.
 *  Returns empty buffer when has_net=false.
 *  When has_net=true:
 *    has_fs=false: adds types 11-18, instances 8-10, comp funcs 9-20 (12 http funcs).
 *    has_fs=true:  adds types 15-22, instances 10-12, comp funcs 15-26 (12 http funcs).
 *  All type/instance indices are patched to match our component's context.
 */
export let p2_build_http_sections = fn (has_fs: bool, has_net: bool) -> %ByteBuffer do
  if has_net then
    // io/poll type section content is the same regardless of has_fs (self-contained).
    let %out = bb.empty()
    let %s = cm_wrap_section(section_id: wdefs.cm_sec_type, content: bb.push_bytes(buf: bb.empty(), bytes: [
      1, 66, 4, 4, 0, 8, 112, 111, 108, 108, 97, 98, 108, 101, 3, 1,
      1, 104, 0, 1, 64, 1, 4, 115, 101, 108, 102, 1, 1, 0, 4, 0,
      22, 91, 109, 101, 116, 104, 111, 100, 93, 112, 111, 108, 108, 97, 98, 108,
      101, 46, 98, 108, 111, 99, 107, 1, 2 ]))
    let %out = bb.push_buf(buf: %out, src: &s)
    bb.free(buf: %s)
    // io/poll import: type idx differs by has_fs.
    // no-fs: io/poll=type11, io/poll inst=8; has-fs: io/poll=type15, io/poll inst=10.
    let %s = if has_fs then
      cm_wrap_section(section_id: wdefs.cm_sec_import, content: bb.push_bytes(buf: bb.empty(), bytes: [
        1, 0, 18, 119, 97, 115, 105, 58, 105, 111, 47, 112, 111, 108, 108, 64, 48, 46, 50, 46, 48, 5, 15 ]))
    else
      cm_wrap_section(section_id: wdefs.cm_sec_import, content: bb.push_bytes(buf: bb.empty(), bytes: [
        1, 0, 18, 119, 97, 115, 105, 58, 105, 111, 47, 112, 111, 108, 108, 64, 48, 46, 50, 46, 48, 5, 11 ]))
    end
    let %out = bb.push_buf(buf: %out, src: &s)
    bb.free(buf: %s)
    // pollable alias from io/poll instance.
    // no-fs: inst8, pollable=type12; has-fs: inst10, pollable=type16.
    let %s = if has_fs then
      cm_wrap_section(section_id: wdefs.cm_sec_alias, content: bb.push_bytes(buf: bb.empty(), bytes: [
        1, 3, 0, 10, 8, 112, 111, 108, 108, 97, 98, 108, 101 ]))
    else
      cm_wrap_section(section_id: wdefs.cm_sec_alias, content: bb.push_bytes(buf: bb.empty(), bytes: [
        1, 3, 0, 8, 8, 112, 111, 108, 108, 97, 98, 108, 101 ]))
    end
    let %out = bb.push_buf(buf: %out, src: &s)
    bb.free(buf: %s)
    // http/types type section: 2247 bytes, self-contained instance type with func exports.
    // 73 entries: outgoing-request SubResource, pollable Alias+Eq (to io/poll pollable),
    //   TypeDefs (Option, Record, Variant, Borrow, Own, Result), Eq exports, and
    //   10 func exports ([constructor]outgoing-request, [method]outgoing-request.set-method,
    //   set-scheme, set-authority, set-path-with-query, [method]future-incoming-response.get,
    //   [method]incoming-response.consume, [method]incoming-body.stream,
    //   [constructor]fields, [method]future-incoming-response.subscribe).
    // pollable must alias the io/poll pollable (outer type), NOT be a fresh SubResource.
    // no-fs: outer_pollable_idx=12; has-fs: outer_pollable_idx=16.
    let %s = if has_fs then
      cm_wrap_section(section_id: wdefs.cm_sec_type, content: bb.push_bytes(buf: bb.empty(), bytes: [
        1, 66, 77, 4, 0, 16, 111, 117, 116, 103, 111, 105, 110, 103, 45, 114,
        101, 113, 117, 101, 115, 116, 3, 1, 4, 0, 15, 114, 101, 113, 117, 101,
        115, 116, 45, 111, 112, 116, 105, 111, 110, 115, 3, 1, 4, 0, 24, 102,
