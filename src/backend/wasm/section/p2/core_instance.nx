/**
 * wasm/section/p2/core_instance: WASI preview2 core instance section builder.
 *
 * Builds the core instance section that instantiates the stub, adapter, p2ext,
 * and optionally p2fs/p2net/p2sock modules, connecting them via FromExports
 * and Instantiate entries.
 */

import { ByteBuffer }, * as bb from "std:bytebuffer"
import * as str from "std:str"
import * as wdefs from "src/backend/wasm/defs.nx"
import { cm_emit_func_export_entry } from "src/backend/wasm/section/cm_common.nx"
import { build_p2http_from_exports } from "src/backend/wasm/section/p2/http.nx"
import { build_p2sock_raw_from_exports } from "src/backend/wasm/section/p2/socket.nx"

/** Build the p2 core-instance section that creates instances (indices 1-N):
 *  inst 1: Instantiate(module=0=stub, 0 args)
 *  inst 2: FromExports { "get-stdout"=func_0, "write"=func_1 }                     <- p2
 *  inst 3: FromExports { "exit"=func_2, "now"=func_3 }                             <- p2ext_raw
 *  inst 4: FromExports { "get-random-bytes"=func_5 }                               <- p2rand
 *  inst 5: FromExports { "blocking-read"=func_6, "get-stdin"=func_7 }              <- p2stdin
 *  inst 6: FromExports { "get-environment"=func_8, "get-arguments"=func_9 }        <- p2env
 *  (has-fs only):
 *  inst 7: FromExports { "write"=func_12, "create-directory-at"=func_13, ... }     <- p2fs_raw
 *  inst 8: Instantiate(module=2=p2ext, ...) / inst 7 (no-fs)
 *  inst 9: Instantiate(module=4=p2fs, ...) (has-fs only)
 *  (has-net only):
 *  inst N-3: FromExports { http funcs } <- p2http
 *  inst N-2: Instantiate(module=p2net, {env, p2http})
 *  inst N-1: Instantiate(module=adapter, {env, p2, p2ext[, p2fs][, p2net]})
 *  inst N:   Instantiate(module=nexus, {env, wasi_snapshot_preview1=N-1})
 */
export let p2_inst_count = fn (has_fs: bool, has_net: bool, has_server: bool) -> i64 do
  // no-fs+no-net=9, has-fs+no-net=11
  // no-fs+has-net+no-srv=11, no-fs+has-net+has-srv=13
  // has-fs+has-net+no-srv=13, has-fs+has-net+has-srv=15
  // (has-server adds +2 over has-net-only: p2sock_raw + p2sock core instances)
  if has_fs then
    if has_net then
      if has_server then return 15 end
      return 13
    end
    return 11
  end
  if has_net then
    if has_server then return 13 end
    return 11
  end
  return 9
end

export let build_p2_core_instance_section = fn (has_fs: bool, has_net: bool, has_server: bool) -> %ByteBuffer do
  let %out = bb.empty()
  let inst_count = p2_inst_count(has_fs, has_net, has_server)
  let %out = bb.push_uleb128(buf: %out, val: inst_count)
  // Entry 0: Instantiate(module=0=stub, args=[]) → core instance 1
  let %out = bb.push_bytes(buf: %out, bytes: [0, 0, 0])
  // Entry 1: FromExports count=2 { get-stdout=func0, write=func1 } → core instance 2
  let %out = bb.push_bytes(buf: %out, bytes: [1, 2])
  let %out = bb.push_uleb128(buf: %out, val: str.byte_length(s: "get-stdout"))
  let %out = bb.push_string(buf: %out, s: "get-stdout")
  let %out = bb.push_bytes(buf: %out, bytes: [0, 0])
  let %out = bb.push_uleb128(buf: %out, val: str.byte_length(s: "write"))
  let %out = bb.push_string(buf: %out, s: "write")
  let %out = bb.push_bytes(buf: %out, bytes: [0, 1])
  // Entry 2: FromExports count=2 { exit=func2, now=func3 } → core instance 3 (p2ext_raw)
  let %out = bb.push_bytes(buf: %out, bytes: [1, 2])
  let %out = bb.push_uleb128(buf: %out, val: str.byte_length(s: "exit"))
  let %out = bb.push_string(buf: %out, s: "exit")
  let %out = bb.push_bytes(buf: %out, bytes: [0, 2])
  let %out = bb.push_uleb128(buf: %out, val: str.byte_length(s: "now"))
  let %out = bb.push_string(buf: %out, s: "now")
  let %out = bb.push_bytes(buf: %out, bytes: [0, 3])
  // Entry 3: FromExports count=1 { get-random-bytes=func5 } → core instance 4 (p2rand)
  let %out = bb.push_bytes(buf: %out, bytes: [1, 1])
  let %out = bb.push_uleb128(buf: %out, val: str.byte_length(s: "get-random-bytes"))
  let %out = bb.push_string(buf: %out, s: "get-random-bytes")
  let %out = bb.push_bytes(buf: %out, bytes: [0, 5])
  // Entry 4: FromExports count=2 { blocking-read=func6, get-stdin=func7 } → core instance 5 (p2stdin)
  let %out = bb.push_bytes(buf: %out, bytes: [1, 2])
  let %out = bb.push_uleb128(buf: %out, val: str.byte_length(s: "blocking-read"))
  let %out = bb.push_string(buf: %out, s: "blocking-read")
  let %out = bb.push_bytes(buf: %out, bytes: [0, 6])
  let %out = bb.push_uleb128(buf: %out, val: str.byte_length(s: "get-stdin"))
  let %out = bb.push_string(buf: %out, s: "get-stdin")
  let %out = bb.push_bytes(buf: %out, bytes: [0, 7])
  // Entry 5: FromExports count=2 { get-environment=func8, get-arguments=func9 } → core instance 6 (p2env)
  let %out = bb.push_bytes(buf: %out, bytes: [1, 2])
  let %out = bb.push_uleb128(buf: %out, val: str.byte_length(s: "get-environment"))
  let %out = bb.push_string(buf: %out, s: "get-environment")
  let %out = bb.push_bytes(buf: %out, bytes: [0, 8])
  let %out = bb.push_uleb128(buf: %out, val: str.byte_length(s: "get-arguments"))
  let %out = bb.push_string(buf: %out, s: "get-arguments")
  let %out = bb.push_bytes(buf: %out, bytes: [0, 9])
  // Entries 6+ differ based on has_fs and has_net.
  let %out = if has_fs then
    // Entry 6: FromExports count=8 { write=func12, create-directory-at=func13, unlink-file-at=func14,
    //           get-directories=func15, open-at=func10, read=func11,
    //           read-directory=func16, read-directory-entry=func17 } → core instance 7 (p2fs_raw)
    let %o = bb.push_bytes(buf: %out, bytes: [1, 8])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "write"))
    let %o = bb.push_string(buf: %o, s: "write")
    let %o = bb.push_bytes(buf: %o, bytes: [0, 12])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "create-directory-at"))
    let %o = bb.push_string(buf: %o, s: "create-directory-at")
    let %o = bb.push_bytes(buf: %o, bytes: [0, 13])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "unlink-file-at"))
    let %o = bb.push_string(buf: %o, s: "unlink-file-at")
    let %o = bb.push_bytes(buf: %o, bytes: [0, 14])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "get-directories"))
    let %o = bb.push_string(buf: %o, s: "get-directories")
    let %o = bb.push_bytes(buf: %o, bytes: [0, 15])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "open-at"))
    let %o = bb.push_string(buf: %o, s: "open-at")
    let %o = bb.push_bytes(buf: %o, bytes: [0, 10])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "read"))
    let %o = bb.push_string(buf: %o, s: "read")
    let %o = bb.push_bytes(buf: %o, bytes: [0, 11])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "read-directory"))
    let %o = bb.push_string(buf: %o, s: "read-directory")
    let %o = bb.push_bytes(buf: %o, bytes: [0, 16])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "read-directory-entry"))
    let %o = bb.push_string(buf: %o, s: "read-directory-entry")
    let %o = bb.push_bytes(buf: %o, bytes: [0, 17])
    // Entry 7: Instantiate(module=2=p2ext, args=5: {env=inst0, p2ext_raw=inst3, p2rand=inst4, p2stdin=inst5, p2env=inst6}) → inst8
    let %o = bb.push_bytes(buf: %o, bytes: [0, 2, 5])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
    let %o = bb.push_string(buf: %o, s: "env")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2ext_raw"))
    let %o = bb.push_string(buf: %o, s: "p2ext_raw")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 3])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2rand"))
    let %o = bb.push_string(buf: %o, s: "p2rand")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 4])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2stdin"))
    let %o = bb.push_string(buf: %o, s: "p2stdin")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 5])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2env"))
    let %o = bb.push_string(buf: %o, s: "p2env")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 6])
    // Entry 8: Instantiate(module=4=p2fs, args=2: {env=inst0, p2fs_raw=inst7}) → inst9
    let %o = bb.push_bytes(buf: %o, bytes: [0, 4, 2])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
    let %o = bb.push_string(buf: %o, s: "env")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2fs_raw"))
    let %o = bb.push_string(buf: %o, s: "p2fs_raw")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 7])
    if has_net then
      // has-fs+has-net: inst9=p2fs. Add p2http + p2net + (optionally p2sock_raw + p2sock) + adapter + nexus.
      // Entry 9: FromExports (p2http) = build_p2http_from_exports(has_fs: true) → inst10
      let %p2h = build_p2http_from_exports(has_fs: true)
      let %o = bb.push_buf(buf: %o, src: &p2h)
      bb.free(buf: %p2h)
      // Entry 10: Instantiate(module=5=p2net, args=3: {env=inst0, p2http=inst10, p2ext=inst8}) → inst11
      let %o = bb.push_bytes(buf: %o, bytes: [0, 5, 3])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
      let %o = bb.push_string(buf: %o, s: "env")
      let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2http"))
      let %o = bb.push_string(buf: %o, s: "p2http")
      let %o = bb.push_bytes(buf: %o, bytes: [18, 10])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2ext"))
      let %o = bb.push_string(buf: %o, s: "p2ext")
      let %o = bb.push_bytes(buf: %o, bytes: [18, 8])
      if has_server then
        // Entry 11: FromExports p2sock_raw (16 socket funcs) → inst12
        let %psr = build_p2sock_raw_from_exports(has_fs: true)
        let %o = bb.push_buf(buf: %o, src: &psr)
        bb.free(buf: %psr)
        // Entry 12: Instantiate(module=6=p2sock, args=2: {env=inst0, p2sock_raw=inst12}) → inst13
        let %o = bb.push_bytes(buf: %o, bytes: [0, 6, 2])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
        let %o = bb.push_string(buf: %o, s: "env")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2sock_raw"))
        let %o = bb.push_string(buf: %o, s: "p2sock_raw")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 12])
        // Entry 13: Instantiate(module=1=adapter, args=6: {env,p2,p2ext=inst8,p2fs=inst9,p2net=inst11,p2sock=inst13}) → inst14
        let %o = bb.push_bytes(buf: %o, bytes: [0, 1, 6])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
        let %o = bb.push_string(buf: %o, s: "env")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2"))
        let %o = bb.push_string(buf: %o, s: "p2")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 2])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2ext"))
        let %o = bb.push_string(buf: %o, s: "p2ext")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 8])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2fs"))
        let %o = bb.push_string(buf: %o, s: "p2fs")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 9])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2net"))
        let %o = bb.push_string(buf: %o, s: "p2net")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 11])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2sock"))
        let %o = bb.push_string(buf: %o, s: "p2sock")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 13])
        // Entry 14: Instantiate(module=3=nexus, args=2: {env,wasi=inst14}) → inst15
        let %o = bb.push_bytes(buf: %o, bytes: [0, 3, 2])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
        let %o = bb.push_string(buf: %o, s: "env")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "wasi_snapshot_preview1"))
        let %o = bb.push_string(buf: %o, s: "wasi_snapshot_preview1")
        bb.push_bytes(buf: %o, bytes: [18, 14])
      else
        // has-fs+has-net+no-server: inst11=p2net, adapter=inst12, nexus=inst13
        // Entry 11: Instantiate(module=1=adapter, args=5: {env,p2,p2ext=inst8,p2fs=inst9,p2net=inst11}) → inst12
        let %o = bb.push_bytes(buf: %o, bytes: [0, 1, 5])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
        let %o = bb.push_string(buf: %o, s: "env")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2"))
        let %o = bb.push_string(buf: %o, s: "p2")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 2])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2ext"))
        let %o = bb.push_string(buf: %o, s: "p2ext")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 8])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2fs"))
        let %o = bb.push_string(buf: %o, s: "p2fs")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 9])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2net"))
        let %o = bb.push_string(buf: %o, s: "p2net")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 11])
        // Entry 12: Instantiate(module=3=nexus, args=2: {env,wasi=inst12}) → inst13
        let %o = bb.push_bytes(buf: %o, bytes: [0, 3, 2])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
        let %o = bb.push_string(buf: %o, s: "env")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "wasi_snapshot_preview1"))
        let %o = bb.push_string(buf: %o, s: "wasi_snapshot_preview1")
        bb.push_bytes(buf: %o, bytes: [18, 12])
      end
    else
      // has-fs+no-net: inst9=p2fs, adapter=inst10, nexus=inst11
      // Entry 9: Instantiate(module=1=adapter, args=4: {env,p2,p2ext=inst8,p2fs=inst9}) → inst10
      let %o = bb.push_bytes(buf: %o, bytes: [0, 1, 4])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
      let %o = bb.push_string(buf: %o, s: "env")
      let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2"))
      let %o = bb.push_string(buf: %o, s: "p2")
      let %o = bb.push_bytes(buf: %o, bytes: [18, 2])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2ext"))
      let %o = bb.push_string(buf: %o, s: "p2ext")
      let %o = bb.push_bytes(buf: %o, bytes: [18, 8])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2fs"))
      let %o = bb.push_string(buf: %o, s: "p2fs")
      let %o = bb.push_bytes(buf: %o, bytes: [18, 9])
      // Entry 10: Instantiate(module=3=nexus, {env,wasi=inst10}) → inst11
      let %o = bb.push_bytes(buf: %o, bytes: [0, 3, 2])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
      let %o = bb.push_string(buf: %o, s: "env")
      let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "wasi_snapshot_preview1"))
      let %o = bb.push_string(buf: %o, s: "wasi_snapshot_preview1")
      bb.push_bytes(buf: %o, bytes: [18, 10])
    end
  else
    // no-fs: p2ext at inst7
    // Entry 6: Instantiate(module=2=p2ext, args=5: {env=inst0, p2ext_raw=inst3, p2rand=inst4, p2stdin=inst5, p2env=inst6}) → inst7
    let %o = bb.push_bytes(buf: %out, bytes: [0, 2, 5])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
    let %o = bb.push_string(buf: %o, s: "env")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2ext_raw"))
    let %o = bb.push_string(buf: %o, s: "p2ext_raw")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 3])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2rand"))
    let %o = bb.push_string(buf: %o, s: "p2rand")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 4])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2stdin"))
    let %o = bb.push_string(buf: %o, s: "p2stdin")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 5])
    let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2env"))
    let %o = bb.push_string(buf: %o, s: "p2env")
    let %o = bb.push_bytes(buf: %o, bytes: [18, 6])
    if has_net then
      // no-fs+has-net: p2ext=inst7. Add p2http + p2net + (optionally p2sock_raw + p2sock) + adapter + nexus.
      // Entry 7: FromExports (p2http) = build_p2http_from_exports(has_fs: false) → inst8
      let %p2h = build_p2http_from_exports(has_fs: false)
      let %o = bb.push_buf(buf: %o, src: &p2h)
      bb.free(buf: %p2h)
      // Entry 8: Instantiate(module=4=p2net, args=3: {env,p2http=inst8,p2ext=inst7}) → inst9
      let %o = bb.push_bytes(buf: %o, bytes: [0, 4, 3])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
      let %o = bb.push_string(buf: %o, s: "env")
      let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2http"))
      let %o = bb.push_string(buf: %o, s: "p2http")
      let %o = bb.push_bytes(buf: %o, bytes: [18, 8])
      let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2ext"))
      let %o = bb.push_string(buf: %o, s: "p2ext")
      let %o = bb.push_bytes(buf: %o, bytes: [18, 7])
      if has_server then
        // Entry 9: FromExports p2sock_raw (16 socket funcs) → inst10
        let %psr = build_p2sock_raw_from_exports(has_fs: false)
        let %o = bb.push_buf(buf: %o, src: &psr)
        bb.free(buf: %psr)
        // Entry 10: Instantiate(module=5=p2sock, args=2: {env=inst0, p2sock_raw=inst10}) → inst11
        let %o = bb.push_bytes(buf: %o, bytes: [0, 5, 2])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "env"))
        let %o = bb.push_string(buf: %o, s: "env")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 0])
        let %o = bb.push_uleb128(buf: %o, val: str.byte_length(s: "p2sock_raw"))
        let %o = bb.push_string(buf: %o, s: "p2sock_raw")
        let %o = bb.push_bytes(buf: %o, bytes: [18, 10])
        // Entry 11: Instantiate(module=1=adapter, args=5: {env,p2,p2ext=inst7,p2net=inst9,p2sock=inst11}) → inst12
