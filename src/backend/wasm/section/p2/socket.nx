    110, 101, 116, 119, 111, 114, 107, 1, 0, 14, 17, 99, 114, 101, 97, 116,
    101, 45, 116, 99, 112, 45, 115, 111, 99, 107, 101, 116, 1, 0, 13, 29,
    91, 109, 101, 116, 104, 111, 100, 93, 116, 99, 112, 45, 115, 111, 99, 107,
    101, 116, 46, 115, 116, 97, 114, 116, 45, 98, 105, 110, 100, 1, 0, 13,
    30, 91, 109, 101, 116, 104, 111, 100, 93, 116, 99, 112, 45, 115, 111, 99,
    107, 101, 116, 46, 102, 105, 110, 105, 115, 104, 45, 98, 105, 110, 100, 1,
    0, 13, 31, 91, 109, 101, 116, 104, 111, 100, 93, 116, 99, 112, 45, 115,
    111, 99, 107, 101, 116, 46, 115, 116, 97, 114, 116, 45, 108, 105, 115, 116,
    101, 110, 1, 0, 13, 32, 91, 109, 101, 116, 104, 111, 100, 93, 116, 99,
    112, 45, 115, 111, 99, 107, 101, 116, 46, 102, 105, 110, 105, 115, 104, 45,
    108, 105, 115, 116, 101, 110, 1, 0, 13, 25, 91, 109, 101, 116, 104, 111,
    100, 93, 116, 99, 112, 45, 115, 111, 99, 107, 101, 116, 46, 97, 99, 99,
    101, 112, 116, 1, 0, 13, 28, 91, 109, 101, 116, 104, 111, 100, 93, 116,
    99, 112, 45, 115, 111, 99, 107, 101, 116, 46, 115, 117, 98, 115, 99, 114,
    105, 98, 101, 1, 0, 8, 22, 91, 109, 101, 116, 104, 111, 100, 93, 112,
    111, 108, 108, 97, 98, 108, 101, 46, 98, 108, 111, 99, 107]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  return %out
end

export let p2_build_socket_sections_hasfs = fn () -> %ByteBuffer do
  // secA: type section — network interface instance type (type 23, = nofs+4 for fs types)
  let %out = bb.empty()
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_type, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 66, 15, 4, 0, 7, 110, 101, 116, 119, 111, 114, 107, 3, 1, 1, 109, 2, 4, 105, 112, 118, 52, 4, 105, 112, 118,
    54, 4, 0, 17, 105, 112, 45, 97, 100, 100, 114, 101, 115, 115, 45, 102, 97, 109, 105, 108, 121, 3, 0, 1, 1, 109,
    21, 7, 117, 110, 107, 110, 111, 119, 110, 13, 97, 99, 99, 101, 115, 115, 45, 100, 101, 110, 105, 101, 100, 13,
