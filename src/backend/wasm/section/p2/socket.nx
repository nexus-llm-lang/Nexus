  // secK: import wasi:sockets/tcp-create-socket@0.2.0 (instance 32, type 32)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_import, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 0, 36, 119, 97, 115, 105, 58, 115, 111, 99, 107, 101, 116, 115, 47, 116, 99, 112, 45, 99, 114, 101, 97,
    116, 101, 45, 115, 111, 99, 107, 101, 116, 64, 48, 46, 50, 46, 48, 5, 32]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // secL: alias 10 socket+io comp funcs (comp funcs 21-30) for canon lower → core funcs 22-31.
  // Resource drops (tcp-socket, input-stream, output-stream, pollable, network) use canon resource.drop
  // in p2_sock_canon_lower_nofs (comp funcs 31-35 → core funcs 32-36).
  // nofs instances: io/streams=1, io/poll=8, network=11, inst-net=12, tcp=13, tcp-create-socket=14.
  // Order: blocking-write(1), instance-network(12), create-tcp-socket(14),
  //        start-bind(13), finish-bind(13), start-listen(13), finish-listen(13), accept(13), subscribe(13),
  //        pollable.block(8).
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_alias, content: bb.push_bytes(buf: bb.empty(), bytes: [
