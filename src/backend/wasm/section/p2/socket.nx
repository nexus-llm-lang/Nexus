/**
 * wasm/section/p2/socket: WASI preview2 socket (TCP server) component sections.
 *
 * Builds the wasi:sockets component import sections, the p2sock core module,
 * and the canon-lower wrappers for the TCP socket host functions.
 */

import { ByteBuffer }, * as bb from "std:bytebuffer"
import * as wdefs from "src/backend/wasm/defs.nx"
import { cm_wrap_section, cm_emit_func_export_entry } from "src/backend/wasm/section/cm_common.nx"

// Build the FromExports core instance for p2sock_raw: maps 16 socket function names
// to the canon-lowered core func indices produced by p2_build_socket_canon_lower.
// no-fs+has-net: socket lowers start at core22 (after http 10-21, blocking-write=core22)
// has-fs+has-net: socket lowers start at core28 (after http 16-27, blocking-write=core28)
// blocking-read (io/streams) = core6 in both cases (already lowered earlier).
// The 9 socket funcs + 5 drops follow blocking-write in order.
export let build_p2sock_raw_from_exports = fn (has_fs: bool) -> %ByteBuffer do
  // bw_base = first socket core func index:
  //   nofs: base 10 + http 12 = 22
  //   hasfs: base 10 + fs 8 + http 12 = 30
  let bw_base = if has_fs then 30 else 22 end
  // blocking-write = bw_base + 0
  // instance-network = bw_base + 1
  // create-tcp-socket = bw_base + 2
  // start-bind = bw_base + 3
  // finish-bind = bw_base + 4
  // start-listen = bw_base + 5
  // finish-listen = bw_base + 6
  // tcp-accept = bw_base + 7
  // tcp-subscribe = bw_base + 8
  // poll = bw_base + 9
  // drop-tcp-socket = bw_base + 10
  // drop-istream = bw_base + 11
  // drop-ostream = bw_base + 12
  // drop-pollable = bw_base + 13
  // drop-network = bw_base + 14
  // blocking-read = core6 (from io/streams, already lowered)
  let %out = bb.push_bytes(buf: bb.empty(), bytes: [1, 16])
  let %out = cm_emit_func_export_entry(buf: %out, name: "instance-network", idx: bw_base + 1)
  let %out = cm_emit_func_export_entry(buf: %out, name: "create-tcp-socket", idx: bw_base + 2)
  let %out = cm_emit_func_export_entry(buf: %out, name: "start-bind", idx: bw_base + 3)
  let %out = cm_emit_func_export_entry(buf: %out, name: "finish-bind", idx: bw_base + 4)
  let %out = cm_emit_func_export_entry(buf: %out, name: "start-listen", idx: bw_base + 5)
  let %out = cm_emit_func_export_entry(buf: %out, name: "finish-listen", idx: bw_base + 6)
  let %out = cm_emit_func_export_entry(buf: %out, name: "tcp-accept", idx: bw_base + 7)
  let %out = cm_emit_func_export_entry(buf: %out, name: "tcp-subscribe", idx: bw_base + 8)
  let %out = cm_emit_func_export_entry(buf: %out, name: "poll", idx: bw_base + 9)
  let %out = cm_emit_func_export_entry(buf: %out, name: "blocking-read", idx: 6)
  let %out = cm_emit_func_export_entry(buf: %out, name: "blocking-write", idx: bw_base + 0)
  let %out = cm_emit_func_export_entry(buf: %out, name: "drop-tcp-socket", idx: bw_base + 10)
  let %out = cm_emit_func_export_entry(buf: %out, name: "drop-istream", idx: bw_base + 11)
  let %out = cm_emit_func_export_entry(buf: %out, name: "drop-ostream", idx: bw_base + 12)
  let %out = cm_emit_func_export_entry(buf: %out, name: "drop-pollable", idx: bw_base + 13)
  return cm_emit_func_export_entry(buf: %out, name: "drop-network", idx: bw_base + 14)
end

/** Build wasi:sockets/{network,instance-network,tcp,tcp-create-socket} component sections.
 *  Returns empty buffer when has_net=false.
 *  When has_net=true, adds 14 comp types and 4 comp instances.
 *  For no-fs: types 19-32, instances 19,21,28,32.
 *  For has-fs: types 23-36, instances 22,24,31,35.
 *  These come from pre-computed bytes generated by wasm-tools against WASI WIT definitions.
 */
export let p2_build_socket_sections = fn (has_fs: bool, has_server: bool) -> %ByteBuffer do
  if has_server then
    if has_fs then
      return p2_build_socket_sections_hasfs()
    end
    return p2_build_socket_sections_nofs()
  end
  return bb.empty()
end

export let p2_build_socket_sections_nofs = fn () -> %ByteBuffer do
  // secA: type section — network interface instance type (type 19)
  let %out = bb.empty()
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_type, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 66, 15, 4, 0, 7, 110, 101, 116, 119, 111, 114, 107, 3, 1, 1, 109, 2, 4, 105, 112, 118, 52, 4, 105, 112, 118,
    54, 4, 0, 17, 105, 112, 45, 97, 100, 100, 114, 101, 115, 115, 45, 102, 97, 109, 105, 108, 121, 3, 0, 1, 1, 109,
    21, 7, 117, 110, 107, 110, 111, 119, 110, 13, 97, 99, 99, 101, 115, 115, 45, 100, 101, 110, 105, 101, 100, 13,
    110, 111, 116, 45, 115, 117, 112, 112, 111, 114, 116, 101, 100, 16, 105, 110, 118, 97, 108, 105, 100, 45, 97,
    114, 103, 117, 109, 101, 110, 116, 13, 111, 117, 116, 45, 111, 102, 45, 109, 101, 109, 111, 114, 121, 7, 116,
    105, 109, 101, 111, 117, 116, 20, 99, 111, 110, 99, 117, 114, 114, 101, 110, 99, 121, 45, 99, 111, 110, 102,
    108, 105, 99, 116, 15, 110, 111, 116, 45, 105, 110, 45, 112, 114, 111, 103, 114, 101, 115, 115, 11, 119, 111,
    117, 108, 100, 45, 98, 108, 111, 99, 107, 13, 105, 110, 118, 97, 108, 105, 100, 45, 115, 116, 97, 116, 101, 16,
    110, 101, 119, 45, 115, 111, 99, 107, 101, 116, 45, 108, 105, 109, 105, 116, 20, 97, 100, 100, 114, 101, 115,
    115, 45, 110, 111, 116, 45, 98, 105, 110, 100, 97, 98, 108, 101, 14, 97, 100, 100, 114, 101, 115, 115, 45, 105,
    110, 45, 117, 115, 101, 18, 114, 101, 109, 111, 116, 101, 45, 117, 110, 114, 101, 97, 99, 104, 97, 98, 108, 101,
    18, 99, 111, 110, 110, 101, 99, 116, 105, 111, 110, 45, 114, 101, 102, 117, 115, 101, 100, 16, 99, 111, 110,
    110, 101, 99, 116, 105, 111, 110, 45, 114, 101, 115, 101, 116, 18, 99, 111, 110, 110, 101, 99, 116, 105, 111,
    110, 45, 97, 98, 111, 114, 116, 101, 100, 18, 100, 97, 116, 97, 103, 114, 97, 109, 45, 116, 111, 111, 45, 108,
    97, 114, 103, 101, 17, 110, 97, 109, 101, 45, 117, 110, 114, 101, 115, 111, 108, 118, 97, 98, 108, 101, 26,
    116, 101, 109, 112, 111, 114, 97, 114, 121, 45, 114, 101, 115, 111, 108, 118, 101, 114, 45, 102, 97, 105, 108,
    117, 114, 101, 26, 112, 101, 114, 109, 97, 110, 101, 110, 116, 45, 114, 101, 115, 111, 108, 118, 101, 114, 45,
    102, 97, 105, 108, 117, 114, 101, 4, 0, 10, 101, 114, 114, 111, 114, 45, 99, 111, 100, 101, 3, 0, 3, 1, 111,
    4, 125, 125, 125, 125, 4, 0, 12, 105, 112, 118, 52, 45, 97, 100, 100, 114, 101, 115, 115, 3, 0, 5, 1, 114, 2,
    4, 112, 111, 114, 116, 123, 7, 97, 100, 100, 114, 101, 115, 115, 6, 4, 0, 19, 105, 112, 118, 52, 45, 115, 111,
    99, 107, 101, 116, 45, 97, 100, 100, 114, 101, 115, 115, 3, 0, 7, 1, 111, 8, 123, 123, 123, 123, 123, 123, 123,
    123, 4, 0, 12, 105, 112, 118, 54, 45, 97, 100, 100, 114, 101, 115, 115, 3, 0, 9, 1, 114, 4, 4, 112, 111, 114,
    116, 123, 9, 102, 108, 111, 119, 45, 105, 110, 102, 111, 121, 7, 97, 100, 100, 114, 101, 115, 115, 10, 8, 115,
    99, 111, 112, 101, 45, 105, 100, 121, 4, 0, 19, 105, 112, 118, 54, 45, 115, 111, 99, 107, 101, 116, 45, 97,
    100, 100, 114, 101, 115, 115, 3, 0, 11, 1, 113, 2, 4, 105, 112, 118, 52, 1, 8, 0, 4, 105, 112, 118, 54, 1,
    12, 0, 4, 0, 17, 105, 112, 45, 115, 111, 99, 107, 101, 116, 45, 97, 100, 100, 114, 101, 115, 115, 3, 0, 13]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // secB: import wasi:sockets/network@0.2.0 (instance 19, type 19)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_import, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 0, 26, 119, 97, 115, 105, 58, 115, 111, 99, 107, 101, 116, 115, 47, 110, 101, 116, 119, 111, 114, 107, 64,
    48, 46, 50, 46, 48, 5, 19]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // secC: alias network type from network instance (type 20)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_alias, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 3, 0, 11, 7, 110, 101, 116, 119, 111, 114, 107]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // secD: type section — instance-network interface type (type 21)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_type, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 66, 5, 2, 3, 2, 1, 20, 4, 0, 7, 110, 101, 116, 119, 111, 114, 107, 3, 0, 0, 1, 105, 1, 1, 64, 0, 0, 2,
    4, 0, 16, 105, 110, 115, 116, 97, 110, 99, 101, 45, 110, 101, 116, 119, 111, 114, 107, 1, 3]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // secE: import wasi:sockets/instance-network@0.2.0 (instance 21, type 21)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_import, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 0, 35, 119, 97, 115, 105, 58, 115, 111, 99, 107, 101, 116, 115, 47, 105, 110, 115, 116, 97, 110, 99, 101,
    45, 110, 101, 116, 119, 111, 114, 107, 64, 48, 46, 50, 46, 48, 5, 21]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // secF: alias 6 types from tcp+io interfaces (types 22-27): network, ip-socket-address, error-code, input-stream, output-stream, pollable
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_alias, content: bb.push_bytes(buf: bb.empty(), bytes: [
