    1, 66, 10, 2, 3, 2, 1, 29, 4, 0, 17, 105, 112, 45, 97, 100, 100, 114, 101, 115, 115, 45, 102, 97, 109, 105,
    108, 121, 3, 0, 0, 2, 3, 2, 1, 30, 4, 0, 10, 116, 99, 112, 45, 115, 111, 99, 107, 101, 116, 3, 0, 2, 2, 3,
    2, 1, 31, 4, 0, 10, 101, 114, 114, 111, 114, 45, 99, 111, 100, 101, 3, 0, 4, 1, 105, 3, 1, 106, 1, 6, 1, 5,
    1, 64, 1, 14, 97, 100, 100, 114, 101, 115, 115, 45, 102, 97, 109, 105, 108, 121, 1, 0, 7, 4, 0, 17, 99, 114,
    101, 97, 116, 101, 45, 116, 99, 112, 45, 115, 111, 99, 107, 101, 116, 1, 8]))
  let %out = bb.push_buf(buf: %out, src: &s)
