// Canon lower the 10 socket component funcs + 5 resource.drops when has_server=true.
// no-fs+has-server: comp funcs 21..30 → canon lower core22..31; resource.drops → core32..36.
// has-fs+has-server: comp funcs 27..36 → canon lower core30..39; resource.drops → core40..44.
// (core indices follow naturally from sequential section emission.)
export let p2_build_socket_canon_lower = fn (has_fs: bool, has_server: bool, base: %ByteBuffer) -> %ByteBuffer do
  if has_server then
    if has_fs then
      return p2_sock_canon_lower_hasfs(base: %base)
    end
    return p2_sock_canon_lower_nofs(base: %base)
  end
  return %base
end

// no-fs+has-net: comp funcs 21..30 canon lower → core22..31; resource.drops → core32..36.
export let p2_sock_canon_lower_nofs = fn (base: %ByteBuffer) -> %ByteBuffer do
  // cf21: [method]output-stream.blocking-write-and-flush → 1 opt mem0
  let %s0 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 21, 1, 3, 0]))
  let %o = bb.push_buf(buf: %base, src: &s0)
  bb.free(buf: %s0)
  // cf22: instance-network → 0 opts (returns own<network>=i32)
  let %s1 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 22, 0]))
  let %o = bb.push_buf(buf: %o, src: &s1)
  bb.free(buf: %s1)
  // cf23: create-tcp-socket → 1 opt mem0 (result stored via retptr)
  let %s2 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 23, 1, 3, 0]))
  let %o = bb.push_buf(buf: %o, src: &s2)
  bb.free(buf: %s2)
  // cf24: [method]tcp-socket.start-bind → 1 opt mem0 (ip-socket-address via memory)
  let %s3 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 24, 1, 3, 0]))
  let %o = bb.push_buf(buf: %o, src: &s3)
  bb.free(buf: %s3)
  // cf25: [method]tcp-socket.finish-bind → 1 opt mem0 (result via retptr)
  let %s4 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 25, 1, 3, 0]))
  let %o = bb.push_buf(buf: %o, src: &s4)
  bb.free(buf: %s4)
  // cf26: [method]tcp-socket.start-listen → 1 opt mem0
  let %s5 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 26, 1, 3, 0]))
  let %o = bb.push_buf(buf: %o, src: &s5)
  bb.free(buf: %s5)
  // cf27: [method]tcp-socket.finish-listen → 1 opt mem0
  let %s6 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 27, 1, 3, 0]))
  let %o = bb.push_buf(buf: %o, src: &s6)
  bb.free(buf: %s6)
  // cf28: [method]tcp-socket.accept → 1 opt mem0 (tuple result via retptr)
  let %s7 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 28, 1, 3, 0]))
  let %o = bb.push_buf(buf: %o, src: &s7)
  bb.free(buf: %s7)
  // cf29: [method]tcp-socket.subscribe → 0 opts (returns own<pollable>=i32)
  let %s8 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 29, 0]))
  let %o = bb.push_buf(buf: %o, src: &s8)
  bb.free(buf: %s8)
  // cf30: [method]pollable.block (= p2sock_raw "poll") → 0 opts
  let %s9 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 30, 0]))
  let %o = bb.push_buf(buf: %o, src: &s9)
  bb.free(buf: %s9)
  // core32: resource.drop tcp-socket (type 30)
  let %s10 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                              content: bb.push_bytes(buf: bb.empty(), bytes: [1, 3, 30]))
  let %o = bb.push_buf(buf: %o, src: &s10)
  bb.free(buf: %s10)
  // core33: resource.drop input-stream (type 25)
  let %s11 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                              content: bb.push_bytes(buf: bb.empty(), bytes: [1, 3, 25]))
  let %o = bb.push_buf(buf: %o, src: &s11)
  bb.free(buf: %s11)
  // core34: resource.drop output-stream (type 26)
  let %s12 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                              content: bb.push_bytes(buf: bb.empty(), bytes: [1, 3, 26]))
  let %o = bb.push_buf(buf: %o, src: &s12)
  bb.free(buf: %s12)
  // core35: resource.drop pollable (type 27)
  let %s13 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                              content: bb.push_bytes(buf: bb.empty(), bytes: [1, 3, 27]))
  let %o = bb.push_buf(buf: %o, src: &s13)
  bb.free(buf: %s13)
  // core36: resource.drop network (type 20)
  let %s14 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                              content: bb.push_bytes(buf: bb.empty(), bytes: [1, 3, 20]))
  let %o = bb.push_buf(buf: %o, src: &s14)
  bb.free(buf: %s14)
  return %o
end

