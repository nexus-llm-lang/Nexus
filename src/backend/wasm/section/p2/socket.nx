    115, 116, 114, 101, 97, 109, 3, 0, 8, 8, 112, 111, 108, 108, 97, 98, 108, 101]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // secG: type section — tcp interface type (type 28)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_type, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 66, 32, 4, 0, 10, 116, 99, 112, 45, 115, 111, 99, 107, 101, 116, 3, 1, 2, 3, 2, 1, 22, 4, 0, 7, 110, 101,
    116, 119, 111, 114, 107, 3, 0, 1, 2, 3, 2, 1, 23, 4, 0, 17, 105, 112, 45, 115, 111, 99, 107, 101, 116, 45,
    97, 100, 100, 114, 101, 115, 115, 3, 0, 3, 2, 3, 2, 1, 24, 4, 0, 10, 101, 114, 114, 111, 114, 45, 99, 111,
    100, 101, 3, 0, 5, 2, 3, 2, 1, 25, 4, 0, 12, 105, 110, 112, 117, 116, 45, 115, 116, 114, 101, 97, 109, 3, 0,
    7, 2, 3, 2, 1, 26, 4, 0, 13, 111, 117, 116, 112, 117, 116, 45, 115, 116, 114, 101, 97, 109, 3, 0, 9, 2, 3,
    2, 1, 27, 4, 0, 8, 112, 111, 108, 108, 97, 98, 108, 101, 3, 0, 11, 1, 104, 0, 1, 104, 2, 1, 106, 0, 1, 6,
    1, 64, 3, 4, 115, 101, 108, 102, 13, 7, 110, 101, 116, 119, 111, 114, 107, 14, 13, 108, 111, 99, 97, 108, 45,
    97, 100, 100, 114, 101, 115, 115, 4, 0, 15, 4, 0, 29, 91, 109, 101, 116, 104, 111, 100, 93, 116, 99, 112, 45,
    115, 111, 99, 107, 101, 116, 46, 115, 116, 97, 114, 116, 45, 98, 105, 110, 100, 1, 16, 1, 64, 1, 4, 115, 101,
    108, 102, 13, 0, 15, 4, 0, 30, 91, 109, 101, 116, 104, 111, 100, 93, 116, 99, 112, 45, 115, 111, 99, 107, 101,
    116, 46, 102, 105, 110, 105, 115, 104, 45, 98, 105, 110, 100, 1, 17, 4, 0, 31, 91, 109, 101, 116, 104, 111,
    100, 93, 116, 99, 112, 45, 115, 111, 99, 107, 101, 116, 46, 115, 116, 97, 114, 116, 45, 108, 105, 115, 116,
    101, 110, 1, 17, 4, 0, 32, 91, 109, 101, 116, 104, 111, 100, 93, 116, 99, 112, 45, 115, 111, 99, 107, 101,
    116, 46, 102, 105, 110, 105, 115, 104, 45, 108, 105, 115, 116, 101, 110, 1, 17, 1, 105, 0, 1, 105, 8, 1, 105,
    10, 1, 111, 3, 18, 19, 20, 1, 106, 1, 21, 1, 6, 1, 64, 1, 4, 115, 101, 108, 102, 13, 0, 22, 4, 0, 25, 91,
    109, 101, 116, 104, 111, 100, 93, 116, 99, 112, 45, 115, 111, 99, 107, 101, 116, 46, 97, 99, 99, 101, 112, 116,
    1, 23, 1, 105, 12, 1, 64, 1, 4, 115, 101, 108, 102, 13, 0, 24, 4, 0, 28, 91, 109, 101, 116, 104, 111, 100,
    93, 116, 99, 112, 45, 115, 111, 99, 107, 101, 116, 46, 115, 117, 98, 115, 99, 114, 105, 98, 101, 1, 25]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // secH: import wasi:sockets/tcp@0.2.0 (instance 28, type 28)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_import, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 0, 22, 119, 97, 115, 105, 58, 115, 111, 99, 107, 101, 116, 115, 47, 116, 99, 112, 64, 48, 46, 50, 46, 48,
