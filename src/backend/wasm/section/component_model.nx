let p2_build_fs_sections = fn (has_fs: bool) -> %ByteBuffer do
  let %base = bb.empty()
  let %out = p2_build_fs_sections_inner(has_fs: has_fs, base: %base)
  return %out
end

let p2_build_fs_sections_inner = fn (has_fs: bool, base: %ByteBuffer) -> %ByteBuffer do
