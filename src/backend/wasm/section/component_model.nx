  bb.free(buf: %s)
  // Sec 19: type — wasi:cli/stdin instance type (get-stdin returning own<input-stream>)
  // Outer alias index 4 = component type 4 = input-stream alias (from unified io/streams Sec 5).
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_type, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 66, 4, 2, 3, 2, 1, 4, 1, 105, 0, 1, 64, 0, 0, 1, 4, 0, 9, 103, 101, 116, 45, 115, 116,
    100, 105, 110, 1, 2]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // Sec 20: import wasi:cli/stdin@0.2.0 (instance 6, type 9)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_import, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 0, 20, 119, 97, 115, 105, 58, 99, 108, 105, 47, 115, 116, 100, 105, 110, 64, 48, 46, 50,
    46, 48, 5, 9]))
