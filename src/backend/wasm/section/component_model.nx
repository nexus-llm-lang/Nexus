let p2_build_canon_lower = fn (has_fs: bool, has_net: bool) -> %ByteBuffer do
  let %out = bb.empty()

  // Sec 29: instantiate stub (module 0) with no args → core instance 0
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_core_instance,
                            content: bb.push_bytes(buf: bb.empty(), bytes: [1, 0, 0, 0]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 30: canon lower get-stdout (component func 0) → core func 0
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                            content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 0, 0]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 31: alias core memory from instance 0 → core memory 0
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_alias,
                            content: bb.push_bytes(buf: bb.empty(), bytes: [1, 0, 2, 1, 0, 6, 109, 101, 109, 111, 114, 121]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 32: canon lower write (component func 1) with memory 0 → core func 1
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                            content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 1, 1, 3, 0]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 33: canon lower exit (component func 2) → core func 2 (i32 discriminant, no memory needed)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                            content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 2, 0]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 34: canon lower now (component func 3) → core func 3 (returns i64, no memory needed)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                            content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 3, 0]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 35: alias cabi_realloc from stub (core instance 0) → core func 4
  // Needed as realloc option for canon lower of get-random-bytes and blocking-read.
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_alias, content: bb.push_bytes(buf: bb.empty(), bytes: [
    1, 0, 0, 1, 0, 12, 99, 97, 98, 105, 95, 114, 101, 97, 108, 108, 111, 99]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 36: canon lower get-random-bytes (comp func 4) with memory 0, realloc core_func 4 → core func 5
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                            content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 4, 2, 3, 0, 4, 4]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 37: canon lower [method]input-stream.blocking-read (comp func 5) with mem=0, realloc=4 → core func 6
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                            content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 5, 2, 3, 0, 4, 4]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  // Sec 38: canon lower get-stdin (comp func 6) → core func 7 (returns i32 handle, no memory)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                            content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 6, 0]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // Sec 38b: canon lower get-environment (comp func 7) with mem=0, realloc=4 → core func 8
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                            content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 7, 2, 3, 0, 4, 4]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // Sec 38c: canon lower get-arguments (comp func 8) with mem=0, realloc=4 → core func 9
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                            content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 8, 2, 3, 0, 4, 4]))
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // Secs 38d/38e/38f/38g/38h/38i: canon lower fs component funcs → core funcs 10-15 (has_fs only).
  let %out = p2_build_fs_canon_lower(has_fs: has_fs, base: %out)
  // Secs 38j..38u: canon lower 12 http component funcs → core funcs (has_net only).
  // no-fs+has-net: comp funcs 9-20 → core funcs 10-21.
  // has-fs+has-net: comp funcs 15-26 → core funcs 16-27.
  let %out = p2_build_http_canon_lower(has_fs: has_fs, has_net: has_net, base: %out)
  return %out
end

let p2_build_fs_canon_lower = fn (has_fs: bool, base: %ByteBuffer) -> %ByteBuffer do
  if has_fs then
    // Sec 38d: cf9=open-at → core func 10
    let %s38d = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 9, 2, 3, 0, 4, 4]))
    let %o = bb.push_buf(buf: %base, src: &s38d)
    bb.free(buf: %s38d)
    // Sec 38e: cf10=read → core func 11
    let %s38e = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 10, 2, 3, 0, 4, 4]))
    let %o = bb.push_buf(buf: %o, src: &s38e)
    bb.free(buf: %s38e)
    // Sec 38f: cf11=write → core func 12
    let %s38f = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 11, 2, 3, 0, 4, 4]))
    let %o = bb.push_buf(buf: %o, src: &s38f)
    bb.free(buf: %s38f)
    // Sec 38g: cf12=create-directory-at → core func 13
    let %s38g = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 12, 2, 3, 0, 4, 4]))
    let %o = bb.push_buf(buf: %o, src: &s38g)
    bb.free(buf: %s38g)
    // Sec 38h: cf13=unlink-file-at → core func 14
    let %s38h = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 13, 2, 3, 0, 4, 4]))
    let %o = bb.push_buf(buf: %o, src: &s38h)
    bb.free(buf: %s38h)
    // Sec 38i: cf16=get-directories → core func 15
    let %s38i = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 16, 2, 3, 0, 4, 4]))
    let %o = bb.push_buf(buf: %o, src: &s38i)
    bb.free(buf: %s38i)
    // Sec 38j: cf14=read-directory → core func 16 (memory only)
    let %s38j = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 14, 1, 3, 0]))
    let %o = bb.push_buf(buf: %o, src: &s38j)
    bb.free(buf: %s38j)
    // Sec 38k: cf15=read-directory-entry → core func 17 (memory + realloc for string output)
    let %s38k = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                                content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 15, 2, 3, 0, 4, 4]))
    let %o = bb.push_buf(buf: %o, src: &s38k)
    bb.free(buf: %s38k)
    return %o
  end
  return %base
end

// Canon lower the 12 http component funcs when has_net=true.
// no-fs+has-net: comp funcs 9..20 → core funcs 10..21.
// has-fs+has-net: comp funcs 15..26 → core funcs 16..27.
// Dispatch to has_fs-specific helpers to avoid expressions in list literals.
let p2_build_http_canon_lower = fn (has_fs: bool, has_net: bool, base: %ByteBuffer) -> %ByteBuffer do
  if has_net then
    if has_fs then
      return p2_http_canon_lower_hasfs(base: %base)
    end
    return p2_http_canon_lower_nofs(base: %base)
  end
  return %base
end

// no-fs+has-net: comp funcs 9..20, core funcs 10..21.
let p2_http_canon_lower_nofs = fn (base: %ByteBuffer) -> %ByteBuffer do
  // cf9: pollable.block → 0 opts
  let %s0 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 9, 0]))
  let %o = bb.push_buf(buf: %base, src: &s0)
  bb.free(buf: %s0)
  // cf10: set-method → 2 opts mem0+realloc4 (method variant has other(string))
  let %s1 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 10, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s1)
  bb.free(buf: %s1)
  // cf11: set-scheme → 2 opts mem0+realloc4 (scheme variant has other(string))
  let %s2 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 11, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s2)
  bb.free(buf: %s2)
  // cf12: set-authority → 2 opts mem0+realloc4 (option<string> param)
  let %s3 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 12, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s3)
  bb.free(buf: %s3)
  // cf13: set-path-with-query → 2 opts mem0+realloc4 (option<string> param)
  let %s4 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 13, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s4)
  bb.free(buf: %s4)
  // cf14: future-inresp.get → 2 opts mem0+realloc4 (error-code has Option<String>)
  let %s5 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 14, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s5)
  bb.free(buf: %s5)
  // cf15: inresp.consume → 2 opts mem0+realloc4 (result error-code has Option<String>)
  let %s6 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 15, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s6)
  bb.free(buf: %s6)
  // cf16: inbody.stream-it → 2 opts mem0+realloc4 (result error-code has Option<String>)
  let %s7 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 16, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s7)
  bb.free(buf: %s7)
  // cf17: handle → 2 opts mem0+realloc4 (result err-code has Option<String>)
  let %s8 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 17, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s8)
  bb.free(buf: %s8)
  // cf18: ctor-fields → 2 opts mem0+realloc4
  let %s9 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 18, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s9)
  bb.free(buf: %s9)
  // cf19: ctor-outreq → 1 opt mem0 (params have strings, result is own<outreq>=i32; no realloc for string params)
  let %s10 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                              content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 19, 1, 3, 0]))
  let %o = bb.push_buf(buf: %o, src: &s10)
  bb.free(buf: %s10)
  // cf20: future.subscribe → 0 opts
  let %s11 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                              content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 20, 0]))
  let %o = bb.push_buf(buf: %o, src: &s11)
  bb.free(buf: %s11)
  return %o
end

// has-fs+has-net: comp funcs 15..26, core funcs 16..27.
let p2_http_canon_lower_hasfs = fn (base: %ByteBuffer) -> %ByteBuffer do
  // cf15: pollable.block → 0 opts
  let %s0 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 15, 0]))
  let %o = bb.push_buf(buf: %base, src: &s0)
  bb.free(buf: %s0)
  // cf16: set-method → 2 opts mem0+realloc4 (method variant has other(string))
  let %s1 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 16, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s1)
  bb.free(buf: %s1)
  // cf17: set-scheme → 2 opts mem0+realloc4 (scheme variant has other(string))
  let %s2 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 17, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s2)
  bb.free(buf: %s2)
  // cf18: set-authority → 2 opts mem0+realloc4 (option<string> param)
  let %s3 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 18, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s3)
  bb.free(buf: %s3)
  // cf19: set-path-with-query → 2 opts mem0+realloc4 (option<string> param)
  let %s4 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 19, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s4)
  bb.free(buf: %s4)
  // cf20: future-inresp.get → 2 opts mem0+realloc4 (error-code has Option<String>)
  let %s5 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 20, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s5)
  bb.free(buf: %s5)
  // cf21: inresp.consume → 2 opts mem0+realloc4 (result error-code has Option<String>)
  let %s6 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 21, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s6)
  bb.free(buf: %s6)
  // cf22: inbody.stream-it → 2 opts mem0+realloc4 (result error-code has Option<String>)
  let %s7 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 22, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s7)
  bb.free(buf: %s7)
  // cf23: handle → 2 opts mem0+realloc4 (result err-code has Option<String>)
  let %s8 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 23, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s8)
  bb.free(buf: %s8)
  // cf24: ctor-fields → 2 opts mem0+realloc4
  let %s9 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                             content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 24, 2, 3, 0, 4, 4]))
  let %o = bb.push_buf(buf: %o, src: &s9)
  bb.free(buf: %s9)
  // cf25: ctor-outreq → 1 opt mem0 (params have strings, result is own<outreq>=i32; no realloc for string params)
  let %s10 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                              content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 25, 1, 3, 0]))
  let %o = bb.push_buf(buf: %o, src: &s10)
  bb.free(buf: %s10)
  // cf26: future.subscribe → 0 opts
  let %s11 = cm_wrap_section(section_id: wdefs.cm_sec_canon,
                              content: bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 0, 26, 0]))
  let %o = bb.push_buf(buf: %o, src: &s11)
  bb.free(buf: %s11)
  return %o
end

// 4-way helpers for p2_build_alias_type_canon index selection.
// Using early returns avoids nested if-else-end which Nexus can't parse.
let p2_nexus_alias_inst = fn (has_fs: bool, has_net: bool) -> i64 do
  // no-fs+no-net=9, no-fs+has-net=11, has-fs+no-net=11, has-fs+has-net=13
  if has_fs then
    if has_net then return 13 end
    return 11
  end
  if has_net then return 11 end
  return 9
end

let p2_result_type_byte = fn (has_fs: bool, has_net: bool) -> i64 do
  // Byte for result type index: no-fs+no-net=11, no-fs+has-net=19, has-fs+no-net=15, has-fs+has-net=23
  // has-fs indices updated +1 for readdir's directory-entry-stream type.
  if has_fs then
    if has_net then return 23 end
    return 15
  end
  if has_net then return 19 end
  return 11
end

let p2_canon_lift_bytes_nofs_nonet = fn () -> %ByteBuffer do
  return bb.push_bytes(buf: bb.empty(), bytes: [1, 0, 0, 10, 0, 12])
end
let p2_canon_lift_bytes_nofs_hasnet = fn () -> %ByteBuffer do
  return bb.push_bytes(buf: bb.empty(), bytes: [1, 0, 0, 22, 0, 20])
end
let p2_canon_lift_bytes_hasfs_nonet = fn () -> %ByteBuffer do
  // has-fs+no-net: core func 18 = run, lifted as comp func 17 using type 16.
  // +2 core funcs from readdir (read-directory + read-directory-entry canon lowers).
  return bb.push_bytes(buf: bb.empty(), bytes: [1, 0, 0, 18, 0, 16])
end
let p2_canon_lift_bytes_hasfs_hasnet = fn () -> %ByteBuffer do
  // has-fs+has-net: core func 30 = run, lifted as comp func 29 using type 24.
  // +2 core funcs and +1 type from readdir.
  return bb.push_bytes(buf: bb.empty(), bytes: [1, 0, 0, 30, 0, 24])
end

let p2_run_inst_byte = fn (has_fs: bool, has_net: bool) -> i64 do
  // Comp lift func index: no-fs+no-net=9, no-fs+has-net=21, has-fs+no-net=17, has-fs+has-net=29
  // has-fs indices updated +2 for readdir's two extra canon lowers.
  if has_fs then
    if has_net then return 29 end
    return 17
  end
  if has_net then return 21 end
  return 9
end

// Emit canon lift section for run func using has_fs/has_net dispatch.
// Avoids nested if-else-end which Nexus parser rejects.
let p2_build_alias_canon_lift_section = fn (has_fs: bool, has_net: bool, base: %ByteBuffer) -> %ByteBuffer do
  if has_fs then
    if has_net then
      let %lb = p2_canon_lift_bytes_hasfs_hasnet()
      let %sc = cm_wrap_section(section_id: wdefs.cm_sec_canon, content: %lb)
      let %o = bb.push_buf(buf: %base, src: &sc)
      bb.free(buf: %sc)
      return %o
    end
    let %lb = p2_canon_lift_bytes_hasfs_nonet()
    let %sc = cm_wrap_section(section_id: wdefs.cm_sec_canon, content: %lb)
    let %o = bb.push_buf(buf: %base, src: &sc)
    bb.free(buf: %sc)
    return %o
  end
  if has_net then
    let %lb = p2_canon_lift_bytes_nofs_hasnet()
    let %sc = cm_wrap_section(section_id: wdefs.cm_sec_canon, content: %lb)
    let %o = bb.push_buf(buf: %base, src: &sc)
    bb.free(buf: %sc)
    return %o
  end
  let %lb = p2_canon_lift_bytes_nofs_nonet()
  let %sc = cm_wrap_section(section_id: wdefs.cm_sec_canon, content: %lb)
  let %o = bb.push_buf(buf: %base, src: &sc)
  bb.free(buf: %sc)
  return %o
end

let p2_export_inst_byte = fn (has_fs: bool, has_net: bool) -> i64 do
  // Export inst idx: no-fs+no-net=8, no-fs+has-net=11, has-fs+no-net=10, has-fs+has-net=13
  if has_fs then
    if has_net then return 13 end
    return 10
  end
  if has_net then return 11 end
  return 8
end

// Builds alias + type + canon-lift + instance sections (first half of lift+export).
let p2_build_alias_type_canon = fn (has_fs: bool, has_net: bool, run_func_export: string, base: %ByteBuffer) -> %ByteBuffer do
  // Alias run func from nexus instance.
  // 4-way index: no-fs+no-net=9, no-fs+has-net=11, has-fs+no-net=11, has-fs+has-net=13.
  let nexus_inst = p2_nexus_alias_inst(has_fs, has_net)
  let %alias_body = bb.empty()
  let %alias_body = bb.push_uleb128(buf: %alias_body, val: 1)
  let %alias_body = bb.push_bytes(buf: %alias_body, bytes: [0, 0, 1])
  let %alias_body = bb.push_uleb128(buf: %alias_body, val: nexus_inst)
  let %alias_body = bb.push_uleb128(buf: %alias_body, val: str.byte_length(s: run_func_export))
  let %alias_body = bb.push_string(buf: %alias_body, s: run_func_export)
  let %sa = cm_wrap_section(section_id: wdefs.cm_sec_alias, content: %alias_body)
  let %out = bb.push_buf(buf: %base, src: &sa)
  bb.free(buf: %sa)

  // Component types: result<_,_> and func()->result<_,_>.
  // 4-way result type idx: no-fs+no-net=11, no-fs+has-net=19, has-fs+no-net=15, has-fs+has-net=23.
  let result_type_byte = p2_result_type_byte(has_fs, has_net)
  let %type_body = bb.push_bytes(buf: bb.empty(), bytes: [2, 106, 0, 0, 64, 0, 0])
  let %type_body = bb.push_uleb128(buf: %type_body, val: result_type_byte)
  let %st = cm_wrap_section(section_id: wdefs.cm_sec_type, content: %type_body)
  let %out = bb.push_buf(buf: %out, src: &st)
  bb.free(buf: %st)

  // Canon lift run core func → component func (4-way).
  // Use p2_build_alias_canon_lift_section to avoid nested if-else-end which Nexus can't parse.
  let %out = p2_build_alias_canon_lift_section(has_fs, has_net, base: %out)

  // Component instance {run: comp lift func idx} (4-way).
  let run_inst_byte = p2_run_inst_byte(has_fs, has_net)
  let %inst_body = bb.push_bytes(buf: bb.empty(), bytes: [1, 1, 1, 0, 3, 114, 117, 110, 1])
  let %inst_body = bb.push_uleb128(buf: %inst_body, val: run_inst_byte)
  let %si = cm_wrap_section(section_id: wdefs.cm_sec_instance, content: %inst_body)
  let %out = bb.push_buf(buf: %out, src: &si)
  bb.free(buf: %si)

  return %out
end

// Builds export section and assembles the full lift+export result.
let p2_build_instance_lift_export = fn (has_fs: bool, has_net: bool, wasi_iface: string, run_func_export: string) -> %ByteBuffer do
  // Sec 39: core instances — 9/11/11/13 for the 4 has_fs×has_net variants.
  let %core_inst_content = build_p2_core_instance_section(has_fs: has_fs, has_net: has_net)
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_core_instance, content: %core_inst_content)
  let %out = bb.empty()
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  let %out = p2_build_alias_type_canon(has_fs: has_fs, has_net: has_net, run_func_export: run_func_export, base: %out)

  // Export wasi_iface = locally created component instance.
  // 4-way export inst idx: no-fs+no-net=8, no-fs+has-net=11, has-fs+no-net=10, has-fs+has-net=13.
  let export_idx = p2_export_inst_byte(has_fs, has_net)
  let %export_body = bb.empty()
  let %export_body = bb.push_uleb128(buf: %export_body, val: 1)
  let %export_body = bb.push_bytes(buf: %export_body, bytes: [0])
  let %export_body = bb.push_uleb128(buf: %export_body, val: str.byte_length(s: wasi_iface))
  let %export_body = bb.push_string(buf: %export_body, s: wasi_iface)
  let %export_body = bb.push_bytes(buf: %export_body, bytes: [5])
  let %export_body = bb.push_uleb128(buf: %export_body, val: export_idx)
  let %export_body = bb.push_bytes(buf: %export_body, bytes: [0])
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_export, content: %export_body)
  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)

  return %out
end

export let build_p2_component = fn (core_wasm: %ByteBuffer, wasi_iface: string, run_func_export: string, has_fs: bool, has_net: bool) -> %ByteBuffer do
  let %wasi = p2_build_wasi_header_sections()
  let %fs = p2_build_fs_sections(has_fs)
  let %http = p2_build_http_sections(has_fs, has_net)
  let %mods = p2_build_core_modules(core_wasm: %core_wasm, has_fs, has_net)
  let %canon_lo = p2_build_canon_lower(has_fs, has_net)
  let %canon_hi = p2_build_instance_lift_export(has_fs, has_net, wasi_iface, run_func_export)
  let %out = bb.push_buf(buf: %wasi, src: &fs)
  bb.free(buf: %fs)
  let %out = bb.push_buf(buf: %out, src: &http)
  bb.free(buf: %http)
  let %out = bb.push_buf(buf: %out, src: &mods)
  bb.free(buf: %mods)
  let %out = bb.push_buf(buf: %out, src: &canon_lo)
  bb.free(buf: %canon_lo)
  let %out = bb.push_buf(buf: %out, src: &canon_hi)
  bb.free(buf: %canon_hi)
  return %out
end

/** Write the full component-model wrapper for `core_wasm` to `fd` without
 *  allocating a large intermediate buffer.  Frees `core_wasm`.
 */
export let write_p3_component_to_fd = fn (core_wasm: %ByteBuffer, fd: i64) -> unit do
  let core_ptr = bb.raw_data_ptr(buf: &core_wasm)
  let core_len = bb.length(buf: &core_wasm)
  bb.free(buf: %core_wasm)
  write_p3_component_raw_to_fd(core_ptr, core_len, fd)
  return ()
end

/** Write the full component-model wrapper using a raw pointer to core wasm bytes.
 *  Mirrors build_p3_component exactly but streams each section to fd instead
 *  of accumulating into a large ByteBuffer.
 */
export let write_p3_component_raw_to_fd = fn (core_ptr: i64, core_len: i64, fd: i64) -> unit do
  // Magic + version (8 bytes component header)
  // magic: 0 97 115 109 = 0x00 0x61 0x73 0x6d = \0asm
  // cm version bytes from wdefs: 13 0 1 0 = 0x0d 0x00 0x01 0x00
  let %hdr = bb.empty()
  let %hdr = bb.push_bytes(buf: %hdr, bytes: [0, 97, 115, 109])
  let %hdr = bb.push_bytes(buf: %hdr, bytes: [wdefs.cm_version_byte0, wdefs.cm_version_byte1,
                                              wdefs.cm_version_byte2, wdefs.cm_version_byte3])
  write_buf_to_fd(fd, buf: %hdr)

  // Component type section: [type 0] future<u64>
  write_section_to_fd(fd, section_id: wdefs.cm_sec_type,
    content: build_cm_type_section_future_u64())

  // Core module 0 (main): section id + uleb128 length prefix, then raw wasm bytes
  let %mod_hdr = bb.empty()
  let %mod_hdr = bb.push_uleb128(%mod_hdr, val: wdefs.cm_sec_core_module)
  let %mod_hdr = bb.push_uleb128(%mod_hdr, val: core_len)
  write_buf_to_fd(fd, buf: %mod_hdr)
  let _ = fd_write(a_fd: fd, b_content_ptr: cast.i32_of(x: core_ptr), c_content_len: cast.i32_of(x: core_len))

  // Core module 1 (stub): minimal module providing a memory export
  let %stub_bytes = build_p3_stub_module()
  let %stub_hdr = bb.empty()
  let %stub_hdr = bb.push_uleb128(%stub_hdr, val: wdefs.cm_sec_core_module)
  let %stub_hdr = bb.push_uleb128(%stub_hdr, val: bb.length(buf: &stub_bytes))
  write_buf_to_fd(fd, buf: %stub_hdr)
  write_buf_to_fd(fd, buf: %stub_bytes)

  // Core instance 0: instantiate stub (module 1) with no args
  let %stub_inst_body = bb.empty()
  let %stub_inst_body = bb.push_uleb128(%stub_inst_body, val: 1)
  let %stub_inst_body = bb.push_bytes(buf: %stub_inst_body, bytes: [0, 1, 0])
  write_section_to_fd(fd, section_id: wdefs.cm_sec_core_instance, content: %stub_inst_body)

  // Canon section: future.new (core func 0)
  write_section_to_fd(fd, section_id: wdefs.cm_sec_canon,
    content: build_cm_canon_future_new())

  // Alias section: stub_inst(0).memory -> core memory 0
  write_section_to_fd(fd, section_id: wdefs.cm_sec_alias,
    content: build_cm_alias_section_one_memory(instance_idx: 0))

  // Canon section: future.write async (memory 0) (core func 1)
  write_section_to_fd(fd, section_id: wdefs.cm_sec_canon,
    content: build_cm_canon_future_write_async(mem_idx: 0))

  // Alias section: stub_inst(0).memory -> core memory 1
  write_section_to_fd(fd, section_id: wdefs.cm_sec_alias,
    content: build_cm_alias_section_one_memory(instance_idx: 0))

  // Canon section: future.read + drop-writable + drop-readable + task.return + ws.new (core funcs 2-6)
  write_section_to_fd(fd, section_id: wdefs.cm_sec_canon,
    content: build_cm_canon_read_drop_task_ws(mem_idx: 1))

  // Alias section: stub_inst(0).memory -> core memory 2
  write_section_to_fd(fd, section_id: wdefs.cm_sec_alias,
    content: build_cm_alias_section_one_memory(instance_idx: 0))

  // Canon section: ws.wait + ws.drop (core funcs 7-8)
  write_section_to_fd(fd, section_id: wdefs.cm_sec_canon,
    content: build_cm_canon_ws_wait_drop(mem_idx: 2))

  // Final core instance section: FromExports + Instantiate main (module 0)
  // After this, core instance 2 is the main module instance.
  write_section_to_fd(fd, section_id: wdefs.cm_sec_core_instance,
    content: build_cm_core_instance_section_final(main_module_idx: 0))

  // WASI CLI run export:
  // 1. Alias the core `wasi:cli/run@0.2.6#run` func from core instance 2 (main).
  write_section_to_fd(fd, section_id: wdefs.cm_sec_alias,
    content: build_cm_alias_section_run_func(instance_idx: 2))

  // 1b. Alias the core memory from main instance (core instance 2) -> core memory 3.
  //     The canon lift for the run function needs a memory option.
  write_section_to_fd(fd, section_id: wdefs.cm_sec_alias,
    content: build_cm_alias_section_one_memory(instance_idx: 2))

  // 2. Component type section: Result<None,None> + func()->(result).
  write_section_to_fd(fd, section_id: wdefs.cm_sec_type,
    content: build_cm_wasi_run_type_section())

  // 3. Canon lift: lift core func 9 with memory(3) to component func 0, type 2.
  write_section_to_fd(fd, section_id: wdefs.cm_sec_canon,
    content: build_cm_wasi_run_canon_lift())

  // 4. Component instance: {run: func 0}.
  write_section_to_fd(fd, section_id: wdefs.cm_sec_instance,
    content: build_cm_wasi_run_instance())

  // 5. Component export: "wasi:cli/run@0.2.6" = instance 0.
  write_section_to_fd(fd, section_id: wdefs.cm_sec_export,
    content: build_cm_wasi_run_export())

  return ()
end
