  let %out = bb.push_buf(buf: %out, src: &s)
  bb.free(buf: %s)
  // Sec 21d: alias get-environment (comp func 7) and get-arguments (comp func 8) from instance 7
  let %s = cm_wrap_section(section_id: wdefs.cm_sec_alias, content: bb.push_bytes(buf: bb.empty(), bytes: [
    2, 1, 0, 7, 15, 103, 101, 116, 45, 101, 110, 118, 105, 114, 111, 110, 109, 101, 110, 116,
