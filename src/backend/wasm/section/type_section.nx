/**
 * wasm/section/type_section: WASM type section builder with deduplication.
 *
 * Builds the type section payload with duplicate-signature deduplication.
 * Exports DedupedTypes and build_type_section_dedup.
 */

import { ByteBuffer }, * as bb from "std:bytebuffer"
import { StringMap, Found, Missing }, * as sm from "std:stringmap"
import * as str from "std:str"
import { TypeExpr } from "src/common/ast.nx"
import { LirProgram, LirFunction, LirExternal, LirParam } from "src/ir/lir/types.nx"
import * as wdefs from "src/backend/wasm/defs.nx"
import * as wcollect from "src/backend/wasm/collect.nx"
import * as list from "std:list"

/** Emit the wasm valtype bytes for external import params.
 *  When `is_component` is true (foreign component-model module), user-defined
 *  types lower as i32 (canonical-ABI resource handles are i32 table indices).
 */
let emit_ext_param_types = fn (buf: %ByteBuffer, params: [LirParam], is_component: bool) -> %ByteBuffer do
  match params do
    | [] -> %buf
    | LirParam(label: _, name: _, typ: t) :: rest ->
      let %buf = match wdefs.peel_linear(typ: t) do
        | TyString | TyArray(_) ->
          let %b = bb.push_byte(%buf, byte: wdefs.vt_i32)
          bb.push_byte(buf: %b, byte: wdefs.vt_i32)
        | TyChar -> bb.push_byte(%buf, byte: wdefs.vt_i32)
        | TyUserDefined(name: _, args: _) ->
          // In foreign component-model modules user-defined types are resource
          // handles (own<T> / borrow<T>) which lower as i32 table indices.
          if is_component then bb.push_byte(%buf, byte: wdefs.vt_i32)
          else bb.push_byte(%buf, byte: wdefs.type_to_valtype(typ: t))
          end
        | _ -> bb.push_byte(%buf, byte: wdefs.type_to_valtype(typ: t))
      end
      emit_ext_param_types(%buf, params: rest, is_component)
  end
end

/** Map an external return type to its wasm valtype byte.
 *  In foreign component-model modules user-defined return types are resource
 *  handles and lower as i32 (own<T> borrow<T> → i32 table index).
 */
let ext_return_valtype = fn (typ: TypeExpr, is_component: bool) -> i64 do
  match wdefs.peel_linear(typ) do
    | TyChar -> return wdefs.vt_i32
    | TyUserDefined(name: _, args: _) ->
      if is_component then return wdefs.vt_i32
      else return wdefs.type_to_valtype(typ)
      end
    | _ -> return wdefs.type_to_valtype(typ)
  end
end

let emit_ext_return_type = fn (buf: %ByteBuffer, typ: TypeExpr, is_component: bool) -> %ByteBuffer do
  if wdefs.is_unit(typ) then return bb.push_uleb128(%buf, val: 0)
  else
    let %buf = bb.push_uleb128(%buf, val: 1)
    return bb.push_byte(%buf, byte: ext_return_valtype(typ, is_component))
  end
end

let emit_internal_param_types = fn (buf: %ByteBuffer, params: [LirParam]) -> %ByteBuffer do
  match params do
    | [] -> %buf
    | LirParam(label: _, name: _, typ: t) :: rest ->
      emit_internal_param_types(buf: bb.push_byte(%buf, byte: wdefs.type_to_valtype(typ: t)), params: rest)
  end
end

/** Check if an external uses canonical string return (retptr convention).
 *  Component-model externals (wasm_module contains ':') that return string
 *  use void return + retptr param instead of packed i64 return.
 */
let ext_uses_canonical_string_return = fn (wasm_module: string, ret_type: TypeExpr) -> bool do
  if str.contains(s: wasm_module, sub: ":") then
    if wasm_module == "nexus:intrinsic" then return false end
    if str.starts_with(s: wasm_module, prefix: "nexus:runtime/") then return false end
    if str.starts_with(s: wasm_module, prefix: "nexus:std/") then return false end
    match wdefs.peel_linear(typ: ret_type) do
      | TyString -> return true
      | _ -> return false
    end
  end
  return false
end

let emit_one_ext_type = fn (scratch: %ByteBuffer, ext: LirExternal) -> %ByteBuffer do
  let LirExternal(name: _, wasm_module: m, wasm_name: _, params: ps, ret_type: rt, throw_row: _) = ext
  let is_component = wcollect.is_foreign_component_module(m)
  let canonical_str_ret = ext_uses_canonical_string_return(wasm_module: m, ret_type: rt)
  // For canonical string return: add 1 slot for retptr param
  let extra_params = match canonical_str_ret do | true -> 1 | false -> 0 end
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: wcollect.count_ext_param_slots(params: ps) + extra_params)
  let %buf = emit_ext_param_types(%buf, params: ps, is_component)
  return if canonical_str_ret then
    // Canonical string return: retptr (i32) as last param, void return
    let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
    bb.push_uleb128(%buf, val: 0)
  else
    emit_ext_return_type(%buf, typ: rt, is_component)
  end
end

let emit_one_func_type = fn (scratch: %ByteBuffer, func: LirFunction) -> %ByteBuffer do
  let LirFunction(name: _, params: ps, ret_type: rt, body: _, ret: _, span: _) = func
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: list.length(xs: ps))
  let %buf = emit_internal_param_types(%buf, params: ps)
  return emit_ext_return_type(%buf, typ: rt, is_component: false)
end

let emit_n_i64_params = fn (buf: %ByteBuffer, count: i64) -> %ByteBuffer do
  if count <= 0 then return %buf
  else emit_n_i64_params(buf: bb.push_byte(%buf, byte: wdefs.vt_i64), count: count - 1)
  end
end

/** Emit a closure call type: (N+1 x i64) -> i64 (env + N args → result). */
let emit_one_closure_type = fn (scratch: %ByteBuffer, arity: i64) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: arity + 1)
  let %buf = emit_n_i64_params(%buf, count: arity + 1)
  let %buf = bb.push_uleb128(%buf, val: 1)
  return bb.push_byte(%buf, byte: wdefs.vt_i64)
end

// Deduplicates type entries by their raw byte signature. The section buffer
// accumulates only first-occurrence entries; duplicates reuse an existing
// canonical index.
//
// State is threaded through function calls as three parallel values
// (section, seen, n_unique) rather than a single %TypeDedupBuilder record.
// Reason: Nexus's typechecker does not currently preserve linearity for
// user-type fields when destructuring records — a `%MyRecord` field
// destructured cannot be passed back as a `%MyRecord`. Only opaque
// primitive fields (%ByteBuffer, %StringMap) can be relinearized via a
// round-trip through a typed identity function (launder_buf/launder_smap).

let launder_buf = fn (b: %ByteBuffer) -> %ByteBuffer do return %b end
let launder_smap = fn (m: %StringMap) -> %StringMap do return %m end

// Commit-step result: primitive linear fields + canonical index.
type CommitStep = CommitStep(section: %ByteBuffer, seen: %StringMap, n_unique: i64, idx: i64)
// Commit-list result (for loops over exts/funcs/closures): primitives + the
// per-entity canonical index list (in original order).
type CommitList = CommitList(section: %ByteBuffer, seen: %StringMap, n_unique: i64, idxs: [i64])

/** Encode a byte range as decimal-CSV (e.g., "96,2,127,127,1,127,"). UTF-8 safe
 *  regardless of byte values — every emitted character is ASCII digit or comma.
 */
let buf_range_key_go = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, end_pos: i64) -> %ByteBuffer do
  if pos >= end_pos then return %out end
  let b = bb.get_byte(buf: src, idx: pos)
  let %out = bb.push_string(buf: %out, s: str.from_i64(val: b))
  let %out = bb.push_byte(buf: %out, byte: 44)  // ','
  return buf_range_key_go(%out, src, pos: pos + 1, end_pos)
end

let buf_range_to_key = fn (src: &ByteBuffer, end_pos: i64) -> string do
  let %scratch = bb.empty()
  let %scratch = buf_range_key_go(out: %scratch, src, pos: 0, end_pos)
  let key = bb.to_string(buf: &scratch)
  bb.free(buf: %scratch)
  return key
end

/** Commit a scratch buffer (containing exactly one type entry starting at 0).
 *  Frees scratch. Returns updated (section, seen, n_unique) + the canonical
 *  index for the entry (existing slot if the signature was already seen, else
 *  the newly-assigned slot).
 */
let td_commit = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, scratch: %ByteBuffer) -> %CommitStep do
  let slen = bb.length(buf: &scratch)
  let key = buf_range_to_key(src: &scratch, end_pos: slen)
  match sm.get(map: &seen, key) do
    | Found(value: canonical_idx) ->
      bb.free(buf: %scratch)
      let %r = CommitStep(%section, %seen, n_unique, idx: canonical_idx)
      return %r
    | Missing ->
      let %section = bb.copy_range(dst: %section, src: &scratch, start: 0, end_pos: slen)
      bb.free(buf: %scratch)
      let %seen = sm.put(map: %seen, key, value: n_unique)
      let %r = CommitStep(%section, %seen, n_unique: n_unique + 1, idx: n_unique)
      return %r
  end
end

let commit_exts_go = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, exts: [LirExternal], acc: [i64]) -> %CommitList do
  match exts do
    | [] ->
      let %r = CommitList(%section, %seen, n_unique, idxs: list.reverse(xs: acc))
      return %r
    | e :: rest ->
      let %scratch = bb.empty()
      let %scratch = emit_one_ext_type(%scratch, ext: e)
      let CommitStep(%section, %seen, n_unique: nu, idx: ti) = td_commit(%section, %seen, n_unique, %scratch)
      let %section = launder_buf(b: %section)
      let %seen = launder_smap(m: %seen)
      return commit_exts_go(%section, %seen, n_unique: nu, exts: rest, acc: ti :: acc)
  end
end

let commit_funcs_go = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, funcs: [LirFunction], acc: [i64]) -> %CommitList do
  match funcs do
    | [] ->
      let %r = CommitList(%section, %seen, n_unique, idxs: list.reverse(xs: acc))
      return %r
    | f :: rest ->
      let %scratch = bb.empty()
      let %scratch = emit_one_func_type(%scratch, func: f)
      let CommitStep(%section, %seen, n_unique: nu, idx: ti) = td_commit(%section, %seen, n_unique, %scratch)
      let %section = launder_buf(b: %section)
      let %seen = launder_smap(m: %seen)
      return commit_funcs_go(%section, %seen, n_unique: nu, funcs: rest, acc: ti :: acc)
  end
end

let commit_closures_go = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, arities: [i64], acc: [i64]) -> %CommitList do
  match arities do
    | [] ->
      let %r = CommitList(%section, %seen, n_unique, idxs: list.reverse(xs: acc))
      return %r
    | a :: rest ->
      let %scratch = bb.empty()
      let %scratch = emit_one_closure_type(%scratch, arity: a)
      let CommitStep(%section, %seen, n_unique: nu, idx: ti) = td_commit(%section, %seen, n_unique, %scratch)
      let %section = launder_buf(b: %section)
      let %seen = launder_smap(m: %seen)
      return commit_closures_go(%section, %seen, n_unique: nu, arities: rest, acc: ti :: acc)
  end
end

let emit_wasi_run_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 0)
  return bb.push_uleb128(%buf, val: 0)
end

/** For p3-component mode: wasi_run wrapper returns i32 (0=ok) to satisfy
 *  the component canon lift for `result<none,none>`. */
let emit_wasi_run_type_scratch_p3 = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 0)
  let %buf = bb.push_uleb128(%buf, val: 1)
  return bb.push_byte(buf: %buf, byte: wdefs.vt_i32)
end

let emit_eh_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i64)
  return bb.push_uleb128(%buf, val: 0)
end

let emit_alloc_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
  let %buf = bb.push_uleb128(%buf, val: 1)
  return bb.push_byte(%buf, byte: wdefs.vt_i32)
end

/** `() -> i32` for `__nx_alloc_mark` — snapshots the routed allocator's
 *  LIFO bookkeeping count.
 */
let emit_alloc_mark_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 0)
  let %buf = bb.push_uleb128(%buf, val: 1)
  return bb.push_byte(%buf, byte: wdefs.vt_i32)
end

/** `(i32) -> ()` for `__nx_alloc_reset(mark)` — pops every routed allocation
 *  past `mark` in LIFO order.
 */
let emit_alloc_reset_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 1)
  let %buf = bb.push_byte(%buf, byte: wdefs.vt_i32)
  return bb.push_uleb128(%buf, val: 0)
end

let emit_cabi_type_scratch = fn (scratch: %ByteBuffer) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 4)
  let %buf = bb.push_bytes(%buf, bytes: [wdefs.vt_i32, wdefs.vt_i32, wdefs.vt_i32, wdefs.vt_i32])
  let %buf = bb.push_uleb128(%buf, val: 1)
  return bb.push_byte(%buf, byte: wdefs.vt_i32)
end

/** DedupedTypes carries the built type section payload plus per-entity
 *  canonical type indices. Sentinel -1 for entries not in this module.
 *  `alloc_mark_type_idx` / `alloc_reset_type_idx` index the `() -> i32` and
 *  `(i32) -> ()` shapes used by the routed allocator's mark/reset hooks.
 */
export type DedupedTypes = DedupedTypes(
  section: %ByteBuffer,
  count: i64,
  ext_type_idxs: [i64],
  func_type_idxs: [i64],
  wasi_run_type_idx: i64,
  exn_tag_type_idx: i64,
  ss_tag_type_idx: i64,
  alloc_type_idx: i64,
  alloc_mark_type_idx: i64,
  alloc_reset_type_idx: i64,
  cabi_type_idx: i64,
  closure_type_idxs: [i64],
  ss_cont_type_idx: i64,
  ss_dispatch_block_type_idx: i64
)

// Helper: skip a commit (returning CommitStep with idx = -1).
// Used to pass state through when a feature is not enabled.
let commit_skip = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64) -> %CommitStep do
  let %r = CommitStep(%section, %seen, n_unique, idx: -1)
  return %r
end

let commit_eh_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_eh: bool) -> %CommitStep do
  if has_eh then
    let %scratch = bb.empty()
    let %scratch = emit_eh_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

/** Commit the (i64) -> () func type used by stack-switching tags. If the
 *  program also has EH, this reuses the EH tag type via dedup.
 */
let commit_i64_to_void_type_for_ss = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_ss: bool) -> %CommitStep do
  if has_ss then
    let %scratch = bb.empty()
    let %scratch = emit_eh_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

/** `(cont $body_func_type)` form: byte 0x5d (form_cont = 93), then LEB
 *  of the body's func-type index.
 */
let emit_cont_type_scratch = fn (scratch: %ByteBuffer, body_func_type_idx: i64) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.form_cont)
  return bb.push_sleb128(%buf, val: body_func_type_idx)
end

/** Commit a fresh () -> () func type for the cont's body, bypassing dedup.
 *  Reusing wasi_run_idx is unreliable because the dedup map's behaviour for
 *  shared signatures is inconsistent for our use-case.
 */
let commit_ss_body_fn_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_ss: bool) -> %CommitStep do
  // PROBE: ALWAYS commit, ignore has_ss
  let %scratch = bb.empty()
  let %scratch = emit_wasi_run_type_scratch(%scratch)
  let slen = bb.length(buf: &scratch)
  let %section = bb.copy_range(dst: %section, src: &scratch, start: 0, end_pos: slen)
  bb.free(buf: %scratch)
  let %r = CommitStep(%section, %seen, n_unique: n_unique + 1, idx: n_unique)
  return %r
end

let commit_ss_cont_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_ss: bool, body_func_type_idx: i64) -> %CommitStep do
  if !has_ss then return commit_skip(%section, %seen, n_unique) end
  if body_func_type_idx < 0 then return commit_skip(%section, %seen, n_unique) end
  let %scratch = bb.empty()
  let %scratch = emit_cont_type_scratch(%scratch, body_func_type_idx)
  let slen = bb.length(buf: &scratch)
  let %section = bb.copy_range(dst: %section, src: &scratch, start: 0, end_pos: slen)
  bb.free(buf: %scratch)
  let %r = CommitStep(%section, %seen, n_unique: n_unique + 1, idx: n_unique)
  return %r
end

/** On-clause block type: returns (i64, ref null $cont_t). When `resume`'s
 *  on-clause fires, control transfers to the labeled block's end, pushing
 *  (payload, new-cont) onto the block's result stack.
 *  Encoding: 0x60 (func form) + 0 params + 2 results + i64 (0x7e) + ref-null
 *  heap (0x63 + signed-LEB cont_type_idx).
 */
let emit_ss_dispatch_block_type_scratch = fn (scratch: %ByteBuffer, cont_type_idx: i64) -> %ByteBuffer do
  let %buf = bb.push_byte(buf: %scratch, byte: wdefs.wasm_form_func)
  let %buf = bb.push_uleb128(%buf, val: 0)
  let %buf = bb.push_uleb128(%buf, val: 2)
  let %buf = bb.push_bytes(%buf, bytes: [wdefs.vt_i64, wdefs.vt_ref_null_ht])
  return bb.push_sleb128(%buf, val: cont_type_idx)
end

let commit_ss_dispatch_block_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_ss: bool, cont_type_idx: i64) -> %CommitStep do
  if !has_ss then return commit_skip(%section, %seen, n_unique) end
  if cont_type_idx < 0 then return commit_skip(%section, %seen, n_unique) end
  let %scratch = bb.empty()
  let %scratch = emit_ss_dispatch_block_type_scratch(%scratch, cont_type_idx)
  let slen = bb.length(buf: &scratch)
  let %section = bb.copy_range(dst: %section, src: &scratch, start: 0, end_pos: slen)
  bb.free(buf: %scratch)
  let %r = CommitStep(%section, %seen, n_unique: n_unique + 1, idx: n_unique)
  return %r
end

let commit_alloc_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_alloc: bool) -> %CommitStep do
  if has_alloc then
    let %scratch = bb.empty()
    let %scratch = emit_alloc_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

let commit_alloc_mark_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_alloc: bool) -> %CommitStep do
  if has_alloc then
    let %scratch = bb.empty()
    let %scratch = emit_alloc_mark_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

let commit_alloc_reset_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_alloc: bool) -> %CommitStep do
  if has_alloc then
    let %scratch = bb.empty()
    let %scratch = emit_alloc_reset_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

let commit_cabi_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, has_cabi: bool) -> %CommitStep do
  if has_cabi then
    let %scratch = bb.empty()
    let %scratch = emit_cabi_type_scratch(%scratch)
    return td_commit(%section, %seen, n_unique, %scratch)
  end
  return commit_skip(%section, %seen, n_unique)
end

let commit_wasi_run_type = fn (section: %ByteBuffer, seen: %StringMap, n_unique: i64, p3_component: bool) -> %CommitStep do
  let %scratch = bb.empty()
  let %scratch = if p3_component then
    emit_wasi_run_type_scratch_p3(%scratch)
  else
    emit_wasi_run_type_scratch(%scratch)
  end
  return td_commit(%section, %seen, n_unique, %scratch)
end

/** Build the type section with duplicate-signature deduplication.
 *  Returns the vector-count-prefixed payload + per-entity canonical type indices.
 *  The cont-type wrapping the lifted inject body reuses wasi_run_type's
 *  `() -> ()` signature today (all lifted bodies are unit-returning at MVP);
 *  extension to varied signatures is future work.
 */
export let build_type_section_dedup = fn (program: LirProgram, has_eh: bool, has_ss: bool,
                                          has_alloc: bool,
                                          has_cabi_realloc: bool, closure_arities: [i64],
                                          p3_component: bool) -> %DedupedTypes do
  let LirProgram(functions: funcs, externals: exts) = program
  let %section = bb.empty()
  let %seen = sm.empty()

  let CommitList(%section, %seen, n_unique: nu_a, idxs: ext_idxs) =
    commit_exts_go(%section, %seen, n_unique: 0, exts, acc: [])
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)
  let CommitList(%section, %seen, n_unique: nu_b, idxs: func_idxs) =
    commit_funcs_go(%section, %seen, n_unique: nu_a, funcs, acc: [])
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu_c, idx: wasi_run_idx_raw) =
    commit_wasi_run_type(%section, %seen, n_unique: nu_b, p3_component)
  let wasi_run_idx = wasi_run_idx_raw
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu_d, idx: exn_tag_idx) =
    commit_eh_type(%section, %seen, n_unique: nu_c, has_eh)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu_e, idx: ss_tag_idx) =
    commit_i64_to_void_type_for_ss(%section, %seen, n_unique: nu_d, has_ss)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu, idx: alloc_idx) =
    commit_alloc_type(%section, %seen, n_unique: nu_e, has_alloc)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu, idx: alloc_mark_idx) =
    commit_alloc_mark_type(%section, %seen, n_unique: nu, has_alloc)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu, idx: alloc_reset_idx) =
    commit_alloc_reset_type(%section, %seen, n_unique: nu, has_alloc)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: nu, idx: cabi_idx) =
    commit_cabi_type(%section, %seen, n_unique: nu, has_cabi: has_cabi_realloc)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitList(%section, %seen, n_unique: n_after_closures, idxs: closure_idxs) =
    commit_closures_go(%section, %seen, n_unique: nu, arities: closure_arities, acc: [])
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  // Stack-switching types committed AT THE END so their slot indices match
  // n_unique-after-closures. body_fn, cont, dispatch in that order.
  let CommitStep(%section, %seen, n_unique: n_after_body_fn, idx: ss_body_fn_idx) =
    commit_ss_body_fn_type(%section, %seen, n_unique: n_after_closures, has_ss)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: n_after_cont, idx: ss_cont_idx) =
    commit_ss_cont_type(%section, %seen, n_unique: n_after_body_fn, has_ss, body_func_type_idx: ss_body_fn_idx)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)

  let CommitStep(%section, %seen, n_unique: n, idx: ss_dispatch_idx) =
    commit_ss_dispatch_block_type(%section, %seen, n_unique: n_after_cont, has_ss, cont_type_idx: ss_cont_idx)
  let %section = launder_buf(b: %section)
  let %seen = launder_smap(m: %seen)
  sm.free(map: %seen)

  // Finalize: prepend vector-count to section bytes.
  let %final = bb.empty()
  let %final = bb.push_uleb128(buf: %final, val: n)
  let %final = bb.push_buf(dst: %final, src: &section)
  bb.free(buf: %section)
  let %r = DedupedTypes(
    section: %final,
    count: n,
    ext_type_idxs: ext_idxs,
    func_type_idxs: func_idxs,
    wasi_run_type_idx: wasi_run_idx,
    exn_tag_type_idx: exn_tag_idx,
    ss_tag_type_idx: ss_tag_idx,
    alloc_type_idx: alloc_idx,
    alloc_mark_type_idx: alloc_mark_idx,
    alloc_reset_type_idx: alloc_reset_idx,
    cabi_type_idx: cabi_idx,
    closure_type_idxs: closure_idxs,
    ss_cont_type_idx: ss_cont_idx,
    ss_dispatch_block_type_idx: ss_dispatch_idx
  )
  return %r
end
