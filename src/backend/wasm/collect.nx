/**
 * wasm/collect: Pre-codegen analysis passes.
 *
 * Collects string literals, detects heap usage, analyzes external ABIs,
 * determines memory mode, and collects local variables from "LIR."
 */

import { TypeExpr } from "src/syntax/ast.nx"
import {
  LirFunction,
  LirStmt,
  LirExpr,
  LirAtom,
  LirExternal,
  LirParam,
  LirCallArg,
  LirNamedAtom
} from "src/ir/lir/types.nx"
import { LocalEntry, StringEntry }, * as wdefs from "src/backend/wasm/defs.nx"
import * as list from "std:list"

import * as str from "std:str"
import { HashMap }, * as hmap from "std:hashmap"
import { Map }, * as map from "std:collection/map"

let collect_atom_strings = fn (atom: LirAtom, acc: [ string ]) -> [ string ] do
  if let LirAtomString(val: s) = atom then
    s :: acc
  else
    acc
  end
end

let collect_call_arg_strings = fn (args: [ LirCallArg ], acc: [ string ]) -> [ string ] do
  match args do
    | [] -> acc
    | LirCallArg(label: _, value: v) :: rest ->
      collect_call_arg_strings(args: rest, acc: collect_atom_strings(atom: v, acc))
  end
end

let collect_atom_list_strings = fn (atoms: [ LirAtom ], acc: [ string ]) -> [ string ] do
  match atoms do
    | [] -> acc
    | a :: rest ->
      collect_atom_list_strings(atoms: rest, acc: collect_atom_strings(atom: a, acc))
  end
end

let collect_named_atom_strings = fn (fields: [ LirNamedAtom ], acc: [ string ]) -> [ string ] do
  match fields do
    | [] -> acc
    | LirNamedAtom(name: _, value: v) :: rest ->
      collect_named_atom_strings(fields: rest, acc: collect_atom_strings(atom: v, acc))
  end
end

let collect_expr_strings = fn (expr: LirExpr, acc: [ string ]) -> [ string ] do
  match expr do
    | LirExprAtom(atom: a) -> collect_atom_strings(atom: a, acc)
    | LirExprBinary(op: _, lhs: l, rhs: r, typ: _) ->
      collect_atom_strings(atom: r, acc: collect_atom_strings(atom: l, acc))
    | LirExprCall(
      func: _,
      args,
      typ: _
    ) | LirExprTailCall(func: _, args, typ: _) -> collect_call_arg_strings(args, acc)
    | LirExprConstructor(name: _, args: atoms, typ: _) -> collect_atom_list_strings(atoms, acc)
    | LirExprRecord(fields, typ: _) -> collect_named_atom_strings(fields, acc)
    | LirExprObjectTag(value: v, typ: _)
    | LirExprObjectField(value: v, index: _, typ: _)
    | LirExprRaise(value: v, typ: _)
    | LirExprForce(value: v, typ: _) -> collect_atom_strings(atom: v, acc)
    | LirExprMakeClosure(
      func_name: _,
      captures: caps,
      typ: _
    ) -> collect_atom_list_strings(atoms: caps, acc)
    | LirExprCallClosure(closure: c, args, typ: _) ->
      collect_call_arg_strings(args, acc: collect_atom_strings(atom: c, acc))
    | LirExprSuspend(tag_name: _, payload: p, typ: _) -> collect_atom_strings(atom: p, acc)
    | LirExprResume(cont: c, value: v, typ: _) ->
      collect_atom_strings(atom: v, acc: collect_atom_strings(atom: c, acc))
    | LirExprContNew(
      func_ref: _,
      typ: _
    ) | LirExprInjectResume(body_fn: _, arm_fns: _, arm_tags: _, typ: _) -> acc
  end
end

let collect_stmt_strings = fn (stmt: LirStmt, acc: [ string ]) -> [ string ] do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) ->
      collect_expr_strings(expr: e, acc)
    | LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      collect_stmts_strings(
        stmts: eb,
        acc: collect_stmts_strings(stmts: tb, acc: collect_atom_strings(atom: c, acc))
      )
    | LirStmtIfReturn(
      cond: c,
      then_body: tb,
      then_ret: tr,
      else_body: eb,
      else_ret: er,
      ret_type: _
    ) ->
      let acc2 = collect_stmts_strings(
        stmts: eb,
        acc: collect_atom_strings(
          atom: tr,
          acc: collect_stmts_strings(stmts: tb, acc: collect_atom_strings(atom: c, acc))
        )
      )
      match er do
        | Some(val: a) -> collect_atom_strings(atom: a, acc: acc2)
        | None -> acc2
      end
    | LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      collect_stmts_strings(
        stmts: b,
        acc: collect_atom_strings(atom: c, acc: collect_stmts_strings(stmts: cs, acc))
      )
    | LirStmtTryCatch(body: b, body_ret: br, catch_param: _, catch_param_typ: _,
                          catch_body: cb, catch_ret: cr) ->
      let acc2 = match br do
        | Some(val: a) -> collect_atom_strings(atom: a, acc: collect_stmts_strings(stmts: b, acc))
        | None -> collect_stmts_strings(stmts: b, acc)
      end
      let acc3 = collect_stmts_strings(stmts: cb, acc: acc2)
      match cr do
        | Some(val: a) -> collect_atom_strings(atom: a, acc: acc3)
        | None -> acc3
      end
  end
end

let collect_stmts_strings = fn (stmts: [ LirStmt ], acc: [ string ]) -> [ string ] do
  match stmts do
    | [] -> acc
    | s :: rest ->
      collect_stmts_strings(stmts: rest, acc: collect_stmt_strings(stmt: s, acc))
  end
end

let collect_func_strings = fn (func: LirFunction, acc: [ string ]) -> [ string ] do
  let LirFunction(name: _, params: _, ret_type: _, body: b, ret: r, span: _) = func
  collect_atom_strings(atom: r, acc: collect_stmts_strings(stmts: b, acc))
end

/** Walk every function body and accumulate the values of every `LirAtomString` literal encountered, prepending into `acc`. Caller is responsible for dedup; pairs with `build_string_entries` to produce the wasm data segment. */
export let collect_program_strings = fn (funcs: [ LirFunction ], acc: [ string ]) -> [ string ] do
  match funcs do
    | [] -> acc
    | f :: rest ->
      collect_program_strings(funcs: rest, acc: collect_func_strings(func: f, acc))
  end
end

/** Lexicographic string comparison via char_code. Returns -1, 0, or 1. */
let str_compare_go = fn (a: string, b: string, idx: i64, alen: i64, blen: i64) -> i64 do
  if idx == alen then
    if idx == blen then return 0
    else return -1
    end
  end
  if idx == blen then return 1 end
  let ca = str.char_code(s: a, idx)
  let cb = str.char_code(s: b, idx)
  if ca < cb then return -1 end
  if ca > cb then return 1 end
  return str_compare_go(a, b, idx: idx + 1, alen, blen)
end

let str_compare = fn (a: string, b: string) -> i64 do
  return str_compare_go(a, b, idx: 0, alen: str.length(s: a), blen: str.length(s: b))
end

let string_seen_sorted = fn (s: string, seen: [ string ]) -> bool do
  match seen do
    | [] -> false
    | x :: rest ->
      let cmp = str_compare(a: s, b: x)
      return if cmp < 0 then false
      else if cmp == 0 then true
      else string_seen_sorted(s, seen: rest)
      end
  end
end

let insert_sorted_string = fn (s: string, xs: [ string ]) -> [ string ] do
  return insert_sorted_string_go(s, lst: xs, acc: [])
end

let insert_sorted_string_go = fn (s: string, lst: [ string ], acc: [ string ]) -> [ string ] do
  match lst do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: [ s ])
    | x :: rest ->
      if str_compare(a: s, b: x) < 0 then
        return list.concat(xs: list.reverse(xs: acc), ys: s :: lst)
      else
        return insert_sorted_string_go(s, lst: rest, acc: x :: acc)
      end
  end
end

/** Deduplicate `strings` (lexicographic sorted-list set) and lay them out at consecutive byte offsets starting at `next_offset`, producing one `StringEntry(value, offset, len)` per unique string in encounter order. The `acc` parameter is an in-progress accumulator threaded by the recursive worker. */
export let build_string_entries = fn (
  strings: [ string ],
  next_offset: i64,
  acc: [ StringEntry ]
) -> [ StringEntry ] do
  return build_string_entries_go(strings, next_offset, acc: [], seen: [])
end

let build_string_entries_go = fn (
  strings: [ string ],
  next_offset: i64,
  acc: [ StringEntry ],
  seen: [ string ]
) -> [ StringEntry ] do
  match strings do
    | [] -> list.reverse(xs: acc)
    | s :: rest ->
      if string_seen_sorted(s, seen) then
        return build_string_entries_go(strings: rest, next_offset, acc, seen)
      end
      let slen = str.byte_length(s)
      return build_string_entries_go(strings: rest, next_offset: next_offset + slen,
                           acc: StringEntry(value: s, offset: next_offset, slen) :: acc,
                           seen: insert_sorted_string(s, xs: seen))
  end
end

/** Byte address immediately past the last `StringEntry` (i.e. `offset + slen` of the final entry); used to position the heap base right after the string-literal pool. Returns 0 for an empty list. */
export let compute_last_string_end = fn (entries: [ StringEntry ]) -> i64 do
  match entries do
    | [] -> 0
    | [ StringEntry(value: _, offset: off, slen: sl) ] -> off + sl
    | _ :: rest -> compute_last_string_end(entries: rest)
  end
end

let expr_uses_heap = fn (expr: LirExpr) -> bool do
  match expr do
    | LirExprConstructor(_) | LirExprRecord(_)
    | LirExprObjectTag(_) | LirExprObjectField(_)
    | LirExprBinary(op: OpConcat, lhs: _, rhs: _, typ: _)
    | LirExprMakeClosure(_) -> true
    | LirExprBinary(op: OpAdd, lhs: _, rhs: _, typ: t) ->
      match wdefs.peel_linear(typ: t) do
        | TyString -> true
        | _ -> false
      end
    | _ -> false
  end
end

let stmt_uses_heap = fn (stmt: LirStmt) -> bool do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) -> expr_uses_heap(expr: e)
    | LirStmtIf(cond: _, then_body: tb, else_body: eb)
    | LirStmtIfReturn(
      cond: _,
      then_body: tb,
      then_ret: _,
      else_body: eb,
      else_ret: _,
      ret_type: _
    ) ->
      stmts_use_heap(stmts: tb) || stmts_use_heap(stmts: eb)
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      stmts_use_heap(stmts: cs) || stmts_use_heap(stmts: b)
    | LirStmtTryCatch(body: b, body_ret: _, catch_param: _, catch_param_typ: _,
                          catch_body: cb, catch_ret: _) ->
      stmts_use_heap(stmts: b) || stmts_use_heap(stmts: cb)
  end
end

let stmts_use_heap = fn (stmts: [ LirStmt ]) -> bool do
  match stmts do
    | [] -> false
    | s :: rest ->
      if stmt_uses_heap(stmt: s) then return true end
      return stmts_use_heap(stmts: rest)
  end
end

/** True iff the program contains any LIR construct that allocates on the bump heap — constructors, records, object ops, string concat / add, or closure capture. Drives whether the wasm output needs a heap-pointer global and `memory.grow` plumbing. */
export let program_uses_heap = fn (funcs: [ LirFunction ]) -> bool do
  match funcs do
    | [] -> false
    | LirFunction(name: _, params: _, ret_type: _, body: b, ret: _, span: _) :: rest ->
      if stmts_use_heap(stmts: b) then return true end
      return program_uses_heap(funcs: rest)
  end
end

let expr_needs_eh = fn (expr: LirExpr) -> bool do
  match expr do
    | LirExprRaise(_) -> true
    | LirExprForce(_) | _ -> false
  end
end

let stmt_needs_eh = fn (stmt: LirStmt) -> bool do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) -> expr_needs_eh(expr: e)
    | LirStmtIf(cond: _, then_body: tb, else_body: eb)
    | LirStmtIfReturn(
      cond: _,
      then_body: tb,
      then_ret: _,
      else_body: eb,
      else_ret: _,
      ret_type: _
    ) ->
      stmts_need_eh(stmts: tb) || stmts_need_eh(stmts: eb)
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      stmts_need_eh(stmts: cs) || stmts_need_eh(stmts: b)
    | LirStmtTryCatch(_) -> true
  end
end

let stmts_need_eh = fn (stmts: [ LirStmt ]) -> bool do
  match stmts do
    | [] -> false
    | s :: rest ->
      if stmt_needs_eh(stmt: s) then return true end
      return stmts_need_eh(stmts: rest)
  end
end

/** True iff any `LirExprRaise` or `LirStmtTryCatch` appears anywhere in the program; codegen uses this to decide whether the wasm output should import the exception-handling extension's tag and emit `try_table`/`throw` instructions. */
export let program_needs_eh = fn (funcs: [ LirFunction ]) -> bool do
  match funcs do
    | [] -> false
    | LirFunction(name: _, params: _, ret_type: _, body: b, ret: _, span: _) :: rest ->
      if stmts_need_eh(stmts: b) then return true end
      return program_needs_eh(funcs: rest)
  end
end

let expr_needs_ss = fn (expr: LirExpr) -> bool do
  match expr do
    | LirExprSuspend(_) | LirExprResume(_)
    | LirExprContNew(_) | LirExprInjectResume(_) -> true
    | _ -> false
  end
end

let stmt_needs_ss = fn (stmt: LirStmt) -> bool do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) -> expr_needs_ss(expr: e)
    | LirStmtIf(cond: _, then_body: tb, else_body: eb)
    | LirStmtIfReturn(
      cond: _,
      then_body: tb,
      then_ret: _,
      else_body: eb,
      else_ret: _,
      ret_type: _
    ) ->
      stmts_need_ss(stmts: tb) || stmts_need_ss(stmts: eb)
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      stmts_need_ss(stmts: cs) || stmts_need_ss(stmts: b)
    | LirStmtTryCatch(
      body: b,
      body_ret: _,
      catch_param: _,
      catch_param_typ: _,
      catch_body: cb,
      catch_ret: _
    ) ->
      stmts_need_ss(stmts: b) || stmts_need_ss(stmts: cb)
  end
end

let stmts_need_ss = fn (stmts: [ LirStmt ]) -> bool do
  match stmts do
    | [] -> false
    | s :: rest ->
      if stmt_needs_ss(stmt: s) then return true end
      return stmts_need_ss(stmts: rest)
  end
end

/** True iff the program contains any stack-switching construct (`suspend` / `resume` / `cont.new` / `inject` resume dispatch); gates emission of the stack-switching proposal's type table and runtime globals. */
export let program_needs_stack_switching = fn (funcs: [ LirFunction ]) -> bool do
  match funcs do
    | [] -> false
    | LirFunction(name: _, params: _, ret_type: _, body: b, ret: _, span: _) :: rest ->
      if stmts_need_ss(stmts: b) then return true end
      return program_needs_stack_switching(funcs: rest)
  end
end

//
// Each `MirSuspend(tag_name)` and `LirExprInjectResume.arm_tags` entry in the
// program identifies a `<cap>::<method>` cap method. We allocate one wasm
// tag per distinct cap method and use `on tag_i → label_i` clauses on the
// `resume` instruction so the dispatcher can branch directly to the matching
// arm — collapsing all methods onto one tag would route every suspend to
// `afs[0]` and break multi-method handlers.

// ALL match arms below use explicit `return`. Mixed return / non-return arms
// trigger an apparent infinite loop on bootstrap-self-compile (root cause
// not nailed; defensive uniformity).

// Collection happens in two phases:
//   1. Walk the program appending every tag occurrence into a raw list
//      (with duplicates) — O(N) without per-step membership probing.
//   2. dedup_tags reduces to first-seen entries using a Map<string, i64> for
//      O(1) membership — one O(N) pass instead of the previous O(N²)
//      str_list_contains-driven merge.
//
// The dedup map is also reused (re-computed cheaply at codegen time) to
// answer `lookup_tag_idx` in O(1) — see `build_tag_idx_map` below.

let collect_expr_tag_names = fn (expr: LirExpr, acc: [ string ]) -> [ string ] do
  match expr do
    | LirExprSuspend(tag_name: tn, payload: _, typ: _) ->
      return tn :: acc
    | LirExprInjectResume(body_fn: _, arm_fns: _, arm_tags: ats, typ: _) ->
      // Include arm declarations even if no suspend uses them. A handler may
      // declare arms (yield, spawn) but a particular fixture only uses one;
      // the dispatcher still emits on-clauses for all, so all need a tag.
      return prepend_all(xs: ats, acc)
    | _ -> return acc
  end
end

let prepend_all = fn (xs: [ string ], acc: [ string ]) -> [ string ] do
  match xs do
    | [] -> return acc
    | x :: rest -> return prepend_all(xs: rest, acc: x :: acc)
  end
end

let collect_stmt_tag_names = fn (stmt: LirStmt, acc: [ string ]) -> [ string ] do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) -> return collect_expr_tag_names(expr: e, acc)
    | LirStmtIf(cond: _, then_body: tb, else_body: eb)
    | LirStmtIfReturn(
      cond: _,
      then_body: tb,
      then_ret: _,
      else_body: eb,
      else_ret: _,
      ret_type: _
    ) ->
      let acc1 = collect_stmts_tag_names(stmts: tb, acc)
      return collect_stmts_tag_names(stmts: eb, acc: acc1)
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      let acc1 = collect_stmts_tag_names(stmts: cs, acc)
      return collect_stmts_tag_names(stmts: b, acc: acc1)
    | LirStmtTryCatch(
      body: b,
      body_ret: _,
      catch_param: _,
      catch_param_typ: _,
      catch_body: cb,
      catch_ret: _
    ) ->
      let acc1 = collect_stmts_tag_names(stmts: b, acc)
      return collect_stmts_tag_names(stmts: cb, acc: acc1)
  end
end

let collect_stmts_tag_names = fn (stmts: [ LirStmt ], acc: [ string ]) -> [ string ] do
  match stmts do
    | [] -> return acc
    | s :: rest ->
      let acc1 = collect_stmt_tag_names(stmt: s, acc)
      return collect_stmts_tag_names(stmts: rest, acc: acc1)
  end
end

// O(N) dedup that preserves the prior first-define-wins-then-prepended
// order: walk `raw` in encounter order; for each tag, if it's the first
// time we see it, prepend onto `out_acc`; afterwards `out_acc` is the
// reversed deduped order, exactly matching the previous merge_tag_list
// invariant (older entries end up deeper in `acc`).
let dedup_tags = fn (raw: [ string ]) -> [ string ] do
  return dedup_tags_go(raw, seen: map.string_map(), out_acc: [])
end

let dedup_tags_go = fn (
  raw: [ string ],
  seen: Map<string,
  i64>,
  out_acc: [ string ]
) -> [ string ] do
  match raw do
    | [] -> return out_acc
    | x :: rest ->
      if map.contains(m: seen, k: x) then
        return dedup_tags_go(raw: rest, seen, out_acc)
      end
      let seen2 = map.insert(m: seen, k: x, v: 0)
      return dedup_tags_go(raw: rest, seen: seen2, out_acc: x :: out_acc)
  end
end

/** Walk the program for every `LirExprSuspend.tag_name` and `LirExprInjectResume.arm_tags` occurrence and return the deduped list in first-encounter order. Each entry needs its own wasm tag so resume `on tag_i → label_i` clauses can branch directly to the matching arm. */
export let collect_program_tag_names = fn (funcs: [ LirFunction ]) -> [ string ] do
  // Phase 1: collect raw (with duplicates), in reverse-encounter order on `acc`.
  let raw = collect_program_tag_names_go(funcs, acc: [])
  // Phase 2: dedup. The previous merge_tag_list pushed unique tags onto the
  // head as they were first encountered — i.e. result order = first-seen,
  // newest-prepended. `dedup_tags` walks `raw` in the same order and
  // prepends on first sight, preserving that exact ordering.
  return dedup_tags(raw: list.reverse(xs: raw))
end

let collect_program_tag_names_go = fn (funcs: [ LirFunction ], acc: [ string ]) -> [ string ] do
  match funcs do
    | [] -> return acc
    | LirFunction(name: _, params: _, ret_type: _, body: b, ret: _, span: _) :: rest ->
      let acc1 = collect_stmts_tag_names(stmts: b, acc)
      return collect_program_tag_names_go(funcs: rest, acc: acc1)
  end
end

/** Build a `tag_name -> position` map for O(1) `lookup_tag_idx_map`; position is the index the prior linear scan would have returned. First-occurrence wins so the indexing matches `collect_program_tag_names`'s ordering. */
export let build_tag_idx_map = fn (tag_names: [ string ]) -> Map<string, i64> do
  return build_tag_idx_map_go(tag_names, idx: 0, acc: map.string_map())
end

let build_tag_idx_map_go = fn (
  tag_names: [ string ],
  idx: i64,
  acc: Map<string,
  i64>
) -> Map<string, i64> do
  match tag_names do
    | [] -> return acc
    | x :: rest ->
      // First occurrence wins (matches the linear-scan semantics).
      let acc2 = match map.get(m: acc, k: x) do
        | Some(_) -> acc
        | None -> map.insert(m: acc, k: x, v: idx)
      end
      return build_tag_idx_map_go(tag_names: rest, idx: idx + 1, acc: acc2)
  end
end

/** O(1) lookup: tag_name → index. Returns -1 if absent. */
export let lookup_tag_idx_map = fn (tag_name: string, idx_map: Map<string, i64>) -> i64 do
  match map.get(m: idx_map, k: tag_name) do
    | Some(val: i) -> return i
    | None -> return -1
  end
end

let ext_param_is_string = fn (typ: TypeExpr) -> bool do
  match wdefs.peel_linear(typ) do
    | TyString -> true
    | _ -> false
  end
end

let external_uses_string_abi = fn (ext: LirExternal) -> bool do
  let LirExternal(
    name: _,
    wasm_module: _,
    wasm_name: _,
    params: ps,
    ret_type: rt,
    throw_row: _
  ) = ext
  if ext_param_is_string(typ: rt) then return true end
  return ext_params_use_string(params: ps)
end

let ext_params_use_string = fn (params: [ LirParam ]) -> bool do
  match params do
    | [] -> false
    | LirParam(label: _, name: _, typ: t) :: rest ->
      if ext_param_is_string(typ: t) then return true end
      return ext_params_use_string(params: rest)
  end
end

/** Number of wasm parameter slots an external import consumes: strings and arrays cost 2 slots each (ptr + len), every other type costs 1. Drives the type-section signature emission for imports. */
export let count_ext_param_slots = fn (params: [ LirParam ]) -> i64 do
  match params do
    | [] -> 0
    | LirParam(label: _, name: _, typ: t) :: rest ->
      let slots = match wdefs.peel_linear(typ: t) do
        | TyString | TyArray(_) -> 2
        | _ -> 1
      end
      slots + count_ext_param_slots(params: rest)
  end
end

/** Find the shared-memory stdlib module for memory import.
 *  Only nexus:std/<...> modules own shared memory; all other modules
 *  (foreign `:'-namespaced modules, bare names like wasi_snapshot_preview1,
 *  or env) do not provide the shared linear memory and are skipped.
 */
let find_string_abi_module = fn (exts: [ LirExternal ]) -> Option<string> do
  match exts do
    | [] -> return None
    | e :: rest ->
      if external_uses_string_abi(ext: e) then
        let LirExternal(
          name: _,
          wasm_module: m,
          wasm_name: _,
          params: _,
          ret_type: _,
          throw_row: _
        ) = e
        if str.starts_with(s: m, prefix: "nexus:std/") then
          return Some(val: m)
        end
        return find_string_abi_module(exts: rest)
      end
      return find_string_abi_module(exts: rest)
  end
end

let has_stdlib = fn (externals: [ LirExternal ]) -> bool do
  match find_string_abi_module(exts: externals) do
    | None -> return false
    | Some(_) -> return true
  end
end

/** Memory-mode tag: replaces the prior magic-string protocol
 *  ("none" / "defined" / <module-name>). `MemoryImported(name)` carries the
 *  import-module name (typically "env" or a stdlib path) so callers that
 *  need to emit the wasm import can reach it.
 */
export type MemoryMode =
  MemoryNone
  | MemoryDefined
  | MemoryImported(name: string)

/** Decide whether the wasm module needs no memory, defines its own, or imports one (and from where). Imports `env.memory` for any program that uses strings, the heap, or a component-style string ABI — required by WASI threads so workers share a host-created memory; nexus-std externals carry their own import-module name. */
export let choose_memory_mode = fn (
  externals: [ LirExternal ],
  has_strings: bool,
  has_heap: bool
) -> MemoryMode do
  match find_string_abi_module(exts: externals) do
    | None ->
      // Import the shared linear memory from `env` whenever memory is needed
      // (string literals, object heap, or the dormant cabi_realloc string path).
      // An IMPORTED shared memory is required by WASI threads — every worker
      // instance gets the same host-created memory, so growth and writes from
      // any thread are visible to all. (`wasmtime run -S threads` and the
      // bundled `nexus` launcher both provide `env.memory`.)
      let has_component_strings = any_external_uses_component_string(exts: externals)
      if has_strings || has_heap || has_component_strings then return MemoryImported(name: "env") end
      return MemoryNone
    | Some(val: m) -> return MemoryImported(name: m)
  end
end

/** Like `choose_memory_mode` but for WASI preview3 mode: when a module would
 *  normally import `env.memory` (shared), it instead defines its own non-shared
 *  memory. WASI p3 hosts (wasmtime 44 with `-S p3=y`) do not provide
 *  `env::memory`, so the module must own its linear memory and export it
 *  under the name `"memory"`. The stdlib-string ABI path is unchanged since
 *  those modules manage their own memory import; p3 only affects the
 *  `env.memory` (wasi-threads) case.
 */
export let choose_memory_mode_p3 = fn (
  externals: [ LirExternal ],
  has_strings: bool,
  has_heap: bool
) -> MemoryMode do
  match find_string_abi_module(exts: externals) do
    | None ->
      let has_component_strings = any_external_uses_component_string(exts: externals)
      if has_strings || has_heap || has_component_strings then return MemoryDefined end
      return MemoryNone
    | Some(val: m) -> return MemoryImported(name: m)
  end
end

let any_external_uses_component_string = fn (exts: [ LirExternal ]) -> bool do
  match exts do
    | [] -> return false
    | e :: rest ->
      if external_uses_string_abi(ext: e) then
        let LirExternal(
          name: _,
          wasm_module: m,
          wasm_name: _,
          params: _,
          ret_type: _,
          throw_row: _
        ) = e
        if str.contains(s: m, sub: ":") then return true end
      end
      return any_external_uses_component_string(exts: rest)
  end
end

/** Check if any external uses the canonical-ABI string-lift/lower path
 *  (foreign namespaced module — i.e. ':' but not nexus:intrinsic,
 *  nexus:runtime/, or nexus:std/). Currently dormant: all extant ':' modules
 *  are nexus:intrinsic, nexus:runtime/, or nexus:std/.
 */
export let needs_cabi_realloc = fn (exts: [ LirExternal ]) -> bool do
  match exts do
    | [] -> return false
    | e :: rest ->
      let LirExternal(
        name: _,
        wasm_module: m,
        wasm_name: _,
        params: _,
        ret_type: _,
        throw_row: _
      ) = e
      if str.contains(s: m, sub: ":") then
        if m != "nexus:intrinsic" then
          if !str.starts_with(s: m, prefix: "nexus:runtime/") then
            if !str.starts_with(s: m, prefix: "nexus:std/") then
              if external_uses_string_abi(ext: e) then return true end
            end
          end
        end
      end
      return needs_cabi_realloc(exts: rest)
  end
end

/** True iff `m` is a foreign component-model module — contains ':' but is not
 *  nexus:intrinsic, a nexus:runtime/ module, or a nexus:std/ module. Foreign
 *  component modules use the canonical ABI: resource handles lower as i32.
 */
export let is_foreign_component_module = fn (m: string) -> bool do
  if !str.contains(s: m, sub: ":") then return false end
  if m == "nexus:intrinsic" then return false end
  if str.starts_with(s: m, prefix: "nexus:runtime/") then return false end
  if str.starts_with(s: m, prefix: "nexus:std/") then return false end
  return true
end

/** Round `v` up to the next multiple of 8; used to keep data-segment offsets and heap allocations 8-byte aligned (the natural i64 boundary). */
export let align8 = fn (v: i64) -> i64 do
  return (v + 7) / 8 * 8
end

/** Register a local under `name`, allocating a fresh wasm local index when the name is unseen and widening the existing slot to i64 when a same-name binding shows up later with a different valtype. Returns the updated `(locals, next_idx, local_map)` triple; `TyUnit` locals are skipped because they consume no stack slot. */
export let register_local = fn (
  name: string,
  typ: TypeExpr,
  locals: [ LocalEntry ],
  next_idx: i64,
  local_map: %HashMap
)
    -> LocalResult do
  if wdefs.is_unit(typ) then
    return LocalResult(locals, next_idx, %local_map)
  end
  let vt = wdefs.type_to_valtype(typ)
  // Map stores packed `(index << 32) | valtype`. Sentinel -1
  // means "no entry"; both fields fit since valtype < 256 and indexes are well
  // under 2^32 per function.
  let existing_packed = hmap.get_or(map: &local_map, key: wdefs.hash_name(name), default: -1)
  if existing_packed < 0 then
    let packed = (next_idx * wdefs.u32_radix) + vt
    let %local_map = hmap.put(map: %local_map, key: wdefs.hash_name(name), value: packed)
    return LocalResult(
      locals: LocalEntry(name, index: next_idx, valtype: vt) :: locals,
      next_idx: next_idx + 1,
      %local_map
    )
  end
  let existing_idx = existing_packed / wdefs.u32_radix
  let existing_vt = existing_packed - existing_idx * wdefs.u32_radix
  if existing_vt == vt then
    return LocalResult(locals, next_idx, %local_map)
  end
  let widened_packed = (existing_idx * wdefs.u32_radix) + 126
  let %local_map = hmap.put(map: %local_map, key: wdefs.hash_name(name), value: widened_packed)
  return LocalResult(
    locals: wdefs.widen_local(name, new_vt: 126, entries: locals),
    next_idx,
    %local_map
  )
end

/** Carrier for `register_local` / `collect_local_stmts`: the accumulated `LocalEntry` list (newest-first), the next free wasm local index, and the linear `name → packed(index,valtype)` hashmap. Linear in the last field so consumers must thread the value through. */
export type LocalResult = LocalResult(locals: [ LocalEntry ], next_idx: i64, local_map: %HashMap)

/** Walk `stmts` and register every `let`-bound name plus every `try_catch` catch-param via `register_local`. Recurses into nested if/loop/try arms; the same `LocalResult` triple is threaded through so all sibling arms share one index space. */
export let collect_local_stmts = fn (
  stmts: [ LirStmt ],
  locals: [ LocalEntry ],
  next_idx: i64,
  local_map: %HashMap
)
    -> LocalResult do
  match stmts do
    | [] -> return LocalResult(locals, next_idx, %local_map)
    | s :: rest ->
      let LocalResult(
        locals: ls,
        next_idx: ni,
        local_map: lm
      ) = collect_local_stmt(stmt: s, locals, next_idx, %local_map)
      return collect_local_stmts(stmts: rest, locals: ls, next_idx: ni, local_map: %lm)
  end
end

let collect_local_stmt = fn (
  stmt: LirStmt,
  locals: [ LocalEntry ],
  next_idx: i64,
  local_map: %HashMap
)
    -> LocalResult do
  match stmt do
    | LirStmtLet(name: n, typ: t, expr: _) ->
      return register_local(name: n, typ: t, locals, next_idx, %local_map)
    | LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
      let LocalResult(
        locals: ls,
        next_idx: ni,
        local_map: lm
      ) = collect_local_stmts(stmts: tb, locals, next_idx, %local_map)
      return collect_local_stmts(stmts: eb, locals: ls, next_idx: ni, local_map: %lm)
    | LirStmtIfReturn(
      cond: _,
      then_body: tb,
      then_ret: _,
      else_body: eb,
      else_ret: _,
      ret_type: _
    ) ->
      let LocalResult(
        locals: ls,
        next_idx: ni,
        local_map: lm
      ) = collect_local_stmts(stmts: tb, locals, next_idx, %local_map)
      return collect_local_stmts(stmts: eb, locals: ls, next_idx: ni, local_map: %lm)
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      let LocalResult(
        locals: ls,
        next_idx: ni,
        local_map: lm
      ) = collect_local_stmts(stmts: cs, locals, next_idx, %local_map)
      return collect_local_stmts(stmts: b, locals: ls, next_idx: ni, local_map: %lm)
    | LirStmtTryCatch(body: b, body_ret: _, catch_param: cp, catch_param_typ: cpt,
                          catch_body: cb, catch_ret: _) ->
      let LocalResult(
        locals: ls,
        next_idx: ni,
        local_map: lm
      ) = register_local(name: cp, typ: cpt, locals, next_idx, %local_map)
      let LocalResult(
        locals: ls2,
        next_idx: ni2,
        local_map: lm2
      ) = collect_local_stmts(stmts: b, locals: ls, next_idx: ni, local_map: %lm)
      return collect_local_stmts(stmts: cb, locals: ls2, next_idx: ni2, local_map: %lm2)
  end
end
