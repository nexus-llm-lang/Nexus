/**
 * wasm_collect: Pre-codegen analysis passes.
 *
 * Collects string literals, detects heap usage, analyzes external ABIs,
 * determines memory mode, and collects local variables from "LIR."
 */

import { TypeExpr } from "src/common/ast.nx"
import { LirFunction, LirStmt, LirExpr, LirAtom, LirExternal, LirParam, LirCallArg, LirNamedAtom } from "src/ir/lir_types.nx"
import { LocalEntry, StringEntry }, * as wdefs from "src/backend/wasm_defs.nx"
import * as list from "std:list"

import * as str from "std:string_ops"
import { HashMap }, * as hmap from "std:hashmap"


// ─── String literal collection ──────────────────────────────────────────────

let collect_atom_strings = fn (atom: LirAtom, acc: [string]) -> [string] do
  match atom do
    | LirAtomString(val: s) -> s :: acc
    | _ -> acc
  end
end

let collect_call_arg_strings = fn (args: [LirCallArg], acc: [string]) -> [string] do
  match args do
    | [] -> acc
    | LirCallArg(label: _, value: v) :: rest ->
      collect_call_arg_strings(args: rest, acc: collect_atom_strings(atom: v, acc: acc))
  end
end

let collect_atom_list_strings = fn (atoms: [LirAtom], acc: [string]) -> [string] do
  match atoms do
    | [] -> acc
    | a :: rest ->
      collect_atom_list_strings(atoms: rest, acc: collect_atom_strings(atom: a, acc: acc))
  end
end

let collect_named_atom_strings = fn (fields: [LirNamedAtom], acc: [string]) -> [string] do
  match fields do
    | [] -> acc
    | LirNamedAtom(name: _, value: v) :: rest ->
      collect_named_atom_strings(fields: rest, acc: collect_atom_strings(atom: v, acc: acc))
  end
end

let collect_expr_strings = fn (expr: LirExpr, acc: [string]) -> [string] do
  match expr do
    | LirExprAtom(atom: a) -> collect_atom_strings(atom: a, acc: acc)
    | LirExprBinary(op: _, lhs: l, rhs: r, typ: _) ->
      collect_atom_strings(atom: r, acc: collect_atom_strings(atom: l, acc: acc))
    | LirExprCall(func: _, args: args, typ: _) -> collect_call_arg_strings(args: args, acc: acc)
    | LirExprTailCall(func: _, args: args, typ: _) -> collect_call_arg_strings(args: args, acc: acc)
    | LirExprConstructor(name: _, args: atoms, typ: _) -> collect_atom_list_strings(atoms: atoms, acc: acc)
    | LirExprRecord(fields: fields, typ: _) -> collect_named_atom_strings(fields: fields, acc: acc)
    | LirExprObjectTag(value: v, typ: _) -> collect_atom_strings(atom: v, acc: acc)
    | LirExprObjectField(value: v, index: _, typ: _) -> collect_atom_strings(atom: v, acc: acc)
    | LirExprRaise(value: v, typ: _) -> collect_atom_strings(atom: v, acc: acc)
    | LirExprForce(value: v, typ: _) -> collect_atom_strings(atom: v, acc: acc)
    | LirExprMakeClosure(func_name: _, captures: caps, typ: _) -> collect_atom_list_strings(atoms: caps, acc: acc)
    | LirExprCallClosure(closure: c, args: args, typ: _) ->
      collect_call_arg_strings(args: args, acc: collect_atom_strings(atom: c, acc: acc))
  end
end

let collect_stmt_strings = fn (stmt: LirStmt, acc: [string]) -> [string] do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) ->
      collect_expr_strings(expr: e, acc: acc)
    | LirStmtIf(cond: c, then_body: tb, else_body: eb) ->
      collect_stmts_strings(stmts: eb, acc: collect_stmts_strings(stmts: tb, acc: collect_atom_strings(atom: c, acc: acc)))
    | LirStmtIfReturn(cond: c, then_body: tb, then_ret: tr, else_body: eb, else_ret: er, ret_type: _) ->
      let acc2 = collect_stmts_strings(stmts: eb, acc: collect_atom_strings(atom: tr, acc: collect_stmts_strings(stmts: tb, acc: collect_atom_strings(atom: c, acc: acc))))
      match er do
        | Some(val: a) -> collect_atom_strings(atom: a, acc: acc2)
        | None -> acc2
      end
    | LirStmtLoop(cond_stmts: cs, cond: c, body: b) ->
      collect_stmts_strings(stmts: b, acc: collect_atom_strings(atom: c, acc: collect_stmts_strings(stmts: cs, acc: acc)))
    | LirStmtTryCatch(body: b, body_ret: br, catch_param: _, catch_param_typ: _,
                          catch_body: cb, catch_ret: cr) ->
      let acc2 = match br do
        | Some(val: a) -> collect_atom_strings(atom: a, acc: collect_stmts_strings(stmts: b, acc: acc))
        | None -> collect_stmts_strings(stmts: b, acc: acc)
      end
      let acc3 = collect_stmts_strings(stmts: cb, acc: acc2)
      match cr do
        | Some(val: a) -> collect_atom_strings(atom: a, acc: acc3)
        | None -> acc3
      end
  end
end

let collect_stmts_strings = fn (stmts: [LirStmt], acc: [string]) -> [string] do
  match stmts do
    | [] -> acc
    | s :: rest ->
      collect_stmts_strings(stmts: rest, acc: collect_stmt_strings(stmt: s, acc: acc))
  end
end

let collect_func_strings = fn (func: LirFunction, acc: [string]) -> [string] do
  let LirFunction(name: _, params: _, ret_type: _, body: b, ret: r, span: _) = func
  collect_atom_strings(atom: r, acc: collect_stmts_strings(stmts: b, acc: acc))
end

export let collect_program_strings = fn (funcs: [LirFunction], acc: [string]) -> [string] do
  match funcs do
    | [] -> acc
    | f :: rest ->
      collect_program_strings(funcs: rest, acc: collect_func_strings(func: f, acc: acc))
  end
end

// ─── String deduplication ───────────────────────────────────────────────────

/// Lexicographic string comparison via char_code. Returns -1, 0, or 1.
let str_compare_go = fn (a: string, b: string, idx: i64, alen: i64, blen: i64) -> i64 do
  if idx == alen then
    match idx == blen do
      | true -> return 0
      | false -> return -1
    end
  end
  if idx == blen then return 1 end
  let ca = str.char_code(s: a, idx: idx)
  let cb = str.char_code(s: b, idx: idx)
  if ca < cb then return -1 end
  if ca > cb then return 1 end
  return str_compare_go(a: a, b: b, idx: idx + 1, alen: alen, blen: blen)
end

let str_compare = fn (a: string, b: string) -> i64 do
  return str_compare_go(a: a, b: b, idx: 0, alen: str.length(s: a), blen: str.length(s: b))
end

let string_seen_sorted = fn (s: string, seen: [string]) -> bool do
  match seen do
    | [] -> false
    | x :: rest ->
      let cmp = str_compare(a: s, b: x)
      match cmp < 0 do
        | true -> false
        | false ->
          match cmp == 0 do
            | true -> true
            | false -> string_seen_sorted(s: s, seen: rest)
          end
      end
  end
end

let rev_strings = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_strings(lst: rest, out: x :: out)
  end
end

let insert_sorted_string = fn (s: string, xs: [string]) -> [string] do
  return insert_sorted_string_go(s: s, lst: xs, acc: [])
end

let insert_sorted_string_go = fn (s: string, lst: [string], acc: [string]) -> [string] do
  match lst do
    | [] -> return rev_strings(lst: acc, out: [s])
    | x :: rest ->
      match str_compare(a: s, b: x) < 0 do
        | true -> return rev_strings(lst: acc, out: s :: lst)
        | false -> return insert_sorted_string_go(s: s, lst: rest, acc: x :: acc)
      end
  end
end

export let build_string_entries = fn (strings: [string], next_offset: i64, acc: [StringEntry]) -> [StringEntry] do
  return build_string_entries_go(strings: strings, next_offset: next_offset, acc: [], seen: [])
end

let build_string_entries_go = fn (strings: [string], next_offset: i64, acc: [StringEntry], seen: [string]) -> [StringEntry] do
  match strings do
    | [] -> list.reverse(xs: acc)
    | s :: rest ->
      if string_seen_sorted(s: s, seen: seen) then
        return build_string_entries_go(strings: rest, next_offset: next_offset, acc: acc, seen: seen)
      end
      let slen = str.byte_length(s: s)
      return build_string_entries_go(strings: rest, next_offset: next_offset + slen,
                           acc: StringEntry(value: s, offset: next_offset, slen: slen) :: acc,
                           seen: insert_sorted_string(s: s, xs: seen))
  end
end

export let compute_last_string_end = fn (entries: [StringEntry]) -> i64 do
  match entries do
    | [] -> 0
    | [StringEntry(value: _, offset: off, slen: sl)] -> off + sl
    | _ :: rest -> compute_last_string_end(entries: rest)
  end
end

// ─── Object heap detection ──────────────────────────────────────────────────

let expr_uses_heap = fn (expr: LirExpr) -> bool do
  match expr do
    | LirExprConstructor(_) -> true
    | LirExprRecord(_) -> true
    | LirExprObjectTag(_) -> true
    | LirExprObjectField(_) -> true
    | LirExprBinary(op: OpConcat, lhs: _, rhs: _, typ: _) -> true
    | LirExprBinary(op: OpAdd, lhs: _, rhs: _, typ: t) ->
      match wdefs.peel_linear(typ: t) do
        | TyString -> true
        | _ -> false
      end
    | LirExprMakeClosure(_) -> true
    | _ -> false
  end
end

let stmt_uses_heap = fn (stmt: LirStmt) -> bool do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) -> expr_uses_heap(expr: e)
    | LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
      stmts_use_heap(stmts: tb) || stmts_use_heap(stmts: eb)
    | LirStmtIfReturn(cond: _, then_body: tb, then_ret: _, else_body: eb, else_ret: _, ret_type: _) ->
      stmts_use_heap(stmts: tb) || stmts_use_heap(stmts: eb)
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      stmts_use_heap(stmts: cs) || stmts_use_heap(stmts: b)
    | LirStmtTryCatch(body: b, body_ret: _, catch_param: _, catch_param_typ: _,
                          catch_body: cb, catch_ret: _) ->
      stmts_use_heap(stmts: b) || stmts_use_heap(stmts: cb)
  end
end

let stmts_use_heap = fn (stmts: [LirStmt]) -> bool do
  match stmts do
    | [] -> false
    | s :: rest ->
      if stmt_uses_heap(stmt: s) then return true end
      return stmts_use_heap(stmts: rest)
  end
end

export let program_uses_heap = fn (funcs: [LirFunction]) -> bool do
  match funcs do
    | [] -> false
    | LirFunction(name: _, params: _, ret_type: _, body: b, ret: _, span: _) :: rest ->
      if stmts_use_heap(stmts: b) then return true end
      return program_uses_heap(funcs: rest)
  end
end

// ─── Exception handling detection ────────────────────────────────────────────

let expr_needs_eh = fn (expr: LirExpr) -> bool do
  match expr do
    | LirExprRaise(_) -> true
    | LirExprForce(_) -> false
    | _ -> false
  end
end

let stmt_needs_eh = fn (stmt: LirStmt) -> bool do
  match stmt do
    | LirStmtLet(name: _, typ: _, expr: e) -> expr_needs_eh(expr: e)
    | LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
      stmts_need_eh(stmts: tb) || stmts_need_eh(stmts: eb)
    | LirStmtIfReturn(cond: _, then_body: tb, then_ret: _, else_body: eb, else_ret: _, ret_type: _) ->
      stmts_need_eh(stmts: tb) || stmts_need_eh(stmts: eb)
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      stmts_need_eh(stmts: cs) || stmts_need_eh(stmts: b)
    | LirStmtTryCatch(_) -> true
  end
end

let stmts_need_eh = fn (stmts: [LirStmt]) -> bool do
  match stmts do
    | [] -> false
    | s :: rest ->
      if stmt_needs_eh(stmt: s) then return true end
      return stmts_need_eh(stmts: rest)
  end
end

export let program_needs_eh = fn (funcs: [LirFunction]) -> bool do
  match funcs do
    | [] -> false
    | LirFunction(name: _, params: _, ret_type: _, body: b, ret: _, span: _) :: rest ->
      if stmts_need_eh(stmts: b) then return true end
      return program_needs_eh(funcs: rest)
  end
end

// ─── External ABI helpers ───────────────────────────────────────────────────

let ext_param_is_string = fn (typ: TypeExpr) -> bool do
  match wdefs.peel_linear(typ: typ) do
    | TyString -> true
    | _ -> false
  end
end

let external_uses_string_abi = fn (ext: LirExternal) -> bool do
  let LirExternal(name: _, wasm_module: _, wasm_name: _, params: ps, ret_type: rt, throw_row: _) = ext
  if ext_param_is_string(typ: rt) then return true end
  return ext_params_use_string(params: ps)
end

let ext_params_use_string = fn (params: [LirParam]) -> bool do
  match params do
    | [] -> false
    | LirParam(label: _, name: _, typ: t) :: rest ->
      if ext_param_is_string(typ: t) then return true end
      return ext_params_use_string(params: rest)
  end
end

export let count_ext_param_slots = fn (params: [LirParam]) -> i64 do
  match params do
    | [] -> 0
    | LirParam(label: _, name: _, typ: t) :: rest ->
      let slots = match wdefs.peel_linear(typ: t) do
        | TyString -> 2
        | TyArray(_) -> 2
        | _ -> 1
      end
      slots + count_ext_param_slots(params: rest)
  end
end

// ─── Memory mode ────────────────────────────────────────────────────────────

/// Find a shared-memory (non-WIT) stdlib module for memory import.
/// Component-model modules (containing ':') own their memory — skip them.
let find_string_abi_module = fn (exts: [LirExternal]) -> Option<string> do
  match exts do
    | [] -> return None
    | e :: rest ->
      if external_uses_string_abi(ext: e) then
        let LirExternal(name: _, wasm_module: m, wasm_name: _, params: _, ret_type: _, throw_row: _) = e
        // Component-model modules don't share memory — skip.
        // But nexus:std/* modules ARE stdlib (WIT-renamed file-path imports).
        if str.contains(s: m, sub: ":") then
          if str.starts_with(s: m, prefix: "nexus:std/") == false then
            return find_string_abi_module(exts: rest)
          end
        end
        return Some(val: m)
      end
      return find_string_abi_module(exts: rest)
  end
end

export let has_stdlib = fn (externals: [LirExternal]) -> bool do
  match find_string_abi_module(exts: externals) do
    | None -> return false
    | Some(_) -> return true
  end
end

export let choose_memory_mode = fn (externals: [LirExternal], has_strings: bool, has_heap: bool) -> string do
  match find_string_abi_module(exts: externals) do
    | None ->
      // No shared-memory module found. Define own memory if needed for
      // string literals, object heap, or canonical ABI string crossing.
      let has_component_strings = any_external_uses_component_string(exts: externals)
      if has_strings || has_heap || has_component_strings then return "defined" end
      return "none"
    | Some(val: m) -> return m
  end
end

let any_external_uses_component_string = fn (exts: [LirExternal]) -> bool do
  match exts do
    | [] -> return false
    | e :: rest ->
      if external_uses_string_abi(ext: e) then
        let LirExternal(name: _, wasm_module: m, wasm_name: _, params: _, ret_type: _, throw_row: _) = e
        if str.contains(s: m, sub: ":") then return true end
      end
      return any_external_uses_component_string(exts: rest)
  end
end

/// Check if any external uses canonical ABI (component model boundary with string params/returns).
export let needs_cabi_realloc = fn (exts: [LirExternal]) -> bool do
  match exts do
    | [] -> return false
    | e :: rest ->
      let LirExternal(name: _, wasm_module: m, wasm_name: _, params: _, ret_type: _, throw_row: _) = e
      if str.contains(s: m, sub: ":") then
        if str.starts_with(s: m, prefix: "nexus:runtime/") == false then
          if str.starts_with(s: m, prefix: "nexus:std/") == false then
            if external_uses_string_abi(ext: e) then return true end
          end
        end
      end
      return needs_cabi_realloc(exts: rest)
  end
end

export let align8 = fn (v: i64) -> i64 do
  return (v + 7) / 8 * 8
end

// ─── Local variable collection ──────────────────────────────────────────────

export let register_local = fn (name: string, typ: TypeExpr, locals: [LocalEntry], next_idx: i64, local_map: %HashMap)
    -> LocalResult do
  if wdefs.is_unit(typ: typ) then
    return LocalResult(locals: locals, next_idx: next_idx, local_map: %local_map)
  end
  let vt = wdefs.type_to_valtype(typ: typ)
  let existing_vt = hmap.get_or(map: &local_map, key: wdefs.hash_name(name: name), default: -1)
  match existing_vt < 0 do
    | true ->
      let %local_map = hmap.put(map: %local_map, key: wdefs.hash_name(name: name), value: vt)
      return LocalResult(locals: LocalEntry(name: name, index: next_idx, valtype: vt) :: locals, next_idx: next_idx + 1, local_map: %local_map)
    | false ->
      match existing_vt == vt do
        | true -> return LocalResult(locals: locals, next_idx: next_idx, local_map: %local_map)
        | false ->
          let %local_map = hmap.put(map: %local_map, key: wdefs.hash_name(name: name), value: 126)
          return LocalResult(locals: wdefs.widen_local(name: name, new_vt: 126, entries: locals), next_idx: next_idx, local_map: %local_map)
      end
  end
end

export type LocalResult = LocalResult(locals: [LocalEntry], next_idx: i64, local_map: %HashMap)

export let collect_local_stmts = fn (stmts: [LirStmt], locals: [LocalEntry], next_idx: i64, local_map: %HashMap)
    -> LocalResult do
  match stmts do
    | [] -> return LocalResult(locals: locals, next_idx: next_idx, local_map: %local_map)
    | s :: rest ->
      match collect_local_stmt(stmt: s, locals: locals, next_idx: next_idx, local_map: %local_map) do
        | LocalResult(locals: ls, next_idx: ni, local_map: lm) ->
          return collect_local_stmts(stmts: rest, locals: ls, next_idx: ni, local_map: %lm)
      end
  end
end

export let collect_local_stmt = fn (stmt: LirStmt, locals: [LocalEntry], next_idx: i64, local_map: %HashMap)
    -> LocalResult do
  match stmt do
    | LirStmtLet(name: n, typ: t, expr: _) ->
      return register_local(name: n, typ: t, locals: locals, next_idx: next_idx, local_map: %local_map)
    | LirStmtIf(cond: _, then_body: tb, else_body: eb) ->
      match collect_local_stmts(stmts: tb, locals: locals, next_idx: next_idx, local_map: %local_map) do
        | LocalResult(locals: ls, next_idx: ni, local_map: lm) ->
          return collect_local_stmts(stmts: eb, locals: ls, next_idx: ni, local_map: %lm)
      end
    | LirStmtIfReturn(cond: _, then_body: tb, then_ret: _, else_body: eb, else_ret: _, ret_type: _) ->
      match collect_local_stmts(stmts: tb, locals: locals, next_idx: next_idx, local_map: %local_map) do
        | LocalResult(locals: ls, next_idx: ni, local_map: lm) ->
          return collect_local_stmts(stmts: eb, locals: ls, next_idx: ni, local_map: %lm)
      end
    | LirStmtLoop(cond_stmts: cs, cond: _, body: b) ->
      match collect_local_stmts(stmts: cs, locals: locals, next_idx: next_idx, local_map: %local_map) do
        | LocalResult(locals: ls, next_idx: ni, local_map: lm) ->
          return collect_local_stmts(stmts: b, locals: ls, next_idx: ni, local_map: %lm)
      end
    | LirStmtTryCatch(body: b, body_ret: _, catch_param: cp, catch_param_typ: cpt,
                          catch_body: cb, catch_ret: _) ->
      match register_local(name: cp, typ: cpt, locals: locals, next_idx: next_idx, local_map: %local_map) do
        | LocalResult(locals: ls, next_idx: ni, local_map: lm) ->
          match collect_local_stmts(stmts: b, locals: ls, next_idx: ni, local_map: %lm) do
            | LocalResult(locals: ls2, next_idx: ni2, local_map: lm2) ->
              return collect_local_stmts(stmts: cb, locals: ls2, next_idx: ni2, local_map: %lm2)
          end
      end
  end
end
