import { ByteBuffer }, * as bb from "stdlib/bytebuffer.nx"
import * as sm from "stdlib/stringmap.nx"
import * as str from "stdlib/string.nx"

external __nx_buf_new = "__nx_buf_new" : () -> i64
external __nx_buf_push_i32_le = "__nx_buf_push_i32_le" : (id: i64, val: i64) -> unit
external __nx_buf_get_byte = "__nx_buf_get_byte" : (id: i64, idx: i64) -> i64
external __nx_buf_free_raw = "__nx_buf_free" : (id: i64) -> bool
external __nx_smap_new = "__nx_smap_new" : () -> i64
external __nx_smap_put = "__nx_smap_put" : (id: i64, key: string, value: i64) -> i64
external __nx_smap_get = "__nx_smap_get" : (id: i64, key: string, default_val: i64) -> i64
external __nx_smap_has = "__nx_smap_has" : (id: i64, key: string) -> bool
external __nx_smap_free = "__nx_smap_free" : (id: i64) -> bool
external __nx_smap_size = "__nx_smap_size" : (id: i64) -> i64

// ─── Dense i32 array (int→int table) ─────────────────────────────────────
// Backed by a raw ByteBuffer. Avoids from_i64 string allocation that occurs
// in every smap lookup; function-index remaps happen thousands of times per
// merge, so hot-path allocation fills dlmalloc before merge finishes.
let intarr_new = fn () -> i64 do return __nx_buf_new() end
let intarr_push = fn (id: i64, val: i64) -> unit do
  __nx_buf_push_i32_le(id: id, val: val)
end
let intarr_get = fn (id: i64, idx: i64) -> i64 do
  let pos = idx * 4
  let b0 = __nx_buf_get_byte(id: id, idx: pos)
  let b1 = __nx_buf_get_byte(id: id, idx: pos + 1)
  let b2 = __nx_buf_get_byte(id: id, idx: pos + 2)
  let b3 = __nx_buf_get_byte(id: id, idx: pos + 3)
  return b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
end
let intarr_free = fn (id: i64) -> unit do
  let _r = __nx_buf_free_raw(id: id)
  return ()
end

let pack = fn (val: i64, p: i64) -> i64 do return val * 4294967296 + p end
let pval = fn (pk: i64) -> i64 do return pk / 4294967296 end
let ppos = fn (pk: i64) -> i64 do return pk % 4294967296 end

let shl = fn (v: i64, n: i64) -> i64 do
  if n <= 0 then return v end
  return shl(v: v + v, n: n - 1)
end

let rd_uleb = fn (buf: &ByteBuffer, pos: i64) -> i64 do
  return rd_uleb_go(buf: buf, pos: pos, r: 0, s: 0)
end
let rd_uleb_go = fn (buf: &ByteBuffer, pos: i64, r: i64, s: i64) -> i64 do
  let b = bb.get_byte(buf: buf, idx: pos)
  let r2 = r + (b % 128) * shl(v: 1, n: s)
  if b < 128 then return pack(val: r2, p: pos + 1) end
  return rd_uleb_go(buf: buf, pos: pos + 1, r: r2, s: s + 7)
end

let set_p = fn (ps: i64, v: i64) -> unit do let _r = __nx_smap_put(id: ps, key: "_", value: v) end
let get_p = fn (ps: i64) -> i64 do return __nx_smap_get(id: ps, key: "_", default_val: 0) end
let set_v = fn (ps: i64, v: i64) -> unit do let _r = __nx_smap_put(id: ps, key: "_v", value: v) end
let get_v = fn (ps: i64) -> i64 do return __nx_smap_get(id: ps, key: "_v", default_val: 0) end

// ─── Signed LEB128 reader ─────────────────────────────────────────────────
// Returns new position; value stored in pos_state via set_v/get_v.
// Packed return (val*2^32+pos) breaks for negative values because
// negative val*2^32 makes pval/ppos give wrong results.
// Terminal step: given accumulated r and shift s, plus the terminal byte b,
// compute final value (sign-extended if bit 6 set) and return pos+1.
let rd_sleb_term = fn (ps: i64, pos: i64, r: i64, s: i64, b: i64) -> i64 do
  let r2 = r + (b % 128) * shl(v: 1, n: s)
  if s + 7 < 64 then
    if b >= 64 then
      set_v(ps: ps, v: r2 - shl(v: 1, n: s + 7))
      return pos + 1
    end
  end
  set_v(ps: ps, v: r2)
  return pos + 1
end

// Scan forward from `pos` and return position after the terminal LEB128 byte
// (first byte with high bit cleared). Used for bulk-copying SLEB-encoded
// operands without re-encoding.
let scan_sleb_end = fn (buf: &ByteBuffer, pos: i64) -> i64 do
  let b = bb.get_byte(buf: buf, idx: pos)
  if b < 128 then return pos + 1 end
  return scan_sleb_end(buf: buf, pos: pos + 1)
end

let rd_sleb = fn (ps: i64, buf: &ByteBuffer, pos: i64) -> i64 do
  let b0 = bb.get_byte(buf: buf, idx: pos)
  if b0 < 128 then return rd_sleb_term(ps: ps, pos: pos, r: 0, s: 0, b: b0) end
  let r1 = b0 % 128
  let b1 = bb.get_byte(buf: buf, idx: pos + 1)
  if b1 < 128 then return rd_sleb_term(ps: ps, pos: pos + 1, r: r1, s: 7, b: b1) end
  let r2 = r1 + (b1 % 128) * 128
  let b2 = bb.get_byte(buf: buf, idx: pos + 2)
  if b2 < 128 then return rd_sleb_term(ps: ps, pos: pos + 2, r: r2, s: 14, b: b2) end
  let r3 = r2 + (b2 % 128) * 16384
  let b3 = bb.get_byte(buf: buf, idx: pos + 3)
  if b3 < 128 then return rd_sleb_term(ps: ps, pos: pos + 3, r: r3, s: 21, b: b3) end
  let r4 = r3 + (b3 % 128) * 2097152
  let b4 = bb.get_byte(buf: buf, idx: pos + 4)
  if b4 < 128 then return rd_sleb_term(ps: ps, pos: pos + 4, r: r4, s: 28, b: b4) end
  let r5 = r4 + (b4 % 128) * 268435456
  let b5 = bb.get_byte(buf: buf, idx: pos + 5)
  if b5 < 128 then return rd_sleb_term(ps: ps, pos: pos + 5, r: r5, s: 35, b: b5) end
  let r6 = r5 + (b5 % 128) * 34359738368
  let b6 = bb.get_byte(buf: buf, idx: pos + 6)
  if b6 < 128 then return rd_sleb_term(ps: ps, pos: pos + 6, r: r6, s: 42, b: b6) end
  let r7 = r6 + (b6 % 128) * 4398046511104
  let b7 = bb.get_byte(buf: buf, idx: pos + 7)
  if b7 < 128 then return rd_sleb_term(ps: ps, pos: pos + 7, r: r7, s: 49, b: b7) end
  let r8 = r7 + (b7 % 128) * 562949953421312
  let b8 = bb.get_byte(buf: buf, idx: pos + 8)
  if b8 < 128 then return rd_sleb_term(ps: ps, pos: pos + 8, r: r8, s: 56, b: b8) end
  let r9 = r8 + (b8 % 128) * 72057594037927936
  let b9 = bb.get_byte(buf: buf, idx: pos + 9)
  return rd_sleb_term(ps: ps, pos: pos + 9, r: r9, s: 63, b: b9)
end

// ─── Section scanning ─────────────────────────────────────────────────────
// Scan WASM module sections into an smap: section_id -> pack(content_offset, size)
let scan_secs = fn (buf: &ByteBuffer) -> i64 do
  let map = __nx_smap_new()
  scan_secs_go(buf: buf, pos: 8, end_pos: bb.length(buf: buf), map: map)
  return map
end
let scan_secs_go = fn (buf: &ByteBuffer, pos: i64, end_pos: i64, map: i64) -> unit do
  if pos < end_pos then
    let sec_id = bb.get_byte(buf: buf, idx: pos)
    let pk = rd_uleb(buf: buf, pos: pos + 1)
    let sec_size = pval(pk: pk)
    let content_start = ppos(pk: pk)
    __nx_smap_put(id: map, key: str.from_i64(val: sec_id), value: pack(val: content_start, p: sec_size))
    scan_secs_go(buf: buf, pos: content_start + sec_size, end_pos: end_pos, map: map)
  end
end

// Get packed section info (0 if section not present)
let get_sec = fn (map: i64, sec: i64) -> i64 do
  return __nx_smap_get(id: map, key: str.from_i64(val: sec), default_val: 0)
end
// Extract content offset from packed section info
let sec_off = fn (pk: i64) -> i64 do return pval(pk: pk) end
// Extract section size from packed section info
let sec_sz = fn (pk: i64) -> i64 do return ppos(pk: pk) end

// Read the ULEB count at the start of a section (0 if section absent)
let count_sec = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  return pval(pk: rd_uleb(buf: buf, pos: sec_off(pk: sec_pk)))
end

// Position right after the section count ULEB
let sec_body = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  return ppos(pk: rd_uleb(buf: buf, pos: sec_off(pk: sec_pk)))
end

// ─── String reading ───────────────────────────────────────────────────────
// Read a WASM string (ULEB length + bytes). Sets pos_state to end position.
let rd_str = fn (ps: i64, buf: &ByteBuffer, pos: i64) -> string do
  let pk = rd_uleb(buf: buf, pos: pos)
  let len = pval(pk: pk)
  let start = ppos(pk: pk)
  set_p(ps: ps, v: start + len)
  let %tmp = bb.empty()
  let %tmp = bb.copy_range(dst: %tmp, src: buf, start: start, end_pos: start + len)
  let s = bb.to_string(buf: &tmp)
  bb.free(buf: %tmp)
  return s
end

// ─── Import descriptor skipping ───────────────────────────────────────────
// Skip limits encoding (flags + min [+ max])
let skip_limits = fn (buf: &ByteBuffer, pos: i64) -> i64 do
  let flags = bb.get_byte(buf: buf, idx: pos)
  let pk = rd_uleb(buf: buf, pos: pos + 1)
  if flags == 0 then return ppos(pk: pk) end
  return ppos(pk: rd_uleb(buf: buf, pos: ppos(pk: pk)))
end

// Skip an import descriptor; returns position after it
let skip_imp_desc = fn (buf: &ByteBuffer, pos: i64) -> i64 do
  let kind = bb.get_byte(buf: buf, idx: pos)
  if kind == 0 then
    // func: skip type index ULEB
    return ppos(pk: rd_uleb(buf: buf, pos: pos + 1))
  end
  if kind == 1 then
    // table: reftype byte + limits
    return skip_limits(buf: buf, pos: pos + 2)
  end
  if kind == 2 then
    // memory: limits
    return skip_limits(buf: buf, pos: pos + 1)
  end
  if kind == 3 then
    // global: valtype + mutability = 2 bytes
    return pos + 3
  end
  // tag: attribute ULEB + type index ULEB
  let pk = rd_uleb(buf: buf, pos: pos + 1)
  return ppos(pk: rd_uleb(buf: buf, pos: ppos(pk: pk)))
end

// ─── WIT name conversion ─────────────────────────────────────────────────
// Convert WIT function name to stdlib export name:
//   "smap-new" → "__nx_smap_new" (prepend __nx_, replace - with _)
let wit_to_export = fn (wit_name: string) -> string do
  let %buf = bb.empty()
  let %buf = bb.push_string(buf: %buf, s: "__nx_")
  let %buf = wit_to_export_go(buf: %buf, name: wit_name, pos: 0, len: str.byte_length(s: wit_name))
  let s = bb.to_string(buf: &buf)
  bb.free(buf: %buf)
  return s
end
let wit_to_export_go = fn (buf: %ByteBuffer, name: string, pos: i64, len: i64) -> %ByteBuffer do
  if pos >= len then return %buf end
  let ch = str.char_code(s: name, idx: pos)
  let b = match ch == 45 do case true -> 95 case false -> ch end
  let %buf = bb.push_byte(buf: %buf, byte: b)
  return wit_to_export_go(buf: %buf, name: name, pos: pos + 1, len: len)
end

// ─── Import scanning ──────────────────────────────────────────────────────
// Parse dep (stdlib) exports into smap: export_name -> func_idx+1 (0=not found)
let parse_dep_exports = fn (ps: i64, buf: &ByteBuffer, sec_pk: i64) -> i64 do
  let map = __nx_smap_new()
  if sec_pk == 0 then return map end
  let pk = rd_uleb(buf: buf, pos: sec_off(pk: sec_pk))
  let count = pval(pk: pk)
  parse_dep_exports_go(ps: ps, buf: buf, pos: ppos(pk: pk), remaining: count, map: map)
  return map
end
let parse_dep_exports_go = fn (ps: i64, buf: &ByteBuffer, pos: i64, remaining: i64, map: i64) -> unit do
  if remaining <= 0 then return () end
  let name = rd_str(ps: ps, buf: buf, pos: pos)
  let pos2 = get_p(ps: ps)
  let kind = bb.get_byte(buf: buf, idx: pos2)
  let pk = rd_uleb(buf: buf, pos: pos2 + 1)
  let idx = pval(pk: pk)
  if kind == 0 then
    let _r = __nx_smap_put(id: map, key: name, value: idx + 1)
  end
  parse_dep_exports_go(ps: ps, buf: buf, pos: ppos(pk: pk), remaining: remaining - 1, map: map)
end

// Count function imports in a module (kind == 0x00)
let count_func_imps = fn (ps: i64, buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  let pk = rd_uleb(buf: buf, pos: sec_off(pk: sec_pk))
  return count_func_imps_go(ps: ps, buf: buf, pos: ppos(pk: pk), remaining: pval(pk: pk), acc: 0)
end
let count_func_imps_go = fn (ps: i64, buf: &ByteBuffer, pos: i64, remaining: i64, acc: i64) -> i64 do
  if remaining <= 0 then return acc end
  let _mod = rd_str(ps: ps, buf: buf, pos: pos)
  let pos2 = get_p(ps: ps)
  let _name = rd_str(ps: ps, buf: buf, pos: pos2)
  let pos3 = get_p(ps: ps)
  let kind = bb.get_byte(buf: buf, idx: pos3)
  let pos4 = skip_imp_desc(buf: buf, pos: pos3)
  let inc = match kind == 0 do case true -> 1 case false -> 0 end
  return count_func_imps_go(ps: ps, buf: buf, pos: pos4, remaining: remaining - 1, acc: acc + inc)
end

// ─── Main non-stdlib import counting ─────────────────────────────────────
// Count ALL main imports that are NOT from nexus:stdlib/* (for import section entry count)
let count_main_kept_imps = fn (ps: i64, buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  let pk = rd_uleb(buf: buf, pos: sec_off(pk: sec_pk))
  return count_main_kept_go(ps: ps, buf: buf, pos: ppos(pk: pk), remaining: pval(pk: pk), acc: 0)
end
let count_main_kept_go = fn (ps: i64, buf: &ByteBuffer, pos: i64, remaining: i64, acc: i64) -> i64 do
  if remaining <= 0 then return acc end
  let mod_name = rd_str(ps: ps, buf: buf, pos: pos)
  let pos2 = get_p(ps: ps)
  let _name = rd_str(ps: ps, buf: buf, pos: pos2)
  let pos3 = get_p(ps: ps)
  let kind = bb.get_byte(buf: buf, idx: pos3)
  let pos4 = skip_imp_desc(buf: buf, pos: pos3)
  if str.starts_with(s: mod_name, prefix: "nexus:stdlib/") then
    return count_main_kept_go(ps: ps, buf: buf, pos: pos4, remaining: remaining - 1, acc: acc)
  end
  if str.byte_length(s: mod_name) == 0 then
    return count_main_kept_go(ps: ps, buf: buf, pos: pos4, remaining: remaining - 1, acc: acc)
  end
  if kind == 2 then
    return count_main_kept_go(ps: ps, buf: buf, pos: pos4, remaining: remaining - 1, acc: acc)
  end
  return count_main_kept_go(ps: ps, buf: buf, pos: pos4, remaining: remaining - 1, acc: acc + 1)
end

// Count main FUNCTION imports that are NOT from nexus:stdlib/* (for function index layout)
let count_main_kept_func_imps = fn (ps: i64, buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  let pk = rd_uleb(buf: buf, pos: sec_off(pk: sec_pk))
  return count_main_kept_func_go(ps: ps, buf: buf, pos: ppos(pk: pk), remaining: pval(pk: pk), acc: 0)
end
let count_main_kept_func_go = fn (ps: i64, buf: &ByteBuffer, pos: i64, remaining: i64, acc: i64) -> i64 do
  if remaining <= 0 then return acc end
  let mod_name = rd_str(ps: ps, buf: buf, pos: pos)
  let pos2 = get_p(ps: ps)
  let _name = rd_str(ps: ps, buf: buf, pos: pos2)
  let pos3 = get_p(ps: ps)
  let kind = bb.get_byte(buf: buf, idx: pos3)
  let pos4 = skip_imp_desc(buf: buf, pos: pos3)
  if kind == 0 then
    if str.starts_with(s: mod_name, prefix: "nexus:stdlib/") then
      return count_main_kept_func_go(ps: ps, buf: buf, pos: pos4, remaining: remaining - 1, acc: acc)
    end
    if str.byte_length(s: mod_name) == 0 then
      return count_main_kept_func_go(ps: ps, buf: buf, pos: pos4, remaining: remaining - 1, acc: acc)
    end
    return count_main_kept_func_go(ps: ps, buf: buf, pos: pos4, remaining: remaining - 1, acc: acc + 1)
  end
  return count_main_kept_func_go(ps: ps, buf: buf, pos: pos4, remaining: remaining - 1, acc: acc)
end

// ─── Main non-stdlib import copying ──────────────────────────────────────
// Copy main's non-stdlib function imports to output (no type offset needed — main types first)
let copy_main_kept_imps = fn (ps: i64, out: %ByteBuffer, buf: &ByteBuffer, sec_pk: i64) -> %ByteBuffer do
  if sec_pk == 0 then return %out end
  let pk = rd_uleb(buf: buf, pos: sec_off(pk: sec_pk))
  return copy_main_kept_go(ps: ps, out: %out, buf: buf, pos: ppos(pk: pk), remaining: pval(pk: pk))
end
// A main import is satisfied by dep (and dropped from merged imports) if:
//   - module is "nexus:stdlib/*" (function, resolved to dep export), OR
//   - module is "" (anonymous .memory/.allocate bound to dep-provided ones), OR
//   - import kind is memory (merged declares its own memory).
// Keeping main imports intact would require shifting dep's function indices by
// m_kept, but remap_dep_func is identity (see remap_dep_func comment), so any
// kept main import breaks dep internal calls.
let copy_main_kept_go = fn (ps: i64, out: %ByteBuffer, buf: &ByteBuffer, pos: i64, remaining: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let start = pos
  let mod_name = rd_str(ps: ps, buf: buf, pos: pos)
  let pos2 = get_p(ps: ps)
  let _name = rd_str(ps: ps, buf: buf, pos: pos2)
  let pos3 = get_p(ps: ps)
  let kind = bb.get_byte(buf: buf, idx: pos3)
  let pos4 = skip_imp_desc(buf: buf, pos: pos3)
  if str.starts_with(s: mod_name, prefix: "nexus:stdlib/") then
    return copy_main_kept_go(ps: ps, out: %out, buf: buf, pos: pos4, remaining: remaining - 1)
  end
  if str.byte_length(s: mod_name) == 0 then
    return copy_main_kept_go(ps: ps, out: %out, buf: buf, pos: pos4, remaining: remaining - 1)
  end
  if kind == 2 then
    return copy_main_kept_go(ps: ps, out: %out, buf: buf, pos: pos4, remaining: remaining - 1)
  end
  // Non-stdlib import: copy as-is (type indices correct — main types first)
  let %out = bb.copy_range(dst: %out, src: buf, start: start, end_pos: pos4)
  return copy_main_kept_go(ps: ps, out: %out, buf: buf, pos: pos4, remaining: remaining - 1)
end

// ─── Main import resolution ───────────────────────────────────────────────
// Populates remap_m intarr (dense i32 array, indexed by fidx) with the merged
// function index for each main function import. Iterates import section
// sequentially; fidx increments only for function-kind imports, matching
// the array index.
// Context keys in ps: "remap", "dep_exp", "kept", "stubs", "m_imp_base", "m_kept_idx"
let resolve_main_imports = fn (ps: i64, buf: &ByteBuffer, sec_pk: i64) -> unit do
  if sec_pk > 0 then
    __nx_smap_put(id: ps, key: "m_kept_idx", value: 0)
    let pk = rd_uleb(buf: buf, pos: sec_off(pk: sec_pk))
    resolve_main_go(ps: ps, buf: buf, pos: ppos(pk: pk), remaining: pval(pk: pk), fidx: 0)
  end
end
let resolve_main_go = fn (ps: i64, buf: &ByteBuffer, pos: i64, remaining: i64, fidx: i64) -> unit do
  if remaining > 0 then
    let mod_name = rd_str(ps: ps, buf: buf, pos: pos)
    let pos2 = get_p(ps: ps)
    let func_name = rd_str(ps: ps, buf: buf, pos: pos2)
    let pos3 = get_p(ps: ps)
    let kind = bb.get_byte(buf: buf, idx: pos3)
    let pos4 = skip_imp_desc(buf: buf, pos: pos3)
    if kind == 0 then
      let remap = __nx_smap_get(id: ps, key: "remap", default_val: 0)
      // stdlib/* and empty-module function imports resolve to dep exports.
      let is_dep = if str.starts_with(s: mod_name, prefix: "nexus:stdlib/") then true
                   else str.byte_length(s: mod_name) == 0 end
      let new_idx = if is_dep then
        let dep_exports = __nx_smap_get(id: ps, key: "dep_exp", default_val: 0)
        let raw_lookup = __nx_smap_get(id: dep_exports, key: func_name, default_val: 0)
        let dep_raw = if raw_lookup > 0 then raw_lookup
        else
          let exp_name = wit_to_export(wit_name: func_name)
          __nx_smap_get(id: dep_exports, key: exp_name, default_val: 0)
        end
        if dep_raw > 0 then
          let dep_fidx = dep_raw - 1
          let kept_fimp = __nx_smap_get(id: ps, key: "kept", default_val: 0)
          let n_stubs = __nx_smap_get(id: ps, key: "stubs", default_val: 0)
          let orig_dep_fimp = __nx_smap_get(id: ps, key: "dep_fimp", default_val: 0)
          remap_dep_func(dep_fidx: dep_fidx, kept_fimp: kept_fimp,
                         n_stubs: n_stubs, dep_fimp: orig_dep_fimp)
        else fidx end
      else
        let m_imp_base = __nx_smap_get(id: ps, key: "m_imp_base", default_val: 0)
        let m_kept_idx = __nx_smap_get(id: ps, key: "m_kept_idx", default_val: 0)
        let _r2 = __nx_smap_put(id: ps, key: "m_kept_idx", value: m_kept_idx + 1)
        m_imp_base + m_kept_idx
      end
      intarr_push(id: remap, val: new_idx)
      resolve_main_go(ps: ps, buf: buf, pos: pos4, remaining: remaining - 1, fidx: fidx + 1)
    else
      resolve_main_go(ps: ps, buf: buf, pos: pos4, remaining: remaining - 1, fidx: fidx)
    end
  end
end

// Map a dep function index to its new merged index
let remap_dep_func = fn (dep_fidx: i64, kept_fimp: i64, n_stubs: i64, dep_fimp: i64) -> i64 do
  // With stubbed stdlib (stubs replace CLI imports), dep function indices are
  // preserved verbatim in the merged output. Identity remap.
  return dep_fidx
end

// ─── Populate remap intarrs ──────────────────────────────────────────────
// Each remap array holds a dense i32 table indexed by original fidx.
// push_identity(arr, 0..n): arr[i] = i. Used for dep WASI imports (preserved).
// push_offset(arr, n, off): arr[len..len+n] = [len+off, len+1+off, ...].
// Arrays must be populated in order matching their index space.
let push_identity = fn (arr: i64, i: i64, n: i64) -> unit do
  if i < n then
    intarr_push(id: arr, val: i)
    push_identity(arr: arr, i: i + 1, n: n)
  end
end
let push_offset = fn (arr: i64, i: i64, n: i64, off: i64) -> unit do
  if i < n then
    intarr_push(id: arr, val: i + off)
    push_offset(arr: arr, i: i + 1, n: n, off: off)
  end
end

let remap_main_locals = fn (remap: i64, m_fimp: i64, m_loc: i64,
    kept_fimp: i64, n_stubs: i64, d_loc: i64) -> unit do
  // Main locals sit at merged idx = (kept_fimp + n_stubs + d_loc) + (i - m_fimp).
  // Entries m_fimp..m_fimp+m_loc append after main-import entries.
  push_offset(arr: remap, i: m_fimp, n: m_fimp + m_loc,
    off: kept_fimp + n_stubs + d_loc - m_fimp)
end

let remap_dep_locals = fn (remap: i64, dep_fimp: i64, d_loc: i64,
    kept_fimp: i64, n_stubs: i64) -> unit do
  // Dep locals sit at merged idx = (kept_fimp + n_stubs) + (i - dep_fimp).
  push_offset(arr: remap, i: dep_fimp, n: dep_fimp + d_loc,
    off: kept_fimp + n_stubs - dep_fimp)
end

// ─── Instruction rewriter ─────────────────────────────────────────────────

// Context keys in ps: "remap", "glo", "typ", "tbl"
let rw_body = fn (ps: i64, out: %ByteBuffer, src: &ByteBuffer,
    body_start: i64, body_end: i64) -> %ByteBuffer do
  let pk = rd_uleb(buf: src, pos: body_start)
  let n_local_groups = pval(pk: pk)
  let locals_end = skip_local_decls(buf: src, pos: ppos(pk: pk), remaining: n_local_groups)
  let %out = bb.copy_range(dst: %out, src: src, start: body_start, end_pos: locals_end)
  set_p(ps: ps, v: locals_end)
  return rw_instrs(ps: ps, out: %out, src: src, end_pos: body_end)
end

let skip_local_decls = fn (buf: &ByteBuffer, pos: i64, remaining: i64) -> i64 do
  if remaining <= 0 then return pos end
  let pk = rd_uleb(buf: buf, pos: pos)
  return skip_local_decls(buf: buf, pos: ppos(pk: pk) + 1, remaining: remaining - 1)
end

// Context keys in ps: "remap" -> smap id, "glo" -> glo_off, "typ" -> type_off, "tbl" -> tbl_off
let rw_instrs = fn (ps: i64, out: %ByteBuffer, src: &ByteBuffer, end_pos: i64) -> %ByteBuffer do
  let pos = get_p(ps: ps)
  if pos >= end_pos then return %out end
  let op = bb.get_byte(buf: src, idx: pos)
  set_p(ps: ps, v: pos + 1)

  // Classify opcode into handling groups:
  // 0 = no operand, 1 = single ULEB (no remap), 2 = call_indirect (type_off + tbl_off),
  // 3 = blocktype, 4 = sleb, 5 = f64 (8 bytes), 6 = memarg (2 ULEBs, load/store),
  // 7 = mem index byte, 8 = br_table, 9 = try_table, 10 = 0xFC prefix,
  // 11 = call/return_call (remap func idx), 12 = global.get/set (add glo_off),
  // 13 = ref.func (remap func idx)
  let cls = if op >= 40 then
    if op <= 62 then 6
    else
    if op == 63 then 7
    else
    if op == 64 then 7
    else
    if op == 65 then 4
    else
    if op == 66 then 4
    else
    if op == 68 then 5
    else
    if op == 210 then 13
    else
    if op == 252 then 10
    else 0
    end end end end end end end end
  else
    match op do
      case 2 -> 3
      case 3 -> 3
      case 4 -> 3
      case 6 -> 9
      case 8 -> 1
      case 12 -> 1
      case 13 -> 1
      case 14 -> 8
      case 16 -> 11
      case 17 -> 2
      case 18 -> 11
      case 32 -> 1
      case 33 -> 1
      case 34 -> 1
      case 35 -> 12
      case 36 -> 12
      case _ -> 0
    end
  end

  // Handle each class — flat if-return-end pattern for TCO + typechecker compat
  let %out = bb.push_byte(buf: %out, byte: op)

  if cls == 1 then
    let pos2 = get_p(ps: ps)
    let pk = rd_uleb(buf: src, pos: pos2)
    set_p(ps: ps, v: ppos(pk: pk))
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk))
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 2 then
    // call_indirect: type_idx (+ type_off), table_idx (+ tbl_off)
    let type_off = __nx_smap_get(id: ps, key: "typ", default_val: 0)
    let tbl_off = __nx_smap_get(id: ps, key: "tbl", default_val: 0)
    let pos2 = get_p(ps: ps)
    let pk = rd_uleb(buf: src, pos: pos2)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk) + type_off)
    let pk2 = rd_uleb(buf: src, pos: ppos(pk: pk))
    set_p(ps: ps, v: ppos(pk: pk2))
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk2) + tbl_off)
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 3 then
    let type_off = __nx_smap_get(id: ps, key: "typ", default_val: 0)
    let %out = rw_blocktype_operand(ps: ps, out: %out, src: src, type_off: type_off)
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 4 then
    // SLEB operand: no remap needed, just copy bytes verbatim.
    // Find terminal byte (first byte < 128 or >= 128 flipped — i.e., high bit clear)
    // and bulk-copy. Avoids rd_sleb entirely (which was hitting a codegen quirk).
    let pos2 = get_p(ps: ps)
    let end_sleb = scan_sleb_end(buf: src, pos: pos2)
    let %out = bb.copy_range(dst: %out, src: src, start: pos2, end_pos: end_sleb)
    set_p(ps: ps, v: end_sleb)
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 5 then
    let pos2 = get_p(ps: ps)
    let %out = bb.copy_range(dst: %out, src: src, start: pos2, end_pos: pos2 + 8)
    set_p(ps: ps, v: pos2 + 8)
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 6 then
    let pos2 = get_p(ps: ps)
    let pk = rd_uleb(buf: src, pos: pos2)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk))
    let pk2 = rd_uleb(buf: src, pos: ppos(pk: pk))
    set_p(ps: ps, v: ppos(pk: pk2))
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk2))
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 7 then
    let pos2 = get_p(ps: ps)
    let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos2))
    set_p(ps: ps, v: pos2 + 1)
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 8 then
    let pos2 = get_p(ps: ps)
    let pk = rd_uleb(buf: src, pos: pos2)
    let count = pval(pk: pk)
    let %out = bb.push_uleb128(buf: %out, val: count)
    set_p(ps: ps, v: ppos(pk: pk))
    let %out = copy_br_labels(ps: ps, out: %out, src: src, remaining: count + 1)
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 9 then
    let type_off = __nx_smap_get(id: ps, key: "typ", default_val: 0)
    let %out = rw_blocktype_operand(ps: ps, out: %out, src: src, type_off: type_off)
    let pos2 = get_p(ps: ps)
    let pk = rd_uleb(buf: src, pos: pos2)
    let n_handlers = pval(pk: pk)
    let %out = bb.push_uleb128(buf: %out, val: n_handlers)
    set_p(ps: ps, v: ppos(pk: pk))
    let %out = copy_try_handlers(ps: ps, out: %out, src: src, remaining: n_handlers)
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 10 then
    let pos2 = get_p(ps: ps)
    let pk = rd_uleb(buf: src, pos: pos2)
    let sub_op = pval(pk: pk)
    let %out = bb.push_uleb128(buf: %out, val: sub_op)
    set_p(ps: ps, v: ppos(pk: pk))
    let %out = rw_fc_prefix(ps: ps, out: %out, src: src, sub_op: sub_op)
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 11 then
    // call / return_call: remap function index via intarr (dense i32 lookup)
    let pos2 = get_p(ps: ps)
    let pk = rd_uleb(buf: src, pos: pos2)
    let old_idx = pval(pk: pk)
    set_p(ps: ps, v: ppos(pk: pk))
    let remap = __nx_smap_get(id: ps, key: "remap", default_val: 0)
    let new_idx = intarr_get(id: remap, idx: old_idx)
    let %out = bb.push_uleb128(buf: %out, val: new_idx)
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 12 then
    // global.get / global.set: add glo_off to index
    let glo_off = __nx_smap_get(id: ps, key: "glo", default_val: 0)
    let pos2 = get_p(ps: ps)
    let pk = rd_uleb(buf: src, pos: pos2)
    set_p(ps: ps, v: ppos(pk: pk))
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk) + glo_off)
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  if cls == 13 then
    // ref.func: remap function index via intarr
    let pos2 = get_p(ps: ps)
    let pk = rd_uleb(buf: src, pos: pos2)
    let old_idx = pval(pk: pk)
    set_p(ps: ps, v: ppos(pk: pk))
    let remap = __nx_smap_get(id: ps, key: "remap", default_val: 0)
    let new_idx = intarr_get(id: remap, idx: old_idx)
    let %out = bb.push_uleb128(buf: %out, val: new_idx)
    return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
  end
  // cls == 0: no operand, already pushed byte
  return rw_instrs(ps: ps, out: %out, src: src, end_pos: end_pos)
end

// Handle 0xFC prefix sub-opcodes (extracted to avoid deep nesting)
let rw_fc_prefix = fn (ps: i64, out: %ByteBuffer, src: &ByteBuffer, sub_op: i64) -> %ByteBuffer do
  if sub_op <= 7 then return %out end
  if sub_op == 10 then
    let pos3 = get_p(ps: ps)
    let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos3))
    let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos3 + 1))
    set_p(ps: ps, v: pos3 + 2)
    return %out
  end
  if sub_op == 11 then
    let pos3 = get_p(ps: ps)
    let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos3))
    set_p(ps: ps, v: pos3 + 1)
    return %out
  end
  if sub_op >= 8 then
    let pos3 = get_p(ps: ps)
    let pk2 = rd_uleb(buf: src, pos: pos3)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk2))
    if sub_op == 8 then
      let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: ppos(pk: pk2)))
      set_p(ps: ps, v: ppos(pk: pk2) + 1)
      return %out
    end
    if sub_op == 12 then
      let pk3 = rd_uleb(buf: src, pos: ppos(pk: pk2))
      let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk3))
      set_p(ps: ps, v: ppos(pk: pk3))
      return %out
    end
    if sub_op == 14 then
      let pk3 = rd_uleb(buf: src, pos: ppos(pk: pk2))
      let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk3))
      set_p(ps: ps, v: ppos(pk: pk3))
      return %out
    end
    set_p(ps: ps, v: ppos(pk: pk2))
    return %out
  end
  return %out
end


let rw_blocktype_operand = fn (ps: i64, out: %ByteBuffer, src: &ByteBuffer, type_off: i64) -> %ByteBuffer do
  let pos = get_p(ps: ps)
  let b = bb.get_byte(buf: src, idx: pos)
  // void blocktype (0x40) or valtype (>= 0x60)
  if b == 64 then
    set_p(ps: ps, v: pos + 1)
    return bb.push_byte(buf: %out, byte: 64)
  end
  if b >= 96 then
    set_p(ps: ps, v: pos + 1)
    return bb.push_byte(buf: %out, byte: b)
  end
  // Type index as sleb
  let end2 = rd_sleb(ps: ps, buf: src, pos: pos)
  let type_idx = get_v(ps: ps)
  set_p(ps: ps, v: end2)
  return bb.push_sleb128(buf: %out, val: type_idx + type_off)
end

let copy_br_labels = fn (ps: i64, out: %ByteBuffer, src: &ByteBuffer, remaining: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let pos = get_p(ps: ps)
  let pk = rd_uleb(buf: src, pos: pos)
  set_p(ps: ps, v: ppos(pk: pk))
  let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk))
  return copy_br_labels(ps: ps, out: %out, src: src, remaining: remaining - 1)
end

let copy_try_handlers = fn (ps: i64, out: %ByteBuffer, src: &ByteBuffer, remaining: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let pos = get_p(ps: ps)
  let catch_kind = bb.get_byte(buf: src, idx: pos)
  let %out = bb.push_byte(buf: %out, byte: catch_kind)
  if catch_kind <= 1 then
    let pk = rd_uleb(buf: src, pos: pos + 1)
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk))
    let pk2 = rd_uleb(buf: src, pos: ppos(pk: pk))
    let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk2))
    set_p(ps: ps, v: ppos(pk: pk2))
    return copy_try_handlers(ps: ps, out: %out, src: src, remaining: remaining - 1)
  end
  let pk = rd_uleb(buf: src, pos: pos + 1)
  let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk))
  set_p(ps: ps, v: ppos(pk: pk))
  return copy_try_handlers(ps: ps, out: %out, src: src, remaining: remaining - 1)
end

// ─── Section emitters ─────────────────────────────────────────────────────

let emit_sec = fn (out: %ByteBuffer, sec_id: i64, content: &ByteBuffer) -> %ByteBuffer do
  let %out = bb.push_byte(buf: %out, byte: sec_id)
  let %out = bb.push_uleb128(buf: %out, val: bb.length(buf: content))
  return bb.push_buf(dst: %out, src: content)
end

let copy_raw_sec = fn (out: %ByteBuffer, src: &ByteBuffer, sec_pk: i64, sec_id: i64) -> %ByteBuffer do
  if sec_pk == 0 then return %out end
  let off = sec_off(pk: sec_pk)
  let sz = sec_sz(pk: sec_pk)
  let %tmp = bb.empty()
  let %tmp = bb.copy_range(dst: %tmp, src: src, start: off, end_pos: off + sz)
  let %out = emit_sec(out: %out, sec_id: sec_id, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let copy_sec_body = fn (buf: %ByteBuffer, src: &ByteBuffer, sec_pk: i64) -> %ByteBuffer do
  if sec_pk > 0 then
    let body = sec_body(buf: src, sec_pk: sec_pk)
    return bb.copy_range(dst: %buf, src: src, start: body, end_pos: sec_off(pk: sec_pk) + sec_sz(pk: sec_pk))
  end
  return %buf
end

let emit_merged_types_inline = fn (d_buf: &ByteBuffer, d_sec: i64, m_buf: &ByteBuffer, m_sec: i64, out: %ByteBuffer) -> %ByteBuffer do
  let %tmp = bb.empty()
  let m_count = count_sec(buf: m_buf, sec_pk: m_sec)
  let d_count = count_sec(buf: d_buf, sec_pk: d_sec)
  let %tmp = bb.push_uleb128(buf: %tmp, val: m_count + d_count)
  let %tmp = copy_sec_body(buf: %tmp, src: m_buf, sec_pk: m_sec)
  let %tmp = copy_sec_body(buf: %tmp, src: d_buf, sec_pk: d_sec)
  let %out = emit_sec(out: %out, sec_id: 1, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let copy_imports_with_type_off = fn (ps: i64, out: %ByteBuffer, buf: &ByteBuffer,
    pos: i64, remaining: i64, type_off: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let start = pos
  let _mod = rd_str(ps: ps, buf: buf, pos: pos)
  let pos2 = get_p(ps: ps)
  let _name = rd_str(ps: ps, buf: buf, pos: pos2)
  let pos3 = get_p(ps: ps)
  let kind = bb.get_byte(buf: buf, idx: pos3)
  if kind == 0 then
    // Function import: copy name bytes, then offset type index
    let %out = bb.copy_range(dst: %out, src: buf, start: start, end_pos: pos3 + 1)
    let pk = rd_uleb(buf: buf, pos: pos3 + 1)
    let type_idx = pval(pk: pk)
    let %out = bb.push_uleb128(buf: %out, val: type_idx + type_off)
    return copy_imports_with_type_off(ps: ps, out: %out, buf: buf,
      pos: ppos(pk: pk), remaining: remaining - 1, type_off: type_off)
  end
  // Non-function import: copy everything as-is
  let pos4 = skip_imp_desc(buf: buf, pos: pos3)
  let %out = bb.copy_range(dst: %out, src: buf, start: start, end_pos: pos4)
  return copy_imports_with_type_off(ps: ps, out: %out, buf: buf,
    pos: pos4, remaining: remaining - 1, type_off: type_off)
end

let maybe_copy_func_types = fn (buf: %ByteBuffer, src: &ByteBuffer, sec_pk: i64, off: i64) -> %ByteBuffer do
  if sec_pk > 0 then
    return copy_func_types_with_off(out: %buf, buf: src, sec_pk: sec_pk, off: off)
  end
  return %buf
end

let emit_merged_funcs = fn (out: %ByteBuffer,
    m_buf: &ByteBuffer, m_func_sec: i64, m_count: i64,
    d_buf: &ByteBuffer, d_func_sec: i64, d_count: i64,
    stub_types: i64, n_stubs: i64,
    d_type_off: i64) -> %ByteBuffer do
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: n_stubs + d_count + m_count)
  let %tmp = emit_stub_type_indices(out: %tmp, stub_types: stub_types, i: 0, n: n_stubs)
  let %tmp = maybe_copy_func_types(buf: %tmp, src: d_buf, sec_pk: d_func_sec, off: d_type_off)
  let %tmp = copy_sec_body(buf: %tmp, src: m_buf, sec_pk: m_func_sec)
  let %out = emit_sec(out: %out, sec_id: 3, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let emit_stub_type_indices = fn (out: %ByteBuffer, stub_types: i64, i: i64, n: i64) -> %ByteBuffer do
  if i >= n then return %out end
  let type_idx = __nx_smap_get(id: stub_types, key: str.from_i64(val: i), default_val: 0)
  let %out = bb.push_uleb128(buf: %out, val: type_idx)
  return emit_stub_type_indices(out: %out, stub_types: stub_types, i: i + 1, n: n)
end

let copy_func_types_with_off = fn (out: %ByteBuffer, buf: &ByteBuffer, sec_pk: i64, off: i64) -> %ByteBuffer do
  let pk = rd_uleb(buf: buf, pos: sec_off(pk: sec_pk))
  let count = pval(pk: pk)
  return copy_func_types_go(out: %out, buf: buf, pos: ppos(pk: pk), remaining: count, off: off)
end
let copy_func_types_go = fn (out: %ByteBuffer, buf: &ByteBuffer, pos: i64, remaining: i64, off: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let pk = rd_uleb(buf: buf, pos: pos)
  let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk) + off)
  return copy_func_types_go(out: %out, buf: buf, pos: ppos(pk: pk), remaining: remaining - 1, off: off)
end

let emit_merged_globals = fn (out: %ByteBuffer, m_buf: &ByteBuffer, m_sec: i64,
    d_buf: &ByteBuffer, d_sec: i64) -> %ByteBuffer do
  let m_count = count_sec(buf: m_buf, sec_pk: m_sec)
  let d_count = count_sec(buf: d_buf, sec_pk: d_sec)
  if m_count + d_count == 0 then return %out end
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: d_count + m_count)
  let %tmp = copy_sec_body(buf: %tmp, src: d_buf, sec_pk: d_sec)
  let %tmp = copy_sec_body(buf: %tmp, src: m_buf, sec_pk: m_sec)
  let %out = emit_sec(out: %out, sec_id: 6, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

// Like emit_merged_globals but patches main G0 (heap_base += reloc) and G1 (str_base = reloc).
// Main globals are: G0 (heap_base), G1 (str_base=0→patched), G2 (placeholder).
// Each global: valtype(1) + mut(1) + i32.const(1) + sleb128(value) + end(1).
let emit_remapped_exports = fn (ps: i64, out: %ByteBuffer, m_buf: &ByteBuffer, m_sec: i64,
    remap: i64) -> %ByteBuffer do
  if m_sec == 0 then return %out end
  let %tmp = bb.empty()
  let pk = rd_uleb(buf: m_buf, pos: sec_off(pk: m_sec))
  let count = pval(pk: pk)
  let %tmp = bb.push_uleb128(buf: %tmp, val: count)
  let %tmp = remap_export_entries(ps: ps, out: %tmp, buf: m_buf, pos: ppos(pk: pk),
    remaining: count, remap: remap)
  let %out = emit_sec(out: %out, sec_id: 7, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let remap_export_entries = fn (ps: i64, out: %ByteBuffer, buf: &ByteBuffer, pos: i64,
    remaining: i64, remap: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let name_start = pos
  let _name = rd_str(ps: ps, buf: buf, pos: pos)
  let pos2 = get_p(ps: ps)
  let kind = bb.get_byte(buf: buf, idx: pos2)
  let pk = rd_uleb(buf: buf, pos: pos2 + 1)
  let old_idx = pval(pk: pk)
  let pos3 = ppos(pk: pk)
  let %out = bb.copy_range(dst: %out, src: buf, start: name_start, end_pos: pos2)
  let %out = bb.push_byte(buf: %out, byte: kind)
  if kind == 0 then
    let new_idx = intarr_get(id: remap, idx: old_idx)
    let %out = bb.push_uleb128(buf: %out, val: new_idx)
    return remap_export_entries(ps: ps, out: %out, buf: buf, pos: pos3, remaining: remaining - 1, remap: remap)
  end
  let %out = bb.push_uleb128(buf: %out, val: old_idx)
  return remap_export_entries(ps: ps, out: %out, buf: buf, pos: pos3, remaining: remaining - 1, remap: remap)
end

// Context already set in ps: "remap", "glo", "typ", "tbl"
let maybe_rewrite_bodies = fn (ps: i64, buf: %ByteBuffer, src: &ByteBuffer, sec_pk: i64) -> %ByteBuffer do
  if sec_pk > 0 then
    return rewrite_code_bodies(ps: ps, out: %buf, src: src, sec_pk: sec_pk)
  end
  return %buf
end

let emit_merged_code = fn (ps: i64, out: %ByteBuffer,
    m_buf: &ByteBuffer, m_code_sec: i64, remap_m: i64, m_count: i64,
    d_buf: &ByteBuffer, d_code_sec: i64, remap_d: i64, d_count: i64,
    n_stubs: i64,
    m_glo_off: i64, d_glo_off: i64,
    m_type_off: i64, d_type_off: i64,
    m_tbl_off: i64, d_tbl_off: i64) -> %ByteBuffer do
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: n_stubs + d_count + m_count)
  let %tmp = emit_stub_bodies(out: %tmp, i: 0, n: n_stubs)
  // Set context for dep code body rewriting
  __nx_smap_put(id: ps, key: "remap", value: remap_d)
  __nx_smap_put(id: ps, key: "glo", value: d_glo_off)
  __nx_smap_put(id: ps, key: "typ", value: d_type_off)
  __nx_smap_put(id: ps, key: "tbl", value: d_tbl_off)
  let %tmp = maybe_rewrite_bodies(ps: ps, buf: %tmp, src: d_buf, sec_pk: d_code_sec)
  // Set context for main code body rewriting
  __nx_smap_put(id: ps, key: "remap", value: remap_m)
  __nx_smap_put(id: ps, key: "glo", value: m_glo_off)
  __nx_smap_put(id: ps, key: "typ", value: m_type_off)
  __nx_smap_put(id: ps, key: "tbl", value: m_tbl_off)
  let %tmp = maybe_rewrite_bodies(ps: ps, buf: %tmp, src: m_buf, sec_pk: m_code_sec)
  let %out = emit_sec(out: %out, sec_id: 10, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let emit_stub_bodies = fn (out: %ByteBuffer, i: i64, n: i64) -> %ByteBuffer do
  if i >= n then return %out end
  let %out = bb.push_uleb128(buf: %out, val: 3)
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_byte(buf: %out, byte: 11)
  return emit_stub_bodies(out: %out, i: i + 1, n: n)
end

let rewrite_code_bodies = fn (ps: i64, out: %ByteBuffer, src: &ByteBuffer, sec_pk: i64) -> %ByteBuffer do
  let pk = rd_uleb(buf: src, pos: sec_off(pk: sec_pk))
  let count = pval(pk: pk)
  let %body_buf = bb.empty()
  let %out = rewrite_code_go(ps: ps, out: %out, src: src, pos: ppos(pk: pk), remaining: count, body_buf: %body_buf)
  return %out
end
let rewrite_code_go = fn (ps: i64, out: %ByteBuffer, src: &ByteBuffer, pos: i64, remaining: i64, body_buf: %ByteBuffer) -> %ByteBuffer do
  if remaining <= 0 then
    bb.free(buf: %body_buf)
    return %out
  end
  let pk = rd_uleb(buf: src, pos: pos)
  let body_size = pval(pk: pk)
  let body_start = ppos(pk: pk)
  let body_end = body_start + body_size
  let %body_buf = bb.truncate(buf: %body_buf, len: 0)
  let %body_buf = rw_body(ps: ps, out: %body_buf, src: src, body_start: body_start, body_end: body_end)
  let new_size = bb.length(buf: &body_buf)
  let %out = bb.push_uleb128(buf: %out, val: new_size)
  let %out = bb.push_buf(dst: %out, src: &body_buf)
  return rewrite_code_go(ps: ps, out: %out, src: src, pos: body_end, remaining: remaining - 1, body_buf: %body_buf)
end

// Find the highest data-segment end (offset + length) in a data section.
// Returns 0 if no data segments.
let find_data_end = fn (buf: &ByteBuffer, sec_pk: i64) -> i64 do
  if sec_pk == 0 then return 0 end
  let pk = rd_uleb(buf: buf, pos: sec_off(pk: sec_pk))
  return find_data_end_go(buf: buf, pos: ppos(pk: pk), remaining: pval(pk: pk), max_end: 0)
end
let find_data_end_go = fn (buf: &ByteBuffer, pos: i64, remaining: i64, max_end: i64) -> i64 do
  if remaining <= 0 then return max_end end
  // Active segment: flags=0x00, i32.const(0x41), uleb128(offset), end(0x0B), uleb128(len), data
  let _flags = bb.get_byte(buf: buf, idx: pos)
  let _opcode = bb.get_byte(buf: buf, idx: pos + 1)
  let pk_off = rd_uleb(buf: buf, pos: pos + 2)
  let offset = pval(pk: pk_off)
  let end_expr = ppos(pk: pk_off) + 1
  let pk_len = rd_uleb(buf: buf, pos: end_expr)
  let data_len = pval(pk: pk_len)
  let data_start = ppos(pk: pk_len)
  let seg_end = offset + data_len
  let new_max = if seg_end > max_end then seg_end else max_end end
  return find_data_end_go(buf: buf, pos: data_start + data_len, remaining: remaining - 1, max_end: new_max)
end

// Copy main data segments with offset relocation: each segment's i32.const offset += reloc.
let copy_data_relocated = fn (out: %ByteBuffer, src: &ByteBuffer, sec_pk: i64, reloc: i64) -> %ByteBuffer do
  if sec_pk == 0 then return %out end
  let pk = rd_uleb(buf: src, pos: sec_off(pk: sec_pk))
  return copy_data_relocated_go(out: %out, src: src, pos: ppos(pk: pk), remaining: pval(pk: pk), reloc: reloc)
end
let copy_data_relocated_go = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, remaining: i64, reloc: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  // Emit flags + opcode
  let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos))
  let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: pos + 1))
  // Read original offset, add reloc, emit new offset
  let pk_off = rd_uleb(buf: src, pos: pos + 2)
  let new_offset = pval(pk: pk_off) + reloc
  let %out = bb.push_sleb128(buf: %out, val: new_offset)
  // Emit end opcode
  let %out = bb.push_byte(buf: %out, byte: bb.get_byte(buf: src, idx: ppos(pk: pk_off)))
  // Copy data length + data bytes
  let end_expr = ppos(pk: pk_off) + 1
  let pk_len = rd_uleb(buf: src, pos: end_expr)
  let data_len = pval(pk: pk_len)
  let data_start = ppos(pk: pk_len)
  let %out = bb.push_uleb128(buf: %out, val: data_len)
  let %out = bb.copy_range(dst: %out, src: src, start: data_start, end_pos: data_start + data_len)
  return copy_data_relocated_go(out: %out, src: src, pos: data_start + data_len, remaining: remaining - 1, reloc: reloc)
end

let emit_merged_data = fn (out: %ByteBuffer, m_buf: &ByteBuffer, m_sec: i64,
    d_buf: &ByteBuffer, d_sec: i64, reloc: i64) -> %ByteBuffer do
  let m_count = count_sec(buf: m_buf, sec_pk: m_sec)
  let d_count = count_sec(buf: d_buf, sec_pk: d_sec)
  if m_count + d_count == 0 then return %out end
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: d_count + m_count)
  let %tmp = copy_sec_body(buf: %tmp, src: d_buf, sec_pk: d_sec)
  let %tmp = copy_data_relocated(out: %tmp, src: m_buf, sec_pk: m_sec, reloc: reloc)
  let %out = emit_sec(out: %out, sec_id: 11, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let maybe_remap_elem = fn (ps: i64, buf: %ByteBuffer, src: &ByteBuffer, sec_pk: i64, remap: i64) -> %ByteBuffer do
  if sec_pk > 0 then
    return remap_elem_segments(ps: ps, out: %buf, buf: src, sec_pk: sec_pk, remap: remap)
  end
  return %buf
end

let emit_merged_elements = fn (ps: i64, out: %ByteBuffer,
    d_buf: &ByteBuffer, d_sec: i64, remap_d: i64,
    m_buf: &ByteBuffer, m_sec: i64, remap_m: i64) -> %ByteBuffer do
  let d_count = count_sec(buf: d_buf, sec_pk: d_sec)
  let m_count = count_sec(buf: m_buf, sec_pk: m_sec)
  if d_count + m_count == 0 then return %out end
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: d_count + m_count)
  let %tmp = maybe_remap_elem(ps: ps, buf: %tmp, src: d_buf, sec_pk: d_sec, remap: remap_d)
  let %tmp = maybe_remap_elem(ps: ps, buf: %tmp, src: m_buf, sec_pk: m_sec, remap: remap_m)
  let %out = emit_sec(out: %out, sec_id: 9, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end

let remap_elem_segments = fn (ps: i64, out: %ByteBuffer, buf: &ByteBuffer, sec_pk: i64, remap: i64) -> %ByteBuffer do
  let pk = rd_uleb(buf: buf, pos: sec_off(pk: sec_pk))
  return remap_elem_go(ps: ps, out: %out, buf: buf, pos: ppos(pk: pk), remaining: pval(pk: pk), remap: remap)
end
let remap_elem_go = fn (ps: i64, out: %ByteBuffer, buf: &ByteBuffer, pos: i64, remaining: i64, remap: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let kind = bb.get_byte(buf: buf, idx: pos)
  let %out = bb.push_byte(buf: %out, byte: kind)
  if kind == 0 then
    // Init expression: i32.const <sleb-offset> end — no remap needed.
    // Bulk-copy the opcode + SLEB + end byte (scan_sleb_end finds terminal).
    let sleb_start = pos + 2
    let sleb_end = scan_sleb_end(buf: buf, pos: sleb_start)
    // Copy [pos+1 .. sleb_end+1) — opcode + SLEB + end byte
    let %out = bb.copy_range(dst: %out, src: buf, start: pos + 1, end_pos: sleb_end + 1)
    let pk = rd_uleb(buf: buf, pos: sleb_end + 1)
    let n_funcs = pval(pk: pk)
    let %out = bb.push_uleb128(buf: %out, val: n_funcs)
    set_p(ps: ps, v: ppos(pk: pk))
    let %out = remap_elem_funcs(ps: ps, out: %out, buf: buf, remaining: n_funcs, remap: remap)
    return remap_elem_go(ps: ps, out: %out, buf: buf, pos: get_p(ps: ps), remaining: remaining - 1, remap: remap)
  end
  return %out
end

let remap_elem_funcs = fn (ps: i64, out: %ByteBuffer, buf: &ByteBuffer, remaining: i64, remap: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let pos = get_p(ps: ps)
  let pk = rd_uleb(buf: buf, pos: pos)
  let old_idx = pval(pk: pk)
  set_p(ps: ps, v: ppos(pk: pk))
  let new_idx = intarr_get(id: remap, idx: old_idx)
  let %out = bb.push_uleb128(buf: %out, val: new_idx)
  return remap_elem_funcs(ps: ps, out: %out, buf: buf, remaining: remaining - 1, remap: remap)
end

// ─── Full merge assembler ─────────────────────────────────────────────────
let emit_tag_sec_with_off = fn (out: %ByteBuffer, buf: &ByteBuffer, sec_pk: i64, off: i64) -> %ByteBuffer do
  if sec_pk == 0 then return %out end
  let tag_count = count_sec(buf: buf, sec_pk: sec_pk)
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: tag_count)
  let %tmp = offset_tag_types(out: %tmp, buf: buf, pos: sec_body(buf: buf, sec_pk: sec_pk), remaining: tag_count, off: off)
  let %out = emit_sec(out: %out, sec_id: 13, content: &tmp)
  bb.free(buf: %tmp)
  return %out
end
let offset_tag_types = fn (out: %ByteBuffer, buf: &ByteBuffer, pos: i64, remaining: i64, off: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let pk1 = rd_uleb(buf: buf, pos: pos)
  let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk1))
  let pk2 = rd_uleb(buf: buf, pos: ppos(pk: pk1))
  let %out = bb.push_uleb128(buf: %out, val: pval(pk: pk2) + off)
  return offset_tag_types(out: %out, buf: buf, pos: ppos(pk: pk2), remaining: remaining - 1, off: off)
end

// ─── Custom section preservation ──────────────────────────────────────────
// Scan all custom sections (id=0) in buf. Returns an smap keyed by sequential
// index ("0", "1", …) -> pack(content_start, sec_size). The special key
// "__count" holds the total number of custom sections discovered.
// `scan_secs` collapses all customs onto key="0", which is why we need this.
let scan_custom_secs = fn (buf: &ByteBuffer) -> i64 do
  let map = __nx_smap_new()
  let c = scan_custom_go(buf: buf, pos: 8, end_pos: bb.length(buf: buf), map: map, idx: 0)
  __nx_smap_put(id: map, key: "__count", value: c)
  return map
end
let scan_custom_go = fn (buf: &ByteBuffer, pos: i64, end_pos: i64, map: i64, idx: i64) -> i64 do
  if pos >= end_pos then return idx end
  let sec_id = bb.get_byte(buf: buf, idx: pos)
  let pk = rd_uleb(buf: buf, pos: pos + 1)
  let sec_size = pval(pk: pk)
  let content_start = ppos(pk: pk)
  let new_idx = if sec_id == 0 then
      __nx_smap_put(id: map, key: str.from_i64(val: idx), value: pack(val: content_start, p: sec_size))
      idx + 1
    else idx end
  return scan_custom_go(buf: buf, pos: content_start + sec_size, end_pos: end_pos, map: map, idx: new_idx)
end

// Compare the ULEB-prefixed section name at `content_start` to `target`.
let custom_name_equals = fn (buf: &ByteBuffer, content_start: i64, target: string) -> bool do
  let pk = rd_uleb(buf: buf, pos: content_start)
  let len = pval(pk: pk)
  let name_start = ppos(pk: pk)
  let tlen = str.byte_length(s: target)
  if len != tlen then return false end
  return name_eq_go(buf: buf, start: name_start, target: target, i: 0, n: tlen)
end
let name_eq_go = fn (buf: &ByteBuffer, start: i64, target: string, i: i64, n: i64) -> bool do
  if i >= n then return true end
  if bb.get_byte(buf: buf, idx: start + i) != str.char_code(s: target, idx: i) then return false end
  return name_eq_go(buf: buf, start: start, target: target, i: i + 1, n: n)
end

// Emit a custom section verbatim: id=0, ULEB(size), content bytes.
let emit_custom_raw = fn (out: %ByteBuffer, src: &ByteBuffer, content_start: i64, sec_size: i64) -> %ByteBuffer do
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_uleb128(buf: %out, val: sec_size)
  return bb.copy_range(dst: %out, src: src, start: content_start, end_pos: content_start + sec_size)
end

// Iterate name-section subsections; dispatch on subsec id.
// Subsec 1 (func names) and 2 (local names) get func_idx remapped.
// All other subsecs are pass-through.
let emit_name_subsecs_go = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64,
                                 end_pos: i64, remap: i64, remap_size: i64) -> %ByteBuffer do
  if pos >= end_pos then return %out end
  let sub_id = bb.get_byte(buf: src, idx: pos)
  let pk = rd_uleb(buf: src, pos: pos + 1)
  let sub_size = pval(pk: pk)
  let sub_start = ppos(pk: pk)
  let sub_end = sub_start + sub_size
  let %out = if sub_id == 1 then
      emit_name_funcsubsec(out: %out, src: src, sub_start: sub_start, remap: remap, remap_size: remap_size)
    else
      if sub_id == 2 then
        emit_name_localsubsec(out: %out, src: src, sub_start: sub_start, sub_size: sub_size, remap: remap, remap_size: remap_size)
      else
        bb.copy_range(dst: %out, src: src, start: pos, end_pos: sub_end)
      end
    end
  return emit_name_subsecs_go(out: %out, src: src, pos: sub_end, end_pos: end_pos, remap: remap, remap_size: remap_size)
end

// Re-emit subsec 1 (function names): vec<(func_idx:ULEB, name:ULEB+bytes)>.
// Build into tmp buf so we can prefix with ULEB(payload_len).
let emit_name_funcsubsec = fn (out: %ByteBuffer, src: &ByteBuffer, sub_start: i64,
                                 remap: i64, remap_size: i64) -> %ByteBuffer do
  let pk = rd_uleb(buf: src, pos: sub_start)
  let count = pval(pk: pk)
  let entries_start = ppos(pk: pk)
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: count)
  let %tmp = emit_name_func_entries(out: %tmp, src: src, pos: entries_start,
                                      remaining: count, remap: remap, remap_size: remap_size)
  let tmp_len = bb.length(buf: &tmp)
  let %out = bb.push_byte(buf: %out, byte: 1)
  let %out = bb.push_uleb128(buf: %out, val: tmp_len)
  let %out = bb.push_buf(dst: %out, src: &tmp)
  bb.free(buf: %tmp)
  return %out
end
let emit_name_func_entries = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64,
                                   remaining: i64, remap: i64, remap_size: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let pk1 = rd_uleb(buf: src, pos: pos)
  let old_idx = pval(pk: pk1)
  let after_idx = ppos(pk: pk1)
  let pk2 = rd_uleb(buf: src, pos: after_idx)
  let n_len = pval(pk: pk2)
  let n_end = ppos(pk: pk2) + n_len
  let new_idx = if old_idx < remap_size then intarr_get(id: remap, idx: old_idx) else old_idx end
  let %out = bb.push_uleb128(buf: %out, val: new_idx)
  let %out = bb.copy_range(dst: %out, src: src, start: after_idx, end_pos: n_end)
  return emit_name_func_entries(out: %out, src: src, pos: n_end, remaining: remaining - 1, remap: remap, remap_size: remap_size)
end

// Re-emit subsec 2 (local names): vec<(func_idx:ULEB, vec<(local_idx, name)>)>.
// Only the outer func_idx is remapped; inner local vec is copied verbatim.
let emit_name_localsubsec = fn (out: %ByteBuffer, src: &ByteBuffer, sub_start: i64, sub_size: i64,
                                  remap: i64, remap_size: i64) -> %ByteBuffer do
  let pk = rd_uleb(buf: src, pos: sub_start)
  let count = pval(pk: pk)
  let entries_start = ppos(pk: pk)
  let sub_end = sub_start + sub_size
  let %tmp = bb.empty()
  let %tmp = bb.push_uleb128(buf: %tmp, val: count)
  let %tmp = emit_name_local_entries(out: %tmp, src: src, pos: entries_start, end_pos: sub_end,
                                       remaining: count, remap: remap, remap_size: remap_size)
  let tmp_len = bb.length(buf: &tmp)
  let %out = bb.push_byte(buf: %out, byte: 2)
  let %out = bb.push_uleb128(buf: %out, val: tmp_len)
  let %out = bb.push_buf(dst: %out, src: &tmp)
  bb.free(buf: %tmp)
  return %out
end
let emit_name_local_entries = fn (out: %ByteBuffer, src: &ByteBuffer, pos: i64, end_pos: i64,
                                    remaining: i64, remap: i64, remap_size: i64) -> %ByteBuffer do
  if remaining <= 0 then return %out end
  let pk1 = rd_uleb(buf: src, pos: pos)
  let old_idx = pval(pk: pk1)
  let after_idx = ppos(pk: pk1)
  let pk2 = rd_uleb(buf: src, pos: after_idx)
  let inner_count = pval(pk: pk2)
  let inner_start = ppos(pk: pk2)
  let inner_end = skip_local_inner(src: src, pos: inner_start, remaining: inner_count)
  let new_idx = if old_idx < remap_size then intarr_get(id: remap, idx: old_idx) else old_idx end
  let %out = bb.push_uleb128(buf: %out, val: new_idx)
  let %out = bb.copy_range(dst: %out, src: src, start: after_idx, end_pos: inner_end)
  return emit_name_local_entries(out: %out, src: src, pos: inner_end, end_pos: end_pos,
                                   remaining: remaining - 1, remap: remap, remap_size: remap_size)
end
let skip_local_inner = fn (src: &ByteBuffer, pos: i64, remaining: i64) -> i64 do
  if remaining <= 0 then return pos end
  let pk1 = rd_uleb(buf: src, pos: pos)
  let pk2 = rd_uleb(buf: src, pos: ppos(pk: pk1))
  let name_end = ppos(pk: pk2) + pval(pk: pk2)
  return skip_local_inner(src: src, pos: name_end, remaining: remaining - 1)
end

// Emit a "name" custom section with function indices remapped via `remap`.
// The section-name ULEB-string is copied verbatim; subsections are walked.
let emit_name_remapped = fn (out: %ByteBuffer, src: &ByteBuffer,
                              content_start: i64, sec_size: i64,
                              remap: i64, remap_size: i64) -> %ByteBuffer do
  let sec_end = content_start + sec_size
  let pk = rd_uleb(buf: src, pos: content_start)
  let name_len = pval(pk: pk)
  let name_end = ppos(pk: pk) + name_len
  let %payload = bb.empty()
  let %payload = bb.copy_range(dst: %payload, src: src, start: content_start, end_pos: name_end)
  let %payload = emit_name_subsecs_go(out: %payload, src: src, pos: name_end, end_pos: sec_end,
                                        remap: remap, remap_size: remap_size)
  let payload_len = bb.length(buf: &payload)
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_uleb128(buf: %out, val: payload_len)
  let %out = bb.push_buf(dst: %out, src: &payload)
  bb.free(buf: %payload)
  return %out
end

// Emit all preserved custom sections from `buf`:
//   * "name"  → rewritten via `remap` (func indices remapped per merge).
//   * others  → passed through byte-for-byte (DWARF, producers, target_features,
//     etc.). For .debug_* this is a placeholder — PC-offset rewriting is only
//     needed when nxc codegen starts emitting DWARF (currently it does not).
let emit_preserved_customs = fn (out: %ByteBuffer, buf: &ByteBuffer, customs: i64,
                                   remap: i64, remap_size: i64) -> %ByteBuffer do
  let total = __nx_smap_get(id: customs, key: "__count", default_val: 0)
  return emit_custom_each(out: %out, buf: buf, customs: customs, idx: 0, total: total,
                            remap: remap, remap_size: remap_size)
end
let emit_custom_each = fn (out: %ByteBuffer, buf: &ByteBuffer, customs: i64, idx: i64, total: i64,
                             remap: i64, remap_size: i64) -> %ByteBuffer do
  if idx >= total then return %out end
  let pk = __nx_smap_get(id: customs, key: str.from_i64(val: idx), default_val: 0)
  let content_start = pval(pk: pk)
  let sec_size = ppos(pk: pk)
  let %out = if custom_name_equals(buf: buf, content_start: content_start, target: "name") then
      emit_name_remapped(out: %out, src: buf, content_start: content_start, sec_size: sec_size,
                          remap: remap, remap_size: remap_size)
    else
      emit_custom_raw(out: %out, src: buf, content_start: content_start, sec_size: sec_size)
    end
  return emit_custom_each(out: %out, buf: buf, customs: customs, idx: idx + 1, total: total,
                            remap: remap, remap_size: remap_size)
end

export let merge_with_stdlib = fn (core_wasm: %ByteBuffer, stdlib_path: string) -> %ByteBuffer do
  let %dep = bb.read_binary_file(path: stdlib_path)
  let ps = __nx_smap_new()

  let m_secs = scan_secs(buf: &core_wasm)
  let d_secs = scan_secs(buf: &dep)

  // Dep types first → dep type indices unchanged, main types offset by dep count
  let d_type_off = 0
  let m_type_off = count_sec(buf: &dep, sec_pk: get_sec(map: d_secs, sec: 1))

  let dep_exports = parse_dep_exports(ps: ps, buf: &dep, sec_pk: get_sec(map: d_secs, sec: 7))

  let dep_fimp = count_func_imps(ps: ps, buf: &dep, sec_pk: get_sec(map: d_secs, sec: 2))
  let kept_fimp = dep_fimp
  let n_stubs = 0

  let d_loc = count_sec(buf: &dep, sec_pk: get_sec(map: d_secs, sec: 3))
  let m_fimp = count_func_imps(ps: ps, buf: &core_wasm, sec_pk: get_sec(map: m_secs, sec: 2))
  let m_loc = count_sec(buf: &core_wasm, sec_pk: get_sec(map: m_secs, sec: 3))

  // Count main's non-stdlib imports
  let m_imp_sec_pk = get_sec(map: m_secs, sec: 2)
  // m_kept_all = ALL non-stdlib imports (for import section entry count)
  let m_kept_all = count_main_kept_imps(ps: ps, buf: &core_wasm, sec_pk: m_imp_sec_pk)
  // m_kept = non-stdlib FUNCTION imports only (for function index layout)
  let m_kept = count_main_kept_func_imps(ps: ps, buf: &core_wasm, sec_pk: m_imp_sec_pk)

  // Dep remap intarr: identity for WASI imports, then offset for dep locals.
  // All stdlib imports are WASI (indices preserved); only used by element-segment remap.
  let remap_d = intarr_new()
  push_identity(arr: remap_d, i: 0, n: dep_fimp)
  remap_dep_locals(remap: remap_d, dep_fimp: dep_fimp, d_loc: d_loc,
    kept_fimp: kept_fimp + m_kept, n_stubs: n_stubs)

  let remap_m = intarr_new()
  // Store context for resolve_main_imports
  // "kept" = dep_fimp + m_kept (base for remap_dep_func: dep locals start after all func imports)
  // "m_imp_base" = dep_fimp (base for non-stdlib main func imports, right after dep WASI imports)
  __nx_smap_put(id: ps, key: "remap", value: remap_m)
  __nx_smap_put(id: ps, key: "dep_exp", value: dep_exports)
  __nx_smap_put(id: ps, key: "kept", value: kept_fimp + m_kept)
  __nx_smap_put(id: ps, key: "m_imp_base", value: kept_fimp)
  __nx_smap_put(id: ps, key: "dep_fimp", value: dep_fimp)
  __nx_smap_put(id: ps, key: "stubs", value: n_stubs)
  resolve_main_imports(ps: ps, buf: &core_wasm, sec_pk: m_imp_sec_pk)

  // Main locals start after: dep WASI imports + main non-stdlib func imports + stubs + dep locals
  remap_main_locals(remap: remap_m, m_fimp: m_fimp, m_loc: m_loc,
    kept_fimp: kept_fimp + m_kept, n_stubs: n_stubs, d_loc: d_loc)

  let d_glo = count_sec(buf: &dep, sec_pk: get_sec(map: d_secs, sec: 6))
  let d_tbl_count = count_sec(buf: &dep, sec_pk: get_sec(map: d_secs, sec: 4))

  // Assemble output — all section emission inlined to avoid parameter-passing bugs
  // in Nexus functions with many params (param sorting causes confusion)
  let %out = assemble_header()

  // Section 1: merged types (DEP first, then main)
  let %out = emit_merged_types_inline(out: %out,
    m_buf: &dep, m_sec: get_sec(map: d_secs, sec: 1),
    d_buf: &core_wasm, d_sec: get_sec(map: m_secs, sec: 1))

  // Section 2: merged imports (dep WASI imports + main non-stdlib imports)
  // Dep imports need type offset (dep types come second in merged type section)
  // Main non-stdlib imports need no type offset (main types come first)
  let d_imp_pk = get_sec(map: d_secs, sec: 2)
  let dep_imp_count = count_sec(buf: &dep, sec_pk: d_imp_pk)
  let total_imp_count = dep_imp_count + m_kept_all
  let %tmp_i = bb.empty()
  let %tmp_i = bb.push_uleb128(buf: %tmp_i, val: total_imp_count)
  // Copy dep imports with type offset
  let %tmp_i = if d_imp_pk > 0 then
    copy_imports_with_type_off(ps: ps, out: %tmp_i, buf: &dep,
      pos: sec_body(buf: &dep, sec_pk: d_imp_pk), remaining: dep_imp_count, type_off: d_type_off)
  else %tmp_i end
  // Copy main's non-stdlib imports (type indices already correct — main types first)
  let %tmp_i = copy_main_kept_imps(ps: ps, out: %tmp_i, buf: &core_wasm, sec_pk: m_imp_sec_pk)
  let %out = emit_sec(out: %out, sec_id: 2, content: &tmp_i)
  bb.free(buf: %tmp_i)

  // Section 3: merged func types (count + dep with type offset + main)
  let d_func_sec_pk = get_sec(map: d_secs, sec: 3)
  let m_func_sec_pk = get_sec(map: m_secs, sec: 3)
  let %tmp_f = bb.empty()
  // Use code section counts (rewrite_code_bodies determines the actual body count)
  let d_code_cnt = count_sec(buf: &dep, sec_pk: get_sec(map: d_secs, sec: 10))
  let m_code_cnt = count_sec(buf: &core_wasm, sec_pk: get_sec(map: m_secs, sec: 10))
  // TODO: m_code_cnt != m_loc (23 vs 28 for simple program). Need to investigate.
  // Use d_code_cnt + m_code_cnt to match code section bodies
  let n_total_funcs = n_stubs + d_code_cnt + m_code_cnt
  let %tmp_f = bb.push_uleb128(buf: %tmp_f, val: n_total_funcs)
  // Dep func types: NO offset (dep types first)
  let %tmp_f = copy_sec_body(buf: %tmp_f, src: &dep, sec_pk: d_func_sec_pk)
  // Main func types: offset by m_type_off
  let %tmp_f = if m_func_sec_pk > 0 then
    copy_func_types_with_off(out: %tmp_f, buf: &core_wasm, sec_pk: m_func_sec_pk, off: m_type_off)
  else %tmp_f end
  let %out = emit_sec(out: %out, sec_id: 3, content: &tmp_f)
  bb.free(buf: %tmp_f)

  // Section 4: table (from dep)
  let %out = copy_raw_sec(out: %out, src: &dep, sec_pk: get_sec(map: d_secs, sec: 4), sec_id: 4)
  // Compute relocation base: dep_initial_pages * 65536 (above dep's entire memory region)
  // This ensures main data doesn't overlap with dep's stack, data, or heap.
  // Size memory to cover both dep and main data (main already at absolute offsets)
  let d_data_end = find_data_end(buf: &dep, sec_pk: get_sec(map: d_secs, sec: 11))
  let m_data_end = find_data_end(buf: &core_wasm, sec_pk: get_sec(map: m_secs, sec: 11))
  let max_data = if d_data_end > m_data_end then d_data_end else m_data_end end
  let min_pages = (max_data + 65535) / 65536
  let dep_pages = if get_sec(map: d_secs, sec: 5) > 0 then
    let pk_mem = rd_uleb(buf: &dep, pos: sec_off(pk: get_sec(map: d_secs, sec: 5)))
    let pk_min = rd_uleb(buf: &dep, pos: ppos(pk: pk_mem) + 1)
    pval(pk: pk_min)
  else 0 end
  let pages_raw = if dep_pages > min_pages then dep_pages else min_pages end
  // Reserve ≥256 initial pages (16MB) for merged modules. The compiler loads
  // stdlib (~300KB) + main code + allocates Vec<u8>-backed buffers; dlmalloc
  // fragmentation under doubling-growth patterns exhausts a 1.2MB heap well
  // before memory.grow proves out. 16MB suffices for stage2.
  let pages = if pages_raw < 256 then 256 else pages_raw end
  let %tmp_mem = bb.empty()
  let %tmp_mem = bb.push_uleb128(buf: %tmp_mem, val: 1)
  let %tmp_mem = bb.push_byte(buf: %tmp_mem, byte: 0)
  let %tmp_mem = bb.push_uleb128(buf: %tmp_mem, val: pages)
  let %out = emit_sec(out: %out, sec_id: 5, content: &tmp_mem)
  bb.free(buf: %tmp_mem)
  // Section 13: tag (from main, type indices offset by m_type_off)
  let %out = emit_tag_sec_with_off(out: %out, buf: &core_wasm, sec_pk: get_sec(map: m_secs, sec: 13), off: m_type_off)

  // Section 6: merged globals (dep first, then main)
  let m_glo_pk = get_sec(map: m_secs, sec: 6)
  let d_glo_pk = get_sec(map: d_secs, sec: 6)
  let %out = emit_merged_globals(out: %out,
    m_buf: &core_wasm, m_sec: m_glo_pk,
    d_buf: &dep, d_sec: d_glo_pk)

  // Section 7: remapped exports (main exports with func idx remap)
  let %out = emit_remapped_exports(ps: ps, out: %out,
    m_buf: &core_wasm, m_sec: get_sec(map: m_secs, sec: 7), remap: remap_m)

  // Section 9: merged elements (dep + main, both remapped)
  let %out = emit_merged_elements(ps: ps, out: %out,
    d_buf: &dep, d_sec: get_sec(map: d_secs, sec: 9), remap_d: remap_d,
    m_buf: &core_wasm, m_sec: get_sec(map: m_secs, sec: 9), remap_m: remap_m)

  // Section 10: merged code (stubs + dep bodies rewritten + main bodies rewritten) — inlined
  let d_code_sec_pk = get_sec(map: d_secs, sec: 10)
  let m_code_sec_pk = get_sec(map: m_secs, sec: 10)
  // Use actual code section counts (must match bodies written by rewrite_code_bodies)
  let d_code_count = count_sec(buf: &dep, sec_pk: d_code_sec_pk)
  let m_code_count = count_sec(buf: &core_wasm, sec_pk: m_code_sec_pk)
  let %tmp_c = bb.empty()
  let %tmp_c = bb.push_uleb128(buf: %tmp_c, val: d_code_count + m_code_count)
  let %tmp_c = emit_stub_bodies(out: %tmp_c, i: 0, n: n_stubs)
  // Dep code: COPY VERBATIM (identity remap + dep types first = no rewriting needed)
  let %tmp_c = copy_sec_body(buf: %tmp_c, src: &dep, sec_pk: d_code_sec_pk)
  // Main code bodies — rewrite with intarr-backed func remap (remap_m covers
  // all main fidxs: imports 0..m_fimp, locals m_fimp..m_fimp+m_loc)
  __nx_smap_put(id: ps, key: "remap", value: remap_m)
  __nx_smap_put(id: ps, key: "glo", value: d_glo)
  __nx_smap_put(id: ps, key: "typ", value: m_type_off)
  let _r = __nx_smap_put(id: ps, key: "tbl", value: d_tbl_count)
  let %tmp_c = maybe_rewrite_bodies(ps: ps, buf: %tmp_c, src: &core_wasm, sec_pk: m_code_sec_pk)
  let %out = emit_sec(out: %out, sec_id: 10, content: &tmp_c)
  bb.free(buf: %tmp_c)

  // Section 11: merged data (dep + main, both verbatim — codegen already used correct offsets)
  let %out = emit_merged_data(out: %out,
    m_buf: &core_wasm, m_sec: get_sec(map: m_secs, sec: 11),
    d_buf: &dep, d_sec: get_sec(map: d_secs, sec: 11), reloc: 0)

  // Preserve custom sections from both inputs. `name` sections are rewritten
  // with func indices remapped; other customs (producers, target_features,
  // future .debug_*) pass through verbatim. Must run before the remap intarrs
  // are freed.
  let m_customs = scan_custom_secs(buf: &core_wasm)
  let d_customs = scan_custom_secs(buf: &dep)
  let %out = emit_preserved_customs(out: %out, buf: &core_wasm, customs: m_customs,
                                      remap: remap_m, remap_size: m_fimp + m_loc)
  let %out = emit_preserved_customs(out: %out, buf: &dep, customs: d_customs,
                                      remap: remap_d, remap_size: dep_fimp + d_loc)
  __nx_smap_free(id: m_customs)
  __nx_smap_free(id: d_customs)

  __nx_smap_free(id: ps)
  __nx_smap_free(id: m_secs)
  __nx_smap_free(id: d_secs)
  __nx_smap_free(id: dep_exports)
  intarr_free(id: remap_d)
  intarr_free(id: remap_m)
  bb.free(buf: %dep)
  bb.free(buf: %core_wasm)

  return %out
end

let assemble_header = fn () -> %ByteBuffer do
  let %out = bb.empty()
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_string(buf: %out, s: "asm")
  let %out = bb.push_byte(buf: %out, byte: 1)
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_byte(buf: %out, byte: 0)
  let %out = bb.push_byte(buf: %out, byte: 0)
  return %out
end

