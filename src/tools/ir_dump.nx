/**
 * ir_dump: machine-readable IR dumps for `nexus hir` / `nexus lir`.
 *
 * Two subcommands:
 *   - `nexus hir <file> [--format=text|json]` — parses + lowers to HIR, prints.
 *   - `nexus lir <file> [--format=text|json]` — same, but through MIR→LIR.
 *
 * JSON shape (V2, issue nexus-stj8): one JsonObject per top-level function
 * with `{name, params, ret_type, span, body}`. `body` is itself a structured
 * JSON expression tree (no opaque `body_pp` string) — each node carries
 *   `{kind: "<VariantName>", <variant-flat-fields>, children: [...]}`
 * where `children` holds sub-expr/sub-stmt nodes. Non-recursive payload
 * (literal value, identifier strings, types as strings) sits as flat keys
 * beside `kind`. Sub-lists with both a label and a child (call args, named
 * record fields, match arms, handler arms) are emitted under
 * purpose-specific keys (`args`, `fields`, `cases`, `arms`). Span objects
 * are `{offset, line, col}`; patterns are non-spanned per types.nx and so
 * omit `span`.
 *
 * V1 (issue nexus-ud6j) emitted `body_pp` as a stringified pretty-print;
 * V2 deletes that field entirely so consumers walk the tree structurally.
 */

import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"
import { SubcommandHit, detect_subcommand } from "std:argparse"
import { JsonValue, JsonString, JsonArray, JsonObject, JsonField, JsonThrow, JsonInt, JsonBool, JsonNull }, * as json from "std:json"
import { Span } from "src/common/token.nx"
import { Sigil, SigilImmutable, SigilMutable, SigilLinear, SigilBorrow, SigilLazy,
  BinaryOp, UnaryOp, Literal, LitInt, LitFloat, LitBool, LitChar, LitString, LitUnit,
  TypeExpr } from "src/common/ast.nx"
import { type_to_string } from "src/typecheck/types.nx"
import { HirProgram, HirFunction, HirParam, HirBody, EagerBody, LazyBody,
  HirExpr, HirExprKind, HirStmt, HirStmtKind, HirCallArg, HirNamedExpr,
  HirMatchCase, HirPatternKind, HirPatternField, HirRecordPatField,
  HirHandlerArm } from "src/ir/hir/types.nx"
import { LirFunction, LirParam, LirStmt, LirExpr, LirAtom, LirCallArg, LirNamedAtom } from "src/ir/lir/types.nx"

// ─── Subcommand stripping ──────────────────────────────────────────────────

export type ParsedHirSubcommand = ParsedHirSubcommand(remaining: [string], is_hir: bool)
export type ParsedLirSubcommand = ParsedLirSubcommand(remaining: [string], is_lir: bool)

/** Detect a leading `hir` subcommand. Thin wrapper over argparse's
 *  shared `detect_subcommand` primitive (issue nexus-8vu5). */
export let strip_hir_subcommand = fn (xs: [string]) -> ParsedHirSubcommand do
  match detect_subcommand(args: xs, kw: "hir") do | SubcommandHit(present, remaining) ->
    if present then return ParsedHirSubcommand(remaining, is_hir: true) end
    return ParsedHirSubcommand(remaining: xs, is_hir: false)
  end
end

/** Detect a leading `lir` subcommand. */
export let strip_lir_subcommand = fn (xs: [string]) -> ParsedLirSubcommand do
  match detect_subcommand(args: xs, kw: "lir") do | SubcommandHit(present, remaining) ->
    if present then return ParsedLirSubcommand(remaining, is_lir: true) end
    return ParsedLirSubcommand(remaining: xs, is_lir: false)
  end
end

// ─── Sigil / Literal / op stringifiers ─────────────────────────────────────

export let sigil_to_str = fn (s: Sigil) -> string do
  match s do
    | SigilImmutable -> return ""
    | SigilMutable -> return "mut"
    | SigilLinear -> return "%"
    | SigilBorrow -> return "&"
    | SigilLazy -> return "@"
  end
end

let literal_to_str = fn (lit: Literal) -> string do
  match lit do
    | LitInt(val) -> return str.from_i64(val)
    | LitFloat(val) -> return val
    | LitBool(val) -> return str.from_bool(val)
    | LitChar(val) -> return "char(" ++ str.from_i64(val) ++ ")"
    | LitString(val) -> return "\"" ++ val ++ "\""
    | LitUnit -> return "()"
  end
end

let binop_to_str = fn (op: BinaryOp) -> string do
  match op do
    | OpAdd -> return "+"
    | OpSub -> return "-"
    | OpMul -> return "*"
    | OpDiv -> return "/"
    | OpMod -> return "%"
    | OpFAdd -> return "+."
    | OpFSub -> return "-."
    | OpFMul -> return "*."
    | OpFDiv -> return "/."
    | OpEq -> return "=="
    | OpNe -> return "!="
    | OpLt -> return "<"
    | OpLe -> return "<="
    | OpGt -> return ">"
    | OpGe -> return ">="
    | OpFEq -> return "==."
    | OpFNe -> return "!=."
    | OpFLt -> return "<."
    | OpFLe -> return "<=."
    | OpFGt -> return ">."
    | OpFGe -> return ">=."
    | OpBitAnd -> return "&"
    | OpBitOr -> return "|"
    | OpBitXor -> return "^"
    | OpShl -> return "<<"
    | OpShr -> return ">>"
    | OpAnd -> return "&&"
    | OpOr -> return "||"
    | OpConcat -> return "++"
  end
end

let unop_to_str = fn (op: UnaryOp) -> string do
  match op do
    | OpNeg -> return "-"
    | OpFNeg -> return "-."
    | OpNot -> return "!"
  end
end

// ─── HIR body stringifier (text pretty-printer) ────────────────────────────

let join_strs = fn (xs: [string], sep: string) -> string do
  return str.join(xs, sep)
end

let hir_call_args_to_strs = fn (args: [HirCallArg]) -> [string] do
  match args do
    | [] -> return []
    | HirCallArg(label, value: v) :: rest ->
      let head = if str.length(s: label) > 0 then label ++ ": " ++ hir_expr_to_str(e: v) else hir_expr_to_str(e: v) end
      return head :: hir_call_args_to_strs(args: rest)
  end
end

let hir_exprs_to_strs = fn (es: [HirExpr]) -> [string] do
  match es do
    | [] -> return []
    | e :: rest -> return hir_expr_to_str(e) :: hir_exprs_to_strs(es: rest)
  end
end

let hir_named_exprs_to_strs = fn (fs: [HirNamedExpr]) -> [string] do
  match fs do
    | [] -> return []
    | HirNamedExpr(name, value: v) :: rest ->
      return (name ++ ": " ++ hir_expr_to_str(e: v)) :: hir_named_exprs_to_strs(fs: rest)
  end
end

let hir_params_to_strs = fn (ps: [HirParam]) -> [string] do
  match ps do
    | [] -> return []
    | HirParam(label, name, sigil, typ) :: rest ->
      let pre = sigil_to_str(s: sigil)
      let head = label ++ ": " ++ pre ++ name ++ ": " ++ type_to_string(typ)
      return head :: hir_params_to_strs(ps: rest)
  end
end

let hir_pattern_fields_to_strs = fn (fs: [HirPatternField]) -> [string] do
  match fs do
    | [] -> return []
    | HirPatternField(name, pattern: p) :: rest ->
      let pre = match name do | Some(val: n) -> n ++ ": " | None -> "" end
      return (pre ++ hir_pattern_to_str(p)) :: hir_pattern_fields_to_strs(fs: rest)
  end
end

let hir_record_pat_fields_to_strs = fn (fs: [HirRecordPatField]) -> [string] do
  match fs do
    | [] -> return []
    | HirRecordPatField(name, pattern: p) :: rest ->
      return (name ++ ": " ++ hir_pattern_to_str(p)) :: hir_record_pat_fields_to_strs(fs: rest)
  end
end

let hir_pattern_alts_to_strs = fn (alts: [HirPatternKind]) -> [string] do
  match alts do
    | [] -> return []
    | a :: rest -> return hir_pattern_to_str(p: a) :: hir_pattern_alts_to_strs(alts: rest)
  end
end

let hir_pattern_to_str = fn (p: HirPatternKind) -> string do
  match p do
    | PLit(lit) -> return literal_to_str(lit)
    | PVar(name, sigil) -> return sigil_to_str(s: sigil) ++ name
    | PCtor(variant, fields, sigil) ->
      let fs_str = join_strs(xs: hir_pattern_fields_to_strs(fs: fields), sep: ", ")
      return sigil_to_str(s: sigil) ++ variant ++ "(" ++ fs_str ++ ")"
    | PRec(fields, is_partial) ->
      let fs_str = join_strs(xs: hir_record_pat_fields_to_strs(fs: fields), sep: ", ")
      let suff = if is_partial then ", _" else "" end
      return "{" ++ fs_str ++ suff ++ "}"
    | PWild -> return "_"
    | POr(alts) -> return join_strs(xs: hir_pattern_alts_to_strs(alts), sep: " | ")
  end
end

let hir_match_cases_to_strs = fn (cs: [HirMatchCase]) -> [string] do
  match cs do
    | [] -> return []
    | HirMatchCase(pattern, body) :: rest ->
      let head = "| " ++ hir_pattern_to_str(p: pattern) ++ " -> " ++ hir_stmts_to_str(stmts: body)
      return head :: hir_match_cases_to_strs(cs: rest)
  end
end

let hir_handler_arms_to_strs = fn (arms: [HirHandlerArm]) -> [string] do
  match arms do
    | [] -> return []
    | HirHandlerArm(arm: HirFunction(name, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span: _, file: _, requires: _), cont_binder) :: rest ->
      let cb = match cont_binder do | Some(val: n) -> " with @" ++ n | None -> "" end
      return ("arm " ++ name ++ cb) :: hir_handler_arms_to_strs(arms: rest)
  end
end

let hir_expr_to_str = fn (e: HirExpr) -> string do
  match e do | HirExpr(node, span: _) ->
    match node do
      | Literal(lit) -> return literal_to_str(lit)
      | Variable(name, sigil) -> return sigil_to_str(s: sigil) ++ name
      | BinOp(left, op, right) ->
        return "(" ++ hir_expr_to_str(e: left) ++ " " ++ binop_to_str(op) ++ " " ++ hir_expr_to_str(e: right) ++ ")"
      | UnOp(op, operand) -> return "(" ++ unop_to_str(op) ++ hir_expr_to_str(e: operand) ++ ")"
      | Borrow(name, sigil) -> return "&" ++ sigil_to_str(s: sigil) ++ name
      | Call(func, args) ->
        let args_str = join_strs(xs: hir_call_args_to_strs(args), sep: ", ")
        return func ++ "(" ++ args_str ++ ")"
      | Ctor(variant, args, sigil) ->
        let args_str = join_strs(xs: hir_exprs_to_strs(es: args), sep: ", ")
        return sigil_to_str(s: sigil) ++ variant ++ "(" ++ args_str ++ ")"
      | Record(fields) ->
        let fs_str = join_strs(xs: hir_named_exprs_to_strs(fs: fields), sep: ", ")
        return "{" ++ fs_str ++ "}"
      | Array(elems) ->
        let es_str = join_strs(xs: hir_exprs_to_strs(es: elems), sep: ", ")
        return "[" ++ es_str ++ "]"
      | Index(target, index) -> return hir_expr_to_str(e: target) ++ "[" ++ hir_expr_to_str(e: index) ++ "]"
      | FieldAccess(target, field) -> return hir_expr_to_str(e: target) ++ "." ++ field
      | If(cond, then_branch, else_branch) ->
        let else_str = match else_branch do
          | Some(val: eb) -> " else " ++ hir_stmts_to_str(stmts: eb)
          | None -> ""
        end
        return "if " ++ hir_expr_to_str(e: cond) ++ " then " ++ hir_stmts_to_str(stmts: then_branch) ++ else_str ++ " end"
      | Match(target, cases) ->
        let cs_str = join_strs(xs: hir_match_cases_to_strs(cs: cases), sep: " ")
        return "match " ++ hir_expr_to_str(e: target) ++ " do " ++ cs_str ++ " end"
      | While(cond, body) ->
        return "while " ++ hir_expr_to_str(e: cond) ++ " do " ++ hir_stmts_to_str(stmts: body) ++ " end"
      | For(var, start, end_expr, body) ->
        return "for " ++ var ++ " in " ++ hir_expr_to_str(e: start) ++ ".." ++ hir_expr_to_str(e: end_expr) ++ " do " ++ hir_stmts_to_str(stmts: body) ++ " end"
      | Lambda(type_params: _, params, ret_type, body) ->
        let ps_str = join_strs(xs: hir_params_to_strs(ps: params), sep: ", ")
        return "fn (" ++ ps_str ++ ") -> " ++ type_to_string(typ: ret_type) ++ " do " ++ hir_stmts_to_str(stmts: body) ++ " end"
      | Raise(expr) -> return "raise " ++ hir_expr_to_str(e: expr)
      | Force(expr) -> return "@" ++ hir_expr_to_str(e: expr)
      | Thunk(body) -> return "@(" ++ hir_expr_to_str(e: body) ++ ")"
      | ExternalRef(symbol, type_params: _, arg_names: _, typ) -> return "extern " ++ symbol ++ ": " ++ type_to_string(typ)
      | Handler(port_name, arms) ->
        let arms_str = join_strs(xs: hir_handler_arms_to_strs(arms), sep: ", ")
        return "handler " ++ port_name ++ " { " ++ arms_str ++ " }"
    end
  end
end

let hir_stmt_to_str = fn (s: HirStmt) -> string do
  match s do | HirStmt(node, span: _) ->
    match node do
      | Let(name, sigil, typ, value) ->
        let pre = sigil_to_str(s: sigil)
        let ty_str = match typ do | Some(val: t) -> ": " ++ type_to_string(typ: t) | None -> "" end
        return "let " ++ pre ++ name ++ ty_str ++ " = " ++ hir_expr_to_str(e: value)
      | Expr(expr) -> return hir_expr_to_str(e: expr)
      | Return(expr) -> return "return " ++ hir_expr_to_str(e: expr)
      | Assign(target, value) -> return hir_expr_to_str(e: target) ++ " <- " ++ hir_expr_to_str(e: value)
      | Try(body, catch_param, catch_body) ->
        return "try " ++ hir_stmts_to_str(stmts: body) ++ " catch " ++ catch_param ++ " -> " ++ hir_stmts_to_str(stmts: catch_body) ++ " end"
      | Inject(handlers, body) ->
        let hs = join_strs(xs: handlers, sep: ", ")
        return "inject " ++ hs ++ " do " ++ hir_stmts_to_str(stmts: body) ++ " end"
    end
  end
end

let hir_stmts_to_str_go = fn (stmts: [HirStmt], acc: [string]) -> [string] do
  match stmts do
    | [] -> return list.reverse(xs: acc)
    | s :: rest -> return hir_stmts_to_str_go(stmts: rest, acc: hir_stmt_to_str(s) :: acc)
  end
end

let hir_stmts_to_str = fn (stmts: [HirStmt]) -> string do
  return join_strs(xs: hir_stmts_to_str_go(stmts, acc: []), sep: "; ")
end

let hir_body_to_str = fn (body: HirBody) -> string do
  match body do
    | EagerBody(stmts) -> return hir_stmts_to_str(stmts)
    | LazyBody(ast_expr: _, entries: _) -> return "<lazy-body>"
  end
end

// ─── HIR text dump ─────────────────────────────────────────────────────────

let hir_func_to_text_lines = fn (f: HirFunction) -> [string] do
  match f do | HirFunction(name, type_params: _, params, ret_type, throw_row: _, body, span: _, file: _, requires: _) ->
    let ps_str = join_strs(xs: hir_params_to_strs(ps: params), sep: ", ")
    let header = "fn " ++ name ++ "(" ++ ps_str ++ ") -> " ++ type_to_string(typ: ret_type)
    let body_line = "  body: " ++ hir_body_to_str(body)
    return [header, body_line]
  end
end

let hir_funcs_to_text_go = fn (fs: [HirFunction], acc: [string]) -> [string] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      let lines = hir_func_to_text_lines(f)
      return hir_funcs_to_text_go(fs: rest, acc: list.concat(xs: list.reverse(xs: lines), ys: acc))
  end
end

export let hir_to_text = fn (prog: HirProgram) -> string do
  match prog do | HirProgram(ports: _, functions, externals: _, handler_bindings: _, enum_defs: _, exception_groups: _, value_binding_names: _, type_defs: _) ->
    let banner = "=== HIR dump (" ++ str.from_i64(val: list.length(xs: functions)) ++ " functions) ==="
    let lines = hir_funcs_to_text_go(fs: functions, acc: [])
    return banner ++ "\n" ++ join_strs(xs: lines, sep: "\n") ++ "\n"
  end
end

// ─── HIR JSON dump ─────────────────────────────────────────────────────────

let hir_param_to_json = fn (p: HirParam) -> JsonValue do
  match p do | HirParam(label, name, sigil, typ) ->
    return JsonObject(fields: [
      JsonField(key: "label", value: JsonString(val: label)),
      JsonField(key: "name", value: JsonString(val: name)),
      JsonField(key: "sigil", value: JsonString(val: sigil_to_str(s: sigil))),
      JsonField(key: "type", value: JsonString(val: type_to_string(typ)))
    ])
  end
end

let hir_params_to_json_go = fn (ps: [HirParam], acc: [JsonValue]) -> [JsonValue] do
  match ps do
    | [] -> return list.reverse(xs: acc)
    | p :: rest -> return hir_params_to_json_go(ps: rest, acc: hir_param_to_json(p) :: acc)
  end
end

// ─── HIR JSON expr/stmt walker (V2: structured tree) ───────────────────────

/** Per-node shape used by the V2 IR-dump walker.
 *
 * Every emitted node is a JsonObject with at least:
 *   - "kind": the variant name (e.g. "Literal", "BinOp", "Let", …)
 *   - "children": JsonArray of sub-expr/sub-stmt JSON objects, in source order
 *
 * Non-recursive payload (variant names, identifier strings, literal values,
 * span offsets, …) lives as flat keys alongside `kind`/`children`. Sub-lists
 * that carry both a label and a child (call args, named record fields, match
 * arms with their pattern, handler arms with arm-function name) are emitted
 * as objects of their own under purpose-specific keys; the inner expr/stmt
 * is itself the JSON node, threaded back into the same shape recursively.
 *
 * Span is included when cheaply available — HirExpr and HirStmt both carry
 * one. Patterns are non-spanned (per types.nx) so we omit it there.
 */

let span_to_json = fn (sp: Span) -> JsonValue do
  match sp do | Span(offset, line, col) ->
    return JsonObject(fields: [
      JsonField(key: "offset", value: JsonInt(val: offset)),
      JsonField(key: "line", value: JsonInt(val: line)),
      JsonField(key: "col", value: JsonInt(val: col))
    ])
  end
end

let literal_kind_str = fn (lit: Literal) -> string do
  match lit do
    | LitInt(val: _) -> return "Int"
    | LitFloat(val: _) -> return "Float"
    | LitBool(val: _) -> return "Bool"
    | LitChar(val: _) -> return "Char"
    | LitString(val: _) -> return "String"
    | LitUnit -> return "Unit"
  end
end

let literal_value_json = fn (lit: Literal) -> JsonValue do
  match lit do
    | LitInt(val) -> return JsonInt(val)
    | LitFloat(val) -> return JsonString(val)
    | LitBool(val) -> return JsonBool(val)
    | LitChar(val) -> return JsonInt(val)
    | LitString(val) -> return JsonString(val)
    | LitUnit -> return JsonNull
  end
end

let hir_exprs_to_json_go = fn (es: [HirExpr], acc: [JsonValue]) -> [JsonValue] do
  match es do
    | [] -> return list.reverse(xs: acc)
    | e :: rest -> return hir_exprs_to_json_go(es: rest, acc: hir_expr_to_json(e) :: acc)
  end
end

let hir_stmts_to_json_go = fn (ss: [HirStmt], acc: [JsonValue]) -> [JsonValue] do
  match ss do
    | [] -> return list.reverse(xs: acc)
    | s :: rest -> return hir_stmts_to_json_go(ss: rest, acc: hir_stmt_to_json(s) :: acc)
  end
end

let hir_call_args_to_json_go = fn (args: [HirCallArg], acc: [JsonValue]) -> [JsonValue] do
  match args do
    | [] -> return list.reverse(xs: acc)
    | HirCallArg(label, value: v) :: rest ->
      let obj = JsonObject(fields: [
        JsonField(key: "label", value: JsonString(val: label)),
        JsonField(key: "value", value: hir_expr_to_json(e: v))
      ])
      return hir_call_args_to_json_go(args: rest, acc: obj :: acc)
  end
end

let hir_named_exprs_to_json_go = fn (fs: [HirNamedExpr], acc: [JsonValue]) -> [JsonValue] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | HirNamedExpr(name, value: v) :: rest ->
      let obj = JsonObject(fields: [
        JsonField(key: "name", value: JsonString(val: name)),
        JsonField(key: "value", value: hir_expr_to_json(e: v))
      ])
      return hir_named_exprs_to_json_go(fs: rest, acc: obj :: acc)
  end
end

let hir_pattern_fields_to_json_go = fn (fs: [HirPatternField], acc: [JsonValue]) -> [JsonValue] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | HirPatternField(name, pattern: p) :: rest ->
      let name_v = match name do
        | Some(val: n) -> JsonString(val: n)
        | None -> JsonNull
      end
      let obj = JsonObject(fields: [
        JsonField(key: "name", value: name_v),
        JsonField(key: "pattern", value: hir_pattern_to_json(p))
      ])
      return hir_pattern_fields_to_json_go(fs: rest, acc: obj :: acc)
  end
end

let hir_record_pat_fields_to_json_go = fn (fs: [HirRecordPatField], acc: [JsonValue]) -> [JsonValue] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | HirRecordPatField(name, pattern: p) :: rest ->
      let obj = JsonObject(fields: [
        JsonField(key: "name", value: JsonString(val: name)),
        JsonField(key: "pattern", value: hir_pattern_to_json(p))
      ])
      return hir_record_pat_fields_to_json_go(fs: rest, acc: obj :: acc)
  end
end

let hir_pattern_alts_to_json_go = fn (alts: [HirPatternKind], acc: [JsonValue]) -> [JsonValue] do
  match alts do
    | [] -> return list.reverse(xs: acc)
    | a :: rest -> return hir_pattern_alts_to_json_go(alts: rest, acc: hir_pattern_to_json(p: a) :: acc)
  end
end

let hir_pattern_to_json = fn (p: HirPatternKind) -> JsonValue do
  match p do
    | PLit(lit) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "PLit")),
        JsonField(key: "lit_kind", value: JsonString(val: literal_kind_str(lit))),
        JsonField(key: "value", value: literal_value_json(lit)),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | PVar(name, sigil) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "PVar")),
        JsonField(key: "name", value: JsonString(val: name)),
        JsonField(key: "sigil", value: JsonString(val: sigil_to_str(s: sigil))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | PCtor(variant, fields, sigil) ->
      let fs_json = JsonArray(items: hir_pattern_fields_to_json_go(fs: fields, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "PCtor")),
        JsonField(key: "variant", value: JsonString(val: variant)),
        JsonField(key: "sigil", value: JsonString(val: sigil_to_str(s: sigil))),
        JsonField(key: "fields", value: fs_json),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | PRec(fields, is_partial) ->
      let fs_json = JsonArray(items: hir_record_pat_fields_to_json_go(fs: fields, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "PRec")),
        JsonField(key: "is_partial", value: JsonBool(val: is_partial)),
        JsonField(key: "fields", value: fs_json),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | PWild ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "PWild")),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | POr(alts) ->
      let alts_json = JsonArray(items: hir_pattern_alts_to_json_go(alts, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "POr")),
        JsonField(key: "alts", value: alts_json),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
  end
end

let hir_match_cases_to_json_go = fn (cs: [HirMatchCase], acc: [JsonValue]) -> [JsonValue] do
  match cs do
    | [] -> return list.reverse(xs: acc)
    | HirMatchCase(pattern, body) :: rest ->
      let body_json = JsonArray(items: hir_stmts_to_json_go(ss: body, acc: []))
      let obj = JsonObject(fields: [
        JsonField(key: "pattern", value: hir_pattern_to_json(p: pattern)),
        JsonField(key: "body", value: body_json)
      ])
      return hir_match_cases_to_json_go(cs: rest, acc: obj :: acc)
  end
end

let hir_handler_arms_to_json_go = fn (arms: [HirHandlerArm], acc: [JsonValue]) -> [JsonValue] do
  match arms do
    | [] -> return list.reverse(xs: acc)
    | HirHandlerArm(arm: HirFunction(name, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span: _, file: _, requires: _), cont_binder) :: rest ->
      let cb = match cont_binder do
        | Some(val: n) -> JsonString(val: n)
        | None -> JsonNull
      end
      let obj = JsonObject(fields: [
        JsonField(key: "arm_name", value: JsonString(val: name)),
        JsonField(key: "cont_binder", value: cb)
      ])
      return hir_handler_arms_to_json_go(arms: rest, acc: obj :: acc)
  end
end

let hir_expr_to_json = fn (e: HirExpr) -> JsonValue do
  match e do | HirExpr(node, span) ->
    let sp_json = span_to_json(sp: span)
    match node do
      | Literal(lit) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Literal")),
          JsonField(key: "lit_kind", value: JsonString(val: literal_kind_str(lit))),
          JsonField(key: "value", value: literal_value_json(lit)),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | Variable(name, sigil) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Variable")),
          JsonField(key: "name", value: JsonString(val: name)),
          JsonField(key: "sigil", value: JsonString(val: sigil_to_str(s: sigil))),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | BinOp(left, op, right) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "BinOp")),
          JsonField(key: "op", value: JsonString(val: binop_to_str(op))),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [
            hir_expr_to_json(e: left),
            hir_expr_to_json(e: right)
          ]))
        ])
      | UnOp(op, operand) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "UnOp")),
          JsonField(key: "op", value: JsonString(val: unop_to_str(op))),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [hir_expr_to_json(e: operand)]))
        ])
      | Borrow(name, sigil) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Borrow")),
          JsonField(key: "name", value: JsonString(val: name)),
          JsonField(key: "sigil", value: JsonString(val: sigil_to_str(s: sigil))),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | Call(func, args) ->
        let args_json = JsonArray(items: hir_call_args_to_json_go(args, acc: []))
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Call")),
          JsonField(key: "func", value: JsonString(val: func)),
          JsonField(key: "args", value: args_json),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | Ctor(variant, args, sigil) ->
        let args_json = JsonArray(items: hir_exprs_to_json_go(es: args, acc: []))
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Ctor")),
          JsonField(key: "variant", value: JsonString(val: variant)),
          JsonField(key: "sigil", value: JsonString(val: sigil_to_str(s: sigil))),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: args_json)
        ])
      | Record(fields) ->
        let fs_json = JsonArray(items: hir_named_exprs_to_json_go(fs: fields, acc: []))
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Record")),
          JsonField(key: "fields", value: fs_json),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | Array(elems) ->
        let es_json = JsonArray(items: hir_exprs_to_json_go(es: elems, acc: []))
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Array")),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: es_json)
        ])
      | Index(target, index) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Index")),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [
            hir_expr_to_json(e: target),
            hir_expr_to_json(e: index)
          ]))
        ])
      | FieldAccess(target, field) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "FieldAccess")),
          JsonField(key: "field", value: JsonString(val: field)),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [hir_expr_to_json(e: target)]))
        ])
      | If(cond, then_branch, else_branch) ->
        let then_json = JsonArray(items: hir_stmts_to_json_go(ss: then_branch, acc: []))
        let else_json = match else_branch do
          | Some(val: eb) -> JsonArray(items: hir_stmts_to_json_go(ss: eb, acc: []))
          | None -> JsonNull
        end
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "If")),
          JsonField(key: "then_branch", value: then_json),
          JsonField(key: "else_branch", value: else_json),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [hir_expr_to_json(e: cond)]))
        ])
      | Match(target, cases) ->
        let cs_json = JsonArray(items: hir_match_cases_to_json_go(cs: cases, acc: []))
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Match")),
          JsonField(key: "cases", value: cs_json),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [hir_expr_to_json(e: target)]))
        ])
      | While(cond, body) ->
        let body_json = JsonArray(items: hir_stmts_to_json_go(ss: body, acc: []))
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "While")),
          JsonField(key: "body", value: body_json),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [hir_expr_to_json(e: cond)]))
        ])
      | For(var, start, end_expr, body) ->
        let body_json = JsonArray(items: hir_stmts_to_json_go(ss: body, acc: []))
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "For")),
          JsonField(key: "var", value: JsonString(val: var)),
          JsonField(key: "body", value: body_json),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [
            hir_expr_to_json(e: start),
            hir_expr_to_json(e: end_expr)
          ]))
        ])
      | Lambda(type_params: _, params, ret_type, body) ->
        let ps_json = JsonArray(items: hir_params_to_json_go(ps: params, acc: []))
        let body_json = JsonArray(items: hir_stmts_to_json_go(ss: body, acc: []))
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Lambda")),
          JsonField(key: "params", value: ps_json),
          JsonField(key: "ret_type", value: JsonString(val: type_to_string(typ: ret_type))),
          JsonField(key: "body", value: body_json),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | Raise(expr) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Raise")),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [hir_expr_to_json(e: expr)]))
        ])
      | Force(expr) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Force")),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [hir_expr_to_json(e: expr)]))
        ])
      | Thunk(body) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Thunk")),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [hir_expr_to_json(e: body)]))
        ])
      | ExternalRef(symbol, type_params: _, arg_names: _, typ) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "ExternalRef")),
          JsonField(key: "symbol", value: JsonString(val: symbol)),
          JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | Handler(port_name, arms) ->
        let arms_json = JsonArray(items: hir_handler_arms_to_json_go(arms, acc: []))
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Handler")),
          JsonField(key: "port_name", value: JsonString(val: port_name)),
          JsonField(key: "arms", value: arms_json),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
    end
  end
end

let hir_stmt_to_json = fn (s: HirStmt) -> JsonValue do
  match s do | HirStmt(node, span) ->
    let sp_json = span_to_json(sp: span)
    match node do
      | Let(name, sigil, typ, value) ->
        let ty_v = match typ do
          | Some(val: t) -> JsonString(val: type_to_string(typ: t))
          | None -> JsonNull
        end
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Let")),
          JsonField(key: "name", value: JsonString(val: name)),
          JsonField(key: "sigil", value: JsonString(val: sigil_to_str(s: sigil))),
          JsonField(key: "type", value: ty_v),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [hir_expr_to_json(e: value)]))
        ])
      | Expr(expr) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Expr")),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [hir_expr_to_json(e: expr)]))
        ])
      | Return(expr) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Return")),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [hir_expr_to_json(e: expr)]))
        ])
      | Assign(target, value) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Assign")),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: [
            hir_expr_to_json(e: target),
            hir_expr_to_json(e: value)
          ]))
        ])
      | Try(body, catch_param, catch_body) ->
        let body_json = JsonArray(items: hir_stmts_to_json_go(ss: body, acc: []))
        let catch_json = JsonArray(items: hir_stmts_to_json_go(ss: catch_body, acc: []))
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Try")),
          JsonField(key: "catch_param", value: JsonString(val: catch_param)),
          JsonField(key: "body", value: body_json),
          JsonField(key: "catch_body", value: catch_json),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | Inject(handlers, body) ->
        let hs_json = JsonArray(items: strings_to_json_go(xs: handlers, acc: []))
        let body_json = JsonArray(items: hir_stmts_to_json_go(ss: body, acc: []))
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "Inject")),
          JsonField(key: "handlers", value: hs_json),
          JsonField(key: "body", value: body_json),
          JsonField(key: "span", value: sp_json),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
    end
  end
end

let strings_to_json_go = fn (xs: [string], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | s :: rest -> return strings_to_json_go(xs: rest, acc: JsonString(val: s) :: acc)
  end
end

let hir_body_to_json = fn (body: HirBody) -> JsonValue do
  match body do
    | EagerBody(stmts) ->
      let stmts_json = JsonArray(items: hir_stmts_to_json_go(ss: stmts, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "EagerBody")),
        JsonField(key: "stmts", value: stmts_json),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LazyBody(ast_expr: _, entries: _) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LazyBody")),
        JsonField(key: "note", value: JsonString(val: "AST-level body, deferred convert_expr")),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
  end
end

let hir_func_to_json = fn (f: HirFunction) -> JsonValue do
  match f do | HirFunction(name, type_params: _, params, ret_type, throw_row: _, body, span, file: _, requires: _) ->
    let ps_json = JsonArray(items: hir_params_to_json_go(ps: params, acc: []))
    return JsonObject(fields: [
      JsonField(key: "name", value: JsonString(val: name)),
      JsonField(key: "params", value: ps_json),
      JsonField(key: "ret_type", value: JsonString(val: type_to_string(typ: ret_type))),
      JsonField(key: "span", value: span_to_json(sp: span)),
      JsonField(key: "body", value: hir_body_to_json(body))
    ])
  end
end

let hir_funcs_to_json_go = fn (fs: [HirFunction], acc: [JsonValue]) -> [JsonValue] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest -> return hir_funcs_to_json_go(fs: rest, acc: hir_func_to_json(f) :: acc)
  end
end

export let hir_to_json = fn (prog: HirProgram) -> string throws { JsonThrow } do
  match prog do | HirProgram(ports: _, functions, externals: _, handler_bindings: _, enum_defs: _, exception_groups: _, value_binding_names: _, type_defs: _) ->
    let fs_json = JsonArray(items: hir_funcs_to_json_go(fs: functions, acc: []))
    let obj = JsonObject(fields: [
      JsonField(key: "kind", value: JsonString(val: "hir")),
      JsonField(key: "functions", value: fs_json)
    ])
    return json.serialize(v: obj)
  end
end

// ─── LIR body stringifier ──────────────────────────────────────────────────

let lir_atom_to_str = fn (a: LirAtom) -> string do
  match a do
    | LirAtomVar(name, typ: _) -> return name
    | LirAtomInt(val) -> return str.from_i64(val)
    | LirAtomFloat(val) -> return val
    | LirAtomBool(val) -> return str.from_bool(val)
    | LirAtomChar(val) -> return "char(" ++ str.from_i64(val) ++ ")"
    | LirAtomString(val) -> return "\"" ++ val ++ "\""
    | LirAtomUnit -> return "()"
  end
end

let lir_atoms_to_strs = fn (xs: [LirAtom]) -> [string] do
  match xs do
    | [] -> return []
    | a :: rest -> return lir_atom_to_str(a) :: lir_atoms_to_strs(xs: rest)
  end
end

let lir_call_args_to_strs = fn (args: [LirCallArg]) -> [string] do
  match args do
    | [] -> return []
    | LirCallArg(label, value) :: rest ->
      let head = if str.length(s: label) > 0 then label ++ ": " ++ lir_atom_to_str(a: value) else lir_atom_to_str(a: value) end
      return head :: lir_call_args_to_strs(args: rest)
  end
end

let lir_named_atoms_to_strs = fn (fs: [LirNamedAtom]) -> [string] do
  match fs do
    | [] -> return []
    | LirNamedAtom(name, value) :: rest ->
      return (name ++ ": " ++ lir_atom_to_str(a: value)) :: lir_named_atoms_to_strs(fs: rest)
  end
end

let zip_arm_fns_tags = fn (fns: [string], tags: [string]) -> [string] do
  match fns do
    | [] -> return []
    | f :: rest_f ->
      match tags do
        | [] -> return [f] // mismatched lengths -> degrade gracefully
        | t :: rest_t -> return (t ++ "->" ++ f) :: zip_arm_fns_tags(fns: rest_f, tags: rest_t)
      end
  end
end

let lir_expr_to_str = fn (e: LirExpr) -> string do
  match e do
    | LirExprAtom(atom) -> return lir_atom_to_str(a: atom)
    | LirExprBinary(op, lhs, rhs, typ: _) ->
      return "(" ++ lir_atom_to_str(a: lhs) ++ " " ++ binop_to_str(op) ++ " " ++ lir_atom_to_str(a: rhs) ++ ")"
    | LirExprCall(func, args, typ: _) ->
      return func ++ "(" ++ join_strs(xs: lir_call_args_to_strs(args), sep: ", ") ++ ")"
    | LirExprTailCall(func, args, typ: _) ->
      return "tail " ++ func ++ "(" ++ join_strs(xs: lir_call_args_to_strs(args), sep: ", ") ++ ")"
    | LirExprConstructor(name, args, typ: _) ->
      return name ++ "(" ++ join_strs(xs: lir_atoms_to_strs(xs: args), sep: ", ") ++ ")"
    | LirExprRecord(fields, typ: _) ->
      return "{" ++ join_strs(xs: lir_named_atoms_to_strs(fs: fields), sep: ", ") ++ "}"
    | LirExprObjectTag(value, typ: _) -> return "tag(" ++ lir_atom_to_str(a: value) ++ ")"
    | LirExprObjectField(value, index, typ: _) ->
      return "field(" ++ lir_atom_to_str(a: value) ++ ", " ++ str.from_i64(val: index) ++ ")"
    | LirExprRaise(value, typ: _) -> return "raise " ++ lir_atom_to_str(a: value)
    | LirExprForce(value, typ: _) -> return "force " ++ lir_atom_to_str(a: value)
    | LirExprMakeClosure(func_name, captures, typ: _) ->
      return "closure(" ++ func_name ++ "; " ++ join_strs(xs: lir_atoms_to_strs(xs: captures), sep: ", ") ++ ")"
    | LirExprCallClosure(closure, args, typ: _) ->
      return "callcl " ++ lir_atom_to_str(a: closure) ++ "(" ++ join_strs(xs: lir_call_args_to_strs(args), sep: ", ") ++ ")"
    | LirExprSuspend(tag_name, payload, typ: _) ->
      return "suspend $" ++ tag_name ++ " " ++ lir_atom_to_str(a: payload)
    | LirExprResume(cont, value, typ: _) ->
      return "resume " ++ lir_atom_to_str(a: cont) ++ " " ++ lir_atom_to_str(a: value)
    | LirExprContNew(func_ref, typ: _) -> return "cont.new $" ++ func_ref
    | LirExprInjectResume(body_fn, arm_fns, arm_tags, typ: _) ->
      let arms_str = join_strs(xs: zip_arm_fns_tags(fns: arm_fns, tags: arm_tags), sep: "; ")
      return "inject_resume " ++ body_fn ++ " [" ++ arms_str ++ "]"
  end
end

let lir_stmts_to_str_go = fn (stmts: [LirStmt], acc: [string]) -> [string] do
  match stmts do
    | [] -> return list.reverse(xs: acc)
    | s :: rest -> return lir_stmts_to_str_go(stmts: rest, acc: lir_stmt_to_str(s) :: acc)
  end
end

let lir_stmts_to_str = fn (stmts: [LirStmt]) -> string do
  return join_strs(xs: lir_stmts_to_str_go(stmts, acc: []), sep: "; ")
end

let lir_stmt_to_str = fn (s: LirStmt) -> string do
  match s do
    | LirStmtLet(name, typ, expr) -> return "let " ++ name ++ ": " ++ type_to_string(typ) ++ " = " ++ lir_expr_to_str(e: expr)
    | LirStmtIf(cond, then_body, else_body) ->
      return "if " ++ lir_atom_to_str(a: cond) ++ " then " ++ lir_stmts_to_str(stmts: then_body) ++ " else " ++ lir_stmts_to_str(stmts: else_body) ++ " end"
    | LirStmtIfReturn(cond, then_body, then_ret, else_body, else_ret, ret_type: _) ->
      let else_ret_str = match else_ret do | Some(val: v) -> " -> " ++ lir_atom_to_str(a: v) | None -> "" end
      return "ifret " ++ lir_atom_to_str(a: cond) ++ " then " ++ lir_stmts_to_str(stmts: then_body) ++ " -> " ++ lir_atom_to_str(a: then_ret) ++ " else " ++ lir_stmts_to_str(stmts: else_body) ++ else_ret_str
    | LirStmtLoop(cond_stmts, cond, body) ->
      return "loop while " ++ lir_stmts_to_str(stmts: cond_stmts) ++ " | " ++ lir_atom_to_str(a: cond) ++ " do " ++ lir_stmts_to_str(stmts: body) ++ " end"
    | LirStmtTryCatch(body, body_ret, catch_param, catch_param_typ: _, catch_body, catch_ret) ->
      let body_ret_str = match body_ret do | Some(val: v) -> " -> " ++ lir_atom_to_str(a: v) | None -> "" end
      let catch_ret_str = match catch_ret do | Some(val: v) -> " -> " ++ lir_atom_to_str(a: v) | None -> "" end
      return "try " ++ lir_stmts_to_str(stmts: body) ++ body_ret_str ++ " catch " ++ catch_param ++ " -> " ++ lir_stmts_to_str(stmts: catch_body) ++ catch_ret_str
  end
end

let lir_params_to_strs = fn (ps: [LirParam]) -> [string] do
  match ps do
    | [] -> return []
    | LirParam(label, name, typ) :: rest ->
      return (label ++ ": " ++ name ++ ": " ++ type_to_string(typ)) :: lir_params_to_strs(ps: rest)
  end
end

let lir_func_body_to_str = fn (f: LirFunction) -> string do
  match f do | LirFunction(name: _, params: _, ret_type: _, body, ret, span: _) ->
    let body_str = lir_stmts_to_str(stmts: body)
    return body_str ++ " => " ++ lir_atom_to_str(a: ret)
  end
end

// ─── LIR text dump ─────────────────────────────────────────────────────────

let lir_func_to_text_lines = fn (f: LirFunction) -> [string] do
  match f do | LirFunction(name, params, ret_type, body: _, ret: _, span: _) ->
    let ps_str = join_strs(xs: lir_params_to_strs(ps: params), sep: ", ")
    let header = "fn " ++ name ++ "(" ++ ps_str ++ ") -> " ++ type_to_string(typ: ret_type)
    let body_line = "  body: " ++ lir_func_body_to_str(f)
    return [header, body_line]
  end
end

let lir_funcs_to_text_go = fn (fs: [LirFunction], acc: [string]) -> [string] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      let lines = lir_func_to_text_lines(f)
      return lir_funcs_to_text_go(fs: rest, acc: list.concat(xs: list.reverse(xs: lines), ys: acc))
  end
end

export let lir_to_text = fn (funcs: [LirFunction]) -> string do
  let banner = "=== LIR dump (" ++ str.from_i64(val: list.length(xs: funcs)) ++ " functions) ==="
  let lines = lir_funcs_to_text_go(fs: funcs, acc: [])
  return banner ++ "\n" ++ join_strs(xs: lines, sep: "\n") ++ "\n"
end

// ─── LIR JSON dump ─────────────────────────────────────────────────────────

let lir_param_to_json = fn (p: LirParam) -> JsonValue do
  match p do | LirParam(label, name, typ) ->
    return JsonObject(fields: [
      JsonField(key: "label", value: JsonString(val: label)),
      JsonField(key: "name", value: JsonString(val: name)),
      JsonField(key: "type", value: JsonString(val: type_to_string(typ)))
    ])
  end
end

let lir_params_to_json_go = fn (ps: [LirParam], acc: [JsonValue]) -> [JsonValue] do
  match ps do
    | [] -> return list.reverse(xs: acc)
    | p :: rest -> return lir_params_to_json_go(ps: rest, acc: lir_param_to_json(p) :: acc)
  end
end

// ─── LIR JSON expr/stmt walker (V2: structured tree) ───────────────────────
//
// Shape mirrors the HIR walker: each node is a JsonObject with
//   - "kind": variant name
//   - "children": sub-stmt/sub-expr nodes (LIR sub-children that route
//     structurally to other expr/stmt nodes; atoms are emitted as flat
//     fields beside `kind`).
// LIR atoms are leaves (no sub-expr), so we serialise them as
// `{kind: "<AtomVariant>", ...payload}` JsonObjects under purpose-specific
// keys (`lhs`/`rhs`/`atom`/`value`/`cond`/`closure`/`payload`/`cont`/`captures`).

let lir_atom_to_json = fn (a: LirAtom) -> JsonValue do
  match a do
    | LirAtomVar(name, typ) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirAtomVar")),
        JsonField(key: "name", value: JsonString(val: name)),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ)))
      ])
    | LirAtomInt(val) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirAtomInt")),
        JsonField(key: "value", value: JsonInt(val))
      ])
    | LirAtomFloat(val) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirAtomFloat")),
        JsonField(key: "value", value: JsonString(val))
      ])
    | LirAtomBool(val) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirAtomBool")),
        JsonField(key: "value", value: JsonBool(val))
      ])
    | LirAtomChar(val) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirAtomChar")),
        JsonField(key: "value", value: JsonInt(val))
      ])
    | LirAtomString(val) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirAtomString")),
        JsonField(key: "value", value: JsonString(val))
      ])
    | LirAtomUnit ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirAtomUnit"))
      ])
  end
end

let lir_atoms_to_json_go = fn (xs: [LirAtom], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | a :: rest -> return lir_atoms_to_json_go(xs: rest, acc: lir_atom_to_json(a) :: acc)
  end
end

let lir_call_args_to_json_go = fn (args: [LirCallArg], acc: [JsonValue]) -> [JsonValue] do
  match args do
    | [] -> return list.reverse(xs: acc)
    | LirCallArg(label, value) :: rest ->
      let obj = JsonObject(fields: [
        JsonField(key: "label", value: JsonString(val: label)),
        JsonField(key: "value", value: lir_atom_to_json(a: value))
      ])
      return lir_call_args_to_json_go(args: rest, acc: obj :: acc)
  end
end

let lir_named_atoms_to_json_go = fn (fs: [LirNamedAtom], acc: [JsonValue]) -> [JsonValue] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | LirNamedAtom(name, value) :: rest ->
      let obj = JsonObject(fields: [
        JsonField(key: "name", value: JsonString(val: name)),
        JsonField(key: "value", value: lir_atom_to_json(a: value))
      ])
      return lir_named_atoms_to_json_go(fs: rest, acc: obj :: acc)
  end
end

let lir_arm_pairs_to_json_go = fn (fns: [string], tags: [string], acc: [JsonValue]) -> [JsonValue] do
  match fns do
    | [] -> return list.reverse(xs: acc)
    | f :: rest_f ->
      match tags do
        | [] ->
          let obj = JsonObject(fields: [
            JsonField(key: "tag", value: JsonNull),
            JsonField(key: "func", value: JsonString(val: f))
          ])
          return lir_arm_pairs_to_json_go(fns: rest_f, tags: [], acc: obj :: acc)
        | t :: rest_t ->
          let obj = JsonObject(fields: [
            JsonField(key: "tag", value: JsonString(val: t)),
            JsonField(key: "func", value: JsonString(val: f))
          ])
          return lir_arm_pairs_to_json_go(fns: rest_f, tags: rest_t, acc: obj :: acc)
      end
  end
end

let lir_expr_to_json = fn (e: LirExpr) -> JsonValue do
  match e do
    | LirExprAtom(atom) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprAtom")),
        JsonField(key: "atom", value: lir_atom_to_json(a: atom)),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprBinary(op, lhs, rhs, typ) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprBinary")),
        JsonField(key: "op", value: JsonString(val: binop_to_str(op))),
        JsonField(key: "lhs", value: lir_atom_to_json(a: lhs)),
        JsonField(key: "rhs", value: lir_atom_to_json(a: rhs)),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprCall(func, args, typ) ->
      let args_json = JsonArray(items: lir_call_args_to_json_go(args, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprCall")),
        JsonField(key: "func", value: JsonString(val: func)),
        JsonField(key: "args", value: args_json),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprTailCall(func, args, typ) ->
      let args_json = JsonArray(items: lir_call_args_to_json_go(args, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprTailCall")),
        JsonField(key: "func", value: JsonString(val: func)),
        JsonField(key: "args", value: args_json),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprConstructor(name, args, typ) ->
      let args_json = JsonArray(items: lir_atoms_to_json_go(xs: args, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprConstructor")),
        JsonField(key: "name", value: JsonString(val: name)),
        JsonField(key: "args", value: args_json),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprRecord(fields, typ) ->
      let fs_json = JsonArray(items: lir_named_atoms_to_json_go(fs: fields, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprRecord")),
        JsonField(key: "fields", value: fs_json),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprObjectTag(value, typ) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprObjectTag")),
        JsonField(key: "value", value: lir_atom_to_json(a: value)),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprObjectField(value, index, typ) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprObjectField")),
        JsonField(key: "value", value: lir_atom_to_json(a: value)),
        JsonField(key: "index", value: JsonInt(val: index)),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprRaise(value, typ) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprRaise")),
        JsonField(key: "value", value: lir_atom_to_json(a: value)),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprForce(value, typ) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprForce")),
        JsonField(key: "value", value: lir_atom_to_json(a: value)),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprMakeClosure(func_name, captures, typ) ->
      let caps_json = JsonArray(items: lir_atoms_to_json_go(xs: captures, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprMakeClosure")),
        JsonField(key: "func_name", value: JsonString(val: func_name)),
        JsonField(key: "captures", value: caps_json),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprCallClosure(closure, args, typ) ->
      let args_json = JsonArray(items: lir_call_args_to_json_go(args, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprCallClosure")),
        JsonField(key: "closure", value: lir_atom_to_json(a: closure)),
        JsonField(key: "args", value: args_json),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprSuspend(tag_name, payload, typ) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprSuspend")),
        JsonField(key: "tag_name", value: JsonString(val: tag_name)),
        JsonField(key: "payload", value: lir_atom_to_json(a: payload)),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprResume(cont, value, typ) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprResume")),
        JsonField(key: "cont", value: lir_atom_to_json(a: cont)),
        JsonField(key: "value", value: lir_atom_to_json(a: value)),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprContNew(func_ref, typ) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprContNew")),
        JsonField(key: "func_ref", value: JsonString(val: func_ref)),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirExprInjectResume(body_fn, arm_fns, arm_tags, typ) ->
      let arms_json = JsonArray(items: lir_arm_pairs_to_json_go(fns: arm_fns, tags: arm_tags, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirExprInjectResume")),
        JsonField(key: "body_fn", value: JsonString(val: body_fn)),
        JsonField(key: "arms", value: arms_json),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
  end
end

let lir_stmts_to_json_go = fn (stmts: [LirStmt], acc: [JsonValue]) -> [JsonValue] do
  match stmts do
    | [] -> return list.reverse(xs: acc)
    | s :: rest -> return lir_stmts_to_json_go(stmts: rest, acc: lir_stmt_to_json(s) :: acc)
  end
end

let lir_stmt_to_json = fn (s: LirStmt) -> JsonValue do
  match s do
    | LirStmtLet(name, typ, expr) ->
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirStmtLet")),
        JsonField(key: "name", value: JsonString(val: name)),
        JsonField(key: "type", value: JsonString(val: type_to_string(typ))),
        JsonField(key: "children", value: JsonArray(items: [lir_expr_to_json(e: expr)]))
      ])
    | LirStmtIf(cond, then_body, else_body) ->
      let then_json = JsonArray(items: lir_stmts_to_json_go(stmts: then_body, acc: []))
      let else_json = JsonArray(items: lir_stmts_to_json_go(stmts: else_body, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirStmtIf")),
        JsonField(key: "cond", value: lir_atom_to_json(a: cond)),
        JsonField(key: "then_body", value: then_json),
        JsonField(key: "else_body", value: else_json),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirStmtIfReturn(cond, then_body, then_ret, else_body, else_ret, ret_type) ->
      let then_json = JsonArray(items: lir_stmts_to_json_go(stmts: then_body, acc: []))
      let else_json = JsonArray(items: lir_stmts_to_json_go(stmts: else_body, acc: []))
      let else_ret_v = match else_ret do
        | Some(val: v) -> lir_atom_to_json(a: v)
        | None -> JsonNull
      end
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirStmtIfReturn")),
        JsonField(key: "cond", value: lir_atom_to_json(a: cond)),
        JsonField(key: "then_body", value: then_json),
        JsonField(key: "then_ret", value: lir_atom_to_json(a: then_ret)),
        JsonField(key: "else_body", value: else_json),
        JsonField(key: "else_ret", value: else_ret_v),
        JsonField(key: "ret_type", value: JsonString(val: type_to_string(typ: ret_type))),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirStmtLoop(cond_stmts, cond, body) ->
      let cs_json = JsonArray(items: lir_stmts_to_json_go(stmts: cond_stmts, acc: []))
      let body_json = JsonArray(items: lir_stmts_to_json_go(stmts: body, acc: []))
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirStmtLoop")),
        JsonField(key: "cond_stmts", value: cs_json),
        JsonField(key: "cond", value: lir_atom_to_json(a: cond)),
        JsonField(key: "body", value: body_json),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
    | LirStmtTryCatch(body, body_ret, catch_param, catch_param_typ, catch_body, catch_ret) ->
      let body_json = JsonArray(items: lir_stmts_to_json_go(stmts: body, acc: []))
      let catch_json = JsonArray(items: lir_stmts_to_json_go(stmts: catch_body, acc: []))
      let body_ret_v = match body_ret do
        | Some(val: v) -> lir_atom_to_json(a: v)
        | None -> JsonNull
      end
      let catch_ret_v = match catch_ret do
        | Some(val: v) -> lir_atom_to_json(a: v)
        | None -> JsonNull
      end
      return JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "LirStmtTryCatch")),
        JsonField(key: "body", value: body_json),
        JsonField(key: "body_ret", value: body_ret_v),
        JsonField(key: "catch_param", value: JsonString(val: catch_param)),
        JsonField(key: "catch_param_type", value: JsonString(val: type_to_string(typ: catch_param_typ))),
        JsonField(key: "catch_body", value: catch_json),
        JsonField(key: "catch_ret", value: catch_ret_v),
        JsonField(key: "children", value: JsonArray(items: []))
      ])
  end
end

let lir_func_body_to_json = fn (f: LirFunction) -> JsonValue do
  match f do | LirFunction(name: _, params: _, ret_type: _, body, ret, span: _) ->
    let body_json = JsonArray(items: lir_stmts_to_json_go(stmts: body, acc: []))
    return JsonObject(fields: [
      JsonField(key: "stmts", value: body_json),
      JsonField(key: "ret", value: lir_atom_to_json(a: ret))
    ])
  end
end

let lir_func_to_json = fn (f: LirFunction) -> JsonValue do
  match f do | LirFunction(name, params, ret_type, body: _, ret: _, span) ->
    let ps_json = JsonArray(items: lir_params_to_json_go(ps: params, acc: []))
    return JsonObject(fields: [
      JsonField(key: "name", value: JsonString(val: name)),
      JsonField(key: "params", value: ps_json),
      JsonField(key: "ret_type", value: JsonString(val: type_to_string(typ: ret_type))),
      JsonField(key: "span", value: span_to_json(sp: span)),
      JsonField(key: "body", value: lir_func_body_to_json(f))
    ])
  end
end

let lir_funcs_to_json_go = fn (fs: [LirFunction], acc: [JsonValue]) -> [JsonValue] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest -> return lir_funcs_to_json_go(fs: rest, acc: lir_func_to_json(f) :: acc)
  end
end

export let lir_to_json = fn (funcs: [LirFunction]) -> string throws { JsonThrow } do
  let fs_json = JsonArray(items: lir_funcs_to_json_go(fs: funcs, acc: []))
  let obj = JsonObject(fields: [
    JsonField(key: "kind", value: JsonString(val: "lir")),
    JsonField(key: "functions", value: fs_json)
  ])
  return json.serialize(v: obj)
end
