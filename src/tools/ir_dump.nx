/**
 * ir_dump: machine-readable IR dumps for `nexus hir` / `nexus lir`.
 *
 * Issue nexus-ud6j V1. Two subcommands:
 *   - `nexus hir <file> [--format=text|json]` — parses + lowers to HIR, prints.
 *   - `nexus lir <file> [--format=text|json]` — same, but through MIR→LIR.
 *
 * JSON shape: one JsonObject per top-level function with `{name, params,
 * ret_type, body_pp}`. The body is opaque-stringified through the inline
 * text pretty-printer below; full JSON expression trees are V2.
 */

import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"
import { JsonValue, JsonString, JsonArray, JsonObject, JsonField, JsonThrow }, * as json from "std:json"
import { Sigil, SigilImmutable, SigilMutable, SigilLinear, SigilBorrow, SigilLazy,
  BinaryOp, UnaryOp, Literal, LitInt, LitFloat, LitBool, LitChar, LitString, LitUnit,
  TypeExpr } from "src/common/ast.nx"
import { type_to_string } from "src/typecheck/types.nx"
import { HirProgram, HirFunction, HirParam, HirBody, EagerBody, LazyBody,
  HirExpr, HirExprKind, HirStmt, HirStmtKind, HirCallArg, HirNamedExpr,
  HirMatchCase, HirPatternKind, HirPatternField, HirRecordPatField,
  HirHandlerArm } from "src/ir/hir/types.nx"
import { LirFunction, LirParam, LirStmt, LirExpr, LirAtom, LirCallArg, LirNamedAtom } from "src/ir/lir/types.nx"

// ─── Subcommand stripping ──────────────────────────────────────────────────

export type ParsedHirSubcommand = ParsedHirSubcommand(remaining: [string], is_hir: bool)
export type ParsedLirSubcommand = ParsedLirSubcommand(remaining: [string], is_lir: bool)

/** Detect a leading `hir` subcommand. Strips it from the arg list when
 * present. Mirrors `strip_test_subcommand` shape. */
export let strip_hir_subcommand = fn (xs: [string]) -> ParsedHirSubcommand do
  match xs do
    | [] -> return ParsedHirSubcommand(remaining: [], is_hir: false)
    | prog :: rest ->
      match rest do
        | [] -> return ParsedHirSubcommand(remaining: xs, is_hir: false)
        | second :: rest2 ->
          if second == "hir" then
            return ParsedHirSubcommand(remaining: prog :: rest2, is_hir: true)
          end
          return ParsedHirSubcommand(remaining: xs, is_hir: false)
      end
  end
end

/** Detect a leading `lir` subcommand. */
export let strip_lir_subcommand = fn (xs: [string]) -> ParsedLirSubcommand do
  match xs do
    | [] -> return ParsedLirSubcommand(remaining: [], is_lir: false)
    | prog :: rest ->
      match rest do
        | [] -> return ParsedLirSubcommand(remaining: xs, is_lir: false)
        | second :: rest2 ->
          if second == "lir" then
            return ParsedLirSubcommand(remaining: prog :: rest2, is_lir: true)
          end
          return ParsedLirSubcommand(remaining: xs, is_lir: false)
      end
  end
end

// ─── Sigil / Literal / op stringifiers ─────────────────────────────────────

export let sigil_to_str = fn (s: Sigil) -> string do
  match s do
    | SigilImmutable -> return ""
    | SigilMutable -> return "mut"
    | SigilLinear -> return "%"
    | SigilBorrow -> return "&"
    | SigilLazy -> return "@"
  end
end

let literal_to_str = fn (lit: Literal) -> string do
  match lit do
    | LitInt(val) -> return str.from_i64(val)
    | LitFloat(val) -> return val
    | LitBool(val) -> return str.from_bool(val)
    | LitChar(val) -> return "char(" ++ str.from_i64(val) ++ ")"
    | LitString(val) -> return "\"" ++ val ++ "\""
    | LitUnit -> return "()"
  end
end

let binop_to_str = fn (op: BinaryOp) -> string do
  match op do
    | OpAdd -> return "+"
    | OpSub -> return "-"
    | OpMul -> return "*"
    | OpDiv -> return "/"
    | OpMod -> return "%"
    | OpFAdd -> return "+."
    | OpFSub -> return "-."
    | OpFMul -> return "*."
    | OpFDiv -> return "/."
    | OpEq -> return "=="
    | OpNe -> return "!="
    | OpLt -> return "<"
    | OpLe -> return "<="
    | OpGt -> return ">"
    | OpGe -> return ">="
    | OpFEq -> return "==."
    | OpFNe -> return "!=."
    | OpFLt -> return "<."
    | OpFLe -> return "<=."
    | OpFGt -> return ">."
    | OpFGe -> return ">=."
    | OpBitAnd -> return "&"
    | OpBitOr -> return "|"
    | OpBitXor -> return "^"
    | OpShl -> return "<<"
    | OpShr -> return ">>"
    | OpAnd -> return "&&"
    | OpOr -> return "||"
    | OpConcat -> return "++"
  end
end

let unop_to_str = fn (op: UnaryOp) -> string do
  match op do
    | OpNeg -> return "-"
    | OpFNeg -> return "-."
    | OpNot -> return "!"
  end
end

// ─── HIR body stringifier (text pretty-printer) ────────────────────────────

let join_strs = fn (xs: [string], sep: string) -> string do
  return str.join(xs, sep)
end

let hir_call_args_to_strs = fn (args: [HirCallArg]) -> [string] do
  match args do
    | [] -> return []
    | HirCallArg(label, value: v) :: rest ->
      let head = if str.length(s: label) > 0 then label ++ ": " ++ hir_expr_to_str(e: v) else hir_expr_to_str(e: v) end
      return head :: hir_call_args_to_strs(args: rest)
  end
end

let hir_exprs_to_strs = fn (es: [HirExpr]) -> [string] do
  match es do
    | [] -> return []
    | e :: rest -> return hir_expr_to_str(e) :: hir_exprs_to_strs(es: rest)
  end
end

let hir_named_exprs_to_strs = fn (fs: [HirNamedExpr]) -> [string] do
  match fs do
    | [] -> return []
    | HirNamedExpr(name, value: v) :: rest ->
      return (name ++ ": " ++ hir_expr_to_str(e: v)) :: hir_named_exprs_to_strs(fs: rest)
  end
end

let hir_params_to_strs = fn (ps: [HirParam]) -> [string] do
  match ps do
    | [] -> return []
    | HirParam(label, name, sigil, typ) :: rest ->
      let pre = sigil_to_str(s: sigil)
      let head = label ++ ": " ++ pre ++ name ++ ": " ++ type_to_string(typ)
      return head :: hir_params_to_strs(ps: rest)
  end
end

let hir_pattern_fields_to_strs = fn (fs: [HirPatternField]) -> [string] do
  match fs do
    | [] -> return []
    | HirPatternField(name, pattern: p) :: rest ->
      let pre = match name do | Some(val: n) -> n ++ ": " | None -> "" end
      return (pre ++ hir_pattern_to_str(p)) :: hir_pattern_fields_to_strs(fs: rest)
  end
end

let hir_record_pat_fields_to_strs = fn (fs: [HirRecordPatField]) -> [string] do
  match fs do
    | [] -> return []
    | HirRecordPatField(name, pattern: p) :: rest ->
      return (name ++ ": " ++ hir_pattern_to_str(p)) :: hir_record_pat_fields_to_strs(fs: rest)
  end
end

let hir_pattern_alts_to_strs = fn (alts: [HirPatternKind]) -> [string] do
  match alts do
    | [] -> return []
    | a :: rest -> return hir_pattern_to_str(p: a) :: hir_pattern_alts_to_strs(alts: rest)
  end
end

let hir_pattern_to_str = fn (p: HirPatternKind) -> string do
  match p do
    | PLit(lit) -> return literal_to_str(lit)
    | PVar(name, sigil) -> return sigil_to_str(s: sigil) ++ name
    | PCtor(variant, fields, sigil) ->
      let fs_str = join_strs(xs: hir_pattern_fields_to_strs(fs: fields), sep: ", ")
      return sigil_to_str(s: sigil) ++ variant ++ "(" ++ fs_str ++ ")"
    | PRec(fields, is_partial) ->
      let fs_str = join_strs(xs: hir_record_pat_fields_to_strs(fs: fields), sep: ", ")
      let suff = if is_partial then ", _" else "" end
      return "{" ++ fs_str ++ suff ++ "}"
    | PWild -> return "_"
    | POr(alts) -> return join_strs(xs: hir_pattern_alts_to_strs(alts), sep: " | ")
  end
end

let hir_match_cases_to_strs = fn (cs: [HirMatchCase]) -> [string] do
  match cs do
    | [] -> return []
    | HirMatchCase(pattern, body) :: rest ->
      let head = "| " ++ hir_pattern_to_str(p: pattern) ++ " -> " ++ hir_stmts_to_str(stmts: body)
      return head :: hir_match_cases_to_strs(cs: rest)
  end
end

let hir_handler_arms_to_strs = fn (arms: [HirHandlerArm]) -> [string] do
  match arms do
    | [] -> return []
    | HirHandlerArm(arm: HirFunction(name, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span: _, file: _), cont_binder) :: rest ->
      let cb = match cont_binder do | Some(val: n) -> " with @" ++ n | None -> "" end
      return ("arm " ++ name ++ cb) :: hir_handler_arms_to_strs(arms: rest)
  end
end

let hir_expr_to_str = fn (e: HirExpr) -> string do
  match e do | HirExpr(node, span: _) ->
    match node do
      | Literal(lit) -> return literal_to_str(lit)
      | Variable(name, sigil) -> return sigil_to_str(s: sigil) ++ name
      | BinOp(left, op, right) ->
        return "(" ++ hir_expr_to_str(e: left) ++ " " ++ binop_to_str(op) ++ " " ++ hir_expr_to_str(e: right) ++ ")"
      | UnOp(op, operand) -> return "(" ++ unop_to_str(op) ++ hir_expr_to_str(e: operand) ++ ")"
      | Borrow(name, sigil) -> return "&" ++ sigil_to_str(s: sigil) ++ name
      | Call(func, args) ->
        let args_str = join_strs(xs: hir_call_args_to_strs(args), sep: ", ")
        return func ++ "(" ++ args_str ++ ")"
      | Ctor(variant, args, sigil) ->
        let args_str = join_strs(xs: hir_exprs_to_strs(es: args), sep: ", ")
        return sigil_to_str(s: sigil) ++ variant ++ "(" ++ args_str ++ ")"
      | Record(fields) ->
        let fs_str = join_strs(xs: hir_named_exprs_to_strs(fs: fields), sep: ", ")
        return "{" ++ fs_str ++ "}"
      | Array(elems) ->
        let es_str = join_strs(xs: hir_exprs_to_strs(es: elems), sep: ", ")
        return "[" ++ es_str ++ "]"
      | Index(target, index) -> return hir_expr_to_str(e: target) ++ "[" ++ hir_expr_to_str(e: index) ++ "]"
      | FieldAccess(target, field) -> return hir_expr_to_str(e: target) ++ "." ++ field
      | If(cond, then_branch, else_branch) ->
        let else_str = match else_branch do
          | Some(val: eb) -> " else " ++ hir_stmts_to_str(stmts: eb)
          | None -> ""
        end
        return "if " ++ hir_expr_to_str(e: cond) ++ " then " ++ hir_stmts_to_str(stmts: then_branch) ++ else_str ++ " end"
      | Match(target, cases) ->
        let cs_str = join_strs(xs: hir_match_cases_to_strs(cs: cases), sep: " ")
        return "match " ++ hir_expr_to_str(e: target) ++ " do " ++ cs_str ++ " end"
      | While(cond, body) ->
        return "while " ++ hir_expr_to_str(e: cond) ++ " do " ++ hir_stmts_to_str(stmts: body) ++ " end"
      | For(var, start, end_expr, body) ->
        return "for " ++ var ++ " in " ++ hir_expr_to_str(e: start) ++ ".." ++ hir_expr_to_str(e: end_expr) ++ " do " ++ hir_stmts_to_str(stmts: body) ++ " end"
      | Lambda(type_params: _, params, ret_type, body) ->
        let ps_str = join_strs(xs: hir_params_to_strs(ps: params), sep: ", ")
        return "fn (" ++ ps_str ++ ") -> " ++ type_to_string(typ: ret_type) ++ " do " ++ hir_stmts_to_str(stmts: body) ++ " end"
      | Raise(expr) -> return "raise " ++ hir_expr_to_str(e: expr)
      | Force(expr) -> return "@" ++ hir_expr_to_str(e: expr)
      | Thunk(body) -> return "@(" ++ hir_expr_to_str(e: body) ++ ")"
      | ExternalRef(symbol, type_params: _, arg_names: _, typ) -> return "extern " ++ symbol ++ ": " ++ type_to_string(typ)
      | Handler(port_name, arms) ->
        let arms_str = join_strs(xs: hir_handler_arms_to_strs(arms), sep: ", ")
        return "handler " ++ port_name ++ " { " ++ arms_str ++ " }"
    end
  end
end

let hir_stmt_to_str = fn (s: HirStmt) -> string do
  match s do | HirStmt(node, span: _) ->
    match node do
      | Let(name, sigil, typ, value) ->
        let pre = sigil_to_str(s: sigil)
        let ty_str = match typ do | Some(val: t) -> ": " ++ type_to_string(typ: t) | None -> "" end
        return "let " ++ pre ++ name ++ ty_str ++ " = " ++ hir_expr_to_str(e: value)
      | Expr(expr) -> return hir_expr_to_str(e: expr)
      | Return(expr) -> return "return " ++ hir_expr_to_str(e: expr)
      | Assign(target, value) -> return hir_expr_to_str(e: target) ++ " <- " ++ hir_expr_to_str(e: value)
      | Try(body, catch_param, catch_body) ->
        return "try " ++ hir_stmts_to_str(stmts: body) ++ " catch " ++ catch_param ++ " -> " ++ hir_stmts_to_str(stmts: catch_body) ++ " end"
      | Inject(handlers, body) ->
        let hs = join_strs(xs: handlers, sep: ", ")
        return "inject " ++ hs ++ " do " ++ hir_stmts_to_str(stmts: body) ++ " end"
    end
  end
end

let hir_stmts_to_str_go = fn (stmts: [HirStmt], acc: [string]) -> [string] do
  match stmts do
    | [] -> return list.reverse(xs: acc)
    | s :: rest -> return hir_stmts_to_str_go(stmts: rest, acc: hir_stmt_to_str(s) :: acc)
  end
end

let hir_stmts_to_str = fn (stmts: [HirStmt]) -> string do
  return join_strs(xs: hir_stmts_to_str_go(stmts, acc: []), sep: "; ")
end

let hir_body_to_str = fn (body: HirBody) -> string do
  match body do
    | EagerBody(stmts) -> return hir_stmts_to_str(stmts)
    | LazyBody(ast_expr: _, entries: _) -> return "<lazy-body>"
  end
end

// ─── HIR text dump ─────────────────────────────────────────────────────────

let hir_func_to_text_lines = fn (f: HirFunction) -> [string] do
  match f do | HirFunction(name, type_params: _, params, ret_type, throw_row: _, body, span: _, file: _) ->
    let ps_str = join_strs(xs: hir_params_to_strs(ps: params), sep: ", ")
    let header = "fn " ++ name ++ "(" ++ ps_str ++ ") -> " ++ type_to_string(typ: ret_type)
    let body_line = "  body: " ++ hir_body_to_str(body)
    return [header, body_line]
  end
end

let hir_funcs_to_text_go = fn (fs: [HirFunction], acc: [string]) -> [string] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      let lines = hir_func_to_text_lines(f)
      return hir_funcs_to_text_go(fs: rest, acc: list.concat(xs: list.reverse(xs: lines), ys: acc))
  end
end

export let hir_to_text = fn (prog: HirProgram) -> string do
  match prog do | HirProgram(ports: _, functions, externals: _, handler_bindings: _, enum_defs: _, exception_groups: _, value_binding_names: _, type_defs: _) ->
    let banner = "=== HIR dump (" ++ str.from_i64(val: list.length(xs: functions)) ++ " functions) ==="
    let lines = hir_funcs_to_text_go(fs: functions, acc: [])
    return banner ++ "\n" ++ join_strs(xs: lines, sep: "\n") ++ "\n"
  end
end

// ─── HIR JSON dump ─────────────────────────────────────────────────────────

let hir_param_to_json = fn (p: HirParam) -> JsonValue do
  match p do | HirParam(label, name, sigil, typ) ->
    return JsonObject(fields: [
      JsonField(key: "label", value: JsonString(val: label)),
      JsonField(key: "name", value: JsonString(val: name)),
      JsonField(key: "sigil", value: JsonString(val: sigil_to_str(s: sigil))),
      JsonField(key: "type", value: JsonString(val: type_to_string(typ)))
    ])
  end
end

let hir_params_to_json_go = fn (ps: [HirParam], acc: [JsonValue]) -> [JsonValue] do
  match ps do
    | [] -> return list.reverse(xs: acc)
    | p :: rest -> return hir_params_to_json_go(ps: rest, acc: hir_param_to_json(p) :: acc)
  end
end

let hir_func_to_json = fn (f: HirFunction) -> JsonValue do
  match f do | HirFunction(name, type_params: _, params, ret_type, throw_row: _, body, span: _, file: _) ->
    let ps_json = JsonArray(items: hir_params_to_json_go(ps: params, acc: []))
    return JsonObject(fields: [
      JsonField(key: "name", value: JsonString(val: name)),
      JsonField(key: "params", value: ps_json),
      JsonField(key: "ret_type", value: JsonString(val: type_to_string(typ: ret_type))),
      JsonField(key: "body_pp", value: JsonString(val: hir_body_to_str(body)))
    ])
  end
end

let hir_funcs_to_json_go = fn (fs: [HirFunction], acc: [JsonValue]) -> [JsonValue] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest -> return hir_funcs_to_json_go(fs: rest, acc: hir_func_to_json(f) :: acc)
  end
end

export let hir_to_json = fn (prog: HirProgram) -> string throws { JsonThrow } do
  match prog do | HirProgram(ports: _, functions, externals: _, handler_bindings: _, enum_defs: _, exception_groups: _, value_binding_names: _, type_defs: _) ->
    let fs_json = JsonArray(items: hir_funcs_to_json_go(fs: functions, acc: []))
    let obj = JsonObject(fields: [
      JsonField(key: "kind", value: JsonString(val: "hir")),
      JsonField(key: "functions", value: fs_json)
    ])
    return json.serialize(v: obj)
  end
end

// ─── LIR body stringifier ──────────────────────────────────────────────────

let lir_atom_to_str = fn (a: LirAtom) -> string do
  match a do
    | LirAtomVar(name, typ: _) -> return name
    | LirAtomInt(val) -> return str.from_i64(val)
    | LirAtomFloat(val) -> return val
    | LirAtomBool(val) -> return str.from_bool(val)
    | LirAtomChar(val) -> return "char(" ++ str.from_i64(val) ++ ")"
    | LirAtomString(val) -> return "\"" ++ val ++ "\""
    | LirAtomUnit -> return "()"
  end
end

let lir_atoms_to_strs = fn (xs: [LirAtom]) -> [string] do
  match xs do
    | [] -> return []
    | a :: rest -> return lir_atom_to_str(a) :: lir_atoms_to_strs(xs: rest)
  end
end

let lir_call_args_to_strs = fn (args: [LirCallArg]) -> [string] do
  match args do
    | [] -> return []
    | LirCallArg(label, value) :: rest ->
      let head = if str.length(s: label) > 0 then label ++ ": " ++ lir_atom_to_str(a: value) else lir_atom_to_str(a: value) end
      return head :: lir_call_args_to_strs(args: rest)
  end
end

let lir_named_atoms_to_strs = fn (fs: [LirNamedAtom]) -> [string] do
  match fs do
    | [] -> return []
    | LirNamedAtom(name, value) :: rest ->
      return (name ++ ": " ++ lir_atom_to_str(a: value)) :: lir_named_atoms_to_strs(fs: rest)
  end
end

let zip_arm_fns_tags = fn (fns: [string], tags: [string]) -> [string] do
  match fns do
    | [] -> return []
    | f :: rest_f ->
      match tags do
        | [] -> return [f] // mismatched lengths -> degrade gracefully
        | t :: rest_t -> return (t ++ "->" ++ f) :: zip_arm_fns_tags(fns: rest_f, tags: rest_t)
      end
  end
end

let lir_expr_to_str = fn (e: LirExpr) -> string do
  match e do
    | LirExprAtom(atom) -> return lir_atom_to_str(a: atom)
    | LirExprBinary(op, lhs, rhs, typ: _) ->
      return "(" ++ lir_atom_to_str(a: lhs) ++ " " ++ binop_to_str(op) ++ " " ++ lir_atom_to_str(a: rhs) ++ ")"
    | LirExprCall(func, args, typ: _) ->
      return func ++ "(" ++ join_strs(xs: lir_call_args_to_strs(args), sep: ", ") ++ ")"
    | LirExprTailCall(func, args, typ: _) ->
      return "tail " ++ func ++ "(" ++ join_strs(xs: lir_call_args_to_strs(args), sep: ", ") ++ ")"
    | LirExprConstructor(name, args, typ: _) ->
      return name ++ "(" ++ join_strs(xs: lir_atoms_to_strs(xs: args), sep: ", ") ++ ")"
    | LirExprRecord(fields, typ: _) ->
      return "{" ++ join_strs(xs: lir_named_atoms_to_strs(fs: fields), sep: ", ") ++ "}"
    | LirExprObjectTag(value, typ: _) -> return "tag(" ++ lir_atom_to_str(a: value) ++ ")"
    | LirExprObjectField(value, index, typ: _) ->
      return "field(" ++ lir_atom_to_str(a: value) ++ ", " ++ str.from_i64(val: index) ++ ")"
    | LirExprRaise(value, typ: _) -> return "raise " ++ lir_atom_to_str(a: value)
    | LirExprForce(value, typ: _) -> return "force " ++ lir_atom_to_str(a: value)
    | LirExprMakeClosure(func_name, captures, typ: _) ->
      return "closure(" ++ func_name ++ "; " ++ join_strs(xs: lir_atoms_to_strs(xs: captures), sep: ", ") ++ ")"
    | LirExprCallClosure(closure, args, typ: _) ->
      return "callcl " ++ lir_atom_to_str(a: closure) ++ "(" ++ join_strs(xs: lir_call_args_to_strs(args), sep: ", ") ++ ")"
    | LirExprSuspend(tag_name, payload, typ: _) ->
      return "suspend $" ++ tag_name ++ " " ++ lir_atom_to_str(a: payload)
    | LirExprResume(cont, value, typ: _) ->
      return "resume " ++ lir_atom_to_str(a: cont) ++ " " ++ lir_atom_to_str(a: value)
    | LirExprContNew(func_ref, typ: _) -> return "cont.new $" ++ func_ref
    | LirExprInjectResume(body_fn, arm_fns, arm_tags, typ: _) ->
      let arms_str = join_strs(xs: zip_arm_fns_tags(fns: arm_fns, tags: arm_tags), sep: "; ")
      return "inject_resume " ++ body_fn ++ " [" ++ arms_str ++ "]"
  end
end

let lir_stmts_to_str_go = fn (stmts: [LirStmt], acc: [string]) -> [string] do
  match stmts do
    | [] -> return list.reverse(xs: acc)
    | s :: rest -> return lir_stmts_to_str_go(stmts: rest, acc: lir_stmt_to_str(s) :: acc)
  end
end

let lir_stmts_to_str = fn (stmts: [LirStmt]) -> string do
  return join_strs(xs: lir_stmts_to_str_go(stmts, acc: []), sep: "; ")
end

let lir_stmt_to_str = fn (s: LirStmt) -> string do
  match s do
    | LirStmtLet(name, typ, expr) -> return "let " ++ name ++ ": " ++ type_to_string(typ) ++ " = " ++ lir_expr_to_str(e: expr)
    | LirStmtIf(cond, then_body, else_body) ->
      return "if " ++ lir_atom_to_str(a: cond) ++ " then " ++ lir_stmts_to_str(stmts: then_body) ++ " else " ++ lir_stmts_to_str(stmts: else_body) ++ " end"
    | LirStmtIfReturn(cond, then_body, then_ret, else_body, else_ret, ret_type: _) ->
      let else_ret_str = match else_ret do | Some(val: v) -> " -> " ++ lir_atom_to_str(a: v) | None -> "" end
      return "ifret " ++ lir_atom_to_str(a: cond) ++ " then " ++ lir_stmts_to_str(stmts: then_body) ++ " -> " ++ lir_atom_to_str(a: then_ret) ++ " else " ++ lir_stmts_to_str(stmts: else_body) ++ else_ret_str
    | LirStmtLoop(cond_stmts, cond, body) ->
      return "loop while " ++ lir_stmts_to_str(stmts: cond_stmts) ++ " | " ++ lir_atom_to_str(a: cond) ++ " do " ++ lir_stmts_to_str(stmts: body) ++ " end"
    | LirStmtTryCatch(body, body_ret, catch_param, catch_param_typ: _, catch_body, catch_ret) ->
      let body_ret_str = match body_ret do | Some(val: v) -> " -> " ++ lir_atom_to_str(a: v) | None -> "" end
      let catch_ret_str = match catch_ret do | Some(val: v) -> " -> " ++ lir_atom_to_str(a: v) | None -> "" end
      return "try " ++ lir_stmts_to_str(stmts: body) ++ body_ret_str ++ " catch " ++ catch_param ++ " -> " ++ lir_stmts_to_str(stmts: catch_body) ++ catch_ret_str
  end
end

let lir_params_to_strs = fn (ps: [LirParam]) -> [string] do
  match ps do
    | [] -> return []
    | LirParam(label, name, typ) :: rest ->
      return (label ++ ": " ++ name ++ ": " ++ type_to_string(typ)) :: lir_params_to_strs(ps: rest)
  end
end

let lir_func_body_to_str = fn (f: LirFunction) -> string do
  match f do | LirFunction(name: _, params: _, ret_type: _, body, ret, span: _) ->
    let body_str = lir_stmts_to_str(stmts: body)
    return body_str ++ " => " ++ lir_atom_to_str(a: ret)
  end
end

// ─── LIR text dump ─────────────────────────────────────────────────────────

let lir_func_to_text_lines = fn (f: LirFunction) -> [string] do
  match f do | LirFunction(name, params, ret_type, body: _, ret: _, span: _) ->
    let ps_str = join_strs(xs: lir_params_to_strs(ps: params), sep: ", ")
    let header = "fn " ++ name ++ "(" ++ ps_str ++ ") -> " ++ type_to_string(typ: ret_type)
    let body_line = "  body: " ++ lir_func_body_to_str(f)
    return [header, body_line]
  end
end

let lir_funcs_to_text_go = fn (fs: [LirFunction], acc: [string]) -> [string] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      let lines = lir_func_to_text_lines(f)
      return lir_funcs_to_text_go(fs: rest, acc: list.concat(xs: list.reverse(xs: lines), ys: acc))
  end
end

export let lir_to_text = fn (funcs: [LirFunction]) -> string do
  let banner = "=== LIR dump (" ++ str.from_i64(val: list.length(xs: funcs)) ++ " functions) ==="
  let lines = lir_funcs_to_text_go(fs: funcs, acc: [])
  return banner ++ "\n" ++ join_strs(xs: lines, sep: "\n") ++ "\n"
end

// ─── LIR JSON dump ─────────────────────────────────────────────────────────

let lir_param_to_json = fn (p: LirParam) -> JsonValue do
  match p do | LirParam(label, name, typ) ->
    return JsonObject(fields: [
      JsonField(key: "label", value: JsonString(val: label)),
      JsonField(key: "name", value: JsonString(val: name)),
      JsonField(key: "type", value: JsonString(val: type_to_string(typ)))
    ])
  end
end

let lir_params_to_json_go = fn (ps: [LirParam], acc: [JsonValue]) -> [JsonValue] do
  match ps do
    | [] -> return list.reverse(xs: acc)
    | p :: rest -> return lir_params_to_json_go(ps: rest, acc: lir_param_to_json(p) :: acc)
  end
end

let lir_func_to_json = fn (f: LirFunction) -> JsonValue do
  match f do | LirFunction(name, params, ret_type, body: _, ret: _, span: _) ->
    let ps_json = JsonArray(items: lir_params_to_json_go(ps: params, acc: []))
    return JsonObject(fields: [
      JsonField(key: "name", value: JsonString(val: name)),
      JsonField(key: "params", value: ps_json),
      JsonField(key: "ret_type", value: JsonString(val: type_to_string(typ: ret_type))),
      JsonField(key: "body_pp", value: JsonString(val: lir_func_body_to_str(f)))
    ])
  end
end

let lir_funcs_to_json_go = fn (fs: [LirFunction], acc: [JsonValue]) -> [JsonValue] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest -> return lir_funcs_to_json_go(fs: rest, acc: lir_func_to_json(f) :: acc)
  end
end

export let lir_to_json = fn (funcs: [LirFunction]) -> string throws { JsonThrow } do
  let fs_json = JsonArray(items: lir_funcs_to_json_go(fs: funcs, acc: []))
  let obj = JsonObject(fields: [
    JsonField(key: "kind", value: JsonString(val: "lir")),
    JsonField(key: "functions", value: fs_json)
  ])
  return json.serialize(v: obj)
end
