/**
 * lsp/protocol/json: LSP error types and JSON decoding helpers.
 *
 * Defines the `LspProtocolError` exception (and its group) plus the
 * low-level `require_field` / `as_*` helpers used by every codec in the
 * protocol sub-modules.
 */

import { JsonValue, JsonNull, JsonBool, JsonInt, JsonString,
         JsonArray, JsonError, get_field } from "std:json"
import { JsonRpcFrameError, JsonRpcEof } from "std:jsonrpc"
import { Option, Some, None } from "std:option"

/** Raised by `*_from_json` decoders when input violates the LSP schema; routes back to clients as JSON-RPC `InvalidParams`. */
export exception LspProtocolError(msg: string)

/** Exception group covering every LSP wire-format decoder failure (sole member: `LspProtocolError`). */
export exception group LspProtocolThrow = LspProtocolError

/** Joint umbrella covering every exception the LSP I/O loop can raise:
 *  JSON-RPC framing errors (`JsonRpcFrameError`, `JsonRpcEof`, `JsonError`)
 *  plus LSP wire-codec failures (`LspProtocolError`).
 *  Used at `run_server` / `run_server_go` boundaries in `handlers.nx`.
 */
export exception group LspError =
    JsonRpcFrameError | JsonRpcEof | JsonError | LspProtocolError

//
// These walk the json.nx algebra and throw LspProtocolError on the first
// schema violation. They are not exported — the wire types are the public
// surface — but their shape is consistent so adding new types follows the
// same pattern.

export let require_field = fn (
  obj: JsonValue,
  key: string
) -> JsonValue throws { LspProtocolThrow } do
  match get_field(obj, key) do
    | Some(val: v) -> return v
    | None -> throw LspProtocolError(msg: "missing required field '" ++ key ++ "'")
  end
end

export let optional_field = fn (obj: JsonValue, key: string) -> Option<JsonValue> do
  return get_field(obj, key)
end

export let as_string = fn (v: JsonValue, ctx: string) -> string throws { LspProtocolThrow } do
  match v do
    | JsonString(val: s) -> return s
    | _ -> throw LspProtocolError(msg: ctx ++ ": expected string")
  end
end

export let as_i64 = fn (v: JsonValue, ctx: string) -> i64 throws { LspProtocolThrow } do
  match v do
    | JsonInt(val: i) -> return i
    | _ -> throw LspProtocolError(msg: ctx ++ ": expected integer")
  end
end

export let as_bool = fn (v: JsonValue, ctx: string) -> bool throws { LspProtocolThrow } do
  match v do
    | JsonBool(val: b) -> return b
    | _ -> throw LspProtocolError(msg: ctx ++ ": expected boolean")
  end
end

export let as_array = fn (v: JsonValue, ctx: string) -> [ JsonValue ] throws { LspProtocolThrow } do
  match v do
    | JsonArray(items: xs) -> return xs
    | _ -> throw LspProtocolError(msg: ctx ++ ": expected array")
  end
end

export let optional_string = fn (
  obj: JsonValue,
  key: string,
  ctx: string
) -> Option<string> throws { LspProtocolThrow } do
  match optional_field(obj, key) do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ -> return Some(val: as_string(v, ctx))
      end
  end
end

export let optional_int = fn (
  obj: JsonValue,
  key: string,
  ctx: string
) -> Option<i64> throws { LspProtocolThrow } do
  match optional_field(obj, key) do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ -> return Some(val: as_i64(v, ctx))
      end
  end
end

export let optional_bool = fn (
  obj: JsonValue,
  key: string,
  ctx: string
) -> Option<bool> throws { LspProtocolThrow } do
  match optional_field(obj, key) do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ -> return Some(val: as_bool(v, ctx))
      end
  end
end

export let strings_to_json_items = fn (xs: [ string ], acc: [ JsonValue ]) -> [ JsonValue ] do
  match xs do
    | [] -> return acc
    | s :: rest -> return strings_to_json_items(xs: rest, acc: JsonString(val: s) :: acc)
  end
end
