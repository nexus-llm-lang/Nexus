/**
 * lsp/handlers: Nexus-specific LSP server dispatch.
 *
 * Owns method-name routing, lifecycle gating, and the stdin/stdout loop.
 * The Nexus compiler is the sole LSP consumer, so the previous
 * language-agnostic scaffold (the `Handlers` vtable + `default_*` row in
 * `nxlib/lsp/server.nx`) collapsed into direct dispatch here.
 *
 * Layering:
 *   std:jsonrpc                       — Content-Length framing, frame error mapping
 *   src/tools/lsp/protocol.nx               — wire types + JSON codecs (LSP spec shapes)
 *   src/tools/lsp/diagnostics.nx            — typecheck → internal Diagnostic stream
 *   src/tools/lsp/handlers/symbols.nx                — parsed AST → DocumentSymbol tree
 *   src/tools/lsp/handlers/definition.nx             — go-to-definition resolver
 *   src/tools/lsp/handlers/completion.nx             — completion provider
 *   src/tools/lsp/handlers/references.nx             — references provider
 *   src/tools/lsp/handlers/signature_help.nx         — signature help provider
 *   src/tools/lsp/handlers/semantic_tokens.nx        — semantic tokens provider
 *   src/tools/lsp/handlers/workspace_symbol.nx       — workspace symbol provider
 *   src/tools/lsp/state.nx                  — server state types + accessors
 *   src/tools/lsp/diagnostics_pipeline.nx   — per-buffer diagnostics + publishDiagnostics
 *   src/tools/lsp/request_handlers.nx       — per-method LSP handlers
 *   src/tools/lsp/handlers.nx (this file)   — dispatch + initialize + loop
 *   src/tools/lsp/main.nx                   — entry point (capability injection only)
 *
 * Lifecycle invariants (LSP base spec §`Lifecycle Messages`):
 *   - `initialize` is the first request; other requests before it return
 *     a JSON-RPC error with code -32002 (server not initialized).
 *   - `shutdown` flips a flag; further requests return InvalidRequest.
 *   - `exit` returns `StepExit` from the dispatch step; the I/O loop
 *     observes it and stops reading.
 *
 * Document sync is full-content only (TextDocumentSyncKind = 1).
 * Incremental sync is post-MVP — an incremental change in the stream
 * raises `LspProtocolError` so the gap is visible rather than silently
 * dropped.
 */

import { JsonValue, JsonNull } from "std:json"
import { Option, Some, None } from "std:option"
import { Fs } from "std:fs"
import { Console } from "std:stdio"
import { Coop, scheduler } from "std:concurrency/coop"
import {
  IncomingMessage, Request, Notification, Malformed,
  JsonRpcFrameError, JsonRpcError,
  response_ok, response_error,
  method_not_found, invalid_request, invalid_params, internal_error,
  classify, read_message, read_message_pipelined, read_message_cooperative, write_message
} from "std:jsonrpc"
import { Pair } from "std:tuple"
import { semantic_tokens_legend } from "src/tools/lsp/handlers/semantic_tokens.nx"
import { LspProtocolError, LspProtocolThrow, LspError } from "src/tools/lsp/protocol/json.nx"
import {
  LspMethod, MInitialize, MInitialized, MShutdown,
  MTextDocumentDidOpen, MTextDocumentDidChange, MTextDocumentDidClose,
  MTextDocumentDidSave, MTextDocumentDocumentSymbol, MTextDocumentHover,
  MTextDocumentDefinition, MTextDocumentCompletion,
  MTextDocumentReferences, MTextDocumentSignatureHelp,
  MTextDocumentSemanticTokensFull, MTextDocumentFormatting,
  MWorkspaceSymbol,
  MUnknownMethod, parse_method
} from "src/tools/lsp/protocol/method.nx"
import {
  TdsFull,
  TdsSyncOptions,
  TextDocumentSyncOptions
} from "src/tools/lsp/protocol/text_doc.nx"
import {
  ServerCapabilities,
  InitializeResult, ServerInfo,
  initialize_params_from_json, initialize_result_to_json,
  CompletionOptions,
  SignatureHelpOptions,
  SemanticTokensOptions
} from "src/tools/lsp/protocol/completion.nx"
import {
  ServerState, HandlerResult,
  server_not_initialized,
  with_lifecycle_running,
  lifecycle_is_uninitialized, lifecycle_is_running, lifecycle_is_shutdown
} from "src/tools/lsp/state/server_state.nx"
import {
  on_did_open, on_did_change, on_did_close, on_did_save,
  on_noop, on_shutdown,
  on_document_symbol, on_hover, on_definition, on_completion,
  on_references, on_signature_help, on_semantic_tokens,
  on_formatting, on_workspace_symbol
} from "src/tools/lsp/request_handlers.nx"
import * as arena from "std:runtime/arena"

//
// Outcome of routing a single inbound message. `Continue` advances the
// loop with possibly-updated state plus an optional response and any
// outbound notifications; `Exit` stops the loop (received on the LSP
// `exit` notification).

/** Outcome of routing a single inbound LSP message: `Continue` advances the loop with an optional response + notifications, `Exit` terminates on the `exit` notification. */
export type StepOutcome =
    StepContinue(state: ServerState, response: Option<JsonValue>, notifications: [ JsonValue ])
  | StepExit(state: ServerState)

let on_initialize = fn (
  state: ServerState,
  params: JsonValue
) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  // Validate input shape; we don't read fields beyond what the protocol
  // codec checks. Errors propagate as LspProtocolError -> InvalidParams.
  initialize_params_from_json(v: params)
  let caps = ServerCapabilities(
    text_document_sync: Some(val: TdsSyncOptions(opts: TextDocumentSyncOptions(change: TdsFull, save: true))),
    /**
    textDocument/documentSymbol is routed through
    `src/tools/lsp/symbols.document_symbols_for_program`; advertise the
    capability so clients populate the outline view.
    */
    document_symbol_provider: Some(val: true),
    /** textDocument/hover surfaces the file-level `/** ... */` doc comment
     *  when the cursor is on the first line. Per-definition hovers are
     * out of scope (MVP).
     */
    hover_provider: Some(val: true),
    /**
    textDocument/definition routes through `src/tools/lsp/definition.resolve_definition`,
    which uses the same import-aware build pipeline as the diagnostics
    path to follow `alias.foo` / bare-identifier references back to
    their defining `let` / `cap` site.
    */
    definition_provider: Some(val: true),
    /**
    textDocument/references routes through `src/tools/lsp/references.find_references`,
    which reuses the definition-path rename pipeline plus a full AST
    walk to collect every use site for the canonical name under the
    cursor.
    */
    references_provider: Some(val: true),
    /**
    textDocument/completion routes through `src/tools/lsp/completion.resolve_completion`.
    Trigger characters `.` and `:` cover future record-field /
    module-qualified suggestions; the MVP returns the same scope-derived
    list regardless of trigger. `resolveProvider: false` — every
    CompletionItem is fully populated in the initial response
   .
    */
    completion_provider: Some(val: CompletionOptions(
      trigger_characters: [ ".", ":" ],
      resolve_provider: false
    )),
    /**
    textDocument/signatureHelp routes through
    `src/tools/lsp/signature_help.resolve_signature_help`. Trigger character
    `(` opens the popup; `,` advances to the next parameter. The MVP
    emits one SignatureInformation per call site (no overload
    resolution; Nexus has none).
    */
    signature_help_provider: Some(val: SignatureHelpOptions(trigger_characters: [ "(", "," ])),
    /**
    textDocument/semanticTokens/full routes through
    `src/tools/lsp/semantic_tokens.compute_semantic_tokens`. The legend pairs
    the in-stream `tokenType` integers with the spec-style names the
    client renders (keyword / function / variable / parameter / type /
    variant / string / number / comment / operator). MVP advertises
    `full: true` only; range / delta requests are post-MVP
   .
    */
    semantic_tokens_provider: Some(val: SemanticTokensOptions(
      legend: semantic_tokens_legend(),
      full: true
    )),
    /**
    textDocument/formatting routes through
    `src/tools/lsp/handlers/formatting.compute_formatting_edits`, which wraps
    the same `format_source` byte-level pass `nexus fmt` uses. MVP
    returns one full-document TextEdit (range = (0,0)..end-of-doc,
    newText = formatted buffer); incremental edits / range formatting
    are post-MVP refinements (subset).
    */
    document_formatting_provider: Some(val: true),
    /**
    workspace/symbol routes through
    `src/tools/lsp/workspace_symbol.find_workspace_symbols`. Each open document
    contributes its top-level lets / caps / types / exceptions to a flat
    SymbolInformation stream, filtered by case-insensitive substring
    match against the client query.
    */
    workspace_symbol_provider: Some(val: true)
  )
  let info = ServerInfo(name: "nexus-lsp", version: Some(val: "0.1.0"))
  let result = InitializeResult(capabilities: caps, server_info: Some(val: info))
  return HandlerResult(
    state: with_lifecycle_running(state),
    response: Some(val: initialize_result_to_json(r: result)),
    notifications: []
  )
end

//
// `parse_method` lifts the wire string into the closed `LspMethod` sum; the
// `match` below is exhaustive, so adding a new LSP method to `parse_method`
// without wiring it here is a typechecker error. `MUnknownMethod(name)`
// returns `response: None` so request dispatch routes it as MethodNotFound
// and notifications collapse to a no-op.

let invoke_method = fn (
  state: ServerState,
  method: string,
  params: JsonValue
) -> HandlerResult require { Console, Fs, Coop } throws { LspProtocolThrow } do
  match parse_method(s: method) do
    | MInitialize -> return on_initialize(state, params)
    | MInitialized -> return on_noop(state, params)
    | MTextDocumentDidSave -> return on_did_save(state, params)
    | MTextDocumentDidOpen -> return on_did_open(state, params)
    | MTextDocumentDidChange -> return on_did_change(state, params)
    | MTextDocumentDidClose -> return on_did_close(state, params)
    | MShutdown -> return on_shutdown(state, params)
    | MTextDocumentDocumentSymbol -> return on_document_symbol(state, params)
    | MTextDocumentHover -> return on_hover(state, params)
    | MTextDocumentDefinition -> return on_definition(state, params)
    | MTextDocumentCompletion -> return on_completion(state, params)
    | MTextDocumentReferences -> return on_references(state, params)
    | MTextDocumentSignatureHelp -> return on_signature_help(state, params)
    | MTextDocumentSemanticTokensFull -> return on_semantic_tokens(state, params)
    | MTextDocumentFormatting -> return on_formatting(state, params)
    | MWorkspaceSymbol -> return on_workspace_symbol(state, params)
    | MUnknownMethod(name: _) ->
      params
      return HandlerResult(state, response: None, notifications: [])
  end
end

//
// Routes `msg` through the per-method handlers while enforcing LSP lifecycle
// invariants. Returns a StepOutcome the I/O loop (or a test driver) consumes.

/** Pure per-message router enforcing LSP lifecycle gates (pre-initialize, post-shutdown) and translating handler results into a `StepOutcome`. */
export let dispatch_message = fn (
  state: ServerState,
  msg: IncomingMessage
) -> StepOutcome require { Console, Fs, Coop } throws { LspProtocolThrow } do
  match msg do
    | Request(id, method, params) ->
      // Pre-initialize gate: only `initialize` is permitted before handshake.
      if lifecycle_is_uninitialized(state) && method != "initialize" then
        let err = response_error(id,
          code: server_not_initialized(),
          message: "server not initialized")
        return StepContinue(state, response: Some(val: err), notifications: [])
      end
      // Per LSP spec, a second `initialize` after the handshake completes is
      // invalid. Return InvalidRequest (-32600).
      if lifecycle_is_running(state) && method == "initialize" then
        let err = response_error(id,
          code: invalid_request(),
          message: "server already initialized")
        return StepContinue(state, response: Some(val: err), notifications: [])
      end
      // Post-shutdown gate: any request other than `exit` (a notification)
      // is rejected per spec.
      if lifecycle_is_shutdown(state) then
        let err = response_error(id,
          code: invalid_request(),
          message: "server has shut down")
        return StepContinue(state, response: Some(val: err), notifications: [])
      end
      try
        let result = invoke_method(state, method, params)
        let HandlerResult(state: new_state, response, notifications) = result
        let response_envelope = match response do
            | Some(val: r) -> Some(val: response_ok(id, result: r))
            | None ->
              // Unknown method → MethodNotFound.
              Some(val: response_error(id,
                code: method_not_found(),
                message: "method not found: " ++ method))
          end
          return StepContinue(state: new_state, response: response_envelope, notifications)
      catch err ->
        let err_response = match err do
          | LspProtocolError(msg) ->
            response_error(id, code: invalid_params(), message: msg)
          | _ ->
            response_error(id,
              code: internal_error(),
              message: "internal error in handler")
        end
        return StepContinue(state, response: Some(val: err_response), notifications: [])
      end
    | Notification(method, params) ->
      // `exit` short-circuits. Per spec, the server must exit even if no
      // shutdown was received; the I/O loop converts StepExit into a
      // graceful loop termination.
      if method == "exit" then
        return StepExit(state)
      end
      // Post-shutdown gate: after `shutdown`, only `exit` (handled above) is
      // acknowledged; all other notifications are silently dropped per LSP spec.
      if lifecycle_is_shutdown(state) then
        return StepContinue(state, response: None, notifications: [])
      end
      // Pre-initialize gate for notifications: spec drops them silently
      // except `exit` (handled above), `initialized`, and `$/cancelRequest`.
      // `$/cancelRequest` must not be blocked by the lifecycle gate per LSP
      // spec §3.16.2 — pass it through regardless of lifecycle state.
      if lifecycle_is_uninitialized(state) && method != "initialized" && method != "$/cancelRequest" then
        return StepContinue(state, response: None, notifications: [])
      end
      try
        let result = invoke_method(state, method, params)
        let HandlerResult(state: new_state, response: _, notifications) = result
        return StepContinue(state: new_state, response: None, notifications)
      // Notifications have no reply channel; per LSP spec the server
      // logs and continues. Catch LspProtocolError (malformed params)
      // here and discharge as a no-op state transition. Other
      // exceptions propagate so genuine invariant violations surface
      // at the entry point.
      catch
        | LspProtocolError(_) -> return StepContinue(state, response: None, notifications: [])
        | err -> throw err
      end
    | Malformed(reason) ->
      // Already-classified malformed input (no `method` or non-string method).
      // Surface as a JSON-RPC error with null id.
      return StepContinue(
        state,
        response: Some(val: response_error(id: JsonNull, code: invalid_request(), message: reason)),
        notifications: []
      )
  end
end

// ═══════════════════════════════════════════════════════════════════════════
// I/O layer
// ═══════════════════════════════════════════════════════════════════════════
//
// `run_server` ties the pure dispatch to stdin/stdout via the std:jsonrpc
// framing primitives. The loop is hand-rolled (rather than calling
// jsonrpc.dispatch_loop) because we need to thread `ServerState` through
// each step and observe StepExit — both of which the generic dispatch_loop
// can't carry through its closure-based API.

let write_notifications = fn (xs: [ JsonValue ]) -> unit require { Console } throws { JsonRpcError } do
  match xs do
    | [] -> return ()
    | n :: rest ->
      write_message(value: n)
      return write_notifications(xs: rest)
  end
end

/** The stdin/stdout dispatch loop, run inside a `scheduler` inject so each
 *  frame ends at a `Coop.yield()` cooperative scheduling point. Two contracts
 *  follow from running under the cooperative scheduler: (1) the loop body is
 *  exception-airtight — every dispatch fault (frame/JSON parse error, protocol
 *  error, or handler invariant violation) is caught and logged, never
 *  propagated, both because an LSP server must survive a single bad frame and
 *  because an exception escaping the cooperative block would abort the process
 *  under wasmtime#13584; (2) it stays on the normal return path. */
let run_server_go = fn (
  state: ServerState,
  remaining: i64,
  leftover: string
) -> ServerState require { Console, Fs, Coop } throws { LspError } do
  if remaining == 0 then return state end
  try
    /* Arena discipline: `read_message_cooperative` allocates `next_leftover`
       from the arena. We take the mark AFTER that allocation so the leftover
       string (which must survive into the next iteration) sits BELOW the mark.
       The entire dispatch — parse tree, HIR, typecheck, wire diagnostics,
       notifications — is allocated ABOVE the mark and reclaimed in O(1).

       The cooperative read replaces the blocking `read_message_pipelined`:
       while idle-waiting for the next frame it yields to spawned fibers (e.g.
       the diagnostics fiber from a didChange/didOpen) and non-blocking-polls
       input, blocking in `poll_oneoff` only when the run queue is empty. Frame
       assembly is identical to the blocking read for a piped/buffered stream. */
    let Pair(left: msg_opt, right: next_leftover) = read_message_cooperative(leftover)
    arena.save_request_mark()
    match msg_opt do
      | None ->
        arena.reset_to_request_mark()
        return state
      | Some(val: value) ->
        let classified = classify(value)
        match dispatch_message(state, msg: classified) do
          | StepExit(state: new_state) ->
            /* Write any pending notifications before resetting, then exit. */
            arena.reset_to_request_mark()
            return new_state
          | StepContinue(state: new_state, response, notifications) ->
            match response do
              | Some(val: r) -> write_message(value: r)
              | None -> ()
            end
            write_notifications(xs: notifications)
            /* Yield to the scheduler BEFORE reclaiming this request's arena.
               A diagnostics fiber spawned during dispatch (didChange/didOpen)
               captured this request's buffer text/uri ABOVE the mark; it has
               no internal `Coop.yield`, so it runs to completion in this resume
               while those captures are still live. Only then do we reset, which
               reclaims the fiber's scratch along with the rest of the request. */
            Coop.yield()
            arena.reset_to_request_mark()
            let next_remaining = if remaining < 0 then -1 else remaining - 1 end
            return run_server_go(
              state: new_state,
              remaining: next_remaining,
              leftover: next_leftover
            )
        end
    end
  catch err ->
    arena.reset_to_request_mark()
    let detail = match err do
      | JsonRpcFrameError(msg) -> "frame error: " ++ msg
      | LspProtocolError(msg) -> "protocol error: " ++ msg
      | _ -> "unexpected dispatch fault"
    end
    Console.eprintln(val: "[lsp/server] " ++ detail ++ "; continuing")
    let next_remaining = if remaining < 0 then -1 else remaining - 1 end
    return run_server_go(state, remaining: next_remaining, leftover: "")
  end
end

/**
Read JSON-RPC frames off stdin, dispatch through the per-method handlers
while threading `state`, and write responses + notifications back to
stdout. Returns the final ServerState when the loop terminates (EOF,
`exit` notification, or `max_iters` reached).

`max_iters < 0` is unbounded (production setting); tests pass a small
bound to drive a finite synthetic stream.

Capability discipline: the import-aware diagnostics path requires `Fs`
(cross-file reads) and `Console` (log lines). The caller discharges
both via a wrapping `inject` block — typically
`inject stdio.system_handler, fs_mod.system_handler do run_server(...) end`
at the entry point.
*/
/** Main stdin/stdout LSP loop; threads `initial_state` through each frame and stops at EOF, `exit` notification, or after `max_iters` (negative = unbounded). */
export let run_server = fn (
  initial_state: ServerState,
  max_iters: i64
) -> ServerState require { Console, Fs } throws { LspError } do
  inject scheduler do
    return run_server_go(state: initial_state, remaining: max_iters, leftover: "")
  end
end
