/**
 * lsp/state: server state types + accessors.
 *
 * Owns the document buffer store, the per-URI diagnostics cache, the
 * `ServerState` aggregate, and the small `require_object_field` helper
 * shared by every handler that decodes wire JSON.
 *
 * Split out of `lsp/handlers.nx` so the dispatch layer can stay focused on
 * method routing while the value types and their accessors live alongside
 * each other. No public-API change: every export here was an export (or
 * an internal let) in the old `handlers.nx`; callers in `lsp/main.nx`
 * and the sibling handler modules continue to import the same names.
 */

import { JsonValue, get_field } from "std:json"
import * as list from "std:list"
import { Option, Some, None } from "std:option"
import { Diagnostic } from "src/tools/lsp/protocol/diag.nx"
import { LspProtocolError, LspProtocolThrow } from "src/tools/lsp/protocol/json.nx"

/** LSP error code returned when a request arrives before `initialize` (§3.6). */
export let server_not_initialized = fn () -> i64 do return -32002 end

//
// LSP servers track open documents keyed by `uri`. Full-content sync stores
// the latest text + version; the version is the integer the client last
// sent in `didOpen` / `didChange`. A list-based assoc structure is fine for
// MVP — typical editors keep tens of files open, and lookup/update is
// linear in that count.

/** One open document: its URI, the latest full text, and the client's version integer. */
export type DocumentRecord = DocumentRecord(uri: string, text: string, version: i64)

/** Collection of open documents, indexed by URI via linear scan over `records`. */
export type DocumentStore = DocumentStore(records: [ DocumentRecord ])

let documents_empty = fn () -> DocumentStore do
  return DocumentStore(records: [])
end

let docs_lookup_go = fn (xs: [ DocumentRecord ], uri: string) -> Option<DocumentRecord> do
  match xs do
    | [] -> return None
    | r :: rest ->
      let DocumentRecord(uri: u, text: _, version: _) = r
      if u == uri then return Some(val: r) end
        return docs_lookup_go(xs: rest, uri)
  end
end

/**
Look up the latest record for `uri`. Returns `None` if no document with
this URI is open.
*/
export let documents_lookup = fn (store: DocumentStore, uri: string) -> Option<DocumentRecord> do
  let DocumentStore(records) = store
  return docs_lookup_go(xs: records, uri)
end

let reverse_records_then_append = fn (
  xs: [ DocumentRecord ],
  tail: [ DocumentRecord ]
) -> [ DocumentRecord ] do
  match xs do
    | [] -> return tail
    | r :: rest -> return reverse_records_then_append(xs: rest, tail: r :: tail)
  end
end

let docs_remove_go = fn (
  xs: [ DocumentRecord ],
  uri: string,
  acc: [ DocumentRecord ]
) -> [ DocumentRecord ] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | r :: rest ->
      let DocumentRecord(uri: u, text: _, version: _) = r
      if u == uri then
          return reverse_records_then_append(xs: acc, tail: rest)
        end
        return docs_remove_go(xs: rest, uri, acc: r :: acc)
  end
end

/**
Insert or replace the record for `uri`. Existing entries with the same
URI are removed first so each URI maps to at most one record.
*/
export let documents_put = fn (store: DocumentStore, rec: DocumentRecord) -> DocumentStore do
  let DocumentStore(records) = store
  let DocumentRecord(uri, text: _, version: _) = rec
  let pruned = docs_remove_go(xs: records, uri, acc: [])
      return DocumentStore(records: rec :: pruned)
end

/** Remove the record for `uri` (no-op if absent). */
export let documents_remove = fn (store: DocumentStore, uri: string) -> DocumentStore do
  let DocumentStore(records) = store
  return DocumentStore(records: docs_remove_go(xs: records, uri, acc: []))
end

//
// One row per open URI, carrying the most recent `(version, diagnostics)` pair
// from the typecheck pipeline. Replacing the old `ServerState.user_data:
// JsonValue` slot with a typed list drops the JSON encode/decode round-trip
// that every cache read used to incur.

/** Cached typecheck output for one document version: the diagnostics list keyed by `(uri, version)`. */
export type DiagCacheEntry = DiagCacheEntry(uri: string, version: i64, diagnostics: [ Diagnostic ])

let cache_lookup_go = fn (
  xs: [ DiagCacheEntry ],
  uri: string,
  version: i64
) -> Option<[ Diagnostic ]> do
  match xs do
    | [] -> return None
    | DiagCacheEntry(uri: u, version: v, diagnostics: d) :: rest ->
      if u == uri && v == version then return Some(val: d) end
      return cache_lookup_go(xs: rest, uri, version)
  end
end

/** Find cached diagnostics for `(uri, version)`. Returns `None` on a miss or version mismatch. */
export let cache_lookup = fn (
  cache: [ DiagCacheEntry ],
  uri: string,
  version: i64
) -> Option<[ Diagnostic ]> do
  return cache_lookup_go(xs: cache, uri, version)
end

// Strip any existing row for `uri`, then prepend the fresh entry.
let cache_drop_uri = fn (
  xs: [ DiagCacheEntry ],
  uri: string,
  acc: [ DiagCacheEntry ]
) -> [ DiagCacheEntry ] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | DiagCacheEntry(uri: u, version: v, diagnostics: d) :: rest ->
      if u == uri then return cache_drop_uri(xs: rest, uri, acc) end
      return cache_drop_uri(
        xs: rest,
        uri,
        acc: DiagCacheEntry(uri: u, version: v, diagnostics: d) :: acc
      )
  end
end

/** Insert or replace the cache row for `uri`. Any prior entry (any version) is dropped first. */
export let cache_put = fn (
  cache: [ DiagCacheEntry ],
  uri: string,
  version: i64,
  diagnostics: [ Diagnostic ]
) -> [ DiagCacheEntry ] do
  let pruned = cache_drop_uri(xs: cache, uri, acc: [])
  return DiagCacheEntry(uri, version, diagnostics) :: pruned
end

/** Remove every cache row for `uri` (no-op if absent). Used by `on_did_close` to prevent unbounded cache growth. */
export let cache_evict_uri = fn (cache: [ DiagCacheEntry ], uri: string) -> [ DiagCacheEntry ] do
  return cache_drop_uri(xs: cache, uri, acc: [])
end

//
// Tracks lifecycle phase, open documents, and the typed diagnostics cache.

/** LSP server lifecycle phase: pre-`initialize`, post-`initialized`, or post-`shutdown`. */
export type Lifecycle =
    LifecycleUninitialized
  | LifecycleRunning
  | LifecycleShutdown

/** Aggregate server state: lifecycle phase, open documents, and the typed diagnostics cache. */
export type ServerState = ServerState(
  lifecycle: Lifecycle,
  documents: DocumentStore,
  diagnostics_cache: [ DiagCacheEntry ]
)

/** Fresh state at process start: uninitialized lifecycle, no documents, empty cache. */
export let empty_state = fn () -> ServerState do
  return ServerState(
    lifecycle: LifecycleUninitialized,
    documents: documents_empty(),
    diagnostics_cache: []
  )
end

/** Project out the document store from `state`. */
export let state_documents = fn (state: ServerState) -> DocumentStore do
  let ServerState(lifecycle: _, documents, diagnostics_cache: _) = state
  return documents
end

/** Project out the diagnostics cache list from `state`. */
export let state_cache = fn (state: ServerState) -> [ DiagCacheEntry ] do
  let ServerState(lifecycle: _, documents: _, diagnostics_cache) = state
  return diagnostics_cache
end

/** Return `state` with its `documents` field replaced by `docs`; other fields are unchanged. */
export let with_documents = fn (state: ServerState, docs: DocumentStore) -> ServerState do
  let ServerState(lifecycle, documents: _, diagnostics_cache) = state
  return ServerState(lifecycle, documents: docs, diagnostics_cache)
end

/** Return `state` with its `diagnostics_cache` field replaced by `cache`; other fields are unchanged. */
export let with_cache = fn (state: ServerState, cache: [ DiagCacheEntry ]) -> ServerState do
  let ServerState(lifecycle, documents, diagnostics_cache: _) = state
  return ServerState(lifecycle, documents, diagnostics_cache: cache)
end

/** Return `state` with its lifecycle set to `LifecycleRunning` (post-`initialized`). */
export let with_lifecycle_running = fn (state: ServerState) -> ServerState do
  let ServerState(lifecycle: _, documents, diagnostics_cache) = state
  return ServerState(lifecycle: LifecycleRunning, documents, diagnostics_cache)
end

/** Return `state` with its lifecycle set to `LifecycleShutdown` (post-`shutdown`, pre-`exit`). */
export let with_lifecycle_shutdown = fn (state: ServerState) -> ServerState do
  let ServerState(lifecycle: _, documents, diagnostics_cache) = state
  return ServerState(lifecycle: LifecycleShutdown, documents, diagnostics_cache)
end

/** True iff `state` is in the running phase (post-`initialize`, pre-`shutdown`). */
export let lifecycle_is_running = fn (state: ServerState) -> bool do
  let ServerState(lifecycle, documents: _, diagnostics_cache: _) = state
  match lifecycle do
      | LifecycleRunning -> return true
      | _ -> return false
    end
end

/** True iff `state` is still in the pre-`initialize` phase. */
export let lifecycle_is_uninitialized = fn (state: ServerState) -> bool do
  let ServerState(lifecycle, documents: _, diagnostics_cache: _) = state
  match lifecycle do
      | LifecycleUninitialized -> return true
      | _ -> return false
    end
end

/** True iff `state` has been shut down (post-`shutdown`, awaiting `exit`). */
export let lifecycle_is_shutdown = fn (state: ServerState) -> bool do
  let ServerState(lifecycle, documents: _, diagnostics_cache: _) = state
  match lifecycle do
      | LifecycleShutdown -> return true
      | _ -> return false
    end
end

/** Extract `obj[key]` or throw `LspProtocolError` whose message embeds `ctx` to locate the call site. */
export let require_object_field = fn (
  obj: JsonValue,
  key: string,
  ctx: string
) -> JsonValue throws { LspProtocolThrow } do
  match get_field(obj, key) do
    | Some(val: v) -> return v
    | None -> throw LspProtocolError(msg: ctx ++ ": missing '" ++ key ++ "'")
  end
end

/** Per-handler return shape: the updated state, an optional response payload, and any notifications to publish. */
export type HandlerResult = HandlerResult(
  state: ServerState,
  response: Option<JsonValue>,
  notifications: [ JsonValue ]
)
