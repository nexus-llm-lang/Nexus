/**
 * lsp/diagnostics_pipeline: per-buffer diagnostics emission.
 *
 * Layers on top of `src/tools/lsp/diagnostics.nx` (the position-keyed surface over
 * the typechecker). This module owns the editor-facing pipeline:
 *
 *   1. Lex + parse + import resolution (`program_state.build_program_state`).
 *   2. Import-aware HIR build (`build_hir_with_imports` here).
 *   3. Typecheck via `enumerate_diagnostics`.
 *   4. Translate internal `DiagEntry` → wire `Diagnostic`.
 *   5. Build the `textDocument/publishDiagnostics` notification, consulting
 *      the per-URI version cache.
 *
 * The split keeps `lsp/handlers.nx` focused on method routing while this
 * file owns the diagnostics flow shared by `on_did_open`, `on_did_change`
 * and any future "republish" trigger.
 *
 * Name chosen to avoid collision with `src/tools/lsp/diagnostics.nx`, which holds
 * the smaller `DiagEntry` / `enumerate_diagnostics` surface this module
 * sits above.
 */

import { JsonValue, JsonObject, JsonString, JsonField, get_field } from "std:json"
import * as list from "std:list"
import { Option, Some, None } from "std:option"
import { HirProgram } from "src/ir/hir/types.nx"
import { HirError } from "src/diagnostics/error.nx"
import { SpannedTopLevel, GlobalLet, TLLet } from "src/syntax/ast.nx"
import { process_defs } from "src/ir/hir/build/defs.nx"
import { accum_to_program } from "src/ir/hir/build/accum.nx"
import * as parser from "src/frontend/parser.nx"
import * as rdr from "src/ir/shared/rdrname.nx"
import { resolve_all_lazy_no_filter } from "src/ir/hir/demand.nx"
import { Fs } from "std:fs"
import { Console } from "std:stdio"
import {
  DiagEntry, DiagRange,
  SeverityError,
  enumerate_diagnostics,
  make_origin_error_diagnostic
} from "src/tools/lsp/state/diagnostics.nx"
import { ProgramState, resolve_imports_for } from "src/tools/lsp/state/program_state.nx"
import { Position, Range } from "src/tools/lsp/protocol/text_doc.nx"
import {
  PublishDiagnosticsParams, publish_diagnostics_params_to_json,
  Diagnostic, DiagSevError
} from "src/tools/lsp/protocol/diag.nx"
import {
  ServerState, DocumentRecord, HandlerResult,
  documents_put, state_documents, state_cache,
  cache_lookup, cache_put,
  with_documents, with_cache
} from "src/tools/lsp/state/server_state.nx"
import { saturating_pred } from "src/tools/lsp/common.nx"
import * as arena from "std:runtime/arena"
import { Coop, spawn } from "std:concurrency/coop"
import { write_message, JsonRpcError } from "std:jsonrpc"

//
// Saturating clamp on coordinate conversion: a bogus 0 in the input becomes
// wire 0 (the closest valid LSP coordinate) rather than -1 which the spec
// rejects. `saturating_pred` lives in `src/tools/lsp/common.nx`.

let to_wire_diagnostic = fn (d: DiagEntry) -> Diagnostic do
  let DiagEntry(file: _, range, severity, code, message) = d
  let DiagRange(start_line, start_col, end_line, end_col) = range
  let start_pos = Position(
        line: saturating_pred(n: start_line),
        character: saturating_pred(n: start_col)
      )
      let end_pos = Position(
        line: saturating_pred(n: end_line),
        character: saturating_pred(n: end_col)
      )
      let wire_sev = match severity do
        | SeverityError -> Some(val: DiagSevError)
      end
      let wire_code = if code == "" then None else Some(val: code) end
      return Diagnostic(
        range: Range(start: start_pos, end_: end_pos),
        severity: wire_sev,
        code: wire_code,
        source: Some(val: "nexus"),
        message
      )
end

let translate_diagnostics_go = fn (xs: [ DiagEntry ], acc: [ Diagnostic ]) -> [ Diagnostic ] do
  match xs do
    | [] -> return acc
    | d :: rest -> return translate_diagnostics_go(xs: rest, acc: to_wire_diagnostic(d: d) :: acc)
  end
end

let to_wire_diagnostics = fn (xs: [ DiagEntry ]) -> [ Diagnostic ] do
  let reversed = translate_diagnostics_go(xs, acc: [])
  return list.reverse(xs: reversed)
end

//
// `build_hir_with_imports` layers HIR accumulation + lazy resolution on top
// of `build_program_state`'s shared lex+parse+import-resolution stage. The
// typechecker then sees the importer's own functions plus the imported
// ones, so a type error in an imported function (called from the importer)
// surfaces as a diagnostic.

let build_hir_with_imports = fn (
  state: ProgramState,
  source_file: string
) -> HirProgram require { Console, Fs } throws { HirError } do
  let ProgramState(
    prog: _,
    defs,
    cache: _,
    accum,
    self_entries: _,
    caller_entries: _,
    all_entries
  ) = state
  let accum2 = process_defs(defs, entries: all_entries, accum, source_file, is_defining: 1)
  let raw = accum_to_program(accum: accum2)
  let HirProgram(
    caps: hp,
    functions: hf,
    externals: he,
    handler_bindings: hb,
    enum_defs: hed,
    exception_groups: heg,
    value_binding_names: hvbns,
    type_defs: htds,
    visible_enum_names: hven,
    ext_wasm_deps: hewds
  ) = raw
  let resolved = resolve_all_lazy_no_filter(funcs: hf)
    return HirProgram(caps: hp, functions: resolved, externals: he,
      handler_bindings: hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds, visible_enum_names: hven, ext_wasm_deps: hewds)
end

//
// Pipeline: lex -> parse -> import-aware HIR build -> typecheck. Each phase
// boundary is wrapped so a failure surfaces as a single file-origin
// DiagEntry instead of crashing the LSP loop. The typechecker itself
// returns either an empty list (clean) or one DiagEntry per CompileError.

/**
Compute internal diagnostics for an editor buffer: lex+parse → import-aware
HIR build → typecheck. Each `DiagEntry` carries the *originating* file path
 — a TypeMismatch inside an imported function reports the
imported file's path even though the editor only opened the importer.
Exported so tests / future LSP routing layers can inspect file identity
before the wire-format DocumentFilter.

The `parse_source` + `resolve_imports_for` split mirrors the helpers
`lsp/definition.resolve_definition` consumes through `build_program_state`
— a single Fs walk per request grounds both the typecheck and the
go-to-definition paths.
*/
/** Canonicalize a top-level let's name the same way the driver does (see
 * `extract_function_names` in src/main.nx,). `main`
 *  keeps its bare name; every other top-level let canonicalises to
 *  `<sanitised-path>#name`. Mirrors `process_top_level` in hir.nx so the
 *  typecheck allow-list matches the HIR-side qualified names.
 */
let entry_canonical_name = fn (source: string, name: string) -> string do
  if name == "main" then return "main" end
  return rdr.canonical_name(source_path: source, name)
end

let extract_entry_function_names = fn (defs: [ SpannedTopLevel ], source: string) -> [ string ] do
  match defs do
    | [] -> return []
    | SpannedTopLevel(
      node: TLLet(def: GlobalLet(name, is_public: _, typ: _, value: _)),
      span: _
    ) :: rest ->
      return entry_canonical_name(source, name) :: extract_entry_function_names(defs: rest, source)
    | _ :: rest -> return extract_entry_function_names(defs: rest, source)
  end
end

/**
Driver-scoped buffer typecheck: mirrors `nexus build`'s typecheck pass for
the MCP `typecheck` tool. Same lex+parse+import-aware HIR build as
`compute_diagnostics_for_buffer`, and (like that LSP path) restricts the
typechecker's `local_names` allow-list to the *entry file's own* top-level
lets. Both paths scope to what `nexus build <file>` would reject — otherwise
latent bugs inside unreached stdlib functions (e.g. `str.from_char`, never
called by the entry file) fire as false-positive E2001s the user cannot act
on.

Also passes `require_main: false`: the MCP surface treats the buffer as a
file-under-edit which may legitimately lack a `main` (library fragments,
WIP code). Driver `nexus build` passes `require_main: true` because it
emits an executable wasm and an entryless module is degenerate there.
*/
/** MCP-scoped buffer typecheck mirroring `nexus build`: restricts allow-list to the entry file's own lets and skips `main` requirement. */
export let compute_driver_diagnostics_for_buffer = fn (
  text: string,
  file: string
) -> [ DiagEntry ] require { Console, Fs } do
  try
    let prog = parser.parse_source(src: text)
    try
      let state = resolve_imports_for(prog, file)
      let hir_prog = build_hir_with_imports(state, source_file: file)
      let ProgramState(
        prog: _,
        defs,
        cache: _,
        accum: _,
        self_entries: _,
        caller_entries: _,
        all_entries: _
      ) = state
      let local_names = extract_entry_function_names(defs, source: file)
        return enumerate_diagnostics(
          hir: hir_prog,
          local_names,
          file,
          require_main: false,
          src: text
        )
    catch _ ->
      return [make_origin_error_diagnostic(file, message: "lsp: import resolution failed")]
    end
  catch _ ->
    return [make_origin_error_diagnostic(file, message: "lsp: failed to lex or parse source")]
  end
end

/** LSP-scoped buffer typecheck: lex+parse → import-aware HIR → typecheck scoped to the entry file's own top-level lets. `require_main:false` — library files legitimately lack `main`. */
export let compute_diagnostics_for_buffer = fn (
  text: string,
  file: string
) -> [ DiagEntry ] require { Console, Fs } do
  try
    let prog = parser.parse_source(src: text)
    try
      let state = resolve_imports_for(prog, file)
      let hir_prog = build_hir_with_imports(state, source_file: file)
      // Scope `local_names` to the buffer's *own* top-level lets — the same
      // allow-list the driver path uses (`extract_entry_function_names`).
      // Passing ALL HIR function names (incl. imported stdlib bodies) made the
      // typechecker walk unreached stdlib functions out of context, so a latent
      // mismatch inside e.g. `str.from_char` fired as a spurious E2001 into
      // `nxlib/stdlib/text/str.nx` on a clean buffer that merely `import`s
      // `std:str` and never calls that function. Confining the
      // allow-list to user code makes the LSP buffer path agree with
      // `./nexus typecheck` and `compute_driver_diagnostics_for_buffer`, while
      // genuine errors in the buffer's own definitions are still reported.
      let ProgramState(
        prog: _,
        defs,
        cache: _,
        accum: _,
        self_entries: _,
        caller_entries: _,
        all_entries: _
      ) = state
      let local_names = extract_entry_function_names(defs, source: file)
      return enumerate_diagnostics(hir: hir_prog, local_names, file, require_main: false, src: text)
    catch _ ->
      // Import resolution failure (missing file, parse error in an imported
      // module, cycle): surface as a single origin-anchored diagnostic. The
      // raw exception carries the offending path; we render it via the
      // generic format_error path inside `make_origin_error_diagnostic`.
      return [make_origin_error_diagnostic(file, message: "lsp: import resolution failed")]
    end
  catch _ ->
    return [make_origin_error_diagnostic(file, message: "lsp: failed to lex or parse source")]
  end
end

let notification_frame = fn (method: string, params: JsonValue) -> JsonValue do
  return JsonObject(fields: [
    JsonField(key: "jsonrpc", value: JsonString(val: "2.0")),
    JsonField(key: "method", value: JsonString(val: method)),
    JsonField(key: "params", value: params)
  ])
end

let make_publish_diagnostics_notification = fn (params: PublishDiagnosticsParams) -> JsonValue do
  return notification_frame(
    method: "textDocument/publishDiagnostics",
    params: publish_diagnostics_params_to_json(p: params)
  )
end

//
// Shared between on_did_open and on_did_change. Updates the document
// store, consults the per-URI version cache, and produces a
// publishDiagnostics notification. The internal DiagEntry stream may be
// empty (clean program); we still publish an empty array because LSP
// clients use that signal to clear stale markers.

/** Shared on_did_open / on_did_change pipeline: store the buffer, run/cache diagnostics for `(uri, version)`, and emit `textDocument/publishDiagnostics`.
 *
 * Arena discipline: arena mark/reset is the caller's responsibility.
 * `run_server_go` brackets each dispatch (including the call to this function)
 * with `arena.save_request_mark` / `arena.reset_to_request_mark` so that the
 * full pipeline scratch (parse tree, HIR, typecheck state, wire diagnostics,
 * notification JSON) is reclaimed after each request.  The `next_leftover`
 * allocation from `read_message_pipelined` is placed BELOW the mark, ensuring
 * the mark advances monotonically and the memoization-cache collision hazard
 * is avoided.
 */
export let publish_for_buffer = fn (
  state: ServerState,
  uri: string,
  text: string,
  version: i64
) -> HandlerResult require { Console, Fs } do
  let new_docs = documents_put(
    store: state_documents(state),
    rec: DocumentRecord(uri, text, version)
  )
  let cache = state_cache(state)
  match cache_lookup(cache, uri, version) do
    | Some(val: cached_diags) ->
      // Cache hit: same (uri, version) -> reuse stored wire diagnostics.
      let params = PublishDiagnosticsParams(
        uri,
        version: Some(val: version),
        diagnostics: cached_diags
      )
      let frame = make_publish_diagnostics_notification(params)
      return HandlerResult(
        state: with_documents(state, docs: new_docs),
        response: None,
        notifications: [ frame ]
      )
    | None ->
      let internal = compute_diagnostics_for_buffer(text, file: uri)
      let wire = to_wire_diagnostics(xs: internal)
      let new_cache = cache_put(cache, uri, version, diagnostics: wire)
      let params = PublishDiagnosticsParams(uri, version: Some(val: version), diagnostics: wire)
      let frame = make_publish_diagnostics_notification(params)
      let updated = with_cache(state: with_documents(state, docs: new_docs), cache: new_cache)
      return HandlerResult(state: updated, response: None, notifications: [ frame ])
  end
end

/** Compute diagnostics for `(text, uri)` and write the publishDiagnostics
 *  frame. Exception-airtight: every fault on the fallible diagnostics path
 *  (Fs reads, HIR build, typecheck) and the frame write is caught and logged
 *  to stderr, never propagated. This is mandatory for a spawned fiber — an
 *  exception or trap escaping a fiber after a resume aborts the whole process
 *  under wasmtime#13584 (see std:concurrency/coop). The published content is
 *  identical to `publish_for_buffer`'s cache-miss branch; only delivery is
 *  asynchronous. */
let publish_diagnostics_airtight = fn (
  uri: string,
  text: string,
  version: i64
) -> unit require { Console, Fs } do
  try
    let internal = compute_diagnostics_for_buffer(text, file: uri)
    let wire = to_wire_diagnostics(xs: internal)
    let params = PublishDiagnosticsParams(uri, version: Some(val: version), diagnostics: wire)
    let frame = make_publish_diagnostics_notification(params)
    write_message(value: frame)
    return ()
  catch _ ->
    Console.eprintln(val: "[lsp/diagnostics] spawned compute failed for " ++ uri ++ "; skipped publish")
    return ()
  end
end

/** Spawn-based variant of `publish_for_buffer` for `didOpen` / `didChange`:
 *  records the buffer text in the document store synchronously (so subsequent
 *  hover/definition/etc. see the latest content immediately), then SPAWNS a
 *  cooperative fiber that computes the buffer's diagnostics and writes the
 *  `publishDiagnostics` notification itself. The main dispatch loop returns
 *  right away (no notifications threaded back) and proceeds to read the next
 *  frame; the spawned fiber runs during the loop's idle-wait yields.
 *
 *  The spawned thunk is exception-airtight (`publish_diagnostics_airtight`) per
 *  the wasmtime#13584 constraint. The version cache is intentionally bypassed on
 *  this path: the cache is threaded through the functional `ServerState`, which
 *  a detached fiber cannot write back into, so the spawned fiber recomputes
 *  rather than memoizing. Published content is identical to the synchronous
 *  path; only the memoization is skipped.
 *
 *  Arena safety: `text` and `uri` are captured by the spawned thunk and must
 *  survive until the fiber runs. The dispatch loop (`run_server_go`) yields to
 *  the scheduler BEFORE resetting the per-request arena mark, and a diagnostics
 *  fiber has no internal `Coop.yield`, so it runs to completion in that single
 *  resume while its captures are still live; the subsequent reset then reclaims
 *  the fiber's scratch along with the rest of the request.
 *
 *  Must be called inside a `scheduler` inject (it uses `Coop` via `spawn`).
 */
export let spawn_publish_for_buffer = fn (
  state: ServerState,
  uri: string,
  text: string,
  version: i64
) -> HandlerResult require { Console, Fs, Coop } do
  let new_docs = documents_put(
    store: state_documents(state),
    rec: DocumentRecord(uri, text, version)
  )
  spawn(task: fn () -> unit require { Console, Fs } do
    return publish_diagnostics_airtight(uri, text, version)
  end)
  return HandlerResult(
    state: with_documents(state, docs: new_docs),
    response: None,
    notifications: []
  )
end
