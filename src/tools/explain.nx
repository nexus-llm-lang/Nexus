/**
 * explain/main: `nexus explain <symbol> [--file FILE]` subcommand.
 *
 * V1: one-shot CLI surface that mirrors the LSP/MCP
 * `explain` query so agents can drop the JSON-RPC bridge for the common
 * "what is this symbol?" lookup. Re-uses `src/tools/lsp/program_state` for the
 * shared lex+parse+import-resolve stage and the same DefEntry walk
 * `lsp/handlers/definition` uses to locate the symbol's def site.
 *
 * Output (text mode):
 *   <symbol>
 *     location: <file>:<line>:<col>
 *     signature: <name>(p0: T0, ...) -> Ret require { ... } throws { ... }
 *     docstring: <attached /** ... */ block, or "(none)">
 *
 * Output (--format=json):
 *   {"symbol": "...", "file": "...", "line": N, "col": N,
 *    "signature": "...", "docstring": "..." | null,
 *    "tags": {"intent":...,"invariant":...,"complexity":...,"alternatives":...,"owner":...} }
 *
 * Symbol resolution: bare top-level name in `--file` (default `main.nx`)
 * or the entry file. Cross-file qualified lookups (`alias.foo`) are out
 * of V1 scope — file follow-up `cgfd.3` if demanded.
 *
 * @intent surface structured @-tag metadata from /** */ doc blocks alongside
 * the existing symbol signature/docstring output.
 */

import { Option, Some, None } from "std:option"
import { TypeExpr, TyRow, TyUserDefined } from "src/types/type_expr.nx"
import {
  Program,
  SpannedTopLevel,
  GlobalLet,
  TLLet,
  Cap,
  TLCap,
  FunctionSig,
  SpannedExpr,
  Expr,
  ExprLambda,
  Param
} from "src/syntax/ast.nx"
import { Span } from "src/types/span.nx"
import { ProgramState, build_program_state } from "src/tools/lsp/state/program_state.nx"
import * as types from "src/typecheck/types.nx"
import { Fs }, * as fs_mod from "std:fs"
import { Console }, * as stdio from "std:stdio"
import * as str from "std:str"
import * as list from "std:list"
import { InvalidUsage }, * as err from "src/diagnostics/error.nx"
import {
  ArgSpec, SubcommandHit,
  spec_opt, spec_positional,
  parse, get_opt, get_positionals_all, is_ok, first_error,
  detect_subcommand
} from "std:argparse"

export type ExplainOutputFormat = ExplainText | ExplainJson

export type ParsedExplainSubcommand = ParsedExplainSubcommand(
  remaining: [ string ],
  is_explain: bool
)

/** Detect a leading `explain` subcommand. Thin wrapper over argparse's
 * shared `detect_subcommand` primitive. */
export let strip_explain_subcommand = fn (xs: [ string ]) -> ParsedExplainSubcommand do
  let SubcommandHit(present, remaining) = detect_subcommand(args: xs, kw: "explain")
  if present then return ParsedExplainSubcommand(remaining, is_explain: true) end
    return ParsedExplainSubcommand(remaining: xs, is_explain: false)
end

type ExplainArgs = ExplainArgs(symbol: string, file: string, format: ExplainOutputFormat)

/** Declarative spec list for `nexus explain`. */
let explain_specs = fn () -> [ ArgSpec ] do
  return [
    spec_opt(
      name: "file",
      short: "",
      long: "--file",
      required: false,
      help: "source file containing the symbol"
    ),
    spec_opt(
      name: "format",
      short: "",
      long: "--format",
      required: false,
      help: "output format (text|json)"
    ),
    spec_positional(name: "symbol", required: true, help: "symbol name to explain"),
  ]
end

// Intentional narrow row: only argparse failures escape here.
// InvalidUsage routes to main.nx exit code 2 (separate from SandboxRefusal → 3).
let parse_explain_args = fn (xs: [ string ]) -> ExplainArgs throws { InvalidUsage } do
  let result = parse(args: xs, specs: explain_specs())
  if !is_ok(result) then
    throw InvalidUsage(detail: "explain: " ++ first_error(result))
  end
  let format = match get_opt(result, name: "format") do
    | Some(val: "text") -> ExplainText
    | Some(val: "json") -> ExplainJson
    | Some(val: v) -> throw InvalidUsage(detail: "explain: invalid --format value: " ++ v)
    | None -> ExplainText
  end
  let file = match get_opt(result, name: "file") do
    | Some(val: f) -> f
    | None -> "main.nx"
  end
  let positionals = get_positionals_all(result)
  let symbol = match positionals do
    | [] -> throw InvalidUsage(detail: "explain: missing <symbol> argument")
    | s :: _ -> s
  end
  return ExplainArgs(symbol, file, format)
end

/** Structured @-tags extracted from a /** */ doc block.
 *  Each field holds the free-text value after the tag keyword, or None when
 *  the tag is absent. Multiple occurrences of the same tag use the last value.
 *  Recognised tags: @intent, @invariant, @complexity, @alternatives, @owner.
 */
export type DocTags = DocTags(
  intent: Option<string>,
  invariant: Option<string>,
  complexity: Option<string>,
  alternatives: Option<string>,
  owner: Option<string>
)

let empty_doc_tags = fn () -> DocTags do
  return DocTags(intent: None, invariant: None, complexity: None, alternatives: None, owner: None)
end

// Extract the text after `@<tag>` on a single trimmed line.
// Returns None when the line does not start with the given tag keyword.
// Strip a single leading `*` from a trimmed doc line (JavaDoc/Nexus doc style:
// each interior line often has `* text`). Leaves the remainder untrimmed so
// the caller can trim after the star strip.
let strip_leading_star = fn (s: string) -> string do
  if str.byte_length(s) == 0 then return s end
  let b = str.byte_at(s, idx: 0)
  // 42 = '*'
  if b == 42 then
    let rest_len = str.byte_length(s) - 1
    if rest_len <= 0 then return "" end
    return str.trim(s: str.byte_substring(s, start: 1, len: rest_len))
  end
  return s
end

let extract_tag_value = fn (line: string, tag: string) -> Option<string> do
  let prefix = "@" ++ tag
  // Strip leading `* ` prefix (JavaDoc/Nexus doc-block style) before matching.
  let trimmed0 = str.trim(s: line)
  let trimmed = strip_leading_star(s: trimmed0)
  if str.starts_with(s: trimmed, prefix) then
    let plen = str.byte_length(s: prefix)
    let rest_len = str.byte_length(s: trimmed) - plen
    if rest_len <= 0 then return Some(val: "") end
    let rest = str.byte_substring(s: trimmed, start: plen, len: rest_len)
    return Some(val: str.trim(s: rest))
  end
  return None
end

// Apply a single doc line to the accumulator DocTags. Keeps last-wins for dup tags.
let apply_doc_line = fn (line: string, acc: DocTags) -> DocTags do
  let DocTags(intent, invariant, complexity, alternatives, owner) = acc
  match extract_tag_value(line, tag: "intent") do
    | Some(val: v) -> return DocTags(
      intent: Some(val: v),
      invariant,
      complexity,
      alternatives,
      owner
    )
    | None -> ()
  end
  match extract_tag_value(line, tag: "invariant") do
    | Some(val: v) -> return DocTags(
      intent,
      invariant: Some(val: v),
      complexity,
      alternatives,
      owner
    )
    | None -> ()
  end
  match extract_tag_value(line, tag: "complexity") do
    | Some(val: v) -> return DocTags(
      intent,
      invariant,
      complexity: Some(val: v),
      alternatives,
      owner
    )
    | None -> ()
  end
  match extract_tag_value(line, tag: "alternatives") do
    | Some(val: v) -> return DocTags(
      intent,
      invariant,
      complexity,
      alternatives: Some(val: v),
      owner
    )
    | None -> ()
  end
  match extract_tag_value(line, tag: "owner") do
    | Some(val: v) -> return DocTags(
      intent,
      invariant,
      complexity,
      alternatives,
      owner: Some(val: v)
    )
    | None -> ()
  end
  return acc
end

let parse_doc_tags_go = fn (lines: [ string ], acc: DocTags) -> DocTags do
  match lines do
    | [] -> return acc
    | line :: rest -> return parse_doc_tags_go(lines: rest, acc: apply_doc_line(line, acc))
  end
end

/** Parse @-tags from the raw inner text of a /** */ block.
 *  Lines that do not start with a recognised @tag are ignored (they form the
 *  prose description part of the docstring). */
export let parse_doc_tags = fn (raw: string) -> DocTags do
  let lines = str.split(s: raw, sep: "\n")
  return parse_doc_tags_go(lines, acc: empty_doc_tags())
end

type DefHit = DefHit(
  name: string,
  span: Span,
  signature: string,
  docstring: Option<string>,
  tags: DocTags
)

let render_param = fn (p: Param) -> string do
  let Param(name, sigil: _, typ) = p
  return name ++ ": " ++ types.type_to_string(typ)
end

let render_params_go = fn (ps: [ Param ], acc: [ string ]) -> [ string ] do
  match ps do
    | [] -> return list.reverse(xs: acc)
    | p :: rest -> return render_params_go(ps: rest, acc: render_param(p) :: acc)
  end
end

let render_params = fn (ps: [ Param ]) -> string do
  let labels = render_params_go(ps, acc: [])
  return str.join(xs: labels, sep: ", ")
end

let collect_cap_names = fn (xs: [ TypeExpr ], acc: [ string ]) -> [ string ] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | t :: rest ->
      match t do
        | TyUserDefined(name, args: []) -> return collect_cap_names(xs: rest, acc: name :: acc)
        | _ -> return collect_cap_names(xs: rest, acc)
      end
  end
end

/** Render a row `{Console, Fs}` etc. from a TyRow into the brace-suffix form.
 *  Returns "" when the row is empty (no `require`/`throws` clause needed).
 */
let render_row = fn (row: TypeExpr, kw: string) -> string do
  match row do
    | TyRow(types: ts, rest: _) ->
      let names = collect_cap_names(xs: ts, acc: [])
      if list.is_empty(xs: names) then return "" end
      return " " ++ kw ++ " { " ++ str.join(xs: names, sep: ", ") ++ " }"
    | _ -> return ""
  end
end

/** Render a top-level lambda's signature as a single `name(...) -> Ret ...` line. */
let render_lambda_signature = fn (name: string, lam: Expr) -> string do
  match lam do
    | ExprLambda(type_params: _, params, ret_type, requires, throw_row, body: _) ->
      let ps = render_params(params)
      let ret = types.type_to_string(typ: ret_type)
      let req = render_row(row: requires, kw: "require")
      let thr = render_row(row: throw_row, kw: "throws")
      return name ++ "(" ++ ps ++ ") -> " ++ ret ++ req ++ thr
    | _ -> return name
  end
end

/** Render a non-lambda global let: `name: T` if annotated, else `name = ...`. */
let render_value_signature = fn (name: string, typ_opt: Option<TypeExpr>) -> string do
  match typ_opt do
    | Some(val: t) -> return name ++ ": " ++ types.type_to_string(typ: t)
    | None -> return name
  end
end

/** Render a Cap's signature (member functions). */
let render_function_sig_go = fn (sigs: [ FunctionSig ], acc: [ string ]) -> [ string ] do
  match sigs do
    | [] -> return list.reverse(xs: acc)
    | FunctionSig(name, params, ret_type, requires, throw_row) :: rest ->
      let ps = render_params(params)
      let ret = types.type_to_string(typ: ret_type)
      let req = render_row(row: requires, kw: "require")
      let thr = render_row(row: throw_row, kw: "throws")
      let line = "  fn " ++ name ++ "(" ++ ps ++ ") -> " ++ ret ++ req ++ thr
      return render_function_sig_go(sigs: rest, acc: line :: acc)
  end
end

let render_cap_signature = fn (name: string, cap_def: Cap) -> string do
  let Cap(name: _, is_public: _, functions) = cap_def
  let lines = render_function_sig_go(sigs: functions, acc: [])
    if list.is_empty(xs: lines) then
      return "cap " ++ name ++ " {}"
    end
    return "cap " ++ name ++ " {\n" ++ str.join(xs: lines, sep: "\n") ++ "\n}"
end

//
// V1 doc-comment harvesting: walk the source bytes backwards from the def's
// span looking for the closest preceding `*/`; if that closes a `/** ... */`
// block whose `/**` start is reachable by walking only whitespace/newlines
// between the close and the def, treat the inner content as the docstring.
// This matches the convention every Nexus stdlib file uses without
// requiring an AST-level pass.

let is_ws_byte = fn (b: char) -> bool do
  return b == 32 || b == 9 || b == 10 || b == 13
end

let scan_back_ws = fn (src: string, pos: i64) -> i64 do
  if pos <= 0 then return pos end
  let b = str.byte_at(s: src, idx: pos - 1)
  if is_ws_byte(b) then return scan_back_ws(src, pos: pos - 1) end
  return pos
end

// Walk backwards from end_pos (exclusive) looking for the slash-star-star
// sequence that opens the block whose close lies at end_pos - 2. Returns
// Some(start) where start is the byte offset of the opener, or None if the
// comment is malformed / not a doc block (open is two-star only, no third).
let scan_back_open_doc = fn (src: string, end_pos: i64, pos: i64) -> Option<i64> do
  if pos < 0 then return None end
  if pos + 3 > end_pos then return scan_back_open_doc(src, end_pos, pos: pos - 1) end
  let b0 = str.byte_at(s: src, idx: pos)
  let b1 = str.byte_at(s: src, idx: pos + 1)
  let b2 = str.byte_at(s: src, idx: pos + 2)
  if b0 == 47 && b1 == 42 && b2 == 42 then
    // Reject `/**/` shape (b3 == '/'): not a doc block.
    if pos + 3 < end_pos then
      let b3 = str.byte_at(s: src, idx: pos + 3)
      if b3 == 47 then return None end
    end
    return Some(val: pos)
  end
  return scan_back_open_doc(src, end_pos, pos: pos - 1)
end

// Trim outer whitespace; the leading-star line-prefix strip is deferred (V1).
let strip_doc_line_prefixes = fn (s: string) -> string do
  let trimmed = str.trim(s)
  return trimmed
end

let extract_preceding_docstring = fn (src: string, def_offset: i64) -> Option<string> do
  let ws_end = scan_back_ws(src, pos: def_offset)
  // Need at least `*/` (2 bytes) before the whitespace run.
  if ws_end < 2 then return None end
  let b1 = str.byte_at(s: src, idx: ws_end - 1)
  let b2 = str.byte_at(s: src, idx: ws_end - 2)
  if b2 != 42 || b1 != 47 then return None end
  let close_pos = ws_end - 2
  match scan_back_open_doc(src, end_pos: close_pos, pos: close_pos - 3) do
    | None -> return None
    | Some(val: open_pos) ->
      let inner_start = open_pos + 3
      let inner_len = close_pos - inner_start
      if inner_len <= 0 then return None end
      let raw = str.byte_substring(s: src, start: inner_start, len: inner_len)
      return Some(val: strip_doc_line_prefixes(s: raw))
  end
end

let find_def_go = fn (defs: [ SpannedTopLevel ], target: string, src: string) -> Option<DefHit> do
  match defs do
    | [] -> return None
    | SpannedTopLevel(node: TLLet(def: GlobalLet(name, is_public: _, typ, value)), span) :: rest ->
      if name == target then
        let sig = match value do | SpannedExpr(node, span: _) ->
          match node do
            | ExprLambda(
              type_params: _,
              params: _,
              ret_type: _,
              requires: _,
              throw_row: _,
              body: _
            ) ->
              render_lambda_signature(name, lam: node)
            | _ -> render_value_signature(name, typ_opt: typ)
          end
        end
        let Span(offset: off, line: _, col: _) = span
        let doc = extract_preceding_docstring(src, def_offset: off)
        let tag_data = match doc do
          | Some(val: raw) -> parse_doc_tags(raw)
          | None -> empty_doc_tags()
        end
        return Some(val: DefHit(name, span, signature: sig, docstring: doc, tags: tag_data))
      end
      return find_def_go(defs: rest, target, src)
    | SpannedTopLevel(node: TLCap(def: cap_def), span) :: rest ->
      let Cap(name, is_public: _, functions: _) = cap_def
      if name == target then
          let sig = render_cap_signature(name, cap_def)
          let Span(offset: off, line: _, col: _) = span
          let doc = extract_preceding_docstring(src, def_offset: off)
          let tag_data = match doc do
            | Some(val: raw) -> parse_doc_tags(raw)
            | None -> empty_doc_tags()
          end
          return Some(val: DefHit(name, span, signature: sig, docstring: doc, tags: tag_data))
        end
      return find_def_go(defs: rest, target, src)
    | _ :: rest -> return find_def_go(defs: rest, target, src)
  end
end

let render_tag_line = fn (label: string, opt: Option<string>) -> string do
  match opt do
    | None -> return ""
    | Some(val: v) -> return "\n  @" ++ label ++ ": " ++ v
  end
end

let render_text = fn (hit: DefHit, file: string) -> string do
  let DefHit(name, span, signature, docstring, tags) = hit
  let Span(offset: _, line, col) = span
  let doc_line = match docstring do
        | None -> "  docstring: (none)"
        | Some(val: d) -> "  docstring: " ++ d
      end
      let DocTags(intent, invariant, complexity, alternatives, owner) = tags
      let tag_lines = render_tag_line(label: "intent", opt: intent)
        ++ render_tag_line(label: "invariant", opt: invariant)
        ++ render_tag_line(label: "complexity", opt: complexity)
        ++ render_tag_line(label: "alternatives", opt: alternatives)
        ++ render_tag_line(label: "owner", opt: owner)
      return name ++ "\n"
        ++ "  location: " ++ file ++ ":" ++ str.from_i64(val: line) ++ ":" ++ str.from_i64(val: col) ++ "\n"
        ++ "  signature: " ++ signature ++ "\n"
        ++ doc_line
        ++ tag_lines
end

let escape_one_byte = fn (s: string, i: i64, b: char, acc: string) -> string do
  if b == 34 then return acc ++ "\\\"" end
  if b == 92 then return acc ++ "\\\\" end
  if b == 10 then return acc ++ "\\n" end
  if b == 13 then return acc ++ "\\r" end
  if b == 9 then return acc ++ "\\t" end
  return acc ++ str.byte_substring(s, start: i, len: 1)
end

let escape_json_str_go = fn (s: string, i: i64, n: i64, acc: string) -> string do
  if i >= n then return acc end
  let b = str.byte_at(s, idx: i)
  let next = escape_one_byte(s, i, b, acc)
  return escape_json_str_go(s, i: i + 1, n, acc: next)
end

let json_escape = fn (s: string) -> string do
  return escape_json_str_go(s, i: 0, n: str.byte_length(s), acc: "")
end

let json_opt_str_field = fn (key: string, opt: Option<string>) -> string do
  match opt do
    | None -> return "\"" ++ key ++ "\":null"
    | Some(val: v) -> return "\"" ++ key ++ "\":\"" ++ json_escape(s: v) ++ "\""
  end
end

let render_tags_json = fn (tags: DocTags) -> string do
  let DocTags(intent, invariant, complexity, alternatives, owner) = tags
  return "{"
    ++ json_opt_str_field(key: "intent", opt: intent)
    ++ "," ++ json_opt_str_field(key: "invariant", opt: invariant)
    ++ "," ++ json_opt_str_field(key: "complexity", opt: complexity)
    ++ "," ++ json_opt_str_field(key: "alternatives", opt: alternatives)
    ++ "," ++ json_opt_str_field(key: "owner", opt: owner)
    ++ "}"
end

let render_json = fn (hit: DefHit, file: string) -> string do
  let DefHit(name, span, signature, docstring, tags) = hit
  let Span(offset: _, line, col) = span
  let doc_field = match docstring do
        | None -> "\"docstring\":null"
        | Some(val: d) -> "\"docstring\":\"" ++ json_escape(s: d) ++ "\""
      end
      return "{\"symbol\":\"" ++ json_escape(s: name) ++ "\""
        ++ ",\"file\":\"" ++ json_escape(s: file) ++ "\""
        ++ ",\"line\":" ++ str.from_i64(val: line)
        ++ ",\"col\":" ++ str.from_i64(val: col)
        ++ ",\"signature\":\"" ++ json_escape(s: signature) ++ "\""
        ++ "," ++ doc_field
        ++ ",\"tags\":" ++ render_tags_json(tags)
        ++ "}"
end

let render_not_found_text = fn (symbol: string, file: string) -> string do
  return "explain: symbol '" ++ symbol ++ "' not found in " ++ file
end

let render_not_found_json = fn (symbol: string, file: string) -> string do
  return "{\"symbol\":\"" ++ json_escape(s: symbol) ++ "\""
    ++ ",\"file\":\"" ++ json_escape(s: file) ++ "\""
    ++ ",\"found\":false}"
end

/** Look up `symbol` in `file` and return the rendered explain output.
 *  Returns the rendered string ready to write to stdout. `Fs` reads the
 *  source, lex/parse runs through `build_program_state` (same path as LSP).
 */
export let run_explain = fn (
  symbol: string,
  file: string,
  format: ExplainOutputFormat
) -> string require { Console, Fs } do
  try
    let src = Fs.read_to_string(path: file)
    let ProgramState(
      prog,
      defs,
      cache: _,
      accum: _,
      self_entries: _,
      caller_entries: _,
      all_entries: _
    ) =
      build_program_state(text: src, file)
    prog
    match find_def_go(defs, target: symbol, src) do
      | None ->
        match format do
          | ExplainText -> return render_not_found_text(symbol, file)
          | ExplainJson -> return render_not_found_json(symbol, file)
        end
      | Some(val: hit) ->
        match format do
          | ExplainText -> return render_text(hit, file)
          | ExplainJson -> return render_json(hit, file)
        end
    end
  catch _ ->
    match format do
      | ExplainText -> return "explain: failed to read or parse " ++ file
      | ExplainJson -> return "{\"file\":\"" ++ json_escape(s: file) ++ "\",\"error\":\"failed to read or parse\"}"
    end
  end
end

/** CLI driver for `nexus explain <symbol> [--file FILE] [--format text|json]`.
 *  Returns the process exit code (0 on success, 1 on symbol-not-found,
 *  2 on usage error).
 */
export let run_explain_subcommand = fn (args: [ string ]) -> i64 require { PermConsole, PermFs } do
  inject stdio.system_handler, fs_mod.system_handler do
    try
      let parsed = parse_explain_args(xs: args)
      let ExplainArgs(symbol, file, format) = parsed
      let out = run_explain(symbol, file, format)
        Console.println(val: out)
        // Heuristic: not-found path emits the "not found" prefix or
        // `"found":false`. Map those to exit 1.
        if str.starts_with(s: out, prefix: "explain: symbol '") then return 1 end
        if str.index_of(s: out, sub: "\"found\":false") >= 0 then return 1 end
        return 0
    catch
      | InvalidUsage(detail: d) ->
        Console.eprintln(val: err.format_error(err: InvalidUsage(detail: d)))
        return 2
    end
  end
end
