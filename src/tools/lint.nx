/**
 * lint: `nexus lint [--check|--fix|--fix-diff] FILE [FILE...]` driver
 * wrapper for the AST-driven lint pack in src/lint/lint.nx (V1).
 *
 * Modes:
 *   default          run every lint rule, emit findings to stdout, exit 0
 *                    when no findings, exit 1 when any L-code fires.
 *   `--check`        same as default but exit 1 on any finding even when
 *                    stdout was redirected (CI-friendly; mirrors `fmt --check`).
 *   `--fix`          run AST lint rules AND the front-end pipeline (parse ->
 *                    HIR -> linearity -> typecheck), collect all fixable
 *                    diagnostics (L0001/L0002 hints + E2005/E2007 span
 *                    rewrites), apply in one pass, loop to fixpoint.
 *                    Rewrites files in place.
 *   `--fix-diff`     same analysis as `--fix` but shows a before/after diff
 *                    without modifying any files.
 *
 * Output format mirrors `format_error` in src/common/error.nx:
 *
 *   <file>:<line>:<col>: warning: <human prose> [Lxxxx]
 *     help: <fix-it suggestion>
 *
 * The fix-it line is only present when the rule supplied one. Each finding
 * is one stdout entry; multiple files separate cleanly because every line
 * is prefixed with the file path.
 *
 * Parallelism: when more than PARALLEL_THRESHOLD files are requested, the
 * analysis phase (read + tokenize + parse + lint_program) runs in parallel
 * via `lazy.force_all` / WASI threads, mirroring `test_runner.nx`'s
 * `run_all` + `build_test_thunks`.  The emit phase (Console output + exit
 * code tallying) is always sequential so output order matches input order.
 *
 * Small invocations (N <= PARALLEL_THRESHOLD, e.g. the 1-file
 * lint_check_mode_test fixture) take a sequential path that never calls
 * `lazy.force_all`, so they work in wasm contexts without `-S threads`.
 *
 * Note: `--fix` / `--fix-diff` (the heavier front-end coupling) are
 * confined to fix mode only. Plain `lint` / `--check` remain AST-only,
 * fast, and partial-program-tolerant.
 */

import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"
import * as lazy from "std:lazy"
import { Fs, FileNotFound } from "std:fs"
import { Console } from "std:stdio"
import { InvalidUsage }, * as err from "src/common/error.nx"
import {
  ArgSpec, SubcommandHit,
  spec_flag, spec_positional,
  parse, get_flag, get_positionals_all, is_ok, first_error,
  detect_subcommand
} from "std:argparse"
import * as lexer from "src/frontend/lexer.nx"
import { ParseDiagnostics }, * as parser from "src/frontend/parser.nx"
import {
  LintFinding, LintSeverity, LintWarning, LintInfo
} from "src/lint/types.nx"
import { lint_program, format_finding } from "src/lint/lint.nx"
import { apply_suppressions } from "src/lint/suppress.nx"
import {
  Fixit, apply_fixit, fixit_for_exn,
  format_check_line, format_diff_block, slice_old_text
} from "src/tools/fix.nx"
import { iterative_resolve, resolve_all_lazy_no_filter } from "src/ir/hir/demand.nx"
import * as main_wrap from "src/ir/main_wrap.nx"
import { HirProgram } from "src/ir/hir/types.nx"
import { expand_groups_in_functions, expand_groups_in_handler_bindings } from "src/ir/hir/build/accum.nx"
import * as linearity from "src/ir/shared/linearity.nx"
import * as tc from "src/typecheck/check.nx"
import * as tc_linearity from "src/typecheck/linearity.nx"
import { HirBuildResult, build_hir } from "src/pipeline.nx"
import { extract_function_names } from "src/ir/shared/resolve.nx"
import { get_defs } from "src/ir/shared/imports.nx"
import { LazyBindingUnused, LinearUnused } from "src/typecheck/errors.nx"
import { Span } from "src/common/token.nx"

/** Detection result for the `lint` subcommand. */
export type ParsedLintSubcommand = ParsedLintSubcommand(remaining: [ string ], is_lint: bool)

/** Detect a leading `lint` subcommand. Thin wrapper over argparse's shared
 *  `detect_subcommand` primitive — same shape as fmt/grep. */
export let strip_lint_subcommand = fn (xs: [ string ]) -> ParsedLintSubcommand do
  match detect_subcommand(args: xs, kw: "lint") do | SubcommandHit(present, remaining) ->
    if present then return ParsedLintSubcommand(remaining, is_lint: true) end
    return ParsedLintSubcommand(remaining: xs, is_lint: false)
  end
end

export type LintOptions = LintOptions(check_mode: bool, fix_mode: bool, fix_diff: bool, paths: [ string ])

let lint_specs = fn () -> [ ArgSpec ] do
  return [
    spec_flag(name: "check", short: "", long: "--check", help: "exit 1 if any finding (CI mode)"),
    spec_flag(name: "fix", short: "", long: "--fix", help: "apply fix-its in place (lint rules + E2005/E2007; loops to fixpoint)"),
    spec_flag(name: "fix-diff", short: "", long: "--fix-diff", help: "show before/after diff for all fix-its without writing"),
    spec_positional(name: "paths", required: false, help: "files to lint"),
  ]
end

// Intentional narrow row: only argparse failures escape here.
// InvalidUsage routes to main.nx exit code 2.
let parse_lint_options = fn (args: [ string ]) -> LintOptions throws { InvalidUsage } do
  let result = parse(args, specs: lint_specs())
  if !is_ok(result) then
    throw InvalidUsage(detail: "nexus lint: " ++ first_error(result))
  end
  let check = get_flag(result, name: "check")
  let fix = get_flag(result, name: "fix")
  let fix_diff = get_flag(result, name: "fix-diff")
  let paths = get_positionals_all(result)
  if fix && fix_diff then
    throw InvalidUsage(detail: "nexus lint: --fix and --fix-diff are mutually exclusive")
  end
  if check && (fix || fix_diff) then
    throw InvalidUsage(detail: "nexus lint: --check cannot be combined with --fix / --fix-diff")
  end
  return LintOptions(check_mode: check, fix_mode: fix, fix_diff, paths)
end

/** Per-file analysis result: the path and the findings collected from it.
 *  No Console dependency — the analysis phase reads and lints only; the
 *  emit phase (emit_results) attaches the Console cap separately.
 */
export type LintFileResult = LintFileResult(path: string, findings: [ LintFinding ])

/** Analyse one file: read, tokenize, parse (best-effort), lint.
 *  Returns LintFileResult carrying the path and findings list.
 *  No findings are emitted here — Console is not required.
 *  A missing file returns an empty findings list (the existence check
 *  mirrors lint_file's pre-read guard).
 */
let lint_collect_one = fn (path: string) -> LintFileResult require { Fs } do
  if Fs.exists(path) == false then
    return LintFileResult(path, findings: [])
  end
  let src = Fs.read_to_string(path)
  let tokens = lexer.tokenize(src)
  let ParseDiagnostics(prog, diags: _) = parser.parse_collect(tokens, file: path)
  let raw_findings = lint_program(prog)
  let findings = apply_suppressions(src, findings: raw_findings)
  return LintFileResult(path, findings)
end

/** Emit findings for one result and return the count of warning-severity
 *  findings (the `--check` gate counts only warnings, not info/notes).
 *  `LintInfo` findings (e.g. L0100 cognitive-complexity) are emitted to
 *  stdout but do NOT increment the gate counter.
 */
let emit_one_result = fn (r: LintFileResult) -> i64 require { Console } do
  let LintFileResult(path, findings) = r
  emit_findings(file: path, fs: findings)
  return count_warnings(fs: findings)
end

let count_warnings = fn (fs: [ LintFinding ]) -> i64 do
  match fs do
    | [] -> return 0
    | LintFinding(code: _, severity, message: _, fix_it: _, span: _) :: rest ->
      let this = match severity do
        | LintWarning -> 1
        | LintInfo -> 0
      end
      return this + count_warnings(fs: rest)
  end
end

/** Emit all findings across a list of results; return the total count. */
let emit_results = fn (results: [ LintFileResult ], total: i64) -> i64 require { Console } do
  match results do
    | [] -> return total
    | r :: rest ->
      let n = emit_one_result(r)
      return emit_results(results: rest, total: total + n)
  end
end

let emit_findings = fn (file: string, fs: [ LintFinding ]) -> unit require { Console } do
  match fs do
    | [] -> return ()
    | f :: rest ->
      Console.println(val: format_finding(file, f))
      return emit_findings(file, fs: rest)
  end
end

/** Sequential collect: map lint_collect_one over paths in order.
 *  Used for small invocations (N <= PARALLEL_THRESHOLD) and any wasm
 *  context without WASI threads (e.g. the lint_check_mode_test fixture).
 */
let collect_sequential = fn (paths: [ string ], acc: [ LintFileResult ]) -> [ LintFileResult ] require { Fs } do
  match paths do
    | [] -> return list.reverse(xs: acc)
    | p :: rest ->
      let r = lint_collect_one(path: p)
      return collect_sequential(paths: rest, acc: r :: acc)
  end
end

/** Parallel collect: bind each lint_collect_one call as an @LintFileResult
 *  thunk, then hand the list to lazy.force_all.  Results arrive in input
 *  order (force_all joins left-to-right), so output order is deterministic.
 *  Requires WASI threads; only called when N > PARALLEL_THRESHOLD.
 */
let collect_parallel = fn (paths: [ string ]) -> [ LintFileResult ] require { Fs } do
  let thunks = build_lint_thunks(paths, acc: [])
  return lazy.force_all(tasks: thunks)
end

let build_lint_thunks = fn (paths: [ string ], acc: [ @LintFileResult ]) -> [ @LintFileResult ] require { Fs } do
  match paths do
    | [] -> return list.reverse(xs: acc)
    | p :: rest ->
      let @t = lint_collect_one(path: p)
      return build_lint_thunks(paths: rest, acc: t :: acc)
  end
end

/** File-count threshold below which the sequential path is taken.
 *  Set to 2 so that the 1-file lint_check_mode_test fixture never
 *  reaches force_all (which requires WASI threads).  The CI gate runs
 *  over ~150 files and always takes the parallel path.
 */
let parallel_threshold = fn () -> i64 do return 2 end

//
// Fix mode: front-end pipeline runner
//
// In `--fix` / `--fix-diff` mode the lint runner must also invoke the full
// typecheck pipeline to catch E2005/E2007 diagnostics.  The logic mirrors
// src/cli/build.nx's `typecheck_for_fix` / `fix_loop` but is integrated
// here so the lint command is the single entry point for all fix-its.

let fix_max_passes = fn () -> i64 do return 32 end

/** Outcome of a single pipeline pass: did we find a fix-it or not? */
type LintFixOutcome = LintFixClean | LintFixSkipped(message: string) | LintFixFound(sp: Span, fix: Fixit)

// Run parse + HIR + linearity + typecheck, catch the first fix-able diagnostic.
let pipeline_for_fix = fn (src: string, input_path: string) -> LintFixOutcome require { Console, Fs } do
  try
    let tokens = lexer.tokenize(src)
    let ParseDiagnostics(prog, diags: _) = parser.parse_collect(tokens, file: input_path)
    let HirBuildResult(program: hir_raw, import_cache: _) = build_hir(prog, source_file: input_path, verbose: false)
    let hir_resolved = match hir_raw do
      | HirProgram(caps: hp, functions: hf, externals: he, handler_bindings: hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds, visible_enum_names: hven) ->
        let resolved = resolve_all_lazy_no_filter(funcs: hf)
        let expanded_fs = expand_groups_in_functions(funcs: resolved, groups: heg)
        let expanded_hb = expand_groups_in_handler_bindings(bindings: hb, groups: heg)
        HirProgram(caps: hp, functions: expanded_fs, externals: he, handler_bindings: expanded_hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds, visible_enum_names: hven)
    end
    let hir_wrapped = main_wrap.wrap_main_if_needed(prog: hir_resolved)
    linearity.check_program(prog: hir_wrapped)
    let local_names = main_wrap.user_main_name() :: extract_function_names(defs: get_defs(prog), source: input_path)
    let hir_checked = tc.check_program(hir: hir_wrapped, local_names, require_main: false)
    tc_linearity.check_program(prog: hir_checked)
    return LintFixClean
  catch e ->
    match e do
      | LazyBindingUnused(name: _, span: sp) ->
        match fixit_for_exn(src, err: e) do
          | Some(val: fix) -> return LintFixFound(sp, fix)
          | None -> return LintFixSkipped(message: err.format_error(err: e))
        end
      | LinearUnused(name: _, span: sp) ->
        match fixit_for_exn(src, err: e) do
          | Some(val: fix) -> return LintFixFound(sp, fix)
          | None -> return LintFixSkipped(message: err.format_error(err: e))
        end
      | _ -> return LintFixSkipped(message: err.format_error(err: e))
    end
  end
end

// Collect lint fix-its from a parsed source (AST-only, fast path).
// Returns only fixits that have a non-zero len (i.e. can be applied),
// including L0001/L0002 fixits whose spans are computed by source scanning.
let collect_lint_fixits = fn (src: string, path: string) -> [ Fixit ] do
  let tokens = lexer.tokenize(src)
  let ParseDiagnostics(prog, diags: _) = parser.parse_collect(tokens, file: path)
  let raw_findings = lint_program(prog)
  let findings = apply_suppressions(src, findings: raw_findings)
  return extract_applicable_fixits(src, findings, acc: [])
end

// Source-scanning helpers for L0001 / L0002 span enrichment.
// These live here (not in lint.nx) because they need the raw source string
// which is only available in the fix-mode driver, not the AST linter.

let lint_is_ident_ch = fn (c: char) -> bool do
  if c >= 'a' && c <= 'z' then return true end
  if c >= 'A' && c <= 'Z' then return true end
  if c >= '0' && c <= '9' then return true end
  if c == '_' then return true end
  return false
end

// Find `word` as a whole word (both adjacent bytes are non-ident) starting
// at `start`. `window` is the max bytes to scan. Returns byte offset or -1.
let find_word_in = fn (src: string, start: i64, window: i64, word: string) -> i64 do
  let n = str.byte_length(s: src)
  let m = str.byte_length(s: word)
  let scan_end = if start + window > n then n else start + window end
  return find_word_in_loop(src: src, i: start, limit: scan_end, word: word, m: m)
end

let find_word_in_loop = fn (src: string, i: i64, limit: i64, word: string, m: i64) -> i64 do
  let n = str.byte_length(s: src)
  if i + m > limit then return 0 - 1 end
  let w = str.byte_substring(s: src, start: i, len: m)
  if w == word then
    let prev_ok = if i == 0 then true else !lint_is_ident_ch(c: str.byte_at(s: src, idx: i - 1)) end
    let next_ok = if i + m >= n then true else !lint_is_ident_ch(c: str.byte_at(s: src, idx: i + m)) end
    if prev_ok && next_ok then return i end
  end
  return find_word_in_loop(src: src, i: i + 1, limit: limit, word: word, m: m)
end

// Scan backward from `i` down to `limit` for a ',' byte.
// Returns its position or -1 if not found.
let find_comma_before_loop = fn (src: string, i: i64, limit: i64) -> i64 do
  if i < limit then return 0 - 1 end
  let c = str.byte_at(s: src, idx: i)
  if c == ',' then return i end
  return find_comma_before_loop(src: src, i: i - 1, limit: limit)
end

// Enrich an L0001 fixit: the AST produced `start=0, len=0` as a placeholder.
// We scan from `span.offset` (the `inject` keyword) forward for the whole-word
// `end` that closes the empty inject body, and replace the entire
// `inject … do end` text with "" (empty replacement = delete).
// Returns None if the scan window does not find `end` (defensive).
let enrich_l0001_fixit = fn (src: string, sp: Span, fix: Fixit) -> Option<Fixit> do
  let n = str.byte_length(s: src)
  match sp do | Span(offset, line: _, col: _) ->
    let end_pos = find_word_in(src, start: offset, window: 4096, word: "end")
    if end_pos < 0 then return None end
    let real_start = offset
    let raw_len = end_pos + 3 - real_start
    // Consume a trailing newline so the removed line doesn't leave a blank.
    let real_len = if end_pos + 3 < n then
        let nc = str.byte_at(s: src, idx: end_pos + 3)
        if nc == '\n' then raw_len + 1 else raw_len end
      else raw_len end
    match fix do | Fixit(start: _, len: _, replacement: _, code, message) ->
      return Some(val: Fixit(start: real_start, len: real_len, replacement: "", code, message))
    end
  end
end

// Enrich an L0002 fixit: the AST produced `start=0, len=0, replacement=<cap_name>`.
// We scan from `span.offset` (the fn keyword) forward for the `require` clause,
// locate the cap name inside `{…}`, and compute the span to delete:
//   - single cap: delete the entire `require { Cap }` phrase (plus leading space)
//   - multi cap:  delete `Cap` plus its adjacent `, ` or ` ,` separator
// Returns None if the scan fails (defensive; caller falls back to hint-only).
let enrich_l0002_fixit = fn (src: string, sp: Span, fix: Fixit) -> Option<Fixit> do
  let n = str.byte_length(s: src)
  match fix do | Fixit(start: _, len: _, replacement: cn, code, message) ->
    let cn_len = str.byte_length(s: cn)
    if cn_len == 0 then return None end
    match sp do | Span(offset: offset, line: _, col: _) ->
      // Locate `require` keyword from the fn keyword.
      let req_pos = find_word_in(src, start: offset, window: 2048, word: "require")
      if req_pos < 0 then return None end
      // Find the opening `{` of the require row.
      let brace_open = str.find_byte(s: src, start: req_pos + 7, ch: '{')
      if brace_open < 0 then return None end
      // Find the closing `}`.
      let brace_close = str.find_byte(s: src, start: brace_open + 1, ch: '}')
      if brace_close < 0 then return None end
      // Locate the cap name inside the braces.
      let inner_window = brace_close - brace_open
      let cn_pos = find_word_in(src, start: brace_open + 1, window: inner_window, word: cn)
      if cn_pos < 0 then return None end
      // Is there a comma inside the braces (→ multi-cap row)?
      let comma_in_block = str.find_byte(s: src, start: brace_open + 1, ch: ',')
      let is_single = comma_in_block < 0 || comma_in_block >= brace_close
      if is_single then
        // Remove the entire `require { Cap }`, including one leading space.
        let rm_start = if req_pos > 0 then
            let prev = str.byte_at(s: src, idx: req_pos - 1)
            if prev == ' ' then req_pos - 1 else req_pos end
          else req_pos end
        let rm_len = brace_close + 1 - rm_start
        return Some(val: Fixit(start: rm_start, len: rm_len, replacement: "", code, message))
      else
        // Multi-cap: remove `Cap` + adjacent comma+space.
        let after_cn = cn_pos + cn_len
        // Check if comma follows cn: `cn, NextCap` pattern.
        let comma_after = if after_cn < brace_close then str.byte_at(s: src, idx: after_cn) else ' ' end
        if comma_after == ',' then
          // Remove `cn,` plus any space after the comma.
          let space_after = after_cn + 1
          let skip = if space_after < brace_close then
              let sc = str.byte_at(s: src, idx: space_after)
              if sc == ' ' then space_after + 1 else space_after end
            else space_after end
          let rm_len = skip - cn_pos
          return Some(val: Fixit(start: cn_pos, len: rm_len, replacement: "", code, message))
        else
          // Comma precedes cn: `PrevCap, cn` pattern — find the comma before cn.
          let comma_pos = find_comma_before_loop(src: src, i: cn_pos - 1, limit: brace_open + 1)
          if comma_pos < 0 then return None end
          let rm_len = cn_pos + cn_len - comma_pos
          return Some(val: Fixit(start: comma_pos, len: rm_len, replacement: "", code, message))
        end
      end
    end
  end
end

// Attempt enrichment of a zero-len fixit for L0001 or L0002.
// Returns the updated accumulator (with enriched fixit prepended if successful).
let enrich_zero_len_fixit = fn (src: string, sp: Span, fix: Fixit, acc: [ Fixit ], code: string) -> [ Fixit ] do
  if code == "L0001" then
    match enrich_l0001_fixit(src: src, sp: sp, fix: fix) do
      | Some(val: real_fix) -> return real_fix :: acc
      | None -> return acc
    end
  end
  if code == "L0002" then
    match enrich_l0002_fixit(src: src, sp: sp, fix: fix) do
      | Some(val: real_fix) -> return real_fix :: acc
      | None -> return acc
    end
  end
  return acc
end

let extract_applicable_fixits = fn (src: string, findings: [ LintFinding ], acc: [ Fixit ]) -> [ Fixit ] do
  match findings do
    | [] -> return list.reverse(xs: acc)
    | LintFinding(code: _, severity: _, message: _, fix_it, span) :: rest ->
      match fix_it do
        | None -> return extract_applicable_fixits(src, findings: rest, acc: acc)
        | Some(val: fix) ->
          match fix do | Fixit(start: _, len, replacement: _, code, message: _) ->
            let acc2 = if len > 0 then
                // Real span: apply as-is (E2005/E2007 style).
                fix :: acc
              else
                // len=0: attempt source-scan enrichment for L0001/L0002.
                enrich_zero_len_fixit(src: src, sp: span, fix: fix, acc: acc, code: code)
              end
            return extract_applicable_fixits(src, findings: rest, acc: acc2)
          end
      end
  end
end

// One fix pass on a single file: collect lint findings + pipeline diagnostics,
// apply the first applicable fixit. Returns whether something was applied.
type FixPassResult = FixPassNoChange | FixPassApplied(new_src: string, sp: Span, fix: Fixit) | FixPassPipelineError(message: string)

let run_fix_pass = fn (src: string, path: string) -> FixPassResult require { Console, Fs } do
  // First: collect lint-based fixits (AST-only).
  let lint_fixits = collect_lint_fixits(src, path)
  // Second: run the pipeline to find E2005/E2007 fixits.
  let pipeline_outcome = pipeline_for_fix(src, input_path: path)
  match pipeline_outcome do
    | LintFixClean ->
      // No pipeline diagnostic. Try lint fixits.
      match lint_fixits do
        | [] -> return FixPassNoChange
        | fix :: _ ->
          match fix do | Fixit(start: _, len: _, replacement: _, code: _, message: _) ->
            let new_src = apply_fixit(src, fix)
            let sp = Span(offset: 0, line: 1, col: 1)
            return FixPassApplied(new_src, sp, fix)
          end
      end
    | LintFixSkipped(message) ->
      // Non-fixable pipeline error. Try lint fixits or report error.
      match lint_fixits do
        | [] -> return FixPassPipelineError(message)
        | fix :: _ ->
          match fix do | Fixit(start: _, len: _, replacement: _, code: _, message: _) ->
            let new_src = apply_fixit(src, fix)
            let sp = Span(offset: 0, line: 1, col: 1)
            return FixPassApplied(new_src, sp, fix)
          end
      end
    | LintFixFound(sp, fix) ->
      // Pipeline found a fix-it. Apply it; lint fixits will be picked up next pass.
      let new_src = apply_fixit(src, fix)
      return FixPassApplied(new_src, sp, fix)
  end
end

// Fix loop for a single file: iterate until fixpoint or iteration cap.
let fix_loop_for_file = fn (path: string, src: string, fix_diff: bool, pass: i64, fixes_applied: i64) -> i64 require { Console, Fs } do
  if pass >= fix_max_passes() then
    Console.eprintln(val: "nexus lint --fix: iteration cap reached for " ++ path ++ "; remaining fix-its skipped")
    return 0
  end
  let result = run_fix_pass(src, path)
  match result do
    | FixPassNoChange ->
      return 0
    | FixPassPipelineError(message) ->
      Console.eprintln(val: message)
      if fixes_applied > 0 then return 0 end
      return 1
    | FixPassApplied(new_src, sp, fix) ->
      if fix_diff then
        let old_text = slice_old_text(src, fix)
        Console.println(val: format_diff_block(file: path, fix, old_text))
        return fix_loop_for_file(path, src: new_src, fix_diff, pass: pass + 1, fixes_applied: fixes_applied + 1)
      else
        match fix do | Fixit(start: _, len: _, replacement: _, code: _, message: _) ->
          Fs.write_string(path, content: new_src)
          Console.println(val: format_check_line(file: path, sp, fix))
        end
        return fix_loop_for_file(path, src: new_src, fix_diff, pass: pass + 1, fixes_applied: fixes_applied + 1)
      end
  end
end

// Run fix mode on a single file.
let run_fix_on_lint_file = fn (path: string, fix_diff: bool) -> i64 require { Console, Fs } do
  if Fs.exists(path) == false then
    Console.eprintln(val: "nexus lint --fix: file not found: " ++ path)
    return 1
  end
  try
    let src = Fs.read_to_string(path)
    return fix_loop_for_file(path, src, fix_diff, pass: 0, fixes_applied: 0)
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

// Run fix mode over a list of files.
let run_fix_each_file = fn (paths: [ string ], fix_diff: bool, all_ok: bool) -> i64 require { Console, Fs } do
  match paths do
    | [] ->
      if all_ok then return 0 else return 1 end
    | p :: rest ->
      let rc = run_fix_on_lint_file(path: p, fix_diff)
      let ok2 = all_ok && (rc == 0)
      return run_fix_each_file(paths: rest, fix_diff, all_ok: ok2)
  end
end

/** Execute `nexus lint`. Returns exit code:
 *   0 — no findings (both modes), or findings present without --check
 *   1 — at least one finding AND --check was passed (CI gate), OR a
 *       file-not-found / bad-usage error
 *   2 — invalid CLI usage (handled by the catch arm)
 *
 * Mode summary:
 *   default (no --check)  emit findings to stdout, exit 0 (warning-only)
 *   --check               emit findings to stdout, exit 1 if any fired (CI gate)
 *   --fix                 apply fix-its in place (lint + E2005/E2007; loops to fixpoint)
 *   --fix-diff            show before/after diff without writing
 *
 * Parallelism: analysis runs in parallel (via lazy.force_all / WASI threads)
 * when list.length(paths) > parallel_threshold(); sequential otherwise.
 * Note: --fix / --fix-diff always runs sequentially (the pipeline is heavy
 * enough that parallel overhead outweighs the benefit for fix workloads).
 */
export let run_lint_subcommand = fn (args: [ string ]) -> i64 require { Console, Fs } do
  try
    let opts = parse_lint_options(args)
    let LintOptions(check_mode, fix_mode, fix_diff, paths) = opts
    if list.is_empty(xs: paths) then
      Console.eprintln(val: "Usage: nexus lint [--check|--fix|--fix-diff] FILE [FILE...]")
      return 2
    end
    if fix_mode || fix_diff then
      return run_fix_each_file(paths, fix_diff, all_ok: true)
    end
    let n = list.length(xs: paths)
    let results = if n <= parallel_threshold() then
      collect_sequential(paths, acc: [])
    else
      collect_parallel(paths)
    end
    let total = emit_results(results, total: 0)
    if check_mode && total > 0 then return 1 else return 0 end
  catch
    | InvalidUsage(detail) ->
      Console.eprintln(val: "nexus lint: " ++ detail)
      return 2
    | FileNotFound(path) ->
      Console.eprintln(val: "nexus lint: file not found: " ++ path)
      return 1
    | _ ->
      Console.eprintln(val: "nexus lint: error")
      return 2
  end
end
