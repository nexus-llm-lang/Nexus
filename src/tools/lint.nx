/**
 * lint: `nexus lint [--check|--fix|--fix-diff] FILE [FILE...]` driver
 * wrapper for the AST-driven lint pack in src/lint/lint.nx (V1).
 *
 * Modes:
 *   default          run every lint rule, emit findings to stdout, exit 0
 *                    when no findings, exit 1 when any L-code fires.
 *   `--check`        same as default but exit 1 on any finding even when
 *                    stdout was redirected (CI-friendly; mirrors `fmt --check`).
 *   `--fix`          run AST lint rules AND the front-end pipeline (parse ->
 *                    HIR -> linearity -> typecheck), collect all fixable
 *                    diagnostics (L0001/L0002 hints + E2005/E2007 span
 *                    rewrites), apply in one pass, loop to fixpoint.
 *                    Rewrites files in place.
 *   `--fix-diff`     same analysis as `--fix` but shows a before/after diff
 *                    without modifying any files.
 *
 * Output format mirrors `format_error` in src/diagnostics/error.nx:
 *
 *   <file>:<line>:<col>: warning: <human prose> [Lxxxx]
 *     help: <fix-it suggestion>
 *
 * The fix-it line is only present when the rule supplied one. Each finding
 * is one stdout entry; multiple files separate cleanly because every line
 * is prefixed with the file path.
 *
 * Parallelism: when more than PARALLEL_THRESHOLD files are requested, the
 * analysis phase (read + tokenize + parse + lint_program) runs in parallel
 * via `lazy.force_all` / WASI threads, mirroring `test_runner.nx`'s
 * `run_all` + `build_test_thunks`.  The emit phase (Console output + exit
 * code tallying) is always sequential so output order matches input order.
 *
 * Small invocations (N <= PARALLEL_THRESHOLD, e.g. the 1-file
 * lint_check_mode_test fixture) take a sequential path that never calls
 * `lazy.force_all`, so they work in wasm contexts without `-S threads`.
 *
 * Note: `--fix` / `--fix-diff` (the heavier front-end coupling) are
 * confined to fix mode only. Plain `lint` / `--check` remain AST-only,
 * fast, and partial-program-tolerant.
 */

import * as list from "std:list"
import * as lazy from "std:lazy"
import * as str from "std:str"
import { Fs, FileNotFound } from "std:fs"
import { Console } from "std:stdio"
import { InvalidUsage } from "src/diagnostics/error.nx"
import {
  ArgSpec, SubcommandHit,
  spec_flag, spec_positional,
  parse, get_flag, get_positionals_all, is_ok, first_error,
  detect_subcommand
} from "std:argparse"
import * as lexer from "src/frontend/lexer.nx"
import { ParseDiagnostics }, * as parser from "src/frontend/parser.nx"
import { LintFinding, LintSeverity, LintWarning, LintInfo, LintError } from "src/lint/types.nx"
import { lint_program, format_finding } from "src/lint/lint.nx"
import { apply_suppressions } from "src/lint/suppress.nx"
import { lint_design_authority } from "src/lint/rules/design_authority.nx"
import { run_fix_each_file } from "src/lint/fix.nx"

/** Detection result for the `lint` subcommand. */
export type ParsedLintSubcommand = ParsedLintSubcommand(remaining: [ string ], is_lint: bool)

/** Detect a leading `lint` subcommand. Thin wrapper over argparse's shared
 *  `detect_subcommand` primitive — same shape as fmt/grep. */
export let strip_lint_subcommand = fn (xs: [ string ]) -> ParsedLintSubcommand do
  let SubcommandHit(present, remaining) = detect_subcommand(args: xs, kw: "lint")
  if present then return ParsedLintSubcommand(remaining, is_lint: true) end
    return ParsedLintSubcommand(remaining: xs, is_lint: false)
end

export type LintOptions = LintOptions(
  check_mode: bool,
  fix_mode: bool,
  fix_diff: bool,
  paths: [ string ]
)

let lint_specs = fn () -> [ ArgSpec ] do
  return [
    spec_flag(name: "check", short: "", long: "--check", help: "exit 1 if any finding (CI mode)"),
    spec_flag(
      name: "fix",
      short: "",
      long: "--fix",
      help: "apply fix-its in place (lint rules + E2005/E2007; loops to fixpoint)"
    ),
    spec_flag(
      name: "fix-diff",
      short: "",
      long: "--fix-diff",
      help: "show before/after diff for all fix-its without writing"
    ),
    spec_positional(name: "paths", required: false, help: "files to lint"),
  ]
end

// Intentional narrow row: only argparse failures escape here.
// InvalidUsage routes to main.nx exit code 2.
let parse_lint_options = fn (args: [ string ]) -> LintOptions throws { InvalidUsage } do
  let result = parse(args, specs: lint_specs())
  if !is_ok(result) then
    throw InvalidUsage(detail: "nexus lint: " ++ first_error(result))
  end
  let check = get_flag(result, name: "check")
  let fix = get_flag(result, name: "fix")
  let fix_diff = get_flag(result, name: "fix-diff")
  let paths = get_positionals_all(result)
  if fix && fix_diff then
    throw InvalidUsage(detail: "nexus lint: --fix and --fix-diff are mutually exclusive")
  end
  if check && (fix || fix_diff) then
    throw InvalidUsage(detail: "nexus lint: --check cannot be combined with --fix / --fix-diff")
  end
  return LintOptions(check_mode: check, fix_mode: fix, fix_diff, paths)
end

/** Per-file analysis result: the path and the findings collected from it.
 *  No Console dependency — the analysis phase reads and lints only; the
 *  emit phase (emit_results) attaches the Console cap separately.
 */
export type LintFileResult = LintFileResult(path: string, findings: [ LintFinding ])

/** Analyse one file: read, tokenize, parse (best-effort), lint.
 *  Returns LintFileResult carrying the path and findings list.
 *  No findings are emitted here — Console is not required.
 *  A missing file returns an empty findings list (the existence check
 *  mirrors lint_file's pre-read guard).
 */
let lint_collect_one = fn (path: string) -> LintFileResult require { Fs } do
  if Fs.exists(path) == false then
    return LintFileResult(path, findings: [])
  end
  let src = Fs.read_to_string(path)
  let tokens = lexer.tokenize(src)
  let ParseDiagnostics(prog, diags: _) = parser.parse_collect(tokens, file: path)
  let ast_findings = lint_program(prog)
  let src_findings = lint_design_authority(src)
  let raw_findings = list.concat(xs: ast_findings, ys: src_findings)
  let findings = apply_suppressions(src, findings: raw_findings)
  return LintFileResult(path, findings)
end

/** Emit findings for one result and return the count of warning-severity
 *  findings (the `--check` gate counts only warnings, not info/notes).
 *  `LintInfo` findings (e.g. L0100 cognitive-complexity) are emitted to
 *  stdout but do NOT increment the gate counter.
 */
let emit_one_result = fn (r: LintFileResult) -> i64 require { Console } do
  let LintFileResult(path, findings) = r
  emit_findings(file: path, fs: findings)
  return count_warnings(fs: findings)
end

let count_warnings = fn (fs: [ LintFinding ]) -> i64 do
  match fs do
    | [] -> return 0
    | LintFinding(code: _, severity, message: _, fix_it: _, span: _) :: rest ->
      let this = match severity do
        | LintWarning -> 1
        | LintInfo -> 0
        | LintError -> 1
      end
      return this + count_warnings(fs: rest)
  end
end

/** Emit all findings across a list of results; return the total count. */
let emit_results = fn (results: [ LintFileResult ], total: i64) -> i64 require { Console } do
  match results do
    | [] -> return total
    | r :: rest ->
      let n = emit_one_result(r)
      return emit_results(results: rest, total: total + n)
  end
end

let emit_findings = fn (file: string, fs: [ LintFinding ]) -> unit require { Console } do
  match fs do
    | [] -> return ()
    | f :: rest ->
      Console.println(val: format_finding(file, f))
      return emit_findings(file, fs: rest)
  end
end

/** Sequential collect: map lint_collect_one over paths in order.
 *  Used for small invocations (N <= PARALLEL_THRESHOLD) and any wasm
 *  context without WASI threads (e.g. the lint_check_mode_test fixture).
 */
let collect_sequential = fn (
  paths: [ string ],
  acc: [ LintFileResult ]
) -> [ LintFileResult ] require { Fs } do
  match paths do
    | [] -> return list.reverse(xs: acc)
    | p :: rest ->
      let r = lint_collect_one(path: p)
      return collect_sequential(paths: rest, acc: r :: acc)
  end
end

/** Parallel collect: bind each lint_collect_one call as an @LintFileResult
 *  thunk, then hand the list to lazy.force_all.  Results arrive in input
 *  order (force_all joins left-to-right), so output order is deterministic.
 *  Requires WASI threads; only called when N > PARALLEL_THRESHOLD.
 */
let collect_parallel = fn (paths: [ string ]) -> [ LintFileResult ] require { Fs } do
  let thunks = build_lint_thunks(paths, acc: [])
  return lazy.force_all(tasks: thunks)
end

let build_lint_thunks = fn (
  paths: [ string ],
  acc: [ @(LintFileResult require { Fs }) ]
) -> [ @(LintFileResult require { Fs }) ] require { Fs } do
  match paths do
    | [] -> return list.reverse(xs: acc)
    | p :: rest ->
      let @t = lint_collect_one(path: p)
      return build_lint_thunks(paths: rest, acc: t :: acc)
  end
end

/** File-count threshold below which the sequential path is taken.
 *  Set to 2 so that the 1-file lint_check_mode_test fixture never
 *  reaches force_all (which requires WASI threads).  The CI gate runs
 *  over ~150 files and always takes the parallel path.
 */
let parallel_threshold = fn () -> i64 do return 2 end

//
// Argument resolution: positional args may be files or directories. A
// directory is walked recursively, collecting every `*.nx` file outside the
// hardcoded ignore set (mirrors `nexus fmt` / `nexus test` discovery). Files
// passed directly pass through verbatim (extension not enforced — preserves
// the single-file contract `lint_check_mode_test` relies on). Without this
// expansion a directory path reached `lint_collect_one`, read as empty, and
// silently exited 0 — defeating the advertised `nexus lint --check src/` CI
// gate.

// Directory basenames that are never descended into. Hidden dotfiles are
// caught by the dot-prefix check; this list covers VCS / build scratch dirs
// that don't start with a dot. Same set as `nexus fmt`.
let is_ignored_dirname = fn (name: string) -> bool do
  if str.starts_with(s: name, prefix: ".") then return true end
  if name == "target" then return true end
  if name == "build" then return true end
  if name == "node_modules" then return true end
  return false
end

let has_nx_suffix = fn (name: string) -> bool do
  return str.ends_with(s: name, suffix: ".nx")
end

let strip_trailing_slash = fn (s: string) -> string do
  let n = str.length(s)
  if n == 0 then return s end
  if str.ends_with(s, suffix: "/") then
    return str.substring(s, start: 0, len: n - 1)
  end
  return s
end

// Intentional narrow row for the directory-walk cluster below
// (walk_for_nx / walk_for_nx_entries / visit_lint_entry / expand_lint_input /
//  collect_lint_inputs / collect_lint_inputs_go): only FileNotFound can escape
// from Fs operations at this layer. ArgParse faults are resolved earlier.
let walk_for_nx = fn (
  path: string,
  acc: [ string ]
) -> [ string ] require { Fs } throws { FileNotFound } do
  let names = Fs.list_dir(path)
  return walk_for_nx_entries(names, dir: path, acc)
end

let walk_for_nx_entries = fn (
  names: [ string ],
  dir: string,
  acc: [ string ]
) -> [ string ] require { Fs } throws { FileNotFound } do
  match names do
    | [] -> return acc
    | name :: rest ->
      let full = dir ++ "/" ++ name
      let acc2 = visit_lint_entry(path: full, name, acc)
      return walk_for_nx_entries(names: rest, dir, acc: acc2)
  end
end

let visit_lint_entry = fn (
  path: string,
  name: string,
  acc: [ string ]
) -> [ string ] require { Fs } throws { FileNotFound } do
  if Fs.is_file(path) then
    // Skip non-`.nx` files inside walked directories. Direct file arguments
    // bypass this filter — see `expand_lint_input`.
    if has_nx_suffix(name) then
      return path :: acc
    end
    return acc
  end
  // Directory: honor the ignore list before recursing.
  if is_ignored_dirname(name) then return acc end
  return walk_for_nx(path, acc)
end

// Resolve one CLI positional. Files pass through as-is (extension not checked
// here so `nexus lint myfile` keeps working). Directories expand to every
// `*.nx` descendant.
let expand_lint_input = fn (
  path: string,
  acc: [ string ]
) -> [ string ] require { Fs } throws { FileNotFound } do
  if Fs.exists(path) == false then
    // Keep the path so `lint_collect_one` handles a missing file the same way
    // as before (its existence guard returns no findings → exit 0), preserving
    // the v1 single-file behaviour for typo'd args.
    return path :: acc
  end
  if Fs.is_file(path) then
    return path :: acc
  end
  // Directory entry-point: caller may pass `src/` or `src` — normalize.
  return walk_for_nx(path: strip_trailing_slash(s: path), acc)
end

/** Expand each positional arg, accumulating `*.nx` files for directories and
 *  passing files through unchanged. The order of files within a single dir is
 *  unspecified (depends on `Fs.list_dir` iteration order). */
export let collect_lint_inputs = fn (paths: [ string ]) -> [ string ] require {
  Fs
} throws { FileNotFound } do
  let acc = collect_lint_inputs_go(paths, acc: [])
  return list.reverse(xs: acc)
end

let collect_lint_inputs_go = fn (
  paths: [ string ],
  acc: [ string ]
) -> [ string ] require { Fs } throws { FileNotFound } do
  match paths do
    | [] -> return acc
    | p :: rest ->
      let acc2 = expand_lint_input(path: p, acc)
      return collect_lint_inputs_go(paths: rest, acc: acc2)
  end
end

/** Execute `nexus lint`. Returns exit code:
 *   0 — no findings (both modes), or findings present without --check
 *   1 — at least one finding AND --check was passed (CI gate), OR a
 *       file-not-found / bad-usage error
 *   2 — invalid CLI usage (handled by the catch arm)
 *
 * Mode summary:
 *   default (no --check)  emit findings to stdout, exit 0 (warning-only)
 *   --check               emit findings to stdout, exit 1 if any fired (CI gate)
 *   --fix                 apply fix-its in place (lint + E2005/E2007; loops to fixpoint)
 *   --fix-diff            show before/after diff without writing
 *
 * Parallelism: analysis runs in parallel (via lazy.force_all / WASI threads)
 * when list.length(paths) > parallel_threshold(); sequential otherwise.
 * Note: --fix / --fix-diff always runs sequentially (the pipeline is heavy
 * enough that parallel overhead outweighs the benefit for fix workloads).
 */
export let run_lint_subcommand = fn (args: [ string ]) -> i64 require { Console, Fs } do
  try
    let opts = parse_lint_options(args)
    let LintOptions(check_mode, fix_mode, fix_diff, paths) = opts
    if list.is_empty(xs: paths) then
      Console.eprintln(val: "Usage: nexus lint [--check|--fix|--fix-diff] FILE [FILE...]")
      return 2
    end
    if fix_mode || fix_diff then
      return run_fix_each_file(paths, fix_diff, all_ok: true)
    end
    // Directory args expand to every `*.nx` descendant (ignoring `.git`,
    // `target`, `build`, `node_modules`, and any dot-prefixed dir), mirroring
    // `nexus fmt`. File args pass through verbatim. This makes the advertised
    // `nexus lint --check src/` CI gate (specs.nx) actually scan the tree
    // instead of silently exiting 0 on a directory.
    let expanded = collect_lint_inputs(paths)
    let n = list.length(xs: expanded)
    let results = if n <= parallel_threshold() then
      collect_sequential(paths: expanded, acc: [])
    else
      collect_parallel(paths: expanded)
    end
    let total = emit_results(results, total: 0)
    if check_mode && total > 0 then return 1 else return 0 end
  catch
    | InvalidUsage(detail) ->
      Console.eprintln(val: "nexus lint: " ++ detail)
      return 2
    | FileNotFound(path) ->
      Console.eprintln(val: "nexus lint: file not found: " ++ path)
      return 1
    | _ ->
      Console.eprintln(val: "nexus lint: error")
      return 2
  end
end
