/**
 * grep: structural AST search for `nexus grep <pattern> [path...]`.
 *
 * Issue V1. Pattern syntax (MVP scope; full ast-grep DSL deferred):
 *
 *   let $NAME       — match any top-level `let` binding by NAME. `$NAME`
 *                     may be a literal identifier or a meta-var `$x`/`$_`.
 *   fn $NAME        — same coverage as `let $NAME` in V1 (the lambda-shape
 *                     guard hits a seed-compiler bug, deferred).
 *   call $NAME      — V1: parsed but recognises no matches yet (recursive
 *                     expression walker miscompiles under the seed; see
 *                     commit-message note).
 *   var $NAME       — V1: same status as `call`.
 *   <bareword>      — shorthand for `call <bareword>`.
 *
 * Output format:
 *
 *   <file>:<line>:<col>  <source-line>
 *
 * Deferred to V2 :
 *   - structural call/var matching once the seed is regenerated past the
 *     handler-dispatch fix
 *   - kind constraints `$f:fncall name=...`, nested patterns
 *   - `--captures`, `--rewrite`, `--json`, persistent rule files
 */

import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"
import { Fs, FileNotFound } from "std:fs"
import { Console } from "std:stdio"
import { InvalidUsage } from "src/common/error.nx"
import {
  ArgSpec, SubcommandHit,
  spec_positional,
  parse, get_positionals_all, is_ok, first_error,
  detect_subcommand
} from "std:argparse"
import { Span } from "src/common/token.nx"
import * as lexer from "src/frontend/lexer.nx"
import { ParseDiagnostics }, * as parser from "src/frontend/parser.nx"
import {
  Program, SpannedTopLevel, TopLevel, TLLet, GlobalLet,
  SpannedExpr
} from "src/common/ast.nx"


export type ParsedGrepSubcommand = ParsedGrepSubcommand(remaining: [string], is_grep: bool)

/** Detect a leading `grep` subcommand. Thin wrapper over argparse's
 * shared `detect_subcommand` primitive. */
export let strip_grep_subcommand = fn (xs: [string]) -> ParsedGrepSubcommand do
  match detect_subcommand(args: xs, kw: "grep") do | SubcommandHit(present, remaining) ->
    if present then return ParsedGrepSubcommand(remaining, is_grep: true) end
    return ParsedGrepSubcommand(remaining: xs, is_grep: false)
  end
end


export type NameSel =
  NameLit(name: string)
  | NameAny

export type Pat =
  PatLet(name: NameSel)
  | PatFn(name: NameSel)
  | PatCall(name: NameSel)
  | PatVar(name: NameSel)

let parse_name_sel = fn (tok: string) -> NameSel do
  if str.starts_with(s: tok, prefix: "$") then return NameAny end
  return NameLit(name: tok)
end

let drop_empties = fn (xs: [string], acc: [string]) -> [string] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | head :: rest ->
      if str.length(s: head) == 0 then return drop_empties(xs: rest, acc) end
      return drop_empties(xs: rest, acc: head :: acc)
  end
end

/** Parse a pattern source string.
 *  Intentional narrow row: only well-formedness failures on the user-supplied
 *  pattern string can occur; no I/O. InvalidUsage routes to main.nx exit 2.
 */
export let parse_pattern = fn (src: string) -> Pat throws { InvalidUsage } do
  let trimmed = str.trim(s: src)
  if str.length(s: trimmed) == 0 then
    throw InvalidUsage(detail: "nexus grep: empty pattern")
  end
  let parts = str.split(s: trimmed, sep: " ")
  let cleaned = drop_empties(xs: parts, acc: [])
  match cleaned do
    | [] -> throw InvalidUsage(detail: "nexus grep: empty pattern")
    | one :: [] -> return PatCall(name: parse_name_sel(tok: one))
    | kw :: rest ->
      match rest do
        | nm :: [] ->
          let sel = parse_name_sel(tok: nm)
          if kw == "let" then return PatLet(name: sel) end
          if kw == "fn" then return PatFn(name: sel) end
          if kw == "call" then return PatCall(name: sel) end
          if kw == "var" then return PatVar(name: sel) end
          throw InvalidUsage(detail: "nexus grep: unknown pattern kind '" ++ kw ++ "' (expected let/fn/call/var)")
        | _ -> throw InvalidUsage(detail: "nexus grep: pattern takes one argument after kind")
      end
  end
end


let rdr_name_str = fn (n: RdrName) -> string do
  match n do
    | Unqual(name) -> return name
    | Qual(alias, name) -> return alias ++ "." ++ name
  end
end

let name_matches = fn (sel: NameSel, candidate: string) -> bool do
  match sel do
    | NameAny -> return true
    | NameLit(name) -> return name == candidate
  end
end


export type GrepHit = GrepHit(file: string, span: Span, snippet: string)


let clamp_offset = fn (offset: i64, n: i64) -> i64 do
  if offset < 0 then return 0 end
  if offset >= n then return n - 1 end
  return offset
end

let scan_back_to_newline = fn (src: string, i: i64) -> i64 do
  if i <= 0 then return 0 end
  let prev = i - 1
  let ch = str.byte_at(s: src, idx: prev)
  if ch == '\n' then return i end
  return scan_back_to_newline(src, i: prev)
end

let find_line_end = fn (src: string, off: i64, n: i64) -> i64 do
  if off >= n then return n end
  let ch = str.byte_at(s: src, idx: off)
  if ch == '\n' then return off end
  return find_line_end(src, off: off + 1, n)
end

let cap_snippet = fn (text: string, max_len: i64) -> string do
  let n = str.byte_length(s: text)
  if n <= max_len then return text end
  return str.byte_substring(s: text, start: 0, len: max_len) ++ "..."
end

let line_snippet = fn (src: string, span: Span) -> string do
  match span do | Span(offset, line: _, col: _) ->
    let n = str.byte_length(s: src)
    if n == 0 then return "" end
    let off = clamp_offset(offset, n)
    let ls = scan_back_to_newline(src, i: off)
    let le = find_line_end(src, off, n)
    let raw = str.byte_substring(s: src, start: ls, len: le - ls)
    return cap_snippet(text: str.trim(s: raw), max_len: 120)
  end
end

//
// V1 walks `Program.top_levels` and emits a hit when the binding name
// matches a `let $NAME` / `fn $NAME` pattern. The recursive expression
// walker that V2 needs to support `call $NAME` / `var $NAME` triggers a
// codegen bug in the committed seed nexus.wasm (handler-dispatch index
// gets off-by-one, surfacing as the string `system_handler_ead_to_string`
// instead of `system_handler_read_to_string`). Re-enabling it requires a
// regenerated seed — left as V2 follow-up.

let stmtlet_hit = fn (name: string, value: SpannedExpr, pat: Pat, span: Span, file: string, src: string, acc: [GrepHit]) -> [GrepHit] do
  match pat do
    | PatLet(name: sel) ->
      let _ = value
      if name_matches(sel: sel, candidate: name) then
        return GrepHit(file: file, span: span, snippet: line_snippet(src: src, span: span)) :: acc
      end
      return acc
    | PatFn(name: sel) ->
      // V1: treat PatFn like PatLet (no lambda-shape gate). The
      // is_lambda check on `value` triggers a seed-compiler bug
      // (handler-dispatch corruption — see bd notes).
      // Deferring strict fn-only matching to V2.
      let _ = value
      if name_matches(sel: sel, candidate: name) then
        return GrepHit(file: file, span: span, snippet: line_snippet(src: src, span: span)) :: acc
      end
      return acc
    | _ -> return acc
  end
end




let match_in_top = fn (xs: [SpannedTopLevel], pat: Pat, file: string, src: string, acc: [GrepHit]) -> [GrepHit] do
  match xs do
    | [] -> return acc
    | tl :: rest ->
      let acc2 = match tl do | SpannedTopLevel(node, span) ->
        match node do
          | TLLet(def) ->
            match def do | GlobalLet(name, is_public: _, typ: _, value) ->
              stmtlet_hit(name: name, value: value, pat: pat, span: span, file: file, src: src, acc: acc)
            end
          | _ -> acc
        end
      end
      return match_in_top(xs: rest, pat: pat, file: file, src: src, acc: acc2)
  end
end



/** Find all hits in a single source string. V1 supports the structural
 *  let / fn patterns (top-level binding name match). Call / Var patterns
 *  return an empty list in V1 — see commit-message note on a seed-compiler
 *  bug that prevents the deeply-recursive expression walker from compiling
 *  cleanly until the seed nexus.wasm is regenerated.
 */
export let find_hits = fn (pat: Pat, file: string, src: string) -> [GrepHit] do
  let tokens = lexer.tokenize(src: src)
  let ParseDiagnostics(prog, diags: _) = parser.parse_collect(tokens: tokens, file: file)
  match prog do | Program(definitions, module_doc: _) ->
    let rev = match_in_top(xs: definitions, pat: pat, file: file, src: src, acc: [])
    return list.reverse(xs: rev)
  end
end


let emit_hits = fn (hits: [GrepHit]) -> unit require { Console } do
  match hits do
    | [] -> return ()
    | GrepHit(file, span, snippet) :: rest ->
      match span do | Span(offset: _, line, col) ->
        let l = str.from_i64(val: line)
        let c = str.from_i64(val: col)
        Console.println(val: file ++ ":" ++ l ++ ":" ++ c ++ "  " ++ snippet)
      end
      return emit_hits(hits: rest)
  end
end


let is_ignored_dirname = fn (name: string) -> bool do
  if str.starts_with(s: name, prefix: ".") then return true end
  if name == "target" then return true end
  if name == "build" then return true end
  if name == "node_modules" then return true end
  return false
end

let strip_trailing_slash = fn (path: string) -> string do
  let n = str.length(s: path)
  if n == 0 then return path end
  if str.ends_with(s: path, suffix: "/") then
    return str.substring(s: path, start: 0, len: n - 1)
  end
  return path
end

// Intentional narrow row for the directory-walk cluster below
// (walk_dir_entries / visit_entry / expand_one / expand_inputs /
//  grep_file / grep_files): the only fault that can escape is
// FileNotFound from Fs operations. There are no argparse or
// allocation faults at this layer — keeping the row tight isolates
// I/O errors so callers handle exactly one exception kind.
let walk_dir_entries = fn (names: [string], dir: string, acc: [string]) -> [string] require { Fs } throws { FileNotFound } do
  match names do
    | [] -> return acc
    | name :: rest ->
      let full = dir ++ "/" ++ name
      let acc2 = visit_entry(path: full, name, acc)
      return walk_dir_entries(names: rest, dir, acc: acc2)
  end
end

let visit_entry = fn (path: string, name: string, acc: [string]) -> [string] require { Fs } throws { FileNotFound } do
  if Fs.is_file(path) then
    if str.ends_with(s: name, suffix: ".nx") then return path :: acc end
    return acc
  end
  if is_ignored_dirname(name) then return acc end
  let names = Fs.list_dir(path)
  return walk_dir_entries(names, dir: path, acc)
end

let expand_one = fn (path: string, acc: [string]) -> [string] require { Console, Fs } throws { FileNotFound } do
  if Fs.exists(path) == false then
    Console.eprintln(val: "nexus grep: not found: " ++ path)
    return acc
  end
  if Fs.is_file(path) then return path :: acc end
  let p2 = strip_trailing_slash(path)
  let names = Fs.list_dir(path: p2)
  return walk_dir_entries(names, dir: p2, acc)
end

let expand_inputs = fn (paths: [string], acc: [string]) -> [string] require { Console, Fs } throws { FileNotFound } do
  match paths do
    | [] -> return list.reverse(xs: acc)
    | p :: rest ->
      let acc2 = expand_one(path: p, acc)
      return expand_inputs(paths: rest, acc: acc2)
  end
end

let grep_file = fn (file: string, pat: Pat) -> i64 require { Console, Fs } throws { FileNotFound } do
  let contents = Fs.read_to_string(path: file)
  let hits = find_hits(pat: pat, file: file, src: contents)
  emit_hits(hits)
  return list.length(xs: hits)
end

let grep_files = fn (files: [string], pat: Pat, total: i64) -> i64 require { Console, Fs } throws { FileNotFound } do
  match files do
    | [] -> return total
    | f :: rest ->
      let n = grep_file(file: f, pat)
      return grep_files(files: rest, pat, total: total + n)
  end
end


export type GrepArgs = GrepArgs(pattern: string, paths: [string])

// Intentional narrow row: argparse only; no I/O at this point.
// InvalidUsage routes to main.nx exit code 2.
let parse_grep_args = fn (xs: [string]) -> GrepArgs throws { InvalidUsage } do
  match xs do
    | [] -> throw InvalidUsage(detail: "usage: nexus grep <pattern> [path...]")
    | pat :: rest ->
      let paths = match rest do
        | [] -> ["."]
        | _ -> rest
      end
      return GrepArgs(pattern: pat, paths)
  end
end

export let run_grep_subcommand = fn (args: [string]) -> i64 require { Console, Fs } do
  try
    let parsed = parse_grep_args(xs: args)
    match parsed do | GrepArgs(pattern, paths) ->
      let pat = parse_pattern(src: pattern)
      let files = expand_inputs(paths, acc: [])
      let total = grep_files(files, pat, total: 0)
      if total > 0 then return 0 else return 1 end
    end
  catch e ->
    match e do
      | InvalidUsage(detail) ->
        Console.eprintln(val: "nexus grep: " ++ detail)
        return 2
      | FileNotFound(path) ->
        Console.eprintln(val: "nexus grep: file not found: " ++ path)
        return 2
      | _ ->
        Console.eprintln(val: "nexus grep: error")
        return 2
    end
  end
end
