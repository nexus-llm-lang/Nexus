/**
 * ast_dump: machine-readable AST dump for `nexus ast <file>`.
 *
 * Issue. One subcommand:
 *   - `nexus ast <file> [--format=text|json]` — parses to AST (pre-typecheck,
 *     pre-HIR) and prints it. Mirrors the V1 envelope shipped by ir_dump
 *     (`{kind: "ast", top_levels: [...]}`).
 *
 * The AST carries Spanned* wrappers and RdrName (scope-unresolved names) that
 * HIR has already collapsed; this dump is the right surface for agents that
 * want pre-resolution source positions or to study the raw pattern algebra.
 *
 * Every node has `{kind, span?, ...flat_fields, children: [...]}`. Sub-nodes
 * recurse through `children`; leaf data (names, literal values) is flat.
 *
 * Implementation is split across submodules:
 *   - src/tools/ast_dump/pattern.nx — pattern_to_json / pat_to_lines
 *   - src/tools/ast_dump/type.nx    — type_to_json / named_types_to_json
 *   - src/tools/ast_dump/expr.nx    — expr_to_json + stmt_to_json (mutually recursive)
 *   - src/tools/ast_dump/decl.nx    — top_level_to_json / top_level_to_lines
 */

import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"
import * as bb from "std:bytebuffer"
import { SubcommandHit, detect_subcommand } from "std:argparse"
import {
  JsonValue,
  JsonString,
  JsonArray,
  JsonObject,
  JsonField,
  JsonThrow
}, * as json from "std:json"
import {
  Sigil,
  SigilImmutable,
  SigilMutable,
  SigilLinear,
  SigilBorrow,
  SigilLazy
} from "src/types/vocab.nx"
import { Program, SpannedTopLevel } from "src/syntax/ast.nx"
import { top_levels_to_json, top_levels_to_lines_go } from "src/tools/dump/ast_dump/decl.nx"

export type ParsedAstSubcommand = ParsedAstSubcommand(remaining: [ string ], is_ast: bool)

/** Detect a leading `ast` subcommand. Thin wrapper over argparse's
 * shared `detect_subcommand` primitive. */
export let strip_ast_subcommand = fn (xs: [ string ]) -> ParsedAstSubcommand do
  let SubcommandHit(present, remaining) = detect_subcommand(args: xs, kw: "ast")
  if present then return ParsedAstSubcommand(remaining, is_ast: true) end
    return ParsedAstSubcommand(remaining: xs, is_ast: false)
end

/** Append the lines into `buf`, separating each with "\n" (no trailing
 * separator) — the byte-faithful, linear-time equivalent of
 * `str.join(lines, "\n")`. Pushing into a ByteBuffer keeps each step amortized
 * O(|line|) instead of the O(n^2) of repeated `acc ++ v ++ sep`. */
let join_lines_into = fn (buf: %ByteBuffer, xs: [ string ]) -> %ByteBuffer do
  match xs do
    | [] -> return buf
    | v :: rest ->
      let %buf2 = bb.push_string(%buf, s: v)
      match rest do
        | [] -> return %buf2
        | _ :: _ ->
          let %buf3 = bb.push_string(%buf2, s: "\n")
          return join_lines_into(buf: %buf3, xs: rest)
      end
  end
end

export let ast_to_json = fn (prog: Program) -> string throws { JsonThrow } do
  let Program(definitions, module_doc) = prog
  let doc_str = match module_doc do | Some(val: d) -> d | None -> "" end
    let tls = JsonArray(items: top_levels_to_json(xs: definitions, acc: []))
    let obj = JsonObject(fields: [
      JsonField(key: "kind", value: JsonString(val: "ast")),
      JsonField(key: "module_doc", value: JsonString(val: doc_str)),
      JsonField(key: "top_levels", value: tls)
    ])
    return json.serialize(v: obj)
end

export let ast_to_text = fn (prog: Program) -> string do
  let Program(definitions, module_doc: _) = prog
  let banner = "=== AST dump (parser output, " ++ str.from_i64(val: list.length(xs: definitions)) ++ " top-level items) ==="
    let lines_rev = top_levels_to_lines_go(xs: definitions, depth: 1, acc: [])
    let lines = list.reverse(xs: lines_rev)
    let buf = bb.empty()
    let %buf = bb.push_string(%buf, s: banner)
    let %buf = bb.push_string(%buf, s: "\n")
    let %buf = join_lines_into(%buf, xs: lines)
    let %buf = bb.push_string(%buf, s: "\n")
    let result = bb.to_string(&buf)
    bb.free(%buf)
    return result
end
