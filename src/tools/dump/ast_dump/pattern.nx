/**
 * ast_dump/pattern: SpannedPattern → JSON / text-lines.
 *
 * Exports `pattern_to_json`, `patterns_to_json`,
 *         `pat_to_lines`, `patterns_to_lines`.
 * No dependency on expr or stmt; patterns are self-recursive only.
 */

import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"
import {
  JsonValue,
  JsonString,
  JsonInt,
  JsonBool,
  JsonArray,
  JsonObject,
  JsonField
} from "std:json"
import { Span } from "src/syntax/token.nx"
import { Sigil, SigilImmutable, SigilMutable, SigilLinear, SigilBorrow, SigilLazy, Literal, LitInt, LitFloat, LitBool, LitChar, LitString, LitUnit, RdrName, Unqual, Qual } from "src/types/vocab.nx"
import { CtorPatternField, RecordPatField, SpannedPattern, Pattern } from "src/syntax/ast.nx"

let sigil_to_str = fn (s: Sigil) -> string do
  match s do
    | SigilImmutable -> return ""
    | SigilMutable -> return "mut"
    | SigilLinear -> return "%"
    | SigilBorrow -> return "&"
    | SigilLazy -> return "@"
  end
end

let rdr_to_str = fn (n: RdrName) -> string do
  match n do
    | Unqual(name) -> return name
    | Qual(alias, name) -> return alias ++ "." ++ name
  end
end

let literal_to_str = fn (lit: Literal) -> string do
  match lit do
    | LitInt(val) -> return str.from_i64(val)
    | LitFloat(val) -> return val
    | LitBool(val) -> return str.from_bool(val)
    | LitChar(val) -> return "char(" ++ str.from_i64(val) ++ ")"
    | LitString(val) -> return "\"" ++ val ++ "\""
    | LitUnit -> return "()"
  end
end

let literal_to_value_json = fn (lit: Literal) -> JsonValue do
  match lit do
    | LitInt(val) -> return JsonInt(val)
    | LitFloat(val) -> return JsonString(val)
    | LitBool(val) -> return JsonBool(val)
    | LitChar(val) -> return JsonInt(val)
    | LitString(val) -> return JsonString(val)
    | LitUnit -> return JsonString(val: "()")
  end
end

let literal_kind = fn (lit: Literal) -> string do
  match lit do
    | LitInt(val: _) -> return "int"
    | LitFloat(val: _) -> return "float"
    | LitBool(val: _) -> return "bool"
    | LitChar(val: _) -> return "char"
    | LitString(val: _) -> return "string"
    | LitUnit -> return "unit"
  end
end

let span_to_json = fn (s: Span) -> JsonValue do
  let Span(offset, line, col) = s
  return JsonObject(fields: [
      JsonField(key: "start", value: JsonInt(val: offset)),
      JsonField(key: "end", value: JsonInt(val: offset)),
      JsonField(key: "line", value: JsonInt(val: line)),
      JsonField(key: "col", value: JsonInt(val: col))
    ])
end

let span_to_text = fn (s: Span) -> string do
  let Span(offset: _, line, col) = s
  return "@" ++ str.from_i64(line) ++ ":" ++ str.from_i64(col)
end

let indent_str = fn (n: i64) -> string do
  return indent_str_go(n, acc: "")
end

let indent_str_go = fn (n: i64, acc: string) -> string do
  if n <= 0 then return acc end
  return indent_str_go(n: n - 1, acc: acc ++ "  ")
end

export let pattern_to_json = fn (sp: SpannedPattern) -> JsonValue do
  let SpannedPattern(node, span) = sp
  let sp_field = JsonField(key: "span", value: span_to_json(s: span))
    match node do
      | PatLiteral(lit) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "PatLiteral")),
          sp_field,
          JsonField(key: "lit_kind", value: JsonString(val: literal_kind(lit))),
          JsonField(key: "value", value: literal_to_value_json(lit)),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | PatVariable(name, sigil) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "PatVariable")),
          sp_field,
          JsonField(key: "name", value: JsonString(val: name)),
          JsonField(key: "sigil", value: JsonString(val: sigil_to_str(s: sigil))),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | PatConstructor(name, fields, sigil) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "PatConstructor")),
          sp_field,
          JsonField(key: "name", value: JsonString(val: rdr_to_str(n: name))),
          JsonField(key: "sigil", value: JsonString(val: sigil_to_str(s: sigil))),
          JsonField(
            key: "children",
            value: JsonArray(items: pat_ctor_fields_to_json(fields, acc: []))
          )
        ])
      | PatConstructorWildcard(name, sigil) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "PatConstructorWildcard")),
          sp_field,
          JsonField(key: "name", value: JsonString(val: rdr_to_str(n: name))),
          JsonField(key: "sigil", value: JsonString(val: sigil_to_str(s: sigil))),
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | PatRecord(fields, has_wildcard) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "PatRecord")),
          sp_field,
          JsonField(key: "has_wildcard", value: JsonBool(val: has_wildcard)),
          JsonField(
            key: "children",
            value: JsonArray(items: pat_rec_fields_to_json(fields, acc: []))
          )
        ])
      | PatWildcard ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "PatWildcard")),
          sp_field,
          JsonField(key: "children", value: JsonArray(items: []))
        ])
      | PatOr(alts) ->
        return JsonObject(fields: [
          JsonField(key: "kind", value: JsonString(val: "PatOr")),
          sp_field,
          JsonField(key: "children", value: JsonArray(items: patterns_to_json(alts, acc: [])))
        ])
    end
end

let pat_ctor_fields_to_json = fn (fs: [ CtorPatternField ], acc: [ JsonValue ]) -> [ JsonValue ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | CtorPatternField(name, pattern: p) :: rest ->
      let node = JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "CtorPatternField")),
        JsonField(key: "name", value: JsonString(val: name)),
        JsonField(key: "children", value: JsonArray(items: [ pattern_to_json(sp: p) ]))
      ])
      return pat_ctor_fields_to_json(fs: rest, acc: node :: acc)
  end
end

let pat_rec_fields_to_json = fn (fs: [ RecordPatField ], acc: [ JsonValue ]) -> [ JsonValue ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | RecordPatField(name, pattern: p) :: rest ->
      let node = JsonObject(fields: [
        JsonField(key: "kind", value: JsonString(val: "RecordPatField")),
        JsonField(key: "name", value: JsonString(val: name)),
        JsonField(key: "children", value: JsonArray(items: [ pattern_to_json(sp: p) ]))
      ])
      return pat_rec_fields_to_json(fs: rest, acc: node :: acc)
  end
end

export let patterns_to_json = fn (ps: [ SpannedPattern ], acc: [ JsonValue ]) -> [ JsonValue ] do
  match ps do
    | [] -> return list.reverse(xs: acc)
    | p :: rest -> return patterns_to_json(ps: rest, acc: pattern_to_json(sp: p) :: acc)
  end
end

export let pat_to_lines = fn (sp: SpannedPattern, depth: i64, acc: [ string ]) -> [ string ] do
  let SpannedPattern(node, span) = sp
  let pre = indent_str(depth) ++ span_to_text(s: span)
    match node do
      | PatLiteral(lit) ->
        return (pre ++ " PatLiteral " ++ literal_kind(lit) ++ "=" ++ literal_to_str(lit)) :: acc
      | PatVariable(name, sigil) ->
        return (pre ++ " PatVariable " ++ sigil_to_str(s: sigil) ++ name) :: acc
      | PatConstructor(name, fields, sigil) ->
        let head = pre ++ " PatConstructor " ++ sigil_to_str(s: sigil) ++ rdr_to_str(n: name)
        return pat_ctor_fields_to_lines(fs: fields, depth: depth + 1, acc: head :: acc)
      | PatConstructorWildcard(name, sigil) ->
        return (pre ++ " PatConstructorWildcard " ++ sigil_to_str(s: sigil) ++ rdr_to_str(n: name) ++ "(..)") :: acc
      | PatRecord(fields, has_wildcard) ->
        let suf = if has_wildcard then " {.., ..}" else " {..}" end
        let head = pre ++ " PatRecord" ++ suf
        return pat_rec_fields_to_lines(fs: fields, depth: depth + 1, acc: head :: acc)
      | PatWildcard ->
        return (pre ++ " PatWildcard") :: acc
      | PatOr(alts) ->
        let head = pre ++ " PatOr"
        return patterns_to_lines(ps: alts, depth: depth + 1, acc: head :: acc)
    end
end

let pat_ctor_fields_to_lines = fn (
  fs: [ CtorPatternField ],
  depth: i64,
  acc: [ string ]
) -> [ string ] do
  match fs do
    | [] -> return acc
    | CtorPatternField(name, pattern: p) :: rest ->
      let head = indent_str(depth) ++ " CtorPatternField " ++ name
      let acc2 = pat_to_lines(sp: p, depth: depth + 1, acc: head :: acc)
      return pat_ctor_fields_to_lines(fs: rest, depth, acc: acc2)
  end
end

let pat_rec_fields_to_lines = fn (
  fs: [ RecordPatField ],
  depth: i64,
  acc: [ string ]
) -> [ string ] do
  match fs do
    | [] -> return acc
    | RecordPatField(name, pattern: p) :: rest ->
      let head = indent_str(depth) ++ " RecordPatField " ++ name
      let acc2 = pat_to_lines(sp: p, depth: depth + 1, acc: head :: acc)
      return pat_rec_fields_to_lines(fs: rest, depth, acc: acc2)
  end
end

export let patterns_to_lines = fn (
  ps: [ SpannedPattern ],
  depth: i64,
  acc: [ string ]
) -> [ string ] do
  match ps do
    | [] -> return acc
    | p :: rest ->
      let acc2 = pat_to_lines(sp: p, depth, acc)
      return patterns_to_lines(ps: rest, depth, acc: acc2)
  end
end
