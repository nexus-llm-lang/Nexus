/**
 * ir_dump: machine-readable IR dumps for `nexus hir` / `nexus lir`.
 *
 * Two subcommands:
 *   - `nexus hir <file> [--format=text|json]` — parses + lowers to HIR, prints.
 *   - `nexus lir <file> [--format=text|json]` — same, but through MIR→LIR.
 *
 * JSON shape (V2): one JsonObject per top-level function
 * with `{name, params, ret_type, span, body}`. `body` is itself a structured
 * JSON expression tree (no opaque `body_pp` string) — each node carries
 *   `{kind: "<VariantName>", <variant-flat-fields>, children: [...]}`
 * where `children` holds sub-expr/sub-stmt nodes. Non-recursive payload
 * (literal value, identifier strings, types as strings) sits as flat keys
 * beside `kind`/`children`. Sub-lists with both a label and a child (call args,
 * named record fields, match arms, handler arms) are emitted under
 * purpose-specific keys (`args`, `fields`, `cases`, `arms`). Span objects
 * are `{offset, line, col}`; patterns are non-spanned per types.nx and so
 * omit `span`.
 *
 * V1 emitted `body_pp` as a stringified pretty-print;
 * V2 deletes that field entirely so consumers walk the tree structurally.
 *
 * Implementation is split across submodules:
 *   - src/tools/ir_dump/hir_text.nx  — hir_to_text
 *   - src/tools/ir_dump/hir_json.nx  — hir_to_json
 *   - src/tools/ir_dump/lir_text.nx  — lir_to_text
 *   - src/tools/ir_dump/lir_json.nx  — lir_to_json
 */

import { Option, Some, None } from "std:option"
import * as str from "std:str"
import { SubcommandHit, detect_subcommand } from "std:argparse"
import { JsonThrow } from "std:json"
import { Sigil, SigilImmutable, SigilMutable, SigilLinear, SigilBorrow, SigilLazy } from "src/common/ast.nx"
import { HirProgram } from "src/ir/hir/types.nx"
import { LirFunction } from "src/ir/lir/types.nx"
import { hir_to_text as impl_hir_to_text } from "src/tools/dump/ir_dump/hir_text.nx"
import { hir_to_json as impl_hir_to_json } from "src/tools/dump/ir_dump/hir_json.nx"
import { lir_to_text as impl_lir_to_text } from "src/tools/dump/ir_dump/lir_text.nx"
import { lir_to_json as impl_lir_to_json } from "src/tools/dump/ir_dump/lir_json.nx"

export type ParsedHirSubcommand = ParsedHirSubcommand(remaining: [ string ], is_hir: bool)
export type ParsedLirSubcommand = ParsedLirSubcommand(remaining: [ string ], is_lir: bool)

/** Detect a leading `hir` subcommand. Thin wrapper over argparse's
 * shared `detect_subcommand` primitive. */
export let strip_hir_subcommand = fn (xs: [ string ]) -> ParsedHirSubcommand do
  match detect_subcommand(args: xs, kw: "hir") do | SubcommandHit(present, remaining) ->
    if present then return ParsedHirSubcommand(remaining, is_hir: true) end
    return ParsedHirSubcommand(remaining: xs, is_hir: false)
  end
end

/** Detect a leading `lir` subcommand. */
export let strip_lir_subcommand = fn (xs: [ string ]) -> ParsedLirSubcommand do
  match detect_subcommand(args: xs, kw: "lir") do | SubcommandHit(present, remaining) ->
    if present then return ParsedLirSubcommand(remaining, is_lir: true) end
    return ParsedLirSubcommand(remaining: xs, is_lir: false)
  end
end

export let sigil_to_str = fn (s: Sigil) -> string do
  match s do
    | SigilImmutable -> return ""
    | SigilMutable -> return "mut"
    | SigilLinear -> return "%"
    | SigilBorrow -> return "&"
    | SigilLazy -> return "@"
  end
end

export let hir_to_text = fn (prog: HirProgram) -> string do
  return impl_hir_to_text(prog)
end

export let hir_to_json = fn (prog: HirProgram) -> string throws { JsonThrow } do
  return impl_hir_to_json(prog)
end

export let lir_to_text = fn (funcs: [ LirFunction ]) -> string do
  return impl_lir_to_text(funcs)
end

export let lir_to_json = fn (funcs: [ LirFunction ]) -> string throws { JsonThrow } do
  return impl_lir_to_json(funcs)
end
