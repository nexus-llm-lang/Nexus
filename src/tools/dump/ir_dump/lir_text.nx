/**
 * ir_dump/lir_text: LIR → human-readable text pretty-printer.
 *
 * Exports `lir_to_text` — the text format emitter for `nexus lir --format=text`.
 */

import * as str from "std:str"
import * as list from "std:list"
import { Option, Some, None } from "std:option"
import { BinaryOp, TypeExpr } from "src/common/ast.nx"
import { type_to_string } from "src/typecheck/types.nx"
import {
  LirFunction,
  LirParam,
  LirStmt,
  LirExpr,
  LirAtom,
  LirCallArg,
  LirNamedAtom
} from "src/ir/lir/types.nx"

let binop_to_str = fn (op: BinaryOp) -> string do
  match op do
    | OpAdd -> return "+"
    | OpSub -> return "-"
    | OpMul -> return "*"
    | OpDiv -> return "/"
    | OpMod -> return "%"
    | OpFAdd -> return "+."
    | OpFSub -> return "-."
    | OpFMul -> return "*."
    | OpFDiv -> return "/."
    | OpEq -> return "=="
    | OpNe -> return "!="
    | OpLt -> return "<"
    | OpLe -> return "<="
    | OpGt -> return ">"
    | OpGe -> return ">="
    | OpFEq -> return "==."
    | OpFNe -> return "!=."
    | OpFLt -> return "<."
    | OpFLe -> return "<=."
    | OpFGt -> return ">."
    | OpFGe -> return ">=."
    | OpBitAnd -> return "&"
    | OpBitOr -> return "|"
    | OpBitXor -> return "^"
    | OpShl -> return "<<"
    | OpShr -> return ">>"
    | OpAnd -> return "&&"
    | OpOr -> return "||"
    | OpConcat -> return "++"
  end
end

let join_strs = fn (xs: [ string ], sep: string) -> string do
  return str.join(xs, sep)
end

let lir_atom_to_str = fn (a: LirAtom) -> string do
  match a do
    | LirAtomVar(name, typ: _) -> return name
    | LirAtomInt(val) -> return str.from_i64(val)
    | LirAtomFloat(val) -> return val
    | LirAtomBool(val) -> return str.from_bool(val)
    | LirAtomChar(val) -> return "char(" ++ str.from_i64(val) ++ ")"
    | LirAtomString(val) -> return "\"" ++ val ++ "\""
    | LirAtomUnit -> return "()"
  end
end

let lir_atoms_to_strs = fn (xs: [ LirAtom ]) -> [ string ] do
  match xs do
    | [] -> return []
    | a :: rest -> return lir_atom_to_str(a) :: lir_atoms_to_strs(xs: rest)
  end
end

let lir_call_args_to_strs = fn (args: [ LirCallArg ]) -> [ string ] do
  match args do
    | [] -> return []
    | LirCallArg(label, value) :: rest ->
      let head = if str.length(s: label) > 0 then label ++ ": " ++ lir_atom_to_str(a: value) else lir_atom_to_str(a: value) end
      return head :: lir_call_args_to_strs(args: rest)
  end
end

let lir_named_atoms_to_strs = fn (fs: [ LirNamedAtom ]) -> [ string ] do
  match fs do
    | [] -> return []
    | LirNamedAtom(name, value) :: rest ->
      return (name ++ ": " ++ lir_atom_to_str(a: value)) :: lir_named_atoms_to_strs(fs: rest)
  end
end

let zip_arm_fns_tags = fn (fns: [ string ], tags: [ string ]) -> [ string ] do
  match fns do
    | [] -> return []
    | f :: rest_f ->
      match tags do
        | [] -> return [f] // mismatched lengths -> degrade gracefully
        | t :: rest_t -> return (t ++ "->" ++ f) :: zip_arm_fns_tags(fns: rest_f, tags: rest_t)
      end
  end
end

let lir_expr_to_str = fn (e: LirExpr) -> string do
  match e do
    | LirExprAtom(atom) -> return lir_atom_to_str(a: atom)
    | LirExprBinary(op, lhs, rhs, typ: _) ->
      return "(" ++ lir_atom_to_str(a: lhs) ++ " " ++ binop_to_str(op) ++ " " ++ lir_atom_to_str(a: rhs) ++ ")"
    | LirExprCall(func, args, typ: _) ->
      return func ++ "(" ++ join_strs(xs: lir_call_args_to_strs(args), sep: ", ") ++ ")"
    | LirExprTailCall(func, args, typ: _) ->
      return "tail " ++ func ++ "(" ++ join_strs(xs: lir_call_args_to_strs(args), sep: ", ") ++ ")"
    | LirExprConstructor(name, args, typ: _) ->
      return name ++ "(" ++ join_strs(xs: lir_atoms_to_strs(xs: args), sep: ", ") ++ ")"
    | LirExprRecord(fields, typ: _) ->
      return "{" ++ join_strs(xs: lir_named_atoms_to_strs(fs: fields), sep: ", ") ++ "}"
    | LirExprObjectTag(value, typ: _) -> return "tag(" ++ lir_atom_to_str(a: value) ++ ")"
    | LirExprObjectField(value, index, typ: _) ->
      return "field(" ++ lir_atom_to_str(a: value) ++ ", " ++ str.from_i64(val: index) ++ ")"
    | LirExprRaise(value, typ: _) -> return "throw " ++ lir_atom_to_str(a: value)
    | LirExprForce(value, typ: _) -> return "force " ++ lir_atom_to_str(a: value)
    | LirExprMakeClosure(func_name, captures, typ: _) ->
      return "closure(" ++ func_name ++ "; " ++ join_strs(
        xs: lir_atoms_to_strs(xs: captures),
        sep: ", "
      ) ++ ")"
    | LirExprCallClosure(closure, args, typ: _) ->
      return "callcl " ++ lir_atom_to_str(a: closure) ++ "(" ++ join_strs(
        xs: lir_call_args_to_strs(args),
        sep: ", "
      ) ++ ")"
    | LirExprSuspend(tag_name, payload, typ: _) ->
      return "suspend $" ++ tag_name ++ " " ++ lir_atom_to_str(a: payload)
    | LirExprResume(cont, value, typ: _) ->
      return "resume " ++ lir_atom_to_str(a: cont) ++ " " ++ lir_atom_to_str(a: value)
    | LirExprContNew(func_ref, typ: _) -> return "cont.new $" ++ func_ref
    | LirExprInjectResume(body_fn, arm_fns, arm_tags, typ: _) ->
      let arms_str = join_strs(xs: zip_arm_fns_tags(fns: arm_fns, tags: arm_tags), sep: "; ")
      return "inject_resume " ++ body_fn ++ " [" ++ arms_str ++ "]"
  end
end

let lir_stmts_to_str_go = fn (stmts: [ LirStmt ], acc: [ string ]) -> [ string ] do
  match stmts do
    | [] -> return list.reverse(xs: acc)
    | s :: rest -> return lir_stmts_to_str_go(stmts: rest, acc: lir_stmt_to_str(s) :: acc)
  end
end

let lir_stmts_to_str = fn (stmts: [ LirStmt ]) -> string do
  return join_strs(xs: lir_stmts_to_str_go(stmts, acc: []), sep: "; ")
end

let lir_stmt_to_str = fn (s: LirStmt) -> string do
  match s do
    | LirStmtLet(
      name,
      typ,
      expr
    ) -> return "let " ++ name ++ ": " ++ type_to_string(typ) ++ " = " ++ lir_expr_to_str(e: expr)
    | LirStmtIf(cond, then_body, else_body) ->
      return "if " ++ lir_atom_to_str(a: cond) ++ " then " ++ lir_stmts_to_str(stmts: then_body) ++ " else " ++ lir_stmts_to_str(stmts: else_body) ++ " end"
    | LirStmtIfReturn(cond, then_body, then_ret, else_body, else_ret, ret_type: _) ->
      let else_ret_str = match else_ret do | Some(val: v) -> " -> " ++ lir_atom_to_str(a: v) | None -> "" end
      return "ifret " ++ lir_atom_to_str(a: cond) ++ " then " ++ lir_stmts_to_str(stmts: then_body) ++ " -> " ++ lir_atom_to_str(a: then_ret) ++ " else " ++ lir_stmts_to_str(stmts: else_body) ++ else_ret_str
    | LirStmtLoop(cond_stmts, cond, body) ->
      return "loop while " ++ lir_stmts_to_str(stmts: cond_stmts) ++ " | " ++ lir_atom_to_str(a: cond) ++ " do " ++ lir_stmts_to_str(stmts: body) ++ " end"
    | LirStmtTryCatch(body, body_ret, catch_param, catch_param_typ: _, catch_body, catch_ret) ->
      let body_ret_str = match body_ret do | Some(val: v) -> " -> " ++ lir_atom_to_str(a: v) | None -> "" end
      let catch_ret_str = match catch_ret do | Some(val: v) -> " -> " ++ lir_atom_to_str(a: v) | None -> "" end
      return "try " ++ lir_stmts_to_str(stmts: body) ++ body_ret_str ++ " catch " ++ catch_param ++ " -> " ++ lir_stmts_to_str(stmts: catch_body) ++ catch_ret_str
  end
end

let lir_params_to_strs = fn (ps: [ LirParam ]) -> [ string ] do
  match ps do
    | [] -> return []
    | LirParam(label, name, typ) :: rest ->
      return (label ++ ": " ++ name ++ ": " ++ type_to_string(typ)) :: lir_params_to_strs(ps: rest)
  end
end

let lir_func_body_to_str = fn (f: LirFunction) -> string do
  match f do | LirFunction(name: _, params: _, ret_type: _, body, ret, span: _) ->
    let body_str = lir_stmts_to_str(stmts: body)
    return body_str ++ " => " ++ lir_atom_to_str(a: ret)
  end
end

let lir_func_to_text_lines = fn (f: LirFunction) -> [ string ] do
  match f do | LirFunction(name, params, ret_type, body: _, ret: _, span: _) ->
    let ps_str = join_strs(xs: lir_params_to_strs(ps: params), sep: ", ")
    let header = "fn " ++ name ++ "(" ++ ps_str ++ ") -> " ++ type_to_string(typ: ret_type)
    let body_line = "  body: " ++ lir_func_body_to_str(f)
    return [header, body_line]
  end
end

let lir_funcs_to_text_go = fn (fs: [ LirFunction ], acc: [ string ]) -> [ string ] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      let lines = lir_func_to_text_lines(f)
      return lir_funcs_to_text_go(fs: rest, acc: list.concat(xs: list.reverse(xs: lines), ys: acc))
  end
end

export let lir_to_text = fn (funcs: [ LirFunction ]) -> string do
  let banner = "=== LIR dump (" ++ str.from_i64(val: list.length(xs: funcs)) ++ " functions) ==="
  let lines = lir_funcs_to_text_go(fs: funcs, acc: [])
  return banner ++ "\n" ++ join_strs(xs: lines, sep: "\n") ++ "\n"
end
