/**
 * tools/record_replay: JSONL schema types and serializers for `nexus run --record/--replay`.
 *
 * The record/replay feature persists every `nexus run` invocation as a JSONL
 * file so it can be replayed deterministically for regression detection and
 * agent self-evaluation.
 *
 * JSONL schema (one JSON object per line):
 *
 *   Line 1 — entry record:
 *     {"kind":"entry","source":"<path>","source_hash":"<sha256-hex>",
 *      "argv":[...], "seed":"<N>"|null, "frozen_clock":"<epoch>"|null,
 *      "caps":[...], "nexus_version":"<sha>"}
 *
 *   Lines 2..N — diagnostic records (one per compiler diagnostic):
 *     {"kind":"diagnostic","level":"error"|"warning"|"info",
 *      "code":"E####","message":"<text>","span":"<file>:<line>:<col>"}
 *
 *   Lines N+1..M — output records (stdout/stderr lines with timestamps):
 *     {"kind":"stdout","ts_ms":<i64>,"line":"<text>"}
 *     {"kind":"stderr","ts_ms":<i64>,"line":"<text>"}
 *
 *   Last line — summary record:
 *     {"kind":"summary","exit_code":<i64>,"wall_ms":<i64>}
 *
 * This module provides the type definitions and pure serialization helpers
 * that can be tested in-wasm. The actual subprocess orchestration (build +
 * exec, capture, replay) is implemented in the host-shell layer (header.sh)
 * because WASI preview1 has no subprocess API.
 */

import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"

// ─── Record types ──────────────────────────────────────────────────────────

/** Entry record: captured at invocation time. */
export type EntryRecord = EntryRecord(
  source: string,
  source_hash: string,
  argv: [string],
  seed: Option<string>,
  frozen_clock: Option<string>,
  caps: [string],
  nexus_version: string
)

/** Diagnostic level. */
export type DiagLevel = DiagError | DiagWarning | DiagInfo

/** Single compiler diagnostic. */
export type DiagRecord = DiagRecord(
  level: DiagLevel,
  code: string,
  message: string,
  span: string
)

/** Output stream kind. */
export type OutputKind = OutputStdout | OutputStderr

/** One captured output line. */
export type OutputRecord = OutputRecord(
  kind: OutputKind,
  ts_ms: i64,
  line: string
)

/** Final summary record. */
export type SummaryRecord = SummaryRecord(
  exit_code: i64,
  wall_ms: i64
)

// ─── JSON escaping ────────────────────────────────────────────────────────

/** Escape a single byte for JSON embedding. Handles \, ", \n, \r, \t.
 *  Other bytes pass through as-is (sufficient for UTF-8 text).
 */
let escape_byte = fn (b: char) -> string do
  if b == '\\' then return "\\\\" end
  if b == '"' then return "\\\"" end
  if b == '\n' then return "\\n" end
  if b == '\r' then return "\\r" end
  if b == '\t' then return "\\t" end
  return str.from_char(c: b)
end

/** JSON-escape a string: iterate over bytes and escape special chars. */
export let json_escape = fn (s: string) -> string do
  let n = str.byte_length(s)
  return json_escape_go(s, i: 0, n, acc: "")
end

let json_escape_go = fn (s: string, i: i64, n: i64, acc: string) -> string do
  if i >= n then return acc end
  let b = str.byte_at(s, idx: i)
  let esc = escape_byte(b)
  return json_escape_go(s, i: i + 1, n, acc: acc ++ esc)
end

// ─── Serialization helpers ────────────────────────────────────────────────

let json_str = fn (s: string) -> string do
  let esc = json_escape(s)
  return "\"" ++ esc ++ "\""
end

let json_opt_str = fn (opt: Option<string>) -> string do
  match opt do
    | None -> return "null"
    | Some(val: s) ->
      let v = json_str(s)
      return v
  end
end

let json_str_array = fn (xs: [string]) -> string do
  let quoted = list.map(xs, f: fn (s: string) -> string do
    return json_str(s)
  end)
  return "[" ++ str.join(xs: quoted, sep: ",") ++ "]"
end

// ─── Serializers ─────────────────────────────────────────────────────────

export let serialize_entry = fn (r: EntryRecord) -> string do
  let EntryRecord(
    source: source,
    source_hash: source_hash,
    argv: argv,
    seed: seed,
    frozen_clock: frozen_clock,
    caps: caps,
    nexus_version: nexus_version
  ) = r
  let src_j = json_str(source)
  let hash_j = json_str(source_hash)
  let argv_j = json_str_array(argv)
  let seed_j = json_opt_str(seed)
  let fc_j = json_opt_str(frozen_clock)
  let caps_j = json_str_array(caps)
  let ver_j = json_str(nexus_version)
  return "{\"kind\":\"entry\""
    ++ ",\"source\":" ++ src_j
    ++ ",\"source_hash\":" ++ hash_j
    ++ ",\"argv\":" ++ argv_j
    ++ ",\"seed\":" ++ seed_j
    ++ ",\"frozen_clock\":" ++ fc_j
    ++ ",\"caps\":" ++ caps_j
    ++ ",\"nexus_version\":" ++ ver_j
    ++ "}"
end

let diag_level_str = fn (l: DiagLevel) -> string do
  match l do
    | DiagError -> return "error"
    | DiagWarning -> return "warning"
    | DiagInfo -> return "info"
  end
end

export let serialize_diagnostic = fn (r: DiagRecord) -> string do
  let DiagRecord(level: level, code: code, message: message, span: span) = r
  let lvl = diag_level_str(level)
  let level_j = json_str(lvl)
  let code_j = json_str(code)
  let msg_j = json_str(message)
  let span_j = json_str(span)
  return "{\"kind\":\"diagnostic\""
    ++ ",\"level\":" ++ level_j
    ++ ",\"code\":" ++ code_j
    ++ ",\"message\":" ++ msg_j
    ++ ",\"span\":" ++ span_j
    ++ "}"
end

let output_kind_str = fn (k: OutputKind) -> string do
  match k do
    | OutputStdout -> return "stdout"
    | OutputStderr -> return "stderr"
  end
end

export let serialize_output = fn (r: OutputRecord) -> string do
  let OutputRecord(kind: kind, ts_ms: ts_ms, line: line) = r
  let knd = output_kind_str(kind)
  let kind_j = json_str(knd)
  let line_j = json_str(line)
  let ts_j = str.from_i64(val: ts_ms)
  return "{\"kind\":" ++ kind_j
    ++ ",\"ts_ms\":" ++ ts_j
    ++ ",\"line\":" ++ line_j
    ++ "}"
end

export let serialize_summary = fn (r: SummaryRecord) -> string do
  let SummaryRecord(exit_code: exit_code, wall_ms: wall_ms) = r
  let ec_j = str.from_i64(val: exit_code)
  let wm_j = str.from_i64(val: wall_ms)
  return "{\"kind\":\"summary\""
    ++ ",\"exit_code\":" ++ ec_j
    ++ ",\"wall_ms\":" ++ wm_j
    ++ "}"
end

// ─── JSONL key extraction ────────────────────────────────────────────────

/** Extract the value of a JSON string field from a flat JSONL line.
 *  Scans for `"<key>":"<value>"` and returns the raw (unescaped) value string.
 *  Returns None if the key is absent or the value is `null`.
 *
 *  Limitations: does not unescape backslash sequences in the value.
 *  Sufficient for well-formed replay metadata (paths, hashes, numbers-as-strings).
 */
export let jsonl_get_str = fn (line: string, key: string) -> Option<string> do
  let needle = "\"" ++ key ++ "\":"
  let pos = str.index_of(s: line, sub: needle)
  if pos < 0 then return None end
  let needle_len = str.byte_length(s: needle)
  let line_len = str.byte_length(s: line)
  let after_key = pos + needle_len
  let rest_len = line_len - after_key
  let rest = str.byte_substring(s: line, start: after_key, len: rest_len)
  // Check for null
  if str.starts_with(s: rest, prefix: "null") then return None end
  // Check for quoted string
  if str.starts_with(s: rest, prefix: "\"") then
    let inner_len = str.byte_length(s: rest) - 1
    let inner = str.byte_substring(s: rest, start: 1, len: inner_len)
    let end_pos = find_unescaped_quote(s: inner, i: 0)
    if end_pos < 0 then return None end
    let val = str.byte_substring(s: inner, start: 0, len: end_pos)
    return Some(val: val)
  end
  return None
end

/** Find the position of the next unescaped double-quote in s from position i.
 *  Returns -1 if not found.
 */
let find_unescaped_quote = fn (s: string, i: i64) -> i64 do
  let n = str.byte_length(s)
  return find_unescaped_quote_go(s, i, n)
end

let find_unescaped_quote_go = fn (s: string, i: i64, n: i64) -> i64 do
  if i >= n then return (0 - 1) end
  let b = str.byte_at(s, idx: i)
  if b == '\\' then
    // skip next byte (escaped char)
    return find_unescaped_quote_go(s, i: i + 2, n)
  end
  if b == '"' then return i end
  return find_unescaped_quote_go(s, i: i + 1, n)
end

/** Extract an integer field from a JSONL line. Returns None if absent. */
export let jsonl_get_i64 = fn (line: string, key: string) -> Option<i64> do
  let needle = "\"" ++ key ++ "\":"
  let pos = str.index_of(s: line, sub: needle)
  if pos < 0 then return None end
  let needle_len = str.byte_length(s: needle)
  let line_len = str.byte_length(s: line)
  let after_key = pos + needle_len
  let rest_len = line_len - after_key
  let rest = str.byte_substring(s: line, start: after_key, len: rest_len)
  // Collect leading digits (and optional leading minus)
  let num_str = collect_number(s: rest, i: 0, acc: "", seen_digit: false)
  return str.parse_i64(s: num_str)
end

let collect_number = fn (s: string, i: i64, acc: string, seen_digit: bool) -> string do
  let n = str.byte_length(s)
  if i >= n then return acc end
  let b = str.byte_at(s, idx: i)
  if b == '-' && !seen_digit then
    return collect_number(s, i: i + 1, acc: acc ++ "-", seen_digit: false)
  end
  if b >= '0' && b <= '9' then
    let d = str.from_char(c: b)
    return collect_number(s, i: i + 1, acc: acc ++ d, seen_digit: true)
  end
  return acc
end

/** Read the "kind" field from a JSONL line. Returns "" if absent. */
export let jsonl_get_kind = fn (line: string) -> string do
  match jsonl_get_str(line, key: "kind") do
    | None -> return ""
    | Some(val: k) -> return k
  end
end

/** Parse a summary record from a JSONL summary line. */
export let parse_summary = fn (line: string) -> Option<SummaryRecord> do
  match jsonl_get_i64(line, key: "exit_code") do
    | None -> return None
    | Some(val: exit_code) ->
      match jsonl_get_i64(line, key: "wall_ms") do
        | None -> return None
        | Some(val: wall_ms) ->
          return Some(val: SummaryRecord(exit_code: exit_code, wall_ms: wall_ms))
      end
  end
end
