/**
 * lsp/protocol: LSP wire-format type algebra and JSON codecs.
 *
 * This file has been split into sub-modules under src/lsp/protocol/:
 *
 *   protocol/json.nx       — LspProtocolError, LspProtocolThrow, JSON helpers
 *   protocol/method.nx     — LspMethod, parse_method
 *   protocol/text_doc.nx   — Position, Range, Location, TextEdit,
 *                            TextDocumentItem, VersionedTextDocumentIdentifier,
 *                            TextDocumentContentChangeEvent, TextDocumentSyncKind
 *   protocol/diag.nx       — DiagnosticSeverity, Diagnostic,
 *                            PublishDiagnosticsParams
 *   protocol/symbols.nx    — SymbolKind, DocumentSymbol, SymbolInformation
 *   protocol/completion.nx — CompletionItemKind, CompletionItem, CompletionList,
 *                            CompletionOptions, ParameterInformation,
 *                            SignatureInformation, SignatureHelp,
 *                            SignatureHelpOptions, SemanticTokens,
 *                            SemanticTokensLegend, SemanticTokensOptions,
 *                            ServerCapabilities, InitializeParams,
 *                            ServerInfo, InitializeResult
 *
 * Import from the appropriate sub-module directly. This file is intentionally
 * left as a documentation pointer only (Nexus has no re-export syntax).
 */
