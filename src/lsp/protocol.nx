/**
 * lsp/protocol: LSP wire-format type algebra and JSON codecs.
 *
 * MVP subset of the Language Server Protocol type system, sufficient to
 * exchange `initialize`, `textDocument/didChange`, `textDocument/didOpen`,
 * `textDocument/documentSymbol`, and `textDocument/publishDiagnostics`
 * payloads. Each type pairs with `*_from_json` / `*_to_json` over the
 * `nxlib/stdlib/json` value algebra.
 *
 * Layering vs `src/lsp/diagnostics.nx`:
 *   src/lsp/diagnostics.nx — server-internal types (1-based line/col, span
 *     mapping, Severity tag). Used inside the typecheck pipeline.
 *   src/lsp/protocol.nx (this file) — wire-spec types (0-based line/char,
 *     numeric DiagnosticSeverity codes 1..4 per spec). Used at the
 *     stdin/stdout boundary.
 *
 * The two layers are deliberately disjoint. Adapter helpers that translate
 * between them live in `src/lsp/handlers.nx` (out of scope here);
 * cross-cutting them risks tying the wire types to in-tree compile error
 * shapes, which would break compatibility when the spec evolves.
 *
 * Decoding raises `LspProtocolError` on a missing required field, a wrong
 * value kind, or a numeric severity outside 1..4. Encoding never fails for
 * structurally-correct values (it can still raise `JsonError` from the
 * underlying serializer if a contained f64 is NaN/Infinity, but no LSP
 * field uses f64 in this MVP).
 *
 * Out of scope for MVP (deferred without API churn — add a new exported
 * type alongside the existing ones):
 *   - WorkspaceEdit / TextEdit / DocumentChanges
 *   - Hover / SignatureHelp / CompletionItem
 *   - References / DefinitionLink / CodeAction
 *   - Configuration / Workspace folders
 */

import { JsonValue, JsonField, JsonNull, JsonBool, JsonInt, JsonString,
         JsonArray, JsonObject, get_field } from "std:json"
import { Option, Some, None } from "std:option"

// ─── Error type ──────────────────────────────────────────────────────────────

/**
Raised by every `*_from_json` decoder when the input violates the LSP
schema (missing required key, wrong value kind, out-of-range enum). Carries
a human-readable message; callers route this back as a JSON-RPC
`InvalidParams` error.
*/
/** Raised by `*_from_json` decoders when input violates the LSP schema; routes back to clients as JSON-RPC `InvalidParams`. */
export exception LspProtocolError(msg: string)

/**
Group covering every exception raised by LSP wire-format decoders.
Sole member is LspProtocolError; the group exists so cross-module
callers route errors through a stable group name instead of the
universal Exn.
*/
/** Exception group covering every LSP wire-format decoder failure (sole member: `LspProtocolError`). */
export exception group LspProtocolThrow = LspProtocolError

// ─── JSON decoding helpers ───────────────────────────────────────────────────
//
// These walk the json.nx algebra and raise LspProtocolError on the first
// schema violation. They are not exported — the wire types are the public
// surface — but their shape is consistent so adding new types follows the
// same pattern.

let require_field = fn (obj: JsonValue, key: string) -> JsonValue throws { LspProtocolThrow } do
  match get_field(obj, key) do
    | Some(val: v) -> return v
    | None -> raise LspProtocolError(msg: "missing required field '" ++ key ++ "'")
  end
end

let optional_field = fn (obj: JsonValue, key: string) -> Option<JsonValue> do
  return get_field(obj, key)
end

let as_string = fn (v: JsonValue, ctx: string) -> string throws { LspProtocolThrow } do
  match v do
    | JsonString(val: s) -> return s
    | _ -> raise LspProtocolError(msg: ctx ++ ": expected string")
  end
end

let as_i64 = fn (v: JsonValue, ctx: string) -> i64 throws { LspProtocolThrow } do
  match v do
    | JsonInt(val: i) -> return i
    | _ -> raise LspProtocolError(msg: ctx ++ ": expected integer")
  end
end

let as_bool = fn (v: JsonValue, ctx: string) -> bool throws { LspProtocolThrow } do
  match v do
    | JsonBool(val: b) -> return b
    | _ -> raise LspProtocolError(msg: ctx ++ ": expected boolean")
  end
end

let as_array = fn (v: JsonValue, ctx: string) -> [JsonValue] throws { LspProtocolThrow } do
  match v do
    | JsonArray(items: xs) -> return xs
    | _ -> raise LspProtocolError(msg: ctx ++ ": expected array")
  end
end

// ─── LspMethod ───────────────────────────────────────────────────────────────
//
// JSON-RPC `method` strings travel the wire as opaque text, but the set of
// methods this server dispatches on is closed and known at compile time.
// Modeling the set as a sum type turns the dispatch site into a `match` the
// typechecker checks for exhaustiveness — a new method requires both a new
// variant and a new arm, so a missing wire-up is a build error instead of a
// silent route to MethodNotFound.
//
// `MUnknownMethod(name)` carries the original wire string. LSP can't
// guarantee the client's protocol level matches the server's, so
// unrecognized method names are a runtime observation, not a parse failure.
// Dispatch routes this variant to MethodNotFound.

/** Closed sum of JSON-RPC `method` strings this server dispatches on; exhaustive `match` makes a missing wire-up a build error. Unknown wire names land in `MUnknownMethod`. */
export type LspMethod =
    MInitialize
  | MInitialized
  | MShutdown
  | MTextDocumentDidOpen
  | MTextDocumentDidChange
  | MTextDocumentDidClose
  | MTextDocumentDidSave
  | MTextDocumentDocumentSymbol
  | MTextDocumentHover
  | MTextDocumentDefinition
  | MTextDocumentCompletion
  | MTextDocumentReferences
  | MTextDocumentSignatureHelp
  | MTextDocumentSemanticTokensFull
  | MTextDocumentFormatting
  | MWorkspaceSymbol
  | MUnknownMethod(name: string)

/**
Parse a JSON-RPC `method` string into the closed `LspMethod` sum.
Unrecognized names land in `MUnknownMethod(name)` for the caller to
route as MethodNotFound — per LSP spec, unknown methods are observed
at runtime, not a fatal parse error.
*/
/** Parse a JSON-RPC `method` string into the closed `LspMethod` sum; unrecognized names land in `MUnknownMethod(name)`. */
export let parse_method = fn (s: string) -> LspMethod do
  if s == "initialize" then return MInitialize end
  if s == "initialized" then return MInitialized end
  if s == "shutdown" then return MShutdown end
  if s == "textDocument/didOpen" then return MTextDocumentDidOpen end
  if s == "textDocument/didChange" then return MTextDocumentDidChange end
  if s == "textDocument/didClose" then return MTextDocumentDidClose end
  if s == "textDocument/didSave" then return MTextDocumentDidSave end
  if s == "textDocument/documentSymbol" then return MTextDocumentDocumentSymbol end
  if s == "textDocument/hover" then return MTextDocumentHover end
  if s == "textDocument/definition" then return MTextDocumentDefinition end
  if s == "textDocument/completion" then return MTextDocumentCompletion end
  if s == "textDocument/references" then return MTextDocumentReferences end
  if s == "textDocument/signatureHelp" then return MTextDocumentSignatureHelp end
  if s == "textDocument/semanticTokens/full" then return MTextDocumentSemanticTokensFull end
  if s == "textDocument/formatting" then return MTextDocumentFormatting end
  if s == "workspace/symbol" then return MWorkspaceSymbol end
  return MUnknownMethod(name: s)
end

// ─── Position ────────────────────────────────────────────────────────────────
//
// Spec: zero-based `line` and `character`. Both are uinteger; we model with
// i64 to share the JsonInt lane and surface negative inputs as decode errors
// up the stack (the spec rejects them).

/** LSP `Position` (spec §"Text Documents") — zero-based `line` and UTF-16 `character` offsets within a document. */
export type Position = Position(line: i64, character: i64)

let position_to_json = fn (p: Position) -> JsonValue do
  match p do | Position(line, character) ->
    return JsonObject(fields: [
      JsonField(key: "line", value: JsonInt(val: line)),
      JsonField(key: "character", value: JsonInt(val: character))
    ])
  end
end

let position_from_json = fn (v: JsonValue) -> Position throws { LspProtocolThrow } do
  let line = as_i64(v: require_field(obj: v, key: "line"), ctx: "Position.line")
  let character = as_i64(v: require_field(obj: v, key: "character"), ctx: "Position.character")
  return Position(line, character)
end

// ─── Range ───────────────────────────────────────────────────────────────────

/** LSP `Range` (spec §"Text Documents") — half-open `[start, end)` pair of `Position`s. */
export type Range = Range(start: Position, end_: Position)

let range_to_json = fn (r: Range) -> JsonValue do
  match r do | Range(start, end_) ->
    return JsonObject(fields: [
      JsonField(key: "start", value: position_to_json(p: start)),
      JsonField(key: "end", value: position_to_json(p: end_))
    ])
  end
end

let range_from_json = fn (v: JsonValue) -> Range throws { LspProtocolThrow } do
  let start = position_from_json(v: require_field(obj: v, key: "start"))
  let end_ = position_from_json(v: require_field(obj: v, key: "end"))
  return Range(start, end_)
end

// ─── Location ────────────────────────────────────────────────────────────────

/** LSP `Location` (spec §"Text Documents") — a document URI paired with a `Range`; used by definition/references replies. */
export type Location = Location(uri: string, range: Range)

/** Encode a `Location` as `{ uri, range }` per the LSP wire layout. */
export let location_to_json = fn (loc: Location) -> JsonValue do
  match loc do | Location(uri, range) ->
    return JsonObject(fields: [
      JsonField(key: "uri", value: JsonString(val: uri)),
      JsonField(key: "range", value: range_to_json(r: range))
    ])
  end
end

let location_from_json = fn (v: JsonValue) -> Location throws { LspProtocolThrow } do
  let uri = as_string(v: require_field(obj: v, key: "uri"), ctx: "Location.uri")
  let range = range_from_json(v: require_field(obj: v, key: "range"))
  return Location(uri, range)
end

// ─── TextEdit ────────────────────────────────────────────────────────────────
//
// LSP §`TextEdit`. Pairs a `range` (the region in the original document to
// replace) with `new_text` (the replacement text). The reply shape for
// `textDocument/formatting` is `TextEdit[]`; a single full-document edit is
// the simplest correct response — clients apply the replace atomically.

/** LSP `TextEdit` (spec §"Text Documents") — pairs a `Range` to replace with the `new_text` substitution; used by formatting/refactor replies. */
export type TextEdit = TextEdit(range: Range, new_text: string)

/** Encode a `TextEdit` as `{ range, newText }` per the LSP wire layout. */
export let text_edit_to_json = fn (e: TextEdit) -> JsonValue do
  match e do | TextEdit(range, new_text) ->
    return JsonObject(fields: [
      JsonField(key: "range", value: range_to_json(r: range)),
      JsonField(key: "newText", value: JsonString(val: new_text))
    ])
  end
end

// ─── DiagnosticSeverity ──────────────────────────────────────────────────────
//
// Spec uses integer codes 1..4. Modeling as a closed sum forces every site
// that consumes severity to handle all four cases at compile time, while the
// integer mapping is centralised in the encode/decode pair.

/** LSP `DiagnosticSeverity` (spec §"Diagnostic") — wire codes 1..4 for Error/Warning/Information/Hint. */
export type DiagnosticSeverity =
    DiagSevError
  | DiagSevWarning
  | DiagSevInformation
  | DiagSevHint

let severity_to_int = fn (s: DiagnosticSeverity) -> i64 do
  match s do
    | DiagSevError -> return 1
    | DiagSevWarning -> return 2
    | DiagSevInformation -> return 3
    | DiagSevHint -> return 4
  end
end

let severity_from_int = fn (n: i64) -> DiagnosticSeverity throws { LspProtocolThrow } do
  if n == 1 then return DiagSevError end
  if n == 2 then return DiagSevWarning end
  if n == 3 then return DiagSevInformation end
  if n == 4 then return DiagSevHint end
  raise LspProtocolError(msg: "DiagnosticSeverity out of range (1..4)")
end

// ─── Diagnostic (wire) ───────────────────────────────────────────────────────
//
// Wire layout per LSP spec §`Diagnostic`. `severity`, `code`, and `source`
// are optional; we always emit `severity` and `message` (the only fields LSP
// clients reliably render) and elide the rest when absent.

/** LSP `Diagnostic` (spec §"Diagnostic") wire shape — `range` + `message` always emitted; `severity`/`code`/`source` optional. */
export type Diagnostic = Diagnostic(
  range: Range,
  severity: Option<DiagnosticSeverity>,
  /**
  Spec allows integer or string; we standardise on string to match the
  internal `Diagnostic.code` carried by `src/lsp/diagnostics.nx`.
  */
  code: Option<string>,
  source: Option<string>,
  message: string
)

// Build the field list back-to-front and reverse — matches json.nx
// `serialize_object_fields` ordering, which serialises in input order.
let reverse_fields = fn (xs: [JsonField], acc: [JsonField]) -> [JsonField] do
  match xs do
    | [] -> return acc
    | f :: rest -> return reverse_fields(xs: rest, acc: f :: acc)
  end
end

let diagnostic_to_json = fn (d: Diagnostic) -> JsonValue do
  match d do | Diagnostic(range, severity, code, source, message) ->
    let fields = [JsonField(key: "range", value: range_to_json(r: range))]
    let fields = match severity do
      | None -> fields
      | Some(val: s) ->
        JsonField(key: "severity", value: JsonInt(val: severity_to_int(s))) :: fields
    end
    let fields = match code do
      | None -> fields
      | Some(val: c) -> JsonField(key: "code", value: JsonString(val: c)) :: fields
    end
    let fields = match source do
      | None -> fields
      | Some(val: src) -> JsonField(key: "source", value: JsonString(val: src)) :: fields
    end
    let fields = JsonField(key: "message", value: JsonString(val: message)) :: fields
    return JsonObject(fields: reverse_fields(xs: fields, acc: []))
  end
end

// ─── Grand-fathered Option<T>-AND-throws family (nexus-8jnq.6) ────────────────
//
// The `optional_*` JSON parsers below have a genuine tri-state outcome dictated
// by the LSP wire protocol:
//   None  = field absent or JsonNull  (legitimate not-found)
//   Some  = field present and well-typed
//   throws { LspProtocolThrow } = field present but malformed (wrong JSON type)
//
// The throws is propagated from the strict `as_*` accessors and surfaces as an
// `InvalidParams` JSON-RPC response. See src/common/error.nx header for the
// general error-contract rule and why these helpers are grand-fathered.

let optional_string = fn (obj: JsonValue, key: string, ctx: string) -> Option<string> throws { LspProtocolThrow } do
  match optional_field(obj, key) do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ -> return Some(val: as_string(v, ctx))
      end
  end
end

let optional_severity = fn (obj: JsonValue) -> Option<DiagnosticSeverity> throws { LspProtocolThrow } do
  match optional_field(obj, key: "severity") do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ -> return Some(val: severity_from_int(n: as_i64(v, ctx: "Diagnostic.severity")))
      end
  end
end

let optional_code_string = fn (obj: JsonValue) -> Option<string> throws { LspProtocolThrow } do
  // Spec also permits integer; we coerce JsonInt → its decimal text since the
  // internal Diagnostic surface stores `code` as string.
  match optional_field(obj, key: "code") do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | JsonString(val: s) -> return Some(val: s)
        | JsonInt(val: _) ->
          raise LspProtocolError(msg: "Diagnostic.code as integer not supported (use string form)")
        | _ -> raise LspProtocolError(msg: "Diagnostic.code: expected string")
      end
  end
end

let diagnostic_from_json = fn (v: JsonValue) -> Diagnostic throws { LspProtocolThrow } do
  let range = range_from_json(v: require_field(obj: v, key: "range"))
  let severity = optional_severity(obj: v)
  let code = optional_code_string(obj: v)
  let source = optional_string(obj: v, key: "source", ctx: "Diagnostic.source")
  let message = as_string(v: require_field(obj: v, key: "message"), ctx: "Diagnostic.message")
  return Diagnostic(range, severity, code, source, message)
end

// ─── PublishDiagnosticsParams ────────────────────────────────────────────────

/** LSP `PublishDiagnosticsParams` (spec §"textDocument/publishDiagnostics") — the notification payload listing diagnostics for one `uri`. */
export type PublishDiagnosticsParams = PublishDiagnosticsParams(
  uri: string,
  /** Optional per spec; we allow None to round-trip explicit absence. */
  version: Option<i64>,
  diagnostics: [Diagnostic]
)

let diagnostics_to_json_items = fn (xs: [Diagnostic], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | d :: rest -> return diagnostics_to_json_items(xs: rest, acc: diagnostic_to_json(d) :: acc)
  end
end

let reverse_values = fn (xs: [JsonValue], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | v :: rest -> return reverse_values(xs: rest, acc: v :: acc)
  end
end

/** Encode `PublishDiagnosticsParams` as `{ uri, version?, diagnostics }` for the outbound notification. */
export let publish_diagnostics_params_to_json = fn (p: PublishDiagnosticsParams) -> JsonValue do
  match p do | PublishDiagnosticsParams(uri, version, diagnostics) ->
    let items_rev = diagnostics_to_json_items(xs: diagnostics, acc: [])
    let items = reverse_values(xs: items_rev, acc: [])
    let fields = [
      JsonField(key: "uri", value: JsonString(val: uri))
    ]
    let fields = match version do
      | None -> fields
      | Some(val: n) -> JsonField(key: "version", value: JsonInt(val: n)) :: fields
    end
    let fields = JsonField(key: "diagnostics", value: JsonArray(items)) :: fields
    return JsonObject(fields: reverse_fields(xs: fields, acc: []))
  end
end

let diagnostics_from_json_items = fn (xs: [JsonValue], acc: [Diagnostic]) -> [Diagnostic] throws { LspProtocolThrow } do
  match xs do
    | [] -> return acc
    | v :: rest ->
      let d = diagnostic_from_json(v)
      return diagnostics_from_json_items(xs: rest, acc: d :: acc)
  end
end

let reverse_diagnostics = fn (xs: [Diagnostic], acc: [Diagnostic]) -> [Diagnostic] do
  match xs do
    | [] -> return acc
    | d :: rest -> return reverse_diagnostics(xs: rest, acc: d :: acc)
  end
end

let optional_int = fn (obj: JsonValue, key: string, ctx: string) -> Option<i64> throws { LspProtocolThrow } do
  match optional_field(obj, key) do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ -> return Some(val: as_i64(v, ctx))
      end
  end
end

// ─── TextDocumentItem ────────────────────────────────────────────────────────

/** LSP `TextDocumentItem` (spec §"Text Documents") — `textDocument/didOpen` payload carrying full buffer text + initial version. */
export type TextDocumentItem = TextDocumentItem(
  uri: string,
  language_id: string,
  version: i64,
  text: string
)

/** Decode a `TextDocumentItem` from JSON; raises `LspProtocolError` on missing/mistyped fields. */
export let text_document_item_from_json = fn (v: JsonValue) -> TextDocumentItem throws { LspProtocolThrow } do
  let uri = as_string(v: require_field(obj: v, key: "uri"), ctx: "TextDocumentItem.uri")
  let language_id = as_string(v: require_field(obj: v, key: "languageId"), ctx: "TextDocumentItem.languageId")
  let version = as_i64(v: require_field(obj: v, key: "version"), ctx: "TextDocumentItem.version")
  let text = as_string(v: require_field(obj: v, key: "text"), ctx: "TextDocumentItem.text")
  return TextDocumentItem(uri, language_id, version, text)
end

// ─── VersionedTextDocumentIdentifier ─────────────────────────────────────────

/** LSP `VersionedTextDocumentIdentifier` (spec §"Text Documents") — `(uri, version)` pair stamped on `didChange` events. */
export type VersionedTextDocumentIdentifier = VersionedTextDocumentIdentifier(
  uri: string,
  version: i64
)

/** Decode a `VersionedTextDocumentIdentifier` from JSON; raises `LspProtocolError` on missing/mistyped fields. */
export let versioned_text_document_identifier_from_json = fn (v: JsonValue) -> VersionedTextDocumentIdentifier throws { LspProtocolThrow } do
  let uri = as_string(v: require_field(obj: v, key: "uri"), ctx: "VersionedTextDocumentIdentifier.uri")
  let version = as_i64(v: require_field(obj: v, key: "version"), ctx: "VersionedTextDocumentIdentifier.version")
  return VersionedTextDocumentIdentifier(uri, version)
end

// ─── TextDocumentContentChangeEvent ──────────────────────────────────────────
//
// LSP specifies a union: full-content change `{ text }` versus incremental
// change `{ range, rangeLength?, text }`. We model it as a sum so handlers
// dispatch with exhaustive matching; `range_length` follows the spec by being
// optional even on the incremental side (clients are not required to send it).

/** LSP `TextDocumentContentChangeEvent` (spec §"textDocument/didChange") — sum of full-buffer replace vs incremental edit; MVP only handles `ContentChangeFull`. */
export type TextDocumentContentChangeEvent =
    ContentChangeFull(text: string)
  | ContentChangeIncremental(range: Range, range_length: Option<i64>, text: string)

/** Decode a `TextDocumentContentChangeEvent`; presence of `range` selects the incremental variant. */
export let content_change_event_from_json = fn (v: JsonValue) -> TextDocumentContentChangeEvent throws { LspProtocolThrow } do
  let text = as_string(v: require_field(obj: v, key: "text"), ctx: "TextDocumentContentChangeEvent.text")
  match optional_field(obj: v, key: "range") do
    | None -> return ContentChangeFull(text)
    | Some(val: range_v) ->
      let range = range_from_json(v: range_v)
      let range_length = optional_int(obj: v, key: "rangeLength", ctx: "TextDocumentContentChangeEvent.rangeLength")
      return ContentChangeIncremental(range, range_length, text)
  end
end

// ─── SymbolKind ──────────────────────────────────────────────────────────────
//
// Spec enum 1..26. We only model the kinds the Nexus LSP server emits in MVP
// (Module, Function, Variable, Class, Method, Constant, Constructor); the
// rest pass through as `SymbolKindRaw(code)` to keep the codec total without
// committing to translating every spec entry today. Adding a named variant
// later is purely additive — existing matches that handle SymbolKindRaw stay
// valid because the new variant ships with its own integer.

/** LSP `SymbolKind` (spec §"DocumentSymbol", codes 1..26) — MVP names the kinds Nexus emits; unknown codes pass through as `SymbolKindRaw`. */
export type SymbolKind =
    SymbolKindModule
  | SymbolKindFunction
  | SymbolKindVariable
  | SymbolKindClass
  | SymbolKindMethod
  | SymbolKindConstant
  | SymbolKindConstructor
  | SymbolKindRaw(code: i64)

/** Map a SymbolKind to its LSP integer code (spec §"Document Symbols"; Function=12, Variable=13, etc.). SymbolKindRaw passes its code through. */
export let symbol_kind_to_int = fn (k: SymbolKind) -> i64 do
  match k do
    | SymbolKindFunction -> return 12
    | SymbolKindVariable -> return 13
    | SymbolKindConstant -> return 14
    | SymbolKindClass -> return 5
    | SymbolKindMethod -> return 6
    | SymbolKindConstructor -> return 9
    | SymbolKindModule -> return 2
    | SymbolKindRaw(code) -> return code
  end
end

let symbol_kind_from_int = fn (n: i64) -> SymbolKind do
  if n == 2 then return SymbolKindModule end
  if n == 5 then return SymbolKindClass end
  if n == 6 then return SymbolKindMethod end
  if n == 9 then return SymbolKindConstructor end
  if n == 12 then return SymbolKindFunction end
  if n == 13 then return SymbolKindVariable end
  if n == 14 then return SymbolKindConstant end
  return SymbolKindRaw(code: n)
end

// ─── DocumentSymbol ──────────────────────────────────────────────────────────
//
// Tree-shaped: each symbol may carry children. The wire payload is
// "DocumentSymbol[]" returned from textDocument/documentSymbol.

/** LSP DocumentSymbol (spec §"Document Symbols") — tree-shaped per-buffer symbol with name, detail, kind, full and selection ranges, plus nested children. */
export type DocumentSymbol = DocumentSymbol(
  name: string,
  detail: Option<string>,
  kind: SymbolKind,
  range: Range,
  selection_range: Range,
  children: [DocumentSymbol]
)

let symbols_to_json_items = fn (xs: [DocumentSymbol], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | s :: rest -> return symbols_to_json_items(xs: rest, acc: document_symbol_to_json(s) :: acc)
  end
end

/** Serialize a DocumentSymbol (and its children) to LSP wire JSON for `textDocument/documentSymbol` replies. */
export let document_symbol_to_json = fn (s: DocumentSymbol) -> JsonValue do
  match s do | DocumentSymbol(name, detail, kind, range, selection_range, children) ->
    let kids_rev = symbols_to_json_items(xs: children, acc: [])
    let kids = reverse_values(xs: kids_rev, acc: [])
    let fields = [
      JsonField(key: "name", value: JsonString(val: name))
    ]
    let fields = match detail do
      | None -> fields
      | Some(val: d) -> JsonField(key: "detail", value: JsonString(val: d)) :: fields
    end
    let fields = JsonField(key: "kind", value: JsonInt(val: symbol_kind_to_int(k: kind))) :: fields
    let fields = JsonField(key: "range", value: range_to_json(r: range)) :: fields
    let fields = JsonField(key: "selectionRange", value: range_to_json(r: selection_range)) :: fields
    let fields = JsonField(key: "children", value: JsonArray(items: kids)) :: fields
    return JsonObject(fields: reverse_fields(xs: fields, acc: []))
  end
end

let symbols_from_json_items = fn (xs: [JsonValue], acc: [DocumentSymbol]) -> [DocumentSymbol] throws { LspProtocolThrow } do
  match xs do
    | [] -> return acc
    | v :: rest ->
      let s = document_symbol_from_json(v)
      return symbols_from_json_items(xs: rest, acc: s :: acc)
  end
end

let reverse_symbols = fn (xs: [DocumentSymbol], acc: [DocumentSymbol]) -> [DocumentSymbol] do
  match xs do
    | [] -> return acc
    | s :: rest -> return reverse_symbols(xs: rest, acc: s :: acc)
  end
end

let document_symbol_from_json = fn (v: JsonValue) -> DocumentSymbol throws { LspProtocolThrow } do
  let name = as_string(v: require_field(obj: v, key: "name"), ctx: "DocumentSymbol.name")
  let detail = optional_string(obj: v, key: "detail", ctx: "DocumentSymbol.detail")
  let kind = symbol_kind_from_int(n: as_i64(v: require_field(obj: v, key: "kind"), ctx: "DocumentSymbol.kind"))
  let range = range_from_json(v: require_field(obj: v, key: "range"))
  let selection_range = range_from_json(v: require_field(obj: v, key: "selectionRange"))
  let children_rev = match optional_field(obj: v, key: "children") do
    | None -> []
    | Some(val: jv) ->
      match jv do
        | JsonNull -> []
        | _ ->
          let arr = as_array(v: jv, ctx: "DocumentSymbol.children")
          symbols_from_json_items(xs: arr, acc: [])
      end
  end
  let children = reverse_symbols(xs: children_rev, acc: [])
  return DocumentSymbol(name, detail, kind, range, selection_range, children)
end

// ─── SymbolInformation ──────────────────────────────────────────────────────
//
// Flat (URI-anchored) symbol used by `workspace/symbol`. Unlike DocumentSymbol
// (a tree relative to one buffer), each SymbolInformation carries its own
// Location, so the workspace-wide list can intermix entries from any number of
// open documents. `container_name` is the conventional slot for a parent
// scope (file path / module); we surface the canonical `source#name` lineage
// there so the client can disambiguate two identically-named exports across
// open files without polluting the displayed `name`.

/** LSP SymbolInformation (spec §"Workspace Symbols") — flat URI-anchored symbol returned by `workspace/symbol`; `container_name` carries the parent scope (e.g. `source#name` lineage). */
export type SymbolInformation = SymbolInformation(
  name: string,
  kind: SymbolKind,
  location: Location,
  container_name: Option<string>
)

/** Serialize a SymbolInformation (flat, URI-anchored) to LSP wire JSON for `workspace/symbol` replies. */
export let symbol_information_to_json = fn (s: SymbolInformation) -> JsonValue do
  match s do | SymbolInformation(name, kind, location, container_name) ->
    let fields = [JsonField(key: "name", value: JsonString(val: name))]
    let fields = JsonField(key: "kind", value: JsonInt(val: symbol_kind_to_int(k: kind))) :: fields
    let fields = JsonField(key: "location", value: location_to_json(loc: location)) :: fields
    let fields = match container_name do
      | None -> fields
      | Some(val: c) -> JsonField(key: "containerName", value: JsonString(val: c)) :: fields
    end
    return JsonObject(fields: reverse_fields(xs: fields, acc: []))
  end
end

let symbol_information_from_json = fn (v: JsonValue) -> SymbolInformation throws { LspProtocolThrow } do
  let name = as_string(v: require_field(obj: v, key: "name"), ctx: "SymbolInformation.name")
  let kind = symbol_kind_from_int(n: as_i64(v: require_field(obj: v, key: "kind"), ctx: "SymbolInformation.kind"))
  let location = location_from_json(v: require_field(obj: v, key: "location"))
  let container_name = optional_string(obj: v, key: "containerName", ctx: "SymbolInformation.containerName")
  return SymbolInformation(name, kind, location, container_name)
end

// ─── CompletionItemKind ──────────────────────────────────────────────────────
//
// Spec enum 1..25. The Nexus completion path emits a small, fixed subset
// (Function, Variable, Keyword, Field, EnumMember, Class, Module, Constructor);
// other codes pass through as `CompletionItemKindRaw(code)` so future kinds
// (Snippet, Color, Operator, etc.) can be threaded without breaking the codec.
//
// Numeric codes match the LSP spec table at §`CompletionItemKind`.
/** LSP CompletionItemKind (spec §"CompletionItemKind") — enum 1..25 of icons shown beside completion items.
 *  Unknown codes pass through as `CompletionItemKindRaw(code)` so future spec additions don't break the codec.
 */
export type CompletionItemKind =
    CikText
  | CikMethod
  | CikFunction
  | CikConstructor
  | CikField
  | CikVariable
  | CikClass
  | CikInterface
  | CikModule
  | CikProperty
  | CikUnit
  | CikValue
  | CikEnum
  | CikKeyword
  | CikSnippet
  | CikColor
  | CikFile
  | CikReference
  | CikFolder
  | CikEnumMember
  | CikConstant
  | CikStruct
  | CikEvent
  | CikOperator
  | CikTypeParameter
  | CompletionItemKindRaw(code: i64)

let completion_item_kind_to_int = fn (k: CompletionItemKind) -> i64 do
  match k do
    | CikText -> return 1
    | CikMethod -> return 2
    | CikFunction -> return 3
    | CikConstructor -> return 4
    | CikField -> return 5
    | CikVariable -> return 6
    | CikClass -> return 7
    | CikInterface -> return 8
    | CikModule -> return 9
    | CikProperty -> return 10
    | CikUnit -> return 11
    | CikValue -> return 12
    | CikEnum -> return 13
    | CikKeyword -> return 14
    | CikSnippet -> return 15
    | CikColor -> return 16
    | CikFile -> return 17
    | CikReference -> return 18
    | CikFolder -> return 19
    | CikEnumMember -> return 20
    | CikConstant -> return 21
    | CikStruct -> return 22
    | CikEvent -> return 23
    | CikOperator -> return 24
    | CikTypeParameter -> return 25
    | CompletionItemKindRaw(code) -> return code
  end
end

// ─── CompletionItem (wire) ───────────────────────────────────────────────────
//
// MVP shape per LSP §`CompletionItem`: `label` (the surface name shown in the
// popup) plus optional `kind`, `detail` (a one-liner shown alongside), and
// `documentation` (markdown / plaintext). All other fields (sortText,
// filterText, insertText, textEdit, additionalTextEdits, command, ...) are
// post-MVP; the resolver emits them by extending this record additively.

/** LSP CompletionItem (spec §"CompletionItem") — single candidate in a completion popup.
 *  MVP carries only `label`, optional `kind`, `detail` (one-liner), and `documentation`; richer fields (textEdit, command, ...) are post-MVP additive extensions.
 */
export type CompletionItem = CompletionItem(
  label: string,
  kind: Option<CompletionItemKind>,
  detail: Option<string>,
  documentation: Option<string>
)

let completion_item_to_json = fn (c: CompletionItem) -> JsonValue do
  match c do | CompletionItem(label, kind, detail, documentation) ->
    let fields = [JsonField(key: "label", value: JsonString(val: label))]
    let fields = match kind do
      | None -> fields
      | Some(val: k) ->
        JsonField(key: "kind", value: JsonInt(val: completion_item_kind_to_int(k))) :: fields
    end
    let fields = match detail do
      | None -> fields
      | Some(val: d) -> JsonField(key: "detail", value: JsonString(val: d)) :: fields
    end
    let fields = match documentation do
      | None -> fields
      | Some(val: doc) -> JsonField(key: "documentation", value: JsonString(val: doc)) :: fields
    end
    return JsonObject(fields: reverse_fields(xs: fields, acc: []))
  end
end

// ─── CompletionList (wire) ───────────────────────────────────────────────────
//
// `isIncomplete: false` means the server returned the complete candidate set
// for the cursor's prefix; clients cache and filter locally. Phase 1 always
// returns false — every visible identifier in scope plus the keyword list is
// fully enumerable in one pass.

/** LSP CompletionList (spec §"CompletionList") — response payload for `textDocument/completion`.
 *  `is_incomplete: false` tells the client the candidate set is complete for the cursor's prefix and may be cached/filtered locally.
 */
export type CompletionList = CompletionList(
  is_incomplete: bool,
  items: [CompletionItem]
)

let completion_items_to_json_items = fn (xs: [CompletionItem], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | c :: rest -> return completion_items_to_json_items(xs: rest, acc: completion_item_to_json(c) :: acc)
  end
end

/** Serialize a CompletionList (LSP `textDocument/completion` reply) — `isIncomplete` flag plus `items` array. */
export let completion_list_to_json = fn (cl: CompletionList) -> JsonValue do
  match cl do | CompletionList(is_incomplete, items) ->
    let items_rev = completion_items_to_json_items(xs: items, acc: [])
    let items_json = reverse_values(xs: items_rev, acc: [])
    return JsonObject(fields: [
      JsonField(key: "isIncomplete", value: JsonBool(val: is_incomplete)),
      JsonField(key: "items", value: JsonArray(items: items_json))
    ])
  end
end

// ─── SignatureHelp (wire) ────────────────────────────────────────────────────
//
// LSP §`SignatureHelp`. A response to `textDocument/signatureHelp` contains
// one or more SignatureInformation entries describing the candidate overloads
// for the call under the cursor; Nexus has no overload resolution so we emit
// exactly one entry on a hit and `null` on a miss.
//
// Each SignatureInformation carries `label` (the rendered call shape — e.g.
// `f(x: i64, y: string)`) plus a `parameters` array of ParameterInformation
// values. Each parameter's `label` is the raw parameter token the client uses
// to look it up inside `signature.label`; we emit the parameter name (LSP
// also accepts a `[start, end]` offset pair, but the name-string form is
// simpler and the client substring-matches it against the label).
//
// `activeSignature` is always 0 (single signature). `activeParameter` tracks
// which parameter the cursor is currently inside (post-comma count) — when
// the call has no args yet or the cursor is past the last comma, we report
// the index of the leading / trailing argument respectively.

/** LSP ParameterInformation (spec §"Signature Help") — one parameter entry inside a SignatureInformation's `parameters` array; `label` is the raw parameter token the client substring-matches against the rendered signature label. */
export type ParameterInformation = ParameterInformation(
  label: string,
  documentation: Option<string>
)

let parameter_information_to_json = fn (p: ParameterInformation) -> JsonValue do
  match p do | ParameterInformation(label, documentation) ->
    let fields = [JsonField(key: "label", value: JsonString(val: label))]
    let fields = match documentation do
      | None -> fields
      | Some(val: doc) -> JsonField(key: "documentation", value: JsonString(val: doc)) :: fields
    end
    return JsonObject(fields: reverse_fields(xs: fields, acc: []))
  end
end

/** LSP SignatureInformation (spec §"Signature Help") — rendered call shape, optional doc, parameter info, and which parameter the cursor is currently inside. */
export type SignatureInformation = SignatureInformation(
  label: string,
  documentation: Option<string>,
  parameters: [ParameterInformation],
  active_parameter: Option<i64>
)

let param_infos_to_json_items = fn (xs: [ParameterInformation], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | p :: rest -> return param_infos_to_json_items(xs: rest, acc: parameter_information_to_json(p) :: acc)
  end
end

let signature_information_to_json = fn (s: SignatureInformation) -> JsonValue do
  match s do | SignatureInformation(label, documentation, parameters, active_parameter) ->
    let params_rev = param_infos_to_json_items(xs: parameters, acc: [])
    let params_json = reverse_values(xs: params_rev, acc: [])
    let fields = [JsonField(key: "label", value: JsonString(val: label))]
    let fields = match documentation do
      | None -> fields
      | Some(val: doc) -> JsonField(key: "documentation", value: JsonString(val: doc)) :: fields
    end
    let fields = JsonField(key: "parameters", value: JsonArray(items: params_json)) :: fields
    let fields = match active_parameter do
      | None -> fields
      | Some(val: i) -> JsonField(key: "activeParameter", value: JsonInt(val: i)) :: fields
    end
    return JsonObject(fields: reverse_fields(xs: fields, acc: []))
  end
end

/** LSP SignatureHelp (spec §"Signature Help") — the full reply: list of candidate signatures plus active-signature / active-parameter indices. */
export type SignatureHelp = SignatureHelp(
  signatures: [SignatureInformation],
  active_signature: Option<i64>,
  active_parameter: Option<i64>
)

let sig_infos_to_json_items = fn (xs: [SignatureInformation], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | s :: rest -> return sig_infos_to_json_items(xs: rest, acc: signature_information_to_json(s) :: acc)
  end
end

/** Serialize a SignatureHelp to LSP wire JSON for `textDocument/signatureHelp` replies. */
export let signature_help_to_json = fn (h: SignatureHelp) -> JsonValue do
  match h do | SignatureHelp(signatures, active_signature, active_parameter) ->
    let sigs_rev = sig_infos_to_json_items(xs: signatures, acc: [])
    let sigs_json = reverse_values(xs: sigs_rev, acc: [])
    let fields = [JsonField(key: "signatures", value: JsonArray(items: sigs_json))]
    let fields = match active_signature do
      | None -> fields
      | Some(val: i) -> JsonField(key: "activeSignature", value: JsonInt(val: i)) :: fields
    end
    let fields = match active_parameter do
      | None -> fields
      | Some(val: i) -> JsonField(key: "activeParameter", value: JsonInt(val: i)) :: fields
    end
    return JsonObject(fields: reverse_fields(xs: fields, acc: []))
  end
end

// ─── SignatureHelpOptions (server capability) ────────────────────────────────
//
// Advertised inside ServerCapabilities. `triggerCharacters` makes the editor
// re-query signature help when one of these characters is typed (`(` opens
// the popup, `,` advances to the next parameter). The Nexus MVP does not
// support `retrigger_characters` (refining an existing popup), so the field
// is omitted from the wire form.

/** LSP SignatureHelpOptions (spec §"Server Capabilities") — server capability advertising trigger characters (e.g. `(`, `,`) that re-query `textDocument/signatureHelp`. */
export type SignatureHelpOptions = SignatureHelpOptions(
  trigger_characters: [string]
)

let signature_help_options_to_json = fn (opts: SignatureHelpOptions) -> JsonValue do
  match opts do | SignatureHelpOptions(trigger_characters) ->
    let items_rev = strings_to_json_items(xs: trigger_characters, acc: [])
    let items = reverse_values(xs: items_rev, acc: [])
    return JsonObject(fields: [
      JsonField(key: "triggerCharacters", value: JsonArray(items))
    ])
  end
end

// ─── SemanticTokens (wire) ───────────────────────────────────────────────────
//
// LSP §`textDocument/semanticTokens/full` returns a `SemanticTokens` object
// containing a flat `data: number[]` array of 5-tuples (deltaLine, deltaStart,
// length, tokenType, tokenModifiers) — each tuple delta-encoded relative to
// the previous token. The client decodes these against the legend advertised
// in `ServerCapabilities.semanticTokensProvider.legend`.
//
// MVP token-type legend (issue nexus-2nef): keyword, function, variable,
// parameter, type, variant, string, number, comment, operator. Modifiers are
// always emitted as 0 (no modifier bits set); modifier semantics are an
// additive extension and can grow without breaking the wire layout.

/** LSP SemanticTokens (spec §"Semantic Tokens") — response payload for `textDocument/semanticTokens/full`; flat `data` array of delta-encoded 5-tuples (deltaLine, deltaStart, length, tokenType, tokenModifiers) decoded against the server's advertised legend. */
export type SemanticTokens = SemanticTokens(data: [i64])

let data_items_to_json_items = fn (xs: [i64], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | n :: rest -> return data_items_to_json_items(xs: rest, acc: JsonInt(val: n) :: acc)
  end
end

/** Serialize a SemanticTokens to LSP wire JSON for `textDocument/semanticTokens/full` replies — flat `data` array of delta-encoded 5-tuples. */
export let semantic_tokens_to_json = fn (st: SemanticTokens) -> JsonValue do
  match st do | SemanticTokens(data) ->
    let items_rev = data_items_to_json_items(xs: data, acc: [])
    let items = reverse_values(xs: items_rev, acc: [])
    return JsonObject(fields: [
      JsonField(key: "data", value: JsonArray(items))
    ])
  end
end

// ─── SemanticTokensLegend (server capability) ───────────────────────────────
//
// Advertised inside `ServerCapabilities.semanticTokensProvider`. The legend
// is a fixed pair of string arrays (token types and token modifiers). The
// numeric indices the server emits in the `data` stream reference these
// arrays by position. The legend is part of the static server contract for
// a given session — clients build their decoder from this list at
// `initialize` time.

/** LSP SemanticTokensLegend (spec §"Semantic Tokens") — fixed pair of string arrays the client uses to decode the numeric `tokenType`/`tokenModifiers` indices emitted in `SemanticTokens.data`.
 *  Advertised once at `initialize` time inside `ServerCapabilities.semanticTokensProvider`.
 */
export type SemanticTokensLegend = SemanticTokensLegend(
  token_types: [string],
  token_modifiers: [string]
)

let semantic_tokens_legend_to_json = fn (l: SemanticTokensLegend) -> JsonValue do
  match l do | SemanticTokensLegend(token_types, token_modifiers) ->
    let t_items_rev = strings_to_json_items(xs: token_types, acc: [])
    let t_items = reverse_values(xs: t_items_rev, acc: [])
    let m_items_rev = strings_to_json_items(xs: token_modifiers, acc: [])
    let m_items = reverse_values(xs: m_items_rev, acc: [])
    return JsonObject(fields: [
      JsonField(key: "tokenTypes", value: JsonArray(items: t_items)),
      JsonField(key: "tokenModifiers", value: JsonArray(items: m_items))
    ])
  end
end

// ─── SemanticTokensOptions (server capability) ──────────────────────────────
//
// Advertised inside `ServerCapabilities.semanticTokensProvider`. The MVP
// supports only the `full` request shape; `range` and `full/delta` are
// post-MVP (clients re-request `full` on every keystroke today — the LSP
// reference VS Code client coalesces requests so this is the conventional
// starting point).

/** LSP SemanticTokensOptions (spec §"Server Capabilities") — server capability advertising the semantic-tokens legend and which request shapes are supported; MVP advertises only `full`. */
export type SemanticTokensOptions = SemanticTokensOptions(
  legend: SemanticTokensLegend,
  full: bool
)

let semantic_tokens_options_to_json = fn (opts: SemanticTokensOptions) -> JsonValue do
  match opts do | SemanticTokensOptions(legend, full) ->
    return JsonObject(fields: [
      JsonField(key: "legend", value: semantic_tokens_legend_to_json(l: legend)),
      JsonField(key: "full", value: JsonBool(val: full))
    ])
  end
end

// ─── CompletionOptions (server capability) ───────────────────────────────────
//
// Advertised inside ServerCapabilities. `triggerCharacters` makes the editor
// re-query completion when one of these characters is typed (e.g. `.` for
// future record-field / qualified-name expansion). `resolveProvider: false`
// promises every CompletionItem we emit is already complete — clients won't
// issue a follow-up `completionItem/resolve`.

/** LSP CompletionOptions (spec §"Server Capabilities") — server capability advertising completion trigger characters and whether the server emits a `completionItem/resolve` follow-up; MVP keeps `resolve_provider: false` (every CompletionItem is already complete). */
export type CompletionOptions = CompletionOptions(
  trigger_characters: [string],
  resolve_provider: bool
)

let strings_to_json_items = fn (xs: [string], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | s :: rest -> return strings_to_json_items(xs: rest, acc: JsonString(val: s) :: acc)
  end
end

let completion_options_to_json = fn (opts: CompletionOptions) -> JsonValue do
  match opts do | CompletionOptions(trigger_characters, resolve_provider) ->
    let items_rev = strings_to_json_items(xs: trigger_characters, acc: [])
    let items = reverse_values(xs: items_rev, acc: [])
    return JsonObject(fields: [
      JsonField(key: "triggerCharacters", value: JsonArray(items)),
      JsonField(key: "resolveProvider", value: JsonBool(val: resolve_provider))
    ])
  end
end

// ─── ServerCapabilities ──────────────────────────────────────────────────────
//
// Only `textDocumentSync` (numeric kind) and `documentSymbolProvider` are
// surfaced for MVP; the spec defines dozens more. We keep the type extensible
// by storing a `raw_extra` JsonValue containing the untouched original input
// (or JsonObject(fields: []) when fresh-built). This lets future additions
// (hoverProvider, definitionProvider, ...) flow through without breaking
// callers that already constructed a ServerCapabilities — the to_json merge
// preserves their extra fields.

/** LSP TextDocumentSyncKind (spec §"TextDocumentSyncKind") — server sync mode: `TdsNone` (0), `TdsFull` (1), or `TdsIncremental` (2). */
export type TextDocumentSyncKind =
    TdsNone
  | TdsFull
  | TdsIncremental

let text_document_sync_kind_to_int = fn (k: TextDocumentSyncKind) -> i64 do
  match k do
    | TdsNone -> return 0
    | TdsFull -> return 1
    | TdsIncremental -> return 2
  end
end

let text_document_sync_kind_from_int = fn (n: i64) -> TextDocumentSyncKind throws { LspProtocolThrow } do
  if n == 0 then return TdsNone end
  if n == 1 then return TdsFull end
  if n == 2 then return TdsIncremental end
  raise LspProtocolError(msg: "TextDocumentSyncKind out of range (0..2)")
end

/** LSP ServerCapabilities (spec §"Server Capabilities") — the bundle returned in `InitializeResult.capabilities` declaring which LSP features this server implements.
 *  Each `Option` field maps to the corresponding spec capability; `None` omits the field entirely from the wire payload (clients treat absence as "unsupported").
 */
export type ServerCapabilities = ServerCapabilities(
  text_document_sync: Option<TextDocumentSyncKind>,
  document_symbol_provider: Option<bool>,
  hover_provider: Option<bool>,
  definition_provider: Option<bool>,
  references_provider: Option<bool>,
  completion_provider: Option<CompletionOptions>,
  signature_help_provider: Option<SignatureHelpOptions>,
  semantic_tokens_provider: Option<SemanticTokensOptions>,
  document_formatting_provider: Option<bool>,
  workspace_symbol_provider: Option<bool>
)

let server_capabilities_to_json = fn (caps: ServerCapabilities) -> JsonValue do
  match caps do | ServerCapabilities(text_document_sync, document_symbol_provider,
                                     hover_provider, definition_provider, references_provider,
                                     completion_provider, signature_help_provider,
                                     semantic_tokens_provider, document_formatting_provider,
                                     workspace_symbol_provider) ->
    let fields: [JsonField] = []
    let fields = match text_document_sync do
      | None -> fields
      | Some(val: k) ->
        JsonField(key: "textDocumentSync", value: JsonInt(val: text_document_sync_kind_to_int(k))) :: fields
    end
    let fields = match document_symbol_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "documentSymbolProvider", value: JsonBool(val: b)) :: fields
    end
    let fields = match hover_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "hoverProvider", value: JsonBool(val: b)) :: fields
    end
    let fields = match definition_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "definitionProvider", value: JsonBool(val: b)) :: fields
    end
    let fields = match references_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "referencesProvider", value: JsonBool(val: b)) :: fields
    end
    let fields = match completion_provider do
      | None -> fields
      | Some(val: opts) ->
        JsonField(key: "completionProvider", value: completion_options_to_json(opts)) :: fields
    end
    let fields = match signature_help_provider do
      | None -> fields
      | Some(val: opts) ->
        JsonField(key: "signatureHelpProvider", value: signature_help_options_to_json(opts)) :: fields
    end
    let fields = match semantic_tokens_provider do
      | None -> fields
      | Some(val: opts) ->
        JsonField(key: "semanticTokensProvider", value: semantic_tokens_options_to_json(opts)) :: fields
    end
    let fields = match document_formatting_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "documentFormattingProvider", value: JsonBool(val: b)) :: fields
    end
    let fields = match workspace_symbol_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "workspaceSymbolProvider", value: JsonBool(val: b)) :: fields
    end
    return JsonObject(fields: reverse_fields(xs: fields, acc: []))
  end
end

let optional_bool = fn (obj: JsonValue, key: string, ctx: string) -> Option<bool> throws { LspProtocolThrow } do
  match optional_field(obj, key) do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ -> return Some(val: as_bool(v, ctx))
      end
  end
end

let optional_text_document_sync_kind = fn (obj: JsonValue) -> Option<TextDocumentSyncKind> throws { LspProtocolThrow } do
  match optional_field(obj, key: "textDocumentSync") do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ ->
          let n = as_i64(v, ctx: "ServerCapabilities.textDocumentSync")
          return Some(val: text_document_sync_kind_from_int(n))
      end
  end
end

let server_capabilities_from_json = fn (v: JsonValue) -> ServerCapabilities throws { LspProtocolThrow } do
  let tds = optional_text_document_sync_kind(obj: v)
  let dsp = optional_bool(obj: v, key: "documentSymbolProvider", ctx: "ServerCapabilities.documentSymbolProvider")
  let hov = optional_bool(obj: v, key: "hoverProvider", ctx: "ServerCapabilities.hoverProvider")
  let def = optional_bool(obj: v, key: "definitionProvider", ctx: "ServerCapabilities.definitionProvider")
  let refs = optional_bool(obj: v, key: "referencesProvider", ctx: "ServerCapabilities.referencesProvider")
  let fmtp = optional_bool(obj: v, key: "documentFormattingProvider", ctx: "ServerCapabilities.documentFormattingProvider")
  let wsp = optional_bool(obj: v, key: "workspaceSymbolProvider", ctx: "ServerCapabilities.workspaceSymbolProvider")
  // CompletionProvider round-trip is intentionally lossy on the decode path:
  // tests assert the encoded shape directly, and the LSP loop never reads
  // its own advertised capabilities back. Surface as None so existing
  // round-trip tests on the encoder don't regress.
  return ServerCapabilities(
    text_document_sync: tds,
    document_symbol_provider: dsp,
    hover_provider: hov,
    definition_provider: def,
    references_provider: refs,
    completion_provider: None,
    // SignatureHelpProvider round-trip is intentionally lossy on the decode
    // path (same rationale as completionProvider above).
    signature_help_provider: None,
    // SemanticTokensProvider round-trip is intentionally lossy on the decode
    // path (same rationale as completionProvider above).
    semantic_tokens_provider: None,
    document_formatting_provider: fmtp,
    workspace_symbol_provider: wsp
  )
end

// ─── InitializeParams ────────────────────────────────────────────────────────
//
// `process_id` is `integer | null`; the spec also permits clients to omit the
// field entirely (older protocol versions). We accept all three and surface
// the absence as None.
// `client_capabilities` is intentionally typed as JsonValue: the spec defines
// hundreds of nested optional fields, none of which the MVP server reads.
// Storing the raw payload is an explicit pass-through — a future server
// upgrade adds a typed `ClientCapabilities` field next to this one rather
// than rebuilding the InitializeParams shape.

/** LSP InitializeParams (spec §"Initialize Request") — payload of the first `initialize` request a client sends.
 *  `client_capabilities` is kept as raw `JsonValue` since the MVP server doesn't introspect it; `process_id` accepts `integer | null | omitted` per spec.
 */
export type InitializeParams = InitializeParams(
  process_id: Option<i64>,
  root_uri: Option<string>,
  client_capabilities: JsonValue,
  trace: Option<string>
)

let optional_pid = fn (obj: JsonValue) -> Option<i64> throws { LspProtocolThrow } do
  match optional_field(obj, key: "processId") do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ -> return Some(val: as_i64(v, ctx: "InitializeParams.processId"))
      end
  end
end

let optional_root_uri = fn (obj: JsonValue) -> Option<string> throws { LspProtocolThrow } do
  match optional_field(obj, key: "rootUri") do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ -> return Some(val: as_string(v, ctx: "InitializeParams.rootUri"))
      end
  end
end

/** Decode an LSP `initialize` request's `params` object (spec §"Initialize Request") into an InitializeParams; raises `LspProtocolError` on schema violations. */
export let initialize_params_from_json = fn (v: JsonValue) -> InitializeParams throws { LspProtocolThrow } do
  let process_id = optional_pid(obj: v)
  let root_uri = optional_root_uri(obj: v)
  let client_capabilities = match optional_field(obj: v, key: "capabilities") do
    | None -> JsonObject(fields: [])
    | Some(val: c) -> c
  end
  let trace = optional_string(obj: v, key: "trace", ctx: "InitializeParams.trace")
  return InitializeParams(process_id, root_uri, client_capabilities, trace)
end

// ─── InitializeResult ────────────────────────────────────────────────────────

/** LSP ServerInfo (spec §"Initialize Result") — optional server identification carried inside `InitializeResult.serverInfo`: server `name` and optional `version` string. */
export type ServerInfo = ServerInfo(name: string, version: Option<string>)

let server_info_to_json = fn (info: ServerInfo) -> JsonValue do
  match info do | ServerInfo(name, version) ->
    let fields = [JsonField(key: "name", value: JsonString(val: name))]
    let fields = match version do
      | None -> fields
      | Some(val: vstr) -> JsonField(key: "version", value: JsonString(val: vstr)) :: fields
    end
    return JsonObject(fields: reverse_fields(xs: fields, acc: []))
  end
end

let server_info_from_json = fn (v: JsonValue) -> ServerInfo throws { LspProtocolThrow } do
  let name = as_string(v: require_field(obj: v, key: "name"), ctx: "ServerInfo.name")
  let version = optional_string(obj: v, key: "version", ctx: "ServerInfo.version")
  return ServerInfo(name, version)
end

/** LSP InitializeResult (spec §"Initialize Result") — server's response to `initialize`, carrying advertised `capabilities` and optional `server_info`. */
export type InitializeResult = InitializeResult(
  capabilities: ServerCapabilities,
  server_info: Option<ServerInfo>
)

/** Serialize an InitializeResult to the JSON payload sent in reply to an LSP `initialize` request (spec §"Initialize Result"). */
export let initialize_result_to_json = fn (r: InitializeResult) -> JsonValue do
  match r do | InitializeResult(capabilities, server_info) ->
    let fields = [
      JsonField(key: "capabilities", value: server_capabilities_to_json(caps: capabilities))
    ]
    let fields = match server_info do
      | None -> fields
      | Some(val: info) -> JsonField(key: "serverInfo", value: server_info_to_json(info)) :: fields
    end
    return JsonObject(fields: reverse_fields(xs: fields, acc: []))
  end
end
