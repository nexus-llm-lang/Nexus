/**
 * lsp/protocol/completion: LSP completion, signature-help, semantic-tokens,
 * and server-capabilities wire types.
 *
 * Covers CompletionItemKind, CompletionItem, CompletionList, CompletionOptions,
 * ParameterInformation, SignatureInformation, SignatureHelp, SignatureHelpOptions,
 * SemanticTokens, SemanticTokensLegend, SemanticTokensOptions,
 * ServerCapabilities, InitializeParams, ServerInfo, and InitializeResult.
 */

import { JsonValue, JsonField, JsonInt, JsonString,
         JsonObject, JsonArray, JsonBool, JsonNull } from "std:json"
import * as list from "std:list"
import { Option, Some, None } from "std:option"
import {
  LspProtocolThrow, LspProtocolError,
  require_field, optional_field,
  as_string, as_i64, as_bool,
  optional_string, optional_int, optional_bool,
  strings_to_json_items
} from "src/lsp/protocol/json.nx"
import {
  TextDocumentSyncKind,
  text_document_sync_kind_to_int, text_document_sync_kind_from_int
} from "src/lsp/protocol/text_doc.nx"

// ─── CompletionItemKind ──────────────────────────────────────────────────────
//
// Spec enum 1..25. The Nexus completion path emits a small, fixed subset
// (Function, Variable, Keyword, Field, EnumMember, Class, Module, Constructor);
// other codes pass through as `CompletionItemKindRaw(code)` so future kinds
// (Snippet, Color, Operator, etc.) can be threaded without breaking the codec.
//
// Numeric codes match the LSP spec table at §`CompletionItemKind`.
/** LSP CompletionItemKind (spec §"CompletionItemKind") — enum 1..25 of icons shown beside completion items.
 *  Unknown codes pass through as `CompletionItemKindRaw(code)` so future spec additions don't break the codec.
 */
export type CompletionItemKind =
    CikText
  | CikMethod
  | CikFunction
  | CikConstructor
  | CikField
  | CikVariable
  | CikClass
  | CikInterface
  | CikModule
  | CikProperty
  | CikUnit
  | CikValue
  | CikEnum
  | CikKeyword
  | CikSnippet
  | CikColor
  | CikFile
  | CikReference
  | CikFolder
  | CikEnumMember
  | CikConstant
  | CikStruct
  | CikEvent
  | CikOperator
  | CikTypeParameter
  | CompletionItemKindRaw(code: i64)

let completion_item_kind_to_int = fn (k: CompletionItemKind) -> i64 do
  match k do
    | CikText -> return 1
    | CikMethod -> return 2
    | CikFunction -> return 3
    | CikConstructor -> return 4
    | CikField -> return 5
    | CikVariable -> return 6
    | CikClass -> return 7
    | CikInterface -> return 8
    | CikModule -> return 9
    | CikProperty -> return 10
    | CikUnit -> return 11
    | CikValue -> return 12
    | CikEnum -> return 13
    | CikKeyword -> return 14
    | CikSnippet -> return 15
    | CikColor -> return 16
    | CikFile -> return 17
    | CikReference -> return 18
    | CikFolder -> return 19
    | CikEnumMember -> return 20
    | CikConstant -> return 21
    | CikStruct -> return 22
    | CikEvent -> return 23
    | CikOperator -> return 24
    | CikTypeParameter -> return 25
    | CompletionItemKindRaw(code) -> return code
  end
end

// ─── CompletionItem (wire) ───────────────────────────────────────────────────
//
// MVP shape per LSP §`CompletionItem`: `label` (the surface name shown in the
// popup) plus optional `kind`, `detail` (a one-liner shown alongside), and
// `documentation` (markdown / plaintext). All other fields (sortText,
// filterText, insertText, textEdit, additionalTextEdits, command, ...) are
// post-MVP; the resolver emits them by extending this record additively.

/** LSP CompletionItem (spec §"CompletionItem") — single candidate in a completion popup.
 *  MVP carries only `label`, optional `kind`, `detail` (one-liner), and `documentation`; richer fields (textEdit, command, ...) are post-MVP additive extensions.
 */
export type CompletionItem = CompletionItem(
  label: string,
  kind: Option<CompletionItemKind>,
  detail: Option<string>,
  documentation: Option<string>
)

let completion_item_to_json = fn (c: CompletionItem) -> JsonValue do
  match c do | CompletionItem(label, kind, detail, documentation) ->
    let fields = [JsonField(key: "label", value: JsonString(val: label))]
    let fields = match kind do
      | None -> fields
      | Some(val: k) ->
        JsonField(key: "kind", value: JsonInt(val: completion_item_kind_to_int(k))) :: fields
    end
    let fields = match detail do
      | None -> fields
      | Some(val: d) -> JsonField(key: "detail", value: JsonString(val: d)) :: fields
    end
    let fields = match documentation do
      | None -> fields
      | Some(val: doc) -> JsonField(key: "documentation", value: JsonString(val: doc)) :: fields
    end
    return JsonObject(fields: list.reverse(xs: fields))
  end
end

// ─── CompletionList (wire) ───────────────────────────────────────────────────
//
// `isIncomplete: false` means the server returned the complete candidate set
// for the cursor's prefix; clients cache and filter locally. Phase 1 always
// returns false — every visible identifier in scope plus the keyword list is
// fully enumerable in one pass.

/** LSP CompletionList (spec §"CompletionList") — response payload for `textDocument/completion`.
 *  `is_incomplete: false` tells the client the candidate set is complete for the cursor's prefix and may be cached/filtered locally.
 */
export type CompletionList = CompletionList(
  is_incomplete: bool,
  items: [CompletionItem]
)

let completion_items_to_json_items = fn (xs: [CompletionItem], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | c :: rest -> return completion_items_to_json_items(xs: rest, acc: completion_item_to_json(c) :: acc)
  end
end

/** Serialize a CompletionList (LSP `textDocument/completion` reply) — `isIncomplete` flag plus `items` array. */
export let completion_list_to_json = fn (cl: CompletionList) -> JsonValue do
  match cl do | CompletionList(is_incomplete, items) ->
    let items_rev = completion_items_to_json_items(xs: items, acc: [])
    let items_json = list.reverse(xs: items_rev)
    return JsonObject(fields: [
      JsonField(key: "isIncomplete", value: JsonBool(val: is_incomplete)),
      JsonField(key: "items", value: JsonArray(items: items_json))
    ])
  end
end

// ─── SignatureHelp (wire) ────────────────────────────────────────────────────
//
// LSP §`SignatureHelp`. A response to `textDocument/signatureHelp` contains
// one or more SignatureInformation entries describing the candidate overloads
// for the call under the cursor; Nexus has no overload resolution so we emit
// exactly one entry on a hit and `null` on a miss.

/** LSP ParameterInformation (spec §"Signature Help") — one parameter entry inside a SignatureInformation's `parameters` array; `label` is the raw parameter token the client substring-matches against the rendered signature label. */
export type ParameterInformation = ParameterInformation(
  label: string,
  documentation: Option<string>
)

let parameter_information_to_json = fn (p: ParameterInformation) -> JsonValue do
  match p do | ParameterInformation(label, documentation) ->
    let fields = [JsonField(key: "label", value: JsonString(val: label))]
    let fields = match documentation do
      | None -> fields
      | Some(val: doc) -> JsonField(key: "documentation", value: JsonString(val: doc)) :: fields
    end
    return JsonObject(fields: list.reverse(xs: fields))
  end
end

/** LSP SignatureInformation (spec §"Signature Help") — rendered call shape, optional doc, parameter info, and which parameter the cursor is currently inside. */
export type SignatureInformation = SignatureInformation(
  label: string,
  documentation: Option<string>,
  parameters: [ParameterInformation],
  active_parameter: Option<i64>
)

let param_infos_to_json_items = fn (xs: [ParameterInformation], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | p :: rest -> return param_infos_to_json_items(xs: rest, acc: parameter_information_to_json(p) :: acc)
  end
end

let signature_information_to_json = fn (s: SignatureInformation) -> JsonValue do
  match s do | SignatureInformation(label, documentation, parameters, active_parameter) ->
    let params_rev = param_infos_to_json_items(xs: parameters, acc: [])
    let params_json = list.reverse(xs: params_rev)
    let fields = [JsonField(key: "label", value: JsonString(val: label))]
    let fields = match documentation do
      | None -> fields
      | Some(val: doc) -> JsonField(key: "documentation", value: JsonString(val: doc)) :: fields
    end
    let fields = JsonField(key: "parameters", value: JsonArray(items: params_json)) :: fields
    let fields = match active_parameter do
      | None -> fields
      | Some(val: i) -> JsonField(key: "activeParameter", value: JsonInt(val: i)) :: fields
    end
    return JsonObject(fields: list.reverse(xs: fields))
  end
end

/** LSP SignatureHelp (spec §"Signature Help") — the full reply: list of candidate signatures plus active-signature / active-parameter indices. */
export type SignatureHelp = SignatureHelp(
  signatures: [SignatureInformation],
  active_signature: Option<i64>,
  active_parameter: Option<i64>
)

let sig_infos_to_json_items = fn (xs: [SignatureInformation], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | s :: rest -> return sig_infos_to_json_items(xs: rest, acc: signature_information_to_json(s) :: acc)
  end
end

/** Serialize a SignatureHelp to LSP wire JSON for `textDocument/signatureHelp` replies. */
export let signature_help_to_json = fn (h: SignatureHelp) -> JsonValue do
  match h do | SignatureHelp(signatures, active_signature, active_parameter) ->
    let sigs_rev = sig_infos_to_json_items(xs: signatures, acc: [])
    let sigs_json = list.reverse(xs: sigs_rev)
    let fields = [JsonField(key: "signatures", value: JsonArray(items: sigs_json))]
    let fields = match active_signature do
      | None -> fields
      | Some(val: i) -> JsonField(key: "activeSignature", value: JsonInt(val: i)) :: fields
    end
    let fields = match active_parameter do
      | None -> fields
      | Some(val: i) -> JsonField(key: "activeParameter", value: JsonInt(val: i)) :: fields
    end
    return JsonObject(fields: list.reverse(xs: fields))
  end
end

// ─── SignatureHelpOptions (server capability) ────────────────────────────────

/** LSP SignatureHelpOptions (spec §"Server Capabilities") — server capability advertising trigger characters (e.g. `(`, `,`) that re-query `textDocument/signatureHelp`. */
export type SignatureHelpOptions = SignatureHelpOptions(
  trigger_characters: [string]
)

let signature_help_options_to_json = fn (opts: SignatureHelpOptions) -> JsonValue do
  match opts do | SignatureHelpOptions(trigger_characters) ->
    let items_rev = strings_to_json_items(xs: trigger_characters, acc: [])
    let items = list.reverse(xs: items_rev)
    return JsonObject(fields: [
      JsonField(key: "triggerCharacters", value: JsonArray(items))
    ])
  end
end

// ─── SemanticTokens (wire) ───────────────────────────────────────────────────

/** LSP SemanticTokens (spec §"Semantic Tokens") — response payload for `textDocument/semanticTokens/full`; flat `data` array of delta-encoded 5-tuples (deltaLine, deltaStart, length, tokenType, tokenModifiers) decoded against the server's advertised legend. */
export type SemanticTokens = SemanticTokens(data: [i64])

let data_items_to_json_items = fn (xs: [i64], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return acc
    | n :: rest -> return data_items_to_json_items(xs: rest, acc: JsonInt(val: n) :: acc)
  end
end

/** Serialize a SemanticTokens to LSP wire JSON for `textDocument/semanticTokens/full` replies — flat `data` array of delta-encoded 5-tuples. */
export let semantic_tokens_to_json = fn (st: SemanticTokens) -> JsonValue do
  match st do | SemanticTokens(data) ->
    let items_rev = data_items_to_json_items(xs: data, acc: [])
    let items = list.reverse(xs: items_rev)
    return JsonObject(fields: [
      JsonField(key: "data", value: JsonArray(items))
    ])
  end
end

// ─── SemanticTokensLegend (server capability) ───────────────────────────────

/** LSP SemanticTokensLegend (spec §"Semantic Tokens") — fixed pair of string arrays the client uses to decode the numeric `tokenType`/`tokenModifiers` indices emitted in `SemanticTokens.data`.
 *  Advertised once at `initialize` time inside `ServerCapabilities.semanticTokensProvider`.
 */
export type SemanticTokensLegend = SemanticTokensLegend(
  token_types: [string],
  token_modifiers: [string]
)

let semantic_tokens_legend_to_json = fn (l: SemanticTokensLegend) -> JsonValue do
  match l do | SemanticTokensLegend(token_types, token_modifiers) ->
    let t_items_rev = strings_to_json_items(xs: token_types, acc: [])
    let t_items = list.reverse(xs: t_items_rev)
    let m_items_rev = strings_to_json_items(xs: token_modifiers, acc: [])
    let m_items = list.reverse(xs: m_items_rev)
    return JsonObject(fields: [
      JsonField(key: "tokenTypes", value: JsonArray(items: t_items)),
      JsonField(key: "tokenModifiers", value: JsonArray(items: m_items))
    ])
  end
end

// ─── SemanticTokensOptions (server capability) ──────────────────────────────

/** LSP SemanticTokensOptions (spec §"Server Capabilities") — server capability advertising the semantic-tokens legend and which request shapes are supported; MVP advertises only `full`. */
export type SemanticTokensOptions = SemanticTokensOptions(
  legend: SemanticTokensLegend,
  full: bool
)

let semantic_tokens_options_to_json = fn (opts: SemanticTokensOptions) -> JsonValue do
  match opts do | SemanticTokensOptions(legend, full) ->
    return JsonObject(fields: [
      JsonField(key: "legend", value: semantic_tokens_legend_to_json(l: legend)),
      JsonField(key: "full", value: JsonBool(val: full))
    ])
  end
end

// ─── CompletionOptions (server capability) ───────────────────────────────────

/** LSP CompletionOptions (spec §"Server Capabilities") — server capability advertising completion trigger characters and whether the server emits a `completionItem/resolve` follow-up; MVP keeps `resolve_provider: false` (every CompletionItem is already complete). */
export type CompletionOptions = CompletionOptions(
  trigger_characters: [string],
  resolve_provider: bool
)

let completion_options_to_json = fn (opts: CompletionOptions) -> JsonValue do
  match opts do | CompletionOptions(trigger_characters, resolve_provider) ->
    let items_rev = strings_to_json_items(xs: trigger_characters, acc: [])
    let items = list.reverse(xs: items_rev)
    return JsonObject(fields: [
      JsonField(key: "triggerCharacters", value: JsonArray(items)),
      JsonField(key: "resolveProvider", value: JsonBool(val: resolve_provider))
    ])
  end
end

// ─── ServerCapabilities ──────────────────────────────────────────────────────

/** LSP ServerCapabilities (spec §"Server Capabilities") — the bundle returned in `InitializeResult.capabilities` declaring which LSP features this server implements.
 *  Each `Option` field maps to the corresponding spec capability; `None` omits the field entirely from the wire payload (clients treat absence as "unsupported").
 */
export type ServerCapabilities = ServerCapabilities(
  text_document_sync: Option<TextDocumentSyncKind>,
  document_symbol_provider: Option<bool>,
  hover_provider: Option<bool>,
  definition_provider: Option<bool>,
  references_provider: Option<bool>,
  completion_provider: Option<CompletionOptions>,
  signature_help_provider: Option<SignatureHelpOptions>,
  semantic_tokens_provider: Option<SemanticTokensOptions>,
  document_formatting_provider: Option<bool>,
  workspace_symbol_provider: Option<bool>
)

let server_capabilities_to_json = fn (caps: ServerCapabilities) -> JsonValue do
  match caps do | ServerCapabilities(text_document_sync, document_symbol_provider,
                                     hover_provider, definition_provider, references_provider,
                                     completion_provider, signature_help_provider,
                                     semantic_tokens_provider, document_formatting_provider,
                                     workspace_symbol_provider) ->
    let fields: [JsonField] = []
    let fields = match text_document_sync do
      | None -> fields
      | Some(val: k) ->
        JsonField(key: "textDocumentSync", value: JsonInt(val: text_document_sync_kind_to_int(k))) :: fields
    end
    let fields = match document_symbol_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "documentSymbolProvider", value: JsonBool(val: b)) :: fields
    end
    let fields = match hover_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "hoverProvider", value: JsonBool(val: b)) :: fields
    end
    let fields = match definition_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "definitionProvider", value: JsonBool(val: b)) :: fields
    end
    let fields = match references_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "referencesProvider", value: JsonBool(val: b)) :: fields
    end
    let fields = match completion_provider do
      | None -> fields
      | Some(val: opts) ->
        JsonField(key: "completionProvider", value: completion_options_to_json(opts)) :: fields
    end
    let fields = match signature_help_provider do
      | None -> fields
      | Some(val: opts) ->
        JsonField(key: "signatureHelpProvider", value: signature_help_options_to_json(opts)) :: fields
    end
    let fields = match semantic_tokens_provider do
      | None -> fields
      | Some(val: opts) ->
        JsonField(key: "semanticTokensProvider", value: semantic_tokens_options_to_json(opts)) :: fields
    end
    let fields = match document_formatting_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "documentFormattingProvider", value: JsonBool(val: b)) :: fields
    end
    let fields = match workspace_symbol_provider do
      | None -> fields
      | Some(val: b) -> JsonField(key: "workspaceSymbolProvider", value: JsonBool(val: b)) :: fields
    end
    return JsonObject(fields: list.reverse(xs: fields))
  end
end

let optional_text_document_sync_kind = fn (obj: JsonValue) -> Option<TextDocumentSyncKind> throws { LspProtocolThrow } do
  match optional_field(obj, key: "textDocumentSync") do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ ->
          let n = as_i64(v, ctx: "ServerCapabilities.textDocumentSync")
          return Some(val: text_document_sync_kind_from_int(n))
      end
  end
end

let server_capabilities_from_json = fn (v: JsonValue) -> ServerCapabilities throws { LspProtocolThrow } do
  let tds = optional_text_document_sync_kind(obj: v)
  let dsp = optional_bool(obj: v, key: "documentSymbolProvider", ctx: "ServerCapabilities.documentSymbolProvider")
  let hov = optional_bool(obj: v, key: "hoverProvider", ctx: "ServerCapabilities.hoverProvider")
  let def = optional_bool(obj: v, key: "definitionProvider", ctx: "ServerCapabilities.definitionProvider")
  let refs = optional_bool(obj: v, key: "referencesProvider", ctx: "ServerCapabilities.referencesProvider")
  let fmtp = optional_bool(obj: v, key: "documentFormattingProvider", ctx: "ServerCapabilities.documentFormattingProvider")
  let wsp = optional_bool(obj: v, key: "workspaceSymbolProvider", ctx: "ServerCapabilities.workspaceSymbolProvider")
  // CompletionProvider round-trip is intentionally lossy on the decode path:
  // tests assert the encoded shape directly, and the LSP loop never reads
  // its own advertised capabilities back. Surface as None so existing
  // round-trip tests on the encoder don't regress.
  return ServerCapabilities(
    text_document_sync: tds,
    document_symbol_provider: dsp,
    hover_provider: hov,
    definition_provider: def,
    references_provider: refs,
    completion_provider: None,
    // SignatureHelpProvider round-trip is intentionally lossy on the decode
    // path (same rationale as completionProvider above).
    signature_help_provider: None,
    // SemanticTokensProvider round-trip is intentionally lossy on the decode
    // path (same rationale as completionProvider above).
    semantic_tokens_provider: None,
    document_formatting_provider: fmtp,
    workspace_symbol_provider: wsp
  )
end

// ─── InitializeParams ────────────────────────────────────────────────────────

/** LSP InitializeParams (spec §"Initialize Request") — payload of the first `initialize` request a client sends.
 *  `client_capabilities` is kept as raw `JsonValue` since the MVP server doesn't introspect it; `process_id` accepts `integer | null | omitted` per spec.
 */
export type InitializeParams = InitializeParams(
  process_id: Option<i64>,
  root_uri: Option<string>,
  client_capabilities: JsonValue,
  trace: Option<string>
)

let optional_pid = fn (obj: JsonValue) -> Option<i64> throws { LspProtocolThrow } do
  match optional_field(obj, key: "processId") do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ -> return Some(val: as_i64(v, ctx: "InitializeParams.processId"))
      end
  end
end

let optional_root_uri = fn (obj: JsonValue) -> Option<string> throws { LspProtocolThrow } do
  match optional_field(obj, key: "rootUri") do
    | None -> return None
    | Some(val: v) ->
      match v do
        | JsonNull -> return None
        | _ -> return Some(val: as_string(v, ctx: "InitializeParams.rootUri"))
      end
  end
end

/** Decode an LSP `initialize` request's `params` object (spec §"Initialize Request") into an InitializeParams; raises `LspProtocolError` on schema violations. */
export let initialize_params_from_json = fn (v: JsonValue) -> InitializeParams throws { LspProtocolThrow } do
  let process_id = optional_pid(obj: v)
  let root_uri = optional_root_uri(obj: v)
  let client_capabilities = match optional_field(obj: v, key: "capabilities") do
    | None -> JsonObject(fields: [])
    | Some(val: c) -> c
  end
  let trace = optional_string(obj: v, key: "trace", ctx: "InitializeParams.trace")
  return InitializeParams(process_id, root_uri, client_capabilities, trace)
end

// ─── InitializeResult ────────────────────────────────────────────────────────

/** LSP ServerInfo (spec §"Initialize Result") — optional server identification carried inside `InitializeResult.serverInfo`: server `name` and optional `version` string. */
export type ServerInfo = ServerInfo(name: string, version: Option<string>)

let server_info_to_json = fn (info: ServerInfo) -> JsonValue do
  match info do | ServerInfo(name, version) ->
    let fields = [JsonField(key: "name", value: JsonString(val: name))]
    let fields = match version do
      | None -> fields
      | Some(val: vstr) -> JsonField(key: "version", value: JsonString(val: vstr)) :: fields
    end
    return JsonObject(fields: list.reverse(xs: fields))
  end
end

let server_info_from_json = fn (v: JsonValue) -> ServerInfo throws { LspProtocolThrow } do
  let name = as_string(v: require_field(obj: v, key: "name"), ctx: "ServerInfo.name")
  let version = optional_string(obj: v, key: "version", ctx: "ServerInfo.version")
  return ServerInfo(name, version)
end

/** LSP InitializeResult (spec §"Initialize Result") — server's response to `initialize`, carrying advertised `capabilities` and optional `server_info`. */
export type InitializeResult = InitializeResult(
  capabilities: ServerCapabilities,
  server_info: Option<ServerInfo>
)

/** Serialize an InitializeResult to the JSON payload sent in reply to an LSP `initialize` request (spec §"Initialize Result"). */
export let initialize_result_to_json = fn (r: InitializeResult) -> JsonValue do
  match r do | InitializeResult(capabilities, server_info) ->
    let fields = [
      JsonField(key: "capabilities", value: server_capabilities_to_json(caps: capabilities))
    ]
    let fields = match server_info do
      | None -> fields
      | Some(val: info) -> JsonField(key: "serverInfo", value: server_info_to_json(info)) :: fields
    end
    return JsonObject(fields: list.reverse(xs: fields))
  end
end
