/**
 * lsp/main: Nexus language-server entry point.
 *
 * Wires `nxlib/lsp/server` (generic LSP scaffold) to Nexus-specific
 * compile-pipeline handlers (defined in `src/lsp/handlers.nx`). This
 * file is the build target for `lsp.wasm`:
 *
 *   nexus build src/lsp/main.nx -o lsp.wasm
 *
 * Run with stdio attached:
 *
 *   wasmtime run -W tail-call=y,exceptions=y,function-references=y,\
 *                   stack-switching=y \
 *                --dir=. lsp.wasm
 *
 * Capability flags (must be applied by any launcher that runs lsp.wasm):
 *
 *   PermFs       - wasmtime: --dir=<workspace-root>
 *                  the import-aware diagnostics path resolves cross-file
 *                  references via the standard driver helpers, which read
 *                  source files off disk. The in-buffer-only diagnostics
 *                  path doesn't touch Fs, but the capability stays in the
 *                  required set so a launcher that mounts the workspace
 *                  is the steady-state expectation.
 *   PermConsole  - wasmtime: (always inherited; stdio is the LSP transport)
 *                  read JSON-RPC frames from stdin and write
 *                  responses + publishDiagnostics back on stdout. Errors
 *                  from the framing layer go to stderr.
 *   PermClock    - wasmtime: (no extra flag; clocks are on by default)
 *                  reserved for the debounce timer in front of the
 *                  on_did_change typecheck.
 *
 * Method coverage:
 *   initialize, initialized, shutdown, exit
 *   textDocument/didOpen, didChange, didClose, didSave
 *   textDocument/documentSymbol
 *   (others: MethodNotFound via the scaffold default)
 */

import { Console }, * as stdio from "std:stdio"
import { LspProtocolError } from "nxlib/lsp/protocol.nx"
import { empty_state, run_server } from "nxlib/lsp/server.nx"
import { nexus_handlers } from "src/lsp/handlers.nx"

// Capability discipline:
//   - `inject stdio.system_handler do ...` discharges the Console
//     requirement that `run_server` carries (via jsonrpc.read_message /
//     write_message). PermConsole is the underlying primitive perm.
//   - PermFs / PermClock are NOT yet declared on the entry-point row -
//     the in-buffer pipeline used here doesn't reach Fs or Clock. The
//     module-level doc comment lists them under "Capability flags" as
//     the steady-state expectation; the row will be widened (and
//     `inject fs_mod.system_handler, clock_mod.system_handler do` will
//     wrap the loop) once the import-aware diagnostics path lands.
let main = fn () -> unit require { PermConsole } do
  inject stdio.system_handler do
    try
      let _ = run_server(
        initial_state: empty_state(),
        handlers: nexus_handlers(),
        max_iters: -1
      )
      return ()
    catch err ->
      // Any exception that escapes the dispatch loop is unrecoverable
      // (frame errors and JSON parse errors are caught lower; this
      // catches genuine invariant violations only). Surface a
      // diagnostic to stderr so the editor surface reflects "server
      // crashed" rather than a silent EOF.
      match err do
        | LspProtocolError(msg) ->
          Console.eprintln(val: "[lsp] protocol error: " ++ msg)
        | _ ->
          Console.eprintln(val: "[lsp] server terminated abnormally (unknown exception)")
      end
      return ()
    end
  end
end
