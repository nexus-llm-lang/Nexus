/**
 * lsp/request_handlers: per-method LSP handlers.
 *
 * Each `on_*` function here matches one inbound JSON-RPC method name routed
 * by `lsp/handlers.invoke_method`. Handlers are pure functions over
 * `ServerState` × params → `HandlerResult`; the dispatcher converts that
 * into the wire response/notification stream and threads the new state.
 *
 * Methods covered:
 *   - lifecycle: initialized (no-op), didSave (republish diagnostics)
 *   - document sync: didOpen, didChange, didClose
 *   - query handlers: documentSymbol, hover, definition, completion,
 *     references, signatureHelp, semanticTokens/full
 *   - workspace handlers: workspace/symbol
 *
 * `initialize` and `shutdown` stay in `handlers.nx` because they touch the
 * capability advertisement and lifecycle flag respectively, both of which
 * the dispatcher is closely coupled to.
 *
 * Helper conventions:
 *   - URI extraction lives in `extract_text_document_uri_strict` (raises
 *     `LspProtocolError` on missing / non-string).
 *   - Position decoding lives in `decode_position` (re-used across
 *     definition, completion, references, signatureHelp).
 *   - List → JsonArray reversals follow the rest of the codebase's
 *     accumulator-then-reverse idiom.
 */

import {
  JsonValue, JsonNull, JsonInt, JsonString, JsonArray, JsonBool, JsonObject,
  JsonField, get_field
} from "std:json"
import * as list from "std:list"
import * as str from "std:str"
import { Option, Some, None } from "std:option"
import * as lexer from "src/frontend/lexer.nx"
import * as parser from "src/frontend/parser.nx"
import { Fs } from "std:fs"
import { Console } from "std:stdio"
import {
  document_symbols_for_program
} from "src/lsp/handlers/symbols.nx"
import {
  resolve_definition
} from "src/lsp/handlers/definition.nx"
import {
  resolve_completion
} from "src/lsp/handlers/completion.nx"
import {
  find_references
} from "src/lsp/handlers/references.nx"
import {
  resolve_signature_help
} from "src/lsp/handlers/signature_help.nx"
import {
  compute_semantic_tokens
} from "src/lsp/handlers/semantic_tokens.nx"
import {
  find_workspace_symbols, WorkspaceBuffer
} from "src/lsp/handlers/workspace_symbol.nx"
import {
  compute_formatting_edits
} from "src/lsp/handlers/formatting.nx"
import {
  resolve_hover
} from "src/lsp/handlers/hover.nx"
import {
  LspProtocolError, LspProtocolThrow
} from "src/lsp/protocol/json.nx"
import {
  TextDocumentItem, text_document_item_from_json,
  VersionedTextDocumentIdentifier,
  versioned_text_document_identifier_from_json,
  ContentChangeFull, ContentChangeIncremental,
  content_change_event_from_json,
  Position, Location, location_to_json,
  TextEdit, text_edit_to_json
} from "src/lsp/protocol/text_doc.nx"
import {
  DocumentSymbol, document_symbol_to_json,
  SymbolInformation, symbol_information_to_json
} from "src/lsp/protocol/symbols.nx"
import {
  CompletionList, completion_list_to_json,
  SignatureHelp, signature_help_to_json,
  SemanticTokens, semantic_tokens_to_json
} from "src/lsp/protocol/completion.nx"
import {
  ServerState, DocumentRecord, DocumentStore, HandlerResult,
  documents_lookup, documents_remove, state_documents, state_cache,
  with_documents, with_cache, with_lifecycle_shutdown,
  cache_evict_uri,
  require_object_field
} from "src/lsp/state/server_state.nx"
import {
  publish_for_buffer
} from "src/lsp/state/diagnostics_pipeline.nx"


/**
Decode a TextDocumentIdentifier's `uri` field as a string. Raises
`LspProtocolError` on missing field or non-string value. Shared by every
handler that takes `TextDocumentPositionParams`-shaped params.
*/
let extract_text_document_uri_strict = fn (params: JsonValue, ctx: string) -> string throws { LspProtocolThrow } do
  let td_v = require_object_field(obj: params, key: "textDocument", ctx)
  let uri_v = require_object_field(obj: td_v, key: "uri", ctx: ctx ++ ".textDocument")
  match uri_v do
    | JsonString(val: s) -> return s
    | _ -> throw LspProtocolError(msg: ctx ++ ".textDocument.uri: expected string")
  end
end

/**
Decode a `Position` from a params object. Raises on missing fields or
non-integer line/character. Shared across definition / completion /
references / signatureHelp (all consume `TextDocumentPositionParams`).
*/
let decode_position = fn (params: JsonValue, ctx: string) -> Position throws { LspProtocolThrow } do
  let pos_v = require_object_field(obj: params, key: "position", ctx)
  let line_v = require_object_field(obj: pos_v, key: "line", ctx: ctx ++ ".position")
  let char_v = require_object_field(obj: pos_v, key: "character", ctx: ctx ++ ".position")
  let line = match line_v do
    | JsonInt(val: n) -> n
    | _ -> throw LspProtocolError(msg: ctx ++ ".position.line: expected integer")
  end
  let character = match char_v do
    | JsonInt(val: n) -> n
    | _ -> throw LspProtocolError(msg: ctx ++ ".position.character: expected integer")
  end
  return Position(line, character)
end


/** Handles `textDocument/didOpen`: inserts the buffer (uri/text/version) into
 *  the document store on `state` and emits an initial
 *  `textDocument/publishDiagnostics` notification by running the lex/parse
 *  pipeline through `publish_for_buffer`.
 */
export let on_did_open = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let td_v = require_object_field(obj: params, key: "textDocument",
    ctx: "DidOpenTextDocumentParams")
  let td = text_document_item_from_json(v: td_v)
  match td do | TextDocumentItem(uri, language_id: _, version, text) ->
    return publish_for_buffer(state, uri, text, version)
  end
end

//
// Full-content sync: pick the trailing ContentChangeFull from the
// contentChanges array. An incremental change in this stream is a protocol
// violation per our advertised TextDocumentSyncKind.Full -- surface as
// LspProtocolError so the dispatch layer routes InvalidParams (for
// requests; notifications log + drop).

let pick_full_text = fn (items: [JsonValue], current: Option<string>) -> string throws { LspProtocolThrow } do
  match items do
    | [] ->
      match current do
        | Some(val: t) -> return t
        | None ->
          throw LspProtocolError(
            msg: "DidChangeTextDocumentParams.contentChanges: empty array"
          )
      end
    | v :: rest ->
      let ev = content_change_event_from_json(v)
      match ev do
        | ContentChangeFull(text) ->
          return pick_full_text(items: rest, current: Some(val: text))
        | ContentChangeIncremental(range: _, range_length: _, text: _) ->
          throw LspProtocolError(
            msg: "incremental contentChanges not supported (server advertises TextDocumentSyncKind.Full)"
          )
      end
  end
end

let json_array_items = fn (v: JsonValue) -> [JsonValue] throws { LspProtocolThrow } do
  match v do
    | JsonArray(items) -> return items
    | _ -> throw LspProtocolError(
        msg: "DidChangeTextDocumentParams.contentChanges: expected array"
      )
  end
end

/** Handles `textDocument/didChange`: takes the trailing full-content change
 *  (server advertises `TextDocumentSyncKind.Full`; incremental edits throw
 *  `LspProtocolError`), replaces the cached buffer text + version in the
 *  document store, and republishes diagnostics via `publish_for_buffer`.
 */
export let on_did_change = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let td_v = require_object_field(obj: params, key: "textDocument",
    ctx: "DidChangeTextDocumentParams")
  let id = versioned_text_document_identifier_from_json(v: td_v)
  let changes_v = require_object_field(obj: params, key: "contentChanges",
    ctx: "DidChangeTextDocumentParams")
  let arr = json_array_items(v: changes_v)
  let new_text = pick_full_text(items: arr, current: None)
  match id do | VersionedTextDocumentIdentifier(uri, version) ->
    return publish_for_buffer(state, uri, text: new_text, version)
  end
end


let extract_text_document_uri = fn (params: JsonValue, ctx: string) -> string throws { LspProtocolThrow } do
  match get_field(obj: params, key: "textDocument") do
    | None -> throw LspProtocolError(msg: ctx ++ ": missing 'textDocument'")
    | Some(val: v) ->
      match get_field(obj: v, key: "uri") do
        | None -> throw LspProtocolError(msg: ctx ++ ".textDocument: missing 'uri'")
        | Some(val: u) ->
          match u do
            | JsonString(val: s) -> return s
            | _ -> throw LspProtocolError(msg: ctx ++ ".textDocument.uri: expected string")
          end
      end
  end
end

// Build an empty `textDocument/publishDiagnostics` notification for `uri`.
// Per LSP spec §`textDocument/publishDiagnostics`, servers SHOULD clear
// diagnostics for a closed file by publishing an empty `diagnostics` array.
let make_empty_publish_diagnostics = fn (uri: string) -> JsonValue do
  let params = JsonObject(fields: [
    JsonField(key: "uri",         value: JsonString(val: uri)),
    JsonField(key: "diagnostics", value: JsonArray(items: []))
  ])
  return JsonObject(fields: [
    JsonField(key: "jsonrpc", value: JsonString(val: "2.0")),
    JsonField(key: "method",  value: JsonString(val: "textDocument/publishDiagnostics")),
    JsonField(key: "params",  value: params)
  ])
end

/** Handles `textDocument/didClose`: drops the record for the URI from the
 *  document store (via `documents_remove`) and the diagnostics cache (via
 *  `cache_evict_uri`) so the cache does not grow unbounded. Also publishes
 *  a `textDocument/publishDiagnostics` with `diagnostics:[]` per LSP spec
 *  §`textDocument/publishDiagnostics` — clients use this to clear stale
 *  markers on close.
 */
export let on_did_close = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let uri = extract_text_document_uri(params, ctx: "DidCloseTextDocumentParams")
  let new_docs = documents_remove(store: state_documents(state), uri)
  let new_cache = cache_evict_uri(cache: state_cache(state), uri)
  let new_state = with_cache(state: with_documents(state, docs: new_docs), cache: new_cache)
  let clear_notif = make_empty_publish_diagnostics(uri)
  return HandlerResult(
    state: new_state,
    response: None,
    notifications: [clear_notif]
  )
end


/** Handles `textDocument/didSave`: republishes diagnostics for the saved
 *  URI using the text already cached in the document store (full-content sync
 *  means the buffer is up to date from the preceding didChange). If no record
 *  is cached for the URI (e.g. server restarted without a prior didOpen) the
 *  notification is silently absorbed — returning `state` unchanged with no
 *  notifications. Per LSP spec, servers MAY republish on save; some clients
 *  (e.g. VS Code "Problems" panel refresh) rely on this behaviour.
 */
export let on_did_save = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let uri = extract_text_document_uri(params, ctx: "DidSaveTextDocumentParams")
  let doc_opt = documents_lookup(store: state_documents(state), uri)
  match doc_opt do
    | None ->
      // No cached buffer for this URI: absorb silently (no-op).
      return HandlerResult(state, response: None, notifications: [])
    | Some(val: rec) ->
      match rec do | DocumentRecord(uri: u, text, version) ->
        return publish_for_buffer(state, uri: u, text, version)
      end
  end
end

/** Shared no-op handler for lifecycle notifications the server
 *  acknowledges without acting on (`initialized`):
 *  there are no server-side resources to flush. Returns `state` unchanged
 *  with no response and no notifications.
 */
export let on_noop = fn (state: ServerState, params: JsonValue) -> HandlerResult do
  let _ = params
  return HandlerResult(state, response: None, notifications: [])
end

//
// Outline view: parse the buffer text we cached on didOpen / didChange and
// hand the resulting Program to `src/lsp/symbols.document_symbols_for_program`
// for the AST -> DocumentSymbol[] conversion. The wire reply is the array
// itself (not wrapped in an object); LSP clients accept either flat
// SymbolInformation[] or DocumentSymbol[] as the response shape.

let symbols_to_json_items_go = fn (xs: [DocumentSymbol], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | s :: rest -> return symbols_to_json_items_go(xs: rest, acc: document_symbol_to_json(s) :: acc)
  end
end

let document_symbols_to_json = fn (xs: [DocumentSymbol]) -> JsonValue do
  return JsonArray(items: symbols_to_json_items_go(xs, acc: []))
end

let compute_document_symbols = fn (doc_opt: Option<DocumentRecord>) -> [DocumentSymbol] do
  match doc_opt do
    | None ->
      // No buffer cached for this URI -- return an empty outline rather
      // than InvalidParams. Some clients query documentSymbol before
      // didOpen completes; an empty list is the LSP-friendly response.
      return []
    | Some(val: rec) ->
      match rec do | DocumentRecord(uri: _, text, version: _) ->
        try
          let prog = parser.parse_source(src: text)
          return document_symbols_for_program(prog)
        catch err ->
          // Lex/parse failure: outline is empty for the broken buffer.
          // The client already sees publishDiagnostics with the parse
          // error (pushed by didOpen / didChange), so flooding the
          // outline with a synthetic symbol would be redundant.
          let _ = err
          return []
        end
      end
  end
end

/** Handles `textDocument/documentSymbol`: re-parses the cached buffer and
 *  returns a flat `DocumentSymbol[]` outline as the wire response (a bare
 *  JSON array, accepted by LSP clients alongside the SymbolInformation[]
 *  shape). Missing buffer or parse failure yields an empty array — no
 *  diagnostics are duplicated here.
 */
export let on_document_symbol = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let uri = extract_text_document_uri_strict(params, ctx: "DocumentSymbolParams")
  let doc_opt = documents_lookup(store: state_documents(state), uri)
  let symbols = compute_document_symbols(doc_opt)
  return HandlerResult(
    state,
    response: Some(val: document_symbols_to_json(xs: symbols)),
    notifications: []
  )
end

//
// MVP scope: surface the file-level `/**. */` doc
// comment as a markdown Hover when the cursor sits on the first line of
// the open buffer. Any other position returns JSON `null`, which LSP
// treats as "no hover info".

let hover_position_line_and_char = fn (params: JsonValue) -> Position throws { LspProtocolThrow } do
  let pos_v = require_object_field(obj: params, key: "position",
    ctx: "HoverParams")
  let line_v = require_object_field(obj: pos_v, key: "line",
    ctx: "HoverParams.position")
  let char_v = require_object_field(obj: pos_v, key: "character",
    ctx: "HoverParams.position")
  let line = match line_v do
    | JsonInt(val: n) -> n
    | _ -> throw LspProtocolError(msg: "HoverParams.position.line: expected integer")
  end
  let character = match char_v do
    | JsonInt(val: n) -> n
    | _ -> throw LspProtocolError(msg: "HoverParams.position.character: expected integer")
  end
  return Position(line, character)
end

let make_markdown_hover = fn (content: string) -> JsonValue do
  let markup = JsonObject(fields: [
    JsonField(key: "kind", value: JsonString(val: "markdown")),
    JsonField(key: "value", value: JsonString(val: content))
  ])
  return JsonObject(fields: [
    JsonField(key: "contents", value: markup)
  ])
end

// Return the byte length of line 0 (the number of bytes before the first
// `\n`, or the total byte length if there is no newline). This bounds the
// character position check for the module doc comment hover on line 0:
// the comment occupies [0, line0_byte_length) on that line.
let line0_byte_length = fn (src: string) -> i64 do
  let nl_pos = str.find_byte(s: src, start: 0, ch: '\n')
  if nl_pos < 0 then return str.byte_length(s: src) end
  return nl_pos
end

// Try to produce a hover response for `(line, character)` in `doc_opt`.
//
// Priority:
//   1. If the cursor is on line 0 within the module doc comment extent,
//      return the module doc. (Unchanged MVP behaviour.)
//   2. Otherwise, try `resolve_hover` which looks up the identifier at the
//      cursor in the rename map and renders the function/binding type.
//   3. Fall back to JsonNull ("no hover info").
//
// Phase 1 covers top-level function and `let` binding hovers.
// Phase 2 (local let bindings, inferred types) deferred — HIR caching needed.
let compute_hover_response_for_doc = fn (
  doc_opt: Option<DocumentRecord>,
  line: i64,
  character: i64
) -> JsonValue require { Console, Fs } do
  match doc_opt do
    | None -> return JsonNull
    | Some(val: rec) ->
      match rec do | DocumentRecord(uri, text, version: _) ->
        // Priority 1: module doc comment on line 0.
        if line == 0 then
          match lexer.extract_module_doc(src: text) do
            | Some(val: doc) ->
              let extent = line0_byte_length(text)
              if character < extent then
                return make_markdown_hover(content: doc)
              end
            | None -> let _ = 0
          end
        end
        // Priority 2: identifier type hover via resolve_hover.
        match resolve_hover(text, file_uri: uri, line, character) do
          | Some(val: md) -> return make_markdown_hover(content: md)
          | None -> return JsonNull
        end
      end
  end
end

/** Handles `textDocument/hover`: returns a markdown `Hover` for the cursor
 *  position. Coverage:
 *  - Line 0 within the module doc comment extent → the file's `/** ... */`
 *    module-level doc comment.
 *  - Any identifier that resolves to a top-level `let` or `cap` binding →
 *    the function signature with parameter types, return type, `require {}`,
 *    and `throws {}` annotations (Phase 1).
 *  - Non-lambda top-level `let` with a type annotation → `**name**: Type`.
 *  All other positions reply JSON `null` ("no hover info").
 */
export let on_hover = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let uri = extract_text_document_uri_strict(params, ctx: "HoverParams")
  let pos = hover_position_line_and_char(params)
  let doc_opt = documents_lookup(store: state_documents(state), uri)
  match pos do | Position(line, character) ->
    let response = compute_hover_response_for_doc(doc_opt, line, character)
    return HandlerResult(
      state,
      response: Some(val: response),
      notifications: []
    )
  end
end

//
// Resolution scope (Phase 1):
//   - same-file: an identifier referencing a top-level `let` / `cap` in the
//     entry buffer jumps back to that def's keyword span.
//   - cross-file: `import { foo } from "./other.nx"` plus a call to `foo`
//     jumps to other.nx's `let foo = ...` line.
//   - cross-file with alias: `import * as a from "./other.nx"` plus
//     `a.foo(...)` jumps to other.nx's `foo` def.

/** Handles `textDocument/definition`: decodes the cursor position, hands the
 *  buffer text + URI to `resolve_definition`, and returns the resulting
 *  `Location` (uri + range) as the response. Replies JSON `null` when no
 *  buffer is cached or the symbol cannot be resolved — never a Location[].
 */
export let on_definition = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let uri = extract_text_document_uri_strict(params, ctx: "DefinitionParams")
  let pos = decode_position(params, ctx: "DefinitionParams")
  let doc_opt = documents_lookup(store: state_documents(state), uri)
  match doc_opt do
    | None ->
      return HandlerResult(state, response: Some(val: JsonNull), notifications: [])
    | Some(val: rec) ->
      match rec do | DocumentRecord(uri: _, text, version: _) ->
        match pos do | Position(line, character) ->
          let loc_opt = resolve_definition(text, file_uri: uri, line, character)
          let response = match loc_opt do
            | None -> JsonNull
            | Some(val: loc) -> location_to_json(loc)
          end
          return HandlerResult(state, response: Some(val: response), notifications: [])
        end
      end
  end
end

//
// Reuses `decode_position` (same TextDocumentPositionParams shape) and
// hands the text + cursor coordinates to `lsp/completion.resolve_completion`.
// On any internal failure the resolver returns the keyword-only baseline, so
// this handler does not produce InvalidParams.

/** Handles `textDocument/completion`: decodes the trigger position
 *  (TextDocumentPositionParams shape — the optional `context` is currently
 *  ignored; identifier prefix + manual-trigger paths share one resolver),
 *  calls `resolve_completion`, and returns a `CompletionList { isIncomplete,
 *  items[] }` reply. A missing buffer falls back to the keyword-only
 *  baseline rather than InvalidParams.
 */
export let on_completion = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let uri = extract_text_document_uri_strict(params, ctx: "CompletionParams")
  let pos = decode_position(params, ctx: "CompletionParams")
  let doc_opt = documents_lookup(store: state_documents(state), uri)
  let text = match doc_opt do
    | None -> ""
    | Some(val: rec) ->
      match rec do | DocumentRecord(uri: _, text: t, version: _) -> t end
  end
  match pos do | Position(line, character) ->
    let cl = resolve_completion(text, file_uri: uri, line, character)
    return HandlerResult(
      state,
      response: Some(val: completion_list_to_json(cl)),
      notifications: []
    )
  end
end

//
// Mirrors the definition path. The `context.includeDeclaration` boolean
// toggles whether the def-site Location prefixes the use-site list.

let references_include_declaration = fn (params: JsonValue) -> bool do
  // `context` is optional per the spec (some clients omit it on
  // peek-references). Default: true.
  match get_field(obj: params, key: "context") do
    | None -> return true
    | Some(val: ctx) ->
      match get_field(obj: ctx, key: "includeDeclaration") do
        | None -> return true
        | Some(val: v) ->
          match v do
            | JsonBool(val: b) -> return b
            | _ -> return true
          end
      end
  end
end

let locations_to_json_items = fn (xs: [Location], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | l :: rest -> return locations_to_json_items(xs: rest, acc: location_to_json(loc: l) :: acc)
  end
end

/** Handles `textDocument/references`: decodes position + the optional
 *  `context.includeDeclaration` flag (defaults to `true`), runs
 *  `find_references` over the buffer, and returns a flat `Location[]` array
 *  reply. Missing buffer yields `[]`, never JSON `null`.
 */
export let on_references = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let uri = extract_text_document_uri_strict(params, ctx: "ReferenceParams")
  let pos = decode_position(params, ctx: "ReferenceParams")
  let include_decl = references_include_declaration(params)
  let doc_opt = documents_lookup(store: state_documents(state), uri)
  match doc_opt do
    | None ->
      return HandlerResult(state, response: Some(val: JsonArray(items: [])), notifications: [])
    | Some(val: rec) ->
      match rec do | DocumentRecord(uri: _, text, version: _) ->
        match pos do | Position(line, character) ->
          let locs = find_references(text, file_uri: uri, line, character, include_declaration: include_decl)
          let items = locations_to_json_items(xs: locs, acc: [])
          return HandlerResult(state, response: Some(val: JsonArray(items)), notifications: [])
        end
      end
  end
end

//
// Resolution scope (Phase 1): mirrors definition / references
// — same-file plus cached imported files. Reuses `decode_position` for
// the TextDocumentPositionParams shape, hands the text + cursor coordinates
// to `lsp/signature_help.resolve_signature_help`. The resolver returns None
// for any failure path; the handler maps that to JSON `null`, which clients
// treat as "no signature info" (no popup) rather than an error.

/** Handles `textDocument/signatureHelp`: decodes the cursor position,
 *  delegates to `resolve_signature_help`, and returns a `SignatureHelp {
 *  signatures, activeSignature, activeParameter }` reply. Missing buffer or
 *  unresolved call site maps to JSON `null` (clients render no popup
 *  rather than treating it as an error).
 */
export let on_signature_help = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let uri = extract_text_document_uri_strict(params, ctx: "SignatureHelpParams")
  let pos = decode_position(params, ctx: "SignatureHelpParams")
  let doc_opt = documents_lookup(store: state_documents(state), uri)
  match doc_opt do
    | None ->
      // No buffer: null (LSP "no result" — clients render no popup).
      return HandlerResult(state, response: Some(val: JsonNull), notifications: [])
    | Some(val: rec) ->
      match rec do | DocumentRecord(uri: _, text, version: _) ->
        match pos do | Position(line, character) ->
          let help_opt = resolve_signature_help(text, file_uri: uri, line, character)
          let response = match help_opt do
            | None -> JsonNull
            | Some(val: h) -> signature_help_to_json(h: h)
          end
          return HandlerResult(state, response: Some(val: response), notifications: [])
        end
      end
  end
end

//
// Resolution scope: walks the editor buffer's tokens via
// `lsp/semantic_tokens.compute_semantic_tokens` and emits a flat
// delta-encoded `SemanticTokens.data` array. Returns an empty `data` array
// (a valid "no highlights" reply) when no buffer is cached for the URI; the
// resolver itself never fails for lex / parse errors because it falls back
// to whatever subset of the buffer did tokenize cleanly.

/** Handles `textDocument/semanticTokens/full`: walks the cached buffer's
 *  tokens via `compute_semantic_tokens` and returns a `SemanticTokens {
 *  data }` reply whose `data` is the delta-encoded `[deltaLine, deltaStart,
 *  length, tokenType, tokenModifiers]` quintuple stream. Missing buffer
 *  yields an empty `data` array — a valid "no highlights" response.
 */
export let on_semantic_tokens = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let uri = extract_text_document_uri_strict(params, ctx: "SemanticTokensParams")
  let doc_opt = documents_lookup(store: state_documents(state), uri)
  let text = match doc_opt do
    | None -> ""
    | Some(val: rec) ->
      match rec do | DocumentRecord(uri: _, text: t, version: _) -> t end
  end
  let tokens = compute_semantic_tokens(text)
  return HandlerResult(
    state,
    response: Some(val: semantic_tokens_to_json(st: tokens)),
    notifications: []
  )
end

//
// Walks every open buffer's top-level definitions and returns a flat
// `SymbolInformation[]` filtered by the client's case-insensitive query.
// `params.query` is required by the spec; we tolerate its absence by
// defaulting to "" (all symbols) so a misbehaving client still gets a
// useful response instead of InvalidParams.

let records_to_buffers = fn (xs: [DocumentRecord], acc: [WorkspaceBuffer]) -> [WorkspaceBuffer] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | DocumentRecord(uri, text, version: _) :: rest ->
      return records_to_buffers(xs: rest, acc: WorkspaceBuffer(uri, text) :: acc)
  end
end

let document_store_to_buffers = fn (store: DocumentStore, acc: [WorkspaceBuffer]) -> [WorkspaceBuffer] do
  match store do | DocumentStore(records) ->
    return records_to_buffers(xs: records, acc)
  end
end

let symbol_infos_to_json_items = fn (xs: [SymbolInformation], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | s :: rest -> return symbol_infos_to_json_items(xs: rest, acc: symbol_information_to_json(s) :: acc)
  end
end

let workspace_symbol_query = fn (params: JsonValue) -> string do
  match get_field(obj: params, key: "query") do
    | None -> return ""
    | Some(val: v) ->
      match v do
        | JsonString(val: s) -> return s
        | _ -> return ""
      end
  end
end

/** Handles `workspace/symbol`: collects every open buffer's top-level
 *  definitions, filters them by the case-insensitive `params.query` string
 *  (defaulting to "" when absent or mistyped), and returns a flat
 *  `SymbolInformation[]` reply spanning the whole workspace.
 */
export let on_workspace_symbol = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } do
  let query = workspace_symbol_query(params)
  let buffers = document_store_to_buffers(store: state_documents(state), acc: [])
  let symbols = find_workspace_symbols(buffers, query)
  let items = symbol_infos_to_json_items(xs: symbols, acc: [])
  return HandlerResult(
    state,
    response: Some(val: JsonArray(items)),
    notifications: []
  )
end

//
// Run the same fmt pipeline as `nexus fmt` against the buffered document text
// and return a single full-document `TextEdit` replacing the buffer. Returns
// an empty array when no buffer is cached for the URI, when the text is
// already formatted, or when the pipeline produces a no-op result. The
// `FormattingOptions` payload (tabSize, insertSpaces) is intentionally
// ignored in MVP — the fmt pipeline is opinionated (2-space indent, strip
// trailing whitespace, collapse blank lines) and threading client-side
// options into a byte-level pass is out of scope for this issue.

let text_edits_to_json_items = fn (xs: [TextEdit], acc: [JsonValue]) -> [JsonValue] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | e :: rest -> return text_edits_to_json_items(xs: rest, acc: text_edit_to_json(e: e) :: acc)
  end
end

/** Handles `textDocument/formatting`: runs the `nexus fmt` pipeline against
 *  the cached buffer and returns a `TextEdit[]` reply (typically a single
 *  full-document replacement). Empty array when no buffer is cached, the
 *  text is already formatted, or the pipeline no-ops; the
 *  `FormattingOptions` payload is intentionally ignored (fmt is
 *  opinionated).
 */
export let on_formatting = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } throws { LspProtocolThrow } do
  let uri = extract_text_document_uri_strict(params, ctx: "DocumentFormattingParams")
  let doc_opt = documents_lookup(store: state_documents(state), uri)
  let edits = compute_formatting_edits(doc_opt)
  let items = text_edits_to_json_items(xs: edits, acc: [])
  return HandlerResult(
    state,
    response: Some(val: JsonArray(items)),
    notifications: []
  )
end


/** Handles `shutdown`: flips the server's lifecycle flag to "shutdown"
 *  (via `with_lifecycle_shutdown`) so the dispatcher rejects every
 *  subsequent request except `exit`, and replies with JSON `null` per the
 *  LSP spec.
 */
export let on_shutdown = fn (state: ServerState, params: JsonValue) -> HandlerResult require { Console, Fs } do
  let _ = params
  return HandlerResult(
    state: with_lifecycle_shutdown(state),
    response: Some(val: JsonNull),
    notifications: []
  )
end
