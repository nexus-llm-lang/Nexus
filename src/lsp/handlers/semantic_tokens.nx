/**
 * lsp/semantic_tokens: compute the `textDocument/semanticTokens/full` reply.
 *
 * Pipeline:
 *   1. Tokenize the editor buffer via `lexer.tokenize`. The lexer already
 *      strips whitespace, line comments, and block comments — so for the
 *      comment-class token type we re-scan the source bytes once and merge
 *      the comment spans into the highlight stream.
 *   2. Walk the tokens in source order and classify each into one of the
 *      legend categories (keyword, function, variable, parameter, type,
 *      variant, string, number, operator). Identifier disambiguation uses
 *      a small token-window peek: a `TkIdent` immediately following `TkLet`
 *      whose value-side first non-whitespace token is `TkFn` highlights as
 *      `function`; an `TkIdent` immediately preceded by `TkLParen` (or by
 *      `TkComma` inside an open lambda paren) and followed by `TkColon`
 *      highlights as `parameter`; etc.
 *   3. Sort the merged (token + comment) stream by source position and
 *      delta-encode into the wire 5-tuple shape per
 *      LSP §`textDocument/semanticTokens/full`.
 *
 * Identifier-disambiguation precedence (highest to lowest):
 *   `TkUident` after `TkType` keyword           -> type
 *   `TkUident` after `TkPipe` (variant alt)     -> variant
 *   `TkUident` after `TkException` keyword      -> type
 *   `TkUident` everywhere else                  -> variant (constructor / variant ref)
 *   `TkUident` in a type position (after `:` / `->`) -> type
 *   `TkIdent` after `TkLet` (top-level fn def)  -> function
 *   `TkIdent` after `TkLet` (non-fn binding)    -> variable
 *   `TkIdent` inside `fn ( ... )` params         -> parameter
 *   `TkIdent` after `:` or `->` (type context)   -> type (for builtin lowercase like `i64`)
 *   `TkIdent` elsewhere                          -> variable
 *
 * Coordinate model: LSP wants 0-based (line, character). AST Span is 1-based;
 * we translate at the wire boundary via `saturating_pred`.
 *
 * Out of scope for MVP (issue nexus-2nef):
 *   - delta requests (`textDocument/semanticTokens/full/delta`),
 *   - range requests (`textDocument/semanticTokens/range`),
 *   - modifier bits (every emitted tuple uses `tokenModifiers = 0`),
 *   - multi-line spans for strings / comments (token length is clamped to
 *     the byte length of the literal; for a multi-line string this is the
 *     full byte length, which most clients interpret on the start line —
 *     a per-line span split is post-MVP).
 */

import { Option, Some, None } from "std:option"
import * as lexer from "src/frontend/lexer.nx"
import { Span, SpannedToken, Token,
         TkLet, TkFn, TkDo, TkEnd, TkIf, TkThen, TkElse, TkMatch, TkWhile,
         TkFor, TkTo, TkReturn, TkImport, TkFrom, TkAs, TkExternal, TkPub,
         TkOpaque, TkType, TkCap, TkHandler, TkInject, TkTry, TkCatch,
         TkRaise, TkRequire, TkThrows, TkException, TkRef, TkWith,
         TkPlus, TkMinus, TkStar, TkSlash, TkPlusPlus, TkPlusDot,
         TkMinusDot, TkStarDot, TkSlashDot,
         TkEqEq, TkBangEq, TkLt, TkGt, TkLe, TkGe,
         TkEqEqDot, TkBangEqDot, TkLtDot, TkGtDot, TkLeDot, TkGeDot,
         TkAndAnd, TkPipePipe, TkArrow, TkLArrow, TkEq, TkPipe, TkBang,
         TkLParen, TkRParen, TkLBrace, TkRBrace, TkLBracket, TkRBracket,
         TkLArray, TkRArray, TkComma, TkDot, TkColon, TkColonColon,
         TkTilde, TkPercent, TkAmpersand, TkAt, TkCaret, TkShl, TkShr,
         TkTrue, TkFalse, TkUnit,
         TkInt, TkFloat, TkChar, TkString,
         TkIdent, TkUident,
         TkImportPath, TkError, TkEof } from "src/common/token.nx"
import * as str from "std:str"
import { SemanticTokens, SemanticTokensLegend } from "src/lsp/protocol.nx"
import { saturating_pred } from "src/lsp/common.nx"
import { SourcePos } from "src/common/source_pos.nx"

// ─── Legend token-type indices ──────────────────────────────────────────────
//
// The legend ordering here is the contract advertised to clients via
// `SemanticTokensLegend.tokenTypes`. The integer used in the wire data
// stream is the position of the category in that array. Keep this list and
// `legend_token_types` in sync.

export let tt_keyword = 0
export let tt_function = 1
export let tt_variable = 2
export let tt_parameter = 3
export let tt_type = 4
export let tt_variant = 5
export let tt_string = 6
export let tt_number = 7
export let tt_comment = 8
export let tt_operator = 9

/**
The token-type legend the server advertises in `initialize`. Tests
assert the exact ordering here; clients build their decoder against it.
*/
let legend_token_types = fn () -> [string] do
  return [
    "keyword",
    "function",
    "variable",
    "parameter",
    "type",
    "variant",
    "string",
    "number",
    "comment",
    "operator"
  ]
end

/**
MVP modifier list — empty. The wire format still requires the field, so
the legend exposes an empty array and every emitted tuple uses 0.
*/
let legend_token_modifiers = fn () -> [string] do
  return []
end

export let semantic_tokens_legend = fn () -> SemanticTokensLegend do
  return SemanticTokensLegend(
    token_types: legend_token_types(),
    token_modifiers: legend_token_modifiers()
  )
end

// ─── Intermediate token shape ────────────────────────────────────────────────
//
// We materialise a (line, col, length, token_type) tuple per emitted token
// before delta-encoding, so the source-order walk can produce tokens out of
// the lexer's stream (comments are emitted by a separate pass and merged).

export type SemTok = SemTok(line: i64, col: i64, length: i64, token_type: i64)

// ─── Operator classification ─────────────────────────────────────────────────
//
// Tokens that the LSP layer considers operators per the MVP legend. We
// deliberately exclude `,` / `:` / `;` / `.` / parens / brackets — those are
// punctuation and most clients leave them unstyled (or style via a separate
// category outside the spec's standard legend).

let token_is_operator = fn (t: Token) -> bool do
  match t do
    | TkPlus | TkMinus | TkStar | TkSlash
    | TkPlusPlus | TkPlusDot | TkMinusDot | TkStarDot | TkSlashDot
    | TkEqEq | TkBangEq | TkLt | TkGt | TkLe | TkGe
    | TkEqEqDot | TkBangEqDot | TkLtDot | TkGtDot | TkLeDot | TkGeDot
    | TkAndAnd | TkPipePipe | TkArrow | TkLArrow
    | TkEq | TkPipe | TkBang | TkShl | TkShr -> return true
    | _ -> return false
  end
end

// ─── Operator surface-form lookup ────────────────────────────────────────────
//
// SpannedToken carries the source position but not the source-form length;
// we recover it from the token kind for fixed-width operators. Variable-width
// tokens (identifiers, literals, strings) carry their own surface form so we
// inspect those at emit time instead of going through this table.

let operator_length = fn (t: Token) -> i64 do
  match t do
    | TkPlus | TkMinus | TkStar | TkSlash
    | TkLt | TkGt | TkEq | TkPipe | TkBang -> return 1
    | TkPlusPlus | TkPlusDot | TkMinusDot | TkStarDot | TkSlashDot
    | TkEqEq | TkBangEq | TkLe | TkGe | TkLtDot | TkGtDot
    | TkAndAnd | TkPipePipe | TkArrow | TkLArrow | TkShl | TkShr -> return 2
    | TkEqEqDot | TkBangEqDot | TkLeDot | TkGeDot -> return 3
    | _ -> return 0
  end
end

// ─── Keyword classification ──────────────────────────────────────────────────

let token_is_keyword = fn (t: Token) -> bool do
  match t do
    | TkLet | TkFn | TkDo | TkEnd
    | TkIf | TkThen | TkElse
    | TkMatch | TkWhile | TkFor | TkTo | TkReturn
    | TkImport | TkFrom | TkAs | TkExternal
    | TkPub | TkOpaque | TkType | TkCap
    | TkHandler | TkInject | TkTry | TkCatch | TkRaise
    | TkRequire | TkThrows | TkException
    | TkRef | TkWith | TkTrue | TkFalse | TkUnit -> return true
    | _ -> return false
  end
end

// ─── Keyword surface-form length ────────────────────────────────────────────
//
// Tokens are interned by kind in the lexer; the source byte length must be
// recovered from the kind. `TkRaise` is emitted for both `raise` and `throw`
// (the lexer aliases them), so the length lookup defaults to 5 (`raise`) —
// a slight under-highlight when the source uses `throw` is acceptable for
// MVP; a perfect span would require carrying the surface form on the token.

let keyword_length = fn (t: Token) -> i64 do
  match t do
    | TkLet | TkEnd | TkFor | TkCap | TkTry | TkRef -> return 3
    | TkFn | TkDo | TkIf | TkTo | TkAs -> return 2
    | TkThen | TkElse | TkFrom | TkType | TkWith | TkTrue | TkUnit -> return 4
    | TkMatch | TkWhile | TkCatch | TkRaise | TkFalse -> return 5
    | TkReturn | TkImport | TkPub | TkOpaque | TkInject | TkThrows -> return 6
    | TkHandler | TkRequire -> return 7
    | TkExternal -> return 8
    | TkException -> return 9
    | _ -> return 0
  end
end

// ─── Token-stream slice helpers ──────────────────────────────────────────────
//
// We need to peek both backwards and forwards inside the token stream while
// classifying identifiers. The token list is singly-linked so backwards
// access goes through an index-based view: we keep a parallel `idx` while
// walking forward, and `token_at_index` reuses the array head for random
// access. For MVP this is O(n) per peek, but the stream length is bounded
// by the buffer size and the worst-case is dominated by the lexer pass
// itself — no need for an index map yet.

let token_at_index = fn (toks: [SpannedToken], idx: i64) -> Option<SpannedToken> do
  if idx < 0 then return None end
  match toks do
    | [] -> return None
    | t :: rest ->
      if idx == 0 then return Some(val: t) end
      return token_at_index(toks: rest, idx: idx - 1)
  end
end

let token_kind_at = fn (toks: [SpannedToken], idx: i64) -> Option<Token> do
  match token_at_index(toks, idx) do
    | None -> return None
    | Some(val: SpannedToken(token, span: _)) -> return Some(val: token)
  end
end

// Find the previous token index that is "significant" — every token kind we
// emit is significant; whitespace / comments aren't tokens in our lexer, so
// `idx - 1` already skips them. This helper exists for future symmetry with
// any future ignore-set.
let prev_kind = fn (toks: [SpannedToken], idx: i64) -> Option<Token> do
  return token_kind_at(toks, idx: idx - 1)
end

let next_kind = fn (toks: [SpannedToken], idx: i64) -> Option<Token> do
  return token_kind_at(toks, idx: idx + 1)
end

// ─── Identifier classification ───────────────────────────────────────────────

let kind_is_let = fn (k: Token) -> bool do
  match k do | TkLet -> return true | _ -> return false end
end

let kind_is_fn = fn (k: Token) -> bool do
  match k do | TkFn -> return true | _ -> return false end
end

let kind_is_colon = fn (k: Token) -> bool do
  match k do | TkColon -> return true | _ -> return false end
end

let kind_is_arrow = fn (k: Token) -> bool do
  match k do | TkArrow -> return true | _ -> return false end
end

let kind_is_lparen = fn (k: Token) -> bool do
  match k do | TkLParen -> return true | _ -> return false end
end

let kind_is_comma = fn (k: Token) -> bool do
  match k do | TkComma -> return true | _ -> return false end
end

let kind_is_pipe = fn (k: Token) -> bool do
  match k do | TkPipe -> return true | _ -> return false end
end

let kind_is_eq = fn (k: Token) -> bool do
  match k do | TkEq -> return true | _ -> return false end
end

let kind_is_type = fn (k: Token) -> bool do
  match k do | TkType -> return true | _ -> return false end
end

let kind_is_exception = fn (k: Token) -> bool do
  match k do | TkException -> return true | _ -> return false end
end

let kind_is_dot = fn (k: Token) -> bool do
  match k do | TkDot -> return true | _ -> return false end
end

// Skip backwards over tokens until we find one that isn't a `TkPub`/`TkOpaque`
// modifier, returning the kind of the first content token. Used for the
// `let NAME =` rule so `export let foo` still highlights `foo` as function /
// variable.
let prev_skipping_modifiers = fn (toks: [SpannedToken], idx: i64) -> Option<Token> do
  if idx < 0 then return None end
  match token_kind_at(toks, idx) do
    | None -> return None
    | Some(val: k) ->
      match k do
        | TkPub | TkOpaque -> return prev_skipping_modifiers(toks, idx: idx - 1)
        | _ -> return Some(val: k)
      end
  end
end

// True when the token at `idx - 1` (after skipping `export` / `opaque`) is
// `TkLet`. The `let` keyword's identifier is the binding name; classify it
// based on the rhs (peek forward past `TkIdent TkEq`).
let is_let_binding_name = fn (toks: [SpannedToken], idx: i64) -> bool do
  match prev_skipping_modifiers(toks, idx: idx - 1) do
    | Some(val: k) -> return kind_is_let(k)
    | None -> return false
  end
end

// Look forward over `= <rhs first significant token>` to decide whether a
// let-binding's name should highlight as `function` or `variable`. If the
// rhs is `fn`, the binding is a function definition. Otherwise variable.
let rhs_first_kind = fn (toks: [SpannedToken], name_idx: i64) -> Option<Token> do
  // Expect: name_idx, possibly `:` <type expr> (skip until `=`), then `=`, rhs.
  // Walk forward to the `=`, then return the next token's kind.
  return walk_to_eq_then_next(toks, idx: name_idx + 1, depth: 0)
end

// Skip tokens until we hit a top-level `=` (depth 0) or run out. `depth`
// guards against `=` inside a nested type annotation (e.g. an `i64 = ...`
// wouldn't happen but bracket nesting in the type expr is still tracked
// defensively). Returns the kind of the token immediately after the `=`.
let walk_to_eq_then_next = fn (toks: [SpannedToken], idx: i64, depth: i64) -> Option<Token> do
  match token_kind_at(toks, idx) do
    | None -> return None
    | Some(val: k) ->
      match k do
        | TkLParen | TkLBracket | TkLBrace | TkLArray -> return walk_to_eq_then_next(toks, idx: idx + 1, depth: depth + 1)
        | TkRParen | TkRBracket | TkRBrace | TkRArray -> return walk_to_eq_then_next(toks, idx: idx + 1, depth: depth - 1)
        | TkEq ->
          if depth == 0 then return token_kind_at(toks, idx: idx + 1) end
          return walk_to_eq_then_next(toks, idx: idx + 1, depth)
        | _ -> return walk_to_eq_then_next(toks, idx: idx + 1, depth)
      end
  end
end

// Is this identifier the name of a function parameter? We detect the shape
// `( IDENT :` or `, IDENT :` directly. Both patterns appear inside `fn (...)`
// signatures and inside `(name: value)` call sites — the latter aren't
// parameters but the parser treats their names as field-style labels which
// the LSP layer also colours as `parameter` for visual consistency.
let is_parameter_position = fn (toks: [SpannedToken], idx: i64) -> bool do
  match next_kind(toks, idx) do
    | Some(val: nk) ->
      if !kind_is_colon(nk) then return false end
      match prev_kind(toks, idx) do
        | Some(val: pk) ->
          if kind_is_lparen(pk) then return true end
          if kind_is_comma(pk) then return true end
          return false
        | None -> return false
      end
    | None -> return false
  end
end

// Is this identifier in a type position? Detect `: IDENT` or `-> IDENT`.
// Used for builtin lowercase type names like `i64`, `string`, `bool`.
let is_type_position = fn (toks: [SpannedToken], idx: i64) -> bool do
  match prev_kind(toks, idx) do
    | Some(val: pk) ->
      if kind_is_colon(pk) then return true end
      if kind_is_arrow(pk) then return true end
      return false
    | None -> return false
  end
end

// Is this uppercase identifier the name on the lhs of a `type` definition?
// Detect `type IDENT =`. We accept an optional `export` / `opaque` before
// `type` via `prev_skipping_modifiers`.
let is_type_def_name = fn (toks: [SpannedToken], idx: i64) -> bool do
  match prev_skipping_modifiers(toks, idx: idx - 1) do
    | Some(val: k) -> return kind_is_type(k)
    | None -> return false
  end
end

// Is this uppercase identifier the name of an exception declaration?
// Detect `exception IDENT(...)` or `exception group IDENT = ...`.
let is_exception_def_name = fn (toks: [SpannedToken], idx: i64) -> bool do
  match prev_skipping_modifiers(toks, idx: idx - 1) do
    | Some(val: k) -> return kind_is_exception(k)
    | None -> return false
  end
end

// Classify a `TkIdent` (lowercase identifier) at `idx`.
let classify_ident = fn (toks: [SpannedToken], idx: i64) -> i64 do
  // Let-binding-name? Distinguish fn-binding (function) vs value-binding
  // (variable) by peeking past `=` at the rhs head.
  if is_let_binding_name(toks, idx) then
    match rhs_first_kind(toks, name_idx: idx) do
      | Some(val: k) ->
        if kind_is_fn(k) then return tt_function end
        return tt_variable
      | None -> return tt_variable
    end
  end
  // Parameter / field-label position?
  if is_parameter_position(toks, idx) then return tt_parameter end
  // Builtin lowercase type name (e.g. `i64`) in `: i64` / `-> i64`?
  if is_type_position(toks, idx) then return tt_type end
  // Default lowercase identifier — a value reference / call.
  return tt_variable
end

// Classify a `TkUident` (uppercase identifier) at `idx`.
//
// Default: variant (constructor reference / variant decl). Bump to `type`
// for the explicit `type Foo` / `exception Foo` decl-site, and for `Foo`
// appearing in a type position (`: Foo` / `-> Foo`).
let classify_uident = fn (toks: [SpannedToken], idx: i64) -> i64 do
  if is_type_def_name(toks, idx) then return tt_type end
  if is_exception_def_name(toks, idx) then return tt_type end
  if is_type_position(toks, idx) then return tt_type end
  return tt_variant
end

// ─── Token -> SemTok emission ───────────────────────────────────────────────

// Identifier surface-name length — bytes between the start span and the
// next non-ident byte in the source. We reuse `str.scan_ident` to recover
// the exact byte length the lexer consumed.
let ident_length = fn (src: string, span: Span) -> i64 do
  match span do | Span(offset, line: _, col: _) ->
    let end_pos = str.scan_ident(s: src, start: offset)
    return end_pos - offset
  end
end

// Number literal length. The token carries the parsed value but not the
// surface form; we walk the source from the start span and count digits +
// optional decimal point + exponent letters. For our MVP we accept the
// shape `[0-9_]+(\.[0-9_]*)?([eE][+-]?[0-9_]+)?` which covers every literal
// the lexer emits today.

let ch_zero = '0'
let ch_nine = '9'
let ch_dot_byte = '.'
let ch_underscore_byte = '_'
let ch_lower_e = 'e'
let ch_upper_e = 'E'
let ch_plus_byte = '+'
let ch_minus_byte = '-'
let ch_lower_x = 'x'
let ch_lower_b = 'b'
let ch_lower_o = 'o'
let ch_upper_x = 'X'
let ch_upper_b = 'B'
let ch_upper_o = 'O'
let ch_lower_a = 'a'
let ch_lower_f = 'f'
let ch_upper_a = 'A'
let ch_upper_f = 'F'

let is_digit_or_underscore = fn (c: char) -> bool do
  if c >= ch_zero && c <= ch_nine then return true end
  if c == ch_underscore_byte then return true end
  return false
end

let is_hex_digit = fn (c: char) -> bool do
  if c >= ch_zero && c <= ch_nine then return true end
  if c >= ch_lower_a && c <= ch_lower_f then return true end
  if c >= ch_upper_a && c <= ch_upper_f then return true end
  if c == ch_underscore_byte then return true end
  return false
end

let scan_decimal_run = fn (src: string, src_len: i64, p: i64) -> i64 do
  if p >= src_len then return p end
  let c = str.byte_at(s: src, idx: p)
  if !is_digit_or_underscore(c) then return p end
  return scan_decimal_run(src, src_len, p: p + 1)
end

let scan_hex_run = fn (src: string, src_len: i64, p: i64) -> i64 do
  if p >= src_len then return p end
  let c = str.byte_at(s: src, idx: p)
  if !is_hex_digit(c) then return p end
  return scan_hex_run(src, src_len, p: p + 1)
end

let number_length = fn (src: string, span: Span) -> i64 do
  match span do | Span(offset, line: _, col: _) ->
    let src_len = str.byte_length(s: src)
    if offset >= src_len then return 1 end
    // Hex / bin / oct prefix?
    let c0 = str.byte_at(s: src, idx: offset)
    if c0 == ch_zero && offset + 1 < src_len then
      let c1 = str.byte_at(s: src, idx: offset + 1)
      if c1 == ch_lower_x || c1 == ch_upper_x then
        let end_pos = scan_hex_run(src, src_len, p: offset + 2)
        if end_pos == offset + 2 then return 2 end
        return end_pos - offset
      end
      if c1 == ch_lower_b || c1 == ch_upper_b then
        let end_pos = scan_decimal_run(src, src_len, p: offset + 2)
        if end_pos == offset + 2 then return 2 end
        return end_pos - offset
      end
      if c1 == ch_lower_o || c1 == ch_upper_o then
        let end_pos = scan_decimal_run(src, src_len, p: offset + 2)
        if end_pos == offset + 2 then return 2 end
        return end_pos - offset
      end
    end
    // Plain decimal (optionally float).
    let int_end = scan_decimal_run(src, src_len, p: offset)
    let after_int = int_end
    let after_frac = if after_int < src_len && str.byte_at(s: src, idx: after_int) == ch_dot_byte then
      scan_decimal_run(src, src_len, p: after_int + 1)
    else
      after_int
    end
    let after_exp = if after_frac < src_len && (str.byte_at(s: src, idx: after_frac) == ch_lower_e || str.byte_at(s: src, idx: after_frac) == ch_upper_e) then
      let exp_start = after_frac + 1
      let signed_start = if exp_start < src_len && (str.byte_at(s: src, idx: exp_start) == ch_plus_byte || str.byte_at(s: src, idx: exp_start) == ch_minus_byte) then exp_start + 1 else exp_start end
      scan_decimal_run(src, src_len, p: signed_start)
    else
      after_frac
    end
    if after_exp <= offset then return 1 end
    return after_exp - offset
  end
end

// String literal length: from the opening `"` byte, walk to the closing
// `"`, honouring `\` escapes. The lexer accepts UTF-8 sequences inside
// strings verbatim, so we count bytes — the LSP wire `length` is in UTF-16
// code units per the spec; clients tolerate UTF-8 counts in practice for
// ASCII-only test fixtures, and a UTF-16 conversion pass is post-MVP.

let ch_dquote_byte = '"'
let ch_backslash_byte = '\\'

let scan_string_close = fn (src: string, src_len: i64, p: i64) -> i64 do
  if p >= src_len then return p end
  let c = str.byte_at(s: src, idx: p)
  if c == ch_dquote_byte then return p + 1 end
  if c == ch_backslash_byte then
    if p + 1 >= src_len then return p + 1 end
    return scan_string_close(src, src_len, p: p + 2)
  end
  return scan_string_close(src, src_len, p: p + 1)
end

let string_length = fn (src: string, span: Span) -> i64 do
  match span do | Span(offset, line: _, col: _) ->
    let src_len = str.byte_length(s: src)
    if offset >= src_len then return 2 end
    let end_pos = scan_string_close(src, src_len, p: offset + 1)
    if end_pos <= offset then return 2 end
    return end_pos - offset
  end
end

let ch_squote_byte = '\''

let scan_char_close = fn (src: string, src_len: i64, p: i64) -> i64 do
  if p >= src_len then return p end
  let c = str.byte_at(s: src, idx: p)
  if c == ch_squote_byte then return p + 1 end
  if c == ch_backslash_byte then
    if p + 1 >= src_len then return p + 1 end
    return scan_char_close(src, src_len, p: p + 2)
  end
  return scan_char_close(src, src_len, p: p + 1)
end

let char_lit_length = fn (src: string, span: Span) -> i64 do
  match span do | Span(offset, line: _, col: _) ->
    let src_len = str.byte_length(s: src)
    if offset >= src_len then return 3 end
    let end_pos = scan_char_close(src, src_len, p: offset + 1)
    if end_pos <= offset then return 3 end
    return end_pos - offset
  end
end

// ─── Token-stream classification ────────────────────────────────────────────
//
// Walk the tokens, indexing forward. Emit a SemTok per recognised token,
// skip the rest. We collect in reverse and reverse once at the end so the
// per-step append is O(1).

let classify_token = fn (
  src: string,
  toks: [SpannedToken],
  idx: i64,
  st: SpannedToken
) -> Option<SemTok> do
  match st do | SpannedToken(token, span: Span(offset, line, col)) ->
    if token_is_keyword(t: token) then
      let len = keyword_length(t: token)
      if len <= 0 then return None end
      return Some(val: SemTok(line, col, length: len, token_type: tt_keyword))
    end
    if token_is_operator(t: token) then
      let len = operator_length(t: token)
      if len <= 0 then return None end
      return Some(val: SemTok(line, col, length: len, token_type: tt_operator))
    end
    match token do
      | TkIdent(name: _) ->
        let len = ident_length(src, span: Span(offset, line, col))
        let tt = classify_ident(toks, idx)
        return Some(val: SemTok(line, col, length: len, token_type: tt))
      | TkUident(name: _) ->
        let len = ident_length(src, span: Span(offset, line, col))
        let tt = classify_uident(toks, idx)
        return Some(val: SemTok(line, col, length: len, token_type: tt))
      | TkString(val: _) ->
        let len = string_length(src, span: Span(offset, line, col))
        return Some(val: SemTok(line, col, length: len, token_type: tt_string))
      | TkInt(val: _) | TkFloat(val: _) ->
        let len = number_length(src, span: Span(offset, line, col))
        return Some(val: SemTok(line, col, length: len, token_type: tt_number))
      | TkChar(val: _) ->
        let len = char_lit_length(src, span: Span(offset, line, col))
        return Some(val: SemTok(line, col, length: len, token_type: tt_string))
      | _ -> return None
    end
  end
end

let classify_stream_go = fn (
  src: string,
  all_toks: [SpannedToken],
  toks: [SpannedToken],
  idx: i64,
  acc: [SemTok]
) -> [SemTok] do
  match toks do
    | [] -> return acc
    | st :: rest ->
      let acc2 = match classify_token(src, toks: all_toks, idx, st) do
        | None -> acc
        | Some(val: t) -> t :: acc
      end
      return classify_stream_go(src, all_toks, toks: rest, idx: idx + 1, acc: acc2)
  end
end

let reverse_semtoks = fn (xs: [SemTok], acc: [SemTok]) -> [SemTok] do
  match xs do
    | [] -> return acc
    | t :: rest -> return reverse_semtoks(xs: rest, acc: t :: acc)
  end
end

let classify_token_stream = fn (src: string, toks: [SpannedToken]) -> [SemTok] do
  let rev = classify_stream_go(src, all_toks: toks, toks, idx: 0, acc: [])
  return reverse_semtoks(xs: rev, acc: [])
end

// ─── Comment scanning ────────────────────────────────────────────────────────
//
// The lexer drops comments before the tokenize result reaches us; re-scan
// the source bytes here to find `//` / `/* */` comments and emit one SemTok
// per comment. Block comments may span multiple lines — we emit a SemTok
// per line of the comment so the LSP delta-encode invariant holds and
// clients render each line.

let ch_slash_byte = '/'
let ch_star_byte = '*'
let ch_nl_byte = '\n'

// Track (line, col) while scanning the source so emitted SemToks carry the
// 1-based AST coords the rest of the pipeline expects.

let bump_line = fn (s: SourcePos) -> SourcePos do
  match s do | SourcePos(pos, line, col: _) ->
    return SourcePos(pos: pos + 1, line: line + 1, col: 1)
  end
end

let bump_col = fn (s: SourcePos) -> SourcePos do
  match s do | SourcePos(pos, line, col) ->
    return SourcePos(pos: pos + 1, line, col: col + 1)
  end
end

let advance_state = fn (src: string, s: SourcePos) -> SourcePos do
  let SourcePos(pos, line: _, col: _) = s
  let c = str.byte_at(s: src, idx: pos)
  if c == ch_nl_byte then return bump_line(s) end
  return bump_col(s)
end

let skip_string_literal = fn (src: string, src_len: i64, s: SourcePos) -> SourcePos do
  let SourcePos(pos, line: _, col: _) = s
  if pos >= src_len then return s end
  let c = str.byte_at(s: src, idx: pos)
  if c == ch_dquote_byte then return advance_state(src, s) end
  if c == ch_backslash_byte && pos + 1 < src_len then
    return skip_string_literal(src, src_len, s: advance_state(src, s: advance_state(src, s)))
  end
  return skip_string_literal(src, src_len, s: advance_state(src, s))
end

let skip_char_literal = fn (src: string, src_len: i64, s: SourcePos) -> SourcePos do
  let SourcePos(pos, line: _, col: _) = s
  if pos >= src_len then return s end
  let c = str.byte_at(s: src, idx: pos)
  if c == ch_squote_byte then return advance_state(src, s) end
  if c == ch_backslash_byte && pos + 1 < src_len then
    return skip_char_literal(src, src_len, s: advance_state(src, s: advance_state(src, s)))
  end
  return skip_char_literal(src, src_len, s: advance_state(src, s))
end

let scan_line_comment_end = fn (src: string, src_len: i64, s: SourcePos) -> SourcePos do
  let SourcePos(pos, line: _, col: _) = s
  if pos >= src_len then return s end
  let c = str.byte_at(s: src, idx: pos)
  if c == ch_nl_byte then return s end
  return scan_line_comment_end(src, src_len, s: bump_col(s))
end

// Walk a block comment from just-past `/*`. Returns the state at the byte
// just after the matching `*/`. Supports nested block comments because the
// lexer does — keep this consistent so the highlight covers the same
// region the parser ignores.
let scan_block_comment_end = fn (
  src: string, src_len: i64, s: SourcePos, depth: i64
) -> SourcePos do
  if depth <= 0 then return s end
  let SourcePos(pos, line: _, col: _) = s
  if pos >= src_len then return s end
  let c = str.byte_at(s: src, idx: pos)
  let c2 = if pos + 1 < src_len then str.byte_at(s: src, idx: pos + 1) else '\0' end
  if c == ch_star_byte && c2 == ch_slash_byte then
    return scan_block_comment_end(src, src_len, s: advance_state(src, s: advance_state(src, s)), depth: depth - 1)
  end
  if c == ch_slash_byte && c2 == ch_star_byte then
    return scan_block_comment_end(src, src_len, s: advance_state(src, s: advance_state(src, s)), depth: depth + 1)
  end
  return scan_block_comment_end(src, src_len, s: advance_state(src, s), depth)
end

// Emit one SemTok per *line* of a comment that runs from `start_state` to
// `end_state`. A line comment trivially produces one token. A block comment
// spanning N lines produces N tokens, each covering the comment's portion
// of its own line. This keeps the LSP delta-encode happy (each tuple stays
// on a single line) without forcing the client to handle multi-line spans.

let emit_comment_lines_go = fn (
  src: string,
  start_pos: i64, start_line: i64, start_col: i64,
  end_pos: i64,
  acc: [SemTok]
) -> [SemTok] do
  if start_pos >= end_pos then return acc end
  // Find the next newline at or after start_pos but before end_pos.
  let src_len = str.byte_length(s: src)
  let nl_pos = find_newline_or_end(src, src_len, p: start_pos, limit: end_pos)
  let line_end_pos = nl_pos
  let length = line_end_pos - start_pos
  let acc2 = if length > 0 then
    SemTok(line: start_line, col: start_col, length, token_type: tt_comment) :: acc
  else
    acc
  end
  if nl_pos >= end_pos then return acc2 end
  // Skip past the newline and continue on the next line.
  return emit_comment_lines_go(src, start_pos: nl_pos + 1, start_line: start_line + 1, start_col: 1, end_pos, acc: acc2)
end

let find_newline_or_end = fn (src: string, src_len: i64, p: i64, limit: i64) -> i64 do
  if p >= limit then return limit end
  if p >= src_len then return src_len end
  if str.byte_at(s: src, idx: p) == ch_nl_byte then return p end
  return find_newline_or_end(src, src_len, p: p + 1, limit)
end

let scan_comments_go = fn (
  src: string,
  src_len: i64,
  s: SourcePos,
  acc: [SemTok]
) -> [SemTok] do
  let SourcePos(pos, line, col) = s
  if pos >= src_len then return acc end
  let c = str.byte_at(s: src, idx: pos)
  let c2 = if pos + 1 < src_len then str.byte_at(s: src, idx: pos + 1) else '\0' end
  // Skip string / char literals so a `//` inside a string doesn't trigger.
  if c == ch_dquote_byte then
    let s2 = skip_string_literal(src, src_len, s: bump_col(s))
    return scan_comments_go(src, src_len, s: s2, acc)
  end
  if c == ch_squote_byte then
    let s2 = skip_char_literal(src, src_len, s: bump_col(s))
    return scan_comments_go(src, src_len, s: s2, acc)
  end
  if c == ch_slash_byte && c2 == ch_slash_byte then
    // Line comment: emit from current pos to next newline (or EOF).
    let start_line = line
    let start_col = col
    let s1 = bump_col(s)
    let after_slashes = bump_col(s: s1)
    let s_end = scan_line_comment_end(src, src_len, s: after_slashes)
    match s_end do | SourcePos(pos: end_pos, line: _, col: _) ->
      let length = end_pos - pos
      let acc2 = if length > 0 then
        SemTok(line: start_line, col: start_col, length, token_type: tt_comment) :: acc
      else
        acc
      end
      return scan_comments_go(src, src_len, s: s_end, acc: acc2)
    end
  end
  if c == ch_slash_byte && c2 == ch_star_byte then
    let start_line = line
    let start_col = col
    let after_open = advance_state(src, s: advance_state(src, s))
    let s_end = scan_block_comment_end(src, src_len, s: after_open, depth: 1)
    match s_end do | SourcePos(pos: end_pos, line: _, col: _) ->
      let acc2 = emit_comment_lines_go(src, start_pos: pos, start_line, start_col, end_pos, acc)
      return scan_comments_go(src, src_len, s: s_end, acc: acc2)
    end
  end
  return scan_comments_go(src, src_len, s: advance_state(src, s), acc)
end

let scan_comments = fn (src: string) -> [SemTok] do
  let src_len = str.byte_length(s: src)
  let init = SourcePos(pos: 0, line: 1, col: 1)
  let rev = scan_comments_go(src, src_len, s: init, acc: [])
  return reverse_semtoks(xs: rev, acc: [])
end

// ─── Merge sort of token + comment streams ──────────────────────────────────
//
// Both inputs are already sorted by (line, col); a single linear merge
// produces the combined sorted stream the wire emitter consumes.

let semtok_pos_lt = fn (a: SemTok, b: SemTok) -> bool do
  match a do | SemTok(line: al, col: ac, length: _, token_type: _) ->
    match b do | SemTok(line: bl, col: bc, length: _, token_type: _) ->
      if al < bl then return true end
      if al > bl then return false end
      return ac < bc
    end
  end
end

let merge_streams = fn (a: [SemTok], b: [SemTok], acc: [SemTok]) -> [SemTok] do
  match a do
    | [] -> return prepend_reversed(rest: b, acc)
    | ah :: at ->
      match b do
        | [] -> return prepend_reversed(rest: a, acc)
        | bh :: bt ->
          if semtok_pos_lt(a: ah, b: bh) then
            return merge_streams(a: at, b, acc: ah :: acc)
          end
          return merge_streams(a, b: bt, acc: bh :: acc)
      end
  end
end

let prepend_reversed = fn (rest: [SemTok], acc: [SemTok]) -> [SemTok] do
  match rest do
    | [] -> return acc
    | t :: r -> return prepend_reversed(rest: r, acc: t :: acc)
  end
end

let merge_semtoks = fn (a: [SemTok], b: [SemTok]) -> [SemTok] do
  let rev = merge_streams(a, b, acc: [])
  return reverse_semtoks(xs: rev, acc: [])
end

// ─── Delta encoding ─────────────────────────────────────────────────────────
//
// Convert SemTok stream (AST 1-based coords) to LSP wire data array
// (0-based delta-encoded). Each tuple = (deltaLine, deltaStart, length,
// tokenType, tokenModifiers).
//
// Edge case: two tokens at the same (line, col) — possible if a synthetic
// emission collides with a comment. We tolerate it: deltaLine = 0 and
// deltaStart = 0 are valid; clients render the later token on top.

let delta_encode_go = fn (
  toks: [SemTok],
  prev_line: i64,
  prev_col: i64,
  acc: [i64]
) -> [i64] do
  match toks do
    | [] -> return acc
    | SemTok(line, col, length, token_type) :: rest ->
      let line0 = saturating_pred(n: line)
      let col0 = saturating_pred(n: col)
      let dl = line0 - prev_line
      let ds = if dl == 0 then col0 - prev_col else col0 end
      let acc2 = 0 :: token_type :: length :: ds :: dl :: acc
      return delta_encode_go(toks: rest, prev_line: line0, prev_col: col0, acc: acc2)
  end
end

let reverse_ints = fn (xs: [i64], acc: [i64]) -> [i64] do
  match xs do
    | [] -> return acc
    | n :: rest -> return reverse_ints(xs: rest, acc: n :: acc)
  end
end

let delta_encode = fn (toks: [SemTok]) -> [i64] do
  let rev = delta_encode_go(toks, prev_line: 0, prev_col: 0, acc: [])
  return reverse_ints(xs: rev, acc: [])
end

// ─── Driver ─────────────────────────────────────────────────────────────────

/**
Compute the wire `SemanticTokens` reply for a buffer's full text.

Pipeline: tokenize → classify token-stream → scan comments → merge →
delta-encode. The function is total — a lex failure produces an empty
token list, which still serializes as `SemanticTokens(data: [])` (a valid
"no highlights" reply that clears any stale client-side highlights).
*/
export let compute_semantic_tokens = fn (text: string) -> SemanticTokens do
  let toks = lexer.tokenize(src: text)
  let classified = classify_token_stream(src: text, toks)
  let comments = scan_comments(src: text)
  let merged = merge_semtoks(a: classified, b: comments)
  let data = delta_encode(toks: merged)
  return SemanticTokens(data)
end

/**
Expose the intermediate SemTok stream for testing — fixtures assert on
specific (line, col, length, token_type) tuples without re-deriving the
delta-encoding.
*/
export let compute_sem_toks = fn (text: string) -> [SemTok] do
  let toks = lexer.tokenize(src: text)
  let classified = classify_token_stream(src: text, toks)
  let comments = scan_comments(src: text)
  return merge_semtoks(a: classified, b: comments)
end
