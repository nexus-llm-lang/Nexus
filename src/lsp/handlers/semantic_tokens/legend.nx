import { SemanticTokensLegend } from "src/lsp/protocol/completion.nx"

let legend_token_types = fn () -> [string] do
  return [
    "keyword",
    "function",
    "variable",
    "parameter",
    "type",
    "variant",
    "string",
    "number",
    "comment",
    "operator"
  ]
end

let legend_token_modifiers = fn () -> [string] do
  return []
end

/** Build the SemanticTokensLegend the server advertises in `initialize` — token-type names in legend index order, empty modifier list. */
export let semantic_tokens_legend = fn () -> SemanticTokensLegend do
  return SemanticTokensLegend(
    token_types: legend_token_types(),
    token_modifiers: legend_token_modifiers()
  )
end
