import * as str from "std:str"
import * as char from "std:char"
import { Span } from "src/syntax/token.nx"

let ch_zero = '0'
let ch_nine = '9'
let ch_dot_byte = '.'
let ch_underscore_byte = '_'
let ch_lower_e = 'e'
let ch_upper_e = 'E'
let ch_plus_byte = '+'
let ch_minus_byte = '-'
let ch_lower_x = 'x'
let ch_lower_b = 'b'
let ch_lower_o = 'o'
let ch_upper_x = 'X'
let ch_upper_b = 'B'
let ch_upper_o = 'O'
let ch_lower_a = 'a'
let ch_lower_f = 'f'
let ch_upper_a = 'A'
let ch_upper_f = 'F'

let ch_dquote_byte = '"'
let ch_backslash_byte = '\\'
let ch_squote_byte = '\''

let is_digit_or_underscore = fn (c: char) -> bool do
  if c >= ch_zero && c <= ch_nine then return true end
  if c == ch_underscore_byte then return true end
  return false
end

let is_hex_digit = fn (c: char) -> bool do
  if c >= ch_zero && c <= ch_nine then return true end
  if c >= ch_lower_a && c <= ch_lower_f then return true end
  if c >= ch_upper_a && c <= ch_upper_f then return true end
  if c == ch_underscore_byte then return true end
  return false
end

let scan_decimal_run = fn (src: string, src_len: i64, p: i64) -> i64 do
  if p >= src_len then return p end
  let c = str.byte_at(s: src, idx: p)
  if !is_digit_or_underscore(c) then return p end
  return scan_decimal_run(src, src_len, p: p + 1)
end

let scan_hex_run = fn (src: string, src_len: i64, p: i64) -> i64 do
  if p >= src_len then return p end
  let c = str.byte_at(s: src, idx: p)
  if !is_hex_digit(c) then return p end
  return scan_hex_run(src, src_len, p: p + 1)
end

export let number_length = fn (src: string, span: Span) -> i64 do
  let Span(offset, line: _, col: _) = span
  let src_len = str.byte_length(s: src)
    if offset >= src_len then return 1 end
    let c0 = str.byte_at(s: src, idx: offset)
    if c0 == ch_zero && offset + 1 < src_len then
      let c1 = str.byte_at(s: src, idx: offset + 1)
      if c1 == ch_lower_x || c1 == ch_upper_x then
        let end_pos = scan_hex_run(src, src_len, p: offset + 2)
        if end_pos == offset + 2 then return 2 end
        return end_pos - offset
      end
      if c1 == ch_lower_b || c1 == ch_upper_b then
        let end_pos = scan_decimal_run(src, src_len, p: offset + 2)
        if end_pos == offset + 2 then return 2 end
        return end_pos - offset
      end
      if c1 == ch_lower_o || c1 == ch_upper_o then
        let end_pos = scan_decimal_run(src, src_len, p: offset + 2)
        if end_pos == offset + 2 then return 2 end
        return end_pos - offset
      end
    end
    let int_end = scan_decimal_run(src, src_len, p: offset)
    let after_int = int_end
    let after_frac = if after_int < src_len && str.byte_at(s: src, idx: after_int) == ch_dot_byte then
      scan_decimal_run(src, src_len, p: after_int + 1)
    else
      after_int
    end
    let after_exp = if after_frac < src_len && (str.byte_at(s: src, idx: after_frac) == ch_lower_e || str.byte_at(s: src, idx: after_frac) == ch_upper_e) then
      let exp_start = after_frac + 1
      let signed_start = if exp_start < src_len && (str.byte_at(s: src, idx: exp_start) == ch_plus_byte || str.byte_at(s: src, idx: exp_start) == ch_minus_byte) then exp_start + 1 else exp_start end
      scan_decimal_run(src, src_len, p: signed_start)
    else
      after_frac
    end
    if after_exp <= offset then return 1 end
    return after_exp - offset
end

let scan_string_close = fn (src: string, src_len: i64, p: i64) -> i64 do
  if p >= src_len then return p end
  let c = str.byte_at(s: src, idx: p)
  if c == ch_dquote_byte then return p + 1 end
  if c == ch_backslash_byte then
    if p + 1 >= src_len then return p + 1 end
    return scan_string_close(src, src_len, p: p + 2)
  end
  return scan_string_close(src, src_len, p: p + 1)
end

let scan_char_close = fn (src: string, src_len: i64, p: i64) -> i64 do
  if p >= src_len then return p end
  let c = str.byte_at(s: src, idx: p)
  if c == ch_squote_byte then return p + 1 end
  if c == ch_backslash_byte then
    if p + 1 >= src_len then return p + 1 end
    return scan_char_close(src, src_len, p: p + 2)
  end
  return scan_char_close(src, src_len, p: p + 1)
end

let utf8_seq_len_of = fn (b: i64) -> i64 do
  if b < 128 then return 1 end
  if b < 192 then return 1 end
  if b < 224 then return 2 end
  if b < 240 then return 3 end
  return 4
end

let utf16_len_range_go = fn (src: string, src_len: i64, p: i64, limit: i64, acc: i64) -> i64 do
  if p >= limit then return acc end
  if p >= src_len then return acc end
  let b = char.ord(c: str.byte_at(s: src, idx: p))
  let seq = utf8_seq_len_of(b)
  let units = if seq == 4 then 2 else 1 end
  return utf16_len_range_go(src, src_len, p: p + seq, limit, acc: acc + units)
end

/** Count UTF-16 code units for the UTF-8 source substring [from_byte, to_byte). */
export let utf16_len_range = fn (src: string, from_byte: i64, to_byte: i64) -> i64 do
  let src_len = str.byte_length(s: src)
  return utf16_len_range_go(src, src_len, p: from_byte, limit: to_byte, acc: 0)
end

export let ident_length = fn (src: string, span: Span) -> i64 do
  let Span(offset, line: _, col: _) = span
  let end_pos = str.scan_ident(s: src, start: offset)
    return end_pos - offset
end

export let string_length = fn (src: string, span: Span) -> i64 do
  let Span(offset, line: _, col: _) = span
  let src_len = str.byte_length(s: src)
    if offset >= src_len then return 2 end
    let end_pos = scan_string_close(src, src_len, p: offset + 1)
    if end_pos <= offset then return 2 end
    return utf16_len_range(src, from_byte: offset, to_byte: end_pos)
end

export let char_lit_length = fn (src: string, span: Span) -> i64 do
  let Span(offset, line: _, col: _) = span
  let src_len = str.byte_length(s: src)
    if offset >= src_len then return 3 end
    let end_pos = scan_char_close(src, src_len, p: offset + 1)
    if end_pos <= offset then return 3 end
    return utf16_len_range(src, from_byte: offset, to_byte: end_pos)
end
