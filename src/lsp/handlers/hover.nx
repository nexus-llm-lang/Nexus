/**
 * lsp/hover: resolve textDocument/hover requests.
 *
 * Phase 1 (this module):
 *   - Identifier hover: when the cursor sits on an identifier that resolves
 *     to a top-level `let` or `cap` binding, returns a markdown Hover with
 *     the function signature: name, parameter types, return type, and
 *     `require {}` / `throws {}` annotations.
 *   - Let-binding hover: when the identifier resolves to a non-lambda top-level
 *     `let` with a declared type annotation, renders `**name**: Type`.
 *
 * Pipeline (mirrors `definition.nx`):
 *   1. Tokenize the buffer. Locate the identifier at the cursor via
 *      `definition.find_ident_at`. Collapse `alias.foo` clusters via
 *      `definition.visible_name_for`.
 *   2. Run `build_program_state` (lex+parse+import) to obtain the rename map
 *      and the parsed defs/cache. The HIR is NOT built here — the AST carries
 *      the declared type annotations we need and rebuilding HIR+typecheck per
 *      hover request would be expensive (50-100ms on mid-size files).
 *   3. Translate the visible name through `symtab.rename` to get the canonical
 *      `source#name` form. If no rename hit, the identifier is a local binding,
 *      builtin, or typo — return None (no hover).
 *   4. Walk the entry-file defs then the cached imports for a matching
 *      `GlobalLet`. Extract type information from the AST `ExprLambda` or
 *      from the top-level type annotation.
 *   5. Render markdown.
 *
 * Returns None for:
 *   - cursor not on an identifier,
 *   - identifier does not resolve to a known top-level binding,
 *   - lex/parse/import failure (the try wrapping returns None).
 *
 * Out of scope for this bd (separate issues):
 *   - cap / handler / cap method hover
 *   - enum variant hover
 *   - linear sigil hover
 *   - import-target hover
 *
 * HirProgram rebuild cost note:
 *   This handler deliberately avoids HIR+typecheck to keep hover latency low.
 *   The AST annotation path is adequate for Phase 1 (declared types). Inferred
 *   types for non-annotated locals are a Phase 2 concern requiring HIR caching.
 */

import { Option, Some, None } from "std:option"
import * as list from "std:list"
import * as str from "std:str"
import * as lexer from "src/frontend/lexer.nx"
import {
  SpannedTopLevel, GlobalLet, TLLet, Cap, TLCap, TLEnum,
  EnumDef, VariantDef, VariantField,
  SpannedExpr, Expr, ExprLambda, Param,
  TypeExpr, TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear,
  TyLazy, TyBorrow, TyArray, TyList, TyRecord, TyRow, TyHandler,
  NamedType, Sigil, SigilLinear, SigilLazy, SigilBorrow, SigilMutable,
  FunctionSig
} from "src/common/ast.nx"
import { CacheEntry } from "src/ir/shared/imports.nx"
import { RenameEntry }, * as symtab from "src/ir/shared/symtab.nx"
import * as rdr from "src/ir/shared/rdrname.nx"
import {
  find_ident_at, visible_name_for, canonical_to_local_name
} from "src/lsp/handlers/definition.nx"
import {
  ProgramState, build_program_state
} from "src/lsp/state/program_state.nx"
import { CompileError } from "src/common/error.nx"
import { Fs } from "std:fs"
import { Console } from "std:stdio"

//
// Type rendering: a fuller pp_type than typecheck/types.nx::type_to_string.
// These helpers are intentionally local — shared lsp type rendering may be
// factored into a utility module in a later cleanup pass.

let pp_type_list_go = fn (ts: [TypeExpr], acc: [string]) -> [string] do
  match ts do
    | [] -> return list.reverse(xs: acc)
    | t :: rest -> return pp_type_list_go(ts: rest, acc: pp_type(t) :: acc)
  end
end

let pp_named_types_go = fn (nts: [NamedType], acc: [string]) -> [string] do
  match nts do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name, typ) :: rest ->
      return pp_named_types_go(nts: rest, acc: (name ++ ": " ++ pp_type(t: typ)) :: acc)
  end
end

let pp_row = fn (row: TypeExpr) -> string do
  match row do
    | TyRow(types: ts, rest: _) ->
      if list.is_empty(xs: ts) then return "" end
      let parts = pp_type_list_go(ts, acc: [])
      return "{ " ++ str.join(xs: parts, sep: ", ") ++ " }"
    | _ -> return ""
  end
end

let pp_type = fn (t: TypeExpr) -> string do
  match t do
    | TyI32 -> return "i32"
    | TyI64 -> return "i64"
    | TyF32 -> return "f32"
    | TyF64 -> return "f64"
    | TyBool -> return "bool"
    | TyChar -> return "char"
    | TyString -> return "string"
    | TyUnit -> return "()"
    | TyIntLit -> return "<int>"
    | TyFloatLit -> return "<float>"
    | TyVar(name: n) -> return n
    | TyUserDefined(name: n, args: []) -> return n
    | TyUserDefined(name: n, args: a) ->
      let parts = pp_type_list_go(ts: a, acc: [])
      return n ++ "<" ++ str.join(xs: parts, sep: ", ") ++ ">"
    | TyArrow(params, ret, requires, throw_row) ->
      let ps = pp_named_types_go(nts: params, acc: [])
      let req = pp_row(row: requires)
      let thr = pp_row(row: throw_row)
      let req_str = if str.length(s: req) == 0 then "" else " require " ++ req end
      let thr_str = if str.length(s: thr) == 0 then "" else " throws " ++ thr end
      return "fn(" ++ str.join(xs: ps, sep: ", ") ++ ") -> " ++ pp_type(t: ret) ++ req_str ++ thr_str
    | TyRef(inner) -> return "ref " ++ pp_type(t: inner)
    | TyLinear(inner) -> return "%" ++ pp_type(t: inner)
    | TyLazy(inner) -> return "@" ++ pp_type(t: inner)
    | TyBorrow(inner) -> return "&" ++ pp_type(t: inner)
    | TyArray(elem) -> return "[|" ++ pp_type(t: elem) ++ "|]"
    | TyList(elem) -> return "[" ++ pp_type(t: elem) ++ "]"
    | TyRecord(fields) ->
      let parts = pp_named_types_go(nts: fields, acc: [])
      return "{ " ++ str.join(xs: parts, sep: ", ") ++ " }"
    | TyRow(_) -> return pp_row(row: t)
    | TyHandler(name, requires: _) -> return "handler " ++ name
  end
end

let sigil_prefix = fn (s: Sigil) -> string do
  match s do
    | SigilLinear -> return "%"
    | SigilLazy -> return "@"
    | SigilBorrow -> return "&"
    | SigilMutable -> return "mut "
    | _ -> return ""
  end
end

let param_to_string = fn (p: Param) -> string do
  match p do | Param(name, sigil, typ) ->
    return sigil_prefix(s: sigil) ++ name ++ ": " ++ pp_type(t: typ)
  end
end

let params_to_label_parts = fn (params: [Param], acc: [string]) -> [string] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | p :: rest -> return params_to_label_parts(params: rest, acc: param_to_string(p) :: acc)
  end
end

let join_parts = fn (parts: [string], sep: string, acc: string, first: bool) -> string do
  match parts do
    | [] -> return acc
    | p :: rest ->
      let next = if first then p else acc ++ sep ++ p end
      return join_parts(parts: rest, sep, acc: next, first: false)
  end
end

//
// The `HoverInfo` type carries either a full function signature or a simple
// binding type (for non-lambda top-level lets).

/** Hover content for a resolved identifier: the local name plus rendered type. */
export type HoverInfo =
  HoverFn(local_name: string, params_str: string, ret_str: string, req_str: string, thr_str: string)
  | HoverBinding(local_name: string, type_str: string)
  | HoverEnum(enum_name: string, type_params: [string], variants: [VariantDef])
  | HoverCap(cap_name: string, functions: [FunctionSig])

// Render a single VariantField as "name: Type" or just "Type" for anonymous fields.
let pp_variant_field = fn (vf: VariantField) -> string do
  match vf do
    | VariantField(name: Some(val: n), typ) -> return n ++ ": " ++ pp_type(t: typ)
    | VariantField(name: None, typ) -> return pp_type(t: typ)
  end
end

let pp_variant_fields_go = fn (fs: [VariantField], acc: [string]) -> [string] do
  match fs do
    | [] -> return list.reverse(xs: acc)
    | f :: rest -> return pp_variant_fields_go(fs: rest, acc: pp_variant_field(f) :: acc)
  end
end

// Render one VariantDef as "Name" or "Name(f1, f2, ...)".
let pp_variant_def = fn (vd: VariantDef) -> string do
  match vd do
    | VariantDef(name: n, fields: []) -> return n
    | VariantDef(name: n, fields: fs) ->
      let parts = pp_variant_fields_go(fs, acc: [])
      return n ++ "(" ++ str.join(xs: parts, sep: ", ") ++ ")"
  end
end

let render_variants_go = fn (vs: [VariantDef], acc: string) -> string do
  match vs do
    | [] -> return acc
    | v :: rest ->
      let line = "  - " ++ pp_variant_def(v)
      let next = if str.length(s: acc) == 0 then line else acc ++ "\n" ++ line end
      return render_variants_go(vs: rest, acc: next)
  end
end

// Render enum type params as "<A, B>" or "" when empty.
let pp_type_params = fn (tps: [string]) -> string do
  match tps do
    | [] -> return ""
    | _ -> return "<" ++ str.join(xs: tps, sep: ", ") ++ ">"
  end
end

// Render one FunctionSig as "name(p1, p2) -> ret" for the cap method list.
let pp_function_sig = fn (fs: FunctionSig) -> string do
  match fs do | FunctionSig(name: fn_name, params, ret_type, requires, throw_row) ->
    let param_parts = params_to_label_parts(params, acc: [])
    let params_str = join_parts(parts: param_parts, sep: ", ", acc: "", first: true)
    let ret_str = pp_type(t: ret_type)
    let req_str = pp_row(row: requires)
    let thr_str = pp_row(row: throw_row)
    let req_part = if str.length(s: req_str) == 0 then "" else " require " ++ req_str end
    let thr_part = if str.length(s: thr_str) == 0 then "" else " throws " ++ thr_str end
    return fn_name ++ "(" ++ params_str ++ ") -> " ++ ret_str ++ req_part ++ thr_part
  end
end

let render_cap_methods_go = fn (fns: [FunctionSig], acc: string) -> string do
  match fns do
    | [] -> return acc
    | f :: rest ->
      let line = "  - " ++ pp_function_sig(fs: f)
      let next = if str.length(s: acc) == 0 then line else acc ++ "\n" ++ line end
      return render_cap_methods_go(fns: rest, acc: next)
  end
end

/** Render a HoverInfo as a markdown string for the LSP `contents.value` field. */
export let render_hover_markdown = fn (info: HoverInfo) -> string do
  match info do
    | HoverFn(local_name, params_str, ret_str, req_str, thr_str) ->
      let req_part = if str.length(s: req_str) == 0 then "" else " require " ++ req_str end
      let thr_part = if str.length(s: thr_str) == 0 then "" else " throws " ++ thr_str end
      return "**" ++ local_name ++ "**: fn(" ++ params_str ++ ") -> " ++ ret_str ++ req_part ++ thr_part
    | HoverBinding(local_name, type_str) ->
      return "**" ++ local_name ++ "**: " ++ type_str
    | HoverEnum(enum_name, type_params, variants) ->
      let header = "**" ++ enum_name ++ pp_type_params(type_params) ++ "** (enum)"
      let body = render_variants_go(vs: variants, acc: "")
      if str.length(s: body) == 0 then
        return header
      end
      return header ++ "\nvariants:\n" ++ body
    | HoverCap(cap_name, functions: fns) ->
      let header = "**" ++ cap_name ++ "** (cap)"
      let body = render_cap_methods_go(fns, acc: "")
      if str.length(s: body) == 0 then
        return header
      end
      return header ++ "\nmethods:\n" ++ body
  end
end

//
// Lookup: walk the entry-file defs, then the cached imported files.

let hover_info_from_global_let = fn (
  local_name: string,
  name: string,
  value: SpannedExpr
) -> Option<HoverInfo> do
  match value do | SpannedExpr(node: enode, span: _) ->
    match enode do
      | ExprLambda(type_params: _, params, ret_type, requires, throw_row, body: _) ->
        let param_parts = params_to_label_parts(params, acc: [])
        let params_str = join_parts(parts: param_parts, sep: ", ", acc: "", first: true)
        let ret_str = pp_type(t: ret_type)
        let req_str = pp_row(row: requires)
        let thr_str = pp_row(row: throw_row)
        return Some(val: HoverFn(local_name, params_str, ret_str, req_str, thr_str))
      | _ ->
        // Non-lambda: surface the declared type annotation if present.
        return None
    end
  end
end

let find_hover_in_defs = fn (
  defs: [SpannedTopLevel],
  source: string,
  target_canonical: string,
  local_name: string
) -> Option<HoverInfo> do
  match defs do
    | [] -> return None
    | SpannedTopLevel(node: TLLet(def: GlobalLet(name, is_public: _, typ, value)), span: _) :: rest ->
      let canonical = if name == "main" then "main" else rdr.canonical_name(source_path: source, name) end
      if canonical == target_canonical then
        match hover_info_from_global_let(local_name, name, value) do
          | Some(val: info) -> return Some(val: info)
          | None ->
            // Non-lambda: try the declared type annotation.
            match typ do
              | Some(val: t) ->
                return Some(val: HoverBinding(local_name, type_str: pp_type(t)))
              | None ->
                // No annotation; render as <inferred>.
                return Some(val: HoverBinding(local_name, type_str: "<inferred>"))
            end
        end
      end
      return find_hover_in_defs(defs: rest, source, target_canonical, local_name)
    | SpannedTopLevel(node: TLCap(def: Cap(name, is_public: _, functions: fns)), span: _) :: rest ->
      let canonical = rdr.canonical_name(source_path: source, name)
      if canonical == target_canonical then
        return Some(val: HoverCap(cap_name: local_name, functions: fns))
      end
      return find_hover_in_defs(defs: rest, source, target_canonical, local_name)
    | _ :: rest ->
      return find_hover_in_defs(defs: rest, source, target_canonical, local_name)
  end
end

let find_hover_in_cache = fn (
  cache: [CacheEntry],
  target_canonical: string,
  local_name: string
) -> Option<HoverInfo> do
  match cache do
    | [] -> return None
    | CacheEntry(path, defs, entries: _) :: rest ->
      match find_hover_in_defs(defs, source: path, target_canonical, local_name) do
        | Some(val: info) -> return Some(val: info)
        | None -> return find_hover_in_cache(cache: rest, target_canonical, local_name)
      end
  end
end

// Return true when the name's first character is in [A-Z], identifying an
// enum constructor (TkUident) rather than a lowercase identifier (TkIdent).
let is_uppercase_start = fn (name: string) -> bool do
  if str.length(s: name) == 0 then return false end
  let c = str.char_code(s: name, idx: 0)
  return c >= 65 && c <= 90
end

// Strip a leading `alias.` qualifier from a visible name, returning the bare
// constructor name used for enum variant lookup.
let bare_ctor_name = fn (visible: string) -> string do
  let dot = str.index_of(s: visible, sub: ".")
  if dot < 0 then return visible end
  let total = str.length(s: visible)
  return str.substring(s: visible, start: dot + 1, len: total - dot - 1)
end

// Check whether `variants` contains a variant named `ctor_name`.
let variant_list_has = fn (variants: [VariantDef], ctor_name: string) -> bool do
  match variants do
    | [] -> return false
    | VariantDef(name: n, fields: _) :: rest ->
      if n == ctor_name then return true
      else return variant_list_has(variants: rest, ctor_name)
      end
  end
end

// Walk top-level defs in one file; return the EnumDef whose variants list
// includes `ctor_name`, or None.
let find_enum_for_ctor_in_defs = fn (defs: [SpannedTopLevel], ctor_name: string) -> Option<EnumDef> do
  match defs do
    | [] -> return None
    | SpannedTopLevel(node: TLEnum(def: ed), span: _) :: rest ->
      match ed do | EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs) ->
        if variant_list_has(variants: vs, ctor_name) then
          return Some(val: ed)
        end
      end
      return find_enum_for_ctor_in_defs(defs: rest, ctor_name)
    | _ :: rest ->
      return find_enum_for_ctor_in_defs(defs: rest, ctor_name)
  end
end

// Walk the import cache; return the first EnumDef whose variants include
// `ctor_name`, scanning across all cached files.
let find_enum_for_ctor_in_cache = fn (cache: [CacheEntry], ctor_name: string) -> Option<EnumDef> do
  match cache do
    | [] -> return None
    | CacheEntry(path: _, defs, entries: _) :: rest ->
      match find_enum_for_ctor_in_defs(defs, ctor_name) do
        | Some(val: ed) -> return Some(val: ed)
        | None -> return find_enum_for_ctor_in_cache(cache: rest, ctor_name)
      end
  end
end

/**
Resolve hover information for the identifier at the cursor.

`text` is the editor buffer contents. `file_uri` mirrors what diagnostics uses.
`line` / `character` are 0-based LSP coordinates.

Returns `Some(string)` with the markdown hover content on success, `None` for:
- cursor not on an identifier,
- identifier does not resolve to a known top-level binding,
- lex/parse/import-resolution failure.

No HIR build is performed — the AST annotation path is used. This keeps
hover latency comparable to definition resolution rather than diagnostics
(which runs the full typecheck pass). Inferred types for non-annotated
local let bindings are a Phase 2 concern.
*/
export let resolve_hover = fn (
  text: string,
  file_uri: string,
  line: i64,
  character: i64
) -> Option<string> require { Console, Fs } do
  try
    return resolve_hover_unsafe(text, file_uri, line, character)
  catch _ ->
    return None
  end
end

let resolve_hover_unsafe = fn (
  text: string,
  file_uri: string,
  line: i64,
  character: i64
) -> Option<string> require { Console, Fs } throws { CompileError } do
  let toks = lexer.tokenize(src: text)
  match find_ident_at(toks, line, character) do
    | None -> return None
    | Some(val: hit) ->
      let visible = visible_name_for(toks, hit)
      let ProgramState(prog: _, defs, cache, accum: _, self_entries: _, caller_entries: _, all_entries) =
        build_program_state(text, file: file_uri)
      // Phase 4: enum variant constructor path.
      // Constructor names begin with an uppercase letter (TkUident). They are
      // NOT in the rename map (the rename map covers TLLet/TLCap only).
      // Strip any `alias.` prefix to get the bare constructor name, then scan
      // all TLEnum defs in the entry file and the import cache.
      // This also handles pattern-position constructors (e.g. `Some(x)` in a
      // match arm) — the token stream is identical to the call-expression case.
      //
      // Phase 3 note: cap names also start with uppercase (they are TkUident).
      // When the enum scan returns None, fall through to the rename path below
      // which will find the TLCap and return HoverCap instead.
      let ctor_name = bare_ctor_name(visible)
      if is_uppercase_start(ctor_name) then
        let enum_opt = match find_enum_for_ctor_in_defs(defs, ctor_name) do
          | Some(val: ed) -> Some(val: ed)
          | None -> find_enum_for_ctor_in_cache(cache, ctor_name)
        end
        match enum_opt do
          | Some(val: ed) ->
            let EnumDef(name: ename, is_public: _, is_opaque: _, type_params: tps, variants: vs) = ed
            let info = HoverEnum(enum_name: ename, type_params: tps, variants: vs)
            return Some(val: render_hover_markdown(info))
          | None ->
            // Not an enum variant. Fall through to the rename path: if `visible`
            // renames to a known canonical, lookup handles TLLet / TLCap.
            let _ = 0
        end
      end
      // Phase 3: cap.method qualified reference (e.g. `Console.print`).
      // visible_name_for collapses `Cap TkDot method` into `Cap.method`. The
      // rename map has no entry for `Cap.method` as a unit; instead, split on
      // the first dot, rename just the cap part, then look up the cap def.
      let dot_pos = str.index_of(s: visible, sub: ".")
      if dot_pos > 0 then
        let cap_part = str.substring(s: visible, start: 0, len: dot_pos)
        if is_uppercase_start(cap_part) then
          let cap_canonical = symtab.rename(name: cap_part, entries: all_entries)
          if cap_canonical != cap_part then
            let cap_local = canonical_to_local_name(cap_canonical)
            let cap_info_opt = match find_hover_in_defs(defs, source: file_uri, target_canonical: cap_canonical, local_name: cap_local) do
              | Some(val: info) -> Some(val: info)
              | None -> find_hover_in_cache(cache, target_canonical: cap_canonical, local_name: cap_local)
            end
            match cap_info_opt do
              | Some(val: info) -> return Some(val: render_hover_markdown(info))
              | None -> return None
            end
          end
        end
      end
      let canonical = symtab.rename(name: visible, entries: all_entries)
      // No rename hit: local binding, builtin, or typo.
      if canonical == visible then return None end
      let local_name = canonical_to_local_name(canonical)
      let entry_result = find_hover_in_defs(defs, source: file_uri, target_canonical: canonical, local_name)
      let info_opt = match entry_result do
        | Some(val: info) -> Some(val: info)
        | None -> find_hover_in_cache(cache, target_canonical: canonical, local_name)
      end
      match info_opt do
        | None -> return None
        | Some(val: info) -> return Some(val: render_hover_markdown(info))
      end
  end
end
