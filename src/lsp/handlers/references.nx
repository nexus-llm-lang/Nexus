/**
 * lsp/references: resolve textDocument/references requests.
 *
 * Pipeline:
 *   1. Tokenize the editor buffer; locate the identifier under the cursor
 *      using `definition.find_ident_at` + `visible_name_for` (so `alias.foo`
 *      qualified references collapse to one visible name).
 *   2. Run the same lex+parse+import-aware build pipeline `definition.nx`
 *      uses (`build_program_state`); resolve the cursor name through the
 *      importer rename map to its canonical `source#name` form.
 *   3. Walk every expression in the entry-file's defs PLUS every cached
 *      imported file's defs. For each `ExprVariable` / `ExprCall` /
 *      `ExprConstructor`, apply the *that-file's-own-view* rename map and
 *      compare to the target canonical. Collect spans of all matches.
 *   4. If `include_declaration` is true, prepend the def-site Location
 *      (computed via the same logic `definition.resolve_definition` uses).
 *
 * Returns `[]` for:
 *   - cursor outside any identifier,
 *   - identifier doesn't resolve through the rename map (local binding,
 *     builtin, typo),
 *   - lex/parse/import-resolution failure (the buffer is too broken to
 *     ground a rename map).
 *
 * Out of scope (per non-goals):
 *   - workspace-wide reference (every `.nx` outside imported set),
 *   - type / variant / record-field references,
 *   - shadowing-aware scope analysis (canonical-name match is sufficient
 *     for top-level let / cap names — local lets shadow into a different
 *     space and never collide).
 *
 * Coordinate model: same as definition — Span 1-based -> LSP 0-based,
 * single-line range widened by the identifier name length.
 */

import { Option, Some, None } from "std:option"
import * as list from "std:list"
import * as lexer from "src/frontend/lexer.nx"
import {
  SpannedTopLevel, GlobalLet, TLLet, Cap, TLCap, Function,
  HandlerArm,
  SpannedExpr, Expr, ExprLiteral, ExprVariable, ExprBorrow,
  ExprBinaryOp, ExprUnaryOp, ExprCall, ExprConstructor, ExprExternal,
  ExprArray, ExprList, ExprRecord, ExprIndex, ExprFieldAccess,
  ExprIf, ExprMatch, ExprWhile, ExprFor, ExprLambda,
  ExprRaise, ExprForce, ExprHandler,
  SpannedStmt, Stmt, StmtLet, StmtLetPattern, StmtExpr, StmtReturn,
  StmtAssign, StmtIndexAssign, StmtTry, StmtInject,
  MatchCase, CatchArm, CallArg, CtorArg, NamedExpr,
  RdrName, Unqual, Qual
} from "src/syntax/ast.nx"
import { Span } from "src/syntax/token.nx"
import { CacheEntry } from "src/ir/shared/imports.nx"
import { RenameEntry }, * as symtab from "src/ir/shared/symtab.nx"
import * as rdr from "src/ir/shared/rdrname.nx"
import {
  ProgramState, build_program_state, build_self_entries
} from "src/lsp/state/program_state.nx"
import {
  IdentHit,
  find_ident_at,
  visible_name_for,
  DefEntry,
  collect_defs_from_file,
  collect_defs_from_cache,
  lookup_def,
  canonical_to_local_name,
  make_location
} from "src/lsp/handlers/definition.nx"
import * as str from "std:str"
import * as lazy from "std:lazy"
import { Fs } from "std:fs"
import { Console } from "std:stdio"
import { Location } from "src/lsp/protocol/text_doc.nx"
import { CompileError } from "src/common/error.nx"

//
// We classify a use site by: take its `RdrName`, render it to a visible
// string (`alias.foo` for Qual, plain name for Unqual), apply the file's
// own rename map, and compare against the target canonical. Matches collect
// the SpannedExpr's outer span — the parser anchors that span at the
// identifier (call sites, variable references), so the LSP highlight lands
// directly on the name rather than the whole call expression.

let rdr_visible = fn (r: RdrName) -> string do
  return rdr.rdr_to_string(r)
end

let rdr_local_name = fn (r: RdrName) -> string do
  return rdr.rdr_occ(r)
end

// For a Qual(alias, name) reference the parser anchors the SpannedExpr span
// at the alias token, but the LSP range should cover only the callee name.
// Shift the column forward by len(alias)+1 (the dot) so the highlight lands
// on `name` rather than starting at `alias`.
let rdr_name_span = fn (r: RdrName, span: Span) -> Span do
  match r do
    | Unqual(name: _) -> return span
    | Qual(alias, name: _) ->
      match span do | Span(offset, line, col) ->
        return Span(offset, line, col: col + str.length(s: alias) + 1)
      end
  end
end

// Append `xs ++ ys`. Used for cross-section reference accumulation.
let append_locs = fn (xs: [ Location ], ys: [ Location ]) -> [ Location ] do
  match xs do
    | [] -> return ys
    | x :: rest -> return x :: append_locs(xs: rest, ys)
  end
end

// Resolve `r` against `entries`; return Some(canonical) if it matches the
// target, None otherwise. Treats Unqual and Qual the same: visible name is
// the input to the rename map.
let rdr_resolves_to = fn (r: RdrName, entries: [ RenameEntry ], target: string) -> bool do
  let visible = rdr_visible(r)
  let canon = symtab.rename(name: visible, entries)
  return canon == target
end

let walk_expr = fn (
  e: SpannedExpr, entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match e do | SpannedExpr(node, span) ->
    return walk_expr_node(node, span, entries, target, file, target_local_len, acc)
  end
end

let walk_exprs = fn (
  es: [ SpannedExpr ], entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match es do
    | [] -> return acc
    | e :: rest ->
      let acc2 = walk_expr(e, entries, target, file, target_local_len, acc)
      return walk_exprs(es: rest, entries, target, file, target_local_len, acc: acc2)
  end
end

let walk_call_args = fn (
  args: [ CallArg ], entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match args do
    | [] -> return acc
    | CallArg(name: _, value) :: rest ->
      let acc2 = walk_expr(e: value, entries, target, file, target_local_len, acc)
      return walk_call_args(args: rest, entries, target, file, target_local_len, acc: acc2)
  end
end

let walk_ctor_args = fn (
  args: [ CtorArg ], entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match args do
    | [] -> return acc
    | CtorArg(name: _, value) :: rest ->
      let acc2 = walk_expr(e: value, entries, target, file, target_local_len, acc)
      return walk_ctor_args(args: rest, entries, target, file, target_local_len, acc: acc2)
  end
end

let walk_named_exprs = fn (
  fields: [ NamedExpr ], entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match fields do
    | [] -> return acc
    | NamedExpr(name: _, value) :: rest ->
      let acc2 = walk_expr(e: value, entries, target, file, target_local_len, acc)
      return walk_named_exprs(fields: rest, entries, target, file, target_local_len, acc: acc2)
  end
end

let walk_match_cases = fn (
  cases: [ MatchCase ], entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match cases do
    | [] -> return acc
    | MatchCase(pattern: _, body) :: rest ->
      let acc2 = walk_stmts(ss: body, entries, target, file, target_local_len, acc)
      return walk_match_cases(cases: rest, entries, target, file, target_local_len, acc: acc2)
  end
end

let walk_catch_arms = fn (
  arms: [ CatchArm ], entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match arms do
    | [] -> return acc
    | CatchArm(pattern: _, body) :: rest ->
      let acc2 = walk_stmts(ss: body, entries, target, file, target_local_len, acc)
      return walk_catch_arms(arms: rest, entries, target, file, target_local_len, acc: acc2)
  end
end

let walk_handler_arms = fn (
  arms: [ HandlerArm ], entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match arms do
    | [] -> return acc
    | HandlerArm(arm, cont_binder: _, span: _) :: rest ->
      match arm do | Function(
        name: _,
        is_public: _,
        type_params: _,
        params: _,
        ret_type: _,
        requires: _,
        throw_row: _,
        body,
        span: _
      ) ->
        let acc2 = walk_stmts(ss: body, entries, target, file, target_local_len, acc)
        return walk_handler_arms(arms: rest, entries, target, file, target_local_len, acc: acc2)
      end
  end
end

let walk_expr_node = fn (
  node: Expr, span: Span, entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match node do
    | ExprLiteral(lit: _) | ExprBorrow(name: _, sigil: _)
    | ExprExternal(symbol: _, type_params: _, arg_names: _, typ: _) -> return acc
    | ExprVariable(name, sigil: _) ->
      if rdr_resolves_to(r: name, entries, target) then
        let local = rdr_local_name(r: name)
        let name_span = rdr_name_span(r: name, span)
        let loc = make_location(file, span: name_span, name_len: str.length(s: local))
        return loc :: acc
      end
      return acc
    | ExprCall(func, args) ->
      let acc1 = if rdr_resolves_to(r: func, entries, target) then
        let local = rdr_local_name(r: func)
        let name_span = rdr_name_span(r: func, span)
        make_location(file, span: name_span, name_len: str.length(s: local)) :: acc
      else
        acc
      end
      return walk_call_args(args, entries, target, file, target_local_len, acc: acc1)
    | ExprConstructor(name, args, sigil: _) ->
      let acc1 = if rdr_resolves_to(r: name, entries, target) then
        let local = rdr_local_name(r: name)
        let name_span = rdr_name_span(r: name, span)
        make_location(file, span: name_span, name_len: str.length(s: local)) :: acc
      else
        acc
      end
      return walk_ctor_args(args, entries, target, file, target_local_len, acc: acc1)
    | ExprBinaryOp(left, op: _, right) ->
      let acc1 = walk_expr(e: left, entries, target, file, target_local_len, acc)
      return walk_expr(e: right, entries, target, file, target_local_len, acc: acc1)
    | ExprUnaryOp(op: _, operand) ->
      return walk_expr(e: operand, entries, target, file, target_local_len, acc)
    | ExprArray(elements) | ExprList(elements) ->
      return walk_exprs(es: elements, entries, target, file, target_local_len, acc)
    | ExprRecord(fields) ->
      return walk_named_exprs(fields, entries, target, file, target_local_len, acc)
    | ExprIndex(target: t, index) ->
      let acc1 = walk_expr(e: t, entries, target, file, target_local_len, acc)
      return walk_expr(e: index, entries, target, file, target_local_len, acc: acc1)
    | ExprFieldAccess(target: t, field: _) ->
      return walk_expr(e: t, entries, target, file, target_local_len, acc)
    | ExprIf(cond, then_branch, else_branch) ->
      let acc1 = walk_expr(e: cond, entries, target, file, target_local_len, acc)
      let acc2 = walk_stmts(ss: then_branch, entries, target, file, target_local_len, acc: acc1)
      return walk_stmts(ss: else_branch, entries, target, file, target_local_len, acc: acc2)
    | ExprMatch(target: t, cases) ->
      let acc1 = walk_expr(e: t, entries, target, file, target_local_len, acc)
      return walk_match_cases(cases, entries, target, file, target_local_len, acc: acc1)
    | ExprWhile(cond, body) ->
      let acc1 = walk_expr(e: cond, entries, target, file, target_local_len, acc)
      return walk_stmts(ss: body, entries, target, file, target_local_len, acc: acc1)
    | ExprFor(var: _, start, end_expr, body) ->
      let acc1 = walk_expr(e: start, entries, target, file, target_local_len, acc)
      let acc2 = walk_expr(e: end_expr, entries, target, file, target_local_len, acc: acc1)
      return walk_stmts(ss: body, entries, target, file, target_local_len, acc: acc2)
    | ExprLambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: b) ->
      // Lambda body is a statement list; recurse so identifiers used
      // inside the lambda count as references.
      return walk_stmts(ss: b, entries, target, file, target_local_len, acc)
    | ExprRaise(value) | ExprForce(value) ->
      return walk_expr(e: value, entries, target, file, target_local_len, acc)
    | ExprHandler(coeffect_name: _, requires: _, arms) ->
      return walk_handler_arms(arms, entries, target, file, target_local_len, acc)
  end
end

let walk_stmt = fn (
  s: SpannedStmt, entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match s do | SpannedStmt(node, span: _) ->
    match node do
      | StmtLet(name: _, sigil: _, typ: _, value)
      | StmtLetPattern(pattern: _, value)
      | StmtReturn(value)
      | StmtAssign(target: _, value) ->
        return walk_expr(e: value, entries, target, file, target_local_len, acc)
      | StmtExpr(expr) ->
        return walk_expr(e: expr, entries, target, file, target_local_len, acc)
      | StmtIndexAssign(target: t, index, value) ->
        let acc1 = walk_expr(e: t, entries, target, file, target_local_len, acc)
        let acc2 = walk_expr(e: index, entries, target, file, target_local_len, acc: acc1)
        return walk_expr(e: value, entries, target, file, target_local_len, acc: acc2)
      | StmtTry(body, catch_arms) ->
        let acc1 = walk_stmts(ss: body, entries, target, file, target_local_len, acc)
        return walk_catch_arms(arms: catch_arms, entries, target, file, target_local_len, acc: acc1)
      | StmtInject(handlers, body) ->
        let acc1 = walk_exprs(es: handlers, entries, target, file, target_local_len, acc)
        return walk_stmts(ss: body, entries, target, file, target_local_len, acc: acc1)
    end
  end
end

let walk_stmts = fn (
  ss: [ SpannedStmt ], entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match ss do
    | [] -> return acc
    | s :: rest ->
      let acc2 = walk_stmt(s, entries, target, file, target_local_len, acc)
      return walk_stmts(ss: rest, entries, target, file, target_local_len, acc: acc2)
  end
end

let walk_top_level = fn (
  defs: [ SpannedTopLevel ], entries: [ RenameEntry ], target: string,
  file: string, target_local_len: i64, acc: [ Location ]
) -> [ Location ] do
  match defs do
    | [] -> return acc
    | SpannedTopLevel(
      node: TLLet(def: GlobalLet(name: _, is_public: _, typ: _, value)),
      span: _
    ) :: rest ->
      let acc2 = walk_expr(e: value, entries, target, file, target_local_len, acc)
      return walk_top_level(defs: rest, entries, target, file, target_local_len, acc: acc2)
    | _ :: rest ->
      return walk_top_level(defs: rest, entries, target, file, target_local_len, acc)
  end
end

// Per-file walk: each cached imported file resolves identifiers in its OWN
// body via that file's own self-entries (e.g. inside `other.nx`, a reference
// to local `f` resolves to `other#f`). Importer-view entries from the
// CacheEntry would only resolve references the *importer* makes — not the
// right view for walking the imported file's body. Returns the locations
// from this one file; the driver concatenates per-file results.
let walk_cache_entry = fn (e: CacheEntry, target: string, target_local_len: i64) -> [ Location ] do
  match e do | CacheEntry(path, defs, entries: _) ->
    let self_entries = build_self_entries(defs, source: path)
    return walk_top_level(defs, entries: self_entries, target,
      file: path, target_local_len, acc: [])
  end
end

// Build a list of @[Location] thunks, one per cached imported file, in
// cache order. Paired with `lazy.force_all` below, each cached-file walk
// is dispatched onto its own OS thread; results are joined in input order
// so the final reference list preserves source-walk order. Per-file walks
// are independent (own defs, own self_entries, no shared mutable state) —
// the canonical multi-document parallel case for the LSP.
let build_cache_walk_thunks = fn (
  cache: [ CacheEntry ], target: string, target_local_len: i64,
  acc: [ @[ Location ] ]
) -> [ @[ Location ] ] do
  match cache do
    | [] -> return list.reverse(xs: acc)
    | e :: rest ->
      let @t = walk_cache_entry(e, target, target_local_len)
      return build_cache_walk_thunks(cache: rest, target, target_local_len,
        acc: t :: acc)
  end
end

// Flatten the per-file location chunks (in cache-walk order) into a single
// flat list. Mirrors the prior `walk_cache_entries` left-to-right append.
let concat_loc_chunks = fn (xs: [ [ Location ] ], acc: [ Location ]) -> [ Location ] do
  match xs do
    | [] -> return acc
    | chunk :: rest ->
      let acc2 = append_locs(xs: acc, ys: chunk)
      return concat_loc_chunks(xs: rest, acc: acc2)
  end
end

/** Resolve all references to the identifier under the cursor.
 *
 *  `text` / `file_uri` / `line` / `character` mirror `resolve_definition`.
 *  `include_declaration` per LSP `ReferenceContext.includeDeclaration`:
 *  when true, the def-site Location is prepended to the result; when false,
 *  only use sites are returned. Order is "def first, then use sites in
 *  source-walk order" — clients typically display unsorted.
 *
 *  Returns `[]` for any failure path: cursor not on an identifier, the
 *  identifier doesn't resolve through the rename map (locals / builtins),
 *  or the lex/parse/import pipeline failed to build a program state.
 */
export let find_references = fn (
  text: string,
  file_uri: string,
  line: i64,
  character: i64,
  include_declaration: bool
) -> [ Location ] require { Console, Fs } do
  try
    return find_references_unsafe(text, file_uri, line, character, include_declaration)
  catch _ ->
    return []
  end
end

let find_references_unsafe = fn (
  text: string,
  file_uri: string,
  line: i64,
  character: i64,
  include_declaration: bool
) -> [ Location ] require { Console, Fs } throws { CompileError } do
  let toks = lexer.tokenize(src: text)
  match find_ident_at(toks, line, character) do
    | None -> return []
    | Some(val: hit) ->
      let visible = visible_name_for(toks, hit)
      let ProgramState(
        prog: _,
        defs,
        cache,
        accum: _,
        self_entries: _,
        caller_entries: _,
        all_entries
      ) =
        build_program_state(text, file: file_uri)
      let canonical = symtab.rename(name: visible, entries: all_entries)
      // No rename hit means the visible name is a local binding, a
      // builtin, or a typo. Mirror definition.nx and return nothing.
      if canonical == visible then return [] end
      // The local name (post-`#`) drives the highlight width for use
      // sites; `IdentHit.name_len` would understate Qual'd refs (`alias.foo`
      // would highlight only "foo").
      let target_local = canonical_to_local_name(canonical)
      let target_local_len = str.length(s: target_local)
      // Walk the entry buffer's defs with the importer-view rename map
      // (covers calls into imported modules). Walk each cached file's
      // defs with that file's own self-entries (so internal recursion
      // inside other.nx counts against `other#f` too).
      //
      // The entry walk and every cached-file walk are independent reads
      // over disjoint AST roots — dispatch each as its own `@[Location]`
      // thunk so `lazy.force_all` runs them concurrently on WASI threads.
      // `force_all` joins in input order, so the flattened result preserves
      // the original "entry buffer first, then cache files in cache order"
      // sequence the LSP tests rely on for stable reference lists.
      let @entry_thunk = walk_top_level(
        defs, entries: all_entries, target: canonical,
        file: file_uri, target_local_len, acc: []
      )
      let cache_thunks = build_cache_walk_thunks(
        cache, target: canonical, target_local_len, acc: []
      )
      // Mirror test_runner.run_all: build a list of @[Location] thunks and
      // hand them to force_all. The entry-buffer thunk goes first so its
      // result heads the joined chunk list; cache thunks follow in cache
      // order.
      let all_thunks = entry_thunk :: cache_thunks
      let chunks = lazy.force_all(tasks: all_thunks)
      let all_uses = concat_loc_chunks(xs: chunks, acc: [])
      if !include_declaration then return all_uses end
      // include_declaration=true: prepend the def-site Location, mirroring
      // resolve_definition's lookup. If no def found (broken state), just
      // return the use sites alone.
      let entry_defs = collect_defs_from_file(defs, source: file_uri, acc: [])
      let cached_defs = collect_defs_from_cache(cache, acc: entry_defs)
      match lookup_def(canonical, defs: cached_defs) do
        | None -> return all_uses
        | Some(val: DefEntry(canonical: c, file, span)) ->
          let local = canonical_to_local_name(c)
          let def_loc = make_location(file, span, name_len: str.length(s: local))
          return def_loc :: all_uses
      end
  end
end
