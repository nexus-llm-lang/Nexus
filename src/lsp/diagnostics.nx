/**
 * lsp/diagnostics: Position-keyed query surface for LSP-style consumers.
 *
 * Exposes three Phase 1/1.5 entry points layered over `src/typecheck/check.nx`:
 *
 *   enumerate_diagnostics(hir, local_names, file)
 *       -> [DiagEntry]    — non-raising; collects typecheck failures with
 *                            file/line/col ranges and severity.
 *   type_at(checked, file, line, col)
 *       -> Option<TypeExpr>  (Phase 1.5 stub; shape locked here.)
 *   defining_position(checked, file, line, col)
 *       -> Option<DefiningPosition>  (Phase 1.5 stub; shape locked here.)
 *
 * Existing typecheck callers (driver.nx) stay on `tc.check_program` and are
 * unaffected — `enumerate_diagnostics` runs the same checker inside a
 * try/catch and converts the first raised CompileError into a DiagEntry.
 *
 * Multi-error accumulation per file is Phase 2; this Phase 1 surface emits at
 * most one DiagEntry per call (the first checker failure). See the parent
 * epic nexus-hw47 for follow-ups on per-function continuation and richer
 * range derivation.
 */

import { TypeExpr } from "src/common/ast.nx"
import { Span } from "src/common/token.nx"
import { HirProgram, HirFunction } from "src/ir/hir_types.nx"
import {
  TypeMismatch, MissingMain, MainNotFunction, MainNotUnit, MainThrowsTooBroad,
  LazyBindingUnused, LazyBindingDoubleUse,
  UnexpectedToken, UnexpectedEof, LexError,
  format_error
} from "src/common/error.nx"
import * as tc from "src/typecheck/check.nx"
import { Option, Some, None } from "std:option"

// ─── Severity ────────────────────────────────────────────────────────────────

export type Severity =
  SeverityError
  | SeverityWarning
  | SeverityInformation
  | SeverityHint

// ─── DiagRange ───────────────────────────────────────────────────────────────────

/// A 1-based (line, column) range within a single file. Both endpoints are
/// inclusive. `start` and `end` collapse to the same span point until the
/// Phase 2 widening pass derives true end-of-token offsets — single-point
/// ranges are still actionable for LSP clients (highlighting a caret point).
export type DiagRange = DiagRange(
  start_line: i64,
  start_col: i64,
  end_line: i64,
  end_col: i64
)

// ─── DiagEntry ──────────────────────────────────────────────────────────────

export type DiagEntry = DiagEntry(
  file: string,
  range: DiagRange,
  severity: Severity,
  /// Numeric error code (e.g. `E2001`) when known, otherwise empty string.
  code: string,
  message: string
)

// ─── DefiningPosition (textDocument/definition) ──────────────────────────────

export type DefiningPosition = DefiningPosition(
  file: string,
  range: DiagRange
)

// ─── Builder: file-origin DiagEntry ─────────────────────────────────────────
//
// Synthesises a SeverityError DiagEntry at (1, 1) — the file's first
// character — for failure modes whose underlying error has no source
// span (e.g. "lsp: failed to lex or parse"). Mirrors `file_origin_range`
// inside this module but is exported as a public surface so the LSP
// entry point can build "lex failed" or "parse failed" diagnostics
// without rebuilding the (1, 1)-range scaffolding.

export let make_origin_error_diagnostic = fn (file: string, message: string) -> DiagEntry do
  return DiagEntry(
    file,
    range: DiagRange(start_line: 1, start_col: 1, end_line: 1, end_col: 1),
    severity: SeverityError,
    code: "",
    message
  )
end

// ─── Field accessors ─────────────────────────────────────────────────────────
//
// Field-extraction helpers exported so callers can read DiagEntry /
// DiagRange payloads without re-pattern-matching on the constructors.
// The LSP entry point (`src/lsp/main.nx`) uses these to translate
// internal diagnostics into the LSP wire format.

export let diagnostic_file = fn (d: DiagEntry) -> string do
  match d do | DiagEntry(file, range: _, severity: _, code: _, message: _) ->
    return file
  end
end

export let diagnostic_range = fn (d: DiagEntry) -> DiagRange do
  match d do | DiagEntry(file: _, range, severity: _, code: _, message: _) ->
    return range
  end
end

export let diagnostic_severity = fn (d: DiagEntry) -> Severity do
  match d do | DiagEntry(file: _, range: _, severity, code: _, message: _) ->
    return severity
  end
end

export let diagnostic_code = fn (d: DiagEntry) -> string do
  match d do | DiagEntry(file: _, range: _, severity: _, code, message: _) ->
    return code
  end
end

export let diagnostic_message = fn (d: DiagEntry) -> string do
  match d do | DiagEntry(file: _, range: _, severity: _, code: _, message) ->
    return message
  end
end

export let range_start_line = fn (r: DiagRange) -> i64 do
  match r do | DiagRange(start_line, start_col: _, end_line: _, end_col: _) ->
    return start_line
  end
end

export let range_start_col = fn (r: DiagRange) -> i64 do
  match r do | DiagRange(start_line: _, start_col, end_line: _, end_col: _) ->
    return start_col
  end
end

export let range_end_line = fn (r: DiagRange) -> i64 do
  match r do | DiagRange(start_line: _, start_col: _, end_line, end_col: _) ->
    return end_line
  end
end

export let range_end_col = fn (r: DiagRange) -> i64 do
  match r do | DiagRange(start_line: _, start_col: _, end_line: _, end_col) ->
    return end_col
  end
end

// ─── Public entry point: enumerate_diagnostics ───────────────────────────────

/// Run the typechecker, capturing the first CompileError as a DiagEntry.
/// Returns an empty list when typecheck succeeds.
///
/// `file` is the *fallback* source path the caller associates with `hir`.
/// HIR functions carry their originating `file` field (issue nexus-qgfh,
/// design choice ii) — when a typecheck error names a function, the
/// emitter prefers that function's file over the fallback. The fallback
/// is used for span-less errors (MissingMain) or errors whose function
/// is not in the HIR table (lex/parse failures, exception groups).
export let enumerate_diagnostics = fn (
  hir: HirProgram,
  local_names: [string],
  file: string
) -> [DiagEntry] do
  try
    let _ = tc.check_program(hir, local_names)
    return []
  catch err -> return [diagnostic_from_error(err, hir, fallback_file: file)]
  end
end

// ─── HIR function-name → file lookup ─────────────────────────────────────────
//
// TypeMismatch / linearity errors carry the offending function's *qualified*
// name. The HirFunction list owns the (name, file) pair set during HIR
// build (`process_tl_let` reads the threaded `source_file`); reverse-look
// the function to recover its file. Returns the fallback when no match —
// this happens for synthesised handler-arm names whose binding came from
// a different table, plus span-less errors that have no function context.

let lookup_func_file = fn (funcs: [HirFunction], name: string, fallback: string) -> string do
  match funcs do
    | [] -> return fallback
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span: _, file: fp) :: rest ->
      if n == name then
        if fp == "" then return fallback end
        return fp
      end
      return lookup_func_file(funcs: rest, name, fallback)
  end
end

let resolve_func_file = fn (hir: HirProgram, name: string, fallback: string) -> string do
  match hir do | HirProgram(ports: _, functions, externals: _, handler_bindings: _, enum_defs: _, exception_groups: _) ->
    return lookup_func_file(funcs: functions, name, fallback)
  end
end

// ─── Public entry point: type_at (Phase 1.5 stub) ────────────────────────────

/// Return the inferred type of the AST node whose source span contains
/// (line, col), if any. Phase 1.5 returns `None` unconditionally — the
/// position-indexed type table is built in nexus-hw47.5 and consumed here
/// without changing this signature.
///
/// Coordinates are 1-based (line, col), matching `Span` / LSP text positions.
export let type_at = fn (
  checked: HirProgram,
  file: string,
  line: i64,
  col: i64
) -> Option<TypeExpr> do
  let _ = checked
  let _ = file
  let _ = line
  let _ = col
  return None
end

// ─── Public entry point: defining_position (Phase 1.5 stub) ──────────────────

/// Return the source range that defines the symbol referenced at
/// (file, line, col). Phase 1.5 returns `None` unconditionally — the
/// definition-site index is built in nexus-hw47.6 and consumed here without
/// changing this signature.
export let defining_position = fn (
  checked: HirProgram,
  file: string,
  line: i64,
  col: i64
) -> Option<DefiningPosition> do
  let _ = checked
  let _ = file
  let _ = line
  let _ = col
  return None
end

// ─── Internal: error → DiagEntry ────────────────────────────────────────────

/// Map each CompileError variant whose span is known to a DiagEntry. Other
/// variants (MissingMain, MainNotFunction, MainNotUnit) lack a source span;
/// they collapse onto (1, 1) since they are file-level invariants rather than
/// pointing at specific syntax. `format_error` provides the user-visible
/// message; `code` mirrors the bracketed error code in that message.
///
/// `hir` is consulted for the per-function file lookup (issue nexus-qgfh):
/// errors that carry a function name pick that function's `file` field
/// (set during HIR build from `source_file`); span-less errors fall back
/// to the caller-supplied `fallback_file`.
let diagnostic_from_error = fn (err: Exn, hir: HirProgram, fallback_file: string) -> DiagEntry do
  match err do
    | TypeMismatch(func_name: fname, detail: _, span: sp) ->
      let file = resolve_func_file(hir, name: fname, fallback: fallback_file)
      return DiagEntry(file, range: range_from_span(sp),
        severity: SeverityError, code: "E2001", message: format_error(err))
    | LazyBindingUnused(name: _, span: sp) ->
      return DiagEntry(file: fallback_file, range: range_from_span(sp),
        severity: SeverityError, code: "E2005", message: format_error(err))
    | LazyBindingDoubleUse(name: _, span: sp) ->
      return DiagEntry(file: fallback_file, range: range_from_span(sp),
        severity: SeverityError, code: "E2006", message: format_error(err))
    | UnexpectedToken(expected: _, got: _, span: sp) ->
      return DiagEntry(file: fallback_file, range: range_from_span(sp),
        severity: SeverityError, code: "E1001", message: format_error(err))
    | UnexpectedEof(expected: _, span: sp) ->
      return DiagEntry(file: fallback_file, range: range_from_span(sp),
        severity: SeverityError, code: "E1002", message: format_error(err))
    | LexError(message: _, span: opt_sp) ->
      return DiagEntry(file: fallback_file, range: range_from_optional_span(osp: opt_sp),
        severity: SeverityError, code: "E1000", message: format_error(err))
    | MissingMain ->
      return DiagEntry(file: fallback_file, range: file_origin_range(),
        severity: SeverityError, code: "E2002", message: format_error(err))
    | MainNotFunction ->
      return DiagEntry(file: fallback_file, range: file_origin_range(),
        severity: SeverityError, code: "E2003", message: format_error(err))
    | MainNotUnit ->
      return DiagEntry(file: fallback_file, range: file_origin_range(),
        severity: SeverityError, code: "E2004", message: format_error(err))
    | MainThrowsTooBroad(detail: _) ->
      return DiagEntry(file: fallback_file, range: file_origin_range(),
        severity: SeverityError, code: "E2007", message: format_error(err))
    | _ ->
      // Any other CompileError variant (Hir/MIR/LIR/Codegen/Driver) reaches
      // here. Use format_error for the message and a file-origin range — the
      // diagnostic remains actionable even though phase-specific spans are
      // not surfaced yet.
      return DiagEntry(file: fallback_file, range: file_origin_range(),
        severity: SeverityError, code: "", message: format_error(err))
  end
end

// ─── Span helpers ────────────────────────────────────────────────────────────

let range_from_span = fn (sp: Span) -> DiagRange do
  match sp do | Span(offset: _, line: l, col: c) ->
    return DiagRange(start_line: l, start_col: c, end_line: l, end_col: c)
  end
end

let range_from_optional_span = fn (osp: Option<Span>) -> DiagRange do
  match osp do
    | Some(val: s) -> return range_from_span(sp: s)
    | None -> return file_origin_range()
  end
end

/// Sentinel range for diagnostics whose underlying error has no source span
/// (e.g. MissingMain). Picks (1, 1) — the file's first character — so LSP
/// clients render the marker on line 1 instead of a phantom line 0.
let file_origin_range = fn () -> DiagRange do
  return DiagRange(start_line: 1, start_col: 1, end_line: 1, end_col: 1)
end
