/**
 * lsp/common: Shared coordinate-translation helpers for LSP handlers.
 *
 * Owns:
 * - `saturating_pred`: floor-at-zero predecessor on i64. Used by every
 *   span → wire-position conversion to handle the bogus "column 0" the
 *   parser occasionally emits without producing the negative coordinate
 *   LSP forbids.
 * - `span_to_position`: AST `Span` (1-based line, col) → LSP `Position`
 *   (0-based line, character). Saturates both axes through
 *   `saturating_pred`.
 * - `single_line_range`: starting at `span_to_position(sp)`, widens the
 *   range by `name_len` characters on the same line. The AST does not
 *   carry the end span of an identifier; widening by the source name's
 *   length is the best approximation today and matches the
 *   `selectionRange` convention picked in `lsp/handlers/symbols.nx`.
 *
 * Does not own:
 * - The wire types themselves (see `src/lsp/protocol.nx`).
 * - Span construction (see `src/common/token.nx`).
 * - DocumentSymbol / Diagnostic builders — those compose these helpers
 *   per-handler.
 *
 * Previously duplicated across `lsp/handlers/{definition,symbols,
 * workspace_symbol,semantic_tokens}.nx` and `lsp/diagnostics_pipeline.nx`.
 */

import { Span } from "src/common/token.nx"
import { Position, Range } from "src/lsp/protocol.nx"

/// Floor-at-zero predecessor on i64 — guards against negative LSP coordinates when the parser emits col=0.
export let saturating_pred = fn (n: i64) -> i64 do
  if n <= 0 then return 0 end
  return n - 1
end

/// Convert AST `Span` (1-based line/col) to LSP `Position` (0-based), saturating both axes at zero.
export let span_to_position = fn (sp: Span) -> Position do
  match sp do | Span(offset: _, line, col) ->
    return Position(
      line: saturating_pred(n: line),
      character: saturating_pred(n: col)
    )
  end
end

/// Build a single-line LSP `Range` starting at `sp` and widening `name_len` characters on the same line (AST lacks identifier end-spans).
export let single_line_range = fn (sp: Span, name_len: i64) -> Range do
  let start = span_to_position(sp)
  match start do | Position(line: l, character: c) ->
    let end_pos = Position(line: l, character: c + name_len)
    return Range(start, end_: end_pos)
  end
end
