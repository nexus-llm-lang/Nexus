/**
 * parser/type: Type expression parsing for the Nexus self-hosting compiler.
 *
 * Parses all TypeExpr forms: primitives, user-defined (with type args),
 * arrow types, rows, records, refs, linear, borrow, list, array, handler.
 */

import { SpannedToken } from "src/syntax/token.nx"
import { Span } from "src/types/span.nx"
import { TypeExpr, NamedType } from "src/types/type_expr.nx"
import { UnexpectedToken, ParseError } from "src/diagnostics/error.nx"
import {
  ParsedType,
  ParsedNamedTypes,
  ParsedTypes,
  ParsedIdent
}, * as pcore from "src/frontend/parser/util.nx"
import * as list from "std:list"
import * as str from "std:str"

/** The empty effect/require row `TyRow(types: [], rest: None)`; reused as the default for `requires`/`throws` clauses on arrows where the user wrote nothing. */
export let empty_row = fn () -> TypeExpr do
  return TyRow(types: [], rest: None)
end

let consume_qualified_tail = fn (name: string, toks: [ SpannedToken ]) -> ParsedIdent do
  if pcore.is_tok(toks, expected: ".") then
    let r = pcore.skip(toks)
    match pcore.peek_token(toks: r) do
      | TkIdent(name: next) | TkUident(name: next) -> return consume_qualified_tail(
        name: next,
        toks: pcore.skip(toks: r)
      )
      | _ -> return ParsedIdent(name, rest: toks)
    end
  else
    return ParsedIdent(name, rest: toks)
  end
end

/** Top-level type-expression entry point: dispatches on the lookahead to arrow-type parsing (`(p: T, ...) -> R`), zero-param unit arrow (`() -> R`), or the type atom (primitives, user-defined with args, list, array, ref, linear, borrow, row, record, handler). */
export let parse_type = fn (toks: [ SpannedToken ]) -> ParsedType throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkLParen -> parse_type_maybe_arrow(toks)
    // TkUnit followed by `->` is the zero-param arrow form `() -> Ret`.
    // The lexer collapses `()` into a single TkUnit, so the LParen/RParen
    // arrow lookahead never triggers; route this case explicitly.
    | TkUnit ->
      match pcore.peek_token(toks: pcore.skip(toks)) do
        | TkArrow -> parse_unit_arrow_type(toks)
        | _ -> parse_type_atom(toks)
      end
    | _ -> parse_type_atom(toks)
  end
end

let parse_type_maybe_arrow = fn (toks: [ SpannedToken ]) -> ParsedType throws { ParseError } do
  if pcore.is_arrow_start(toks) then return parse_arrow_type(toks)
  else return parse_type_atom(toks)
  end
end

// `() -> Ret [require ...] [throws ...]` — zero-param arrow whose `()` was
// fused into a single TkUnit token by the lexer.
let parse_unit_arrow_type = fn (toks: [ SpannedToken ]) -> ParsedType throws { ParseError } do
  let r1 = pcore.skip(toks)
  let r2 = pcore.expect(toks: r1, expected: "->")
  let ParsedType(typ: ret, rest: r3) = parse_type(toks: r2)
  let ParsedType(typ: req_ty, rest: r4) = parse_optional_require(toks: r3)
  let ParsedType(typ: thr_ty, rest: r5) = parse_optional_throws(toks: r4)
  ParsedType(typ: TyArrow(params: [], ret, requires: req_ty, throw_row: thr_ty), rest: r5)
end

let parse_arrow_type = fn (toks: [ SpannedToken ]) -> ParsedType throws { ParseError } do
  let r = pcore.expect(toks, expected: "(")
  let ParsedNamedTypes(fields: ps, rest: r2) = parse_arrow_params(toks: r, acc: [])
  let r3 = pcore.expect(toks: r2, expected: ")")
  let r4 = pcore.expect(toks: r3, expected: "->")
  let ParsedType(typ: ret, rest: r5) = parse_type(toks: r4)
  let ParsedType(typ: req_ty, rest: r6) = parse_optional_require(toks: r5)
  let ParsedType(typ: thr_ty, rest: r7) = parse_optional_throws(toks: r6)
  ParsedType(typ: TyArrow(params: ps, ret, requires: req_ty, throw_row: thr_ty), rest: r7)
end

let parse_arrow_params = fn (
  toks: [ SpannedToken ],
  acc: [ NamedType ]
) -> ParsedNamedTypes throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkRParen -> return ParsedNamedTypes(fields: list.reverse(xs: acc), rest: toks)
    | _ ->
      // `arrow_param ::= IDENT ":" type | type`. A labelled param is an
      // identifier immediately followed by `:`; anything else (including a
      // primitive/user type that itself begins with an identifier, e.g.
      // `i64`) is a BARE type whose param name we synthesise positionally.
      // Arrow types unify positionally (unify_arrow_params_i ignores the
      // callee param name), so the synthesised name never blocks passing a
      // differently-labelled function — it only fills the NamedType slot.
      if is_labelled_param(toks) then
        let ParsedIdent(name: n, rest: r) = pcore.expect_ident(toks)
        let r2 = pcore.expect(toks: r, expected: ":")
        let ParsedType(typ: t, rest: r3) = parse_type(toks: r2)
        let new_acc = NamedType(name: n, typ: t) :: acc
        parse_arrow_params_continue(toks: r3, acc: new_acc)
      else
        let ParsedType(typ: t, rest: r3) = parse_type(toks)
        let name = synth_param_name(idx: list.length(xs: acc))
        let new_acc = NamedType(name, typ: t) :: acc
        parse_arrow_params_continue(toks: r3, acc: new_acc)
      end
  end
end

/** True when the head of `toks` is a labelled arrow param `IDENT ":"` (as
 *  opposed to a bare type). A bare type may itself start with an identifier
 *  (`i64`, `Option<T>`), so the discriminator is the colon, not the ident. */
let is_labelled_param = fn (toks: [ SpannedToken ]) -> bool do
  match pcore.peek_token(toks) do
    | TkIdent(_) ->
      match pcore.peek_token(toks: pcore.skip(toks)) do
        | TkColon -> return true
        | _ -> return false
      end
    | _ -> return false
  end
end

/** Synthesise a stable positional label `_p0`, `_p1`, ... for a bare
 *  (unlabelled) arrow param. The `_p` prefix avoids the bare `_`/`_<digits>`
 *  wildcard-discard form while staying a valid identifier. */
let synth_param_name = fn (idx: i64) -> string do
  return "_p" ++ str.from_i64(val: idx)
end

let parse_arrow_params_continue = fn (
  toks: [ SpannedToken ],
  acc: [ NamedType ]
) -> ParsedNamedTypes throws { ParseError } do
  if pcore.is_tok(toks, expected: ",") then return parse_arrow_params(toks: pcore.skip(toks), acc)
  else return ParsedNamedTypes(fields: list.reverse(xs: acc), rest: toks)
  end
end

/** Parse an optional `require ROW` clause on an arrow/cap signature; absence yields `empty_row()` so callers can plug the result into `TyArrow.requires` unconditionally. */
export let parse_optional_require = fn (toks: [ SpannedToken ]) -> ParsedType throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkRequire ->
      let ParsedType(typ: t, rest: r2) = parse_row_or_type(toks: pcore.skip(toks))
      return ParsedType(typ: t, rest: r2)
    | _ -> return ParsedType(typ: empty_row(), rest: toks)
  end
end

/** Parse an optional `throws ROW` clause on an arrow/cap signature.
 *
 *  When the `throws` keyword is present, the clause is parsed literally:
 *  `throws {}` yields `TyRow(types: [], rest: None)` (closed empty row —
 *  the function declares that it raises no exceptions and the typechecker
 *  enforces this via T-Raise).
 *
 *  When the keyword is **absent**, we return an *open* implicit row
 *  `TyRow(types: [], rest: Some(TyVar("__implicit")))` rather than the
 *  closed empty row.  This preserves backward-compatibility for the many
 *  functions in `src/` that pre-date row-typed throws declarations: they
 *  parse to an open row and the typechecker treats them as effect-polymorphic
 *  (any throw is admitted).  Once every raising function in the codebase
 *  carries an explicit `throws { ... }` clause this implicit tail can be
 *  dropped (tracked as mqin.1.2).
 */
export let parse_optional_throws = fn (toks: [ SpannedToken ]) -> ParsedType throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkThrows ->
      let ParsedType(typ: t, rest: r2) = parse_row_or_type(toks: pcore.skip(toks))
      return ParsedType(typ: t, rest: r2)
    | _ ->
      // Implicit (absent) throws: open row. Distinct from `throws {}` (closed empty).
      return ParsedType(
        typ: TyRow(types: [], rest: Some(val: TyVar(name: "__implicit"))),
        rest: toks
      )
  end
end

/** Parse an optional `throws ROW` clause inside `@(...)`.  An absent clause
 *  defaults to the `__implicit` OPEN row — identical to `parse_optional_throws`
 *  for unannotated function arrows — so a thunk type with no explicit `throws`
 *  is effect-polymorphic: a `@T` / `@(T)` parameter admits a row-carrying thunk
 *  `@(T throws {E})` and bundles its throws into the caller, mirroring how an
 *  unannotated arrow callback bundles a throwing function (the force_all /
 *  list-of-thunks pattern).  Explicit `throws {}` still parses to the closed
 *  empty row (a genuinely pure thunk).
 */
let parse_optional_thunk_throws = fn (toks: [ SpannedToken ]) -> ParsedType throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkThrows ->
      let ParsedType(typ: t, rest: r2) = parse_row_or_type(toks: pcore.skip(toks))
      return ParsedType(typ: t, rest: r2)
    | _ -> return ParsedType(typ: TyRow(types: [], rest: Some(val: TyVar(name: "__implicit"))), rest: toks)
  end
end

let parse_row_or_type = fn (toks: [ SpannedToken ]) -> ParsedType throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkLBrace ->
      let r = pcore.skip(toks)
      let ParsedTypes(types: ts, rest: r2) = parse_row_types(toks: r, acc: [])
      match pcore.peek_token(toks: r2) do
        | TkPipe ->
          let ParsedType(typ: tail, rest: r4) = parse_type(toks: pcore.skip(toks: r2))
          let r5 = pcore.expect(toks: r4, expected: "}")
          ParsedType(typ: TyRow(types: ts, rest: Some(val: tail)), rest: r5)
        | _ ->
          let r3 = pcore.expect(toks: r2, expected: "}")
          ParsedType(typ: TyRow(types: ts, rest: None), rest: r3)
      end
    | _ -> parse_type(toks)
  end
end

let parse_row_types = fn (
  toks: [ SpannedToken ],
  acc: [ TypeExpr ]
) -> ParsedTypes throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkRBrace | TkPipe -> return ParsedTypes(types: list.reverse(xs: acc), rest: toks)
    | _ ->
      let ParsedType(typ: t, rest: r) = parse_type(toks)
      let new_acc = t :: acc
      if pcore.is_tok(toks: r, expected: ",") then
        return parse_row_types(toks: pcore.skip(toks: r), acc: new_acc)
      else
        return ParsedTypes(types: list.reverse(xs: new_acc), rest: r)
      end
  end
end

let resolve_primitive_type = fn (name: string) -> Option<TypeExpr> do
  if name == "i32" then return Some(val: TyI32) end
  if name == "i64" then return Some(val: TyI64) end
  if name == "f32" then return Some(val: TyF32) end
  if name == "f64" then return Some(val: TyF64) end
  if name == "float" then return Some(val: TyF64) end
  if name == "bool" then return Some(val: TyBool) end
  if name == "char" then return Some(val: TyChar) end
  if name == "string" then return Some(val: TyString) end
  if name == "unit" then return Some(val: TyUnit) end
  return None
end

let parse_type_atom = fn (toks: [ SpannedToken ]) -> ParsedType throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkIdent(name: n) ->
      let prim = resolve_primitive_type(name: n)
      match prim do
        | Some(val: t) -> return ParsedType(typ: t, rest: pcore.skip(toks))
        | None ->
          let ParsedIdent(
            name: final,
            rest: r
          ) = consume_qualified_tail(name: n, toks: pcore.skip(toks))
          if pcore.is_tok(toks: r, expected: "<") then
            let r2 = pcore.skip(toks: r)
            let ParsedTypes(types: args, rest: r3) = parse_type_args(toks: r2, acc: [])
            let r4 = close_type_args(toks: r3)
            return ParsedType(typ: TyUserDefined(name: final, args), rest: r4)
          else
            return ParsedType(typ: TyUserDefined(name: final, args: []), rest: r)
          end
      end
    | TkUident(name: n) ->
      let ParsedIdent(
        name: final,
        rest: r
      ) = consume_qualified_tail(name: n, toks: pcore.skip(toks))
      if pcore.is_tok(toks: r, expected: "<") then
        let r2 = pcore.skip(toks: r)
        let ParsedTypes(types: args, rest: r3) = parse_type_args(toks: r2, acc: [])
        let r4 = close_type_args(toks: r3)
        return ParsedType(typ: TyUserDefined(name: final, args), rest: r4)
      else
        return ParsedType(typ: TyUserDefined(name: final, args: []), rest: r)
      end
    | TkUnit ->
      return ParsedType(typ: TyUnit, rest: pcore.skip(toks))
    | TkLParen ->
      let r = pcore.skip(toks)
      if pcore.is_tok(toks: r, expected: ")") then
        return ParsedType(typ: TyUnit, rest: pcore.skip(toks: r))
      else
        let ParsedType(typ: t, rest: r2) = parse_type(toks: r)
        let r3 = pcore.expect(toks: r2, expected: ")")
        return ParsedType(typ: t, rest: r3)
      end
    | TkLBracket ->
      let ParsedType(typ: elem, rest: r2) = parse_type(toks: pcore.skip(toks))
      let r3 = pcore.expect(toks: r2, expected: "]")
      return ParsedType(typ: TyList(elem), rest: r3)
    | TkLArray ->
      let ParsedType(typ: elem, rest: r2) = parse_type(toks: pcore.skip(toks))
      let r3 = pcore.expect(toks: r2, expected: "|]")
      return ParsedType(typ: TyArray(elem), rest: r3)
    | TkLBrace ->
      let ParsedNamedTypes(
        fields: fs,
        rest: r2
      ) = parse_record_type_fields(toks: pcore.skip(toks), acc: [])
      let r3 = pcore.expect(toks: r2, expected: "}")
      return ParsedType(typ: TyRecord(fields: fs), rest: r3)
    | TkRef ->
      let r = pcore.skip(toks)
      let r2 = pcore.expect(toks: r, expected: "(")
      let ParsedType(typ: inner, rest: r3) = parse_type(toks: r2)
      let r4 = pcore.expect(toks: r3, expected: ")")
      return ParsedType(typ: TyRef(inner), rest: r4)
    | TkAmpersand ->
      let ParsedType(typ: inner, rest: r2) = parse_type(toks: pcore.skip(toks))
      return ParsedType(typ: TyBorrow(inner), rest: r2)
    | TkPercent ->
      let ParsedType(typ: inner, rest: r2) = parse_type(toks: pcore.skip(toks))
      return ParsedType(typ: TyLinear(inner), rest: r2)
    | TkAt ->
      // `@(T require {R} throws {E})` — parenthesised long form with deferred
      // effect rows; `@T` — sugar for `@(T)`.  Absent `require` defaults to the
      // closed-empty row; absent `throws` defaults to the `__implicit` OPEN row
      // (effect-polymorphic, like unannotated arrows) so a thunk param admits a
      // row-carrying thunk and bundles its throws.
      let after_at = pcore.skip(toks)
      match pcore.peek_token(after_at) do
        | TkLParen ->
          let after_lparen = pcore.skip(after_at)
          let ParsedType(typ: inner, rest: after_inner) = parse_type(toks: after_lparen)
          let ParsedType(typ: req_ty, rest: after_req) = parse_optional_require(toks: after_inner)
          let ParsedType(
            typ: thr_ty,
            rest: after_thr
          ) = parse_optional_thunk_throws(toks: after_req)
          let after_rparen = pcore.expect(toks: after_thr, expected: ")")
          return ParsedType(
            typ: TyLazy(inner, require_row: req_ty, throw_row: thr_ty),
            rest: after_rparen
          )
        | _ ->
          let ParsedType(typ: inner, rest: r2) = parse_type(toks: after_at)
          return ParsedType(
            typ: TyLazy(inner, require_row: empty_row(), throw_row: TyRow(types: [], rest: Some(val: TyVar(name: "__implicit")))),
            rest: r2
          )
      end
    | TkHandler ->
      let ParsedIdent(name: n, rest: r2) = pcore.expect_uident(toks: pcore.skip(toks))
      return ParsedType(typ: TyHandler(name: n, requires: empty_row()), rest: r2)
    | _ ->
      throw UnexpectedToken(
        expected: "type",
        got: pcore.token_tag(tok: pcore.peek_token(toks)),
        span: pcore.peek_span(toks)
      )
  end
end

/** Close a type-argument list's `>`.
 *
 *  In a nested generic such as `Option<Option<i64>>`, the lexer fuses the two
 *  adjacent closing `>` into a single `>>` (`TkShr`) token before the parser
 *  sees them — so the inner list never finds the bare `TkGt` it expects.
 *  This is the classic C++ `>>`-in-templates ambiguity.
 *
 *  Resolve it at the close site (type position only, never in expression
 *  position where `>>` is the right-shift operator): if the head is a bare
 *  `TkGt`, consume it; if it is `TkShr`, consume ONE `>` to close THIS list
 *  and rewrite the head of the remaining stream to a single `TkGt` (spanning
 *  the second `>`) so the ENCLOSING list closes against it on the next call.
 *  Chained depths (`A<B<C<i64>>>`) fall out for free: the lexer is greedy
 *  two-at-a-time, so `>>>` lexes as `TkShr` then `TkGt` — the innermost close
 *  splits the `TkShr`, leaving `TkGt`+`TkGt` for the two enclosing lists. */
let close_type_args = fn (toks: [ SpannedToken ]) -> [ SpannedToken ] throws { ParseError } do
  match toks do
    | SpannedToken(token: TkShr, span: Span(offset: o, line: l, col: c)) :: rest ->
      // Split `>>`: this call consumes the first `>`; leave a `TkGt` at the
      // second `>`'s position for the enclosing type-arg list to consume.
      let residual = SpannedToken(token: TkGt, span: Span(offset: o + 1, line: l, col: c + 1))
      return residual :: rest
    | _ -> return pcore.expect(toks, expected: ">")
  end
end

let parse_type_args = fn (
  toks: [ SpannedToken ],
  acc: [ TypeExpr ]
) -> ParsedTypes throws { ParseError } do
  match pcore.peek_token(toks) do
    // `TkShr` (`>>`) terminates the inner list too: it is two adjacent closing
    // `>` the lexer fused (see `close_type_args`). Stop here and let the close
    // logic split it.
    | TkGt | TkShr -> return ParsedTypes(types: list.reverse(xs: acc), rest: toks)
    | _ ->
      let ParsedType(typ: t, rest: r) = parse_type(toks)
      let new_acc = t :: acc
      if pcore.is_tok(toks: r, expected: ",") then
        return parse_type_args(toks: pcore.skip(toks: r), acc: new_acc)
      else
        return ParsedTypes(types: list.reverse(xs: new_acc), rest: r)
      end
  end
end

/** Parse the comma-separated `field: T, ...` body of a record type inside already-opened `{`; tail-recursive accumulator-reversed-once. Stops at `}` without consuming it — caller closes the brace. */
export let parse_record_type_fields = fn (
  toks: [ SpannedToken ],
  acc: [ NamedType ]
) -> ParsedNamedTypes throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkRBrace -> return ParsedNamedTypes(fields: list.reverse(xs: acc), rest: toks)
    | _ ->
      let ParsedIdent(name: n, rest: r) = pcore.expect_ident(toks)
      let r2 = pcore.expect(toks: r, expected: ":")
      let ParsedType(typ: t, rest: r3) = parse_type(toks: r2)
      let new_acc = NamedType(name: n, typ: t) :: acc
      if pcore.is_tok(toks: r3, expected: ",") then
        return parse_record_type_fields(toks: pcore.skip(toks: r3), acc: new_acc)
      else
        return ParsedNamedTypes(fields: list.reverse(xs: new_acc), rest: r3)
      end
  end
end
