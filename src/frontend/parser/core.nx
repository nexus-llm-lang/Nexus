/**
 * parser/core: Recursive-descent core — expression + statement parsing.
 *
 * Owns the mutually-recursive expression/statement cluster:
 * - Expression parsing (parse_expr / parse_atom / parse_postfix / parse_prec_*)
 * - Literal / constructor / call-argument parsing
 * - Control-flow expressions (if / if-let / match / while / for / lambda /
 *   handler)
 * - Statement parsing (let, return, try, catch, inject)
 *
 * Expression and statement parsing form a single strongly-connected component:
 * control-flow expression bodies parse statement lists, and statements parse
 * expressions. They therefore live together in one module. The public `parse`
 * entry, top-level parsing, and error-recovery driver live in
 * src/frontend/parser.nx, which imports `parse_expr` from here.
 *
 * Does not own:
 * - Token types or span (see src/syntax/token.nx)
 * - Token-level primitives: peek, expect, skip, binop precedence
 *   (see src/frontend/parser/util.nx)
 * - Type-expression parsing (see src/frontend/parser/type.nx)
 * - Pattern parsing (see src/frontend/parser/pattern.nx)
 * - Lexing (see src/frontend/lexer.nx)
 */

import { Span } from "src/types/span.nx"
import { SpannedToken } from "src/syntax/token.nx"
import { Sigil, OpNeg, OpFNeg, OpNot, Unqual } from "src/types/vocab.nx"
import {
  SpannedExpr,
  SpannedStmt,
  SpannedPattern,
  Param,
  Function,
  HandlerArm,
  MatchCase,
  CatchArm,
  CallArg,
  CtorArg,
  NamedExpr
} from "src/syntax/ast.nx"
import * as rdr from "src/ir/shared/rdrname.nx"
import { UnexpectedToken, ParseError } from "src/diagnostics/error.nx"
import { ResumeWithValueUnsupported } from "src/frontend/errors.nx"
import {
  ParsedType,
  ParsedExpr,
  ParsedStmt,
  ParsedPat,
  ParsedIdent,
  ParsedSigil,
  ParsedStmts,
  ParsedCallArgs,
  ParsedCtorArgs,
  ParsedParams,
  ParsedMatchCases,
  ParsedCatchArms,
  ParsedHandlerArms,
  ParsedExprs,
  ParsedNamedExprs,
  ParsedStrings
}, * as pcore from "src/frontend/parser/util.nx"
import * as ptype from "src/frontend/parser/type.nx"
import * as ppat from "src/frontend/parser/pattern.nx"
import {
  parse_fn_params_or_unit,
  parse_params,
  parse_optional_type_params
} from "src/frontend/parser/params.nx"
import {
  parse_dotted_name,
  dotted_name_ends_upper,
  parse_handler_dotted
} from "src/frontend/parser/names.nx"
import {
  PunArgYes,
  try_pun_arg_with_closer,
  try_pun_call_arg,
  ctor_pat_lookahead,
  parse_optional_with_kont
} from "src/frontend/parser/args.nx"
import * as list from "std:list"

export let parse_expr = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  return parse_prec_expr(toks, min_prec: 1)
end

let parse_prec_expr = fn (
  toks: [ SpannedToken ],
  min_prec: i64
) -> ParsedExpr throws { ParseError } do
  let ParsedExpr(expr: left, rest: r) = parse_unary_expr(toks)
  return parse_prec_loop(toks: r, left, min_prec)
end

// Prefix unary: -, -., ! — right-associative, binds tighter than every infix
// binary operator and looser than postfix `.field` / `[idx]`.
let parse_unary_expr = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  let sp = pcore.peek_span(toks)
  match pcore.peek_token(toks) do
    | TkMinus ->
      // Special-case: `-9223372036854775808` is i64::MIN. The lexer rejects the
      // bare magnitude as out-of-range; fold the minus with the overflow sentinel
      // here so the expression compiles to the correct minimum value.
      let next = pcore.peek_token(toks: pcore.skip(toks))
      if let TkError(msg: m) = next then
        if m == "integer literal out of range: 9223372036854775808" then
          let i64_min = 0 - 9223372036854775807 - 1
          return ParsedExpr(
            expr: SpannedExpr(node: ExprLiteral(lit: LitInt(val: i64_min)), span: sp),
            rest: pcore.skip(toks: pcore.skip(toks))
          )
        end
      end
      let ParsedExpr(expr: operand, rest: r) = parse_unary_expr(toks: pcore.skip(toks))
      return ParsedExpr(expr: SpannedExpr(node: ExprUnaryOp(op: OpNeg, operand), span: sp), rest: r)
    | TkMinusDot ->
      let ParsedExpr(expr: operand, rest: r) = parse_unary_expr(toks: pcore.skip(toks))
      return ParsedExpr(
        expr: SpannedExpr(node: ExprUnaryOp(op: OpFNeg, operand), span: sp),
        rest: r
      )
    | TkBang ->
      let ParsedExpr(expr: operand, rest: r) = parse_unary_expr(toks: pcore.skip(toks))
      return ParsedExpr(expr: SpannedExpr(node: ExprUnaryOp(op: OpNot, operand), span: sp), rest: r)
    | _ -> return parse_postfix_expr(toks)
  end
end

let parse_prec_loop = fn (
  toks: [ SpannedToken ],
  left: SpannedExpr,
  min_prec: i64
) -> ParsedExpr throws { ParseError } do
  // :: (cons) — right-associative at precedence 4, desugars to lhs :: rhs
  match pcore.peek_token(toks) do
    | TkColonColon ->
      if 4 >= min_prec then
        let ParsedExpr(expr: right, rest: r2) = parse_prec_expr(toks: pcore.skip(toks), min_prec: 4)
        let SpannedExpr(node: _, span: sp) = left
        let cons_args = CtorArg(name: "v", value: left) ::
          (CtorArg(name: "rest", value: right) :: [])
        let new_left = SpannedExpr(
          node: ExprConstructor(name: Unqual(name: "Cons"), args: cons_args, sigil: SigilImmutable),
          span: sp
        )
        return parse_prec_loop(toks: r2, left: new_left, min_prec)
      else
        return ParsedExpr(expr: left, rest: toks)
      end
    | _ -> ()
  end
  let prec = pcore.get_binop_prec(tok: pcore.peek_token(toks))
  if prec < min_prec then return ParsedExpr(expr: left, rest: toks) end
  match pcore.token_to_binop(tok: pcore.peek_token(toks)) do
    | Some(val: op) ->
      // Disambiguate `|` (TkPipe → OpBitOr) vs match/catch arm separator.
      // If the tokens after `|` form a pattern terminated by `->` at depth 0,
      // the `|` belonged to the outer arm parser — leave it for them.
      let is_arm_sep = match pcore.peek_token(toks) do
        | TkPipe -> pcore.pipe_starts_arm(toks: pcore.skip(toks))
        | _ -> false
      end
      match is_arm_sep do
        | true -> return ParsedExpr(expr: left, rest: toks)
        | false ->
          let ParsedExpr(
            expr: right,
            rest: r2
          ) = parse_prec_expr(toks: pcore.skip(toks), min_prec: prec + 1)
          let SpannedExpr(node: _, span: sp) = left
          let new_left = SpannedExpr(node: ExprBinaryOp(left, op, right), span: sp)
          return parse_prec_loop(toks: r2, left: new_left, min_prec)
      end
    | None -> return ParsedExpr(expr: left, rest: toks)
  end
end

let parse_postfix_expr = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  let ParsedExpr(expr: base, rest: r) = parse_atom(toks)
  return parse_postfix_loop(toks: r, base)
end

let parse_postfix_loop = fn (
  toks: [ SpannedToken ],
  base: SpannedExpr
) -> ParsedExpr throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkDot ->
      let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.skip(toks))
      let SpannedExpr(node: _, span: sp) = base
      return parse_postfix_loop(
        toks: r2,
        base: SpannedExpr(node: ExprFieldAccess(target: base, field: n), span: sp)
      )
    | TkLBracket ->
      let ParsedExpr(expr: idx, rest: r2) = parse_expr(toks: pcore.skip(toks))
      let r3 = pcore.expect(toks: r2, expected: "]")
      let SpannedExpr(node: _, span: sp) = base
      return parse_postfix_loop(
        toks: r3,
        base: SpannedExpr(node: ExprIndex(target: base, index: idx), span: sp)
      )
    | _ -> return ParsedExpr(expr: base, rest: toks)
  end
end

let parse_atom = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  let sp = pcore.peek_span(toks)
  match pcore.peek_token(toks) do
    | TkInt(val: v) ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprLiteral(lit: LitInt(val: v)), span: sp),
        rest: pcore.skip(toks)
      )
    | TkFloat(val: v) ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprLiteral(lit: LitFloat(val: v)), span: sp),
        rest: pcore.skip(toks)
      )
    | TkString(val: v) ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprLiteral(lit: LitString(val: v)), span: sp),
        rest: pcore.skip(toks)
      )
    | TkTrue ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprLiteral(lit: LitBool(val: true)), span: sp),
        rest: pcore.skip(toks)
      )
    | TkFalse ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprLiteral(lit: LitBool(val: false)), span: sp),
        rest: pcore.skip(toks)
      )
    | TkChar(val: v) ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprLiteral(lit: LitChar(val: v)), span: sp),
        rest: pcore.skip(toks)
      )
    | TkUnit ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprLiteral(lit: LitUnit), span: sp),
        rest: pcore.skip(toks)
      )
    | TkLParen -> return parse_paren_expr(toks, sp)
    | TkThrow -> return parse_raise_expr(toks, sp)
    | TkAt -> return parse_at_expr(toks, sp)
    | TkIf -> return parse_if_expr(toks)
    | TkMatch -> return parse_match_expr(toks)
    | TkInject -> return parse_inject_expr(toks)
    | TkWhile -> return parse_while_expr(toks)
    | TkFor -> return parse_for_expr(toks)
    | TkFn -> return parse_lambda(toks)
    | TkLBracket -> return parse_list_literal(toks, sp)
    | TkLArray -> return parse_array_literal(toks, sp)
    | TkLBrace -> return parse_record_literal(toks, sp)
    | TkTilde -> return parse_sigil_var(toks, sp, sigil: SigilMutable)
    | TkPercent ->
      // %[...] linear list literal vs %Ctor(...) linear constructor vs %ident sigil variable
      if let TkLBracket = pcore.peek_token(toks: pcore.skip(toks)) then
        return parse_list_literal(toks: pcore.skip(toks), sp)
      else if let TkUident(name: cn) = pcore.peek_token(toks: pcore.skip(toks)) then
        return parse_constructor_expr(toks: pcore.skip(toks), sp, name: cn, sigil: SigilLinear)
      else
        return parse_sigil_var(toks, sp, sigil: SigilLinear)
      end
    | TkAmpersand -> return parse_borrow_expr(toks, sp)
    | TkUident(name: n) -> return parse_constructor_expr(toks, sp, name: n, sigil: SigilImmutable)
    | TkIdent(name: n) -> return parse_ident_expr(toks, sp, name: n)
    | TkHandler -> return parse_handler_expr(toks)
    | _ ->
      throw UnexpectedToken(
        expected: "expression",
        got: pcore.token_tag(tok: pcore.peek_token(toks)),
        span: sp
      )
  end
end

let parse_paren_expr = fn (toks: [ SpannedToken ], sp: Span) -> ParsedExpr throws { ParseError } do
  let r = pcore.skip(toks)
  if pcore.is_tok(toks: r, expected: ")") then
    return ParsedExpr(
      expr: SpannedExpr(node: ExprLiteral(lit: LitUnit), span: sp),
      rest: pcore.skip(toks: r)
    )
  end
  let ParsedExpr(expr: e, rest: r2) = parse_expr(toks: r)
  let r3 = pcore.expect(toks: r2, expected: ")")
  // `(expr)()` — zero-arg postfix call on a parenthesised callee.
  // Handles `(o.run)()` where the callee is a parenthesized field access.
  // Placed here (not in parse_postfix_loop) so that `f(x)\n()` on the next
  // line is not mis-parsed as a chained call `f(x)()`.
  match pcore.peek_token(toks: r3) do
    | TkUnit ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprCallExpr(callee: e, args: []), span: sp),
        rest: pcore.skip(toks: r3)
      )
    | TkLParen ->
      // `(expr)(arg1, arg2, ...)` — postfix call with arguments on a
      // parenthesised callee. Handles `(o.run)(args)`.
      let r4 = pcore.skip(toks: r3)
      if pcore.is_tok(toks: r4, expected: ")") then
        return ParsedExpr(
          expr: SpannedExpr(node: ExprCallExpr(callee: e, args: []), span: sp),
          rest: pcore.skip(toks: r4)
        )
      end
      let ParsedCallArgs(args, rest: r5) = parse_fn_call_args(toks: r4, acc: [])
      return ParsedExpr(
        expr: SpannedExpr(node: ExprCallExpr(callee: e, args), span: sp),
        rest: pcore.expect(toks: r5, expected: ")")
      )
    | _ -> return ParsedExpr(expr: e, rest: r3)
  end
end

let parse_raise_expr = fn (toks: [ SpannedToken ], sp: Span) -> ParsedExpr throws { ParseError } do
  let ParsedExpr(expr: e, rest: r2) = parse_expr(toks: pcore.skip(toks))
  return ParsedExpr(expr: SpannedExpr(node: ExprRaise(value: e), span: sp), rest: r2)
end

let parse_at_expr = fn (toks: [ SpannedToken ], sp: Span) -> ParsedExpr throws { ParseError } do
  let r = pcore.skip(toks)
  // @ident is a lazy variable reference (consume + unwrap)
  // @(expr) or @{...} is compound force
  if let TkIdent(name: n) = pcore.peek_token(toks: r) then
    let after = pcore.skip(toks: r)
    // `@k(v)` / `@k()` resume-with-value is rejected: the continuation
    // captured by a `with @k` arm can only be resumed with unit. There is
    // no value channel back into the suspended cap call, so `@k(v)` would
    // silently drop `v`. Reject `@ident` immediately followed by a call
    // argument list rather than accept a misleading no-op.
    match pcore.peek_token(toks: after) do
      | TkLParen -> throw ResumeWithValueUnsupported(span: sp)
      | TkUnit -> throw ResumeWithValueUnsupported(span: sp)
      | _ -> ()
    end
    return ParsedExpr(
      expr: SpannedExpr(node: ExprVariable(name: Unqual(name: n), sigil: SigilLazy), span: sp),
      rest: after
    )
  else if pcore.is_tok(toks: r, expected: "(") then
    let inner = pcore.skip(toks: r)
    let ParsedExpr(expr: e, rest: r2) = parse_expr(toks: inner)
    let r3 = pcore.expect(toks: r2, expected: ")")
    return ParsedExpr(expr: SpannedExpr(node: ExprThunk(body: e), span: sp), rest: r3)
  else
    let ParsedExpr(expr: e, rest: r2) = parse_atom(toks: r)
    return ParsedExpr(expr: SpannedExpr(node: ExprForce(value: e), span: sp), rest: r2)
  end
end

let parse_list_literal = fn (
  toks: [ SpannedToken ],
  sp: Span
) -> ParsedExpr throws { ParseError } do
  let r = pcore.skip(toks)
  if pcore.is_tok(toks: r, expected: "]") then
    return ParsedExpr(
      expr: SpannedExpr(node: ExprList(elements: []), span: sp),
      rest: pcore.skip(toks: r)
    )
  end
  let ParsedExprs(exprs: es, rest: r2) = parse_comma_exprs(toks: r, acc: [], closer: "]")
  return ParsedExpr(
    expr: SpannedExpr(node: ExprList(elements: es), span: sp),
    rest: pcore.expect(toks: r2, expected: "]")
  )
end

let parse_array_literal = fn (
  toks: [ SpannedToken ],
  sp: Span
) -> ParsedExpr throws { ParseError } do
  let r = pcore.skip(toks)
  if pcore.is_tok(toks: r, expected: "|]") then
    return ParsedExpr(
      expr: SpannedExpr(node: ExprArray(elements: []), span: sp),
      rest: pcore.skip(toks: r)
    )
  end
  let ParsedExprs(exprs: es, rest: r2) = parse_comma_exprs(toks: r, acc: [], closer: "|]")
  return ParsedExpr(
    expr: SpannedExpr(node: ExprArray(elements: es), span: sp),
    rest: pcore.expect(toks: r2, expected: "|]")
  )
end

let parse_record_literal = fn (
  toks: [ SpannedToken ],
  sp: Span
) -> ParsedExpr throws { ParseError } do
  let ParsedNamedExprs(
    fields: fs,
    rest: r2
  ) = parse_record_expr_fields(toks: pcore.skip(toks), acc: [])
  return ParsedExpr(
    expr: SpannedExpr(node: ExprRecord(fields: fs), span: sp),
    rest: pcore.expect(toks: r2, expected: "}")
  )
end

let parse_sigil_var = fn (
  toks: [ SpannedToken ],
  sp: Span,
  sigil: Sigil
) -> ParsedExpr throws { ParseError } do
  let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.skip(toks))
  return ParsedExpr(
    expr: SpannedExpr(node: ExprVariable(name: Unqual(name: n), sigil), span: sp),
    rest: r2
  )
end

let parse_borrow_expr = fn (toks: [ SpannedToken ], sp: Span) -> ParsedExpr throws { ParseError } do
  let r = pcore.skip(toks)
  let ParsedSigil(sigil: sig, rest: r2) = pcore.parse_sigil(toks: r)
  let ParsedIdent(name: n, rest: r3) = pcore.expect_ident(toks: r2)
  return ParsedExpr(expr: SpannedExpr(node: ExprBorrow(name: n, sigil: sig), span: sp), rest: r3)
end

let parse_constructor_expr = fn (
  toks: [ SpannedToken ],
  sp: Span,
  name: string,
  sigil: Sigil
) -> ParsedExpr throws { ParseError } do
  let r = pcore.skip(toks)
  match pcore.peek_token(toks: r) do
    | TkDot ->
      // Dotted path: mod.Ctor(...) or Cap.method(...)
      let ParsedIdent(name: full_name, rest: r2) = parse_dotted_name(toks: r, prefix: name)
      let rdr_name = rdr.rdr_from_dotted(s: full_name)
      // Check if last segment is uppercase → constructor, otherwise function call
      let last_is_upper = dotted_name_ends_upper(name: full_name)
      if last_is_upper then
        // Qualified constructor: mod.Ctor or mod.Ctor(...)
        match pcore.peek_token(toks: r2) do
          | TkUnit ->
            return ParsedExpr(
              expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: [], sigil), span: sp),
              rest: pcore.skip(toks: r2)
            )
          | TkLParen ->
            let r3 = pcore.skip(toks: r2)
            if pcore.is_tok(toks: r3, expected: ")") then
              return ParsedExpr(
                expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: [], sigil), span: sp),
                rest: pcore.skip(toks: r3)
              )
            end
            let ParsedCtorArgs(args, rest: r4) = parse_ctor_call_args(toks: r3, acc: [])
            return ParsedExpr(
              expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args, sigil), span: sp),
              rest: pcore.expect(toks: r4, expected: ")")
            )
          | _ ->
            return ParsedExpr(
              expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: [], sigil), span: sp),
              rest: r2
            )
        end
      end
      // Lowercase last segment: function call
      match pcore.peek_token(toks: r2) do
        | TkUnit ->
          return ParsedExpr(
            expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp),
            rest: pcore.skip(toks: r2)
          )
        | TkLParen ->
          let r3 = pcore.skip(toks: r2)
          if pcore.is_tok(toks: r3, expected: ")") then
            return ParsedExpr(
              expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp),
              rest: pcore.skip(toks: r3)
            )
          end
          let ParsedCallArgs(args, rest: r4) = parse_fn_call_args(toks: r3, acc: [])
          return ParsedExpr(
            expr: SpannedExpr(node: ExprCall(func: rdr_name, args), span: sp),
            rest: pcore.expect(toks: r4, expected: ")")
          )
        | _ ->
          return ParsedExpr(
            expr: SpannedExpr(node: ExprVariable(name: rdr_name, sigil: SigilImmutable), span: sp),
            rest: r2
          )
      end
    | TkUnit ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprConstructor(name: Unqual(name), args: [], sigil), span: sp),
        rest: pcore.skip(toks: r)
      )
    | TkLParen ->
      let r2 = pcore.skip(toks: r)
      if pcore.is_tok(toks: r2, expected: ")") then
        return ParsedExpr(
          expr: SpannedExpr(node: ExprConstructor(name: Unqual(name), args: [], sigil), span: sp),
          rest: pcore.skip(toks: r2)
        )
      end
      let ParsedCtorArgs(args, rest: r3) = parse_ctor_call_args(toks: r2, acc: [])
      return ParsedExpr(
        expr: SpannedExpr(node: ExprConstructor(name: Unqual(name), args, sigil), span: sp),
        rest: pcore.expect(toks: r3, expected: ")")
      )
    | _ ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprConstructor(name: Unqual(name), args: [], sigil), span: sp),
        rest: r
      )
  end
end

let parse_ident_expr = fn (
  toks: [ SpannedToken ],
  sp: Span,
  name: string
) -> ParsedExpr throws { ParseError } do
  let r = pcore.skip(toks)
  let ParsedIdent(name: full_name, rest: r2) = parse_dotted_name(toks: r, prefix: name)
  let rdr_name = rdr.rdr_from_dotted(s: full_name)
  // If last segment is uppercase, this is a qualified constructor (e.g., hir.PLit)
  let last_upper = dotted_name_ends_upper(name: full_name)
  if last_upper then
    match pcore.peek_token(toks: r2) do
      | TkUnit ->
        return ParsedExpr(
          expr: SpannedExpr(
            node: ExprConstructor(name: rdr_name, args: [], sigil: SigilImmutable),
            span: sp
          ),
          rest: pcore.skip(toks: r2)
        )
      | TkLParen ->
        let r3 = pcore.skip(toks: r2)
        if pcore.is_tok(toks: r3, expected: ")") then
          return ParsedExpr(
            expr: SpannedExpr(
              node: ExprConstructor(name: rdr_name, args: [], sigil: SigilImmutable),
              span: sp
            ),
            rest: pcore.skip(toks: r3)
          )
        else
          let ParsedCtorArgs(args, rest: r4) = parse_ctor_call_args(toks: r3, acc: [])
          return ParsedExpr(
            expr: SpannedExpr(
              node: ExprConstructor(name: rdr_name, args, sigil: SigilImmutable),
              span: sp
            ),
            rest: pcore.expect(toks: r4, expected: ")")
          )
        end
      | _ ->
        return ParsedExpr(
          expr: SpannedExpr(
            node: ExprConstructor(name: rdr_name, args: [], sigil: SigilImmutable),
            span: sp
          ),
          rest: r2
        )
    end
  else
    match pcore.peek_token(toks: r2) do
      | TkUnit ->
        return ParsedExpr(
          expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp),
          rest: pcore.skip(toks: r2)
        )
      | TkLParen ->
        let r3 = pcore.skip(toks: r2)
        if pcore.is_tok(toks: r3, expected: ")") then
          return ParsedExpr(
            expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp),
            rest: pcore.skip(toks: r3)
          )
        else
          let ParsedCallArgs(args, rest: r4) = parse_fn_call_args(toks: r3, acc: [])
          return ParsedExpr(
            expr: SpannedExpr(node: ExprCall(func: rdr_name, args), span: sp),
            rest: pcore.expect(toks: r4, expected: ")")
          )
        end
      | _ ->
        // Multi-segment without call: return first segment as Variable,
        // let postfix loop handle remaining dots as FieldAccess
        if name == full_name then
          return ParsedExpr(
            expr: SpannedExpr(node: ExprVariable(name: rdr_name, sigil: SigilImmutable), span: sp),
            rest: r2
          )
        else
          return ParsedExpr(
            expr: SpannedExpr(
              node: ExprVariable(name: Unqual(name), sigil: SigilImmutable),
              span: sp
            ),
            rest: r
          )
        end
    end
  end
end

let parse_handler_expr = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  let sp = pcore.peek_span(toks)
  let ParsedIdent(
    name: n,
    rest: r2
  ) = pcore.expect_uident(toks: pcore.expect(toks, expected: "handler"))
  let ParsedType(typ: req, rest: r3) = ptype.parse_optional_require(toks: r2)
  let ParsedHandlerArms(
    arms,
    rest: r5
  ) = parse_handler_arms(toks: pcore.expect(toks: r3, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(
    node: ExprHandler(coeffect_name: n, requires: req, arms),
    span: sp
  ), rest: pcore.expect(toks: r5, expected: "end"))
end

// parse_optional_with_kont lives in src/frontend/parser/args.nx

let parse_handler_arms = fn (
  toks: [ SpannedToken ],
  acc: [ HandlerArm ]
) -> ParsedHandlerArms throws { ParseError } do
  if let TkFn = pcore.peek_token(toks) then
    let fn_span = pcore.peek_span(toks)
    let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.skip(toks))
    let ParsedParams(params: ps, rest: r5) = parse_fn_params_or_unit(toks: r2)
    let ParsedType(
      typ: ret,
      rest: r7
    ) = ptype.parse_type(toks: pcore.expect(toks: r5, expected: "->"))
    let ParsedType(typ: thr, rest: r8) = ptype.parse_optional_throws(toks: r7)
    let { binder: kont, rest: r9 } = parse_optional_with_kont(toks: r8)
    let ParsedStmts(
      stmts: body,
      rest: r10
    ) = parse_stmts(toks: pcore.expect(toks: r9, expected: "do"), acc: [])
    let f = Function(name: n, is_public: false, type_params: [],
      params: ps, ret_type: ret, requires: ptype.empty_row(), throw_row: thr, body, span: fn_span)
    let arm = HandlerArm(arm: f, cont_binder: kont, span: fn_span)
    return parse_handler_arms(toks: pcore.expect(toks: r10, expected: "end"), acc: arm :: acc)
  else
    return ParsedHandlerArms(arms: list.reverse(xs: acc), rest: toks)
  end
end

// Dotted-name helpers live in src/frontend/parser/names.nx
// MaybePunArg / try_pun_arg_with_closer / try_pun_call_arg / ctor_pat_lookahead
// / parse_optional_with_kont live in src/frontend/parser/args.nx

type ResolvedArg = ResolvedArg(name: string, value: SpannedExpr, rest: [ SpannedToken ])

let resolve_one_arg = fn (toks: [ SpannedToken ]) -> ResolvedArg throws { ParseError } do
  let punned = try_pun_call_arg(toks)
  if let PunArgYes(name: pn, value: pv, rest: pr) = punned then
    return ResolvedArg(name: pn, value: pv, rest: pr)
  end
  let sp = pcore.peek_span(toks)
  let ParsedIdent(name: n0, rest: r0) = pcore.expect_ident(toks)
  if pcore.is_tok(toks: r0, expected: ":") then
    let ParsedExpr(expr: v0, rest: r1) = parse_expr(toks: pcore.skip(toks: r0))
    return ResolvedArg(name: n0, value: v0, rest: r1)
  end
  return ResolvedArg(
    name: n0,
    value: SpannedExpr(node: ExprVariable(name: Unqual(name: n0), sigil: SigilImmutable), span: sp),
    rest: r0
  )
end

let parse_fn_call_args = fn (
  toks: [ SpannedToken ],
  acc: [ CallArg ]
) -> ParsedCallArgs throws { ParseError } do
  let ResolvedArg(name: n, value: v, rest: r3) = resolve_one_arg(toks)
  let new_acc = CallArg(name: n, value: v) :: acc
  if pcore.is_tok(toks: r3, expected: ",") then
    let r4 = pcore.skip(toks: r3)
    if pcore.is_tok(toks: r4, expected: ")") then
      return ParsedCallArgs(args: list.reverse(xs: new_acc), rest: r4)
    end
    return parse_fn_call_args(toks: r4, acc: new_acc)
  else
    return ParsedCallArgs(args: list.reverse(xs: new_acc), rest: r3)
  end
end

let parse_ctor_call_args = fn (
  toks: [ SpannedToken ],
  acc: [ CtorArg ]
) -> ParsedCtorArgs throws { ParseError } do
  let ResolvedArg(name: n, value: v, rest: r3) = resolve_one_arg(toks)
  let new_acc = CtorArg(name: n, value: v) :: acc
  if pcore.is_tok(toks: r3, expected: ",") then
    let r4 = pcore.skip(toks: r3)
    if pcore.is_tok(toks: r4, expected: ")") then
      return ParsedCtorArgs(args: list.reverse(xs: new_acc), rest: r4)
    end
    return parse_ctor_call_args(toks: r4, acc: new_acc)
  else
    return ParsedCtorArgs(args: list.reverse(xs: new_acc), rest: r3)
  end
end

let parse_comma_exprs = fn (
  toks: [ SpannedToken ],
  acc: [ SpannedExpr ],
  closer: string
) -> ParsedExprs throws { ParseError } do
  let ParsedExpr(expr: e, rest: r) = parse_expr(toks)
  let new_acc = e :: acc
  if pcore.is_tok(toks: r, expected: ",") then
    let r2 = pcore.skip(toks: r)
    if pcore.is_tok(toks: r2, expected: closer) then
      return ParsedExprs(exprs: list.reverse(xs: new_acc), rest: r2)
    end
    return parse_comma_exprs(toks: r2, acc: new_acc, closer)
  else
    return ParsedExprs(exprs: list.reverse(xs: new_acc), rest: r)
  end
end

let parse_record_expr_fields = fn (
  toks: [ SpannedToken ],
  acc: [ NamedExpr ]
) -> ParsedNamedExprs throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkRBrace -> return ParsedNamedExprs(fields: list.reverse(xs: acc), rest: toks)
    | _ ->
      let punned = try_pun_arg_with_closer(toks, closer: "}")
      if let PunArgYes(name: pn, value: pv, rest: pr) = punned then
        let new_acc_p = NamedExpr(name: pn, value: pv) :: acc
        if pcore.is_tok(toks: pr, expected: ",") then
          return parse_record_expr_fields(toks: pcore.skip(toks: pr), acc: new_acc_p)
        else
          return ParsedNamedExprs(fields: list.reverse(xs: new_acc_p), rest: pr)
        end
      end
      let ParsedIdent(name: n, rest: r) = pcore.expect_ident(toks)
      let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r, expected: ":"))
      let new_acc = NamedExpr(name: n, value: v) :: acc
      if pcore.is_tok(toks: r3, expected: ",") then
        return parse_record_expr_fields(toks: pcore.skip(toks: r3), acc: new_acc)
      else
        return ParsedNamedExprs(fields: list.reverse(xs: new_acc), rest: r3)
      end
  end
end

// Param + type-param parsing lives in src/frontend/parser/params.nx

// Parse the stmts that follow `else`. When the next token is `if`, the inner
// if-expression consumes its own `end` (else-if chain sugar, single trailing end);
// otherwise parse a normal stmt list terminated by `end`.
let parse_else_tail = fn (toks: [ SpannedToken ]) -> ParsedStmts throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkIf ->
      let inner_sp = pcore.peek_span(toks)
      let ParsedExpr(expr: inner_if, rest: r) = parse_if_expr(toks)
      return ParsedStmts(
        stmts: [ SpannedStmt(node: StmtExpr(expr: inner_if), span: inner_sp) ],
        rest: r
      )
    | _ ->
      let ParsedStmts(stmts: body, rest: r) = parse_stmts(toks, acc: [])
      return ParsedStmts(stmts: body, rest: pcore.expect(toks: r, expected: "end"))
  end
end

// if let <pattern> = <expr> then <body> [else <body>] end
// → desugar to match <expr> do case <pattern> -> <then> case _ -> <else> end
let parse_if_let_expr = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  let sp = pcore.peek_span(toks)
  let ParsedPat(pat, rest: r2) = ppat.parse_pattern(toks)
  let r3 = pcore.expect(toks: r2, expected: "=")
  let ParsedExpr(expr: target, rest: r4) = parse_expr(toks: r3)
  let ParsedStmts(
    stmts: then_body,
    rest: r5
  ) = parse_stmts(toks: pcore.expect(toks: r4, expected: "then"), acc: [])
  let wildcard_pat = SpannedPattern(node: PatWildcard, span: sp)
  match pcore.peek_token(toks: r5) do
    | TkElse ->
      let ParsedStmts(stmts: else_body, rest: r7) = parse_else_tail(toks: pcore.skip(toks: r5))
      return ParsedExpr(
        expr: SpannedExpr(node: ExprMatch(target, cases: [
          MatchCase(pattern: pat, body: then_body),
          MatchCase(pattern: wildcard_pat, body: else_body)
        ]), span: sp),
        rest: r7)
    | _ ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprMatch(target, cases: [
          MatchCase(pattern: pat, body: then_body),
          MatchCase(pattern: wildcard_pat, body: [])
        ]), span: sp),
        rest: pcore.expect(toks: r5, expected: "end"))
  end
end

let parse_if_expr = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  let sp = pcore.peek_span(toks)
  let r1 = pcore.expect(toks, expected: "if")
  match pcore.peek_token(toks: r1) do
    | TkLet -> return parse_if_let_expr(toks: pcore.skip(toks: r1))
    | _ ->
      let ParsedExpr(expr: cond, rest: r2) = parse_expr(toks: r1)
      let ParsedStmts(
        stmts: then_body,
        rest: r4
      ) = parse_stmts(toks: pcore.expect(toks: r2, expected: "then"), acc: [])
      match pcore.peek_token(toks: r4) do
        | TkElse ->
          let ParsedStmts(stmts: else_body, rest: r6) = parse_else_tail(toks: pcore.skip(toks: r4))
          return ParsedExpr(expr: SpannedExpr(node: ExprIf(cond, then_branch: then_body, else_branch: else_body), span: sp),
            rest: r6)
        | _ ->
          return ParsedExpr(expr: SpannedExpr(node: ExprIf(cond, then_branch: then_body, else_branch: []), span: sp),
            rest: pcore.expect(toks: r4, expected: "end"))
      end
  end
end

let parse_match_expr = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  let sp = pcore.peek_span(toks)
  let ParsedExpr(expr: target, rest: r2) = parse_expr(toks: pcore.expect(toks, expected: "match"))
  let ParsedMatchCases(
    cases: cs,
    rest: r4
  ) = parse_match_cases(toks: pcore.expect(toks: r2, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprMatch(target, cases: cs), span: sp),
    rest: pcore.expect(toks: r4, expected: "end"))
end

let parse_match_cases = fn (
  toks: [ SpannedToken ],
  acc: [ MatchCase ]
) -> ParsedMatchCases throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkPipe ->
      let ParsedPat(pat: p, rest: r2) = ppat.parse_pattern_or(toks: pcore.skip(toks))
      let ParsedStmts(
        stmts: body,
        rest: r4
      ) = parse_stmts(toks: pcore.expect(toks: r2, expected: "->"), acc: [])
      return parse_match_cases(toks: r4, acc: MatchCase(pattern: p, body) :: acc)
    | _ -> return ParsedMatchCases(cases: list.reverse(xs: acc), rest: toks)
  end
end

let parse_while_expr = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  let sp = pcore.peek_span(toks)
  let ParsedExpr(expr: cond, rest: r2) = parse_expr(toks: pcore.expect(toks, expected: "while"))
  let ParsedStmts(
    stmts: body,
    rest: r4
  ) = parse_stmts(toks: pcore.expect(toks: r2, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprWhile(cond, body), span: sp),
    rest: pcore.expect(toks: r4, expected: "end"))
end

let parse_for_expr = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  let sp = pcore.peek_span(toks)
  let ParsedIdent(
    name: var,
    rest: r2
  ) = pcore.expect_ident(toks: pcore.expect(toks, expected: "for"))
  let ParsedExpr(expr: start_e, rest: r4) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
  let ParsedExpr(expr: end_e, rest: r6) = parse_expr(toks: pcore.expect(toks: r4, expected: "to"))
  let ParsedStmts(
    stmts: body,
    rest: r8
  ) = parse_stmts(toks: pcore.expect(toks: r6, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprFor(var, start: start_e, end_expr: end_e, body), span: sp),
    rest: pcore.expect(toks: r8, expected: "end"))
end

let parse_lambda = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  let sp = pcore.peek_span(toks)
  let ParsedStrings(
    items: tps,
    rest: r_tp
  ) = parse_optional_type_params(toks: pcore.expect(toks, expected: "fn"))
  if pcore.is_tok(toks: r_tp, expected: "()") then
    return parse_lambda_body(toks: pcore.skip(toks: r_tp), type_params: tps, params: [], sp)
  end
  let ParsedParams(
    params: ps,
    rest: r3
  ) = parse_params(toks: pcore.expect(toks: r_tp, expected: "("), acc: [])
  return parse_lambda_body(
    toks: pcore.expect(toks: r3, expected: ")"),
    type_params: tps,
    params: ps,
    sp
  )
end

let parse_lambda_body = fn (
  toks: [ SpannedToken ],
  type_params: [ string ],
  params: [ Param ],
  sp: Span
) -> ParsedExpr throws { ParseError } do
  let ParsedType(typ: ret, rest: r6) = ptype.parse_type(toks: pcore.expect(toks, expected: "->"))
  let ParsedType(typ: req, rest: r7) = ptype.parse_optional_require(toks: r6)
  let ParsedType(typ: thr, rest: r8) = ptype.parse_optional_throws(toks: r7)
  let ParsedStmts(
    stmts: body,
    rest: r10
  ) = parse_stmts(toks: pcore.expect(toks: r8, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(
    node: ExprLambda(type_params, params, ret_type: ret, requires: req, throw_row: thr, body),
    span: sp
  ), rest: pcore.expect(toks: r10, expected: "end"))
end

let parse_stmts = fn (
  toks: [ SpannedToken ],
  acc: [ SpannedStmt ]
) -> ParsedStmts throws { ParseError } do
  if pcore.is_block_end(tok: pcore.peek_token(toks)) then
    return ParsedStmts(stmts: list.reverse(xs: acc), rest: toks)
  end
  let ParsedStmt(stmt: s, rest) = parse_stmt(toks)
  return parse_stmts(toks: rest, acc: s :: acc)
end

let parse_stmt = fn (toks: [ SpannedToken ]) -> ParsedStmt throws { ParseError } do
  let sp = pcore.peek_span(toks)
  match pcore.peek_token(toks) do
    | TkLet -> return parse_let_stmt(toks)
    | TkReturn ->
      let ParsedExpr(expr: e, rest: r2) = parse_expr(toks: pcore.skip(toks))
      return ParsedStmt(stmt: SpannedStmt(node: StmtReturn(value: e), span: sp), rest: r2)
    | TkTry -> return parse_try_stmt(toks)
    | TkInject ->
      // Statement-position `inject H do … end`. The dispatcher fires on
      // TkInject before the expression-statement fallthrough, so a bare inject
      // stays a statement — but it is parsed as the SOLE inject form (an
      // ExprInject) and wrapped in a discarded StmtExpr. The body's trailing
      // value is dropped, preserving the old statement-form side-effect
      // semantics while unifying the AST on the expression node.
      let ParsedExpr(expr: ie, rest: ir) = parse_inject_expr(toks)
      return ParsedStmt(stmt: SpannedStmt(node: StmtExpr(expr: ie), span: sp), rest: ir)
    | _ ->
      // Expression statement or assignment
      let ParsedExpr(expr: e, rest: r) = parse_expr(toks)
      match pcore.peek_token(toks: r) do
        | TkLArrow ->
          let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.skip(toks: r))
          // Accept two LHS shapes: a bare variable (`x <- v`) or an indexed
          // target (`arr[idx] <- v`). The latter lowers through HIR
          // Assign(target: ExprIndex(...), value: v) and ultimately becomes
          // a __array_set intrinsic call.
          let SpannedExpr(node: lhs_node, span: _) = e
          match lhs_node do
            | ExprVariable(name: nm, sigil: _) ->
              let target_name = rdr.rdr_to_string(r: nm)
              return ParsedStmt(
                stmt: SpannedStmt(node: StmtAssign(target: target_name, value: v), span: sp),
                rest: r3
              )
            | ExprIndex(target: arr_expr, index: idx_expr) ->
              return ParsedStmt(
                stmt: SpannedStmt(
                  node: StmtIndexAssign(target: arr_expr, index: idx_expr, value: v),
                  span: sp
                ),
                rest: r3
              )
            | _ ->
              throw UnexpectedToken(
                expected: "assignable variable or indexed target before '<-'",
                got: "non-assignable expression",
                span: sp
              )
          end
        | _ ->
          return ParsedStmt(stmt: SpannedStmt(node: StmtExpr(expr: e), span: sp), rest: r)
      end
  end
end

let parse_let_with_type = fn (
  n: string,
  sig: Sigil,
  r3: [ SpannedToken ],
  sp: Span
) -> ParsedStmt throws { ParseError } do
  let ParsedType(typ: t, rest: r5) = ptype.parse_type(toks: pcore.skip(toks: r3))
  let ParsedExpr(expr: v, rest: r7) = parse_expr(toks: pcore.expect(toks: r5, expected: "="))
  ParsedStmt(
    stmt: SpannedStmt(node: StmtLet(name: n, sigil: sig, typ: Some(val: t), value: v), span: sp),
    rest: r7
  )
end

let parse_let_without_type = fn (
  n: string,
  sig: Sigil,
  r3: [ SpannedToken ],
  sp: Span
) -> ParsedStmt throws { ParseError } do
  let ParsedExpr(expr: v, rest: r5) = parse_expr(toks: pcore.expect(toks: r3, expected: "="))
  ParsedStmt(
    stmt: SpannedStmt(node: StmtLet(name: n, sigil: sig, typ: None, value: v), span: sp),
    rest: r5
  )
end

// ctor_pat_lookahead lives in src/frontend/parser/args.nx

let parse_let_stmt = fn (toks: [ SpannedToken ]) -> ParsedStmt throws { ParseError } do
  let sp = pcore.peek_span(toks)
  let r_after_let = pcore.expect(toks, expected: "let")
  // Check for destructuring: let Ctor(...) = expr, let Mod.Ctor(...) = expr,
  // let mod.Ctor(...) = expr (lowercase module alias), or let { ... } = expr
  let is_ctor_pat_head = match pcore.peek_token(toks: r_after_let) do
    | TkUident(_) ->
      // Bare uppercase ctor `Ctor(` or N-deep qualified `Mod.Sub.Ctor(`
      ctor_pat_lookahead(
        toks: pcore.skip(toks: r_after_let),
        last_was_uident: true,
        after_dot: false
      )
    | TkIdent(_) ->
      // Lowercase module alias: `mod.Ctor(` or `mod.sub.Ctor(` — must have at
      // least one dot segment ending at an uppercase ctor before `(`.
      ctor_pat_lookahead(
        toks: pcore.skip(toks: r_after_let),
        last_was_uident: false,
        after_dot: false
      )
    | _ -> false
  end
  if is_ctor_pat_head then
    let ParsedPat(pat, rest: r2) = ppat.parse_pattern(toks: r_after_let)
    let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
    return ParsedStmt(
      stmt: SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp),
      rest: r3
    )
  end
  if let TkLBrace = pcore.peek_token(toks: r_after_let) then
    let ParsedPat(pat, rest: r2) = ppat.parse_pattern(toks: r_after_let)
    let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
    return ParsedStmt(
      stmt: SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp),
      rest: r3
    )
  end
  // `let SIGIL Ctor(.) = expr` destructure. The sigil sits on
  // the constructor pattern (PatConstructor.sigil), not on a let-binding
  // variable, so we route into parse_pattern which already accepts the
  // sigil-prefix shape via parse_atom_pattern's TkPercent/TkTilde/TkAt/
  // TkAmpersand → try_qualified_ctor_pat branches.
  let has_sigil = match pcore.peek_token(toks: r_after_let) do
    | TkPercent | TkTilde | TkAt | TkAmpersand -> true
    | _ -> false
  end
  if has_sigil then
    let r_after_sig = pcore.skip(toks: r_after_let)
    let is_ctor_pat_sig = match pcore.peek_token(toks: r_after_sig) do
      | TkUident(_) ->
        ctor_pat_lookahead(
          toks: pcore.skip(toks: r_after_sig),
          last_was_uident: true,
          after_dot: false
        )
      | _ -> false
    end
    if is_ctor_pat_sig then
      let ParsedPat(pat, rest: r2) = ppat.parse_pattern(toks: r_after_let)
      let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
      return ParsedStmt(
        stmt: SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp),
        rest: r3
      )
    end
  end
  let ParsedSigil(sigil: sig, rest: r2) = pcore.parse_sigil(toks: r_after_let)
  let ParsedIdent(name: n, rest: r3) = pcore.expect_ident(toks: r2)
  if n == "_" then
    throw UnexpectedToken(
      expected: "identifier (not `_`)",
      got: "`_` is reserved for match wildcards, not let-binders",
      span: sp
    )
  end
  return if pcore.is_tok(toks: r3, expected: ":") then
    parse_let_with_type(n, sig, r3, sp)
  else
    parse_let_without_type(n, sig, r3, sp)
  end
end

let parse_try_stmt = fn (toks: [ SpannedToken ]) -> ParsedStmt throws { ParseError } do
  let sp = pcore.peek_span(toks)
  let ParsedStmts(
    stmts: body,
    rest: r2
  ) = parse_stmts(toks: pcore.expect(toks, expected: "try"), acc: [])
  let r_after_catch = pcore.expect(toks: r2, expected: "catch")
  match pcore.peek_token(toks: r_after_catch) do
    | TkPipe ->
      // Selective catch: catch | Pattern -> body ...
      let ParsedCatchArms(arms, rest: r4) = parse_catch_arms(toks: r_after_catch, acc: [])
      return ParsedStmt(stmt: SpannedStmt(node: StmtTry(body, catch_arms: arms), span: sp),
        rest: pcore.expect(toks: r4, expected: "end"))
    | _ ->
      // Bare catch: catch param -> body
      let ParsedIdent(name: param, rest: r4) = pcore.expect_ident(toks: r_after_catch)
      let ParsedStmts(
        stmts: catch_body,
        rest: r6
      ) = parse_stmts(toks: pcore.expect(toks: r4, expected: "->"), acc: [])
      let arm = CatchArm(
        pattern: SpannedPattern(node: PatVariable(name: param, sigil: SigilImmutable), span: sp),
        body: catch_body
      )
      return ParsedStmt(stmt: SpannedStmt(node: StmtTry(body, catch_arms: [ arm ]), span: sp),
        rest: pcore.expect(toks: r6, expected: "end"))
  end
end

let parse_catch_arms = fn (
  toks: [ SpannedToken ],
  acc: [ CatchArm ]
) -> ParsedCatchArms throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkPipe ->
      let ParsedPat(pat: p, rest: r2) = ppat.parse_pattern_or(toks: pcore.skip(toks))
      let ParsedStmts(
        stmts: arm_body,
        rest: r4
      ) = parse_stmts(toks: pcore.expect(toks: r2, expected: "->"), acc: [])
      return parse_catch_arms(toks: r4, acc: CatchArm(pattern: p, body: arm_body) :: acc)
    | _ -> return ParsedCatchArms(arms: list.reverse(xs: acc), rest: toks)
  end
end

/** Parse `inject H do <body> end` as the SOLE inject AST form — an
 *  `ExprInject` node usable in `let`/`return`/argument position, whose value is
 *  the body's trailing value. Statement-position inject reaches this parser via
 *  the statement dispatcher (which matches `TkInject` before falling to the
 *  expression-statement path) and wraps the result in a discarded
 *  `StmtExpr(ExprInject(...))`, so a bare inject stays a statement while every
 *  existing side-effect inject keeps working (its trailing value is dropped).
 */
let parse_inject_expr = fn (toks: [ SpannedToken ]) -> ParsedExpr throws { ParseError } do
  let sp = pcore.peek_span(toks)
  let ParsedExprs(
    exprs: hs,
    rest: r2
  ) = parse_inject_handlers(toks: pcore.expect(toks, expected: "inject"), acc: [])
  let ParsedStmts(
    stmts: body,
    rest: r4
  ) = parse_stmts(toks: pcore.expect(toks: r2, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprInject(handlers: hs, body), span: sp),
    rest: pcore.expect(toks: r4, expected: "end"))
end

/** Parse comma-separated dotted handler names: "a.b, c.d, ..." → [ExprVariable("a.b"), ExprVariable("c.d")] */
let parse_inject_handlers = fn (
  toks: [ SpannedToken ],
  acc: [ SpannedExpr ]
) -> ParsedExprs throws { ParseError } do
  let ParsedIdent(name: first, rest: r1) = parse_handler_dotted(toks)
  let sp = pcore.peek_span(toks)
  let expr = SpannedExpr(
    node: ExprVariable(name: rdr.rdr_from_dotted(s: first), sigil: SigilImmutable),
    span: sp
  )
  match pcore.peek_token(toks: r1) do
    | TkComma ->
      return parse_inject_handlers(toks: pcore.skip(toks: r1), acc: expr :: acc)
    | _ ->
      return ParsedExprs(exprs: list.reverse(xs: expr :: acc), rest: r1)
  end
end
