/**
 * parser/params: function parameter + type-parameter list parsing.
 *
 * Owns:
 * - parse_fn_params_or_unit (top-level: `()` or `(p1, p2, …)`)
 * - parse_params (helper: parses the comma-separated body)
 * - parse_optional_type_params / parse_type_param_list (`<T, U, …>`)
 *
 * Does not own:
 * - Expression / statement / pattern parsing (see src/frontend/parser.nx)
 * - Type-expression parsing (see src/frontend/parser/type.nx)
 *
 * Exists so parser/topdef.nx (cap/lambda-style signatures) and parser.nx
 * (lambdas, top-level function defs) can share param parsing without
 * a cyclic import — every helper here depends only on pcore + ptype.
 */
import { SpannedToken } from "src/syntax/token.nx"
import { Param } from "src/syntax/ast.nx"
import { UnexpectedToken, ParseError } from "src/diagnostics/error.nx"
import { DuplicateParamLabel } from "src/frontend/errors.nx"
import {
  ParsedType,
  ParsedIdent,
  ParsedSigil,
  ParsedParams,
  ParsedStrings
}, * as pcore from "src/frontend/parser/util.nx"
import * as ptype from "src/frontend/parser/type.nx"
import * as list from "std:list"

// Returns true when `name` already appears as a parameter name in `acc`.
// Linear scan is fine: function arities are small in practice.
let param_name_in_acc = fn (name: string, acc: [ Param ]) -> bool do
  match acc do
    | [] -> return false
    | Param(name: n, sigil: _, typ: _) :: rest ->
      if n == name then return true
      else return param_name_in_acc(name, acc: rest)
      end
  end
end

/** Parse the parameter list of a function/lambda head; accepts unit `()` as the empty-params shortcut, otherwise `(p1, p2, ...)`. Top-level entry point shared by parse_topdef (top-level `fn`/`cap`) and parser (lambdas). */
export let parse_fn_params_or_unit = fn (toks: [ SpannedToken ]) -> ParsedParams throws { ParseError } do
  if pcore.is_tok(toks, expected: "()") then
    return ParsedParams(params: [], rest: pcore.skip(toks))
  end
  let ParsedParams(
    params: ps,
    rest: r2
  ) = parse_params(toks: pcore.expect(toks, expected: "("), acc: [])
  return ParsedParams(params: ps, rest: pcore.expect(toks: r2, expected: ")"))
end

/** Parse the comma-separated body of `(sig name: type, ...)` inside an already-opened paren; tail-recursive accumulator-reversed-once for O(n). Stops at `)` without consuming it — caller closes the paren. */
export let parse_params = fn (
  toks: [ SpannedToken ],
  acc: [ Param ]
) -> ParsedParams throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkRParen -> return ParsedParams(params: list.reverse(xs: acc), rest: toks)
    | _ ->
      let ParsedSigil(sigil: sig, rest: r) = pcore.parse_sigil(toks)
      let ident_span = pcore.peek_span(toks: r)
      let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: r)
      // Enforce distinct parameter labels: reject duplicate names early in the
      // parse phase rather than letting the type-checker see a malformed AST.
      if param_name_in_acc(name: n, acc: acc) then
        throw DuplicateParamLabel(name: n, span: ident_span)
      end
      let ParsedType(
        typ: t,
        rest: r4
      ) = ptype.parse_type(toks: pcore.expect(toks: r2, expected: ":"))
      let new_acc = Param(name: n, sigil: sig, typ: t) :: acc
      if pcore.is_tok(toks: r4, expected: ",") then
        return parse_params(toks: pcore.skip(toks: r4), acc: new_acc)
      else
        return ParsedParams(params: list.reverse(xs: new_acc), rest: r4)
      end
  end
end

/** Parse an optional `<T, U, ...>` type-parameter list; returns empty `items` when no `<` is present so callers can blindly thread the rest of the parse without a branch. */
export let parse_optional_type_params = fn (toks: [ SpannedToken ]) -> ParsedStrings throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkLt ->
      let ParsedStrings(
        items: ps,
        rest: r2
      ) = parse_type_param_list(toks: pcore.skip(toks), acc: [])
      match pcore.peek_token(toks: r2) do
        | TkGt -> return ParsedStrings(items: ps, rest: pcore.skip(toks: r2))
        | _ -> return ParsedStrings(items: [], rest: toks)
      end
    | _ -> return ParsedStrings(items: [], rest: toks)
  end
end

/** Parse the comma-separated body of `<T, U, ...>` inside an already-opened `<`; accepts both `TkUident` and `TkIdent` (lowercase generics allowed). Stops at `>` without consuming it — caller closes the bracket. */
let parse_type_param_list = fn (
  toks: [ SpannedToken ],
  acc: [ string ]
) -> ParsedStrings throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkGt -> return ParsedStrings(items: list.reverse(xs: acc), rest: toks)
    | TkUident(name: n) | TkIdent(name: n) ->
      let r = pcore.skip(toks)
      if pcore.is_tok(toks: r, expected: ",") then
        return parse_type_param_list(toks: pcore.skip(toks: r), acc: n :: acc)
      else
        return ParsedStrings(items: list.reverse(xs: n :: acc), rest: r)
      end
    | _ ->
      throw UnexpectedToken(
        expected: "type parameter",
        got: pcore.token_tag(tok: pcore.peek_token(toks)),
        span: pcore.peek_span(toks)
      )
  end
end
