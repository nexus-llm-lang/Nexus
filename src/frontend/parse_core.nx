/**
 * parse_core: Parser utility types and helper functions for the Nexus self-hosting compiler.
 *
 * Contains result/parsed types, token helpers, binop tables, and arrow type lookahead.
 * Extracted from the monolithic parser.nx into a reusable module.
 */

import { Token, Span, SpannedToken } from "src/common/token.nx"
import { Sigil, BinaryOp, TypeExpr, SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel, Param, Function, MatchCase, CatchArm, CallArg, CtorArg, NamedExpr, NamedType, VariantField, CtorPatternField, RecordPatField, VariantDef, FunctionSig, ImportItem } from "src/common/ast.nx"
import { UnexpectedToken } from "src/common/error.nx"

// ─── Result types ────────────────────────────────────────────────────────────

export type ParsedType = ParsedType(typ: TypeExpr, rest: [SpannedToken])
export type ParsedExpr = ParsedExpr(expr: SpannedExpr, rest: [SpannedToken])
export type ParsedStmt = ParsedStmt(stmt: SpannedStmt, rest: [SpannedToken])
export type ParsedPat = ParsedPat(pat: SpannedPattern, rest: [SpannedToken])
export type ParsedIdent = ParsedIdent(name: string, rest: [SpannedToken])
export type ParsedSigil = ParsedSigil(sigil: Sigil, rest: [SpannedToken])
export type ParsedStmts = ParsedStmts(stmts: [SpannedStmt], rest: [SpannedToken])
export type ParsedCallArgs = ParsedCallArgs(args: [CallArg], rest: [SpannedToken])
export type ParsedCtorArgs = ParsedCtorArgs(args: [CtorArg], rest: [SpannedToken])
export type ParsedParams = ParsedParams(params: [Param], rest: [SpannedToken])
export type ParsedMatchCases = ParsedMatchCases(cases: [MatchCase], rest: [SpannedToken])
export type ParsedNamedTypes = ParsedNamedTypes(fields: [NamedType], rest: [SpannedToken])
export type ParsedTypes = ParsedTypes(types: [TypeExpr], rest: [SpannedToken])
export type ParsedVariants = ParsedVariants(variants: [VariantDef], rest: [SpannedToken])
export type ParsedVariantFields = ParsedVariantFields(fields: [VariantField], rest: [SpannedToken])
export type ParsedFunctions = ParsedFunctions(functions: [Function], rest: [SpannedToken])
export type ParsedFunctionSigs = ParsedFunctionSigs(sigs: [FunctionSig], rest: [SpannedToken])
export type ParsedExprs = ParsedExprs(exprs: [SpannedExpr], rest: [SpannedToken])
export type ParsedNamedExprs = ParsedNamedExprs(fields: [NamedExpr], rest: [SpannedToken])
export type ParsedCtorPatFields = ParsedCtorPatFields(fields: [CtorPatternField], rest: [SpannedToken])
export type ParsedRecordPatFields = ParsedRecordPatFields(fields: [RecordPatField], has_wildcard: bool, rest: [SpannedToken])
export type ParsedStrings = ParsedStrings(items: [string], rest: [SpannedToken])
export type ParsedImportItems = ParsedImportItems(items: [ImportItem], rest: [SpannedToken])
export type ParsedCatchArms = ParsedCatchArms(arms: [CatchArm], rest: [SpannedToken])
export type ParsedTopLevel = ParsedTopLevel(item: SpannedTopLevel, rest: [SpannedToken])

// ─── Token helpers ───────────────────────────────────────────────────────────

export let peek_token = fn (toks: [SpannedToken]) -> Token do
  match toks do
    case SpannedToken(token: tk, span: _) :: _ -> tk
    case [] -> TkEof
  end
end

export let peek_span = fn (toks: [SpannedToken]) -> Span do
  match toks do
    case SpannedToken(token: _, span: sp) :: _ -> sp
    case [] -> Span(offset: 0, line: 0, col: 0)
  end
end

export let skip = fn (toks: [SpannedToken]) -> [SpannedToken] do
  match toks do
    case _ :: r -> r
    case [] -> toks
  end
end

export let token_tag = fn (tok: Token) -> string do
  match tok do
    case TkLet -> "let" case TkFn -> "fn" case TkDo -> "do" case TkEnd -> "end"
    case TkIf -> "if" case TkThen -> "then" case TkElse -> "else"
    case TkMatch -> "match" case TkCase -> "case"
    case TkWhile -> "while" case TkFor -> "for" case TkTo -> "to"
    case TkReturn -> "return" case TkImport -> "import" case TkFrom -> "from"
    case TkAs -> "as" case TkExternal -> "external" case TkPub -> "export"
    case TkOpaque -> "opaque" case TkType -> "type" case TkPort -> "port"
    case TkHandler -> "handler" case TkInject -> "inject"
    case TkTry -> "try" case TkCatch -> "catch" case TkRaise -> "raise"
    case TkDrop -> "drop" case TkRequire -> "require" case TkThrows -> "throws"
    case TkException -> "exception" case TkRef -> "ref"
    case TkPlus -> "+" case TkMinus -> "-" case TkStar -> "*" case TkSlash -> "/"
    case TkPlusPlus -> "++" case TkPlusDot -> "+." case TkMinusDot -> "-."
    case TkStarDot -> "*." case TkSlashDot -> "/."
    case TkEqEq -> "==" case TkBangEq -> "!=" case TkLt -> "<" case TkGt -> ">"
    case TkLe -> "<=" case TkGe -> ">="
    case TkEqEqDot -> "==." case TkBangEqDot -> "!=." case TkLtDot -> "<."
    case TkGtDot -> ">." case TkLeDot -> "<=." case TkGeDot -> ">=."
    case TkAndAnd -> "&&" case TkPipePipe -> "||" case TkShl -> "<<" case TkShr -> ">>"
    case TkArrow -> "->" case TkLArrow -> "<-" case TkEq -> "=" case TkPipe -> "|"
    case TkLParen -> "(" case TkRParen -> ")" case TkLBrace -> "{" case TkRBrace -> "}"
    case TkLBracket -> "[" case TkRBracket -> "]" case TkLArray -> "[|" case TkRArray -> "|]"
    case TkComma -> "," case TkDot -> "." case TkColon -> ":" case TkColonColon -> "::"
    case TkTilde -> "~" case TkPercent -> "%" case TkAmpersand -> "&" case TkAt -> "@" case TkCaret -> "^"
    case TkTrue -> "true" case TkFalse -> "false" case TkUnit -> "()"
    case TkInt(_) -> "int" case TkFloat(_) -> "float" case TkChar(_) -> "char"
    case TkString(_) -> "string_lit" case TkIdent(_) -> "ident"
    case TkUident(_) -> "uident" case TkImportPath(_) -> "import_path"
    case TkError(_) -> "error"
    case TkEof -> "eof"
  end
end

export let is_tok = fn (toks: [SpannedToken], expected: string) -> bool do
  return token_tag(tok: peek_token(toks: toks)) == expected
end

export let expect = fn (toks: [SpannedToken], expected: string) -> [SpannedToken] throws { Exn } do
  if token_tag(tok: peek_token(toks: toks)) == expected then return skip(toks: toks)
  else
    raise UnexpectedToken(expected: expected, got: token_tag(tok: peek_token(toks: toks)), span: peek_span(toks: toks))
  end
end

export let expect_ident = fn (toks: [SpannedToken]) -> ParsedIdent throws { Exn } do
  match peek_token(toks: toks) do
    case TkIdent(name: n) -> return ParsedIdent(name: n, rest: skip(toks: toks))
    case _ ->
      raise UnexpectedToken(expected: "identifier", got: token_tag(tok: peek_token(toks: toks)), span: peek_span(toks: toks))
  end
end

export let expect_uident = fn (toks: [SpannedToken]) -> ParsedIdent throws { Exn } do
  match peek_token(toks: toks) do
    case TkUident(name: n) -> return ParsedIdent(name: n, rest: skip(toks: toks))
    case _ ->
      raise UnexpectedToken(expected: "uppercase identifier", got: token_tag(tok: peek_token(toks: toks)), span: peek_span(toks: toks))
  end
end

export let parse_sigil = fn (toks: [SpannedToken]) -> ParsedSigil do
  match peek_token(toks: toks) do
    case TkTilde -> return ParsedSigil(sigil: SigilMutable, rest: skip(toks: toks))
    case TkPercent -> return ParsedSigil(sigil: SigilLinear, rest: skip(toks: toks))
    case TkAmpersand -> return ParsedSigil(sigil: SigilBorrow, rest: skip(toks: toks))
    case TkAt -> return ParsedSigil(sigil: SigilLazy, rest: skip(toks: toks))
    case _ -> return ParsedSigil(sigil: SigilImmutable, rest: toks)
  end
end

/// Check if the next two tokens form a labeled field pattern: `ident : ...`
export let is_labeled_field = fn (toks: [SpannedToken]) -> bool do
  match peek_token(toks: toks) do
    case TkIdent(_) ->
      match peek_token(toks: skip(toks: toks)) do
        case TkColon -> true
        case _ -> false
      end
    case _ -> false
  end
end

export let is_block_end = fn (tok: Token) -> bool do
  match tok do
    case TkEnd -> true case TkElse -> true case TkCase -> true
    case TkCatch -> true case TkEof -> true
    case _ -> false
  end
end

// ─── Arrow type lookahead ────────────────────────────────────────────────────

/// Disambiguate arrow types from parenthesized types using 2-token lookahead.
/// Arrow types always have named parameters: (name: Type, ...) -> RetType
/// So after '(', if we see 'ident :' it's an arrow; if ')' then check for '->'.
export let is_arrow_start = fn (toks: [SpannedToken]) -> bool do
  let inner = skip(toks: toks)
  match peek_token(toks: inner) do
    case TkRParen ->
      // ( ) -> ... is arrow with empty params (rare: usually lexed as TkUnit)
      match peek_token(toks: skip(toks: inner)) do
        case TkArrow -> true
        case _ -> false
      end
    case TkIdent(_) ->
      // (name: ...) -> ... is arrow type
      match peek_token(toks: skip(toks: inner)) do
        case TkColon -> true
        case _ -> false
      end
    case _ -> false
  end
end

// ─── Binop tables ────────────────────────────────────────────────────────────

export let get_binop_prec = fn (tok: Token) -> i64 do
  match tok do
    case TkPipePipe -> return 1
    case TkAndAnd -> return 2
    case TkEqEq -> return 3 case TkBangEq -> return 3
    case TkLt -> return 3 case TkGt -> return 3 case TkLe -> return 3 case TkGe -> return 3
    case TkEqEqDot -> return 3 case TkBangEqDot -> return 3
    case TkLtDot -> return 3 case TkGtDot -> return 3 case TkLeDot -> return 3 case TkGeDot -> return 3
    case TkPlus -> return 4 case TkMinus -> return 4 case TkPlusPlus -> return 4
    case TkPlusDot -> return 4 case TkMinusDot -> return 4
    case TkPipe -> return 4 case TkCaret -> return 4
    case TkStar -> return 5 case TkSlash -> return 5 case TkPercent -> return 5
    case TkStarDot -> return 5 case TkSlashDot -> return 5 case TkAmpersand -> return 5
    case TkShl -> return 6 case TkShr -> return 6
    case _ -> return -1
  end
end

export let token_to_binop = fn (tok: Token) -> Option<BinaryOp> do
  match tok do
    case TkPlus -> return Some(val: OpAdd) case TkMinus -> return Some(val: OpSub)
    case TkStar -> return Some(val: OpMul) case TkSlash -> return Some(val: OpDiv)
    case TkPercent -> return Some(val: OpMod)
    case TkPlusDot -> return Some(val: OpFAdd) case TkMinusDot -> return Some(val: OpFSub)
    case TkStarDot -> return Some(val: OpFMul) case TkSlashDot -> return Some(val: OpFDiv)
    case TkEqEq -> return Some(val: OpEq) case TkBangEq -> return Some(val: OpNe)
    case TkLt -> return Some(val: OpLt) case TkGt -> return Some(val: OpGt)
    case TkLe -> return Some(val: OpLe) case TkGe -> return Some(val: OpGe)
    case TkEqEqDot -> return Some(val: OpFEq) case TkBangEqDot -> return Some(val: OpFNe)
    case TkLtDot -> return Some(val: OpFLt) case TkGtDot -> return Some(val: OpFGt)
    case TkLeDot -> return Some(val: OpFLe) case TkGeDot -> return Some(val: OpFGe)
    case TkPlusPlus -> return Some(val: OpConcat)
    case TkAndAnd -> return Some(val: OpAnd) case TkPipePipe -> return Some(val: OpOr)
    case TkAmpersand -> return Some(val: OpBitAnd)
    case TkPipe -> return Some(val: OpBitOr)
    case TkCaret -> return Some(val: OpBitXor)
    case TkShl -> return Some(val: OpShl)
    case TkShr -> return Some(val: OpShr)
    case _ -> return None
  end
end
