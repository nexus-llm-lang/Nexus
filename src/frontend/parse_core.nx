/**
 * parse_core: Parser utility types and helper functions for the Nexus self-hosting compiler.
 *
 * Contains result/parsed types, token helpers, binop tables, and arrow type lookahead.
 * Extracted from the monolithic parser.nx into a reusable module.
 */

import { Token, Span, SpannedToken } from "src/common/token.nx"
import { Sigil, BinaryOp, TypeExpr, SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel, Param, HandlerArm, MatchCase, CatchArm, CallArg, CtorArg, NamedExpr, NamedType, VariantField, CtorPatternField, RecordPatField, VariantDef, FunctionSig, ImportItem } from "src/common/ast.nx"
import { UnexpectedToken, ParseError } from "src/common/error.nx"

//
// Each Parsed* record bundles a parsed AST fragment with the unconsumed token
// tail (`rest`). The parser is a no-backtracking recursive-descent over a
// token list, so every helper returns its product paired with `rest`, and
// callers thread `rest` into the next helper without mutable state.

/** Parse result: a single type expression plus the unconsumed token tail. */
export type ParsedType = ParsedType(typ: TypeExpr, rest: [SpannedToken])
/** Parse result: a single expression plus the unconsumed token tail. */
export type ParsedExpr = ParsedExpr(expr: SpannedExpr, rest: [SpannedToken])
/** Parse result: a single statement plus the unconsumed token tail. */
export type ParsedStmt = ParsedStmt(stmt: SpannedStmt, rest: [SpannedToken])
/** Parse result: a single pattern plus the unconsumed token tail. */
export type ParsedPat = ParsedPat(pat: SpannedPattern, rest: [SpannedToken])
/** Parse result: an identifier (possibly dotted/joined) plus the unconsumed token tail. */
export type ParsedIdent = ParsedIdent(name: string, rest: [SpannedToken])
/** Parse result: a sigil (`~`/`%`/`&`/`@`/none) plus the unconsumed token tail. */
export type ParsedSigil = ParsedSigil(sigil: Sigil, rest: [SpannedToken])
/** Parse result: a statement sequence plus the unconsumed token tail. */
export type ParsedStmts = ParsedStmts(stmts: [SpannedStmt], rest: [SpannedToken])
/** Parse result: a call-site argument list (named + positional) plus the unconsumed token tail. */
export type ParsedCallArgs = ParsedCallArgs(args: [CallArg], rest: [SpannedToken])
/** Parse result: a constructor-application argument list plus the unconsumed token tail. */
export type ParsedCtorArgs = ParsedCtorArgs(args: [CtorArg], rest: [SpannedToken])
/** Parse result: a function-definition parameter list plus the unconsumed token tail. */
export type ParsedParams = ParsedParams(params: [Param], rest: [SpannedToken])
/** Parse result: a `match` arm list plus the unconsumed token tail. */
export type ParsedMatchCases = ParsedMatchCases(cases: [MatchCase], rest: [SpannedToken])
/** Parse result: a list of `name: Type` fields (record / arrow params) plus the unconsumed token tail. */
export type ParsedNamedTypes = ParsedNamedTypes(fields: [NamedType], rest: [SpannedToken])
/** Parse result: a positional type list plus the unconsumed token tail. */
export type ParsedTypes = ParsedTypes(types: [TypeExpr], rest: [SpannedToken])
/** Parse result: an enum's variant list plus the unconsumed token tail. */
export type ParsedVariants = ParsedVariants(variants: [VariantDef], rest: [SpannedToken])
/** Parse result: a single variant's field list plus the unconsumed token tail. */
export type ParsedVariantFields = ParsedVariantFields(fields: [VariantField], rest: [SpannedToken])
/** Parse result: a handler's arm list plus the unconsumed token tail. */
export type ParsedHandlerArms = ParsedHandlerArms(arms: [HandlerArm], rest: [SpannedToken])
/** Parse result: a cap's function-signature list plus the unconsumed token tail. */
export type ParsedFunctionSigs = ParsedFunctionSigs(sigs: [FunctionSig], rest: [SpannedToken])
/** Parse result: a positional expression list plus the unconsumed token tail. */
export type ParsedExprs = ParsedExprs(exprs: [SpannedExpr], rest: [SpannedToken])
/** Parse result: a list of `name: expr` record-construction fields plus the unconsumed token tail. */
export type ParsedNamedExprs = ParsedNamedExprs(fields: [NamedExpr], rest: [SpannedToken])
/** Parse result: a constructor-pattern field list plus the unconsumed token tail. */
export type ParsedCtorPatFields = ParsedCtorPatFields(fields: [CtorPatternField], rest: [SpannedToken])
/** Parse result: a record-pattern field list plus a `has_wildcard` flag (set by trailing `..`) plus the unconsumed token tail. */
export type ParsedRecordPatFields = ParsedRecordPatFields(fields: [RecordPatField], has_wildcard: bool, rest: [SpannedToken])
/** Parse result: a string list (e.g. type-parameter names, group members) plus the unconsumed token tail. */
export type ParsedStrings = ParsedStrings(items: [string], rest: [SpannedToken])
/** Parse result: an `import { ... }` item list plus the unconsumed token tail. */
export type ParsedImportItems = ParsedImportItems(items: [ImportItem], rest: [SpannedToken])
/** Parse result: a `catch` arm list plus the unconsumed token tail. */
export type ParsedCatchArms = ParsedCatchArms(arms: [CatchArm], rest: [SpannedToken])
/** Parse result: a single top-level definition plus the unconsumed token tail. */
export type ParsedTopLevel = ParsedTopLevel(item: SpannedTopLevel, rest: [SpannedToken])

/** Return the head token of `toks`, or `TkEof` on the empty list — non-throwing peek so callers don't need a separate emptiness check. */
export let peek_token = fn (toks: [SpannedToken]) -> Token do
  match toks do
    | SpannedToken(token: tk, span: _) :: _ -> tk
    | [] -> TkEof
  end
end

/** Return the span of the head token of `toks`, or a zero span on the empty list — used to anchor diagnostics at the failure site.
 *  The zero span `Span(0, 0, 0)` is the conventional EOF sentinel: it signals "past end of input" to
 *  downstream error renderers. This is intentional and not a missing-span bug.
 */
export let peek_span = fn (toks: [SpannedToken]) -> Span do
  match toks do
    | SpannedToken(token: _, span: sp) :: _ -> sp
    | [] -> Span(offset: 0, line: 0, col: 0) // EOF sentinel — intentional zero span
  end
end

/** Drop the head token of `toks`, or return the list unchanged when empty — paired with `peek_token` for the standard consume-after-checking idiom. */
export let skip = fn (toks: [SpannedToken]) -> [SpannedToken] do
  match toks do
    | _ :: r -> r
    | [] -> toks
  end
end

/** Recognise tokens that may start a top-level declaration: import / pub
 *  (export) / type / opaque / let / exception / cap / external. Used by
 *  the multi-error parse loop to resynchronise after a per-decl parse
 * failure.
 */
export let is_top_level_start_token = fn (tok: Token) -> bool do
  match tok do
    | TkImport | TkPub | TkType | TkOpaque | TkLet
    | TkException | TkCap | TkExternal -> return true
    | _ -> return false
  end
end

/** Advance `toks` until the head is a top-level-start token at column 1
 *  (i.e. the leftmost column, where every well-formed decl begins) or
 *  until EOF. Used by the parser's multi-error recovery loop: after a
 *  failed decl parse, drop tokens that are presumed to belong to the
 *  broken decl's tail and resume from the next plausible decl boundary.
 *  `started` guards against an infinite loop on the very first call by
 *  forcing at least one token to be consumed when the current head is
 *  itself a top-level keyword at col 1 (otherwise the loop would return
 *  immediately and the caller would re-enter the same failed parse).
 */
export let recover_to_top_level = fn (toks: [SpannedToken], started: bool) -> [SpannedToken] do
  match toks do
    | [] -> return toks
    | SpannedToken(token: tk, span: Span(offset: _, line: _, col: c)) :: rest ->
      match tk do
        | TkEof -> return toks
        | _ ->
          if started && c == 1 && is_top_level_start_token(tok: tk) then
            return toks
          end
          return recover_to_top_level(toks: rest, started: true)
      end
  end
end

/** Render a token as its canonical surface-syntax tag (e.g. `TkPlus -> "+"`, `TkIdent(_) -> "ident"`); used for diagnostic `expected: ... got: ...` messages and as the comparison key in `is_tok` / `expect`. */
export let token_tag = fn (tok: Token) -> string do
  match tok do
    | TkLet -> "let" | TkFn -> "fn" | TkDo -> "do" | TkEnd -> "end"
    | TkIf -> "if" | TkThen -> "then" | TkElse -> "else"
    | TkMatch -> "match"
    | TkWhile -> "while" | TkFor -> "for" | TkTo -> "to"
    | TkReturn -> "return" | TkImport -> "import" | TkFrom -> "from"
    | TkAs -> "as" | TkExternal -> "external" | TkPub -> "export"
    | TkOpaque -> "opaque" | TkType -> "type" | TkCap -> "cap"
    | TkHandler -> "handler" | TkInject -> "inject"
    | TkTry -> "try" | TkCatch -> "catch" | TkThrow -> "throw"
    | TkRequire -> "require" | TkThrows -> "throws"
    | TkException -> "exception" | TkRef -> "ref" | TkWith -> "with"
    | TkPlus -> "+" | TkMinus -> "-" | TkStar -> "*" | TkSlash -> "/"
    | TkPlusPlus -> "++" | TkPlusDot -> "+." | TkMinusDot -> "-."
    | TkStarDot -> "*." | TkSlashDot -> "/."
    | TkEqEq -> "==" | TkBangEq -> "!=" | TkLt -> "<" | TkGt -> ">"
    | TkLe -> "<=" | TkGe -> ">="
    | TkEqEqDot -> "==." | TkBangEqDot -> "!=." | TkLtDot -> "<."
    | TkGtDot -> ">." | TkLeDot -> "<=." | TkGeDot -> ">=."
    | TkAndAnd -> "&&" | TkPipePipe -> "||" | TkShl -> "<<" | TkShr -> ">>"
    | TkArrow -> "->" | TkLArrow -> "<-" | TkEq -> "=" | TkPipe -> "|" | TkBang -> "!"
    | TkLParen -> "(" | TkRParen -> ")" | TkLBrace -> "{" | TkRBrace -> "}"
    | TkLBracket -> "[" | TkRBracket -> "]" | TkLArray -> "[|" | TkRArray -> "|]"
    | TkComma -> "," | TkDot -> "." | TkColon -> ":" | TkColonColon -> "::"
    | TkTilde -> "~" | TkPercent -> "%" | TkAmpersand -> "&" | TkAt -> "@" | TkCaret -> "^"
    | TkTrue -> "true" | TkFalse -> "false" | TkUnit -> "()"
    | TkInt(_) -> "int" | TkFloat(_) -> "float" | TkChar(_) -> "char"
    | TkString(_) -> "string_lit" | TkIdent(_) -> "ident"
    | TkUident(_) -> "uident" | TkImportPath(_) -> "import_path"
    | TkError(msg: m) -> m
    | TkEof -> "eof"
  end
end

/** Non-throwing check: does the head token's `token_tag` match `expected`? Use to branch without committing — pair with `expect` when consumption is required. */
export let is_tok = fn (toks: [SpannedToken], expected: string) -> bool do
  return token_tag(tok: peek_token(toks)) == expected
end

/** Consume the head token if its `token_tag` matches `expected`; otherwise throw `UnexpectedToken` with the head's span so the caller surfaces a precise diagnostic. */
export let expect = fn (toks: [SpannedToken], expected: string) -> [SpannedToken] throws { ParseError } do
  if token_tag(tok: peek_token(toks)) == expected then return skip(toks)
  else
    throw UnexpectedToken(expected, got: token_tag(tok: peek_token(toks)), span: peek_span(toks))
  end
end

/** Consume the head token as a `TkIdent` (lowercase identifier) or throw `UnexpectedToken`; the parser uses this wherever a value-level name is mandatory (params, fields, etc.). */
export let expect_ident = fn (toks: [SpannedToken]) -> ParsedIdent throws { ParseError } do
  if let TkIdent(name: n) = peek_token(toks) then
    return ParsedIdent(name: n, rest: skip(toks))
  else
    throw UnexpectedToken(expected: "identifier", got: token_tag(tok: peek_token(toks)), span: peek_span(toks))
  end
end

/** Consume the head token as a `TkUident` (uppercase identifier) or throw `UnexpectedToken`; the parser uses this wherever a type/constructor name is mandatory (type defs, variants, exceptions). */
export let expect_uident = fn (toks: [SpannedToken]) -> ParsedIdent throws { ParseError } do
  if let TkUident(name: n) = peek_token(toks) then
    return ParsedIdent(name: n, rest: skip(toks))
  else
    throw UnexpectedToken(expected: "uppercase identifier", got: token_tag(tok: peek_token(toks)), span: peek_span(toks))
  end
end

/** Consume an optional leading sigil (`~` mutable, `%` linear, `&` borrow, `@` lazy) or return `SigilImmutable` without consuming when absent; non-throwing so callers branch on the returned sigil. */
export let parse_sigil = fn (toks: [SpannedToken]) -> ParsedSigil do
  match peek_token(toks) do
    | TkTilde -> return ParsedSigil(sigil: SigilMutable, rest: skip(toks))
    | TkPercent -> return ParsedSigil(sigil: SigilLinear, rest: skip(toks))
    | TkAmpersand -> return ParsedSigil(sigil: SigilBorrow, rest: skip(toks))
    | TkAt -> return ParsedSigil(sigil: SigilLazy, rest: skip(toks))
    | _ -> return ParsedSigil(sigil: SigilImmutable, rest: toks)
  end
end

/** Check if the next two tokens form a labeled field pattern: `ident : ...` */
export let is_labeled_field = fn (toks: [SpannedToken]) -> bool do
  match peek_token(toks) do
    | TkIdent(_) ->
      match peek_token(toks: skip(toks)) do
        | TkColon -> true
        | _ -> false
      end
    | _ -> false
  end
end

/** True when `tok` is a block-closer that should stop statement/expression-sequence parsing: `end`, `else`, `catch`, `|` (arm separator), or `TkEof`. */
export let is_block_end = fn (tok: Token) -> bool do
  match tok do
    | TkEnd | TkElse | TkCatch | TkEof | TkPipe -> true
    | _ -> false
  end
end

/** Disambiguate a leading `|` (TkPipe) at expression infix position: is it
 *  the start of the next match/catch arm pattern (followed by `->` at depth
 *  0), or the bitwise-or operator? `toks` must be positioned AFTER the `|`.
 *  The scan tracks paren/bracket/brace/array nesting. No fuel cap — the
 *  bounded termination comes from TkEof and the expression-only abort set,
 *  both of which are reached in any finite token stream.
 */
export let pipe_starts_arm = fn (toks: [SpannedToken]) -> bool do
  pipe_scan(toks, depth: 0)
end

let pipe_scan = fn (toks: [SpannedToken], depth: i64) -> bool do
  match peek_token(toks) do
    | TkArrow ->
      if depth <= 0 then return true end
      return pipe_scan(toks: skip(toks), depth)
    | TkLParen | TkLBracket | TkLBrace | TkLArray -> return pipe_scan(toks: skip(toks), depth: depth + 1)
    | TkRParen | TkRBracket | TkRBrace | TkRArray ->
      if depth <= 0 then return false end
      return pipe_scan(toks: skip(toks), depth: depth - 1)
    // TkEof aborts the scan; the remaining tokens cannot appear in a pattern
    // at depth 0 — must be expression continuation, so the `|` was bitwise-or,
    // not an arm separator. `!` only appears as unary prefix in expressions,
    // never in a pattern.
    | TkEof
    // TkMinus is NOT aborted here because `-` can start a negative literal
    // pattern (`| -2.5 -> ...`, `| -42 -> ...`). If the scan encounters `-`
    // and eventually finds `->` at depth 0, the `|` was an arm separator.
    | TkPlus | TkStar | TkSlash | TkPercent | TkPlusPlus
    | TkPlusDot | TkMinusDot | TkStarDot | TkSlashDot
    | TkAmpersand | TkCaret | TkShl | TkShr
    | TkEqEq | TkBangEq | TkLt | TkGt | TkLe | TkGe
    | TkEqEqDot | TkBangEqDot | TkLtDot | TkGtDot | TkLeDot | TkGeDot
    | TkAndAnd | TkPipePipe | TkBang
    | TkLArrow | TkEq
    | TkLet | TkFn | TkDo | TkEnd | TkIf | TkThen | TkElse
    | TkMatch | TkWhile | TkFor | TkTo | TkReturn
    | TkImport | TkFrom | TkAs | TkExternal | TkPub | TkOpaque
    | TkType | TkCap | TkHandler | TkInject | TkTry | TkCatch
    | TkThrow | TkRequire | TkThrows | TkException | TkRef | TkWith -> return false
    // Pattern-friendly tokens (literals, identifiers, ::, |, ., :, comma, @, _)
    | _ -> return pipe_scan(toks: skip(toks), depth)
  end
end

/** Disambiguate arrow types from parenthesized types using 2-token lookahead.
 *  Arrow types always have named parameters: (name: Type, ...) -> RetType
 *  So after '(', if we see 'ident :' it's an arrow; if ')' then check for '->'.
 */
export let is_arrow_start = fn (toks: [SpannedToken]) -> bool do
  let inner = skip(toks)
  match peek_token(toks: inner) do
    | TkRParen ->
      // ( ) -> ... is arrow with empty params (rare: usually lexed as TkUnit)
      match peek_token(toks: skip(toks: inner)) do
        | TkArrow -> true
        | _ -> false
      end
    | TkIdent(_) ->
      // (name: ...) -> ... is arrow type
      match peek_token(toks: skip(toks: inner)) do
        | TkColon -> true
        | _ -> false
      end
    | _ -> false
  end
end

/** Pratt-parser precedence (`1`..`6`) for the binary operator denoted by `tok`, or `-1` when `tok` is not an infix operator; higher numbers bind tighter. Levels: 1 `||`, 2 `&&`, 3 comparisons, 4 additive/bit-or, 5 multiplicative/bit-and, 6 shifts. */
export let get_binop_prec = fn (tok: Token) -> i64 do
  match tok do
    | TkPipePipe -> return 1
    | TkAndAnd -> return 2
    | TkEqEq | TkBangEq | TkLt | TkGt | TkLe | TkGe
    | TkEqEqDot | TkBangEqDot | TkLtDot | TkGtDot | TkLeDot | TkGeDot -> return 3
    | TkPlus | TkMinus | TkPlusPlus | TkPlusDot | TkMinusDot
    | TkPipe | TkCaret -> return 4
    | TkStar | TkSlash | TkPercent | TkStarDot | TkSlashDot | TkAmpersand -> return 5
    | TkShl | TkShr -> return 6
    | _ -> return -1
  end
end

/** Map a Token to its `BinaryOp` AST node, or `None` when `tok` is not an infix operator; paired with `get_binop_prec` in the Pratt loop. */
export let token_to_binop = fn (tok: Token) -> Option<BinaryOp> do
  match tok do
    | TkPlus -> return Some(val: OpAdd) | TkMinus -> return Some(val: OpSub)
    | TkStar -> return Some(val: OpMul) | TkSlash -> return Some(val: OpDiv)
    | TkPercent -> return Some(val: OpMod)
    | TkPlusDot -> return Some(val: OpFAdd) | TkMinusDot -> return Some(val: OpFSub)
    | TkStarDot -> return Some(val: OpFMul) | TkSlashDot -> return Some(val: OpFDiv)
    | TkEqEq -> return Some(val: OpEq) | TkBangEq -> return Some(val: OpNe)
    | TkLt -> return Some(val: OpLt) | TkGt -> return Some(val: OpGt)
    | TkLe -> return Some(val: OpLe) | TkGe -> return Some(val: OpGe)
    | TkEqEqDot -> return Some(val: OpFEq) | TkBangEqDot -> return Some(val: OpFNe)
    | TkLtDot -> return Some(val: OpFLt) | TkGtDot -> return Some(val: OpFGt)
    | TkLeDot -> return Some(val: OpFLe) | TkGeDot -> return Some(val: OpFGe)
    | TkPlusPlus -> return Some(val: OpConcat)
    | TkAndAnd -> return Some(val: OpAnd) | TkPipePipe -> return Some(val: OpOr)
    | TkAmpersand -> return Some(val: OpBitAnd)
    | TkPipe -> return Some(val: OpBitOr)
    | TkCaret -> return Some(val: OpBitXor)
    | TkShl -> return Some(val: OpShl)
    | TkShr -> return Some(val: OpShr)
    | _ -> return None
  end
end
