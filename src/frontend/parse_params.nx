/**
 * parse_params: function parameter + type-parameter list parsing.
 *
 * Owns:
 * - parse_fn_params_or_unit (top-level: `()` or `(p1, p2, …)`)
 * - parse_params (helper: parses the comma-separated body)
 * - parse_optional_type_params / parse_type_param_list (`<T, U, …>`)
 *
 * Does not own:
 * - Expression / statement / pattern parsing (see src/frontend/parser.nx)
 * - Type-expression parsing (see src/frontend/parse_type.nx)
 *
 * Exists so parse_topdef.nx (port/lambda-style signatures) and parser.nx
 * (lambdas, top-level function defs) can share param parsing without
 * a cyclic import — every helper here depends only on pcore + ptype.
 */
import { SpannedToken } from "src/common/token.nx"
import { Sigil, Param } from "src/common/ast.nx"
import { UnexpectedToken } from "src/common/error.nx"
import { ParsedType, ParsedIdent, ParsedSigil, ParsedParams, ParsedStrings }, * as pcore from "src/frontend/parse_core.nx"
import * as ptype from "src/frontend/parse_type.nx"
import * as list from "stdlib/list.nx"

export let parse_fn_params_or_unit = fn (toks: [SpannedToken]) -> ParsedParams throws { Exn } do
  if pcore.is_tok(toks: toks, expected: "()") then
    return ParsedParams(params: [], rest: pcore.skip(toks: toks))
  end
  let ParsedParams(params: ps, rest: r2) = parse_params(toks: pcore.expect(toks: toks, expected: "("), acc: [])
  return ParsedParams(params: ps, rest: pcore.expect(toks: r2, expected: ")"))
end

export let parse_params = fn (toks: [SpannedToken], acc: [Param]) -> ParsedParams throws { Exn } do
  match pcore.peek_token(toks: toks) do
    | TkRParen -> return ParsedParams(params: list.reverse(xs: acc), rest: toks)
    | _ ->
      let ParsedSigil(sigil: sig, rest: r) = pcore.parse_sigil(toks: toks)
      let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: r)
      let ParsedType(typ: t, rest: r4) = ptype.parse_type(toks: pcore.expect(toks: r2, expected: ":"))
      let new_acc = Param(name: n, sigil: sig, typ: t) :: acc
      if pcore.is_tok(toks: r4, expected: ",") then
        return parse_params(toks: pcore.skip(toks: r4), acc: new_acc)
      else
        return ParsedParams(params: list.reverse(xs: new_acc), rest: r4)
      end
  end
end

export let parse_optional_type_params = fn (toks: [SpannedToken]) -> ParsedStrings throws { Exn } do
  match pcore.peek_token(toks: toks) do
    | TkLt ->
      let ParsedStrings(items: ps, rest: r2) = parse_type_param_list(toks: pcore.skip(toks: toks), acc: [])
      match pcore.peek_token(toks: r2) do
        | TkGt -> return ParsedStrings(items: ps, rest: pcore.skip(toks: r2))
        | _ -> return ParsedStrings(items: [], rest: toks)
      end
    | _ -> return ParsedStrings(items: [], rest: toks)
  end
end

export let parse_type_param_list = fn (toks: [SpannedToken], acc: [string]) -> ParsedStrings throws { Exn } do
  match pcore.peek_token(toks: toks) do
    | TkGt -> return ParsedStrings(items: list.reverse(xs: acc), rest: toks)
    | TkUident(name: n) ->
      let r = pcore.skip(toks: toks)
      if pcore.is_tok(toks: r, expected: ",") then
        return parse_type_param_list(toks: pcore.skip(toks: r), acc: n :: acc)
      else
        return ParsedStrings(items: list.reverse(xs: n :: acc), rest: r)
      end
    | _ ->
      raise UnexpectedToken(expected: "type parameter", got: pcore.token_tag(tok: pcore.peek_token(toks: toks)), span: pcore.peek_span(toks: toks))
  end
end
