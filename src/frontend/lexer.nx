/**
 * lexer: Tokenizer for Nexus source code.
 *
 * Uses byte-level scanning primitives (byte_at, scan_ident, scan_digits, etc.)
 * for O(1) character access instead of O(n) char_at. Bulk scan functions reduce
 * FFI crossings from O(chars) to O(tokens).
 */

import * as str from "std:str"
import * as list from "std:list"
import * as char from "std:char"
import { Token, Span, SpannedToken }, * as token from "src/common/token.nx"
import { SourcePos } from "src/common/source_pos.nx"

let ch_tab       = '\t'
let ch_newline   = '\n'
let ch_space     = ' '
let ch_bang      = '!'
let ch_dquote    = '"'
let ch_percent   = '%'
let ch_ampersand = '&'
let ch_at        = '@'
let ch_lparen    = '('
let ch_rparen    = ')'
let ch_star      = '*'
let ch_plus      = '+'
let ch_comma     = ','
let ch_minus     = '-'
let ch_dot       = '.'
let ch_slash     = '/'
let ch_colon     = ':'
let ch_lt        = '<'
let ch_eq        = '='
let ch_gt        = '>'
let ch_lbracket  = '['
let ch_backslash = '\\'
let ch_rbracket  = ']'
let ch_lbrace    = '{'
let ch_pipe      = '|'
let ch_rbrace    = '}'
let ch_caret     = '^'
let ch_tilde     = '~'
let ch_underscore = '_'
let ch_squote    = '\''
let ch_eof       = '\0'

type LexerState = LexerState(src: string, sp: SourcePos, len: i64)

let make_lexer = fn (src: string) -> LexerState do
  return LexerState(src, sp: SourcePos(pos: 0, line: 1, col: 1), len: str.byte_length(s: src))
end

let peek = fn (st: LexerState) -> char do
  let LexerState(src: s, sp: SourcePos(pos: p, line: _, col: _), len: l) = st
  if p >= l then return ch_eof end
  return str.byte_at(s, idx: p)
end

let peek_at = fn (st: LexerState, offset: i64) -> char do
  let LexerState(src: s, sp: SourcePos(pos: p, line: _, col: _), len: l) = st
  let idx = p + offset
  if idx >= l then return ch_eof end
  return str.byte_at(s, idx)
end

// UTF-8 sequence length from the lead byte's integer value.
// Continuation bytes (0x80-0xBF) are treated as 1 to avoid stalls.
let utf8_seq_len = fn (b: i64) -> i64 do
  if b < 128 then return 1 end
  if b < 192 then return 1 end
  if b < 224 then return 2 end
  if b < 240 then return 3 end
  return 4
end

// UTF-16 code units for a codepoint whose UTF-8 encoding has `seq` bytes.
// 4-byte sequences (U+10000 and above) encode as surrogate pairs (2 units);
// all others are 1 unit.
let utf16_units = fn (seq: i64) -> i64 do
  if seq == 4 then return 2 end
  return 1
end

// advance() skips one Unicode codepoint (full UTF-8 sequence) and tracks
// the column in UTF-16 code units, matching LSP convention.
let advance = fn (st: LexerState) -> LexerState do
  let LexerState(src: s, sp: SourcePos(pos: p, line: ln, col: c), len: l) = st
  if p >= l then return st end
  if str.byte_at(s, idx: p) == ch_newline then
    return LexerState(src: s, sp: SourcePos(pos: p + 1, line: ln + 1, col: 1), len: l)
  end
  let b = char.ord(c: str.byte_at(s, idx: p))
  let seq = utf8_seq_len(b)
  let units = utf16_units(seq)
  return LexerState(src: s, sp: SourcePos(pos: p + seq, line: ln, col: c + units), len: l)
end

let advance_n = fn (st: LexerState, n: i64) -> LexerState do
  if n <= 0 then return st end
  return advance_n(st: advance(st), n: n - 1)
end

let at_end = fn (st: LexerState) -> bool do
  let LexerState(src: _, sp: SourcePos(pos: p, line: _, col: _), len: l) = st
  return p >= l
end

let current_span = fn (st: LexerState) -> Span do
  let LexerState(src: _, sp: SourcePos(pos: p, line: ln, col: c), len: _) = st
  return Span(offset: p, line: ln, col: c)
end

let slice = fn (st: LexerState, start: i64, length: i64) -> string do
  let LexerState(src: s, sp: _, len: _) = st
  return str.byte_substring(s, start, len: length)
end

// Update LexerState after jumping from current pos to new_pos,
// correctly tracking line/col by counting newlines in the skipped range.
let update_state_bulk = fn (st: LexerState, new_pos: i64) -> LexerState do
  let LexerState(src: s, sp: SourcePos(pos: old_pos, line: ln, col: c), len: l) = st
  if new_pos == old_pos then return st end
  let nl_count = str.count_newlines_in(s, start: old_pos, end_pos: new_pos)
  if nl_count > 0 then
    let last_nl = str.last_newline_in(s, start: old_pos, end_pos: new_pos)
    return LexerState(src: s, sp: SourcePos(pos: new_pos, line: ln + nl_count, col: new_pos - last_nl), len: l)
  else
    return LexerState(src: s, sp: SourcePos(pos: new_pos, line: ln, col: c + (new_pos - old_pos)), len: l)
  end
end

type LexResult = LexResult(st: LexerState, tok: SpannedToken)

let spanned = fn (st: LexerState, token: Token, span: Span) -> LexResult do
  return LexResult(st, tok: SpannedToken(token, span))
end

let skip_line_comment = fn (st: LexerState) -> LexerState do
  let LexerState(src: s, sp: SourcePos(pos: p, line: ln, col: c), len: l) = st
  let nl_pos = str.find_byte(s, start: p, ch: ch_newline)
  if nl_pos < 0 then
    return LexerState(src: s, sp: SourcePos(pos: l, line: ln, col: c + (l - p)), len: l)
  else
    return LexerState(src: s, sp: SourcePos(pos: nl_pos + 1, line: ln + 1, col: 1), len: l)
  end
end

// Result of skip_block_comment: either a clean LexerState or an error token
// for an unterminated block comment (the open span is recorded so the
// diagnostic points at the `/*`).
type BlockCommentScan =
    BlockOk(st: LexerState)
  | BlockErr(st: LexerState, tok: SpannedToken)

let skip_block_comment = fn (st: LexerState, depth: i64, open_span: Span) -> BlockCommentScan do
  if at_end(st) then
    if depth > 0 then
      return BlockErr(st, tok: SpannedToken(token: TkError(msg: "unterminated block comment"), span: open_span))
    end
    return BlockOk(st)
  end
  if depth <= 0 then return BlockOk(st) end
  let c = peek(st)
  let c2 = peek_at(st, offset: 1)
  if c == ch_star && c2 == ch_slash then
    return skip_block_comment(st: advance_n(st, n: 2), depth: depth - 1, open_span)
  end
  if c == ch_slash && c2 == ch_star then
    return skip_block_comment(st: advance_n(st, n: 2), depth: depth + 1, open_span)
  end
  return skip_block_comment(st: advance(st), depth, open_span)
end

// Result of skip_whitespace_and_comments: either a LexerState to continue
// tokenizing from, or an error token (e.g. unterminated block comment) that
// the tokenizer loop should emit before continuing.
type SkipResult =
    SkipOk(st: LexerState)
  | SkipErr(st: LexerState, tok: SpannedToken)

let skip_whitespace_and_comments = fn (st: LexerState) -> SkipResult do
  let LexerState(src: s, sp: SourcePos(pos: p, line: _, col: _), len: l) = st
  if p >= l then return SkipOk(st) end
  let ws_end = str.skip_ws(s, start: p)
  if ws_end > p then
    let st1 = update_state_bulk(st, new_pos: ws_end)
    return skip_whitespace_and_comments(st: st1)
  end
  // Check for comments — use flat if-then chains (codegen miscompiles nested ifs)
  let c = str.byte_at(s, idx: p)
  let c2 = str.byte_at(s, idx: p + 1)
  if c == ch_slash && c2 == ch_slash then
    return skip_whitespace_and_comments(st: skip_line_comment(st))
  end
  if c == ch_slash && c2 == ch_star then
    let open_span = current_span(st)
    let st2 = advance_n(st, n: 2)
    match skip_block_comment(st: st2, depth: 1, open_span) do
      | BlockOk(st: st3) -> return skip_whitespace_and_comments(st: st3)
      | BlockErr(st: st3, tok) -> return SkipErr(st: st3, tok)
    end
  end
  return SkipOk(st)
end

//
// MVP: capture a leading `/**. */` block comment as the
// module-level doc string. The lexer's normal comment skipping discards
// comments wholesale, so we re-scan the prefix here and return the raw
// content between `/**` and `*/` (no `*` line-stripping; that is deferred
// per the issue's non-goals).
//
// A doc comment must start with `/**` and have a fourth byte that is *not*
// `/` — otherwise `/**/` (empty block comment) would qualify, and the issue
// explicitly excludes that shape.

// scan_to_close_star_slash finds the closing `*/` for a nested block comment,
// respecting nesting depth. Returns the byte offset of the `*` that closes
// the outermost comment, or None if the source is unterminated.
// `depth` must be >= 1 on the initial call (the outer `/*` has already been
// consumed; the scan starts just inside the opening delimiter).
let scan_to_close_star_slash = fn (st: LexerState, depth: i64) -> Option<i64> do
  if at_end(st) then return None end
  let c = peek(st)
  let c2 = peek_at(st, offset: 1)
  if c == ch_star && c2 == ch_slash then
    if depth <= 1 then
      let LexerState(src: _, sp: SourcePos(pos: p, line: _, col: _), len: _) = st
      return Some(val: p)
    end
    return scan_to_close_star_slash(st: advance_n(st, n: 2), depth: depth - 1)
  end
  if c == ch_slash && c2 == ch_star then
    return scan_to_close_star_slash(st: advance_n(st, n: 2), depth: depth + 1)
  end
  return scan_to_close_star_slash(st: advance(st), depth)
end

/** Scan the source prefix for a `/** ... */` block comment and return its
 *  raw inner content (bytes between `/**` and `*/`). Returns None if the
 *  file does not start with a doc-shaped block comment, or if the comment
 *  is unterminated. Only the leading run of whitespace is skipped before
 *  checking — leading `//` line comments and other tokens disqualify the
 *  file from carrying a module-level doc, matching the convention that
 *  the doc is the very first thing in the source.
 */
export let extract_module_doc = fn (src: string) -> Option<string> do
  let len = str.byte_length(s: src)
  let after_ws = str.skip_ws(s: src, start: 0)
  if after_ws + 3 >= len then return None end
  if str.byte_at(s: src, idx: after_ws) != ch_slash then return None end
  if str.byte_at(s: src, idx: after_ws + 1) != ch_star then return None end
  if str.byte_at(s: src, idx: after_ws + 2) != ch_star then return None end
  // Reject `/**/` (empty block comment) — fourth byte must not be `/`.
  if str.byte_at(s: src, idx: after_ws + 3) == ch_slash then return None end
  let body_start = after_ws + 3
  let st = LexerState(src, sp: SourcePos(pos: body_start, line: 1, col: 1), len)
  match scan_to_close_star_slash(st, depth: 1) do
    | None -> return None
    | Some(val: close_pos) ->
      let content = str.byte_substring(s: src, start: body_start, len: close_pos - body_start)
      return Some(val: content)
  end
end

let lex_ident_rest = fn (st: LexerState) -> LexerState do
  let LexerState(src: s, sp: SourcePos(pos: p, line: ln, col: c), len: l) = st
  let end_pos = str.scan_ident(s, start: p)
  return LexerState(src: s, sp: SourcePos(pos: end_pos, line: ln, col: c + (end_pos - p)), len: l)
end

let lex_identifier = fn (st: LexerState, span: Span) -> LexResult do
  let Span(offset: start, line: _, col: _) = span
  let st2 = lex_ident_rest(st)
  let LexerState(src: _, sp: SourcePos(pos: end_pos, line: _, col: _), len: elen) = st2
  let name = slice(st: st2, start, length: end_pos - start)
  match token.keyword_lookup(name) do
    | Some(val: tk) -> return spanned(st: st2, token: tk, span)
    | None -> return spanned(st: st2, token: TkIdent(name), span)
  end
end

let lex_uident = fn (st: LexerState, span: Span) -> LexResult do
  let Span(offset: start, line: _, col: _) = span
  let st2 = lex_ident_rest(st)
  let LexerState(src: _, sp: SourcePos(pos: end_pos, line: _, col: _), len: _) = st2
  let name = slice(st: st2, start, length: end_pos - start)
  return spanned(st: st2, token: TkUident(name), span)
end

let lex_digits = fn (st: LexerState) -> LexerState do
  let LexerState(src: s, sp: SourcePos(pos: p, line: ln, col: c), len: l) = st
  let end_pos = str.scan_digits(s, start: p)
  return LexerState(src: s, sp: SourcePos(pos: end_pos, line: ln, col: c + (end_pos - p)), len: l)
end

// After consuming the mantissa, optionally consume a `[eE][+-]?digits`
// exponent suffix. Requires at least one digit after the optional sign;
// if absent we leave state untouched so a bare `1e` lexes as `1` + `e`.
let lex_exponent_opt = fn (st: LexerState) -> LexerState do
  let c = peek(st)
  if c != 'e' && c != 'E' then return st end
  let after_e = advance(st)
  let sign_c = peek(st: after_e)
  let after_sign = if sign_c == ch_plus || sign_c == ch_minus then advance(st: after_e) else after_e end
  if !char.is_digit(c: peek(st: after_sign)) then return st end
  return lex_digits(st: after_sign)
end

let lex_number = fn (st: LexerState, span: Span) -> LexResult do
  let Span(offset: start, line: _, col: _) = span
  let st2 = lex_digits(st)
  let c = peek(st: st2)
  if c == ch_dot then
    if char.is_digit(c: peek_at(st: st2, offset: 1)) then
      let st3 = lex_digits(st: advance(st: st2))
      let st4 = lex_exponent_opt(st: st3)
      let LexerState(src: _, sp: SourcePos(pos: end_pos, line: _, col: _), len: _) = st4
      let text = slice(st: st4, start, length: end_pos - start)
      return spanned(st: st4, token: TkFloat(val: text), span)
    end
  end
  // Integer mantissa: a following `e`/`E` exponent promotes the literal to
  // a float (e.g. `1e10`); otherwise this is an integer token.
  let st_exp = lex_exponent_opt(st: st2)
  let LexerState(src: _, sp: SourcePos(pos: pos2, line: _, col: _), len: _) = st2
  let LexerState(src: _, sp: SourcePos(pos: end_pos, line: _, col: _), len: _) = st_exp
  if end_pos > pos2 then
    let text = slice(st: st_exp, start, length: end_pos - start)
    return spanned(st: st_exp, token: TkFloat(val: text), span)
  end
  let text = slice(st: st2, start, length: end_pos - start)
  match str.parse_i64(s: text) do
    | Some(val: v) -> return spanned(st: st2, token: TkInt(val: v), span)
    | None -> return spanned(st: st2, token: TkError(msg: "integer literal out of range: " ++ text), span)
  end
end

type HexAccum = LexHexOk(st: LexerState, code: i64) | LexHexErr(st: LexerState, msg: string)

let collect_hex_digits = fn (st: LexerState, code: i64) -> HexAccum do
  if at_end(st) then
    return LexHexErr(st, msg: "unterminated \\u{} escape")
  end
  let c = peek(st)
  if c == ch_rbrace then
    let st2 = advance(st)
    if code > 1114111 then
      return LexHexErr(st: st2, msg: "\\u{} codepoint must be at most U+10FFFF")
    end
    if code >= 55296 && code <= 57343 then
      return LexHexErr(st: st2, msg: "\\u{} codepoint must not be a surrogate (U+D800..U+DFFF)")
    end
    return LexHexOk(st: st2, code)
  end
  let v = char.hex_digit_value(c)
  if v >= 0 then
    return collect_hex_digits(st: advance(st), code: code * 16 + v)
  else
    return LexHexErr(st, msg: "invalid hex digit in \\u{} escape")
  end
end

// Flush bytes in the range [start_pos, current pos) into `acc` using a
// raw byte slice. This preserves non-ASCII UTF-8 sequences verbatim instead
// of re-encoding each byte as a codepoint (which would double-encode and
// break stage1 == stage2 fixed-point —).
let flush_plain = fn (st: LexerState, start_pos: i64, acc: string) -> string do
  let LexerState(src: s, sp: SourcePos(pos: p, line: _, col: _), len: _) = st
  if p <= start_pos then return acc end
  return acc ++ str.byte_substring(s, start: start_pos, len: p - start_pos)
end

let lex_string_body = fn (st: LexerState, start_pos: i64, acc: string) -> LexResult do
  if at_end(st) then
    return spanned(st, token: TkError(msg: "unterminated string"), span: current_span(st))
  end
  let c = peek(st)
  if c == ch_dquote then
    let acc2 = flush_plain(st, start_pos, acc)
    return spanned(st: advance(st), token: TkString(val: acc2), span: current_span(st))
  end
  if c == ch_backslash then
    let acc2 = flush_plain(st, start_pos, acc)
    let LexerState(src: s, sp: SourcePos(pos: p, line: _, col: _), len: _) = st
    let c2 = peek_at(st, offset: 1)
    // Named escapes (each consumes 2 bytes, so next start_pos = p + 2)
    if c2 == 'n' then return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2, acc: acc2 ++ "\n") end
    if c2 == 'r' then return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2, acc: acc2 ++ "\r") end
    if c2 == 't' then return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2, acc: acc2 ++ "\t") end
    if c2 == 'a' then return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2, acc: acc2 ++ str.from_char_code(code: 7)) end
    if c2 == 'b' then return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2, acc: acc2 ++ str.from_char_code(code: 8)) end
    if c2 == 'v' then return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2, acc: acc2 ++ str.from_char_code(code: 11)) end
    if c2 == 'f' then return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2, acc: acc2 ++ str.from_char_code(code: 12)) end
    if c2 == 'e' then return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2, acc: acc2 ++ str.from_char_code(code: 27)) end
    if c2 == ch_backslash then return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2, acc: acc2 ++ "\\") end
    if c2 == ch_dquote then return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2, acc: acc2 ++ "\"") end
    // Unicode escape: \u{NNNN}
    if c2 == 'u' then
      if peek_at(st, offset: 2) == ch_lbrace then
        match collect_hex_digits(st: advance_n(st, n: 3), code: 0) do
          | LexHexOk(st: st3, code) ->
            let LexerState(src: _, sp: SourcePos(pos: np, line: _, col: _), len: _) = st3
            return lex_string_body(st: st3, start_pos: np, acc: acc2 ++ str.from_char_code(code))
          | LexHexErr(st: st3, msg) ->
            return spanned(st: st3, token: TkError(msg), span: current_span(st: st3))
        end
      else
        return spanned(st: advance_n(st, n: 2), token: TkError(msg: "expected '{' after \\u"), span: current_span(st))
      end
    end
    // Hex escape: \xNN (exactly 2 hex digits)
    if c2 == 'x' then
      let h1 = peek_at(st, offset: 2)
      let h2 = peek_at(st, offset: 3)
      let v1 = char.hex_digit_value(c: h1)
      let v2 = char.hex_digit_value(c: h2)
      if v1 >= 0 && v2 >= 0 then
        return lex_string_body(st: advance_n(st, n: 4), start_pos: p + 4, acc: acc2 ++ str.from_char_code(code: v1 * 16 + v2))
      else
        return spanned(st: advance_n(st, n: 2), token: TkError(msg: "\\x requires exactly 2 hex digits"), span: current_span(st))
      end
    end
    // Octal escape: \NNN (1-3 octal digits)
    if c2 >= '0' && c2 <= '7' then
      let d1 = char.digit_value(c: c2)
      let c3 = peek_at(st, offset: 2)
      if c3 >= '0' && c3 <= '7' then
        let d2 = char.digit_value(c: c3)
        let c4 = peek_at(st, offset: 3)
        if c4 >= '0' && c4 <= '7' then
          let d3 = char.digit_value(c: c4)
          return lex_string_body(st: advance_n(st, n: 4), start_pos: p + 4, acc: acc2 ++ str.from_char_code(code: d1 * 64 + d2 * 8 + d3))
        else
          return lex_string_body(st: advance_n(st, n: 3), start_pos: p + 3, acc: acc2 ++ str.from_char_code(code: d1 * 8 + d2))
        end
      else
        return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2, acc: acc2 ++ str.from_char_code(code: d1))
      end
    end
    // Unknown escape: pass through as a 1-byte source slice (preserves raw bytes).
    return lex_string_body(st: advance_n(st, n: 2), start_pos: p + 2,
                           acc: acc2 ++ "\\" ++ str.byte_substring(s, start: p + 1, len: 1))
  end
  // Regular character — just advance, byte will be flushed at next escape/terminator.
  return lex_string_body(st: advance(st), start_pos, acc)
end

let lex_string = fn (st: LexerState, span: Span) -> LexResult do
  let LexerState(src: _, sp: SourcePos(pos: p, line: _, col: _), len: _) = st
  let result = lex_string_body(st, start_pos: p, acc: "")
  match result do
    | LexResult(st: st2, tok: SpannedToken(token: TkString(val: v), _)) ->
      return spanned(st: st2, token: TkString(val: v), span)
    | LexResult(st: st2, tok: t) ->
      return LexResult(st: st2, tok: t)
  end
end

let lex_char_escape = fn (st: LexerState, span: Span, c2: char) -> LexResult do
  if c2 == 'n' then return lex_char_close(st: advance_n(st, n: 2), span, code: 10) end
  if c2 == 'r' then return lex_char_close(st: advance_n(st, n: 2), span, code: 13) end
  if c2 == 't' then return lex_char_close(st: advance_n(st, n: 2), span, code: 9) end
  if c2 == '0' then return lex_char_close(st: advance_n(st, n: 2), span, code: 0) end
  if c2 == 'a' then return lex_char_close(st: advance_n(st, n: 2), span, code: 7) end
  if c2 == 'b' then return lex_char_close(st: advance_n(st, n: 2), span, code: 8) end
  if c2 == 'v' then return lex_char_close(st: advance_n(st, n: 2), span, code: 11) end
  if c2 == 'f' then return lex_char_close(st: advance_n(st, n: 2), span, code: 12) end
  if c2 == 'e' then return lex_char_close(st: advance_n(st, n: 2), span, code: 27) end
  if c2 == ch_backslash then return lex_char_close(st: advance_n(st, n: 2), span, code: 92) end
  if c2 == ch_squote then return lex_char_close(st: advance_n(st, n: 2), span, code: 39) end
  if c2 == 'u' then
    if peek_at(st, offset: 2) == ch_lbrace then
      match collect_hex_digits(st: advance_n(st, n: 3), code: 0) do
        | LexHexOk(st: st3, code: hex_code) ->
          return lex_char_close(st: st3, span, code: hex_code)
        | LexHexErr(st: st3, msg) ->
          return spanned(st: st3, token: TkError(msg), span)
      end
    end
  end
  // Hex escape: \xNN (exactly 2 hex digits)
  if c2 == 'x' then
    let h1 = peek_at(st, offset: 2)
    let h2 = peek_at(st, offset: 3)
    let v1 = char.hex_digit_value(c: h1)
    let v2 = char.hex_digit_value(c: h2)
    if v1 >= 0 && v2 >= 0 then
      return lex_char_close(st: advance_n(st, n: 4), span, code: v1 * 16 + v2)
    else
      return spanned(st: advance_n(st, n: 2), token: TkError(msg: "\\x requires exactly 2 hex digits"), span)
    end
  end
  // Octal escape: \NNN (1-3 octal digits)
  if c2 >= '0' && c2 <= '7' then
    let d1 = char.digit_value(c: c2)
    let c3 = peek_at(st, offset: 2)
    if c3 >= '0' && c3 <= '7' then
      let d2 = char.digit_value(c: c3)
      let c4 = peek_at(st, offset: 3)
      if c4 >= '0' && c4 <= '7' then
        let d3 = char.digit_value(c: c4)
        return lex_char_close(st: advance_n(st, n: 4), span, code: d1 * 64 + d2 * 8 + d3)
      else
        return lex_char_close(st: advance_n(st, n: 3), span, code: d1 * 8 + d2)
      end
    else
      return lex_char_close(st: advance_n(st, n: 2), span, code: d1)
    end
  end
  return spanned(st: advance_n(st, n: 2), token: TkError(msg: "unknown char escape"), span)
end

let lex_char_close = fn (st: LexerState, span: Span, code: i64) -> LexResult do
  if peek(st) == ch_squote then
    return spanned(st: advance(st), token: TkChar(val: code), span)
  end
  return spanned(st, token: TkError(msg: "expected closing ' for char literal"), span)
end

let lex_char_literal = fn (st: LexerState, span: Span) -> LexResult do
  if at_end(st) then
    return spanned(st, token: TkError(msg: "unterminated char literal"), span)
  end
  let c = peek(st)
  if c == ch_backslash then
    return lex_char_escape(st, span, c2: peek_at(st, offset: 1))
  end
  let LexerState(src: s, sp: SourcePos(pos: p, line: _, col: _), len: _) = st
  let code = char.ord(c: str.byte_at(s, idx: p))
  return lex_char_close(st: advance(st), span, code)
end

let lex_bracket_body = fn (st: LexerState, start_pos: i64, acc: string) -> LexResult do
  if at_end(st) then
    return spanned(st, token: TkError(msg: "unterminated bracket string"), span: current_span(st))
  end
  let c = peek(st)
  if c == ch_rbracket then
    if peek_at(st, offset: 1) == ch_eq && peek_at(st, offset: 2) == ch_rbracket then
      let acc2 = flush_plain(st, start_pos, acc)
      return spanned(st: advance_n(st, n: 3), token: TkString(val: acc2), span: current_span(st))
    end
  end
  // Escape: \]=] → literal ]=]
  if c == ch_backslash then
    if peek_at(st, offset: 1) == ch_rbracket && peek_at(st, offset: 2) == ch_eq && peek_at(st, offset: 3) == ch_rbracket then
      let acc2 = flush_plain(st, start_pos, acc)
      let LexerState(src: _, sp: SourcePos(pos: p, line: _, col: _), len: _) = st
      return lex_bracket_body(st: advance_n(st, n: 4), start_pos: p + 4, acc: acc2 ++ "]=]")
    end
  end
  // Regular character — just advance, byte will be flushed at next terminator/escape.
  return lex_bracket_body(st: advance(st), start_pos, acc)
end

let lex_bracket_string = fn (st: LexerState, span: Span) -> LexResult do
  let LexerState(src: _, sp: SourcePos(pos: p, line: _, col: _), len: _) = st
  let result = lex_bracket_body(st, start_pos: p, acc: "")
  match result do
    | LexResult(st: st2, tok: SpannedToken(token: TkString(val: v), span: _)) ->
      return spanned(st: st2, token: TkString(val: v), span)
    | LexResult(st: st2, tok: t) ->
      return LexResult(st: st2, tok: t)
  end
end

let lex_three_char_op = fn (st: LexerState, span: Span, c: char, c2: char, c3: char) -> Option<LexResult> do
  // ==.  !=.  <=.  >=.
  if c == ch_eq && c2 == ch_eq && c3 == ch_dot then
    return Some(val: spanned(st: advance_n(st, n: 3), token: TkEqEqDot, span))
  end
  if c == ch_bang && c2 == ch_eq && c3 == ch_dot then
    return Some(val: spanned(st: advance_n(st, n: 3), token: TkBangEqDot, span))
  end
  if c == ch_lt && c2 == ch_eq && c3 == ch_dot then
    return Some(val: spanned(st: advance_n(st, n: 3), token: TkLeDot, span))
  end
  if c == ch_gt && c2 == ch_eq && c3 == ch_dot then
    return Some(val: spanned(st: advance_n(st, n: 3), token: TkGeDot, span))
  end
  return None
end

let lex_two_char_op = fn (st: LexerState, span: Span, c: char, c2: char) -> Option<LexResult> do
  // ++  +.  -.  ->  *.  /.  <-  &&  ||  ==  !=  <=  >=  <.  >.
  if c == ch_plus && c2 == ch_plus then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkPlusPlus, span))
  end
  if c == ch_plus && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkPlusDot, span))
  end
  if c == ch_minus && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkMinusDot, span))
  end
  if c == ch_minus && c2 == ch_gt then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkArrow, span))
  end
  if c == ch_star && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkStarDot, span))
  end
  if c == ch_slash && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkSlashDot, span))
  end
  if c == ch_lt && c2 == ch_lt then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkShl, span))
  end
  if c == ch_gt && c2 == ch_gt then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkShr, span))
  end
  if c == ch_lt && c2 == ch_minus then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkLArrow, span))
  end
  if c == ch_ampersand && c2 == ch_ampersand then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkAndAnd, span))
  end
  if c == ch_pipe && c2 == ch_pipe then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkPipePipe, span))
  end
  if c == ch_eq && c2 == ch_eq then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkEqEq, span))
  end
  if c == ch_bang && c2 == ch_eq then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkBangEq, span))
  end
  if c == ch_lt && c2 == ch_eq then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkLe, span))
  end
  if c == ch_gt && c2 == ch_eq then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkGe, span))
  end
  if c == ch_lt && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkLtDot, span))
  end
  if c == ch_gt && c2 == ch_dot then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkGtDot, span))
  end
  // [| |]
  if c == ch_lbracket && c2 == ch_pipe then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkLArray, span))
  end
  if c == ch_pipe && c2 == ch_rbracket then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkRArray, span))
  end
  // ()
  if c == ch_lparen && c2 == ch_rparen then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkUnit, span))
  end
  // ::
  if c == ch_colon && c2 == ch_colon then
    return Some(val: spanned(st: advance_n(st, n: 2), token: TkColonColon, span))
  end
  return None
end

let lex_single_char = fn (st: LexerState, span: Span, c: char) -> Option<LexResult> do
  if c == ch_lparen then return Some(val: spanned(st: advance(st), token: TkLParen, span)) end
  if c == ch_rparen then return Some(val: spanned(st: advance(st), token: TkRParen, span)) end
  if c == ch_lbrace then return Some(val: spanned(st: advance(st), token: TkLBrace, span)) end
  if c == ch_rbrace then return Some(val: spanned(st: advance(st), token: TkRBrace, span)) end
  if c == ch_lbracket then return Some(val: spanned(st: advance(st), token: TkLBracket, span)) end
  if c == ch_rbracket then return Some(val: spanned(st: advance(st), token: TkRBracket, span)) end
  if c == ch_comma then return Some(val: spanned(st: advance(st), token: TkComma, span)) end
  if c == ch_dot then return Some(val: spanned(st: advance(st), token: TkDot, span)) end
  if c == ch_colon then return Some(val: spanned(st: advance(st), token: TkColon, span)) end
  if c == ch_eq then return Some(val: spanned(st: advance(st), token: TkEq, span)) end
  if c == ch_plus then return Some(val: spanned(st: advance(st), token: TkPlus, span)) end
  if c == ch_minus then return Some(val: spanned(st: advance(st), token: TkMinus, span)) end
  if c == ch_star then return Some(val: spanned(st: advance(st), token: TkStar, span)) end
  if c == ch_slash then return Some(val: spanned(st: advance(st), token: TkSlash, span)) end
  if c == ch_lt then return Some(val: spanned(st: advance(st), token: TkLt, span)) end
  if c == ch_gt then return Some(val: spanned(st: advance(st), token: TkGt, span)) end
  if c == ch_pipe then return Some(val: spanned(st: advance(st), token: TkPipe, span)) end
  if c == ch_tilde then return Some(val: spanned(st: advance(st), token: TkTilde, span)) end
  if c == ch_percent then return Some(val: spanned(st: advance(st), token: TkPercent, span)) end
  if c == ch_ampersand then return Some(val: spanned(st: advance(st), token: TkAmpersand, span)) end
  if c == ch_at then return Some(val: spanned(st: advance(st), token: TkAt, span)) end
  if c == ch_caret then return Some(val: spanned(st: advance(st), token: TkCaret, span)) end
  if c == ch_bang then return Some(val: spanned(st: advance(st), token: TkBang, span)) end
  return None
end

let lex_token = fn (st: LexerState) -> LexResult do
  let st0 = match skip_whitespace_and_comments(st) do
    | SkipErr(st: st_err, tok) -> return LexResult(st: st_err, tok)
    | SkipOk(st: st0) -> st0
  end
  if at_end(st: st0) then
    return spanned(st: st0, token: TkEof, span: current_span(st: st0))
  end

  let span = current_span(st: st0)
  let c = peek(st: st0)
  let c2 = peek_at(st: st0, offset: 1)

  // Identifier or keyword
  if char.is_lower(c) || c == ch_underscore then
    return lex_identifier(st: advance(st: st0), span)
  end

  // Uppercase identifier
  if char.is_upper(c) then
    return lex_uident(st: advance(st: st0), span)
  end

  // Number (digit only — `-INT` is parsed as unary in the parser).
  if char.is_digit(c) then
    return lex_number(st: advance(st: st0), span)
  end

  // String literal
  if c == ch_dquote then
    return lex_string(st: advance(st: st0), span)
  end

  // Char literal
  if c == ch_squote then
    return lex_char_literal(st: advance(st: st0), span)
  end

  // Bracket string [=[
  if c == ch_lbracket && c2 == ch_eq && peek_at(st: st0, offset: 2) == ch_lbracket then
    return lex_bracket_string(st: advance_n(st: st0, n: 3), span)
  end

  // Three-char operators (must check before two-char)
  let c3 = peek_at(st: st0, offset: 2)
  match lex_three_char_op(st: st0, span, c, c2, c3) do
    | Some(val: result) -> return result
    | None -> ()
  end

  // Two-char operators
  match lex_two_char_op(st: st0, span, c, c2) do
    | Some(val: result) -> return result
    | None -> ()
  end

  // Single-char tokens
  match lex_single_char(st: st0, span, c) do
    | Some(val: result) -> return result
    | None -> ()
  end

  // Unknown character → error token, skip and continue
  return spanned(st: advance(st: st0), token: TkError(msg: "unexpected character: " ++ str.from_char(c)), span)
end

// SpannedToken reverse (see src/common/mono_reverse.nx)
// Accumulator-based tokenizer (tail-recursive to avoid stack overflow on large files)
let tokenize_loop = fn (st: LexerState, acc: [ SpannedToken ]) -> [ SpannedToken ] do
  let st1 = match skip_whitespace_and_comments(st) do
    | SkipErr(st: st_err, tok) ->
      return tokenize_loop(st: st_err, acc: tok :: acc)
    | SkipOk(st: st_ok) -> st_ok
  end
  if at_end(st: st1) then
    return list.reverse(xs: SpannedToken(token: TkEof, span: current_span(st: st1)) :: acc)
  end
  let result = lex_token(st: st1)
  let LexResult(st: next, tok) = result
  return tokenize_loop(st: next, acc: tok :: acc)
end

/** Tokenize a source string into a list of SpannedTokens (ending with TkEof). */
export let tokenize = fn (src: string) -> [ SpannedToken ] do
  return tokenize_loop(st: make_lexer(src), acc: [])
end
