/**
 * parse_names: dotted-name parsing + classification helpers.
 *
 * Owns:
 * - parse_dotted_segments / parse_dotted_name (eager O(n) dotted-path parse)
 * - parse_handler_dotted (recursive dotted parse for inject handlers)
 * - dotted_name_ends_upper / dotted_name_last_dot (classification)
 *
 * Does not own:
 * - The expression/statement callers in parser.nx (parse_ident_expr,
 *   parse_constructor_expr, parse_inject_handlers) — they import from here.
 *
 * Exists so parser.nx doesn't carry these string-utility leaves that have
 * no connection to the expr/stmt mutual recursion.
 */
import { SpannedToken } from "src/common/token.nx"
import { UnexpectedToken } from "src/common/error.nx"
import { ParsedIdent }, * as pcore from "src/frontend/parse_core.nx"
import * as list from "std:list"
import * as str from "std:string_ops"

// Accumulate dotted name segments in a reversed list, then join at the end.
// This avoids O(n²) string concatenation on deep dotted paths.
export let parse_dotted_segments = fn (toks: [SpannedToken], acc: [string]) -> ParsedIdent throws { Exn } do
  match pcore.peek_token(toks: toks) do
    | TkDot ->
      let r = pcore.skip(toks: toks)
      match pcore.peek_token(toks: r) do
        | TkIdent(name: n) -> return parse_dotted_segments(toks: pcore.skip(toks: r), acc: n :: acc)
        | TkUident(name: n) -> return ParsedIdent(name: str.join(xs: list.reverse(xs: n :: acc), sep: "."), rest: pcore.skip(toks: r))
        | _ -> return ParsedIdent(name: str.join(xs: list.reverse(xs: acc), sep: "."), rest: toks)
      end
    | _ -> return ParsedIdent(name: str.join(xs: list.reverse(xs: acc), sep: "."), rest: toks)
  end
end

export let parse_dotted_name = fn (toks: [SpannedToken], prefix: string) -> ParsedIdent throws { Exn } do
  return parse_dotted_segments(toks: toks, acc: prefix :: [])
end

/// Check if last segment of a dotted name starts with uppercase (A-Z).
export let dotted_name_ends_upper = fn (name: string) -> bool do
  let len = str.length(s: name)
  let idx = dotted_name_last_dot(name: name, i: len - 1)
  let ch = str.char_code(s: name, idx: idx + 1)
  return ch >= 65 && ch <= 90
end

let dotted_name_last_dot = fn (name: string, i: i64) -> i64 do
  if i < 0 then return -1 end
  if str.char_code(s: name, idx: i) == 46 then return i end
  return dotted_name_last_dot(name: name, i: i - 1)
end

export let parse_handler_dotted = fn (toks: [SpannedToken]) -> ParsedIdent throws { Exn } do
  match pcore.peek_token(toks: toks) do
    | TkIdent(name: name) ->
      let r1 = pcore.skip(toks: toks)
      match pcore.peek_token(toks: r1) do
        | TkDot ->
          let ParsedIdent(name: rest_name, rest: r2) = parse_handler_dotted(toks: pcore.skip(toks: r1))
          return ParsedIdent(name: name ++ "." ++ rest_name, rest: r2)
        | _ -> return ParsedIdent(name: name, rest: r1)
      end
    | _ -> raise UnexpectedToken(expected: "handler name", got: pcore.token_tag(tok: pcore.peek_token(toks: toks)), span: pcore.peek_span(toks: toks))
  end
end
