/**
 * frontend/errors: Parse-phase exception types.
 *
 * Covers exceptions raised exclusively by the frontend parsing layer.
 * All are E1xxx codes in `format_error`.
 */

import { Span } from "src/syntax/token.nx"

/** Raised during parsing when a function declaration or `fn` expression
 *  has two parameters with the same label. Enforces the implicit
 *  distinct-labels premise on parameter lists.
 */
export exception DuplicateParamLabel(name: string, span: Span)
