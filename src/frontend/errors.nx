/**
 * frontend/errors: Parse-phase exception types.
 *
 * Covers exceptions raised exclusively by the frontend parsing layer.
 * All are E1xxx codes in `format_error`.
 */

import { Span } from "src/types/span.nx"

/** Raised during parsing when a function declaration or `fn` expression
 *  has two parameters with the same label. Enforces the implicit
 *  distinct-labels premise on parameter lists.
 */
export exception DuplicateParamLabel(name: string, span: Span)

/** Raised during parsing when a lazy/continuation reference `@x` is
 *  immediately followed by a call argument list — i.e. the `@k(v)`
 *  resume-with-value syntax. The continuation captured by a `with @k`
 *  handler arm can only be resumed with unit (`@k`); there is no value
 *  channel back into the suspended cap call, so `@k(v)` would silently
 *  drop `v` and resume with unit. Reject it at parse time with a clear
 *  diagnostic instead of accepting a misleading no-op.
 */
export exception ResumeWithValueUnsupported(span: Span)
