/**
 * parse_args: Argument-list and punning helpers for the Nexus parser.
 *
 * Owns:
 * - MaybePunArg / try_pun_arg_with_closer / try_pun_call_arg
 *   (sigil-aware argument punning: `f(%v)` etc.)
 * - ctor_pat_lookahead (lookahead helper for constructor-pattern heads
 *   in `let`-destructures — only calls pcore token primitives)
 * - parse_optional_with_kont (handler-arm `with @ Ident` clause)
 *
 * Does not own:
 * - resolve_one_arg / parse_fn_call_args / parse_ctor_call_args
 *   (stay in parser.nx because they call parse_expr)
 * - parse_record_expr_fields (stays in parser.nx, calls parse_expr)
 *
 * Exists because all of the above only depend on pcore token primitives
 * and ast constructors — no dependency on parse_expr or parse_stmts —
 * so they can be lifted out of the mutual-recursion core in parser.nx.
 */

import { Span, SpannedToken } from "src/syntax/token.nx"
import { Sigil, SpannedExpr, Unqual } from "src/syntax/ast.nx"
import { ParseError } from "src/diagnostics/error.nx"
import { ParsedIdent }, * as pcore from "src/frontend/parse_core.nx"

// Sigil-aware punning: `f(%v)` desugars to `f(%v)`, `f(&v)` to
// `f(&v)`, etc. Returns Some(name, expr, rest) when the head of
// `toks` matches a punning shape, None otherwise. `closer` is the
// closing delimiter that, together with `,`, terminates the argument
// (`)` for call/ctor, `}` for record literals).
export type MaybePunArg =
  PunArgYes(name: string, value: SpannedExpr, rest: [ SpannedToken ])
  | PunArgNo

export let try_pun_arg_with_closer = fn (toks: [ SpannedToken ], closer: string) -> MaybePunArg do
  let sp = pcore.peek_span(toks)

  if let TkIdent(name: n) = pcore.peek_token(toks) then
    let r1 = pcore.skip(toks)
    if pcore.is_tok(toks: r1, expected: ",") || pcore.is_tok(toks: r1, expected: closer) then
      return PunArgYes(
        name: n,
        value: SpannedExpr(
          node: ExprVariable(name: Unqual(name: n), sigil: SigilImmutable),
          span: sp
        ),
        rest: r1
      )
    end
    return PunArgNo
  end

  let leading = match pcore.peek_token(toks) do
    | TkPercent -> SigilLinear
    | TkTilde -> SigilMutable
    | TkAt -> SigilLazy
    | _ -> SigilImmutable
  end
  let is_unary_sigil = match pcore.peek_token(toks) do
    | TkPercent | TkTilde | TkAt -> true | _ -> false
  end
  if is_unary_sigil then
    let r1 = pcore.skip(toks)
    if let TkIdent(name: n) = pcore.peek_token(toks: r1) then
      let r2 = pcore.skip(toks: r1)
      if pcore.is_tok(toks: r2, expected: ",") || pcore.is_tok(toks: r2, expected: closer) then
        return PunArgYes(
          name: n,
          value: SpannedExpr(node: ExprVariable(name: Unqual(name: n), sigil: leading), span: sp),
          rest: r2
        )
      end
    end
    return PunArgNo
  end

  if pcore.is_tok(toks, expected: "&") then
    let r1 = pcore.skip(toks)
    let inner = match pcore.peek_token(toks: r1) do
      | TkPercent -> SigilLinear
      | TkTilde -> SigilMutable
      | TkAt -> SigilLazy
      | _ -> SigilImmutable
    end
    let has_inner = match pcore.peek_token(toks: r1) do
      | TkPercent | TkTilde | TkAt -> true | _ -> false
    end
    let r2 = if has_inner then pcore.skip(toks: r1) else r1 end
    if let TkIdent(name: n) = pcore.peek_token(toks: r2) then
      let r3 = pcore.skip(toks: r2)
      if pcore.is_tok(toks: r3, expected: ",") || pcore.is_tok(toks: r3, expected: closer) then
        return PunArgYes(
          name: n,
          value: SpannedExpr(node: ExprBorrow(name: n, sigil: inner), span: sp),
          rest: r3
        )
      end
    end
    return PunArgNo
  end

  return PunArgNo
end

export let try_pun_call_arg = fn (toks: [ SpannedToken ]) -> MaybePunArg do
  return try_pun_arg_with_closer(toks, closer: ")")
end

/** Lookahead helper: given token list already past the first identifier, scan
 *  zero or more `.Ident` segments and return true iff the sequence forms a
 *  valid qualified ctor pattern head.
 *
 *  Rules (matching the original depth-1 behaviour, extended to N levels):
 *    - `Ctor(` → true (bare uppercase ctor with parens)
 *    - `Mod.Ctor` and `Mod.Ctor(` → true (one-level qualified, with or without `(`)
 *    - `a.b.C` and `a.b.C(` → true (multi-level qualified, lowercase path segments)
 *    - bare `Ctor` with no `(` or `.` → false (could be an unboxed value, not a match)
 *
 *  `last_was_uident` tracks whether the most recently consumed segment was an
 *  uppercase identifier (= potentially a constructor).
 *  `after_dot` is true once at least one `.Seg` has been consumed; it allows
 *  `Mod.Ctor<terminator>` to return true while `Ctor<terminator>` stays false.
 */
export let ctor_pat_lookahead = fn (
  toks: [ SpannedToken ],
  last_was_uident: bool,
  after_dot: bool
) -> bool do
  match pcore.peek_token(toks) do
    | TkLParen -> return last_was_uident
    | TkDot ->
      let r_dot = pcore.skip(toks)
      match pcore.peek_token(toks: r_dot) do
        | TkUident(_) -> return ctor_pat_lookahead(
          toks: pcore.skip(toks: r_dot),
          last_was_uident: true,
          after_dot: true
        )
        | TkIdent(_)  -> return ctor_pat_lookahead(
          toks: pcore.skip(toks: r_dot),
          last_was_uident: false,
          after_dot: true
        )
        | _ -> return false
      end
    // Non-dot, non-paren terminator: valid if last seg was Uident AND we already
    // consumed at least one dot-segment (i.e. the path is `Mod.Ctor`, not bare `Ctor`).
    | _ -> return last_was_uident && after_dot
  end
end

/** Parse `with @ Ident` after a handler-arm signature. Returns Some(name)
 *  when the clause is present, None otherwise.
 */
export let parse_optional_with_kont = fn (toks: [ SpannedToken ]) -> {
  binder: Option<string>,
  rest: [ SpannedToken ]
} throws { ParseError } do
  if let TkWith = pcore.peek_token(toks) then
    let r1 = pcore.skip(toks)
    let r2 = pcore.expect(toks: r1, expected: "@")
    let ParsedIdent(name: n, rest: r3) = pcore.expect_ident(toks: r2)
    return { binder: Some(val: n), rest: r3 }
  else
    return { binder: None, rest: toks }
  end
end
