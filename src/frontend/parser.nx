/**
 * parser: Recursive-descent parser — public entry point + top-level parsing.
 *
 * Owns:
 * - Expression parsing (parse_expr / parse_atom / parse_postfix / parse_prec_*)
 * - Statement parsing (let, if, match, while, for, return, try, inject, …)
 * - Top-level parsing (import, export, let, type, port, exception, handler)
 * - Control-flow parsing (match cases, catch arms)
 * - The public `parse` entry used by driver.nx / imports.nx
 *
 * Does not own:
 * - Token types or span (see src/common/token.nx)
 * - Token-level primitives: peek, expect, skip, binop precedence
 *   (see src/frontend/parse_core.nx)
 * - Type-expression parsing (see src/frontend/parse_type.nx)
 * - Pattern parsing (see src/frontend/parse_pattern.nx)
 * - Lexing (see src/frontend/lexer.nx)
 */

import { Span, SpannedToken } from "src/common/token.nx"
import { Sigil, TypeExpr, UnaryOp, OpNeg, OpFNeg, OpNot, SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel, Param, Function, HandlerArm, MatchCase, CatchArm, CallArg, CtorArg, NamedExpr, NamedType, VariantField, VariantDef, EnumDef, RecordDef, ExceptionDef, ExceptionGroupDef, ImportDef, ImportItem, FunctionSig, Cap, GlobalLet, Program, Unqual } from "src/common/ast.nx"
import * as rdr from "src/ir/rdrname.nx"
import { UnexpectedToken } from "src/common/error.nx"
import { ParsedType, ParsedExpr, ParsedStmt, ParsedPat, ParsedIdent, ParsedSigil, ParsedStmts, ParsedCallArgs, ParsedCtorArgs, ParsedParams, ParsedMatchCases, ParsedCatchArms, ParsedNamedTypes, ParsedVariants, ParsedVariantFields, ParsedFunctions, ParsedHandlerArms, ParsedFunctionSigs, ParsedExprs, ParsedNamedExprs, ParsedStrings, ParsedImportItems, ParsedTopLevel }, * as pcore from "src/frontend/parse_core.nx"
import * as ptype from "src/frontend/parse_type.nx"
import * as ppat from "src/frontend/parse_pattern.nx"
import { parse_fn_params_or_unit, parse_params, parse_optional_type_params }, * as pparams from "src/frontend/parse_params.nx"
import { parse_dotted_name, dotted_name_ends_upper, parse_handler_dotted }, * as pnames from "src/frontend/parse_names.nx"
import { parse_import, parse_type_def, parse_exception_def, parse_cap_def, parse_external_def }, * as ptopdef from "src/frontend/parse_topdef.nx"
import * as list from "std:list"
import * as str from "std:string_ops"

// ─── Expression parsing ──────────────────────────────────────────────────────

let parse_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  return parse_prec_expr(toks, min_prec: 1)
end

let parse_prec_expr = fn (toks: [SpannedToken], min_prec: i64) -> ParsedExpr throws { Exn } do
  let ParsedExpr(expr: left, rest: r) = parse_unary_expr(toks)
  return parse_prec_loop(toks: r, left, min_prec)
end

// Prefix unary: -, -., ! — right-associative, binds tighter than every infix
// binary operator and looser than postfix `.field` / `[idx]`.
let parse_unary_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks)
  match pcore.peek_token(toks) do
    | TkMinus ->
      let ParsedExpr(expr: operand, rest: r) = parse_unary_expr(toks: pcore.skip(toks))
      return ParsedExpr(expr: SpannedExpr(node: ExprUnaryOp(op: OpNeg, operand), span: sp), rest: r)
    | TkMinusDot ->
      let ParsedExpr(expr: operand, rest: r) = parse_unary_expr(toks: pcore.skip(toks))
      return ParsedExpr(expr: SpannedExpr(node: ExprUnaryOp(op: OpFNeg, operand), span: sp), rest: r)
    | TkBang ->
      let ParsedExpr(expr: operand, rest: r) = parse_unary_expr(toks: pcore.skip(toks))
      return ParsedExpr(expr: SpannedExpr(node: ExprUnaryOp(op: OpNot, operand), span: sp), rest: r)
    | _ -> return parse_postfix_expr(toks)
  end
end

let parse_prec_loop = fn (toks: [SpannedToken], left: SpannedExpr, min_prec: i64) -> ParsedExpr throws { Exn } do
  // :: (cons) — right-associative at precedence 4, desugars to lhs :: rhs
  match pcore.peek_token(toks) do
    | TkColonColon ->
      if 4 >= min_prec then
        let ParsedExpr(expr: right, rest: r2) = parse_prec_expr(toks: pcore.skip(toks), min_prec: 4)
        let SpannedExpr(node: _, span: sp) = left
        let cons_args = CtorArg(name: "v", value: left) ::
          (CtorArg(name: "rest", value: right) :: [])
        let new_left = SpannedExpr(node: ExprConstructor(name: Unqual(name: "Cons"), args: cons_args), span: sp)
        return parse_prec_loop(toks: r2, left: new_left, min_prec)
      else
        return ParsedExpr(expr: left, rest: toks)
      end
    | _ -> ()
  end
  let prec = pcore.get_binop_prec(tok: pcore.peek_token(toks))
  if prec < min_prec then return ParsedExpr(expr: left, rest: toks) end
  match pcore.token_to_binop(tok: pcore.peek_token(toks)) do
    | Some(val: op) ->
      // Disambiguate `|` (TkPipe → OpBitOr) vs match/catch arm separator.
      // If the tokens after `|` form a pattern terminated by `->` at depth 0,
      // the `|` belonged to the outer arm parser — leave it for them.
      let is_arm_sep = match pcore.peek_token(toks) do
        | TkPipe -> pcore.pipe_starts_arm(toks: pcore.skip(toks))
        | _ -> false
      end
      match is_arm_sep do
        | true -> return ParsedExpr(expr: left, rest: toks)
        | false ->
          let ParsedExpr(expr: right, rest: r2) = parse_prec_expr(toks: pcore.skip(toks), min_prec: prec + 1)
          let SpannedExpr(node: _, span: sp) = left
          let new_left = SpannedExpr(node: ExprBinaryOp(left, op, right), span: sp)
          return parse_prec_loop(toks: r2, left: new_left, min_prec)
      end
    | None -> return ParsedExpr(expr: left, rest: toks)
  end
end

let parse_postfix_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let ParsedExpr(expr: base, rest: r) = parse_atom(toks)
  return parse_postfix_loop(toks: r, base)
end

let parse_postfix_loop = fn (toks: [SpannedToken], base: SpannedExpr) -> ParsedExpr throws { Exn } do
  match pcore.peek_token(toks) do
    | TkDot ->
      let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.skip(toks))
      let SpannedExpr(node: _, span: sp) = base
      return parse_postfix_loop(toks: r2, base: SpannedExpr(node: ExprFieldAccess(target: base, field: n), span: sp))
    | TkLBracket ->
      let ParsedExpr(expr: idx, rest: r2) = parse_expr(toks: pcore.skip(toks))
      let r3 = pcore.expect(toks: r2, expected: "]")
      let SpannedExpr(node: _, span: sp) = base
      return parse_postfix_loop(toks: r3, base: SpannedExpr(node: ExprIndex(target: base, index: idx), span: sp))
    | _ -> return ParsedExpr(expr: base, rest: toks)
  end
end

// ─── Atom parsing ────────────────────────────────────────────────────────────

let parse_atom = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks)
  match pcore.peek_token(toks) do
    | TkInt(val: v) ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitInt(val: v)), span: sp), rest: pcore.skip(toks))
    | TkFloat(val: v) ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitFloat(val: v)), span: sp), rest: pcore.skip(toks))
    | TkString(val: v) ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitString(val: v)), span: sp), rest: pcore.skip(toks))
    | TkTrue ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitBool(val: true)), span: sp), rest: pcore.skip(toks))
    | TkFalse ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitBool(val: false)), span: sp), rest: pcore.skip(toks))
    | TkChar(val: v) ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitChar(val: v)), span: sp), rest: pcore.skip(toks))
    | TkUnit ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitUnit), span: sp), rest: pcore.skip(toks))
    | TkLParen -> return parse_paren_expr(toks, sp)
    | TkRaise -> return parse_raise_expr(toks, sp)
    | TkAt -> return parse_at_expr(toks, sp)
    | TkIf -> return parse_if_expr(toks)
    | TkMatch -> return parse_match_expr(toks)
    | TkWhile -> return parse_while_expr(toks)
    | TkFor -> return parse_for_expr(toks)
    | TkFn -> return parse_lambda(toks)
    | TkLBracket -> return parse_list_literal(toks, sp)
    | TkLArray -> return parse_array_literal(toks, sp)
    | TkLBrace -> return parse_record_literal(toks, sp)
    | TkTilde -> return parse_sigil_var(toks, sp, sigil: SigilMutable)
    | TkPercent ->
      // %[...] linear list literal vs %ident sigil variable
      if let TkLBracket = pcore.peek_token(toks: pcore.skip(toks)) then
        return parse_list_literal(toks: pcore.skip(toks), sp)
      else
        return parse_sigil_var(toks, sp, sigil: SigilLinear)
      end
    | TkAmpersand -> return parse_borrow_expr(toks, sp)
    | TkUident(name: n) -> return parse_constructor_expr(toks, sp, name: n)
    | TkIdent(name: n) -> return parse_ident_expr(toks, sp, name: n)
    | TkHandler -> return parse_handler_expr(toks)
    | _ ->
      raise UnexpectedToken(expected: "expression", got: pcore.token_tag(tok: pcore.peek_token(toks)), span: sp)
  end
end

let parse_paren_expr = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks)
  if pcore.is_tok(toks: r, expected: ")") then
    return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitUnit), span: sp), rest: pcore.skip(toks: r))
  end
  let ParsedExpr(expr: e, rest: r2) = parse_expr(toks: r)
  return ParsedExpr(expr: e, rest: pcore.expect(toks: r2, expected: ")"))
end

let parse_raise_expr = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let ParsedExpr(expr: e, rest: r2) = parse_expr(toks: pcore.skip(toks))
  return ParsedExpr(expr: SpannedExpr(node: ExprRaise(value: e), span: sp), rest: r2)
end

let parse_at_expr = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks)
  // @ident is a lazy variable reference (consume + unwrap)
  // @(expr) or @{...} is compound force
  if let TkIdent(name: n) = pcore.peek_token(toks: r) then
    return ParsedExpr(expr: SpannedExpr(node: ExprVariable(name: Unqual(name: n), sigil: SigilLazy), span: sp), rest: pcore.skip(toks: r))
  else
    let ParsedExpr(expr: e, rest: r2) = parse_atom(toks: r)
    return ParsedExpr(expr: SpannedExpr(node: ExprForce(value: e), span: sp), rest: r2)
  end
end

let parse_list_literal = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks)
  if pcore.is_tok(toks: r, expected: "]") then
    return ParsedExpr(expr: SpannedExpr(node: ExprList(elements: []), span: sp), rest: pcore.skip(toks: r))
  end
  let ParsedExprs(exprs: es, rest: r2) = parse_comma_exprs(toks: r, acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprList(elements: es), span: sp), rest: pcore.expect(toks: r2, expected: "]"))
end

let parse_array_literal = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks)
  if pcore.is_tok(toks: r, expected: "|]") then
    return ParsedExpr(expr: SpannedExpr(node: ExprArray(elements: []), span: sp), rest: pcore.skip(toks: r))
  end
  let ParsedExprs(exprs: es, rest: r2) = parse_comma_exprs(toks: r, acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprArray(elements: es), span: sp), rest: pcore.expect(toks: r2, expected: "|]"))
end

let parse_record_literal = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let ParsedNamedExprs(fields: fs, rest: r2) = parse_record_expr_fields(toks: pcore.skip(toks), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprRecord(fields: fs), span: sp), rest: pcore.expect(toks: r2, expected: "}"))
end

let parse_sigil_var = fn (toks: [SpannedToken], sp: Span, sigil: Sigil) -> ParsedExpr throws { Exn } do
  let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.skip(toks))
  return ParsedExpr(expr: SpannedExpr(node: ExprVariable(name: Unqual(name: n), sigil), span: sp), rest: r2)
end

let parse_borrow_expr = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks)
  let ParsedSigil(sigil: sig, rest: r2) = pcore.parse_sigil(toks: r)
  let ParsedIdent(name: n, rest: r3) = pcore.expect_ident(toks: r2)
  return ParsedExpr(expr: SpannedExpr(node: ExprBorrow(name: n, sigil: sig), span: sp), rest: r3)
end

let parse_constructor_expr = fn (toks: [SpannedToken], sp: Span, name: string) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks)
  match pcore.peek_token(toks: r) do
    | TkDot ->
      // Dotted path: mod.Ctor(...) or Port.method(...)
      let ParsedIdent(name: full_name, rest: r2) = parse_dotted_name(toks: r, prefix: name)
      let rdr_name = rdr.rdr_from_dotted(s: full_name)
      // Check if last segment is uppercase → constructor, otherwise function call
      let last_is_upper = dotted_name_ends_upper(name: full_name)
      if last_is_upper then
        // Qualified constructor: mod.Ctor or mod.Ctor(...)
        match pcore.peek_token(toks: r2) do
          | TkUnit ->
            return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r2))
          | TkLParen ->
            let r3 = pcore.skip(toks: r2)
            if pcore.is_tok(toks: r3, expected: ")") then
              return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r3))
            end
            let ParsedCtorArgs(args, rest: r4) = parse_ctor_call_args(toks: r3, acc: [])
            return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args), span: sp), rest: pcore.expect(toks: r4, expected: ")"))
          | _ ->
            return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: r2)
        end
      end
      // Lowercase last segment: function call
      match pcore.peek_token(toks: r2) do
        | TkUnit ->
          return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r2))
        | TkLParen ->
          let r3 = pcore.skip(toks: r2)
          if pcore.is_tok(toks: r3, expected: ")") then
            return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r3))
          end
          let ParsedCallArgs(args, rest: r4) = parse_fn_call_args(toks: r3, acc: [])
          return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args), span: sp), rest: pcore.expect(toks: r4, expected: ")"))
        | _ ->
          return ParsedExpr(expr: SpannedExpr(node: ExprVariable(name: rdr_name, sigil: SigilImmutable), span: sp), rest: r2)
      end
    | TkUnit ->
      return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: Unqual(name), args: []), span: sp), rest: pcore.skip(toks: r))
    | TkLParen ->
      let r2 = pcore.skip(toks: r)
      if pcore.is_tok(toks: r2, expected: ")") then
        return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: Unqual(name), args: []), span: sp), rest: pcore.skip(toks: r2))
      end
      let ParsedCtorArgs(args, rest: r3) = parse_ctor_call_args(toks: r2, acc: [])
      return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: Unqual(name), args), span: sp), rest: pcore.expect(toks: r3, expected: ")"))
    | _ ->
      return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: Unqual(name), args: []), span: sp), rest: r)
  end
end

let parse_ident_expr = fn (toks: [SpannedToken], sp: Span, name: string) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks)
  let ParsedIdent(name: full_name, rest: r2) = parse_dotted_name(toks: r, prefix: name)
  let rdr_name = rdr.rdr_from_dotted(s: full_name)
  // If last segment is uppercase, this is a qualified constructor (e.g., hir.PLit)
  let last_upper = dotted_name_ends_upper(name: full_name)
  if last_upper then
    match pcore.peek_token(toks: r2) do
      | TkUnit ->
        return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r2))
      | TkLParen ->
        let r3 = pcore.skip(toks: r2)
        if pcore.is_tok(toks: r3, expected: ")") then
          return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r3))
        else
          let ParsedCtorArgs(args, rest: r4) = parse_ctor_call_args(toks: r3, acc: [])
          return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args), span: sp), rest: pcore.expect(toks: r4, expected: ")"))
        end
      | _ ->
        return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: r2)
    end
  else
    match pcore.peek_token(toks: r2) do
      | TkUnit ->
        return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r2))
      | TkLParen ->
        let r3 = pcore.skip(toks: r2)
        if pcore.is_tok(toks: r3, expected: ")") then
          return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r3))
        else
          let ParsedCallArgs(args, rest: r4) = parse_fn_call_args(toks: r3, acc: [])
          return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args), span: sp), rest: pcore.expect(toks: r4, expected: ")"))
        end
      | _ ->
        // Multi-segment without call: return first segment as Variable,
        // let postfix loop handle remaining dots as FieldAccess
        if name == full_name then
          return ParsedExpr(expr: SpannedExpr(node: ExprVariable(name: rdr_name, sigil: SigilImmutable), span: sp), rest: r2)
        else
          return ParsedExpr(expr: SpannedExpr(node: ExprVariable(name: Unqual(name), sigil: SigilImmutable), span: sp), rest: r)
        end
    end
  end
end

let parse_handler_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks)
  let ParsedIdent(name: n, rest: r2) = pcore.expect_uident(toks: pcore.expect(toks, expected: "handler"))
  let ParsedType(typ: req, rest: r3) = ptype.parse_optional_require(toks: r2)
  let ParsedHandlerArms(arms: arms, rest: r5) = parse_handler_arms(toks: pcore.expect(toks: r3, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(
    node: ExprHandler(coeffect_name: n, requires: req, arms),
    span: sp
  ), rest: pcore.expect(toks: r5, expected: "end"))
end

/// Parse `with @ Ident` after a handler-arm signature. Returns Some(name)
/// when the clause is present, None otherwise.
let parse_optional_with_kont = fn (toks: [SpannedToken]) -> { binder: Option<string>, rest: [SpannedToken] } throws { Exn } do
  if let TkWith = pcore.peek_token(toks) then
    let r1 = pcore.skip(toks)
    let r2 = pcore.expect(toks: r1, expected: "@")
    let ParsedIdent(name: n, rest: r3) = pcore.expect_ident(toks: r2)
    return { binder: Some(val: n), rest: r3 }
  else
    return { binder: None, rest: toks }
  end
end

let parse_handler_arms = fn (toks: [SpannedToken], acc: [HandlerArm]) -> ParsedHandlerArms throws { Exn } do
  if let TkFn = pcore.peek_token(toks) then
    let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.skip(toks))
    let ParsedParams(params: ps, rest: r5) = parse_fn_params_or_unit(toks: r2)
    let ParsedType(typ: ret, rest: r7) = ptype.parse_type(toks: pcore.expect(toks: r5, expected: "->"))
    let ParsedType(typ: thr, rest: r8) = ptype.parse_optional_throws(toks: r7)
    let { binder: kont, rest: r9 } = parse_optional_with_kont(toks: r8)
    let ParsedStmts(stmts: body, rest: r10) = parse_stmts(toks: pcore.expect(toks: r9, expected: "do"), acc: [])
    let f = Function(name: n, is_public: false, type_params: [],
      params: ps, ret_type: ret, requires: ptype.empty_row(), throw_row: thr, body)
    let arm = HandlerArm(arm: f, cont_binder: kont)
    return parse_handler_arms(toks: pcore.expect(toks: r10, expected: "end"), acc: arm :: acc)
  else
    return ParsedHandlerArms(arms: list.reverse(xs: acc), rest: toks)
  end
end

// ─── Argument parsing helpers ────────────────────────────────────────────────

// Dotted-name helpers live in src/frontend/parse_names.nx

// Sigil-aware punning: `f(%v)` desugars to `f(v: %v)`, `f(&v)` to
// `f(v: &v)`, etc. Returns Some(name, expr, rest) when the head of
// `toks` matches a punning shape, None otherwise. `closer` is the
// closing delimiter that, together with `,`, terminates the argument
// (`)` for call/ctor, `}` for record literals).
type MaybePunArg =
  PunArgYes(name: string, value: SpannedExpr, rest: [SpannedToken])
  | PunArgNo

let try_pun_arg_with_closer = fn (toks: [SpannedToken], closer: string) -> MaybePunArg do
  let sp = pcore.peek_span(toks)

  if let TkIdent(name: n) = pcore.peek_token(toks) then
    let r1 = pcore.skip(toks)
    if pcore.is_tok(toks: r1, expected: ",") || pcore.is_tok(toks: r1, expected: closer) then
      return PunArgYes(
        name: n,
        value: SpannedExpr(node: ExprVariable(name: Unqual(name: n), sigil: SigilImmutable), span: sp),
        rest: r1
      )
    end
    return PunArgNo
  end

  let leading = match pcore.peek_token(toks) do
    | TkPercent -> SigilLinear
    | TkTilde -> SigilMutable
    | TkAt -> SigilLazy
    | _ -> SigilImmutable
  end
  let is_unary_sigil = match pcore.peek_token(toks) do
    | TkPercent -> true | TkTilde -> true | TkAt -> true | _ -> false
  end
  if is_unary_sigil then
    let r1 = pcore.skip(toks)
    if let TkIdent(name: n) = pcore.peek_token(toks: r1) then
      let r2 = pcore.skip(toks: r1)
      if pcore.is_tok(toks: r2, expected: ",") || pcore.is_tok(toks: r2, expected: closer) then
        return PunArgYes(
          name: n,
          value: SpannedExpr(node: ExprVariable(name: Unqual(name: n), sigil: leading), span: sp),
          rest: r2
        )
      end
    end
    return PunArgNo
  end

  if pcore.is_tok(toks, expected: "&") then
    let r1 = pcore.skip(toks)
    let inner = match pcore.peek_token(toks: r1) do
      | TkPercent -> SigilLinear
      | TkTilde -> SigilMutable
      | TkAt -> SigilLazy
      | _ -> SigilImmutable
    end
    let has_inner = match pcore.peek_token(toks: r1) do
      | TkPercent -> true | TkTilde -> true | TkAt -> true | _ -> false
    end
    let r2 = if has_inner then pcore.skip(toks: r1) else r1 end
    if let TkIdent(name: n) = pcore.peek_token(toks: r2) then
      let r3 = pcore.skip(toks: r2)
      if pcore.is_tok(toks: r3, expected: ",") || pcore.is_tok(toks: r3, expected: closer) then
        return PunArgYes(
          name: n,
          value: SpannedExpr(node: ExprBorrow(name: n, sigil: inner), span: sp),
          rest: r3
        )
      end
    end
    return PunArgNo
  end

  return PunArgNo
end

let try_pun_call_arg = fn (toks: [SpannedToken]) -> MaybePunArg do
  return try_pun_arg_with_closer(toks, closer: ")")
end

type ResolvedArg = ResolvedArg(name: string, value: SpannedExpr, rest: [SpannedToken])

let resolve_one_arg = fn (toks: [SpannedToken]) -> ResolvedArg throws { Exn } do
  let punned = try_pun_call_arg(toks)
  if let PunArgYes(name: pn, value: pv, rest: pr) = punned then
    return ResolvedArg(name: pn, value: pv, rest: pr)
  end
  let sp = pcore.peek_span(toks)
  let ParsedIdent(name: n0, rest: r0) = pcore.expect_ident(toks)
  if pcore.is_tok(toks: r0, expected: ":") then
    let ParsedExpr(expr: v0, rest: r1) = parse_expr(toks: pcore.skip(toks: r0))
    return ResolvedArg(name: n0, value: v0, rest: r1)
  end
  return ResolvedArg(
    name: n0,
    value: SpannedExpr(node: ExprVariable(name: Unqual(name: n0), sigil: SigilImmutable), span: sp),
    rest: r0
  )
end

let parse_fn_call_args = fn (toks: [SpannedToken], acc: [CallArg]) -> ParsedCallArgs throws { Exn } do
  let ResolvedArg(name: n, value: v, rest: r3) = resolve_one_arg(toks)
  let new_acc = CallArg(name: n, value: v) :: acc
  if pcore.is_tok(toks: r3, expected: ",") then
    return parse_fn_call_args(toks: pcore.skip(toks: r3), acc: new_acc)
  else
    return ParsedCallArgs(args: list.reverse(xs: new_acc), rest: r3)
  end
end

let parse_ctor_call_args = fn (toks: [SpannedToken], acc: [CtorArg]) -> ParsedCtorArgs throws { Exn } do
  let ResolvedArg(name: n, value: v, rest: r3) = resolve_one_arg(toks)
  let new_acc = CtorArg(name: n, value: v) :: acc
  if pcore.is_tok(toks: r3, expected: ",") then
    return parse_ctor_call_args(toks: pcore.skip(toks: r3), acc: new_acc)
  else
    return ParsedCtorArgs(args: list.reverse(xs: new_acc), rest: r3)
  end
end

let parse_comma_exprs = fn (toks: [SpannedToken], acc: [SpannedExpr]) -> ParsedExprs throws { Exn } do
  let ParsedExpr(expr: e, rest: r) = parse_expr(toks)
  let new_acc = e :: acc
  if pcore.is_tok(toks: r, expected: ",") then
    return parse_comma_exprs(toks: pcore.skip(toks: r), acc: new_acc)
  else
    return ParsedExprs(exprs: list.reverse(xs: new_acc), rest: r)
  end
end

let parse_record_expr_fields = fn (toks: [SpannedToken], acc: [NamedExpr]) -> ParsedNamedExprs throws { Exn } do
  match pcore.peek_token(toks) do
    | TkRBrace -> return ParsedNamedExprs(fields: list.reverse(xs: acc), rest: toks)
    | _ ->
      let punned = try_pun_arg_with_closer(toks, closer: "}")
      if let PunArgYes(name: pn, value: pv, rest: pr) = punned then
        let new_acc_p = NamedExpr(name: pn, value: pv) :: acc
        if pcore.is_tok(toks: pr, expected: ",") then
          return parse_record_expr_fields(toks: pcore.skip(toks: pr), acc: new_acc_p)
        else
          return ParsedNamedExprs(fields: list.reverse(xs: new_acc_p), rest: pr)
        end
      end
      let ParsedIdent(name: n, rest: r) = pcore.expect_ident(toks)
      let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r, expected: ":"))
      let new_acc = NamedExpr(name: n, value: v) :: acc
      if pcore.is_tok(toks: r3, expected: ",") then
        return parse_record_expr_fields(toks: pcore.skip(toks: r3), acc: new_acc)
      else
        return ParsedNamedExprs(fields: list.reverse(xs: new_acc), rest: r3)
      end
  end
end

// Param + type-param parsing lives in src/frontend/parse_params.nx

// ─── Control flow expressions ────────────────────────────────────────────────

// Parse the stmts that follow `else`. When the next token is `if`, the inner
// if-expression consumes its own `end` (else-if chain sugar, single trailing end);
// otherwise parse a normal stmt list terminated by `end`.
let parse_else_tail = fn (toks: [SpannedToken]) -> ParsedStmts throws { Exn } do
  match pcore.peek_token(toks) do
    | TkIf ->
      let inner_sp = pcore.peek_span(toks)
      let ParsedExpr(expr: inner_if, rest: r) = parse_if_expr(toks)
      return ParsedStmts(stmts: [SpannedStmt(node: StmtExpr(expr: inner_if), span: inner_sp)], rest: r)
    | _ ->
      let ParsedStmts(stmts: body, rest: r) = parse_stmts(toks, acc: [])
      return ParsedStmts(stmts: body, rest: pcore.expect(toks: r, expected: "end"))
  end
end

// if let <pattern> = <expr> then <body> [else <body>] end
// → desugar to match <expr> do case <pattern> -> <then> case _ -> <else> end
let parse_if_let_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks)
  let ParsedPat(pat, rest: r2) = ppat.parse_pattern(toks)
  let r3 = pcore.expect(toks: r2, expected: "=")
  let ParsedExpr(expr: target, rest: r4) = parse_expr(toks: r3)
  let ParsedStmts(stmts: then_body, rest: r5) = parse_stmts(toks: pcore.expect(toks: r4, expected: "then"), acc: [])
  let wildcard_pat = SpannedPattern(node: PatWildcard, span: sp)
  match pcore.peek_token(toks: r5) do
    | TkElse ->
      let ParsedStmts(stmts: else_body, rest: r7) = parse_else_tail(toks: pcore.skip(toks: r5))
      return ParsedExpr(
        expr: SpannedExpr(node: ExprMatch(target, cases: [
          MatchCase(pattern: pat, body: then_body),
          MatchCase(pattern: wildcard_pat, body: else_body)
        ]), span: sp),
        rest: r7)
    | _ ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprMatch(target, cases: [
          MatchCase(pattern: pat, body: then_body),
          MatchCase(pattern: wildcard_pat, body: [])
        ]), span: sp),
        rest: pcore.expect(toks: r5, expected: "end"))
  end
end

let parse_if_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks)
  let r1 = pcore.expect(toks, expected: "if")
  match pcore.peek_token(toks: r1) do
    | TkLet -> return parse_if_let_expr(toks: pcore.skip(toks: r1))
    | _ ->
      let ParsedExpr(expr: cond, rest: r2) = parse_expr(toks: r1)
      let ParsedStmts(stmts: then_body, rest: r4) = parse_stmts(toks: pcore.expect(toks: r2, expected: "then"), acc: [])
      match pcore.peek_token(toks: r4) do
        | TkElse ->
          let ParsedStmts(stmts: else_body, rest: r6) = parse_else_tail(toks: pcore.skip(toks: r4))
          return ParsedExpr(expr: SpannedExpr(node: ExprIf(cond, then_branch: then_body, else_branch: else_body), span: sp),
            rest: r6)
        | _ ->
          return ParsedExpr(expr: SpannedExpr(node: ExprIf(cond, then_branch: then_body, else_branch: []), span: sp),
            rest: pcore.expect(toks: r4, expected: "end"))
      end
  end
end

let parse_match_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks)
  let ParsedExpr(expr: target, rest: r2) = parse_expr(toks: pcore.expect(toks, expected: "match"))
  let ParsedMatchCases(cases: cs, rest: r4) = parse_match_cases(toks: pcore.expect(toks: r2, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprMatch(target, cases: cs), span: sp),
    rest: pcore.expect(toks: r4, expected: "end"))
end

let parse_match_cases = fn (toks: [SpannedToken], acc: [MatchCase]) -> ParsedMatchCases throws { Exn } do
  match pcore.peek_token(toks) do
    | TkPipe ->
      let ParsedPat(pat: p, rest: r2) = ppat.parse_pattern_or(toks: pcore.skip(toks))
      let ParsedStmts(stmts: body, rest: r4) = parse_stmts(toks: pcore.expect(toks: r2, expected: "->"), acc: [])
      return parse_match_cases(toks: r4, acc: MatchCase(pattern: p, body) :: acc)
    | _ -> return ParsedMatchCases(cases: list.reverse(xs: acc), rest: toks)
  end
end

let parse_while_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks)
  let ParsedExpr(expr: cond, rest: r2) = parse_expr(toks: pcore.expect(toks, expected: "while"))
  let ParsedStmts(stmts: body, rest: r4) = parse_stmts(toks: pcore.expect(toks: r2, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprWhile(cond, body), span: sp),
    rest: pcore.expect(toks: r4, expected: "end"))
end

let parse_for_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks)
  let ParsedIdent(name: var, rest: r2) = pcore.expect_ident(toks: pcore.expect(toks, expected: "for"))
  let ParsedExpr(expr: start_e, rest: r4) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
  let ParsedExpr(expr: end_e, rest: r6) = parse_expr(toks: pcore.expect(toks: r4, expected: "to"))
  let ParsedStmts(stmts: body, rest: r8) = parse_stmts(toks: pcore.expect(toks: r6, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprFor(var, start: start_e, end_expr: end_e, body), span: sp),
    rest: pcore.expect(toks: r8, expected: "end"))
end

let parse_lambda = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks)
  let ParsedStrings(items: tps, rest: r_tp) = parse_optional_type_params(toks: pcore.expect(toks, expected: "fn"))
  if pcore.is_tok(toks: r_tp, expected: "()") then
    return parse_lambda_body(toks: pcore.skip(toks: r_tp), type_params: tps, params: [], sp)
  end
  let ParsedParams(params: ps, rest: r3) = parse_params(toks: pcore.expect(toks: r_tp, expected: "("), acc: [])
  return parse_lambda_body(toks: pcore.expect(toks: r3, expected: ")"), type_params: tps, params: ps, sp)
end

let parse_lambda_body = fn (toks: [SpannedToken], type_params: [string], params: [Param], sp: Span) -> ParsedExpr throws { Exn } do
  let ParsedType(typ: ret, rest: r6) = ptype.parse_type(toks: pcore.expect(toks, expected: "->"))
  let ParsedType(typ: req, rest: r7) = ptype.parse_optional_require(toks: r6)
  let ParsedType(typ: thr, rest: r8) = ptype.parse_optional_throws(toks: r7)
  let ParsedStmts(stmts: body, rest: r10) = parse_stmts(toks: pcore.expect(toks: r8, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(
    node: ExprLambda(type_params, params, ret_type: ret, requires: req, throw_row: thr, body),
    span: sp
  ), rest: pcore.expect(toks: r10, expected: "end"))
end

// ─── Statement parsing ───────────────────────────────────────────────────────

let parse_stmts = fn (toks: [SpannedToken], acc: [SpannedStmt]) -> ParsedStmts throws { Exn } do
  if pcore.is_block_end(tok: pcore.peek_token(toks)) then
    return ParsedStmts(stmts: list.reverse(xs: acc), rest: toks)
  end
  let ParsedStmt(stmt: s, rest) = parse_stmt(toks)
  return parse_stmts(toks: rest, acc: s :: acc)
end

let parse_stmt = fn (toks: [SpannedToken]) -> ParsedStmt throws { Exn } do
  let sp = pcore.peek_span(toks)
  match pcore.peek_token(toks) do
    | TkLet -> return parse_let_stmt(toks)
    | TkReturn ->
      let ParsedExpr(expr: e, rest: r2) = parse_expr(toks: pcore.skip(toks))
      return ParsedStmt(stmt: SpannedStmt(node: StmtReturn(value: e), span: sp), rest: r2)
    | TkTry -> return parse_try_stmt(toks)
    | TkInject -> return parse_inject_stmt(toks)
    | _ ->
      // Expression statement or assignment
      let ParsedExpr(expr: e, rest: r) = parse_expr(toks)
      match pcore.peek_token(toks: r) do
        | TkLArrow ->
          let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.skip(toks: r))
          let target_name = if let SpannedExpr(node: ExprVariable(name: nm, sigil: _), span: _) = e then
            rdr.rdr_to_string(r: nm)
          else
            raise UnexpectedToken(expected: "assignable variable before '<-'", got: "non-variable expression", span: sp)
          end
          return ParsedStmt(stmt: SpannedStmt(node: StmtAssign(target: target_name, value: v), span: sp), rest: r3)
        | _ ->
          return ParsedStmt(stmt: SpannedStmt(node: StmtExpr(expr: e), span: sp), rest: r)
      end
  end
end

let parse_let_with_type = fn (n: string, sig: Sigil, r3: [SpannedToken], sp: Span) -> ParsedStmt throws { Exn } do
  let ParsedType(typ: t, rest: r5) = ptype.parse_type(toks: pcore.skip(toks: r3))
  let ParsedExpr(expr: v, rest: r7) = parse_expr(toks: pcore.expect(toks: r5, expected: "="))
  ParsedStmt(stmt: SpannedStmt(node: StmtLet(name: n, sigil: sig, typ: Some(val: t), value: v), span: sp), rest: r7)
end

let parse_let_without_type = fn (n: string, sig: Sigil, r3: [SpannedToken], sp: Span) -> ParsedStmt throws { Exn } do
  let ParsedExpr(expr: v, rest: r5) = parse_expr(toks: pcore.expect(toks: r3, expected: "="))
  ParsedStmt(stmt: SpannedStmt(node: StmtLet(name: n, sigil: sig, typ: None, value: v), span: sp), rest: r5)
end

let parse_let_stmt = fn (toks: [SpannedToken]) -> ParsedStmt throws { Exn } do
  let sp = pcore.peek_span(toks)
  let r_after_let = pcore.expect(toks, expected: "let")
  // Check for destructuring: let Ctor(...) = expr or let { ... } = expr
  if let TkUident(_) = pcore.peek_token(toks: r_after_let) then
    if pcore.is_tok(toks: pcore.skip(toks: r_after_let), expected: "(") then
      let ParsedPat(pat, rest: r2) = ppat.parse_pattern(toks: r_after_let)
      let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
      return ParsedStmt(stmt: SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp), rest: r3)
    end
  end
  if let TkLBrace = pcore.peek_token(toks: r_after_let) then
    let ParsedPat(pat, rest: r2) = ppat.parse_pattern(toks: r_after_let)
    let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
    return ParsedStmt(stmt: SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp), rest: r3)
  end
  let ParsedSigil(sigil: sig, rest: r2) = pcore.parse_sigil(toks: r_after_let)
  let ParsedIdent(name: n, rest: r3) = pcore.expect_ident(toks: r2)
  return if pcore.is_tok(toks: r3, expected: ":") then
    parse_let_with_type(n, sig, r3, sp)
  else
    parse_let_without_type(n, sig, r3, sp)
  end
end

let parse_try_stmt = fn (toks: [SpannedToken]) -> ParsedStmt throws { Exn } do
  let sp = pcore.peek_span(toks)
  let ParsedStmts(stmts: body, rest: r2) = parse_stmts(toks: pcore.expect(toks, expected: "try"), acc: [])
  let r_after_catch = pcore.expect(toks: r2, expected: "catch")
  match pcore.peek_token(toks: r_after_catch) do
    | TkPipe ->
      // Selective catch: catch | Pattern -> body ...
      let ParsedCatchArms(arms, rest: r4) = parse_catch_arms(toks: r_after_catch, acc: [])
      return ParsedStmt(stmt: SpannedStmt(node: StmtTry(body, catch_arms: arms), span: sp),
        rest: pcore.expect(toks: r4, expected: "end"))
    | _ ->
      // Bare catch: catch param -> body
      let ParsedIdent(name: param, rest: r4) = pcore.expect_ident(toks: r_after_catch)
      let ParsedStmts(stmts: catch_body, rest: r6) = parse_stmts(toks: pcore.expect(toks: r4, expected: "->"), acc: [])
      let arm = CatchArm(pattern: SpannedPattern(node: PatVariable(name: param, sigil: SigilImmutable), span: sp), body: catch_body)
      return ParsedStmt(stmt: SpannedStmt(node: StmtTry(body, catch_arms: [arm]), span: sp),
        rest: pcore.expect(toks: r6, expected: "end"))
  end
end

let parse_catch_arms = fn (toks: [SpannedToken], acc: [CatchArm]) -> ParsedCatchArms throws { Exn } do
  match pcore.peek_token(toks) do
    | TkPipe ->
      let ParsedPat(pat: p, rest: r2) = ppat.parse_pattern_or(toks: pcore.skip(toks))
      let ParsedStmts(stmts: arm_body, rest: r4) = parse_stmts(toks: pcore.expect(toks: r2, expected: "->"), acc: [])
      return parse_catch_arms(toks: r4, acc: CatchArm(pattern: p, body: arm_body) :: acc)
    | _ -> return ParsedCatchArms(arms: list.reverse(xs: acc), rest: toks)
  end
end

let parse_inject_stmt = fn (toks: [SpannedToken]) -> ParsedStmt throws { Exn } do
  let sp = pcore.peek_span(toks)
  // Parse handler names as dotted identifiers, producing ExprVariable with dotted name.
  let ParsedExprs(exprs: hs, rest: r2) = parse_inject_handlers(toks: pcore.expect(toks, expected: "inject"), acc: [])
  let ParsedStmts(stmts: body, rest: r4) = parse_stmts(toks: pcore.expect(toks: r2, expected: "do"), acc: [])
  return ParsedStmt(stmt: SpannedStmt(node: StmtInject(handlers: hs, body), span: sp),
    rest: pcore.expect(toks: r4, expected: "end"))
end

/// Parse comma-separated dotted handler names: "a.b, c.d, ..." → [ExprVariable("a.b"), ExprVariable("c.d")]
let parse_inject_handlers = fn (toks: [SpannedToken], acc: [SpannedExpr]) -> ParsedExprs throws { Exn } do
  let ParsedIdent(name: first, rest: r1) = parse_handler_dotted(toks)
  let sp = pcore.peek_span(toks)
  let expr = SpannedExpr(node: ExprVariable(name: rdr.rdr_from_dotted(s: first), sigil: SigilImmutable), span: sp)
  match pcore.peek_token(toks: r1) do
    | TkComma ->
      return parse_inject_handlers(toks: pcore.skip(toks: r1), acc: expr :: acc)
    | _ ->
      // Order doesn't matter for inject handler names
      return ParsedExprs(exprs: expr :: acc, rest: r1)
  end
end

/// Parse a dotted name like "a.b.c" → "a.b.c"
// ─── Top-level parsing ───────────────────────────────────────────────────────
// Import / type / exception / port / external parsers live in
// src/frontend/parse_topdef.nx. parse_global_let stays here because its
// initializer uses parse_expr, which would create a cyclic import.

let parse_global_let_typed = fn (n: string, is_pub: bool, r2: [SpannedToken], sp: Span) -> ParsedTopLevel throws { Exn } do
  let ParsedType(typ: t, rest: r4) = ptype.parse_type(toks: pcore.skip(toks: r2))
  let ParsedExpr(expr: v, rest: r6) = parse_expr(toks: pcore.expect(toks: r4, expected: "="))
  ParsedTopLevel(item: SpannedTopLevel(node: TLLet(def: GlobalLet(name: n, is_public: is_pub, typ: Some(val: t), value: v)), span: sp), rest: r6)
end

let parse_global_let_untyped = fn (n: string, is_pub: bool, r2: [SpannedToken], sp: Span) -> ParsedTopLevel throws { Exn } do
  let ParsedExpr(expr: v, rest: r4) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
  ParsedTopLevel(item: SpannedTopLevel(node: TLLet(def: GlobalLet(name: n, is_public: is_pub, typ: None, value: v)), span: sp), rest: r4)
end

let parse_global_let = fn (toks: [SpannedToken], is_pub: bool) -> ParsedTopLevel throws { Exn } do
  let sp = pcore.peek_span(toks)
  let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.expect(toks, expected: "let"))
  return if pcore.is_tok(toks: r2, expected: ":") then
    parse_global_let_typed(n, is_pub, r2, sp)
  else
    parse_global_let_untyped(n, is_pub, r2, sp)
  end
end

let parse_top_level = fn (toks: [SpannedToken]) -> ParsedTopLevel throws { Exn } do
  match pcore.peek_token(toks) do
    | TkImport -> return parse_import(toks)
    | TkPub ->
      let r = pcore.skip(toks)
      match pcore.peek_token(toks: r) do
        | TkType -> return parse_type_def(toks: r, is_pub: true)
        | TkOpaque -> return parse_type_def(toks: r, is_pub: true)
        | TkLet -> return parse_global_let(toks: r, is_pub: true)
        | TkException -> return parse_exception_def(toks: r, is_pub: true)
        | TkCap -> return parse_cap_def(toks: r, is_pub: true)
        | TkExternal -> return parse_external_def(toks: r, is_pub: true)
        | _ ->
          raise UnexpectedToken(expected: "definition after 'export'", got: pcore.token_tag(tok: pcore.peek_token(toks: r)), span: pcore.peek_span(toks: r))
      end
    | TkType -> return parse_type_def(toks, is_pub: false)
    | TkOpaque -> return parse_type_def(toks, is_pub: false)
    | TkLet -> return parse_global_let(toks, is_pub: false)
    | TkException -> return parse_exception_def(toks, is_pub: false)
    | TkCap -> return parse_cap_def(toks, is_pub: false)
    | TkExternal -> return parse_external_def(toks, is_pub: false)
    | _ ->
      raise UnexpectedToken(expected: "top-level definition", got: pcore.token_tag(tok: pcore.peek_token(toks)), span: pcore.peek_span(toks))
  end
end

// ─── Entry point ─────────────────────────────────────────────────────────────

let parse_program_loop = fn (toks: [SpannedToken], acc: [SpannedTopLevel]) -> Program throws { Exn } do
  match pcore.peek_token(toks) do
    | TkEof -> return Program(definitions: list.reverse(xs: acc))
    | _ ->
      let ParsedTopLevel(item, rest: r) = parse_top_level(toks)
      return parse_program_loop(toks: r, acc: item :: acc)
  end
end

/// Parse a token list into a Program AST.
export let parse = fn (tokens: [SpannedToken]) -> Program throws { Exn } do
  return parse_program_loop(toks: tokens, acc: [])
end
