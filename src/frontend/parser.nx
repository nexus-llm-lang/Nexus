/**
 * parser: Recursive descent parser for Nexus.
 *
 * Expression, statement, control flow, top-level definition parsing,
 * and the public entry point. Type and pattern parsing are in separate
 * modules (parse_type.nx, parse_pattern.nx).
 */

import { Token, Span, SpannedToken } from "src/common/token.nx"
import { Sigil, BinaryOp, Literal, TypeExpr, Pattern, Expr, Stmt,
         SpannedExpr, SpannedStmt, SpannedPattern, SpannedTopLevel,
         Param, Function, MatchCase, CatchArm, CallArg, CtorArg, NamedExpr,
         NamedType, VariantField, CtorPatternField, RecordPatField,
         VariantDef, EnumDef, RecordDef, ExceptionDef, ExceptionGroupDef,
         ImportDef, ImportItem,
         FunctionSig, Port, GlobalLet, TopLevel, Program,
         RdrName, Unqual, Qual } from "src/common/ast.nx"
import * as rdr from "src/ir/rdrname.nx"
import { UnexpectedToken, UnexpectedEof } from "src/common/error.nx"
import { ParsedType, ParsedExpr, ParsedStmt, ParsedPat, ParsedIdent,
         ParsedSigil, ParsedStmts, ParsedCallArgs, ParsedCtorArgs,
         ParsedParams, ParsedMatchCases, ParsedCatchArms,
         ParsedNamedTypes, ParsedTypes,
         ParsedVariants, ParsedVariantFields, ParsedFunctions,
         ParsedFunctionSigs, ParsedExprs, ParsedNamedExprs,
         ParsedStrings, ParsedImportItems, ParsedTopLevel }, * as pcore from "src/frontend/parse_core.nx"
import * as ptype from "src/frontend/parse_type.nx"
import * as ppat from "src/frontend/parse_pattern.nx"
import * as list from "stdlib/list.nx"
import * as str from "stdlib/string.nx"

// ─── Expression parsing ──────────────────────────────────────────────────────

let parse_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  return parse_prec_expr(toks: toks, min_prec: 1)
end

let parse_prec_expr = fn (toks: [SpannedToken], min_prec: i64) -> ParsedExpr throws { Exn } do
  let ParsedExpr(expr: left, rest: r) = parse_postfix_expr(toks: toks)
  return parse_prec_loop(toks: r, left: left, min_prec: min_prec)
end

let parse_prec_loop = fn (toks: [SpannedToken], left: SpannedExpr, min_prec: i64) -> ParsedExpr throws { Exn } do
  // :: (cons) — right-associative at precedence 4, desugars to Cons(v: lhs, rest: rhs)
  match pcore.peek_token(toks: toks) do
    case TkColonColon ->
      if 4 >= min_prec then
        let ParsedExpr(expr: right, rest: r2) = parse_prec_expr(toks: pcore.skip(toks: toks), min_prec: 4)
        let SpannedExpr(node: _, span: sp) = left
        let cons_args = CtorArg(name: Some(val: "v"), value: left) ::
          (CtorArg(name: Some(val: "rest"), value: right) :: [])
        let new_left = SpannedExpr(node: ExprConstructor(name: Unqual(name: "Cons"), args: cons_args), span: sp)
        return parse_prec_loop(toks: r2, left: new_left, min_prec: min_prec)
      else
        return ParsedExpr(expr: left, rest: toks)
      end
    case _ -> ()
  end
  let prec = pcore.get_binop_prec(tok: pcore.peek_token(toks: toks))
  if prec < min_prec then return ParsedExpr(expr: left, rest: toks) end
  match pcore.token_to_binop(tok: pcore.peek_token(toks: toks)) do
    case Some(val: op) ->
      let ParsedExpr(expr: right, rest: r2) = parse_prec_expr(toks: pcore.skip(toks: toks), min_prec: prec + 1)
      let SpannedExpr(node: _, span: sp) = left
      let new_left = SpannedExpr(node: ExprBinaryOp(left: left, op: op, right: right), span: sp)
      return parse_prec_loop(toks: r2, left: new_left, min_prec: min_prec)
    case None -> return ParsedExpr(expr: left, rest: toks)
  end
end

let parse_postfix_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let ParsedExpr(expr: base, rest: r) = parse_atom(toks: toks)
  return parse_postfix_loop(toks: r, base: base)
end

let parse_postfix_loop = fn (toks: [SpannedToken], base: SpannedExpr) -> ParsedExpr throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkDot ->
      let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.skip(toks: toks))
      let SpannedExpr(node: _, span: sp) = base
      return parse_postfix_loop(toks: r2, base: SpannedExpr(node: ExprFieldAccess(target: base, field: n), span: sp))
    case TkLBracket ->
      let ParsedExpr(expr: idx, rest: r2) = parse_expr(toks: pcore.skip(toks: toks))
      let r3 = pcore.expect(toks: r2, expected: "]")
      let SpannedExpr(node: _, span: sp) = base
      return parse_postfix_loop(toks: r3, base: SpannedExpr(node: ExprIndex(target: base, index: idx), span: sp))
    case _ -> return ParsedExpr(expr: base, rest: toks)
  end
end

// ─── Atom parsing ────────────────────────────────────────────────────────────

let parse_atom = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  match pcore.peek_token(toks: toks) do
    case TkInt(val: v) ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitInt(val: v)), span: sp), rest: pcore.skip(toks: toks))
    case TkFloat(val: v) ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitFloat(val: v)), span: sp), rest: pcore.skip(toks: toks))
    case TkString(val: v) ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitString(val: v)), span: sp), rest: pcore.skip(toks: toks))
    case TkTrue ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitBool(val: true)), span: sp), rest: pcore.skip(toks: toks))
    case TkFalse ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitBool(val: false)), span: sp), rest: pcore.skip(toks: toks))
    case TkChar(val: v) ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitChar(val: v)), span: sp), rest: pcore.skip(toks: toks))
    case TkUnit ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitUnit), span: sp), rest: pcore.skip(toks: toks))
    case TkLParen -> return parse_paren_expr(toks: toks, sp: sp)
    case TkMinus -> return parse_neg_literal(toks: toks, sp: sp)
    case TkRaise -> return parse_raise_expr(toks: toks, sp: sp)
    case TkAt -> return parse_at_expr(toks: toks, sp: sp)
    case TkIf -> return parse_if_expr(toks: toks)
    case TkMatch -> return parse_match_expr(toks: toks)
    case TkWhile -> return parse_while_expr(toks: toks)
    case TkFor -> return parse_for_expr(toks: toks)
    case TkFn -> return parse_lambda(toks: toks)
    case TkLBracket -> return parse_list_literal(toks: toks, sp: sp)
    case TkLArray -> return parse_array_literal(toks: toks, sp: sp)
    case TkLBrace -> return parse_record_literal(toks: toks, sp: sp)
    case TkTilde -> return parse_sigil_var(toks: toks, sp: sp, sigil: SigilMutable)
    case TkPercent -> return parse_sigil_var(toks: toks, sp: sp, sigil: SigilLinear)
    case TkAmpersand -> return parse_borrow_expr(toks: toks, sp: sp)
    case TkUident(name: n) -> return parse_constructor_expr(toks: toks, sp: sp, name: n)
    case TkIdent(name: n) -> return parse_ident_expr(toks: toks, sp: sp, name: n)
    case TkHandler -> return parse_handler_expr(toks: toks)
    case _ ->
      raise UnexpectedToken(expected: "expression", got: pcore.token_tag(tok: pcore.peek_token(toks: toks)), span: sp)
  end
end

let parse_paren_expr = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks: toks)
  if pcore.is_tok(toks: r, expected: ")") then
    return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitUnit), span: sp), rest: pcore.skip(toks: r))
  end
  let ParsedExpr(expr: e, rest: r2) = parse_expr(toks: r)
  return ParsedExpr(expr: e, rest: pcore.expect(toks: r2, expected: ")"))
end

let parse_neg_literal = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks: toks)
  match pcore.peek_token(toks: r) do
    case TkInt(val: v) ->
      return ParsedExpr(expr: SpannedExpr(node: ExprLiteral(lit: LitInt(val: 0 - v)), span: sp), rest: pcore.skip(toks: r))
    case _ ->
      raise UnexpectedToken(expected: "number after '-'", got: pcore.token_tag(tok: pcore.peek_token(toks: toks)), span: sp)
  end
end

let parse_raise_expr = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let ParsedExpr(expr: e, rest: r2) = parse_expr(toks: pcore.skip(toks: toks))
  return ParsedExpr(expr: SpannedExpr(node: ExprRaise(value: e), span: sp), rest: r2)
end

let parse_at_expr = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks: toks)
  // @ident is a lazy variable reference (consume + unwrap)
  // @(expr) or @{...} is compound force
  match pcore.peek_token(toks: r) do
    case TkIdent(name: n) ->
      return ParsedExpr(expr: SpannedExpr(node: ExprVariable(name: Unqual(name: n), sigil: SigilLazy), span: sp), rest: pcore.skip(toks: r))
    case _ ->
      let ParsedExpr(expr: e, rest: r2) = parse_atom(toks: r)
      return ParsedExpr(expr: SpannedExpr(node: ExprForce(value: e), span: sp), rest: r2)
  end
end

let parse_list_literal = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks: toks)
  if pcore.is_tok(toks: r, expected: "]") then
    return ParsedExpr(expr: SpannedExpr(node: ExprList(elements: []), span: sp), rest: pcore.skip(toks: r))
  end
  let ParsedExprs(exprs: es, rest: r2) = parse_comma_exprs(toks: r, acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprList(elements: es), span: sp), rest: pcore.expect(toks: r2, expected: "]"))
end

let parse_array_literal = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks: toks)
  if pcore.is_tok(toks: r, expected: "|]") then
    return ParsedExpr(expr: SpannedExpr(node: ExprArray(elements: []), span: sp), rest: pcore.skip(toks: r))
  end
  let ParsedExprs(exprs: es, rest: r2) = parse_comma_exprs(toks: r, acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprArray(elements: es), span: sp), rest: pcore.expect(toks: r2, expected: "|]"))
end

let parse_record_literal = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let ParsedNamedExprs(fields: fs, rest: r2) = parse_record_expr_fields(toks: pcore.skip(toks: toks), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprRecord(fields: fs), span: sp), rest: pcore.expect(toks: r2, expected: "}"))
end

let parse_sigil_var = fn (toks: [SpannedToken], sp: Span, sigil: Sigil) -> ParsedExpr throws { Exn } do
  let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.skip(toks: toks))
  return ParsedExpr(expr: SpannedExpr(node: ExprVariable(name: Unqual(name: n), sigil: sigil), span: sp), rest: r2)
end

let parse_borrow_expr = fn (toks: [SpannedToken], sp: Span) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks: toks)
  let ParsedSigil(sigil: sig, rest: r2) = pcore.parse_sigil(toks: r)
  let ParsedIdent(name: n, rest: r3) = pcore.expect_ident(toks: r2)
  return ParsedExpr(expr: SpannedExpr(node: ExprBorrow(name: n, sigil: sig), span: sp), rest: r3)
end

let parse_constructor_expr = fn (toks: [SpannedToken], sp: Span, name: string) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks: toks)
  match pcore.peek_token(toks: r) do
    case TkDot ->
      // Dotted path: mod.Ctor(...) or Port.method(...)
      let ParsedIdent(name: full_name, rest: r2) = parse_dotted_name(toks: r, prefix: name)
      let rdr_name = rdr.rdr_from_dotted(s: full_name)
      // Check if last segment is uppercase → constructor, otherwise function call
      let last_is_upper = dotted_name_ends_upper(name: full_name)
      if last_is_upper then
        // Qualified constructor: mod.Ctor or mod.Ctor(...)
        match pcore.peek_token(toks: r2) do
          case TkUnit ->
            return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r2))
          case TkLParen ->
            let r3 = pcore.skip(toks: r2)
            if pcore.is_tok(toks: r3, expected: ")") then
              return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r3))
            end
            let ParsedCtorArgs(args: args, rest: r4) = parse_ctor_call_args(toks: r3, acc: [])
            return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: args), span: sp), rest: pcore.expect(toks: r4, expected: ")"))
          case _ ->
            return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: r2)
        end
      end
      // Lowercase last segment: function call
      match pcore.peek_token(toks: r2) do
        case TkUnit ->
          return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r2))
        case TkLParen ->
          let r3 = pcore.skip(toks: r2)
          if pcore.is_tok(toks: r3, expected: ")") then
            return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r3))
          end
          let ParsedCallArgs(args: args, rest: r4) = parse_fn_call_args(toks: r3, acc: [])
          return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args: args), span: sp), rest: pcore.expect(toks: r4, expected: ")"))
        case _ ->
          return ParsedExpr(expr: SpannedExpr(node: ExprVariable(name: rdr_name, sigil: SigilImmutable), span: sp), rest: r2)
      end
    case TkUnit ->
      return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: Unqual(name: name), args: []), span: sp), rest: pcore.skip(toks: r))
    case TkLParen ->
      let r2 = pcore.skip(toks: r)
      if pcore.is_tok(toks: r2, expected: ")") then
        return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: Unqual(name: name), args: []), span: sp), rest: pcore.skip(toks: r2))
      end
      let ParsedCtorArgs(args: args, rest: r3) = parse_ctor_call_args(toks: r2, acc: [])
      return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: Unqual(name: name), args: args), span: sp), rest: pcore.expect(toks: r3, expected: ")"))
    case _ ->
      return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: Unqual(name: name), args: []), span: sp), rest: r)
  end
end

let parse_ident_expr = fn (toks: [SpannedToken], sp: Span, name: string) -> ParsedExpr throws { Exn } do
  let r = pcore.skip(toks: toks)
  let ParsedIdent(name: full_name, rest: r2) = parse_dotted_name(toks: r, prefix: name)
  let rdr_name = rdr.rdr_from_dotted(s: full_name)
  // If last segment is uppercase, this is a qualified constructor (e.g., hir.PLit)
  let last_upper = dotted_name_ends_upper(name: full_name)
  if last_upper then
    match pcore.peek_token(toks: r2) do
      case TkUnit ->
        return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r2))
      case TkLParen ->
        let r3 = pcore.skip(toks: r2)
        if pcore.is_tok(toks: r3, expected: ")") then
          return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r3))
        else
          let ParsedCtorArgs(args: args, rest: r4) = parse_ctor_call_args(toks: r3, acc: [])
          return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: args), span: sp), rest: pcore.expect(toks: r4, expected: ")"))
        end
      case _ ->
        return ParsedExpr(expr: SpannedExpr(node: ExprConstructor(name: rdr_name, args: []), span: sp), rest: r2)
    end
  else
    match pcore.peek_token(toks: r2) do
      case TkUnit ->
        return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r2))
      case TkLParen ->
        let r3 = pcore.skip(toks: r2)
        if pcore.is_tok(toks: r3, expected: ")") then
          return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args: []), span: sp), rest: pcore.skip(toks: r3))
        else
          let ParsedCallArgs(args: args, rest: r4) = parse_fn_call_args(toks: r3, acc: [])
          return ParsedExpr(expr: SpannedExpr(node: ExprCall(func: rdr_name, args: args), span: sp), rest: pcore.expect(toks: r4, expected: ")"))
        end
      case _ ->
        // Multi-segment without call: return first segment as Variable,
        // let postfix loop handle remaining dots as FieldAccess
        if name == full_name then
          return ParsedExpr(expr: SpannedExpr(node: ExprVariable(name: rdr_name, sigil: SigilImmutable), span: sp), rest: r2)
        else
          return ParsedExpr(expr: SpannedExpr(node: ExprVariable(name: Unqual(name: name), sigil: SigilImmutable), span: sp), rest: r)
        end
    end
  end
end

let parse_handler_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let ParsedIdent(name: n, rest: r2) = pcore.expect_uident(toks: pcore.expect(toks: toks, expected: "handler"))
  let ParsedType(typ: req, rest: r3) = ptype.parse_optional_require(toks: r2)
  let ParsedFunctions(functions: fs, rest: r5) = parse_handler_fns(toks: pcore.expect(toks: r3, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(
    node: ExprHandler(coeffect_name: n, requires: req, functions: fs),
    span: sp
  ), rest: pcore.expect(toks: r5, expected: "end"))
end

let parse_handler_fns = fn (toks: [SpannedToken], acc: [Function]) -> ParsedFunctions throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkFn ->
      let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.skip(toks: toks))
      let ParsedParams(params: ps, rest: r5) = parse_fn_params_or_unit(toks: r2)
      let ParsedType(typ: ret, rest: r7) = ptype.parse_type(toks: pcore.expect(toks: r5, expected: "->"))
      let ParsedType(typ: thr, rest: r8) = ptype.parse_optional_throws(toks: r7)
      let ParsedStmts(stmts: body, rest: r10) = parse_stmts(toks: pcore.expect(toks: r8, expected: "do"), acc: [])
      let f = Function(name: n, is_public: false, type_params: [],
        params: ps, ret_type: ret, requires: ptype.empty_row(), throw_row: thr, body: body)
      return parse_handler_fns(toks: pcore.expect(toks: r10, expected: "end"), acc: f :: acc)
    case _ -> return ParsedFunctions(functions: list.reverse(xs: acc), rest: toks)
  end
end

// ─── Argument parsing helpers ────────────────────────────────────────────────

// Accumulate dotted name segments in a reversed list, then join at the end.
// This avoids O(n²) string concatenation on deep dotted paths.
let parse_dotted_segments = fn (toks: [SpannedToken], acc: [string]) -> ParsedIdent throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkDot ->
      let r = pcore.skip(toks: toks)
      match pcore.peek_token(toks: r) do
        case TkIdent(name: n) -> return parse_dotted_segments(toks: pcore.skip(toks: r), acc: n :: acc)
        case TkUident(name: n) -> return ParsedIdent(name: str.join(xs: list.reverse(xs: n :: acc), sep: "."), rest: pcore.skip(toks: r))
        case _ -> return ParsedIdent(name: str.join(xs: list.reverse(xs: acc), sep: "."), rest: toks)
      end
    case _ -> return ParsedIdent(name: str.join(xs: list.reverse(xs: acc), sep: "."), rest: toks)
  end
end

let parse_dotted_name = fn (toks: [SpannedToken], prefix: string) -> ParsedIdent throws { Exn } do
  return parse_dotted_segments(toks: toks, acc: prefix :: [])
end

/// Check if last segment of a dotted name starts with uppercase (A-Z).
let dotted_name_ends_upper = fn (name: string) -> bool do
  let len = str.length(s: name)
  let idx = dotted_name_last_dot(name: name, i: len - 1)
  let ch = str.char_code(s: name, idx: idx + 1)
  return ch >= 65 && ch <= 90
end

let dotted_name_last_dot = fn (name: string, i: i64) -> i64 do
  if i < 0 then return -1 end
  if str.char_code(s: name, idx: i) == 46 then return i end
  return dotted_name_last_dot(name: name, i: i - 1)
end

let parse_fn_call_args = fn (toks: [SpannedToken], acc: [CallArg]) -> ParsedCallArgs throws { Exn } do
  let ParsedIdent(name: n, rest: r) = pcore.expect_ident(toks: toks)
  let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r, expected: ":"))
  let new_acc = CallArg(name: n, value: v) :: acc
  if pcore.is_tok(toks: r3, expected: ",") then
    return parse_fn_call_args(toks: pcore.skip(toks: r3), acc: new_acc)
  else
    return ParsedCallArgs(args: list.reverse(xs: new_acc), rest: r3)
  end
end

let parse_ctor_call_args = fn (toks: [SpannedToken], acc: [CtorArg]) -> ParsedCtorArgs throws { Exn } do
  if pcore.is_labeled_field(toks: toks) then
    return parse_ctor_args_labeled(toks: toks, acc: acc)
  else
    return parse_ctor_args_positional(toks: toks, acc: acc)
  end
end

let parse_ctor_args_labeled = fn (toks: [SpannedToken], acc: [CtorArg]) -> ParsedCtorArgs throws { Exn } do
  let ParsedIdent(name: n, rest: r) = pcore.expect_ident(toks: toks)
  let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r, expected: ":"))
  let new_acc = CtorArg(name: Some(val: n), value: v) :: acc
  if pcore.is_tok(toks: r3, expected: ",") then
    return parse_ctor_call_args(toks: pcore.skip(toks: r3), acc: new_acc)
  else
    return ParsedCtorArgs(args: list.reverse(xs: new_acc), rest: r3)
  end
end

let parse_ctor_args_positional = fn (toks: [SpannedToken], acc: [CtorArg]) -> ParsedCtorArgs throws { Exn } do
  let ParsedExpr(expr: v, rest: r) = parse_expr(toks: toks)
  let new_acc = CtorArg(name: None, value: v) :: acc
  if pcore.is_tok(toks: r, expected: ",") then
    return parse_ctor_call_args(toks: pcore.skip(toks: r), acc: new_acc)
  else
    return ParsedCtorArgs(args: list.reverse(xs: new_acc), rest: r)
  end
end

let parse_comma_exprs = fn (toks: [SpannedToken], acc: [SpannedExpr]) -> ParsedExprs throws { Exn } do
  let ParsedExpr(expr: e, rest: r) = parse_expr(toks: toks)
  let new_acc = e :: acc
  if pcore.is_tok(toks: r, expected: ",") then
    return parse_comma_exprs(toks: pcore.skip(toks: r), acc: new_acc)
  else
    return ParsedExprs(exprs: list.reverse(xs: new_acc), rest: r)
  end
end

let parse_record_expr_fields = fn (toks: [SpannedToken], acc: [NamedExpr]) -> ParsedNamedExprs throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkRBrace -> return ParsedNamedExprs(fields: list.reverse(xs: acc), rest: toks)
    case _ ->
      let ParsedIdent(name: n, rest: r) = pcore.expect_ident(toks: toks)
      let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r, expected: ":"))
      let new_acc = NamedExpr(name: n, value: v) :: acc
      if pcore.is_tok(toks: r3, expected: ",") then
        return parse_record_expr_fields(toks: pcore.skip(toks: r3), acc: new_acc)
      else
        return ParsedNamedExprs(fields: list.reverse(xs: new_acc), rest: r3)
      end
  end
end

let parse_fn_params_or_unit = fn (toks: [SpannedToken]) -> ParsedParams throws { Exn } do
  if pcore.is_tok(toks: toks, expected: "()") then
    return ParsedParams(params: [], rest: pcore.skip(toks: toks))
  end
  let ParsedParams(params: ps, rest: r2) = parse_params(toks: pcore.expect(toks: toks, expected: "("), acc: [])
  return ParsedParams(params: ps, rest: pcore.expect(toks: r2, expected: ")"))
end

let parse_params = fn (toks: [SpannedToken], acc: [Param]) -> ParsedParams throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkRParen -> return ParsedParams(params: list.reverse(xs: acc), rest: toks)
    case _ ->
      let ParsedSigil(sigil: sig, rest: r) = pcore.parse_sigil(toks: toks)
      let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: r)
      let ParsedType(typ: t, rest: r4) = ptype.parse_type(toks: pcore.expect(toks: r2, expected: ":"))
      let new_acc = Param(name: n, sigil: sig, typ: t) :: acc
      if pcore.is_tok(toks: r4, expected: ",") then
        return parse_params(toks: pcore.skip(toks: r4), acc: new_acc)
      else
        return ParsedParams(params: list.reverse(xs: new_acc), rest: r4)
      end
  end
end

let parse_optional_type_params = fn (toks: [SpannedToken]) -> ParsedStrings throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkLt ->
      let ParsedStrings(items: ps, rest: r2) = parse_type_param_list(toks: pcore.skip(toks: toks), acc: [])
      match pcore.peek_token(toks: r2) do
        case TkGt -> return ParsedStrings(items: ps, rest: pcore.skip(toks: r2))
        case _ -> return ParsedStrings(items: [], rest: toks)
      end
    case _ -> return ParsedStrings(items: [], rest: toks)
  end
end

let parse_type_param_list = fn (toks: [SpannedToken], acc: [string]) -> ParsedStrings throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkGt -> return ParsedStrings(items: list.reverse(xs: acc), rest: toks)
    case TkUident(name: n) ->
      let r = pcore.skip(toks: toks)
      if pcore.is_tok(toks: r, expected: ",") then
        return parse_type_param_list(toks: pcore.skip(toks: r), acc: n :: acc)
      else
        return ParsedStrings(items: list.reverse(xs: n :: acc), rest: r)
      end
    case _ ->
      raise UnexpectedToken(expected: "type parameter", got: pcore.token_tag(tok: pcore.peek_token(toks: toks)), span: pcore.peek_span(toks: toks))
  end
end

// ─── Control flow expressions ────────────────────────────────────────────────

// if let <pattern> = <expr> then <body> [else <body>] end
// → desugar to match <expr> do case <pattern> -> <then> case _ -> <else> end
let parse_if_let_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let ParsedPat(pat: pat, rest: r2) = ppat.parse_pattern(toks: toks)
  let r3 = pcore.expect(toks: r2, expected: "=")
  let ParsedExpr(expr: target, rest: r4) = parse_expr(toks: r3)
  let ParsedStmts(stmts: then_body, rest: r5) = parse_stmts(toks: pcore.expect(toks: r4, expected: "then"), acc: [])
  let wildcard_pat = SpannedPattern(node: PatWildcard, span: sp)
  match pcore.peek_token(toks: r5) do
    case TkElse ->
      let ParsedStmts(stmts: else_body, rest: r7) = parse_stmts(toks: pcore.skip(toks: r5), acc: [])
      return ParsedExpr(
        expr: SpannedExpr(node: ExprMatch(target: target, cases: [
          MatchCase(pattern: pat, body: then_body),
          MatchCase(pattern: wildcard_pat, body: else_body)
        ]), span: sp),
        rest: pcore.expect(toks: r7, expected: "end"))
    case _ ->
      return ParsedExpr(
        expr: SpannedExpr(node: ExprMatch(target: target, cases: [
          MatchCase(pattern: pat, body: then_body),
          MatchCase(pattern: wildcard_pat, body: [])
        ]), span: sp),
        rest: pcore.expect(toks: r5, expected: "end"))
  end
end

let parse_if_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let r1 = pcore.expect(toks: toks, expected: "if")
  match pcore.peek_token(toks: r1) do
    case TkLet -> return parse_if_let_expr(toks: pcore.skip(toks: r1))
    case _ ->
      let ParsedExpr(expr: cond, rest: r2) = parse_expr(toks: r1)
      let ParsedStmts(stmts: then_body, rest: r4) = parse_stmts(toks: pcore.expect(toks: r2, expected: "then"), acc: [])
      match pcore.peek_token(toks: r4) do
        case TkElse ->
          let ParsedStmts(stmts: else_body, rest: r6) = parse_stmts(toks: pcore.skip(toks: r4), acc: [])
          return ParsedExpr(expr: SpannedExpr(node: ExprIf(cond: cond, then_branch: then_body, else_branch: else_body), span: sp),
            rest: pcore.expect(toks: r6, expected: "end"))
        case _ ->
          return ParsedExpr(expr: SpannedExpr(node: ExprIf(cond: cond, then_branch: then_body, else_branch: []), span: sp),
            rest: pcore.expect(toks: r4, expected: "end"))
      end
  end
end

let parse_match_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let ParsedExpr(expr: target, rest: r2) = parse_expr(toks: pcore.expect(toks: toks, expected: "match"))
  let ParsedMatchCases(cases: cs, rest: r4) = parse_match_cases(toks: pcore.expect(toks: r2, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprMatch(target: target, cases: cs), span: sp),
    rest: pcore.expect(toks: r4, expected: "end"))
end

let parse_match_cases = fn (toks: [SpannedToken], acc: [MatchCase]) -> ParsedMatchCases throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkCase ->
      let ParsedPat(pat: p, rest: r2) = ppat.parse_pattern(toks: pcore.skip(toks: toks))
      let ParsedStmts(stmts: body, rest: r4) = parse_stmts(toks: pcore.expect(toks: r2, expected: "->"), acc: [])
      return parse_match_cases(toks: r4, acc: MatchCase(pattern: p, body: body) :: acc)
    case _ -> return ParsedMatchCases(cases: list.reverse(xs: acc), rest: toks)
  end
end

let parse_while_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let ParsedExpr(expr: cond, rest: r2) = parse_expr(toks: pcore.expect(toks: toks, expected: "while"))
  let ParsedStmts(stmts: body, rest: r4) = parse_stmts(toks: pcore.expect(toks: r2, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprWhile(cond: cond, body: body), span: sp),
    rest: pcore.expect(toks: r4, expected: "end"))
end

let parse_for_expr = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let ParsedIdent(name: var, rest: r2) = pcore.expect_ident(toks: pcore.expect(toks: toks, expected: "for"))
  let ParsedExpr(expr: start_e, rest: r4) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
  let ParsedExpr(expr: end_e, rest: r6) = parse_expr(toks: pcore.expect(toks: r4, expected: "to"))
  let ParsedStmts(stmts: body, rest: r8) = parse_stmts(toks: pcore.expect(toks: r6, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(node: ExprFor(var: var, start: start_e, end_expr: end_e, body: body), span: sp),
    rest: pcore.expect(toks: r8, expected: "end"))
end

let parse_lambda = fn (toks: [SpannedToken]) -> ParsedExpr throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let ParsedStrings(items: tps, rest: r_tp) = parse_optional_type_params(toks: pcore.expect(toks: toks, expected: "fn"))
  if pcore.is_tok(toks: r_tp, expected: "()") then
    return parse_lambda_body(toks: pcore.skip(toks: r_tp), type_params: tps, params: [], sp: sp)
  end
  let ParsedParams(params: ps, rest: r3) = parse_params(toks: pcore.expect(toks: r_tp, expected: "("), acc: [])
  return parse_lambda_body(toks: pcore.expect(toks: r3, expected: ")"), type_params: tps, params: ps, sp: sp)
end

let parse_lambda_body = fn (toks: [SpannedToken], type_params: [string], params: [Param], sp: Span) -> ParsedExpr throws { Exn } do
  let ParsedType(typ: ret, rest: r6) = ptype.parse_type(toks: pcore.expect(toks: toks, expected: "->"))
  let ParsedType(typ: req, rest: r7) = ptype.parse_optional_require(toks: r6)
  let ParsedType(typ: thr, rest: r8) = ptype.parse_optional_throws(toks: r7)
  let ParsedStmts(stmts: body, rest: r10) = parse_stmts(toks: pcore.expect(toks: r8, expected: "do"), acc: [])
  return ParsedExpr(expr: SpannedExpr(
    node: ExprLambda(type_params: type_params, params: params, ret_type: ret, requires: req, throw_row: thr, body: body),
    span: sp
  ), rest: pcore.expect(toks: r10, expected: "end"))
end

// ─── Statement parsing ───────────────────────────────────────────────────────

let parse_stmts = fn (toks: [SpannedToken], acc: [SpannedStmt]) -> ParsedStmts throws { Exn } do
  if pcore.is_block_end(tok: pcore.peek_token(toks: toks)) then
    return ParsedStmts(stmts: list.reverse(xs: acc), rest: toks)
  end
  let ParsedStmt(stmt: s, rest: rest) = parse_stmt(toks: toks)
  return parse_stmts(toks: rest, acc: s :: acc)
end

let parse_stmt = fn (toks: [SpannedToken]) -> ParsedStmt throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  match pcore.peek_token(toks: toks) do
    case TkLet -> return parse_let_stmt(toks: toks)
    case TkReturn ->
      let ParsedExpr(expr: e, rest: r2) = parse_expr(toks: pcore.skip(toks: toks))
      return ParsedStmt(stmt: SpannedStmt(node: StmtReturn(value: e), span: sp), rest: r2)
    case TkTry -> return parse_try_stmt(toks: toks)
    case TkInject -> return parse_inject_stmt(toks: toks)
    case _ ->
      // Expression statement or assignment
      let ParsedExpr(expr: e, rest: r) = parse_expr(toks: toks)
      match pcore.peek_token(toks: r) do
        case TkLArrow ->
          let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.skip(toks: r))
          let target_name = match e do
            case SpannedExpr(node: ExprVariable(name: nm, sigil: _), span: _) -> rdr.rdr_to_string(r: nm)
            case _ -> "unknown"
          end
          return ParsedStmt(stmt: SpannedStmt(node: StmtAssign(target: target_name, value: v), span: sp), rest: r3)
        case _ ->
          return ParsedStmt(stmt: SpannedStmt(node: StmtExpr(expr: e), span: sp), rest: r)
      end
  end
end

let parse_let_with_type = fn (n: string, sig: Sigil, r3: [SpannedToken], sp: Span) -> ParsedStmt throws { Exn } do
  let ParsedType(typ: t, rest: r5) = ptype.parse_type(toks: pcore.skip(toks: r3))
  let ParsedExpr(expr: v, rest: r7) = parse_expr(toks: pcore.expect(toks: r5, expected: "="))
  ParsedStmt(stmt: SpannedStmt(node: StmtLet(name: n, sigil: sig, typ: Some(val: t), value: v), span: sp), rest: r7)
end

let parse_let_without_type = fn (n: string, sig: Sigil, r3: [SpannedToken], sp: Span) -> ParsedStmt throws { Exn } do
  let ParsedExpr(expr: v, rest: r5) = parse_expr(toks: pcore.expect(toks: r3, expected: "="))
  ParsedStmt(stmt: SpannedStmt(node: StmtLet(name: n, sigil: sig, typ: None, value: v), span: sp), rest: r5)
end

let parse_let_stmt = fn (toks: [SpannedToken]) -> ParsedStmt throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let r_after_let = pcore.expect(toks: toks, expected: "let")
  // Check for destructuring: let Ctor(...) = expr or let { ... } = expr
  if let TkUident(_) = pcore.peek_token(toks: r_after_let) then
    if pcore.is_tok(toks: pcore.skip(toks: r_after_let), expected: "(") then
      let ParsedPat(pat: pat, rest: r2) = ppat.parse_pattern(toks: r_after_let)
      let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
      return ParsedStmt(stmt: SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp), rest: r3)
    end
  end
  if let TkLBrace = pcore.peek_token(toks: r_after_let) then
    let ParsedPat(pat: pat, rest: r2) = ppat.parse_pattern(toks: r_after_let)
    let ParsedExpr(expr: v, rest: r3) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
    return ParsedStmt(stmt: SpannedStmt(node: StmtLetPattern(pattern: pat, value: v), span: sp), rest: r3)
  end
  let ParsedSigil(sigil: sig, rest: r2) = pcore.parse_sigil(toks: r_after_let)
  let ParsedIdent(name: n, rest: r3) = pcore.expect_ident(toks: r2)
  match pcore.is_tok(toks: r3, expected: ":") do
    case true -> parse_let_with_type(n: n, sig: sig, r3: r3, sp: sp)
    case false -> parse_let_without_type(n: n, sig: sig, r3: r3, sp: sp)
  end
end

let parse_try_stmt = fn (toks: [SpannedToken]) -> ParsedStmt throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let ParsedStmts(stmts: body, rest: r2) = parse_stmts(toks: pcore.expect(toks: toks, expected: "try"), acc: [])
  let r_after_catch = pcore.expect(toks: r2, expected: "catch")
  match pcore.peek_token(toks: r_after_catch) do
    case TkCase ->
      // Selective catch: catch case Pattern -> body case Pattern -> body ...
      let ParsedCatchArms(arms: arms, rest: r4) = parse_catch_arms(toks: r_after_catch, acc: [])
      return ParsedStmt(stmt: SpannedStmt(node: StmtTry(body: body, catch_arms: arms), span: sp),
        rest: pcore.expect(toks: r4, expected: "end"))
    case _ ->
      // Legacy catch: catch param -> body
      let ParsedIdent(name: param, rest: r4) = pcore.expect_ident(toks: r_after_catch)
      let ParsedStmts(stmts: catch_body, rest: r6) = parse_stmts(toks: pcore.expect(toks: r4, expected: "->"), acc: [])
      let arm = CatchArm(pattern: SpannedPattern(node: PatVariable(name: param, sigil: SigilImmutable), span: sp), body: catch_body)
      return ParsedStmt(stmt: SpannedStmt(node: StmtTry(body: body, catch_arms: [arm]), span: sp),
        rest: pcore.expect(toks: r6, expected: "end"))
  end
end

let parse_catch_arms = fn (toks: [SpannedToken], acc: [CatchArm]) -> ParsedCatchArms throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkCase ->
      let ParsedPat(pat: p, rest: r2) = ppat.parse_pattern(toks: pcore.skip(toks: toks))
      let ParsedStmts(stmts: arm_body, rest: r4) = parse_stmts(toks: pcore.expect(toks: r2, expected: "->"), acc: [])
      return parse_catch_arms(toks: r4, acc: CatchArm(pattern: p, body: arm_body) :: acc)
    case _ -> return ParsedCatchArms(arms: list.reverse(xs: acc), rest: toks)
  end
end

let parse_inject_stmt = fn (toks: [SpannedToken]) -> ParsedStmt throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  // Parse handler names as dotted identifiers, producing ExprVariable with dotted name.
  let ParsedExprs(exprs: hs, rest: r2) = parse_inject_handlers(toks: pcore.expect(toks: toks, expected: "inject"), acc: [])
  let ParsedStmts(stmts: body, rest: r4) = parse_stmts(toks: pcore.expect(toks: r2, expected: "do"), acc: [])
  return ParsedStmt(stmt: SpannedStmt(node: StmtInject(handlers: hs, body: body), span: sp),
    rest: pcore.expect(toks: r4, expected: "end"))
end

/// Parse comma-separated dotted handler names: "a.b, c.d, ..." → [ExprVariable("a.b"), ExprVariable("c.d")]
let parse_inject_handlers = fn (toks: [SpannedToken], acc: [SpannedExpr]) -> ParsedExprs throws { Exn } do
  let ParsedIdent(name: first, rest: r1) = parse_handler_dotted(toks: toks)
  let sp = pcore.peek_span(toks: toks)
  let expr = SpannedExpr(node: ExprVariable(name: rdr.rdr_from_dotted(s: first), sigil: SigilImmutable), span: sp)
  match pcore.peek_token(toks: r1) do
    case TkComma ->
      return parse_inject_handlers(toks: pcore.skip(toks: r1), acc: expr :: acc)
    case _ ->
      // Order doesn't matter for inject handler names
      return ParsedExprs(exprs: expr :: acc, rest: r1)
  end
end

/// Parse a dotted name like "a.b.c" → "a.b.c"
let parse_handler_dotted = fn (toks: [SpannedToken]) -> ParsedIdent throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkIdent(name: name) ->
      let r1 = pcore.skip(toks: toks)
      match pcore.peek_token(toks: r1) do
        case TkDot ->
          let ParsedIdent(name: rest_name, rest: r2) = parse_handler_dotted(toks: pcore.skip(toks: r1))
          return ParsedIdent(name: name ++ "." ++ rest_name, rest: r2)
        case _ -> return ParsedIdent(name: name, rest: r1)
      end
    case _ -> raise UnexpectedToken(expected: "handler name", got: pcore.token_tag(tok: pcore.peek_token(toks: toks)), span: pcore.peek_span(toks: toks))
  end
end

// ─── Top-level parsing ───────────────────────────────────────────────────────

let parse_import_path = fn (toks: [SpannedToken]) -> ParsedIdent throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkString(val: s) -> return ParsedIdent(name: s, rest: pcore.skip(toks: toks))
    case _ -> raise UnexpectedToken(expected: "quoted import path", got: pcore.token_tag(tok: pcore.peek_token(toks: toks)), span: pcore.peek_span(toks: toks))
  end
end

let parse_import_item_with_alias = fn (n: string, r: [SpannedToken], acc: [ImportItem]) -> ParsedImportItems throws { Exn } do
  match pcore.peek_token(toks: r) do
    case TkAs ->
      let ParsedIdent(name: a, rest: r2) = pcore.expect_ident(toks: pcore.skip(toks: r))
      let item = ImportItem(name: n, item_alias: Some(val: a))
      match pcore.is_tok(toks: r2, expected: ",") do
        case true -> return parse_import_items(toks: pcore.skip(toks: r2), acc: item :: acc)
        case false -> return ParsedImportItems(items: list.reverse(xs: item :: acc), rest: r2)
      end
    case _ ->
      let item = ImportItem(name: n, item_alias: None)
      match pcore.is_tok(toks: r, expected: ",") do
        case true -> return parse_import_items(toks: pcore.skip(toks: r), acc: item :: acc)
        case false -> return ParsedImportItems(items: list.reverse(xs: item :: acc), rest: r)
      end
  end
end

let parse_import_items = fn (toks: [SpannedToken], acc: [ImportItem]) -> ParsedImportItems throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkRBrace -> return ParsedImportItems(items: list.reverse(xs: acc), rest: toks)
    case TkIdent(name: n) -> return parse_import_item_with_alias(n: n, r: pcore.skip(toks: toks), acc: acc)
    case TkUident(name: n) -> return parse_import_item_with_alias(n: n, r: pcore.skip(toks: toks), acc: acc)
    case _ -> raise UnexpectedToken(expected: "import item", got: pcore.token_tag(tok: pcore.peek_token(toks: toks)), span: pcore.peek_span(toks: toks))
  end
end

let parse_import = fn (toks: [SpannedToken]) -> ParsedTopLevel throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let r = pcore.expect(toks: toks, expected: "import")
  match pcore.peek_token(toks: r) do
    case TkExternal ->
      let ParsedIdent(name: p, rest: r3) = parse_import_path(toks: pcore.skip(toks: r))
      return ParsedTopLevel(item: SpannedTopLevel(node: TLImport(def: ImportDef(path: p, alias: None, items: [], is_external: true)), span: sp), rest: r3)
    case TkLBrace ->
      let ParsedImportItems(items: items, rest: r3) = parse_import_items(toks: pcore.skip(toks: r), acc: [])
      let r4 = pcore.expect(toks: r3, expected: "}")
      if pcore.is_tok(toks: r4, expected: ",") then
        let ParsedIdent(name: a, rest: r7) = pcore.expect_ident(toks: pcore.expect(toks: pcore.expect(toks: pcore.skip(toks: r4), expected: "*"), expected: "as"))
        let ParsedIdent(name: p, rest: r9) = parse_import_path(toks: pcore.expect(toks: r7, expected: "from"))
        return ParsedTopLevel(item: SpannedTopLevel(node: TLImport(def: ImportDef(path: p, alias: Some(val: a), items: items, is_external: false)), span: sp), rest: r9)
      else
        let ParsedIdent(name: p, rest: r6) = parse_import_path(toks: pcore.expect(toks: r4, expected: "from"))
        return ParsedTopLevel(item: SpannedTopLevel(node: TLImport(def: ImportDef(path: p, alias: None, items: items, is_external: false)), span: sp), rest: r6)
      end
    case TkStar ->
      let ParsedIdent(name: a, rest: r3) = pcore.expect_ident(toks: pcore.expect(toks: pcore.skip(toks: r), expected: "as"))
      let ParsedIdent(name: p, rest: r5) = parse_import_path(toks: pcore.expect(toks: r3, expected: "from"))
      return ParsedTopLevel(item: SpannedTopLevel(node: TLImport(def: ImportDef(path: p, alias: Some(val: a), items: [], is_external: false)), span: sp), rest: r5)
    case TkAs ->
      let ParsedIdent(name: a, rest: r3) = pcore.expect_ident(toks: pcore.skip(toks: r))
      let ParsedIdent(name: p, rest: r5) = parse_import_path(toks: pcore.expect(toks: r3, expected: "from"))
      return ParsedTopLevel(item: SpannedTopLevel(node: TLImport(def: ImportDef(path: p, alias: Some(val: a), items: [], is_external: false)), span: sp), rest: r5)
    case TkFrom ->
      let ParsedIdent(name: p, rest: r3) = parse_import_path(toks: pcore.skip(toks: r))
      return ParsedTopLevel(item: SpannedTopLevel(node: TLImport(def: ImportDef(path: p, alias: None, items: [], is_external: false)), span: sp), rest: r3)
    case _ ->
      raise UnexpectedToken(expected: "'import' clause ('{'/'as'/'from'/'external')", got: pcore.token_tag(tok: pcore.peek_token(toks: r)), span: pcore.peek_span(toks: r))
  end
end

let parse_type_def = fn (toks: [SpannedToken], is_pub: bool) -> ParsedTopLevel throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let is_opaque = pcore.is_tok(toks: toks, expected: "opaque")
  let r_after_opaque = match pcore.peek_token(toks: toks) do
    case TkOpaque -> pcore.skip(toks: toks)
    case _ -> toks
  end
  let ParsedIdent(name: n, rest: r3) = pcore.expect_uident(toks: pcore.expect(toks: r_after_opaque, expected: "type"))
  let ParsedStrings(items: tps, rest: r4) = parse_optional_type_params(toks: r3)
  let r5 = pcore.expect(toks: r4, expected: "=")
  match pcore.peek_token(toks: r5) do
    case TkLBrace ->
      let ParsedNamedTypes(fields: fs, rest: r7) = ptype.parse_record_type_fields(toks: pcore.skip(toks: r5), acc: [])
      return ParsedTopLevel(item: SpannedTopLevel(node: TLTypeDef(def: RecordDef(name: n, is_public: is_pub, type_params: tps, fields: fs)), span: sp),
        rest: pcore.expect(toks: r7, expected: "}"))
    case _ ->
      let ParsedVariants(variants: vs, rest: r6) = parse_enum_variants(toks: r5, acc: [])
      return ParsedTopLevel(item: SpannedTopLevel(node: TLEnum(def: EnumDef(name: n, is_public: is_pub, is_opaque: is_opaque, type_params: tps, variants: vs)), span: sp), rest: r6)
  end
end

let continue_or_finish_variants = fn (toks: [SpannedToken], acc: [VariantDef]) -> ParsedVariants throws { Exn } do
  match pcore.is_tok(toks: toks, expected: "|") do
    case true -> parse_enum_variants(toks: pcore.skip(toks: toks), acc: acc)
    case false -> ParsedVariants(variants: list.reverse(xs: acc), rest: toks)
  end
end

let parse_enum_variants = fn (toks: [SpannedToken], acc: [VariantDef]) -> ParsedVariants throws { Exn } do
  let ParsedIdent(name: n, rest: r) = pcore.expect_uident(toks: toks)
  match pcore.is_tok(toks: r, expected: "(") do
    case true ->
      let ParsedVariantFields(fields: fs, rest: r3) = parse_variant_fields(toks: pcore.skip(toks: r), acc: [])
      let r4 = pcore.expect(toks: r3, expected: ")")
      let new_acc = VariantDef(name: n, fields: fs) :: acc
      continue_or_finish_variants(toks: r4, acc: new_acc)
    case false ->
      let new_acc = VariantDef(name: n, fields: []) :: acc
      continue_or_finish_variants(toks: r, acc: new_acc)
  end
end

let parse_variant_fields = fn (toks: [SpannedToken], acc: [VariantField]) -> ParsedVariantFields throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkRParen -> return ParsedVariantFields(fields: list.reverse(xs: acc), rest: toks)
    case _ ->
      if pcore.is_labeled_field(toks: toks) then
        let ParsedIdent(name: n, rest: r) = pcore.expect_ident(toks: toks)
        let ParsedType(typ: t, rest: r3) = ptype.parse_type(toks: pcore.expect(toks: r, expected: ":"))
        let new_acc = VariantField(name: Some(val: n), typ: t) :: acc
        if pcore.is_tok(toks: r3, expected: ",") then
          return parse_variant_fields(toks: pcore.skip(toks: r3), acc: new_acc)
        else
          return ParsedVariantFields(fields: list.reverse(xs: new_acc), rest: r3)
        end
      else
        let ParsedType(typ: t, rest: r) = ptype.parse_type(toks: toks)
        let new_acc = VariantField(name: None, typ: t) :: acc
        if pcore.is_tok(toks: r, expected: ",") then
          return parse_variant_fields(toks: pcore.skip(toks: r), acc: new_acc)
        else
          return ParsedVariantFields(fields: list.reverse(xs: new_acc), rest: r)
        end
      end
  end
end

let parse_global_let_typed = fn (n: string, is_pub: bool, r2: [SpannedToken], sp: Span) -> ParsedTopLevel throws { Exn } do
  let ParsedType(typ: t, rest: r4) = ptype.parse_type(toks: pcore.skip(toks: r2))
  let ParsedExpr(expr: v, rest: r6) = parse_expr(toks: pcore.expect(toks: r4, expected: "="))
  ParsedTopLevel(item: SpannedTopLevel(node: TLLet(def: GlobalLet(name: n, is_public: is_pub, typ: Some(val: t), value: v)), span: sp), rest: r6)
end

let parse_global_let_untyped = fn (n: string, is_pub: bool, r2: [SpannedToken], sp: Span) -> ParsedTopLevel throws { Exn } do
  let ParsedExpr(expr: v, rest: r4) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
  ParsedTopLevel(item: SpannedTopLevel(node: TLLet(def: GlobalLet(name: n, is_public: is_pub, typ: None, value: v)), span: sp), rest: r4)
end

let parse_global_let = fn (toks: [SpannedToken], is_pub: bool) -> ParsedTopLevel throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.expect(toks: toks, expected: "let"))
  match pcore.is_tok(toks: r2, expected: ":") do
    case true -> parse_global_let_typed(n: n, is_pub: is_pub, r2: r2, sp: sp)
    case false -> parse_global_let_untyped(n: n, is_pub: is_pub, r2: r2, sp: sp)
  end
end

let parse_exception_def = fn (toks: [SpannedToken], is_pub: bool) -> ParsedTopLevel throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let after_exception = pcore.expect(toks: toks, expected: "exception")
  // Check for "exception group Name = E1 | E2 | ..."
  match pcore.peek_token(toks: after_exception) do
    case TkIdent(name: g) ->
      if g == "group" then
        return parse_exception_group_def(toks: pcore.skip(toks: after_exception), is_pub: is_pub, sp: sp)
      else
        let ParsedIdent(name: n, rest: r2) = pcore.expect_uident(toks: after_exception)
        return parse_exception_fields(n: n, is_pub: is_pub, r2: r2, sp: sp)
      end
    case _ ->
      let ParsedIdent(name: n, rest: r2) = pcore.expect_uident(toks: after_exception)
      return parse_exception_fields(n: n, is_pub: is_pub, r2: r2, sp: sp)
  end
end

let parse_exception_fields = fn (n: string, is_pub: bool, r2: [SpannedToken], sp: Span) -> ParsedTopLevel throws { Exn } do
  if pcore.is_tok(toks: r2, expected: "(") then
    let ParsedVariantFields(fields: fs, rest: r4) = parse_variant_fields(toks: pcore.skip(toks: r2), acc: [])
    return ParsedTopLevel(item: SpannedTopLevel(node: TLException(def: ExceptionDef(name: n, is_public: is_pub, fields: fs)), span: sp),
      rest: pcore.expect(toks: r4, expected: ")"))
  else
    return ParsedTopLevel(item: SpannedTopLevel(node: TLException(def: ExceptionDef(name: n, is_public: is_pub, fields: [])), span: sp), rest: r2)
  end
end

let parse_exception_group_def = fn (toks: [SpannedToken], is_pub: bool, sp: Span) -> ParsedTopLevel throws { Exn } do
  let ParsedIdent(name: n, rest: r2) = pcore.expect_uident(toks: toks)
  let ParsedStrings(items: members, rest: r4) = parse_group_members(toks: pcore.expect(toks: r2, expected: "="), acc: [])
  return ParsedTopLevel(item: SpannedTopLevel(node: TLExceptionGroup(def: ExceptionGroupDef(name: n, is_public: is_pub, members: members)), span: sp), rest: r4)
end

let parse_group_members = fn (toks: [SpannedToken], acc: [string]) -> ParsedStrings throws { Exn } do
  let ParsedIdent(name: m, rest: r2) = pcore.expect_uident(toks: toks)
  let new_acc = m :: acc
  if pcore.is_tok(toks: r2, expected: "|") then
    return parse_group_members(toks: pcore.skip(toks: r2), acc: new_acc)
  else
    return ParsedStrings(items: list.reverse(xs: new_acc), rest: r2)
  end
end

let parse_port_def = fn (toks: [SpannedToken], is_pub: bool) -> ParsedTopLevel throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let ParsedIdent(name: n, rest: r2) = pcore.expect_uident(toks: pcore.expect(toks: toks, expected: "port"))
  let ParsedFunctionSigs(sigs: fs, rest: r4) = parse_port_sigs(toks: pcore.expect(toks: r2, expected: "do"), acc: [])
  return ParsedTopLevel(item: SpannedTopLevel(node: TLPort(def: Port(name: n, is_public: is_pub, functions: fs)), span: sp),
    rest: pcore.expect(toks: r4, expected: "end"))
end

let parse_port_sigs = fn (toks: [SpannedToken], acc: [FunctionSig]) -> ParsedFunctionSigs throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkFn ->
      let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.skip(toks: toks))
      let ParsedParams(params: ps, rest: r5) = parse_fn_params_or_unit(toks: r2)
      let ParsedType(typ: ret, rest: r7) = ptype.parse_type(toks: pcore.expect(toks: r5, expected: "->"))
      let ParsedType(typ: req, rest: r8) = ptype.parse_optional_require(toks: r7)
      let ParsedType(typ: thr, rest: r9) = ptype.parse_optional_throws(toks: r8)
      let sig = FunctionSig(name: n, params: ps, ret_type: ret, requires: req, throw_row: thr)
      return parse_port_sigs(toks: r9, acc: sig :: acc)
    case _ -> return ParsedFunctionSigs(sigs: list.reverse(xs: acc), rest: toks)
  end
end

type ParsedExternalSig = ParsedExternalSig(params: [NamedType], arg_names: [string], ret: TypeExpr, rest: [SpannedToken])
type ParsedExternalParams = ParsedExternalParams(params: [NamedType], names: [string], rest: [SpannedToken])

let parse_external_def = fn (toks: [SpannedToken], is_pub: bool) -> ParsedTopLevel throws { Exn } do
  let sp = pcore.peek_span(toks: toks)
  let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.expect(toks: toks, expected: "external"))
  let r3 = pcore.expect(toks: r2, expected: "=")
  match pcore.peek_token(toks: r3) do
    case TkString(val: symbol) ->
      let ParsedExternalSig(params: params, arg_names: arg_names, ret: ret, rest: r6) = parse_external_sig(toks: pcore.expect(toks: pcore.skip(toks: r3), expected: ":"))
      let t = TyArrow(params: params, ret: ret, requires: ptype.empty_row(), throw_row: ptype.empty_row())
      let def = GlobalLet(
        name: n, is_public: is_pub, typ: Some(val: t),
        value: SpannedExpr(node: ExprExternal(symbol: symbol, arg_names: arg_names, typ: t), span: sp)
      )
      return ParsedTopLevel(item: SpannedTopLevel(node: TLLet(def: def), span: sp), rest: r6)
    case _ ->
      raise UnexpectedToken(expected: "string literal for external symbol", got: pcore.token_tag(tok: pcore.peek_token(toks: r3)), span: pcore.peek_span(toks: r3))
  end
end

let parse_external_sig = fn (toks: [SpannedToken]) -> ParsedExternalSig throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkUnit ->
      let ParsedType(typ: ret, rest: r3) = ptype.parse_type(toks: pcore.expect(toks: pcore.skip(toks: toks), expected: "->"))
      return ParsedExternalSig(params: [], arg_names: [], ret: ret, rest: r3)
    case _ ->
      let ParsedExternalParams(params: ps, names: ns, rest: r2) = parse_external_params(toks: pcore.expect(toks: toks, expected: "("), acc_params: [], acc_names: [])
      let ParsedType(typ: ret, rest: r5) = ptype.parse_type(toks: pcore.expect(toks: pcore.expect(toks: r2, expected: ")"), expected: "->"))
      return ParsedExternalSig(params: ps, arg_names: ns, ret: ret, rest: r5)
  end
end

let parse_external_params = fn (toks: [SpannedToken], acc_params: [NamedType], acc_names: [string]) -> ParsedExternalParams throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkRParen -> return ParsedExternalParams(params: list.reverse(xs: acc_params), names: list.reverse(xs: acc_names), rest: toks)
    case _ ->
      let ParsedIdent(name: n, rest: r) = pcore.expect_ident(toks: toks)
      let ParsedType(typ: t, rest: r3) = ptype.parse_type(toks: pcore.expect(toks: r, expected: ":"))
      let new_params = NamedType(name: n, typ: t) :: acc_params
      let new_names = n :: acc_names
      if pcore.is_tok(toks: r3, expected: ",") then
        return parse_external_params(toks: pcore.skip(toks: r3), acc_params: new_params, acc_names: new_names)
      else
        return ParsedExternalParams(params: list.reverse(xs: new_params), names: list.reverse(xs: new_names), rest: r3)
      end
  end
end

let parse_top_level = fn (toks: [SpannedToken]) -> ParsedTopLevel throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkImport -> return parse_import(toks: toks)
    case TkPub ->
      let r = pcore.skip(toks: toks)
      match pcore.peek_token(toks: r) do
        case TkType -> return parse_type_def(toks: r, is_pub: true)
        case TkOpaque -> return parse_type_def(toks: r, is_pub: true)
        case TkLet -> return parse_global_let(toks: r, is_pub: true)
        case TkException -> return parse_exception_def(toks: r, is_pub: true)
        case TkPort -> return parse_port_def(toks: r, is_pub: true)
        case TkExternal -> return parse_external_def(toks: r, is_pub: true)
        case _ ->
          raise UnexpectedToken(expected: "definition after 'export'", got: pcore.token_tag(tok: pcore.peek_token(toks: r)), span: pcore.peek_span(toks: r))
      end
    case TkType -> return parse_type_def(toks: toks, is_pub: false)
    case TkOpaque -> return parse_type_def(toks: toks, is_pub: false)
    case TkLet -> return parse_global_let(toks: toks, is_pub: false)
    case TkException -> return parse_exception_def(toks: toks, is_pub: false)
    case TkPort -> return parse_port_def(toks: toks, is_pub: false)
    case TkExternal -> return parse_external_def(toks: toks, is_pub: false)
    case _ ->
      raise UnexpectedToken(expected: "top-level definition", got: pcore.token_tag(tok: pcore.peek_token(toks: toks)), span: pcore.peek_span(toks: toks))
  end
end

// ─── Entry point ─────────────────────────────────────────────────────────────

let parse_program_loop = fn (toks: [SpannedToken], acc: [SpannedTopLevel]) -> Program throws { Exn } do
  match pcore.peek_token(toks: toks) do
    case TkEof -> return Program(definitions: list.reverse(xs: acc))
    case _ ->
      let ParsedTopLevel(item: item, rest: r) = parse_top_level(toks: toks)
      return parse_program_loop(toks: r, acc: item :: acc)
  end
end

/// Parse a token list into a Program AST.
export let parse = fn (tokens: [SpannedToken]) -> Program throws { Exn } do
  return parse_program_loop(toks: tokens, acc: [])
end
