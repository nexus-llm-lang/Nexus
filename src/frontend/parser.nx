/**
 * parser: Recursive-descent parser — public entry point + top-level parsing.
 *
 * Owns:
 * - Top-level parsing (import, export, let, type, cap, exception, external)
 * - The public `parse` / `parse_source` entries used by main.nx / imports.nx
 * - Error-recovery driver (`parse_collect` / `parse_source_collect`) that
 *   accumulates structured diagnostics across a whole file in one pass
 *
 * Expression / statement parsing — the mutually-recursive recursive-descent
 * core — lives in src/frontend/parser/core.nx. `parse_global_let` stays here
 * (rather than in parser/topdef.nx) because its initializer calls `parse_expr`,
 * and routing it through core keeps the top-level driver in one place.
 *
 * Does not own:
 * - Token types or span (see src/syntax/token.nx)
 * - Token-level primitives: peek, expect, skip, binop precedence
 *   (see src/frontend/parser/util.nx)
 * - Type-expression parsing (see src/frontend/parser/type.nx)
 * - Pattern parsing (see src/frontend/parser/pattern.nx)
 * - Expression / statement parsing (see src/frontend/parser/core.nx)
 * - Lexing (see src/frontend/lexer.nx)
 */

import { Span } from "src/types/span.nx"
import { SpannedToken } from "src/syntax/token.nx"
import { SpannedTopLevel, GlobalLet, Program } from "src/syntax/ast.nx"
import { extract_module_doc, tokenize } from "src/frontend/lexer.nx"
import {
  UnexpectedToken,
  ParseError,
  CompilerDiagnostic,
  diagnostic_from_exn
} from "src/diagnostics/error.nx"
import { ParsedType, ParsedExpr, ParsedTopLevel }, * as pcore from "src/frontend/parser/util.nx"
import * as ptype from "src/frontend/parser/type.nx"
import { parse_expr } from "src/frontend/parser/core.nx"
import {
  parse_import,
  parse_type_def,
  parse_exception_def,
  parse_cap_def,
  parse_external_def
} from "src/frontend/parser/topdef.nx"
import * as list from "std:list"
import * as str from "std:str"

// Import / type / exception / cap / external parsers live in
// src/frontend/parser/topdef.nx. parse_global_let stays here, alongside the
// public entry, because its initializer calls parse_expr from parser/core.nx.

let parse_global_let_typed = fn (
  n: string,
  is_pub: bool,
  r2: [ SpannedToken ],
  sp: Span
) -> ParsedTopLevel throws { ParseError } do
  let ParsedType(typ: t, rest: r4) = ptype.parse_type(toks: pcore.skip(toks: r2))
  let ParsedExpr(expr: v, rest: r6) = parse_expr(toks: pcore.expect(toks: r4, expected: "="))
  return ParsedTopLevel(
    item: SpannedTopLevel(
      node: TLLet(def: GlobalLet(name: n, is_public: is_pub, typ: Some(val: t), value: v)),
      span: sp
    ),
    rest: r6
  )
end

let parse_global_let_untyped = fn (
  n: string,
  is_pub: bool,
  r2: [ SpannedToken ],
  sp: Span
) -> ParsedTopLevel throws { ParseError } do
  let ParsedExpr(expr: v, rest: r4) = parse_expr(toks: pcore.expect(toks: r2, expected: "="))
  return ParsedTopLevel(
    item: SpannedTopLevel(
      node: TLLet(def: GlobalLet(name: n, is_public: is_pub, typ: None, value: v)),
      span: sp
    ),
    rest: r4
  )
end

let parse_global_let = fn (
  toks: [ SpannedToken ],
  is_pub: bool
) -> ParsedTopLevel throws { ParseError } do
  let sp = pcore.peek_span(toks)
  let ParsedIdent(name: n, rest: r2) = pcore.expect_ident(toks: pcore.expect(toks, expected: "let"))
  return if pcore.is_tok(toks: r2, expected: ":") then
    parse_global_let_typed(n, is_pub, r2, sp)
  else
    parse_global_let_untyped(n, is_pub, r2, sp)
  end
end

let parse_top_level = fn (toks: [ SpannedToken ]) -> ParsedTopLevel throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkImport -> return parse_import(toks)
    | TkPub ->
      let r = pcore.skip(toks)
      match pcore.peek_token(toks: r) do
        | TkType | TkOpaque -> return parse_type_def(toks: r, is_pub: true)
        | TkLet -> return parse_global_let(toks: r, is_pub: true)
        | TkException -> return parse_exception_def(toks: r, is_pub: true)
        | TkCap -> return parse_cap_def(toks: r, is_pub: true)
        | TkExternal -> return parse_external_def(toks: r, is_pub: true)
        | _ ->
          throw UnexpectedToken(
            expected: "definition after 'export'",
            got: pcore.token_tag(tok: pcore.peek_token(toks: r)),
            span: pcore.peek_span(toks: r)
          )
      end
    | TkType | TkOpaque -> return parse_type_def(toks, is_pub: false)
    | TkLet -> return parse_global_let(toks, is_pub: false)
    | TkException -> return parse_exception_def(toks, is_pub: false)
    | TkCap -> return parse_cap_def(toks, is_pub: false)
    | TkExternal -> return parse_external_def(toks, is_pub: false)
    | _ ->
      throw UnexpectedToken(
        expected: "top-level definition",
        got: pcore.token_tag(tok: pcore.peek_token(toks)),
        span: pcore.peek_span(toks)
      )
  end
end

let parse_program_loop = fn (
  toks: [ SpannedToken ],
  acc: [ SpannedTopLevel ]
) -> Program throws { ParseError } do
  match pcore.peek_token(toks) do
    | TkEof -> return Program(definitions: list.reverse(xs: acc), module_doc: None)
    | _ ->
      let ParsedTopLevel(item, rest: r) = parse_top_level(toks)
      return parse_program_loop(toks: r, acc: item :: acc)
  end
end

/** Parse a token list into a Program AST. Module-level doc (`module_doc`)
 *  is left as `None`; callers that have the original source text should use
 *  `parse_source` instead so the field reflects a leading `/** ... */`
 *  block when present.
 */
export let parse = fn (tokens: [ SpannedToken ]) -> Program throws { ParseError } do
  return parse_program_loop(toks: tokens, acc: [])
end

/** Parse source text directly: tokenize + parse, and populate
 *  `Program.module_doc` from the file's leading `/** ... */` block (if any).
 *  Single entry point for callers (LSP handlers, future formatter) that
 *  need the doc trivia preserved alongside the AST.
 */
export let parse_source = fn (src: string) -> Program throws { ParseError } do
  let tokens = tokenize(src)
  let prog = parse_program_loop(toks: tokens, acc: [])
  let doc = extract_module_doc(src)
  let Program(definitions: defs, module_doc: _) = prog
  return Program(definitions: defs, module_doc: doc)
end

//
// `parse` aborts on the first ParseError. For LLM-driven workflows it is much
// more useful to surface every parse error in a file in a single pass so a
// caller can fix N bugs per round-trip. `parse_collect` runs the per-decl
// loop under a try/catch, accumulating formatted diagnostics on failure and
// resynchronising at the next top-level-start token at column 1.
//
// Recovery cap: at `max_diags` accumulated errors the loop aborts with a
// final "too many parse errors" diagnostic to keep cascade explosions from
// drowning the real signal.

/** CompilerDiagnostics carry structured `CompilerDiagnostic` records (see
 *  `src/diagnostics/error.nx`). Renaming from `[string]` to `[CompilerDiagnostic]`
 * lets callers render either the human text path via
 *  `format_error` or the JSON path via `format_diagnostic_json` without
 *  needing to re-parse the error. The `file` field is threaded through
 *  `parse_collect` so each CompilerDiagnostic knows its source path.
 */
export type ParseDiagnostics = ParseDiagnostics(prog: Program, diags: [ CompilerDiagnostic ])

let max_parse_diags = 50

/** Synthetic CompilerDiagnostic for the recovery-cap trailer. Spanless (line=0,
 *  column=0); the cap is a meta-diagnostic, not tied to a token.
 */
let cap_diagnostic = fn (file: string) -> CompilerDiagnostic do
  return CompilerDiagnostic(
    code: "E1003",
    severity: "error",
    file,
    line: 0,
    column: 0,
    message: "parse error: too many parse errors (cap = " ++ str.from_i64(val: max_parse_diags) ++ "); aborting recovery"
  )
end

/** Inner recovery loop. `n_diags` is the running count so the cap can
 *  trigger before we attempt yet another flailing parse_top_level.
 */
let parse_collect_loop = fn (
  toks: [ SpannedToken ],
  acc: [ SpannedTopLevel ],
  diags: [ CompilerDiagnostic ],
  n_diags: i64,
  file: string
) -> ParseDiagnostics do
  match pcore.peek_token(toks) do
    | TkEof -> return ParseDiagnostics(
      prog: Program(definitions: list.reverse(xs: acc), module_doc: None),
      diags: list.reverse(xs: diags)
    )
    | _ -> ()
  end
  if n_diags >= max_parse_diags then
    return ParseDiagnostics(
      prog: Program(definitions: list.reverse(xs: acc), module_doc: None),
      diags: list.reverse(xs: cap_diagnostic(file) :: diags)
    )
  end
  try
    let ParsedTopLevel(item, rest: r) = parse_top_level(toks)
    return parse_collect_loop(toks: r, acc: item :: acc, diags, n_diags, file)
  catch e ->
    let diag = diagnostic_from_exn(err: e, file)
    // Recovery: drop tokens until we reach the next col-1 top-level start
    // (or EOF). `started: false` lets the helper consume at least one token
    // even when the failure points at a col-1 keyword (e.g. `let` with a
    // malformed body) so the loop cannot livelock on the same input.
    let r2 = pcore.recover_to_top_level(toks, started: false)
    return parse_collect_loop(toks: r2, acc, diags: diag :: diags, n_diags: n_diags + 1, file)
  end
end

/** Parse with error recovery: returns the partial Program plus a list of
 *  structured CompilerDiagnostics. Empty diag list means the parse was clean and
 *  the Program is equivalent to `parse(tokens)`. The `file` argument is
 *  stored in each CompilerDiagnostic for downstream JSON serialization; pass
 *  empty string when the caller doesn't have one (LSP, unit tests).
 */
export let parse_collect = fn (tokens: [ SpannedToken ], file: string) -> ParseDiagnostics do
  return parse_collect_loop(toks: tokens, acc: [], diags: [], n_diags: 0, file)
end

/** Source-text variant of `parse_collect`. Populates `Program.module_doc`
 *  from the file's leading `/** ... */` block exactly like `parse_source`.
 */
export let parse_source_collect = fn (src: string, file: string) -> ParseDiagnostics do
  let tokens = tokenize(src)
  let ParseDiagnostics(prog, diags) = parse_collect(tokens, file)
  let doc = extract_module_doc(src)
  let Program(definitions: defs, module_doc: _) = prog
  return ParseDiagnostics(prog: Program(definitions: defs, module_doc: doc), diags)
end
