/**
 * suppress: post-filter lint findings by inline comment directives.
 *
 * Comments are stripped at lex time, so directives never reach the AST.
 * This module re-scans the raw source text to extract directives, then
 * filters the findings list produced by lint_program.
 *
 * Directive syntax (on any line of the source file):
 *   // lint:allow L0001           suppress that code on the SAME line
 *   // lint:allow-next L0001      suppress that code on the NEXT line
 *   // lint:allow-file L0001      suppress that code for the whole file
 *   // lint:allow L0001, L0002    comma-separated list of codes
 *   // lint:allow                 bare form — suppresses ALL codes on the line
 *
 * A directive is honoured only when it appears inside a COMMENT (`//` or
 * `/* */`), anywhere in the line — so `some_call() // lint:allow L0001` works,
 * but the same text inside a string/char literal is treated as program DATA
 * and does NOT disarm any rule (a literal cannot silently disable gating).
 *
 * Suppression is applied ONLY to findings whose span.line matches the target
 * line (on-line or allow-next) or whose code is in the file-wide set.
 */

import * as str from "std:str"
import * as list from "std:list"
import { Span } from "src/types/span.nx"
import { LintFinding } from "src/lint/types.nx"

// ─── Directive parsing ───────────────────────────────────────────────────────

// Prefix tokens
let prefix_allow = fn () -> string do return "lint:allow" end
let prefix_allow_next = fn () -> string do return "lint:allow-next" end
let prefix_allow_file = fn () -> string do return "lint:allow-file" end

// Extract the code-list portion of a directive line, given the portion of
// the line after the prefix keyword. E.g. for "lint:allow L0001, L0002" the
// tail is " L0001, L0002". Returns a list of trimmed code strings, or []
// for a bare directive (meaning "all codes").
let parse_code_list = fn (tail: string) -> [ string ] do
  let t = str.trim(s: tail)
  if str.length(s: t) == 0 then return [] end
  let parts = str.split(s: t, sep: ",")
  return trim_parts(xs: parts, acc: [])
end

let trim_parts = fn (xs: [ string ], acc: [ string ]) -> [ string ] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | p :: rest ->
      let trimmed = str.trim(s: p)
      if str.length(s: trimmed) == 0 then
        return trim_parts(xs: rest, acc: acc)
      end
      return trim_parts(xs: rest, acc: trimmed :: acc)
  end
end

// ─── Comment-aware prefix scan ────────────────────────────────────────────────
//
// A directive is only honoured when it appears inside a COMMENT, never inside a
// string/char literal — otherwise program DATA (e.g. a string literal that
// happens to contain `lint:allow-file L0001`) could silently disable a gating
// rule.  The Nexus lexer discards comments before the AST, so we re-scan the
// raw line tracking literal/comment context, mirroring the literal-aware scanner
// in `src/lint/fix.nx` (`range_has_comment`).
//
// `mode`: 0 = normal code, 1 = inside a string literal, 2 = inside a char
// literal, 3 = inside a `//` line comment, 4 = inside a `/* */` block comment.
// A backslash inside a literal escapes the next byte.  Only while in a comment
// mode (3 or 4) do we test for the directive prefix.

// True if `prefix` matches `line` byte-for-byte starting at offset `i`.
let matches_at = fn (line: string, i: i64, prefix: string, k: i64) -> bool do
  let plen = str.byte_length(s: prefix)
  if k >= plen then return true end
  let pos = i + k
  if pos >= str.byte_length(s: line) then return false end
  if str.byte_at(s: line, idx: pos) != str.byte_at(s: prefix, idx: k) then return false end
  return matches_at(line, i, prefix, k: k + 1)
end

// Walk the line tracking literal/comment context. While inside a comment, test
// whether `prefix` begins at the current byte; if so, return the byte offset
// just past the prefix (so the caller can slice the code-list tail). Returns -1
// if the prefix never occurs inside a comment.
let scan_directive = fn (line: string, prefix: string, i: i64, mode: i64) -> i64 do
  if i >= str.byte_length(s: line) then return -1 end
  let c = str.byte_at(s: line, idx: i)
  if mode == 1 then
    // Inside a string literal: ignore directives, honour backslash escapes.
    if c == '\\' then return scan_directive(line, prefix, i: i + 2, mode: 1) end
    if c == '"' then return scan_directive(line, prefix, i: i + 1, mode: 0) end
    return scan_directive(line, prefix, i: i + 1, mode: 1)
  end
  if mode == 2 then
    // Inside a char literal: ignore directives, honour backslash escapes.
    if c == '\\' then return scan_directive(line, prefix, i: i + 2, mode: 2) end
    if c == '\'' then return scan_directive(line, prefix, i: i + 1, mode: 0) end
    return scan_directive(line, prefix, i: i + 1, mode: 2)
  end
  if mode == 3 then
    // Inside a `//` line comment (runs to end of line): test for the directive.
    if matches_at(line, i, prefix, k: 0) then return i + str.byte_length(s: prefix) end
    return scan_directive(line, prefix, i: i + 1, mode: 3)
  end
  if mode == 4 then
    // Inside a `/* */` block comment: test for the directive, watch for `*/`.
    if matches_at(line, i, prefix, k: 0) then return i + str.byte_length(s: prefix) end
    let n2 = if i + 1 < str.byte_length(s: line) then str.byte_at(s: line, idx: i + 1) else '\0' end
    if c == '*' && n2 == '/' then return scan_directive(line, prefix, i: i + 2, mode: 0) end
    return scan_directive(line, prefix, i: i + 1, mode: 4)
  end
  // Normal code: enter a comment or a literal, otherwise advance.
  let nc = if i + 1 < str.byte_length(s: line) then str.byte_at(s: line, idx: i + 1) else '\0' end
  if c == '/' && nc == '/' then return scan_directive(line, prefix, i: i + 2, mode: 3) end
  if c == '/' && nc == '*' then return scan_directive(line, prefix, i: i + 2, mode: 4) end
  if c == '"' then return scan_directive(line, prefix, i: i + 1, mode: 1) end
  if c == '\'' then return scan_directive(line, prefix, i: i + 1, mode: 2) end
  return scan_directive(line, prefix, i: i + 1, mode: 0)
end

// Find a directive prefix that occurs INSIDE A COMMENT on this line, and return
// the tail after the prefix keyword, or "" if this prefix is not present in a
// comment.  A directive inside a string/char literal is NOT honoured.  The
// distinction between "not present" and "present with empty tail" (a bare
// directive) is carried by `prefix_in_comment`, which the caller checks first.
let after_prefix = fn (line: string, prefix: string) -> string do
  let after = scan_directive(line, prefix, i: 0, mode: 0)
  if after < 0 then return "" end
  return str.byte_substring(s: line, start: after, len: str.byte_length(s: line) - after)
end

// True if `prefix` appears inside a comment on this line (string/char literals
// excluded).  Replaces the old comment-unaware `str.contains` guard.
let prefix_in_comment = fn (line: string, prefix: string) -> bool do
  return scan_directive(line, prefix, i: 0, mode: 0) >= 0
end

// ─── Suppression record ──────────────────────────────────────────────────────

// A suppression entry: target line (1-based, -1 for file-wide) and list of
// codes (empty list = all codes).
type Suppression = Suppression(target_line: i64, codes: [ string ])

// ─── Build suppression list from source ──────────────────────────────────────

/** Scan the source text and return a list of Suppression records. */
let build_suppressions = fn (src: string) -> [ Suppression ] do
  let lines = str.split(s: src, sep: "\n")
  return scan_lines(lines, line_no: 1, acc: [])
end

let scan_lines = fn (lines: [ string ], line_no: i64, acc: [ Suppression ]) -> [ Suppression ] do
  match lines do
    | [] -> return acc
    | ln :: rest ->
      let acc2 = process_line(line: ln, line_no: line_no, acc: acc)
      return scan_lines(lines: rest, line_no: line_no + 1, acc: acc2)
  end
end

let process_line = fn (line: string, line_no: i64, acc: [ Suppression ]) -> [ Suppression ] do
  // Directives are only honoured inside COMMENTS — a `lint:allow…` occurrence
  // inside a string/char literal is program DATA and must NOT disarm any rule.
  // Check lint:allow-file (whole-file suppression)
  if prefix_in_comment(line, prefix: prefix_allow_file()) then
    let tail = after_prefix(line, prefix: prefix_allow_file())
    let codes = parse_code_list(tail)
    return Suppression(target_line: -1, codes) :: acc
  end
  // Check lint:allow-next (next-line suppression)
  if prefix_in_comment(line, prefix: prefix_allow_next()) then
    let tail = after_prefix(line, prefix: prefix_allow_next())
    let codes = parse_code_list(tail)
    return Suppression(target_line: line_no + 1, codes) :: acc
  end
  // Check lint:allow (same-line suppression — only when neither -next nor -file)
  if prefix_in_comment(line, prefix: prefix_allow()) then
    let tail = after_prefix(line, prefix: prefix_allow())
    let codes = parse_code_list(tail)
    return Suppression(target_line: line_no, codes) :: acc
  end
  return acc
end

// ─── Matching logic ──────────────────────────────────────────────────────────

// Does a single suppression entry suppress this finding?
let suppression_covers = fn (s: Suppression, f: LintFinding) -> bool do
  let Suppression(target_line, codes) = s
  if target_line >= 0 then
      let LintFinding(code: _, severity: _, message: _, fix_it: _, span) = f
      let Span(offset: _, line: fl, col: _) = span
      if fl != target_line then return false end
    end
    // Empty codes list = all codes on that line are suppressed
    if list.is_empty(xs: codes) then return true end
    let LintFinding(code, severity: _, message: _, fix_it: _, span: _) = f
    return code_in_list(code, xs: codes)
end

let code_in_list = fn (code: string, xs: [ string ]) -> bool do
  match xs do
    | [] -> return false
    | c :: rest ->
      if c == code then return true end
      return code_in_list(code, xs: rest)
  end
end

// Is the finding covered by ANY suppression?
let is_suppressed = fn (f: LintFinding, suppressions: [ Suppression ]) -> bool do
  match suppressions do
    | [] -> return false
    | s :: rest ->
      if suppression_covers(s, f) then return true end
      return is_suppressed(f, suppressions: rest)
  end
end

// ─── Main API ────────────────────────────────────────────────────────────────

/** Filter out findings that are covered by inline lint-suppress directives.
 *  Pure: reads only `src` and `findings`, no I/O or caps required.
 *
 *  Directive forms recognised:
 *    // lint:allow L0001           same-line suppression
 *    // lint:allow-next L0001      next-line suppression (above the finding)
 *    // lint:allow-file L0001      whole-file suppression
 *    // lint:allow L0001, L0002    comma list
 *    // lint:allow                 bare = suppress all codes on that line
 */
export let apply_suppressions = fn (src: string, findings: [ LintFinding ]) -> [ LintFinding ] do
  if list.is_empty(xs: findings) then return findings end
  let suppressions = build_suppressions(src)
  if list.is_empty(xs: suppressions) then return findings end
  return filter_findings(findings, suppressions, acc: [])
end

let filter_findings = fn (
  findings: [ LintFinding ],
  suppressions: [ Suppression ],
  acc: [ LintFinding ]
) -> [ LintFinding ] do
  match findings do
    | [] -> return list.reverse(xs: acc)
    | f :: rest ->
      if is_suppressed(f, suppressions) then
        return filter_findings(findings: rest, suppressions, acc)
      else
        return filter_findings(findings: rest, suppressions, acc: f :: acc)
      end
  end
end
