/**
 * lint: AST-driven lint pack for AI-frequent error patterns.
 *
 * Scope V1: minimal framework + two reliable rules that fire on programs
 * that type-check successfully but exhibit smell patterns LLM-generated
 * code routinely produces. Each rule has a stable L-code so downstream
 * tooling (LSP, fix-it appliers) can key on it.
 *
 * Rules implemented:
 *   L0001  empty-inject: `inject H do end` with no statements in the body.
 *          The handler binding is allocated and the cap is in scope but
 *          nothing in the body uses it; the entire wrapper is dead code.
 *          Fix-it: delete the inject wrapper, keep the (empty) body.
 *   L0002  unused-require-cap: a function declares `require { Cap }` but
 *          the body has NO call (direct or via helpers) — i.e. it cannot
 *          consume any capability. The declared row is purely decorative.
 *          Fix-it: drop the capability from the `require` row.
 *   L0100  cognitive-complexity: function body exceeds the cognitive
 *          complexity threshold (default 15). Uses SonarSource-style
 *          cognitive complexity rather than raw McCabe: a `match` costs
 *          +1 for the dispatch decision (not +1 per arm), `if`/`while`/
 *          `for` cost +1 plus a nesting-depth penalty, each `&&`/`||`
 *          operand-chain link costs +1, each `catch` arm costs +1.
 *          Emitted as `LintInfo` (note severity) so it does NOT trip the
 *          `--check` CI gate — it informs without failing the pipeline.
 *
 * Design choices (V1):
 *   - Walks the parsed AST directly. No HIR / typecheck dependency: lint
 *     runs against source files independently of the build pipeline and
 *     can surface findings on partially-valid programs (when extended).
 *   - L0002 is **deliberately narrow**: it fires only when the body is
 *     call-free (no `f(...)` calls anywhere). A function that calls a
 *     helper could be transitively consuming the cap through that
 *     helper's own require-row; without a real effect analysis the
 *     syntactic walker cannot tell, so the narrower rule has zero
 *     false positives at the cost of missing the
 *     "cap-declared-but-consumed-only-via-helper" pattern. That broader
 *     rule is tracked as L0004 (deferred — needs effect-row analysis).
 *   - Each finding carries an optional `fix_it` suggestion string. V1
 *     reports the suggestion textually; a future `nexus lint --fix`
 *     applier (deferred) can consume the L-code + span to rewrite source.
 *
 * Deferred rules (tracked under follow-ups):
 *   L0003  missing-require-cap (the symmetric `b` case from the bd —
 *          calls a cap method without declaring the cap)
 *   L0004  effect-row-based unused-cap (broader L0002 that walks the
 *          callee graph via the typecheck effect map, catching caps
 *          consumed only through helpers)
 *   L0005  unnecessary-inject-handler (handler in `inject H1, H2 do …`
 *          whose cap never receives a body-side call)
 *
 * CI-gate design:
 *   `--check` counts only `LintWarning` findings (not `LintInfo`).
 *   L0100 is `LintInfo` so it never trips the gate even when fired.
 *   This sidesteps the need for per-file suppression (which is
 *   impossible since comments are stripped at lex).
 */

import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"

import { Span } from "src/common/token.nx"
import { Fixit } from "src/tools/fix.nx"
import {
  Program, SpannedTopLevel, TopLevel, TLLet, GlobalLet,
  SpannedExpr, Expr, ExprLambda, ExprCall, ExprIf, ExprMatch, ExprWhile,
  ExprFor, ExprBinaryOp, ExprUnaryOp, ExprArray, ExprList, ExprRecord,
  ExprIndex, ExprFieldAccess, ExprRaise, ExprForce, ExprHandler,
  ExprConstructor,
  SpannedStmt, Stmt, StmtLet, StmtLetPattern, StmtExpr, StmtReturn,
  StmtAssign, StmtIndexAssign, StmtTry, StmtInject,
  TypeExpr, TyRow, TyUserDefined,
  HandlerArm, MatchCase, CatchArm, Function,
  NamedExpr, CallArg, CtorArg
} from "src/common/ast.nx"
import * as rdr from "src/ir/shared/rdrname.nx"
import {
  LintSeverity, LintWarning, LintInfo,
  LintFinding
} from "src/lint/types.nx"
import {
  collect_empty_injects_in_stmts, collect_empty_injects_in_expr
} from "src/lint/rules/empty_inject.nx"
import { check_unused_caps_in_function } from "src/lint/rules/unused_cap.nx"

//
// L0100 — cognitive complexity.
//
// Cognitive complexity (SonarSource style) differs from McCabe (cyclomatic)
// in two key ways that suit ML-family languages:
//
//   1. A `match` expression costs +1 for the dispatch decision regardless
//      of how many arms it has. Raw McCabe would charge +1 per arm, which
//      grossly penalises idiomatic exhaustive ADT dispatch.
//
//   2. Nesting depth adds a weight penalty to structural breaks (`if`,
//      `while`, `for`, handler arms) — deeply nested conditionals cost
//      more than flat ones.
//
// Scoring rules:
//   ExprIf           +1 + depth  (for both then-branch and combined if/else)
//   ExprMatch        +1          (the dispatch decision only)
//   ExprWhile/For    +1 + depth
//   each CatchArm    +1          (per catch arm, not the whole try)
//   each HandlerArm  +1          (per op implementation arm)
//   ExprBinaryOp     +1 per &&/|| node (each link in a boolean chain)
//   ExprLambda       evaluated independently (nested fn is its own scope)
//
// Nesting depth increments when entering the body of:
//   if then-branch / else-branch, while body, for body,
//   match case body, catch arm body, handler arm body.
// (Boolean chains do not increase depth.)
//
// Threshold: 15. Functions below the threshold produce no finding.
// This value tolerates moderately complex functions while flagging
// genuinely tangled control flow.

let cognitive_complexity_threshold = fn () -> i64 do return 15 end

let cc_stmts = fn (ss: [ SpannedStmt ], depth: i64) -> i64 do
  match ss do
    | [] -> return 0
    | s :: rest ->
      match s do | SpannedStmt(node, span: _) ->
        return cc_stmt(s: node, depth: depth) + cc_stmts(ss: rest, depth: depth)
      end
  end
end

let cc_stmt = fn (s: Stmt, depth: i64) -> i64 do
  match s do
    | StmtLet(name: _, sigil: _, typ: _, value) | StmtLetPattern(pattern: _, value) ->
      return cc_expr(e: value, depth: depth)
    | StmtExpr(expr) -> return cc_expr(e: expr, depth: depth)
    | StmtReturn(value) | StmtAssign(target: _, value) -> return cc_expr(e: value, depth: depth)
    | StmtIndexAssign(target, index, value) ->
      return cc_expr(e: target, depth: depth) + cc_expr(e: index, depth: depth) + cc_expr(e: value, depth: depth)
    | StmtTry(body, catch_arms) ->
      let body_cost = cc_stmts(ss: body, depth: depth)
      // Each catch arm costs +1 (the decision to handle this exception kind).
      // The arm body runs at depth+1 (inside the catch).
      let arms_cost = cc_catch_arms(arms: catch_arms, depth: depth + 1)
      return body_cost + arms_cost
    | StmtInject(handlers, body) ->
      let h_cost = cc_spanned_exprs(es: handlers, depth: depth)
      return h_cost + cc_stmts(ss: body, depth: depth)
  end
end

let cc_catch_arms = fn (arms: [ CatchArm ], depth: i64) -> i64 do
  match arms do
    | [] -> return 0
    | a :: rest ->
      match a do | CatchArm(pattern: _, body) ->
        // +1 for the catch arm itself (a decision point), body is at depth.
        return 1 + cc_stmts(ss: body, depth: depth) + cc_catch_arms(arms: rest, depth: depth)
      end
  end
end

let cc_expr = fn (e: SpannedExpr, depth: i64) -> i64 do
  match e do | SpannedExpr(node, span: _) ->
    return cc_node(e: node, depth: depth)
  end
end

let cc_node = fn (e: Expr, depth: i64) -> i64 do
  match e do
    | ExprIf(cond, then_branch, else_branch) ->
      // +1 + depth for the if decision. Both branches increase depth by 1.
      let cond_cost = cc_expr(e: cond, depth: depth)
      let then_cost = cc_stmts(ss: then_branch, depth: depth + 1)
      let else_cost = cc_stmts(ss: else_branch, depth: depth + 1)
      return 1 + depth + cond_cost + then_cost + else_cost
    | ExprMatch(target, cases) ->
      // +1 for the dispatch decision; case bodies each at depth+1.
      let target_cost = cc_expr(e: target, depth: depth)
      let cases_cost = cc_match_cases(cs: cases, depth: depth + 1)
      return 1 + target_cost + cases_cost
    | ExprWhile(cond, body) ->
      let cond_cost = cc_expr(e: cond, depth: depth)
      let body_cost = cc_stmts(ss: body, depth: depth + 1)
      return 1 + depth + cond_cost + body_cost
    | ExprFor(var: _, start, end_expr, body) ->
      let start_cost = cc_expr(e: start, depth: depth)
      let end_cost = cc_expr(e: end_expr, depth: depth)
      let body_cost = cc_stmts(ss: body, depth: depth + 1)
      return 1 + depth + start_cost + end_cost + body_cost
    | ExprBinaryOp(left, op, right) ->
      // Each && or || node adds +1 (a link in a boolean chain).
      let op_cost = match op do
        | OpAnd -> 1
        | OpOr -> 1
        | _ -> 0
      end
      return op_cost + cc_expr(e: left, depth: depth) + cc_expr(e: right, depth: depth)
    | ExprHandler(coeffect_name: _, requires: _, arms) ->
      // Each handler arm is a decision point: +1 per arm.
      return cc_handler_arms(arms: arms, depth: depth + 1)
    | ExprLambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body) ->
      // A nested lambda is scored INDEPENDENTLY (its own scope).
      // We do NOT recurse with the outer depth; the nested function's
      // complexity is part of that function's own budget, not the outer one.
      return 0
    | ExprCall(func: _, args) -> return cc_call_args(args: args, depth: depth)
    | ExprConstructor(name: _, args, sigil: _) -> return cc_ctor_args(args: args, depth: depth)
    | ExprUnaryOp(op: _, operand) -> return cc_expr(e: operand, depth: depth)
    | ExprArray(elements) | ExprList(elements) -> return cc_spanned_exprs(es: elements, depth: depth)
    | ExprRecord(fields) -> return cc_named_exprs(fs: fields, depth: depth)
    | ExprIndex(target, index) ->
      return cc_expr(e: target, depth: depth) + cc_expr(e: index, depth: depth)
    | ExprFieldAccess(target, field: _) -> return cc_expr(e: target, depth: depth)
    | ExprRaise(value) | ExprForce(value) -> return cc_expr(e: value, depth: depth)
    | _ -> return 0
  end
end

let cc_match_cases = fn (cs: [ MatchCase ], depth: i64) -> i64 do
  match cs do
    | [] -> return 0
    | c :: rest ->
      match c do | MatchCase(pattern: _, body) ->
        return cc_stmts(ss: body, depth: depth) + cc_match_cases(cs: rest, depth: depth)
      end
  end
end

let cc_handler_arms = fn (arms: [ HandlerArm ], depth: i64) -> i64 do
  match arms do
    | [] -> return 0
    | a :: rest ->
      match a do | HandlerArm(arm, cont_binder: _, span: _) ->
        match arm do | Function(name: _, is_public: _, type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body, span: _) ->
          // +1 per handler arm (a decision point), body at depth.
          return 1 + cc_stmts(ss: body, depth: depth) + cc_handler_arms(arms: rest, depth: depth)
        end
      end
  end
end

let cc_spanned_exprs = fn (es: [ SpannedExpr ], depth: i64) -> i64 do
  match es do
    | [] -> return 0
    | e :: rest ->
      return cc_expr(e: e, depth: depth) + cc_spanned_exprs(es: rest, depth: depth)
  end
end

let cc_call_args = fn (args: [ CallArg ], depth: i64) -> i64 do
  match args do
    | [] -> return 0
    | a :: rest ->
      match a do | CallArg(name: _, value) ->
        return cc_expr(e: value, depth: depth) + cc_call_args(args: rest, depth: depth)
      end
  end
end

let cc_ctor_args = fn (args: [ CtorArg ], depth: i64) -> i64 do
  match args do
    | [] -> return 0
    | a :: rest ->
      match a do | CtorArg(name: _, value) ->
        return cc_expr(e: value, depth: depth) + cc_ctor_args(args: rest, depth: depth)
      end
  end
end

let cc_named_exprs = fn (fs: [ NamedExpr ], depth: i64) -> i64 do
  match fs do
    | [] -> return 0
    | f :: rest ->
      match f do | NamedExpr(name: _, value) ->
        return cc_expr(e: value, depth: depth) + cc_named_exprs(fs: rest, depth: depth)
      end
  end
end

/** Compute cognitive complexity of a function body starting at depth 0. */
let cognitive_complexity_of = fn (body: [ SpannedStmt ]) -> i64 do
  return cc_stmts(ss: body, depth: 0)
end

/** Check a single function for L0100 (cognitive complexity). Emits a
 *  `LintInfo` note when the computed score exceeds the threshold.
 *  `LintInfo` findings are NOT counted by the `--check` CI gate.
 */
let check_cognitive_complexity = fn (
  name: string,
  body: [ SpannedStmt ],
  fn_span: Span,
  acc: [ LintFinding ]
) -> [ LintFinding ] do
  let score = cognitive_complexity_of(body)
  let threshold = cognitive_complexity_threshold()
  if score <= threshold then return acc end
  let msg = "function '" ++ name ++ "' has cognitive complexity "
    ++ str.from_i64(val: score) ++ " (threshold " ++ str.from_i64(val: threshold) ++ ")"
    ++ "; consider splitting into smaller helpers"
  return LintFinding(
    code: "L0100",
    severity: LintInfo,
    message: msg,
    fix_it: None,
    span: fn_span
  ) :: acc
end

/** Walk every top-level `let name = fn …` binding. Other top-level forms
 *  (type defs, enums, exceptions, imports, caps) carry no executable body
 *  for the V1 rule set so are skipped wholesale.
 */
let lint_top_levels = fn (xs: [ SpannedTopLevel ], acc: [ LintFinding ]) -> [ LintFinding ] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | tl :: rest ->
      let acc2 = match tl do | SpannedTopLevel(node, span) ->
        match node do
          | TLLet(def) -> lint_global_let(def: def, acc: acc)
          | _ -> acc
        end
      end
      return lint_top_levels(xs: rest, acc: acc2)
  end
end

let lint_global_let = fn (def: GlobalLet, acc: [ LintFinding ]) -> [ LintFinding ] do
  match def do | GlobalLet(name, is_public: _, typ: _, value) ->
    return lint_global_value(name: name, value: value, acc: acc)
  end
end

let lint_global_value = fn (name: string, value: SpannedExpr, acc: [ LintFinding ]) -> [ LintFinding ] do
  match value do | SpannedExpr(node, span) ->
    match node do
      | ExprLambda(type_params: _, params: _, ret_type: _, requires, throw_row: _, body) ->
        let a1 = check_unused_caps_in_function(name: name, requires: requires, body: body, fn_span: span, acc: acc)
        let a2 = collect_empty_injects_in_stmts(ss: body, acc: a1)
        return check_cognitive_complexity(name: name, body: body, fn_span: span, acc: a2)
      | _ -> return collect_empty_injects_in_expr(e: value, acc: acc)
    end
  end
end

/** Run every V1 lint rule across `prog`. Findings are returned in
 *  source-order (top-down across top-levels, by rule firing within a
 *  function). The file path is not embedded in `LintFinding` — callers
 *  attach it when rendering.
 */
export let lint_program = fn (prog: Program) -> [ LintFinding ] do
  match prog do | Program(definitions, module_doc: _) ->
    return lint_top_levels(xs: definitions, acc: [])
  end
end

let severity_label = fn (s: LintSeverity) -> string do
  match s do
    | LintWarning -> return "warning"
    | LintInfo -> return "note"
  end
end

/** Render a single finding to the user-facing text format. Mirrors
 *  `format_error` in src/common/error.nx: human prose + `[Lxxxx]` code
 *  bracket suffix for grep-ability. The optional fix-it suggestion is
 *  emitted on a continuation line prefixed with `  help: `.
 */
export let format_finding = fn (file: string, f: LintFinding) -> string do
  match f do | LintFinding(code, severity, message, fix_it, span) ->
    match span do | Span(offset: _, line: l, col: c) ->
      let head = file ++ ":" ++ str.from_i64(val: l) ++ ":" ++ str.from_i64(val: c)
        ++ ": " ++ severity_label(s: severity) ++ ": " ++ message
        ++ " [" ++ code ++ "]"
      match fix_it do
        | Some(val: fix) ->
          match fix do | Fixit(start: _, len: _, replacement: _, code: _, message: hint) ->
            return head ++ "\n  help: " ++ hint
          end
        | None -> return head
      end
    end
  end
end
