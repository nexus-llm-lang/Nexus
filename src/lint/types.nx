/**
 * types: shared lint types used by all rule modules and the lint driver.
 *
 * Extracted from src/lint/lint.nx so rule modules can import types without
 * pulling in the full driver. The driver re-exports everything here so
 * existing importers (src/tools/lint.nx, src/lint/suppress.nx) need no
 * changes.
 */

import { Option } from "std:option"
import { Span } from "src/syntax/token.nx"
import { Fixit } from "src/tools/fix.nx"

/** Severity tag for lint findings. Rules emit Warning or Info at the source.
 *  Error is not a source-level severity: it is only reached when a finding is
 *  promoted by a build-time escalation policy (--lint-level=error / --deny).
 */
export type LintSeverity = LintWarning | LintInfo | LintError

/** One lint finding. `code` is the stable Lxxxx identifier; `fix_it` is a
 *  human-readable suggestion (None when the rule has no auto-applicable
 *  hint). `span` localises the finding to a source range; the file path
 *  is held at the runner level rather than per-finding to keep the type
 *  small.
 */
export type LintFinding = LintFinding(
  code: string,
  severity: LintSeverity,
  message: string,
  fix_it: Option<Fixit>,
  span: Span
)
