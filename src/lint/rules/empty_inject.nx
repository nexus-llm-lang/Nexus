/**
 * empty_inject: L0001 rule — `inject H do end` with no body statements.
 *
 * Extracted from src/lint/lint.nx. Pure code movement; no logic change.
 */

import { Option, Some } from "std:option"
import * as list from "std:list"
import { Fixit } from "src/tools/fix.nx"
import { Span } from "src/types/span.nx"
import { SpannedExpr, Expr, SpannedStmt, Stmt, StmtInject } from "src/syntax/ast.nx"
import { LintFinding, LintWarning } from "src/lint/types.nx"
import { fold_stmts, fold_expr } from "src/lint/rules/ast_fold.nx"

//
// `inject H1, H2 do end` (zero statements) compiles fine but the wrapper is
// dead code: the handlers go out of scope unused. Walk every Inject site
// across function bodies and report when its body is empty.
//
// The on_stmt visitor detects StmtInject with an empty body and uses the
// SpannedStmt's span for the finding location. The on_expr visitor is a
// no-op since inject-detection happens at the Stmt level.
// The fold recurses into inject body stmts automatically (after calling the
// visitor), so nested injects are found in a single pass.

// No-op expr visitor: expr nodes contribute no findings directly.
let inject_expr_noop = fn (acc: [ LintFinding ], depth: i64, e: Expr) -> [ LintFinding ] do
  return acc
end

// Stmt visitor: emit L0001 when we see an inject with an empty body.
// The `span` is the source location of the inject statement itself.
let inject_stmt_visitor = fn (
  acc: [ LintFinding ],
  depth: i64,
  s: Stmt,
  span: Span
) -> [ LintFinding ] do
  match s do
    | StmtInject(handlers: _, body) ->
      if list.is_empty(xs: body) then
        return LintFinding(
          code: "L0001",
          severity: LintWarning,
          message: "`inject` block has an empty body; the handler bindings are unreachable",
          fix_it: Some(val: Fixit(
            start: 0,
            len: 0,
            replacement: "",
            code: "L0001",
            message: "remove the surrounding `inject ... do ... end` and keep the (empty) body"
          )),
          span: span
        ) :: acc
      end
      return acc
    | _ -> return acc
  end
end

export let collect_empty_injects_in_stmts = fn (
  ss: [ SpannedStmt ],
  acc: [ LintFinding ]
) -> [ LintFinding ] do
  return fold_stmts(
    ss: ss,
    acc: acc,
    depth: 0,
    on_expr: inject_expr_noop,
    on_stmt: inject_stmt_visitor
  )
end

export let collect_empty_injects_in_expr = fn (
  e: SpannedExpr,
  acc: [ LintFinding ]
) -> [ LintFinding ] do
  return fold_expr(
    e: e,
    acc: acc,
    depth: 0,
    on_expr: inject_expr_noop,
    on_stmt: inject_stmt_visitor
  )
end
