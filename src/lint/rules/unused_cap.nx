/**
 * unused_cap: L0002 rule — `require { Cap }` declared but never called.
 *
 * Extracted from src/lint/lint.nx. Pure code movement; no logic change.
 */

import { Option, Some } from "std:option"
import * as str from "std:str"
import * as list from "std:list"
import { Fixit } from "src/tools/fix.nx"
import { Span } from "src/types/span.nx"
import { TypeExpr, TyRow, TyUserDefined } from "src/types/type_expr.nx"
import { Expr, ExprCall, SpannedStmt, Stmt } from "src/syntax/ast.nx"
import * as rdr from "src/ir/shared/rdrname.nx"
import { LintFinding, LintWarning } from "src/lint/types.nx"
import { fold_stmts } from "src/lint/rules/ast_fold.nx"

//
// A capability appears in the source as a bare `TyUserDefined(name: C, args:
// [])` entry inside the function's `require {…}` row. The set of names that
// look like capabilities for L0002 purposes is the set of "Cap-shaped" idents
// — capitalised, no `Perm` prefix (those are permission tokens consumed by
// system handlers, not user-facing cap surfaces). Permission tokens are
// excluded because the user does not call methods on `PermConsole`; only
// `Console.*` is callable.

let starts_with_upper = fn (s: string) -> bool do
  if str.length(s) == 0 then return false end
  let c = str.char_at(s, idx: 0)
  return c >= 'A' && c <= 'Z'
end

let is_perm_token = fn (name: string) -> bool do
  return str.starts_with(s: name, prefix: "Perm")
end

/** Extract capability names declared in a `TyRow` requires-clause. Skips
 *  `PermX` permission tokens (those are system-handler private surfaces)
 *  and any non-identifier-shaped entry. Order-preserving so the lint
 *  reports findings in declaration order.
 */
let cap_names_in_row = fn (row: TypeExpr) -> [ string ] do
  match row do
    | TyRow(types: ts, rest: _) -> return cap_names_in_row_loop(xs: ts, acc: [])
    | _ -> return []
  end
end

let cap_names_in_row_loop = fn (xs: [ TypeExpr ], acc: [ string ]) -> [ string ] do
  match xs do
    | [] -> return list.reverse(xs: acc)
    | TyUserDefined(name: n, args: _) :: rest ->
      if is_perm_token(name: n) then
        return cap_names_in_row_loop(xs: rest, acc: acc)
      end
      if !starts_with_upper(s: n) then
        return cap_names_in_row_loop(xs: rest, acc: acc)
      end
      return cap_names_in_row_loop(xs: rest, acc: n :: acc)
    | _ :: rest -> return cap_names_in_row_loop(xs: rest, acc: acc)
  end
end

//
// A `Console.println(val: "x")` parses as `ExprCall(func: <qualified-rdr>,
// args: …)`. The rdr's first segment (or only segment in unqual form) is
// the cap name. To stay seed-compatible we walk the rdr via the rdr.nx
// helpers rather than pattern-matching the variant directly.

let call_targets_cap = fn (func: rdr.RdrName, c_name: string) -> bool do
  let s = rdr.rdr_to_string(r: func)
  // The renamed string form is `Cap.method` for qualified cap-method
  // calls. Strict prefix check: `Console` must not also fire on
  // `ConsoleEx.method` if such a name ever exists.
  let needle = c_name ++ "."
  return str.starts_with(s, prefix: needle)
end

// No-op stmt visitor for the bool families: stmts contribute nothing.
let bool_stmt_noop = fn (acc: bool, depth: i64, s: Stmt, span: Span) -> bool do
  return acc
end

// `any_call_to_cap_in_stmts`: true if any ExprCall targets c_name.
let any_call_to_cap_in_stmts = fn (ss: [ SpannedStmt ], c_name: string) -> bool do
  return fold_stmts(
    ss: ss,
    acc: false,
    depth: 0,
    on_expr: fn (acc: bool, depth: i64, e: Expr) -> bool do
      if acc then return true end
      match e do
        | ExprCall(func, args: _) -> return call_targets_cap(func: func, c_name: c_name)
        | _ -> return false
      end
    end,
    on_stmt: bool_stmt_noop
  )
end

// `has_any_call_in_stmts`: true if any ExprCall exists anywhere in the stmt tree.
let has_any_call_in_stmts = fn (ss: [ SpannedStmt ]) -> bool do
  return fold_stmts(
    ss: ss,
    acc: false,
    depth: 0,
    on_expr: fn (acc: bool, depth: i64, e: Expr) -> bool do
      if acc then return true end
      match e do
        | ExprCall(func: _, args: _) -> return true
        | _ -> return false
      end
    end,
    on_stmt: bool_stmt_noop
  )
end

/** Walk a single function definition: extract its declared cap names and
 *  test each against the body's syntactic `Cap.<method>` call set. Emits
 *  one L0002 finding per unused cap, ordered by appearance in the require
 *  row.
 */
export let check_unused_caps_in_function = fn (
  name: string,
  requires: TypeExpr,
  body: [ SpannedStmt ],
  fn_span: Span,
  acc: [ LintFinding ]
) -> [ LintFinding ] do
  let caps = cap_names_in_row(row: requires)
  let has_call = has_any_call_in_stmts(ss: body)
  return check_each_cap(
    caps: caps,
    name: name,
    body: body,
    fn_span: fn_span,
    has_any_call: has_call,
    acc: acc
  )
end

let check_each_cap = fn (
  caps: [ string ],
  name: string,
  body: [ SpannedStmt ],
  fn_span: Span,
  has_any_call: bool,
  acc: [ LintFinding ]
) -> [ LintFinding ] do
  match caps do
    | [] -> return acc
    | cn :: rest ->
      let used = any_call_to_cap_in_stmts(ss: body, c_name: cn)
      // L0002 fires only when the body is also call-free overall: a
      // function that makes ANY other call could be transitively
      // consuming the cap through a helper, which the syntactic walker
      // cannot see. The narrower rule has no documented false positives
      // — it catches the "stub function with over-declared row" pattern
      // which is the LLM-frequent error the bd targets. Cases where a
      // cap is declared but only used by a sub-call are handled by the
      // deferred L0003 / effect-analysis follow-up.
      let acc2 = if used || has_any_call then acc else
          let msg = "function '" ++ name ++ "' declares capability '" ++ cn
                ++ "' in its `require {…}` row but never calls `" ++ cn ++ ".*`"
                ++ " (and the body has no calls that could consume it transitively)"
          let fix_msg = "remove '" ++ cn ++ "' from the `require {…}` clause"
          LintFinding(
            code: "L0002",
            severity: LintWarning,
            message: msg,
            fix_it: Some(val: Fixit(
              start: 0,
              len: 0,
              // replacement carries the cap name so the fix driver can
              // locate and delete it in the require row without re-parsing.
              replacement: cn,
              code: "L0002",
              message: fix_msg
            )),
            span: fn_span
          ) :: acc
        end
      return check_each_cap(
        caps: rest,
        name: name,
        body: body,
        fn_span: fn_span,
        has_any_call: has_any_call,
        acc: acc2
      )
  end
end
