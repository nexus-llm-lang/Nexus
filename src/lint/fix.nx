/**
 * lint/fix: the `--fix` / `--fix-diff` pipeline for `nexus lint`.
 *
 * Engine half of the lint fix-mode driver. The `src/tools/lint.nx` driver
 * owns argparse + the AST-only `--check` path; this module owns the heavier
 * front-end coupling that `--fix` / `--fix-diff` require:
 *
 *   - run AST lint rules AND the front-end pipeline (parse -> HIR ->
 *     linearity -> typecheck), collecting all fixable diagnostics
 *     (L0001/L0002/L0007 hints + E2005/E2007 span rewrites),
 *   - apply them in one pass, loop to fixpoint,
 *   - either rewrite files in place (`--fix`) or show a before/after diff
 *     without modifying any files (`--fix-diff`).
 *
 * The single entry point is `run_fix_each_file`, called by the driver's
 * `run_lint_subcommand` once it has parsed `--fix` / `--fix-diff` + paths.
 *
 * The L0001 / L0002 / L0007 source-scanning enrichment helpers live here
 * (not in src/lint/lint.nx) because they need the raw source string, which
 * is only available in the fix-mode driver, not the AST linter.
 */

import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"
import { Fs } from "std:fs"
import { Console } from "std:stdio"
import * as err from "src/diagnostics/error.nx"
import * as lexer from "src/frontend/lexer.nx"
import { ParseDiagnostics }, * as parser from "src/frontend/parser.nx"
import { LintFinding } from "src/lint/types.nx"
import { lint_program } from "src/lint/lint.nx"
import { apply_suppressions } from "src/lint/suppress.nx"
import {
  Fixit, apply_fixit, fixit_for_exn,
  format_check_line, format_diff_block, slice_old_text
} from "src/tools/fix.nx"
import { resolve_all_lazy_no_filter } from "src/ir/hir/demand.nx"
import * as main_wrap from "src/ir/main_wrap.nx"
import { HirProgram } from "src/ir/hir/types.nx"
import {
  expand_groups_in_functions,
  expand_groups_in_handler_bindings
} from "src/ir/hir/build/accum.nx"
import { extract_function_names } from "src/ir/shared/resolve.nx"
import { get_defs } from "src/ir/shared/imports.nx"
import * as linearity from "src/ir/shared/linearity.nx"
import * as tc from "src/typecheck/check.nx"
import * as iidx from "src/typecheck/import_index.nx"
import * as tc_linearity from "src/typecheck/linearity.nx"
import { HirBuildResult, build_hir } from "src/pipeline.nx"
import { LazyBindingUnused, LinearUnused } from "src/typecheck/errors.nx"
import { Span } from "src/types/span.nx"
import {
  SpannedToken, Token,
  TkMatch, TkDo, TkEnd, TkIf, TkTry, TkElse, TkPipe, TkArrow, TkEof
} from "src/syntax/token.nx"

//
// Fix mode: front-end pipeline runner
//
// In `--fix` / `--fix-diff` mode the lint runner must also invoke the full
// typecheck pipeline to catch E2005/E2007 diagnostics.  The logic mirrors
// src/cli/build.nx's `typecheck_for_fix` / `fix_loop` but is integrated
// here so the lint command is the single entry point for all fix-its.

let fix_max_passes = fn () -> i64 do return 32 end

/** Outcome of a single pipeline pass: did we find a fix-it or not? */
type LintFixOutcome = LintFixClean | LintFixSkipped(message: string) | LintFixFound(
  sp: Span,
  fix: Fixit
)

// Run parse + HIR + linearity + typecheck, catch the first fix-able diagnostic.
let pipeline_for_fix = fn (
  src: string,
  input_path: string
) -> LintFixOutcome require { Console, Fs } do
  try
    let tokens = lexer.tokenize(src)
    let ParseDiagnostics(prog, diags: _) = parser.parse_collect(tokens, file: input_path)
    let HirBuildResult(
      program: hir_raw,
      import_cache: _
    ) = build_hir(prog, source_file: input_path, verbose: false)
    let hir_resolved = match hir_raw do
      | HirProgram(
        caps: hp,
        functions: hf,
        externals: he,
        handler_bindings: hb,
        enum_defs: hed,
        exception_groups: heg,
        value_binding_names: hvbns,
        type_defs: htds,
        visible_enum_names: hven,
        ext_wasm_deps: hewds
      ) ->
        let resolved = resolve_all_lazy_no_filter(funcs: hf)
        let expanded_fs = expand_groups_in_functions(funcs: resolved, groups: heg)
        let expanded_hb = expand_groups_in_handler_bindings(bindings: hb, groups: heg)
        HirProgram(
          caps: hp,
          functions: expanded_fs,
          externals: he,
          handler_bindings: expanded_hb,
          enum_defs: hed,
          exception_groups: heg,
          value_binding_names: hvbns,
          type_defs: htds,
          visible_enum_names: hven,
          ext_wasm_deps: hewds
        )
    end
    let hir_wrapped = main_wrap.wrap_main_if_needed(prog: hir_resolved)
    linearity.check_program(prog: hir_wrapped)
    // Body-check only the entry-file functions.
    let local_names = main_wrap.user_main_name() :: extract_function_names(
      defs: get_defs(prog),
      source: input_path
    )
    let hir_checked = tc.check_program(hir: hir_wrapped, local_names, import_index: iidx.empty_module_import_index(), require_main: false)
    tc_linearity.check_program(prog: hir_checked)
    return LintFixClean
  catch e ->
    match e do
      | LazyBindingUnused(name: _, span: sp) ->
        match fixit_for_exn(src, err: e) do
          | Some(val: fix) -> return LintFixFound(sp, fix)
          | None -> return LintFixSkipped(message: err.format_error(err: e))
        end
      | LinearUnused(name: _, span: sp) ->
        match fixit_for_exn(src, err: e) do
          | Some(val: fix) -> return LintFixFound(sp, fix)
          | None -> return LintFixSkipped(message: err.format_error(err: e))
        end
      | _ -> return LintFixSkipped(message: err.format_error(err: e))
    end
  end
end

// Collect lint fix-its from a parsed source (AST-only, fast path).
// Returns only fixits that have a non-zero len (i.e. can be applied),
// including L0001/L0002 fixits whose spans are computed by source scanning.
let collect_lint_fixits = fn (src: string, path: string) -> [ Fixit ] do
  let tokens = lexer.tokenize(src)
  let ParseDiagnostics(prog, diags: _) = parser.parse_collect(tokens, file: path)
  let raw_findings = lint_program(prog)
  let findings = apply_suppressions(src, findings: raw_findings)
  return extract_applicable_fixits(src, findings, acc: [])
end

// Source-scanning helpers for L0001 / L0002 span enrichment.
// These live here (not in lint.nx) because they need the raw source string
// which is only available in the fix-mode driver, not the AST linter.

let lint_is_ident_ch = fn (c: char) -> bool do
  if c >= 'a' && c <= 'z' then return true end
  if c >= 'A' && c <= 'Z' then return true end
  if c >= '0' && c <= '9' then return true end
  if c == '_' then return true end
  return false
end

// Find `word` as a whole word (both adjacent bytes are non-ident) starting
// at `start`. `window` is the max bytes to scan. Returns byte offset or -1.
let find_word_in = fn (src: string, start: i64, window: i64, word: string) -> i64 do
  let n = str.byte_length(s: src)
  let m = str.byte_length(s: word)
  let scan_end = if start + window > n then n else start + window end
  return find_word_in_loop(src: src, i: start, limit: scan_end, word: word, m: m)
end

let find_word_in_loop = fn (src: string, i: i64, limit: i64, word: string, m: i64) -> i64 do
  let n = str.byte_length(s: src)
  if i + m > limit then return 0 - 1 end
  let w = str.byte_substring(s: src, start: i, len: m)
  if w == word then
    let prev_ok = if i == 0 then true else !lint_is_ident_ch(c: str.byte_at(s: src, idx: i - 1)) end
    let next_ok = if i + m >= n then true else !lint_is_ident_ch(c: str.byte_at(s: src, idx: i + m)) end
    if prev_ok && next_ok then return i end
  end
  return find_word_in_loop(src: src, i: i + 1, limit: limit, word: word, m: m)
end

// Scan backward from `i` down to `limit` for a ',' byte.
// Returns its position or -1 if not found.
let find_comma_before_loop = fn (src: string, i: i64, limit: i64) -> i64 do
  if i < limit then return 0 - 1 end
  let c = str.byte_at(s: src, idx: i)
  if c == ',' then return i end
  return find_comma_before_loop(src: src, i: i - 1, limit: limit)
end

// ── comment-intersection guard for the raw-source rewrite spans ─────────────
//
// The Nexus lexer discards comments wholesale (no comment tokens reach the
// token stream), so the L0001/L0002/L0007 enrichment helpers — which carve
// rewrites out of RAW source byte slices — can splice a stray `//` / `/*`
// comment into the rewritten text (or have a `find_word_in` keyword scan match
// a keyword *inside* a comment).  Either way a passing file becomes
// non-compiling.  These helpers detect whether a comment opener appears inside
// `[start, stop)` so the enrichment can defensively bail (return None, leaving
// the source untouched) when one does.
//
// String (`"…"`) and char (`'…'`) literals are tracked so a `//` or `/*` inside
// a literal (e.g. the target expression `"http://x"`) is NOT mistaken for a
// comment — that would over-bail on perfectly safe rewrites.  The scan must
// start at a byte position known to be outside any literal (a token boundary),
// which is how every caller invokes it.
//
// `mode`: 0 = normal code, 1 = inside a string literal, 2 = inside a char
// literal.  A backslash inside a literal escapes the next byte.
let range_has_comment_loop = fn (src: string, i: i64, stop: i64, mode: i64) -> bool do
  if i >= stop then return false end
  let c = str.byte_at(s: src, idx: i)
  if mode == 1 then
    // Inside a string literal.
    if c == '\\' then return range_has_comment_loop(src, i: i + 2, stop, mode: 1) end
    if c == '"' then return range_has_comment_loop(src, i: i + 1, stop, mode: 0) end
    return range_has_comment_loop(src, i: i + 1, stop, mode: 1)
  end
  if mode == 2 then
    // Inside a char literal.
    if c == '\\' then return range_has_comment_loop(src, i: i + 2, stop, mode: 2) end
    if c == '\'' then return range_has_comment_loop(src, i: i + 1, stop, mode: 0) end
    return range_has_comment_loop(src, i: i + 1, stop, mode: 2)
  end
  // Normal code: look for a comment opener, or the start of a literal.
  let c2 = if i + 1 < str.byte_length(s: src) then str.byte_at(s: src, idx: i + 1) else '\0' end
  if c == '/' && c2 == '/' then return true end
  if c == '/' && c2 == '*' then return true end
  if c == '"' then return range_has_comment_loop(src, i: i + 1, stop, mode: 1) end
  if c == '\'' then return range_has_comment_loop(src, i: i + 1, stop, mode: 2) end
  return range_has_comment_loop(src, i: i + 1, stop, mode: 0)
end

// True if a `//` or `/*` comment opener appears within `[start, stop)`, ignoring
// markers inside string/char literals.  `start` must be outside any literal.
let range_has_comment = fn (src: string, start: i64, stop: i64) -> bool do
  let n = str.byte_length(s: src)
  let lo = if start < 0 then 0 else start end
  let hi = if stop > n then n else stop end
  if hi <= lo then return false end
  return range_has_comment_loop(src, i: lo, stop: hi, mode: 0)
end

// Enrich an L0001 fixit: the AST produced `start=0, len=0` as a placeholder.
// We scan from `span.offset` (the `inject` keyword) forward for the whole-word
// `end` that closes the empty inject body, and replace the entire
// `inject … do end` text with "" (empty replacement = delete).
// Returns None if the scan window does not find `end` (defensive).
let enrich_l0001_fixit = fn (src: string, sp: Span, fix: Fixit) -> Option<Fixit> do
  let n = str.byte_length(s: src)
  let Span(offset, line: _, col: _) = sp
  let end_pos = find_word_in(src, start: offset, window: 4096, word: "end")
    if end_pos < 0 then return None end
    // Defensive: if a comment sits between the `inject` keyword and the matched
    // `end`, the raw `end` scan may have matched a keyword inside the comment
    // (truncating the deletion span) — bail rather than corrupt the file.
    if range_has_comment(src, start: offset, stop: end_pos + 3) then return None end
    let real_start = offset
    let raw_len = end_pos + 3 - real_start
    // Consume a trailing newline so the removed line doesn't leave a blank.
    let real_len = if end_pos + 3 < n then
        let nc = str.byte_at(s: src, idx: end_pos + 3)
        if nc == '\n' then raw_len + 1 else raw_len end
      else raw_len end
    let Fixit(start: _, len: _, replacement: _, code, message) = fix
    return Some(val: Fixit(start: real_start, len: real_len, replacement: "", code, message))
end

// Enrich an L0002 fixit: the AST produced `start=0, len=0, replacement=<cap_name>`.
// We scan from `span.offset` (the fn keyword) forward for the `require` clause,
// locate the cap name inside `{…}`, and compute the span to delete:
//   - single cap: delete the entire `require { Cap }` phrase (plus leading space)
//   - multi cap:  delete `Cap` plus its adjacent `, ` or ` ,` separator
// Returns None if the scan fails (defensive; caller falls back to hint-only).
let enrich_l0002_fixit = fn (src: string, sp: Span, fix: Fixit) -> Option<Fixit> do
  let n = str.byte_length(s: src)
  let Fixit(start: _, len: _, replacement: cn, code, message) = fix
  let cn_len = str.byte_length(s: cn)
    if cn_len == 0 then return None end
    let Span(offset: offset, line: _, col: _) = sp
    let req_pos = find_word_in(src, start: offset, window: 2048, word: "require")
      if req_pos < 0 then return None end
      // Find the opening `{` of the require row.
      let brace_open = str.find_byte(s: src, start: req_pos + 7, ch: '{')
      if brace_open < 0 then return None end
      // Find the closing `}`.
      let brace_close = str.find_byte(s: src, start: brace_open + 1, ch: '}')
      if brace_close < 0 then return None end
      // Defensive: if a comment sits anywhere between the `fn` keyword and the
      // closing `}` of the require row, the raw `require` scan may have anchored
      // on a keyword inside the comment (splicing the rewrite) — bail rather
      // than corrupt the file.
      if range_has_comment(src, start: offset, stop: brace_close + 1) then return None end
      // Locate the cap name inside the braces.
      let inner_window = brace_close - brace_open
      let cn_pos = find_word_in(src, start: brace_open + 1, window: inner_window, word: cn)
      if cn_pos < 0 then return None end
      // Is there a comma inside the braces (→ multi-cap row)?
      let comma_in_block = str.find_byte(s: src, start: brace_open + 1, ch: ',')
      let is_single = comma_in_block < 0 || comma_in_block >= brace_close
      if is_single then
        // Remove the entire `require { Cap }`, including one leading space.
        let rm_start = if req_pos > 0 then
            let prev = str.byte_at(s: src, idx: req_pos - 1)
            if prev == ' ' then req_pos - 1 else req_pos end
          else req_pos end
        let rm_len = brace_close + 1 - rm_start
        return Some(val: Fixit(start: rm_start, len: rm_len, replacement: "", code, message))
      else
        // Multi-cap: remove `Cap` + adjacent comma+space.
        let after_cn = cn_pos + cn_len
        // Check if comma follows cn: `cn, NextCap` pattern.
        let comma_after = if after_cn < brace_close then str.byte_at(
          s: src,
          idx: after_cn
        ) else ' ' end
        if comma_after == ',' then
          // Remove `cn,` plus any space after the comma.
          let space_after = after_cn + 1
          let skip = if space_after < brace_close then
              let sc = str.byte_at(s: src, idx: space_after)
              if sc == ' ' then space_after + 1 else space_after end
            else space_after end
          let rm_len = skip - cn_pos
          return Some(val: Fixit(start: cn_pos, len: rm_len, replacement: "", code, message))
        else
          // Comma precedes cn: `PrevCap, cn` pattern — find the comma before cn.
          let comma_pos = find_comma_before_loop(src: src, i: cn_pos - 1, limit: brace_open + 1)
          if comma_pos < 0 then return None end
          let rm_len = cn_pos + cn_len - comma_pos
          return Some(val: Fixit(start: comma_pos, len: rm_len, replacement: "", code, message))
        end
      end
end

// ── L0007 enrichment (single-arm match → let destructuring) ─────────────────
//
// The AST rule (src/lint/rules/single_arm_match.nx) emits a zero-length L0007
// placeholder anchored at the `match` keyword.  Here we recover the real
// rewrite by token-scanning from that offset:
//
//   match <TARGET> do | <PAT> -> <BODY> end
//     ->  let <PAT> = <TARGET>
//         <BODY>
//
// The scan tracks `end`-block nesting so nested `do` / `if` / `try` inside the
// target or body don't confuse the boundary search.  `else if` chains share a
// single `end`, so an `if` directly after `else` is NOT counted as a new
// opener.  Any failure to locate a boundary yields None (defensive — a bad
// rewrite must never corrupt the file).

// Find the SpannedToken with token == TkMatch whose span offset equals `offset`.
// Returns the token list starting at that match, or [] if not found.
let toks_from_match_at = fn (toks: [ SpannedToken ], offset: i64) -> [ SpannedToken ] do
  match toks do
    | [] -> return []
    | SpannedToken(token, span) :: rest ->
      let here = match span do | Span(offset: off, line: _, col: _) -> off == offset end
      let is_match = match token do | TkMatch -> true | _ -> false end
      if here && is_match then return toks end
      return toks_from_match_at(toks: rest, offset)
  end
end

// Does this token open an `end`-terminated block when not an `else if` link?
let is_block_opener = fn (t: Token) -> bool do
  match t do
    | TkDo -> return true
    | TkTry -> return true
    | _ -> return false
  end
end

let is_if_tok = fn (t: Token) -> bool do
  match t do | TkIf -> return true | _ -> return false end
end

let is_else_tok = fn (t: Token) -> bool do
  match t do | TkElse -> return true | _ -> return false end
end

let is_end_tok = fn (t: Token) -> bool do
  match t do | TkEnd -> return true | _ -> return false end
end

let is_do_tok = fn (t: Token) -> bool do
  match t do | TkDo -> return true | _ -> return false end
end

let is_pipe_tok = fn (t: Token) -> bool do
  match t do | TkPipe -> return true | _ -> return false end
end

let is_arrow_tok = fn (t: Token) -> bool do
  match t do | TkArrow -> return true | _ -> return false end
end

let tok_offset = fn (st: SpannedToken) -> i64 do
  let SpannedToken(token: _, span) = st
  let Span(offset: off, line: _, col: _) = span
  return off
end

// Scan forward from after the `match` token for the match's own `do`, tracking
// nested `end`-block depth (so a `do`/`if`/`try` inside the TARGET expression
// is skipped).  Returns the offset of the opening `do` token, or -1.
// `prev_else` carries whether the previous token was `else` (else-if links).
let find_match_do = fn (toks: [ SpannedToken ], depth: i64, prev_else: bool) -> i64 do
  match toks do
    | [] -> return 0 - 1
    | st :: rest ->
      let SpannedToken(token, span: _) = st
      if is_eof(t: token) then return 0 - 1 end
        if depth == 0 && is_do_tok(t: token) then return tok_offset(st) end
        let depth2 = depth + depth_delta(t: token, prev_else)
        return find_match_do(toks: rest, depth: depth2, prev_else: is_else_tok(t: token))
  end
end

let is_eof = fn (t: Token) -> bool do
  match t do | TkEof -> return true | _ -> return false end
end

// `end`-block depth delta for a token, given whether the previous token was
// `else` (an `if` directly after `else` is an else-if link that shares the
// parent's `end`, so it is not a new opener).
let depth_delta = fn (t: Token, prev_else: bool) -> i64 do
  let opens = is_block_opener(t: t) || (is_if_tok(t: t) && !prev_else)
  if opens then return 1 end
  if is_end_tok(t: t) then return 0 - 1 end
  return 0
end

// From the token list positioned at the match's `do`, find the matching `end`
// (depth returns to 0).  Returns the offset of that `end`, or -1.
let find_match_end = fn (toks: [ SpannedToken ], depth: i64, prev_else: bool) -> i64 do
  match toks do
    | [] -> return 0 - 1
    | st :: rest ->
      let SpannedToken(token, span: _) = st
      if is_eof(t: token) then return 0 - 1 end
        let closes = is_end_tok(t: token)
        let depth2 = depth + depth_delta(t: token, prev_else)
        if closes && depth2 == 0 then return tok_offset(st) end
        return find_match_end(toks: rest, depth: depth2, prev_else: is_else_tok(t: token))
  end
end

// Within the arm head (between `do` and the first nested opener / `->`), find
// the first `|` then the first `->` after it.  Returns the offsets as a pair.
// `pipe_off` is the `|` offset (or -1), `arrow_off` is the `->` offset (or -1).
type ArmHead = ArmHead(pipe_off: i64, arrow_off: i64)

let find_arm_head = fn (toks: [ SpannedToken ], pipe_off: i64) -> ArmHead do
  match toks do
    | [] -> return ArmHead(pipe_off, arrow_off: 0 - 1)
    | st :: rest ->
      let SpannedToken(token, span: _) = st
      if is_eof(t: token) then return ArmHead(pipe_off, arrow_off: 0 - 1) end
        if pipe_off < 0 && is_pipe_tok(t: token) then
          return find_arm_head(toks: rest, pipe_off: tok_offset(st))
        end
        if pipe_off >= 0 && is_arrow_tok(t: token) then
          return ArmHead(pipe_off, arrow_off: tok_offset(st))
        end
        return find_arm_head(toks: rest, pipe_off)
  end
end

// Offset of the first non-EOF token AFTER the given offset (used to find where
// the TARGET / PAT / BODY text starts, just past the boundary keyword).
let first_tok_offset_after = fn (toks: [ SpannedToken ], after: i64) -> i64 do
  match toks do
    | [] -> return 0 - 1
    | st :: rest ->
      let SpannedToken(token, span: _) = st
      if is_eof(t: token) then return 0 - 1 end
        if tok_offset(st) > after then return tok_offset(st) end
        return first_tok_offset_after(toks: rest, after)
  end
end

// Slice src[start, stop) and trim surrounding whitespace.
let slice_trim = fn (src: string, start: i64, stop: i64) -> string do
  if start < 0 then return "" end
  if stop < start then return "" end
  let n = str.byte_length(s: src)
  let s2 = if stop > n then n else stop end
  return str.trim(s: str.byte_substring(s: src, start, len: s2 - start))
end

// Leading whitespace of the source line containing byte `offset`.
let line_indent_at = fn (src: string, offset: i64) -> string do
  let line_start = find_line_start(src, i: offset - 1)
  return scan_indent(src, i: line_start, acc: "")
end

let find_line_start = fn (src: string, i: i64) -> i64 do
  if i < 0 then return 0 end
  let c = str.byte_at(s: src, idx: i)
  if c == '\n' then return i + 1 end
  return find_line_start(src, i: i - 1)
end

let scan_indent = fn (src: string, i: i64, acc: string) -> string do
  let n = str.byte_length(s: src)
  if i >= n then return acc end
  let c = str.byte_at(s: src, idx: i)
  if c == ' ' then return scan_indent(src, i: i + 1, acc: acc ++ " ") end
  if c == '\t' then return scan_indent(src, i: i + 1, acc: acc ++ "\t") end
  return acc
end

// Compute the L0007 rewrite from the `match` keyword at sp.offset.
let enrich_l0007_fixit = fn (src: string, sp: Span, fix: Fixit) -> Option<Fixit> do
  let Span(offset: match_off, line: _, col: _) = sp
  let toks = lexer.tokenize(src)
    let from_match = toks_from_match_at(toks, offset: match_off)
    match from_match do
      | [] -> return None
      | _ :: after_match ->
        // TARGET starts at the first token after `match`.
        let target_start = first_tok_offset_after(toks: from_match, after: match_off)
        let do_off = find_match_do(toks: after_match, depth: 0, prev_else: false)
        if target_start < 0 || do_off < 0 then return None end
        // Tokens at-or-after the `do`.
        let from_do = toks_from_offset(toks: after_match, offset: do_off)
        let end_off = find_match_end(toks: from_do, depth: 0, prev_else: false)
        if end_off < 0 then return None end
        // Defensive: the rewrite reconstructs the `let`/body from raw source
        // slices of `[match_off, end_off)`.  A comment inside that span would be
        // spliced into the slice (e.g. between the pattern and `->`, commenting
        // out the `= target`) or silently dropped — bail rather than corrupt.
        if range_has_comment(src, start: match_off, stop: end_off) then return None end
        let ArmHead(pipe_off, arrow_off) = find_arm_head(toks: from_do, pipe_off: 0 - 1)
        if pipe_off < 0 || arrow_off < 0 then return None end
        let target_text = slice_trim(src, start: target_start, stop: do_off)
        let pat_start = first_tok_offset_after(toks: from_do, after: pipe_off)
        let pat_text = slice_trim(src, start: pat_start, stop: arrow_off)
        let body_start = first_tok_offset_after(toks: from_do, after: arrow_off)
        let body_text = slice_trim(src, start: body_start, stop: end_off)
        if str.byte_length(s: target_text) == 0 then return None end
        if str.byte_length(s: pat_text) == 0 then return None end
        if str.byte_length(s: body_text) == 0 then return None end
        let indent = line_indent_at(src, offset: match_off)
        let replacement = "let " ++ pat_text ++ " = " ++ target_text
          ++ "\n" ++ indent ++ body_text
        let total_len = end_off + 3 - match_off
        let Fixit(start: _, len: _, replacement: _, code, message) = fix
        return Some(val: Fixit(start: match_off, len: total_len, replacement, code, message))
    end
end

// Return the token list starting at the token whose offset == `offset`.
let toks_from_offset = fn (toks: [ SpannedToken ], offset: i64) -> [ SpannedToken ] do
  match toks do
    | [] -> return []
    | st :: rest ->
      if tok_offset(st) == offset then return toks end
      return toks_from_offset(toks: rest, offset)
  end
end

// Attempt enrichment of a zero-len fixit for L0001, L0002, or L0007.
// Returns the updated accumulator (with enriched fixit prepended if successful).
let enrich_zero_len_fixit = fn (
  src: string,
  sp: Span,
  fix: Fixit,
  acc: [ Fixit ],
  code: string
) -> [ Fixit ] do
  if code == "L0001" then
    match enrich_l0001_fixit(src: src, sp: sp, fix: fix) do
      | Some(val: real_fix) -> return real_fix :: acc
      | None -> return acc
    end
  end
  if code == "L0002" then
    match enrich_l0002_fixit(src: src, sp: sp, fix: fix) do
      | Some(val: real_fix) -> return real_fix :: acc
      | None -> return acc
    end
  end
  if code == "L0007" then
    match enrich_l0007_fixit(src: src, sp: sp, fix: fix) do
      | Some(val: real_fix) -> return real_fix :: acc
      | None -> return acc
    end
  end
  return acc
end

let extract_applicable_fixits = fn (
  src: string,
  findings: [ LintFinding ],
  acc: [ Fixit ]
) -> [ Fixit ] do
  match findings do
    | [] -> return list.reverse(xs: acc)
    | LintFinding(code: _, severity: _, message: _, fix_it, span) :: rest ->
      match fix_it do
        | None -> return extract_applicable_fixits(src, findings: rest, acc: acc)
        | Some(val: fix) ->
          let Fixit(start: _, len, replacement: _, code, message: _) = fix
          let acc2 = if len > 0 then
                // Real span: apply as-is (E2005/E2007 style).
                fix :: acc
              else
                // len=0: attempt source-scan enrichment for L0001/L0002.
                enrich_zero_len_fixit(src: src, sp: span, fix: fix, acc: acc, code: code)
              end
            return extract_applicable_fixits(src, findings: rest, acc: acc2)
      end
  end
end

// One fix pass on a single file: collect lint findings + pipeline diagnostics,
// apply the first applicable fixit. Returns whether something was applied.
type FixPassResult = FixPassNoChange | FixPassApplied(
  new_src: string,
  sp: Span,
  fix: Fixit
) | FixPassPipelineError(message: string)

let run_fix_pass = fn (src: string, path: string) -> FixPassResult require { Console, Fs } do
  // First: collect lint-based fix-its (AST-only, cheap). Apply these before
  // touching the heavy pipeline so a purely syntactic rewrite never depends on
  // typechecking the file's whole import closure. This also keeps the pass
  // tractable on large files, where running the full pipeline on every pass
  // would exhaust the wasm32 linear-memory limit.
  let lint_fixits = collect_lint_fixits(src, path)
  match lint_fixits do
    | fix :: _ ->
      let Fixit(start: _, len: _, replacement: _, code: _, message: _) = fix
      let new_src = apply_fixit(src, fix)
      let sp = Span(offset: 0, line: 1, col: 1)
      return FixPassApplied(new_src, sp, fix)
    | [] ->
      // No lint fix-its left: run the pipeline to find E2005/E2007 fix-its.
      let pipeline_outcome = pipeline_for_fix(src, input_path: path)
      match pipeline_outcome do
        | LintFixClean -> return FixPassNoChange
        | LintFixSkipped(message) -> return FixPassPipelineError(message)
        | LintFixFound(sp, fix) ->
          let new_src = apply_fixit(src, fix)
          return FixPassApplied(new_src, sp, fix)
      end
  end
end

// Fix loop for a single file: iterate until fixpoint or iteration cap.
let fix_loop_for_file = fn (
  path: string,
  src: string,
  fix_diff: bool,
  pass: i64,
  fixes_applied: i64
) -> i64 require { Console, Fs } do
  if pass >= fix_max_passes() then
    Console.eprintln(val: "nexus lint --fix: iteration cap reached for " ++ path ++ "; remaining fix-its skipped")
    return 0
  end
  let result = run_fix_pass(src, path)
  match result do
    | FixPassNoChange ->
      return 0
    | FixPassPipelineError(message) ->
      // A residual pipeline error after the fix pass must ALWAYS surface as a
      // nonzero exit, even when earlier fix-its were applied: a corrupting
      // autofix (e.g. a comment-unaware rewrite that produced non-compiling
      // code) would otherwise be silently reported as success (exit 0).
      Console.eprintln(val: message)
      return 1
    | FixPassApplied(new_src, sp, fix) ->
      if fix_diff then
        let old_text = slice_old_text(src, fix)
        Console.println(val: format_diff_block(file: path, fix, old_text))
        return fix_loop_for_file(
          path,
          src: new_src,
          fix_diff,
          pass: pass + 1,
          fixes_applied: fixes_applied + 1
        )
      else
        let Fixit(start: _, len: _, replacement: _, code: _, message: _) = fix
        Fs.write_string(path, content: new_src)
          Console.println(val: format_check_line(file: path, sp, fix))
        return fix_loop_for_file(
          path,
          src: new_src,
          fix_diff,
          pass: pass + 1,
          fixes_applied: fixes_applied + 1
        )
      end
  end
end

// Run fix mode on a single file.
let run_fix_on_lint_file = fn (path: string, fix_diff: bool) -> i64 require { Console, Fs } do
  if Fs.exists(path) == false then
    Console.eprintln(val: "nexus lint --fix: file not found: " ++ path)
    return 1
  end
  try
    let src = Fs.read_to_string(path)
    return fix_loop_for_file(path, src, fix_diff, pass: 0, fixes_applied: 0)
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

/** Run fix mode over a list of files. Entry point for the lint driver's
 *  `--fix` / `--fix-diff` path. Returns 0 when every file is clean, 1 if any
 *  file reported a residual pipeline error or could not be read. */
export let run_fix_each_file = fn (
  paths: [ string ],
  fix_diff: bool,
  all_ok: bool
) -> i64 require { Console, Fs } do
  match paths do
    | [] ->
      if all_ok then return 0 else return 1 end
    | p :: rest ->
      let rc = run_fix_on_lint_file(path: p, fix_diff)
      let ok2 = all_ok && (rc == 0)
      return run_fix_each_file(paths: rest, fix_diff, all_ok: ok2)
  end
end
