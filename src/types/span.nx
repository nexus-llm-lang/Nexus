/**
 * types/span: Source-position primitive shared across all compiler phases.
 *
 * Span records a byte offset plus 1-based line and column numbers.
 * It is attached to every AST node, HIR node, diagnostic, and lint finding,
 * and is safe to import from IR, typecheck, backend, lint, and surface layers.
 */

/** Public type Span. */
export type Span = Span(offset: i64, line: i64, col: i64)
