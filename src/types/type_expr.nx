/**
 * types/type_expr: Type expression vocabulary shared across all compiler phases.
 *
 * TypeExpr and its supporting types (NamedType, VariantField, VariantDef,
 * EnumDef, RecordDef) carry no dependency on parse trees and are safe to
 * import from IR, typecheck, backend, and surface layers alike.
 */

/** Public type NamedType. */
export type NamedType = NamedType(name: string, typ: TypeExpr)

/** Public type VariantField. */
export type VariantField = VariantField(name: Option<string>, typ: TypeExpr)

/** Public type TypeExpr. */
export type TypeExpr =
  TyI32 | TyI64 | TyF32 | TyF64 | TyBool | TyChar | TyString | TyUnit
  | TyIntLit | TyFloatLit
  | TyUserDefined(name: string, args: [ TypeExpr ])
  | TyVar(name: string)
  | TyArrow(params: [ NamedType ], ret: TypeExpr, requires: TypeExpr, throw_row: TypeExpr)
  | TyRef(inner: TypeExpr)
  | TyLinear(inner: TypeExpr)
  | TyLazy(inner: TypeExpr, require_row: TypeExpr, throw_row: TypeExpr)
  | TyBorrow(inner: TypeExpr)
  | TyArray(elem: TypeExpr)
  | TyList(elem: TypeExpr)
  | TyRecord(fields: [ NamedType ])
  | TyRow(types: [ TypeExpr ], rest: Option<TypeExpr>)
  | TyHandler(name: string, requires: TypeExpr)

/** Public type VariantDef. */
export type VariantDef = VariantDef(name: string, fields: [ VariantField ])

/** Public type EnumDef.
 *
 *  `layout_variants` is a LAYOUT-ONLY copy of the constructor list that is
 *  preserved even when `variants` is stripped to `[]` for an opaque imported
 *  enum (D-Type-Sum-Opaque). `variants` stays `[]` so typecheck visibility,
 *  exhaustiveness (SigInfinite) and constructor-registration keep treating the
 *  type as opaque, while the LIR field-extraction path can still recover the
 *  field DECLARATION order (and hence the alphabetical heap layout) for a
 * cross-module field read. It is `[]` for every other enum,
 *  whose layout is already carried by `variants` / the VariantIndex
 *  `by_variant` map. Only `lookup_variant_def_in_index` consults it. */
export type EnumDef = EnumDef(
  name: string,
  is_public: bool,
  is_opaque: bool,
  type_params: [ string ],
  variants: [ VariantDef ],
  layout_variants: [ VariantDef ]
)

/** Public type RecordDef. */
export type RecordDef = RecordDef(
  name: string,
  is_public: bool,
  type_params: [ string ],
  fields: [ NamedType ]
)
