/**
 * cli/args: GlobalFlags type and parse_global_args.
 *
 * Parses every driver-global flag in one argparse pass, leaving subcommand
 * keywords + the input filename in `positionals` and any post-`--` user-program
 * argv in `remaining`. Replaces the legacy strip_verbose_flag / strip_output_flag
 * / strip_polyglot_flags / strip_coverage_flag / strip_format_flag /
 * strip_explain_flags chain (issue nexus-8vu5).
 */

import { ManifestMode, KeepManifest, StripManifest } from "src/backend/polyglot.nx"
import { InvalidUsage } from "src/common/error.nx"
import { Option, Some, None } from "std:option"
import {
  ParseResult,
  parse_permissive, get_flag, get_opt, get_positionals_all, get_remaining, is_ok, first_error
} from "std:argparse"
import { ExplainCaps, ExplainYes, ExplainNone, ExplainWasmtime, ExplainFormat, FormatText, FormatJson,
         read_explain_caps_opt, read_format_opt } from "src/cli/format.nx"
import { OutputMode, BareBinary, PolyglotLauncher } from "src/pipeline.nx"
import { cli_specs } from "src/cli/specs.nx"

export type GlobalFlags = GlobalFlags(
  positionals: [string],
  remaining: [string],
  verbose: bool,
  output: Option<string>,
  diag_format: ExplainFormat,
  explain: ExplainCaps,
  explain_format: ExplainFormat,
  coverage: bool,
  output_mode: OutputMode,
  manifest_mode: ManifestMode,
  dump_imports: bool,
  p3: bool
)

export let parse_global_args = fn (args: [string]) -> GlobalFlags throws { InvalidUsage } do
  let result = parse_permissive(args, specs: cli_specs())
  if !is_ok(result) then
    raise InvalidUsage(detail: first_error(result))
  end
  let verbose = get_flag(result, name: "verbose")
  let output = get_opt(result, name: "output")
  let diag_format = read_format_opt(result, name: "format", flag_name: "--format")
  let explain = read_explain_caps_opt(result)
  let explain_format = read_format_opt(result, name: "explain-capabilities-format", flag_name: "--explain-capabilities-format")
  let coverage = get_flag(result, name: "coverage")
  let polyglot = get_flag(result, name: "polyglot")
  let remain_manifest = get_flag(result, name: "remain-manifest")
  let dump_imports = get_flag(result, name: "dump-imports")
  let p3 = get_flag(result, name: "p3")
  let output_mode = if polyglot then PolyglotLauncher else BareBinary end
  let manifest_mode = if remain_manifest then KeepManifest else StripManifest end
  return GlobalFlags(
    positionals: get_positionals_all(result),
    remaining: get_remaining(result),
    verbose, output, diag_format, explain, explain_format, coverage,
    output_mode, manifest_mode, dump_imports, p3
  )
end
