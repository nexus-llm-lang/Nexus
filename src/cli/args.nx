/**
 * cli/args: GlobalFlags type and parse_global_args.
 *
 * Parses every driver-global flag in one argparse pass, leaving subcommand
 * keywords + the input filename in `positionals` and any post-`--` user-program
 * argv in `remaining`. Replaces the legacy strip_verbose_flag / strip_output_flag
 * / strip_coverage_flag / strip_format_flag / strip_explain_flags chain.
 */

import { InvalidUsage } from "src/diagnostics/error.nx"
import { Option, Some, None } from "std:option"
import {
  ParseResult,
  parse_permissive, get_flag, get_opt, get_positionals_all, get_remaining, is_ok, first_error
} from "std:argparse"
import { ExplainCaps, ExplainYes, ExplainNone, ExplainWasmtime, ExplainFormat, FormatText, FormatJson,
         read_explain_caps_opt, read_format_opt } from "src/cli/format.nx"
import { cli_specs } from "src/cli/specs.nx"

export type GlobalFlags = GlobalFlags(
  positionals: [ string ],
  remaining: [ string ],
  verbose: bool,
  output: Option<string>,
  diag_format: ExplainFormat,
  explain: ExplainCaps,
  explain_format: ExplainFormat,
  coverage: bool,
  profile_out: Option<string>,
  dump_imports: bool,
  p3: bool,
  p3_component: bool,
  p2_component: bool,
  no_lint: bool,
  lint_level_error: bool,
  deny: Option<string>
)

// Intentional narrow row: only argparse failures (bad flags, invalid
// option values) can escape from this function. Callers in main.nx
// catch InvalidUsage at exit code 2 — separate from SandboxRefusal
// (exit 3) and I/O errors (exit 1).
export let parse_global_args = fn (args: [ string ]) -> GlobalFlags throws { InvalidUsage } do
  let result = parse_permissive(args, specs: cli_specs())
  if !is_ok(result) then
    throw InvalidUsage(detail: first_error(result))
  end
  let verbose = get_flag(result, name: "verbose")
  let output = get_opt(result, name: "output")
  let diag_format = read_format_opt(result, name: "format", flag_name: "--format")
  let explain = read_explain_caps_opt(result)
  let explain_format = read_format_opt(
    result,
    name: "explain-capabilities-format",
    flag_name: "--explain-capabilities-format"
  )
  let coverage = get_flag(result, name: "coverage")
  let profile_out = get_opt(result, name: "profile-out")
  let dump_imports = get_flag(result, name: "dump-imports")
  let p3_component = get_flag(result, name: "p3-component")
  let p2_component = get_flag(result, name: "p2-component")
  let p3 = get_flag(result, name: "p3") || p3_component
  let no_lint = get_flag(result, name: "no-lint")
  let lint_level_error = read_lint_level_error(result)
  let deny = get_opt(result, name: "deny")
  return GlobalFlags(
    positionals: get_positionals_all(result),
    remaining: get_remaining(result),
    verbose, output, diag_format, explain, explain_format, coverage, profile_out,
    dump_imports, p3, p3_component, p2_component,
    no_lint, lint_level_error, deny
  )
end

// Read --lint-level (warn|error). Default (absent) is error → true: lint
// findings gate the build unless the caller opts out with --lint-level=warn.
// The advisory carve-out (cli/lint_on_build.nx advisory_codes) still keeps
// intent/style rules non-fatal under the error default.
// Intentional narrow row: only an unrecognized value faults, propagating
// InvalidUsage to main.nx exit code 2 (same cluster as read_format_opt).
let read_lint_level_error = fn (result: ParseResult) -> bool throws { InvalidUsage } do
  match get_opt(result, name: "lint-level") do
    | None -> return true
    | Some(val: v) ->
      if v == "error" then return true end
      if v == "warn" then return false end
      throw InvalidUsage(detail: "invalid --lint-level value: " ++ v ++ " (expected warn|error)")
  end
end
