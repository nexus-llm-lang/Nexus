/**
 * cli/output: Diagnostic and build-result printing helpers.
 *
 * Covers print_parse_diags (text/json) and print_build_result (text/json),
 * which are used by multiple dump subcommands and the main build pipeline.
 */

import { CompilerDiagnostic, format_diagnostic_json, format_summary_json } from "src/common/error.nx"
import { Console }, * as stdio from "std:stdio"
import * as list from "std:list"
import * as str from "std:str"
import { ExplainCaps, ExplainYes, ExplainNone, ExplainWasmtime, ExplainFormat, FormatText, FormatJson, build_run_cmd, wasmtime_feature_flags } from "src/cli/format.nx"

let print_parse_diags_text = fn (diags: [ CompilerDiagnostic ]) -> unit require { Console } do
  match diags do
    | [] -> return ()
    | d :: rest ->
      match d do | CompilerDiagnostic(code, severity: _, file: _, line: _, column: _, message) ->
        let line_str = if str.length(s: code) > 0 then message ++ " [" ++ code ++ "]" else message end
        Console.eprintln(val: line_str)
      end
      return print_parse_diags_text(diags: rest)
  end
end

let print_parse_diags_json = fn (diags: [ CompilerDiagnostic ]) -> unit require { Console } do
  match diags do
    | [] -> return ()
    | d :: rest ->
      Console.eprintln(val: format_diagnostic_json(diag: d))
      return print_parse_diags_json(diags: rest)
  end
end

export let print_parse_diags = fn (diags: [ CompilerDiagnostic ], format: ExplainFormat) -> unit require { Console } do
  match format do
    | FormatText -> print_parse_diags_text(diags)
    | FormatJson -> print_parse_diags_json(diags)
  end
end

let quote_strings_local = fn (xs: [ string ]) -> [ string ] do
  match xs do
    | [] -> return []
    | v :: rest -> return ("\"" ++ v ++ "\"") :: quote_strings_local(xs: rest)
  end
end

let collect_all_wasmtime_flags_local = fn (caps: [ string ]) -> [ string ] do
  match caps do
    | [] -> return []
    | c :: rest ->
      let flags = if c == "Net" then ["--wasi", "inherit-network"] else [] end
      let flags = if c == "Fs" then ["--dir", "."] else flags end
      return list.concat(xs: flags, ys: collect_all_wasmtime_flags_local(caps: rest))
  end
end

let print_build_result_text = fn (output_name: string, caps: [ string ], explain: ExplainCaps, output_is_polyglot: bool) -> unit require { Console } do
  Console.eprintln(val: "Built " ++ output_name)
  match explain do
    | ExplainNone -> return ()
    | ExplainYes ->
      if !list.is_empty(xs: caps) then
        Console.eprintln(val: "Capabilities: " ++ str.join(xs: caps, sep: ", "))
      end
    | ExplainWasmtime ->
      if !list.is_empty(xs: caps) then
        Console.eprintln(val: "Capabilities: " ++ str.join(xs: caps, sep: ", "))
      end
      if output_is_polyglot then
        Console.eprintln(val: "Run: chmod +x " ++ output_name ++ " && ./" ++ output_name)
      else
        Console.eprintln(val: "Run: " ++ build_run_cmd(output_name, caps))
      end
  end
end

let print_build_result_json = fn (output_name: string, caps: [ string ], explain: ExplainCaps, output_is_polyglot: bool) -> unit require { Console } do
  match explain do
    | ExplainNone ->
      Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\"}")
    | ExplainYes ->
      let caps_quoted = quote_strings_local(xs: caps)
      Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\",\"capabilities\":[" ++ str.join(xs: caps_quoted, sep: ",") ++ "]}")
    | ExplainWasmtime ->
      let caps_quoted = quote_strings_local(xs: caps)
      if output_is_polyglot then
        let cmd = "chmod +x " ++ output_name ++ " && ./" ++ output_name
        Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\",\"capabilities\":[" ++ str.join(xs: caps_quoted, sep: ",") ++ "],\"polyglot\":{\"command\":\"" ++ cmd ++ "\"}}")
      else
        let all_flags = list.concat(xs: wasmtime_feature_flags(), ys: collect_all_wasmtime_flags_local(caps))
        let flags_quoted = quote_strings_local(xs: all_flags)
        let cmd = build_run_cmd(output_name, caps)
        Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\",\"capabilities\":[" ++ str.join(xs: caps_quoted, sep: ",") ++ "],\"wasmtime\":{\"command\":\"" ++ cmd ++ "\",\"flags\":[" ++ str.join(xs: flags_quoted, sep: ",") ++ "]}}")
      end
  end
end

export let print_build_result = fn (output_name: string, caps: [ string ], explain: ExplainCaps, format: ExplainFormat, output_is_polyglot: bool) -> unit require { Console } do
  match format do
    | FormatText -> print_build_result_text(output_name, caps, explain, output_is_polyglot)
    | FormatJson -> print_build_result_json(output_name, caps, explain, output_is_polyglot)
  end
end
