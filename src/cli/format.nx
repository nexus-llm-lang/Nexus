/**
 * cli/format: Capability reporting types and output formatters.
 *
 * Covers --explain-capabilities / --explain-capabilities-format,
 * wasmtime argv construction, and the exec_run_artifact helper.
 */

import { Option, Some, None } from "std:option"
import { Console }, * as stdio from "std:stdio"
import { Proc, ExecResult }, * as proc from "std:proc"
import * as str from "std:str"
import * as list from "std:list"
import { SpannedTopLevel, ExprLambda, GlobalLet, TypeExpr, TyRow, TyUserDefined } from "src/common/ast.nx"
import { InvalidUsage, SandboxRefusal } from "src/common/error.nx"
import { ParseResult, get_opt } from "std:argparse"

/** Sandbox options for `nexus run`. */
export type SandboxOpts = SandboxOpts(
  seed: Option<string>,
  frozen_clock: Option<string>,
  max_time: Option<string>,
  max_mem: Option<string>,
  no_net: bool,
  no_fs: bool,
  no_clock: bool,
  no_rand: bool,
  tmp_fs: Option<string>
)

export type ExplainCaps = ExplainYes | ExplainNone | ExplainWasmtime

export type ExplainFormat = FormatText | FormatJson

let parse_explain_caps_value = fn (s: string) -> Option<ExplainCaps> do
  if s == "yes" then return Some(val: ExplainYes) end
  if s == "none" then return Some(val: ExplainNone) end
  if s == "wasmtime" then return Some(val: ExplainWasmtime) end
  return None
end

let parse_explain_format_value = fn (s: string) -> Option<ExplainFormat> do
  if s == "text" then return Some(val: FormatText) end
  if s == "json" then return Some(val: FormatJson) end
  return None
end

let perm_to_cap_name = fn (perm: string) -> Option<string> do
  if perm == "PermFs" then return Some(val: "Fs") end
  if perm == "PermNet" then return Some(val: "Net") end
  if perm == "PermConsole" then return Some(val: "Console") end
  if perm == "PermRandom" then return Some(val: "Random") end
  if perm == "PermClock" then return Some(val: "Clock") end
  if perm == "PermProc" then return Some(val: "Proc") end
  if perm == "PermEnv" then return Some(val: "Env") end
  return None
end

let collect_cap_names = fn (xs: [TypeExpr]) -> [string] do
  match xs do
    | [] -> return []
    | TyUserDefined(name, args: []) :: rest ->
      if let Some(val: c) = perm_to_cap_name(perm: name) then
        return c :: collect_cap_names(xs: rest)
      end
      return collect_cap_names(xs: rest)
    | _ :: rest -> return collect_cap_names(xs: rest)
  end
end

let extract_caps_from_row = fn (row: TypeExpr) -> [string] do
  if let TyRow(types, rest: _) = row then
    return collect_cap_names(xs: types)
  end
  return []
end

export let list_has_str = fn (xs: [string], s: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true end
      return list_has_str(xs: rest, s)
  end
end

/** Walk top-level defs; for `let main = fn (...) require { Perm… }`, return
 *  the capability names. Adds `Proc` when `main` takes `args` so argv can
 *  be read at runtime.
 */
export let find_main_caps = fn (defs: [SpannedTopLevel]) -> [string] do
  match defs do
    | [] -> return []
    | SpannedTopLevel(node: TLLet(def: GlobalLet(name, is_public: _, typ: _, value: SpannedExpr(node: ExprLambda(type_params: _, params, ret_type: _, requires, throw_row: _, body: _), span: _))), span: _) :: rest ->
      if name == "main" then
        let caps = extract_caps_from_row(row: requires)
        if !list.is_empty(xs: params) then
          if list_has_str(xs: caps, s: "Proc") then return caps end
          return list.concat(xs: caps, ys: ["Proc"])
        end
        return caps
      end
      return find_main_caps(defs: rest)
    | _ :: rest -> return find_main_caps(defs: rest)
  end
end

let cap_wasmtime_flags = fn (name: string) -> [string] do
  // Net: only `-S inherit-network` is safe on the preview1 core wasm we
  // emit; `-S http` (wasi-http) requires a preview2 component and would
  // fail at startup with "Cannot enable wasi-http for core wasm modules"
  // Until a preview2 bridge lands the stdlib HTTP primitives
  // are stubs anyway (see nxlib/stdlib/network.nx), so this flag is mostly
  // a marker that the program touches the network.
  if name == "Net" then return ["--wasi", "inherit-network"] end
  if name == "Fs" then return ["--dir", "."] end
  return []
end

let collect_all_wasmtime_flags = fn (caps: [string]) -> [string] do
  match caps do
    | [] -> return []
    | c :: rest -> return list.concat(xs: cap_wasmtime_flags(name: c), ys: collect_all_wasmtime_flags(caps: rest))
  end
end

/** Wasm proposals required at runtime. The inlined stdlib uses every one of
 *  these (TCO, throw/throws, closures, handlers, threads/atomics for `@`), so
 *  emit them all whenever wasmtime mode is selected — detection on the user's
 *  AST alone would underreport because stdlib brings them in regardless.
 */
export let wasmtime_feature_flags = fn () -> [string] do
  return ["-W", "tail-call=y", "-W", "exceptions=y", "-W", "function-references=y", "-W", "stack-switching=y", "-W", "threads=y", "-W", "shared-memory=y", "-S", "threads"]
end

let quote_strings = fn (xs: [string]) -> [string] do
  match xs do
    | [] -> return []
    | v :: rest -> return ("\"" ++ v ++ "\"") :: quote_strings(xs: rest)
  end
end

export let build_run_cmd = fn (output_name: string, caps: [string]) -> string do
  let feat_flags = wasmtime_feature_flags()
  let cap_flags = collect_all_wasmtime_flags(caps)
  let argv = list.concat(xs: feat_flags, ys: list.concat(xs: cap_flags, ys: [output_name]))
  return "wasmtime run " ++ str.join(xs: argv, sep: " ")
end

/** Build the wasmtime argv for `nexus run`: `["run", -W..., -S..., cap-flags,
 *  wasm_path, user_args...]`. Mirrors `build_run_cmd` but emits a list so it
 *  can be fed straight to `Proc.exec`.
 */
let build_wasmtime_run_argv = fn (wasm_path: string, caps: [string], user_args: [string]) -> [string] do
  let feat_flags = wasmtime_feature_flags()
  let cap_flags = collect_all_wasmtime_flags(caps)
  let prefix = list.concat(xs: ["run"], ys: list.concat(xs: feat_flags, ys: cap_flags))
  return list.concat(xs: prefix, ys: list.concat(xs: [wasm_path], ys: user_args))
end

/** Check whether a cap name is in the strip-list implied by sandbox opts.
 *  Returns the flag name that caused the strip, or None if not stripped.
 */
let sandbox_strips_cap = fn (capability: string, sb: SandboxOpts) -> Option<string> do
  let SandboxOpts(seed: _, frozen_clock: _, max_time: _, max_mem: _, no_net, no_fs, no_clock, no_rand, tmp_fs: _) = sb
  if capability == "Net" && no_net then return Some(val: "--no-net") end
  if capability == "Fs" && no_fs then return Some(val: "--no-fs") end
  if capability == "Clock" && no_clock then return Some(val: "--no-clock") end
  if capability == "Random" && no_rand then return Some(val: "--no-rand") end
  return None
end

/** Find the first cap that is stripped by the sandbox opts.
 *  Returns Some((cap, flag)) if there is a violation, None otherwise.
 */
export let first_stripped_cap = fn (caps: [string], sb: SandboxOpts) -> Option<string> do
  match caps do
    | [] -> return None
    | c :: rest ->
      match sandbox_strips_cap(capability: c, sb) do
        | Some(val: flag) -> return Some(val: "capability '" ++ c ++ "' is required by the program but was stripped by " ++ flag ++ " [E4010]")
        | None -> return first_stripped_cap(caps: rest, sb)
      end
  end
end

/** Validate that none of the required caps are stripped.
 *  Raises SandboxRefusal on the first violated cap.
 *
 *  Intentional narrow row: SandboxRefusal is the only fault here.
 *  main.nx catches it separately (exit code 3) from InvalidUsage
 *  (exit code 2), so the two exception types must not be mixed into
 *  a wider row at this layer.
 */
export let check_no_cap_stripped = fn (caps: [string], sb: SandboxOpts) -> unit throws { SandboxRefusal } do
  match caps do
    | [] -> return ()
    | c :: rest ->
      match sandbox_strips_cap(capability: c, sb) do
        | Some(val: flag) -> throw SandboxRefusal(capability: c, flag)
        | None -> return check_no_cap_stripped(caps: rest, sb)
      end
  end
end

/** Build extra wasmtime flags derived from SandboxOpts:
 *  --max-mem → -W max-size=<bytes>
 *  --max-time → --wasm-timeout <ms>ms  (requires wasmtime epoch interruption)
 *  --tmp-fs → --dir=<dir>  (replaces the default --dir=. added by cap_wasmtime_flags)
 *  --seed and --frozen-clock are passed as WASM env-vars via NEXUS_SEED / NEXUS_FROZEN_CLOCK
 *  that the stdlib runtime reads on startup.
 *
 *  Note: --seed / --frozen-clock are forwarded to the program as
 *  NEXUS_SEED=<N> and NEXUS_FROZEN_CLOCK=<epoch> via wasmtime --env.
 */
let build_sandbox_argv = fn (sb: SandboxOpts, caps: [string]) -> [string] do
  let SandboxOpts(seed, frozen_clock, max_time, max_mem, no_net: _, no_fs, no_clock: _, no_rand: _, tmp_fs) = sb
  let acc = []
  // --max-mem MB → -W max-size=<bytes>
  let acc = match max_mem do
    | None -> acc
    | Some(val: mb) -> list.concat(xs: acc, ys: ["-W", "max-size=" ++ mb ++ "000000"])
  end
  // --max-time MS → --epoch-interruption + --wasm-timeout <ms>ms
  let acc = match max_time do
    | None -> acc
    | Some(val: ms) -> list.concat(xs: acc, ys: ["-W", "epoch-interruption=y", "--wasm-timeout", ms ++ "ms"])
  end
  // --seed N → pass as NEXUS_SEED env var
  let acc = match seed do
    | None -> acc
    | Some(val: n) -> list.concat(xs: acc, ys: ["--env", "NEXUS_SEED=" ++ n])
  end
  // --frozen-clock EPOCH → pass as NEXUS_FROZEN_CLOCK env var
  let acc = match frozen_clock do
    | None -> acc
    | Some(val: ep) -> list.concat(xs: acc, ys: ["--env", "NEXUS_FROZEN_CLOCK=" ++ ep])
  end
  // --tmp-fs DIR → use dir as Fs root instead of '.'
  // We only add --dir if Fs cap is present and not stripped
  let acc = match tmp_fs do
    | None -> acc
    | Some(val: dir) ->
      // Replace the default --dir=. with the specified dir
      list.concat(xs: acc, ys: ["--dir", dir ++ "::."])
  end
  return acc
end

/** Remove cap-derived flags for stripped caps.
 *  When --no-fs is set, we skip adding --dir=. for Fs.
 *  When --no-net is set, we skip --wasi inherit-network.
 */
let cap_wasmtime_flags_with_sandbox = fn (name: string, sb: SandboxOpts) -> [string] do
  let SandboxOpts(seed: _, frozen_clock: _, max_time: _, max_mem: _, no_net, no_fs, no_clock: _, no_rand: _, tmp_fs) = sb
  if name == "Net" then
    if no_net then return [] end
    return ["--wasi", "inherit-network"]
  end
  if name == "Fs" then
    if no_fs then return [] end
    // If tmp_fs is set, the dir override is handled in build_sandbox_argv
    match tmp_fs do
      | Some(_) -> return []
      | None -> return ["--dir", "."]
    end
  end
  return []
end

let collect_wasmtime_flags_with_sandbox = fn (caps: [string], sb: SandboxOpts) -> [string] do
  match caps do
    | [] -> return []
    | c :: rest -> return list.concat(
        xs: cap_wasmtime_flags_with_sandbox(name: c, sb),
        ys: collect_wasmtime_flags_with_sandbox(caps: rest, sb))
  end
end

/** Build the wasmtime argv for `nexus run` with sandbox opts applied. */
export let build_wasmtime_run_argv_sandbox = fn (wasm_path: string, caps: [string], user_args: [string], sb: SandboxOpts) -> [string] do
  let feat_flags = wasmtime_feature_flags()
  let cap_flags = collect_wasmtime_flags_with_sandbox(caps, sb)
  let sandbox_flags = build_sandbox_argv(sb, caps)
  let prefix = list.concat(xs: ["run"], ys: list.concat(xs: feat_flags, ys: list.concat(xs: cap_flags, ys: sandbox_flags)))
  return list.concat(xs: prefix, ys: list.concat(xs: [wasm_path], ys: user_args))
end

/** Spawn `wasmtime run` against the freshly-built artifact and return the
 *  child's exit code. The Proc.exec stub returns -1 under WASI preview1 (the
 *  wasmtime profile this driver actually runs under); detect that and tell
 *  the user to switch to the polyglot `./nexus` launcher, which intercepts
 *  `run` at the shell layer and drives wasmtime directly.
 *
 *  When `sandbox` is provided the cap strip flags are validated and the
 *  sandbox wasmtime argv builder is used.
 */
export let exec_run_artifact = fn (wasm_path: string, source: string, caps: [string], user_args: [string], verbose: bool, sandbox: SandboxOpts) -> i64 require { Console, Proc } do
  let argv = build_wasmtime_run_argv_sandbox(wasm_path, caps, user_args, sb: sandbox)
  if verbose then
    Console.eprintln(val: "[nexus] exec wasmtime " ++ str.join(xs: argv, sep: " "))
  end
  match Proc.exec(cmd: "wasmtime", args: argv) do | ExecResult(exit_code, stdout, stderr) ->
    if exit_code == (0 - 1) then
      Console.eprintln(val: "nexus run: subprocess unavailable (WASI preview1 has no exec).")
      Console.eprintln(val: "  Run via the polyglot launcher (`./nexus run " ++ source ++ "`) — it")
      Console.eprintln(val: "  drives wasmtime from the host shell.")
      return 1
    end
    // Stream the child's stdio so `nexus run` is transparent. `eprint` /
    // `print` (without -ln) preserve any trailing newline emitted by the
    // program so output is byte-identical to a direct wasmtime invocation.
    if str.length(s: stdout) > 0 then Console.print(val: stdout) end
    if str.length(s: stderr) > 0 then Console.eprint(val: stderr) end
    return exit_code
  end
end

export let print_build_result_text = fn (output_name: string, caps: [string], explain: ExplainCaps, output_is_polyglot: bool) -> unit require { Console } do
  Console.eprintln(val: "Built " ++ output_name)
  match explain do
    | ExplainNone -> return ()
    | ExplainYes ->
      if !list.is_empty(xs: caps) then
        Console.eprintln(val: "Capabilities: " ++ str.join(xs: caps, sep: ", "))
      end
    | ExplainWasmtime ->
      if !list.is_empty(xs: caps) then
        Console.eprintln(val: "Capabilities: " ++ str.join(xs: caps, sep: ", "))
      end
      // Polyglot launchers are run via `chmod +x && ./<launcher>`; the
      // wasmtime command is embedded inside the launcher itself, so the
      // user-facing run hint switches to the chmod form.
      if output_is_polyglot then
        Console.eprintln(val: "Run: chmod +x " ++ output_name ++ " && ./" ++ output_name)
      else
        Console.eprintln(val: "Run: " ++ build_run_cmd(output_name, caps))
      end
  end
end

export let print_build_result_json = fn (output_name: string, caps: [string], explain: ExplainCaps, output_is_polyglot: bool) -> unit require { Console } do
  match explain do
    | ExplainNone ->
      Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\"}")
    | ExplainYes ->
      let caps_quoted = quote_strings(xs: caps)
      Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\",\"capabilities\":[" ++ str.join(xs: caps_quoted, sep: ",") ++ "]}")
    | ExplainWasmtime ->
      let caps_quoted = quote_strings(xs: caps)
      if output_is_polyglot then
        let cmd = "chmod +x " ++ output_name ++ " && ./" ++ output_name
        Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\",\"capabilities\":[" ++ str.join(xs: caps_quoted, sep: ",") ++ "],\"polyglot\":{\"command\":\"" ++ cmd ++ "\"}}")
      else
        let all_flags = list.concat(xs: wasmtime_feature_flags(), ys: collect_all_wasmtime_flags(caps))
        let flags_quoted = quote_strings(xs: all_flags)
        let cmd = build_run_cmd(output_name, caps)
        Console.eprintln(val: "{\"file\":\"" ++ output_name ++ "\",\"capabilities\":[" ++ str.join(xs: caps_quoted, sep: ",") ++ "],\"wasmtime\":{\"command\":\"" ++ cmd ++ "\",\"flags\":[" ++ str.join(xs: flags_quoted, sep: ",") ++ "]}}")
      end
  end
end

// Intentional narrow row for the option-parsing cluster below
// (parse_explain_caps_or_fail / parse_format_or_fail /
//  read_explain_caps_opt / read_format_opt): these are pure
// value-conversion helpers; the only fault is an unrecognized
// string value supplied by the user. InvalidUsage propagates to
// parse_global_args → main.nx exit code 2.
let parse_explain_caps_or_fail = fn (val: string) -> ExplainCaps throws { InvalidUsage } do
  if let Some(val: e) = parse_explain_caps_value(s: val) then return e end
  throw InvalidUsage(detail: "invalid --explain-capabilities value: " ++ val)
end

let parse_format_or_fail = fn (val: string, flag_name: string) -> ExplainFormat throws { InvalidUsage } do
  if let Some(val: f) = parse_explain_format_value(s: val) then return f end
  throw InvalidUsage(detail: "invalid " ++ flag_name ++ " value: " ++ val ++ " (expected text|json)")
end

export let read_explain_caps_opt = fn (result: ParseResult) -> ExplainCaps throws { InvalidUsage } do
  match get_opt(result, name: "explain-capabilities") do
    | None -> return ExplainYes
    | Some(val: v) -> return parse_explain_caps_or_fail(val: v)
  end
end

export let read_format_opt = fn (result: ParseResult, name: string, flag_name: string) -> ExplainFormat throws { InvalidUsage } do
  match get_opt(result, name) do
    | None -> return FormatText
    | Some(val: v) -> return parse_format_or_fail(val: v, flag_name)
  end
end
