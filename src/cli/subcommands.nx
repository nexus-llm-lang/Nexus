/**
 * cli/subcommands: Back-compat CLI subcommand strip helpers.
 *
 * Thin wrappers over argparse's `detect_subcommand` primitive so tests
 * and callers that relied on the old strip_* / Parsed* shapes continue
 * to work without changes.
 */

import { SubcommandHit, detect_subcommand } from "std:argparse"
import * as list from "std:list"

export type ParsedTypecheckSubcommand = ParsedTypecheckSubcommand(
  remaining: [ string ],
  typecheck_only: bool
)

export let strip_typecheck_subcommand = fn (xs: [ string ]) -> ParsedTypecheckSubcommand do
  match detect_subcommand(args: xs, kw: "typecheck") do | SubcommandHit(present, remaining) ->
    return ParsedTypecheckSubcommand(remaining, typecheck_only: present)
  end
end

export type ParsedRunSubcommand = ParsedRunSubcommand(
  remaining: [ string ],
  run_mode: bool,
  run_args: [ string ]
)

let split_run_args = fn (xs: [ string ], prefix: [ string ]) -> ParsedRunSubcommand do
  match xs do
    | [] -> return ParsedRunSubcommand(
      remaining: list.reverse(xs: prefix),
      run_mode: true,
      run_args: []
    )
    | v :: rest ->
      if v == "--" then
        return ParsedRunSubcommand(
          remaining: list.reverse(xs: prefix),
          run_mode: true,
          run_args: rest
        )
      end
      return split_run_args(xs: rest, prefix: v :: prefix)
  end
end

export let strip_run_subcommand = fn (xs: [ string ]) -> ParsedRunSubcommand do
  match detect_subcommand(args: xs, kw: "run") do | SubcommandHit(present, remaining) ->
    if !present then return ParsedRunSubcommand(remaining, run_mode: false, run_args: []) end
    match remaining do
      | [] -> return ParsedRunSubcommand(remaining: [], run_mode: true, run_args: [])
      | prog :: post ->
        let ParsedRunSubcommand(
          remaining: pre,
          run_mode: _,
          run_args
        ) = split_run_args(xs: post, prefix: [])
        return ParsedRunSubcommand(remaining: prog :: pre, run_mode: true, run_args)
    end
  end
end
