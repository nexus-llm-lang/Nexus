/**
 * cli/help: Help-printing helpers and backtrace-elision utility.
 *
 * Provides print_subcommand_help, try_dispatch_help, print_usage, and
 * compute_elision_pct, extracted from driver.nx (nexus-95iz.30).
 */

import { Console }, * as stdio from "std:stdio"
import { render_subcommand_help, render_subcommand_overview } from "std:argparse"
import { subcommand_specs, lookup_subcommand_spec, global_help_flag_specs } from "src/cli/specs.nx"
import { Option, Some, None } from "std:option"

// Backtrace-elision percentage (issue nexus-kyf8)
export let compute_elision_pct = fn (skip: i64, total: i64) -> i64 do
  if total == 0 then return 0 end
  return (skip * 100) / total
end

export let print_subcommand_help = fn (sub_name: string) -> bool require { Console } do
  match lookup_subcommand_spec(specs: subcommand_specs(), name: sub_name) do
    | None -> return false
    | Some(val: s) ->
      Console.eprintln(val: render_subcommand_help(prog: "nexus", spec: s))
      return true
  end
end

export let print_usage = fn () -> unit require { Console } do
  Console.println(val: render_subcommand_overview(
    summary: "Usage: nexus <subcommand> [options] <args>",
    subs: subcommand_specs(),
    globals: global_help_flag_specs()
  ))
end

export let try_dispatch_help = fn (args: [string]) -> bool require { Console } do
  match args do
    | _ :: a :: b :: _ ->
      if a == "help" then
        if print_subcommand_help(sub_name: b) then return true end
        print_usage()
        return true
      end
      if b == "--help" || b == "-h" then
        if print_subcommand_help(sub_name: a) then return true end
        print_usage()
        return true
      end
      return false
    | _ -> return false
  end
end
