// `nexus ast <file>`. Pre-typecheck, pre-HIR dump: lex +
// parse only, then format the spanned AST. The JSON envelope mirrors the V1
// `{kind, ...}` family shipped by ir_dump so agent consumers can use one
// generic node walker.
export let run_ast_dump_subcommand = fn (
  args: [ string ],
  format: ExplainFormat,
  verbose: bool
) -> i64 require { Clock, Console, Fs } do
  let _ = verbose
  try
    match args do
      | [] -> throw InvalidUsage(detail: "usage: nexus ast <input.nx> [--format=text|json]")
      | input_path :: _ ->
        let src = Fs.read_to_string(path: input_path)
        let tokens = lexer.tokenize(src)
        let ParseDiagnostics(
          prog: prog,
          diags: parse_diags
        ) = parser.parse_collect(tokens, file: input_path)
        print_parse_diags(diags: parse_diags, format)
        let n_parse_diags = list.length(xs: parse_diags)
        if n_parse_diags > 0 then
          match format do
            | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
            | FormatText -> ()
          end
          throw ParseErrorsCollected(count: n_parse_diags)
        end
        let out = match format do
          | FormatText -> ast_to_text(prog)
          | FormatJson -> ast_to_json(prog)
        end
        Console.println(val: out)
        return 0
    end
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

export let run_hir_dump_subcommand = fn (
  args: [ string ],
  format: ExplainFormat,
  verbose: bool
) -> i64 require { Clock, Console, Fs } do
  try
    match args do
      | [] -> throw InvalidUsage(detail: "usage: nexus hir <input.nx> [--format=text|json]")
      | input_path :: _ ->
        let src = Fs.read_to_string(path: input_path)
        let tokens = lexer.tokenize(src)
        let ParseDiagnostics(
          prog: prog,
          diags: parse_diags
        ) = parser.parse_collect(tokens, file: input_path)
        print_parse_diags(diags: parse_diags, format)
        let n_parse_diags = list.length(xs: parse_diags)
        if n_parse_diags > 0 then
          match format do
            | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
            | FormatText -> ()
          end
          throw ParseErrorsCollected(count: n_parse_diags)
        end
        let HirBuildResult(
          program: hir_raw,
          import_cache: _
        ) = build_hir(prog, source_file: input_path, verbose)
        // Run the same resolve+DCE loop as build so the dump reflects the
        // post-link HIR rather than raw lazy bodies. Mirrors the inline
        // `match hir_raw` block in `main`.
        let hir_resolved = match hir_raw do
          | HirProgram(
            caps: hp,
            functions: hf,
            externals: he,
            handler_bindings: hb,
            enum_defs: hed,
            exception_groups: heg,
            value_binding_names: hvbns,
            type_defs: htds,
            visible_enum_names: hven,
            ext_wasm_deps: hewds
          ) ->
            let resolved = iterative_resolve(funcs: hf, hb, max_rounds: 100)
            let expanded_fs = expand_groups_in_functions(funcs: resolved, groups: heg)
            let expanded_hb = expand_groups_in_handler_bindings(bindings: hb, groups: heg)
            let trimmed_reach = reach.collect_reachable_no_thread_start(
              functions: expanded_fs,
              handler_bindings: expanded_hb
            )
            let final_fs = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then expanded_fs
              else reach.filter_reachable_functions(
                functions: expanded_fs,
                reachable: trimmed_reach
              )
            end
            let final_reach = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then
                reach.collect_reachable(functions: final_fs, handler_bindings: expanded_hb)
              else trimmed_reach
            end
            let filtered_exts = reach.filter_reachable_externals(
              externals: he,
              reachable: final_reach
            )
            HirProgram(
              caps: hp,
              functions: final_fs,
              externals: filtered_exts,
              handler_bindings: expanded_hb,
              enum_defs: hed,
              exception_groups: heg,
              value_binding_names: hvbns,
              type_defs: htds,
              visible_enum_names: hven,
              ext_wasm_deps: hewds
            )
        end
        let out = match format do
          | FormatText -> hir_to_text(prog: hir_resolved)
          | FormatJson -> hir_to_json(prog: hir_resolved)
        end
        Console.println(val: out)
        return 0
    end
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

let lir_program_functions = fn (p: LirProgram) -> [ LirFunction ] do
  match p do | LirProgram(functions, externals: _) -> return functions end
end

export let run_lir_dump_subcommand = fn (
  args: [ string ],
  format: ExplainFormat,
  verbose: bool
) -> i64 require { Clock, Console, Fs } do
  try
    match args do
      | [] -> throw InvalidUsage(detail: "usage: nexus lir <input.nx> [--format=text|json]")
      | input_path :: _ ->
        let src = Fs.read_to_string(path: input_path)
        let tokens = lexer.tokenize(src)
        let ParseDiagnostics(
          prog: prog,
          diags: parse_diags
        ) = parser.parse_collect(tokens, file: input_path)
        print_parse_diags(diags: parse_diags, format)
        let n_parse_diags = list.length(xs: parse_diags)
        if n_parse_diags > 0 then
          match format do
            | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
            | FormatText -> ()
          end
          throw ParseErrorsCollected(count: n_parse_diags)
        end
        let HirBuildResult(
          program: hir_raw,
          import_cache: _
        ) = build_hir(prog, source_file: input_path, verbose)
        let hir_resolved = match hir_raw do
          | HirProgram(
            caps: hp,
            functions: hf,
            externals: he,
            handler_bindings: hb,
            enum_defs: hed,
            exception_groups: heg,
            value_binding_names: hvbns,
            type_defs: htds,
            visible_enum_names: hven,
            ext_wasm_deps: hewds
          ) ->
            let resolved = iterative_resolve(funcs: hf, hb, max_rounds: 100)
            let expanded_fs = expand_groups_in_functions(funcs: resolved, groups: heg)
            let expanded_hb = expand_groups_in_handler_bindings(bindings: hb, groups: heg)
            let trimmed_reach = reach.collect_reachable_no_thread_start(
              functions: expanded_fs,
              handler_bindings: expanded_hb
            )
            let final_fs = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then expanded_fs
              else reach.filter_reachable_functions(
                functions: expanded_fs,
                reachable: trimmed_reach
              )
            end
            let final_reach = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then
                reach.collect_reachable(functions: final_fs, handler_bindings: expanded_hb)
              else trimmed_reach
            end
            let filtered_exts = reach.filter_reachable_externals(
              externals: he,
              reachable: final_reach
            )
            HirProgram(
              caps: hp,
              functions: final_fs,
              externals: filtered_exts,
              handler_bindings: expanded_hb,
              enum_defs: hed,
              exception_groups: heg,
              value_binding_names: hvbns,
              type_defs: htds,
              visible_enum_names: hven,
              ext_wasm_deps: hewds
            )
        end
        let enum_defs = get_enum_defs(hir: hir_resolved)
        let type_defs = get_type_defs(hir: hir_resolved)
        let mir_prog = mir.lower_hir_to_mir(hir: hir_resolved)
        let lir_prog = func_lower.lower_mir_to_lir(mir: mir_prog, enum_defs, type_defs)
        let funcs = lir_program_functions(p: lir_prog)
        let out = match format do
          | FormatText -> lir_to_text(funcs)
          | FormatJson -> lir_to_json(funcs)
        end
        Console.println(val: out)
        return 0
    end
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

/** Scan `xs` for the `--transitive` flag. */
let has_transitive_flag = fn (xs: [ string ]) -> bool do
  match xs do
    | [] -> return false
    | h :: rest ->
      if h == "--transitive" then return true end
      return has_transitive_flag(xs: rest)
  end
end

export let run_types_dump_subcommand = fn (
  args: [ string ],
  format: ExplainFormat,
  verbose: bool
) -> i64 require { Clock, Console, Fs } do
  try
    match args do
      | [] -> throw InvalidUsage(detail: "usage: nexus types <input.nx> [--transitive] [--format=text|json]")
      | input_path :: rest_args ->
        let scope = if has_transitive_flag(xs: rest_args) then ScopeAll else ScopeOwn(file: input_path) end
        let src = Fs.read_to_string(path: input_path)
        let tokens = lexer.tokenize(src)
        let ParseDiagnostics(
          prog: prog,
          diags: parse_diags
        ) = parser.parse_collect(tokens, file: input_path)
        print_parse_diags(diags: parse_diags, format)
        let n_parse_diags = list.length(xs: parse_diags)
        if n_parse_diags > 0 then
          match format do
            | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
            | FormatText -> ()
          end
          throw ParseErrorsCollected(count: n_parse_diags)
        end
        let HirBuildResult(
          program: hir_raw,
          import_cache: _
        ) = build_hir(prog, source_file: input_path, verbose)
        // Skip the build-pipeline's reachability DCE pass: dumping types for a
        // library file (no `main`) would otherwise collapse to "0 bindings"
        // because `iterative_resolve` filters by reachability from `main`.
        let hir_resolved = match hir_raw do
          | HirProgram(
            caps: hp,
            functions: hf,
            externals: he,
            handler_bindings: hb,
            enum_defs: hed,
            exception_groups: heg,
            value_binding_names: hvbns,
            type_defs: htds,
            visible_enum_names: hven,
            ext_wasm_deps: hewds
          ) ->
            let resolved = resolve_all_lazy_no_filter(funcs: hf)
            let expanded_fs = expand_groups_in_functions(funcs: resolved, groups: heg)
            let expanded_hb = expand_groups_in_handler_bindings(bindings: hb, groups: heg)
            HirProgram(
              caps: hp,
              functions: expanded_fs,
              externals: he,
              handler_bindings: expanded_hb,
              enum_defs: hed,
              exception_groups: heg,
              value_binding_names: hvbns,
              type_defs: htds,
              visible_enum_names: hven,
              ext_wasm_deps: hewds
            )
        end
        let hir_wrapped = main_wrap.wrap_main_if_needed(prog: hir_resolved)
        linearity.check_program(prog: hir_wrapped)
        // Body-check only the entry-file functions.
        let local_names = main_wrap.user_main_name() :: extract_function_names(
          defs: get_defs(prog),
          source: input_path
        )
        let hir_checked = tc.check_program(hir: hir_wrapped, local_names, require_main: false)
        let out = match format do
          | FormatText -> types_to_text(prog, hir: hir_checked, scope)
          | FormatJson -> types_to_json(prog, hir: hir_checked, scope)
        end
        Console.println(val: out)
        return 0
    end
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end

// Shared HIR build helper for `nexus caps`.
let build_hir_for_caps = fn (
  src: string,
  label_path: string,
  verbose: bool,
  format: ExplainFormat
) -> HirProgram require { Console, Fs } throws { ParseError, HirError } do
  let tokens = lexer.tokenize(src)
  let ParseDiagnostics(prog, diags: parse_diags) = parser.parse_collect(tokens, file: label_path)
  print_parse_diags(diags: parse_diags, format)
  let n_parse_diags = list.length(xs: parse_diags)
  if n_parse_diags > 0 then
    match format do
      | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
      | FormatText -> ()
    end
    throw ParseErrorsCollected(count: n_parse_diags)
  end
  let HirBuildResult(
    program: hir_raw,
    import_cache: _
  ) = build_hir(prog, source_file: label_path, verbose)
  match hir_raw do
    | HirProgram(
      caps: hp,
      functions: hf,
      externals: he,
      handler_bindings: hb,
      enum_defs: hed,
      exception_groups: heg,
      value_binding_names: hvbns,
      type_defs: htds,
      visible_enum_names: hven,
      ext_wasm_deps: hewds
    ) ->
      let resolved = resolve_all_lazy_no_filter(funcs: hf)
      let expanded_fs = expand_groups_in_functions(funcs: resolved, groups: heg)
      let expanded_hb = expand_groups_in_handler_bindings(bindings: hb, groups: heg)
      return HirProgram(
        caps: hp,
        functions: expanded_fs,
        externals: he,
        handler_bindings: expanded_hb,
        enum_defs: hed,
        exception_groups: heg,
        value_binding_names: hvbns,
        type_defs: htds,
        visible_enum_names: hven,
        ext_wasm_deps: hewds
      )
  end
end

type CapsDiffFlag = CapsDiffFlag(rev: Option<string>, base_path: Option<string>, rest: [ string ])

let extract_diff_flag_go = fn (
  args: [ string ],
  acc_rev: Option<string>,
  acc_base: Option<string>,
  acc_rest: [ string ]
) -> CapsDiffFlag throws { InvalidUsage } do
  match args do
    | [] -> return CapsDiffFlag(rev: acc_rev, base_path: acc_base, rest: list.reverse(xs: acc_rest))
    | a :: rest ->
      if a == "--diff" then
        match rest do
          | [] -> throw InvalidUsage(detail: "--diff requires a git revision (e.g., --diff HEAD~1)")
          | rev :: tail -> return extract_diff_flag_go(
            args: tail,
            acc_rev: Some(val: rev),
            acc_base,
            acc_rest
          )
        end
      end
      if a == "--diff-base" then
        match rest do
          | [] -> throw InvalidUsage(detail: "--diff-base requires a path to the base source")
          | bp :: tail -> return extract_diff_flag_go(
            args: tail,
            acc_rev,
            acc_base: Some(val: bp),
            acc_rest
          )
        end
      end
      return extract_diff_flag_go(args: rest, acc_rev, acc_base, acc_rest: a :: acc_rest)
  end
end

let extract_diff_flag = fn (args: [ string ]) -> CapsDiffFlag throws { InvalidUsage } do
  return extract_diff_flag_go(args, acc_rev: None, acc_base: None, acc_rest: [])
end

export let run_caps_dump_subcommand = fn (
  args: [ string ],
  format: ExplainFormat,
  verbose: bool
) -> i64 require { Clock, Console, Fs } do
  try
    let CapsDiffFlag(rev: rev_opt, base_path: base_opt, rest: pos_args) = extract_diff_flag(args)
    if let Some(val: rev_str) = rev_opt then
      if let None = base_opt then
        throw InvalidUsage(detail: "--diff " ++ rev_str ++ ": in-wasm `nexus caps` cannot run `git show` under preview1. Invoke via the polyglot launcher (./nexus), which intercepts --diff and prefetches the base revision.")
      end
    end
    match pos_args do
      | [] -> throw InvalidUsage(detail: "usage: nexus caps <symbol> <input.nx> [--format=text|json] [--diff <rev>]")
      | _ :: [] -> throw InvalidUsage(detail: "usage: nexus caps <symbol> <input.nx> [--format=text|json] [--diff <rev>]")
      | symbol :: input_path :: _ ->
        let src = Fs.read_to_string(path: input_path)
        let hir_resolved = build_hir_for_caps(src, label_path: input_path, verbose, format)
        let found = caps_symbol_exists_impl(prog: hir_resolved, symbol)
        match base_opt do
          | None ->
            let out = match format do
              | FormatText -> caps_to_text(prog: hir_resolved, symbol)
              | FormatJson -> caps_to_json(prog: hir_resolved, symbol)
            end
            Console.println(val: out)
            if found then return 0 else return 1 end
          | Some(val: base_path) ->
            let base_src = Fs.read_to_string(path: base_path)
            let hir_base = build_hir_for_caps(src: base_src, label_path: base_path, verbose, format)
            let found_base = caps_symbol_exists_impl(prog: hir_base, symbol)
            let base_caps = if found_base then caps_closure_capabilities(cl: caps_compute_closure(prog: hir_base, symbol)) else [] end
            let current_caps = if found then caps_closure_capabilities(cl: caps_compute_closure(prog: hir_resolved, symbol)) else [] end
            let d = compute_caps_diff(symbol, base: base_caps, current: current_caps)
            let out = match format do
              | FormatText -> caps_diff_to_text(d)
              | FormatJson -> caps_diff_to_json(d)
            end
            Console.println(val: out)
            if diff_is_widening(d) then return 1 else return 0 end
        end
    end
  catch e ->
    Console.eprintln(val: err.format_error(err: e))
    return 1
  end
end
