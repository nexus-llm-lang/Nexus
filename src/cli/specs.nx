/**
 * cli/specs: Per-subcommand SubcommandSpec table.
 *
 * One SubcommandSpec per top-level routing arm. Drives both
 * `nexus <sub> --help` (via render_subcommand_help) and the grouped
 * top-level overview in `nexus help` (via render_subcommand_overview).
 */

import {
  ArgSpec, SubcommandSpec, ExitCode, SubcommandCategory,
  CategoryBuild, CategoryContext, CategorySafety, CategoryTooling,
  spec_flag, spec_opt, spec_subcommand,
  subspec, example, exit_code
} from "std:argparse"
import * as list from "std:list"
import { Option, Some, None } from "std:option"

export let std_exit_codes = fn () -> [ ExitCode ] do
  return [
    exit_code(code: 0, meaning: "success"),
    exit_code(code: 1, meaning: "compilation or runtime failure (diagnostic on stderr)"),
    exit_code(code: 2, meaning: "invalid CLI usage (E4002 / E4004)")
  ]
end

// Global flags relevant to every build-pipeline subcommand
export let pipeline_flags = fn () -> [ ArgSpec ] do
  return [
    spec_flag(name: "verbose", short: "", long: "--verbose", help: "enable per-pass timing output"),
    spec_opt(
      name: "format",
      short: "",
      long: "--format",
      required: false,
      help: "diagnostic format (text|json)"
    ),
    spec_opt(
      name: "explain-capabilities",
      short: "",
      long: "--explain-capabilities",
      required: false,
      help: "capability reporting (yes|none|wasmtime)"
    ),
    spec_opt(
      name: "explain-capabilities-format",
      short: "",
      long: "--explain-capabilities-format",
      required: false,
      help: "capability report format (text|json)"
    ),
    spec_flag(
      name: "no-lint",
      short: "",
      long: "--no-lint",
      help: "skip the lint pass after typecheck"
    ),
    spec_opt(
      name: "lint-level",
      short: "",
      long: "--lint-level",
      required: false,
      help: "lint finding severity on build (warn|error); default error gates the build, warn opts out"
    ),
    spec_opt(
      name: "deny",
      short: "",
      long: "--deny",
      required: false,
      help: "promote named lint rule codes to build-gating errors (comma-separated, e.g. L0002)"
    )
  ]
end

export let build_subspec = fn () -> SubcommandSpec do
  let flags = list.concat(
    xs: [
      spec_opt(
        name: "output",
        short: "-o",
        long: "--output",
        required: false,
        help: "output wasm path (default: out.wasm)"
      ),
      spec_flag(
        name: "coverage",
        short: "",
        long: "--coverage",
        help: "emit coverage counters and custom section"
      ),
      spec_opt(
        name: "profile-out",
        short: "",
        long: "--profile-out",
        required: false,
        help: "write per-call-site profile JSONL to FILE (static const-arg analysis)"
      ),
      spec_flag(
        name: "dump-imports",
        short: "",
        long: "--dump-imports",
        help: "print the import graph and exit"
      ),
      spec_flag(
        name: "p3",
        short: "",
        long: "--p3",
        help: "emit WASI preview3 compatible wasm (non-shared memory, sequential lazy)"
      ),
      spec_flag(
        name: "p3-component",
        short: "",
        long: "--p3-component",
        help: "wrap output in a component model binary with future<T> canon ABI (implies --p3)"
      ),
      spec_flag(
        name: "p2-component",
        short: "",
        long: "--p2-component",
        help: "wrap output in a WASI preview2 component binary (wasi:cli/run@0.2.0)"
      )
    ],
    ys: pipeline_flags()
  )
  return subspec(
    name: "build",
    synopsis: "<input.nx> [-o <output.wasm>] [--coverage] [--profile-out FILE] [--p3] [--p3-component] [--p2-component]",
    description: "Compile a Nexus source file to a self-contained WebAssembly module.\nThe full pipeline runs (parse, resolve, HIR/MIR/LIR, codegen, link, merge) and\nthe resulting wasm is written to the path given by -o (default: out.wasm).\n\nRun the resulting module directly with wasmtime, e.g.\n  wasmtime run -S threads --dir=. out.wasm\nDeterminism hooks are read from the environment at runtime:\n  --env NEXUS_SEED=N            fixed RNG seed\n  --env NEXUS_FROZEN_CLOCK=EPOCH_MS  pinned wall/mono clock.",
    flags,
    examples: [
      example(
        command: "nexus build examples/hello.nx -o hello.wasm",
        comment: "compile a single source file to a wasm module"
      ),
      example(
        command: "nexus build src/main.nx -o nexus.wasm",
        comment: "compile the compiler to a core wasm module"
      ),
      example(
        command: "nexus build foo.nx --coverage -o foo.cov.wasm",
        comment: "instrument with coverage counters"
      ),
      example(
        command: "nexus build src/main.nx --profile-out profile.jsonl",
        comment: "emit per-call-site const-arg profile"
      )
    ],
    see_also: [ "typecheck", "test" ],
    exit_codes: std_exit_codes(),
    category: CategoryBuild
  )
end


export let typecheck_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "typecheck",
    synopsis: "<input.nx>",
    description: "Run only the front-end: parse, resolve, HIR construction, and full\ntypechecking (including effect rows + linearity). No MIR/LIR/codegen.\n\nUseful as a fast feedback loop and as the pre-commit hook target.",
    flags: pipeline_flags(),
    examples: [
      example(
        command: "nexus typecheck src/main.nx",
        comment: "fast typecheck of the self-hosting driver"
      ),
      example(
        command: "nexus typecheck foo.nx --format json",
        comment: "emit JSON diagnostics for editor integration"
      )
    ],
    see_also: [ "build", "types" ],
    exit_codes: std_exit_codes(),
    category: CategoryBuild
  )
end

export let ast_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "ast",
    synopsis: "<input.nx> [--format text|json]",
    description: "Pretty-print the parsed AST for the given source file. Useful when\ndebugging parser issues or building tooling on top of Nexus.\n\nThe JSON variant is stable enough to feed into external linters.",
    flags: list.concat(
      xs: [ spec_opt(name: "format", short: "", long: "--format", required: false, help: "output format (text|json)") ],
      ys: pipeline_flags()
    ),
    examples: [
      example(command: "nexus ast examples/hello.nx", comment: "pretty-print the AST as text"),
      example(
        command: "nexus ast examples/hello.nx --format json",
        comment: "machine-readable AST dump"
      )
    ],
    see_also: [ "hir", "lir", "types" ],
    exit_codes: std_exit_codes(),
    category: CategoryContext
  )
end

export let hir_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "hir",
    synopsis: "<input.nx> [--format text|json]",
    description: "Dump the High-level IR after name resolution and HIR construction.\nThis is the IR the typechecker consumes; reading it is the fastest way\nto debug `let`/`fn`/handler desugaring or effect-row inference.",
    flags: list.concat(
      xs: [ spec_opt(name: "format", short: "", long: "--format", required: false, help: "output format (text|json)") ],
      ys: pipeline_flags()
    ),
    examples: [
      example(command: "nexus hir foo.nx", comment: "text dump of the HIR"),
      example(command: "nexus hir foo.nx --format json", comment: "JSON HIR for tooling")
    ],
    see_also: [ "ast", "lir", "types" ],
    exit_codes: std_exit_codes(),
    category: CategoryContext
  )
end

export let lir_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "lir",
    synopsis: "<input.nx> [--format text|json]",
    description: "Dump the Low-level IR after MIR→LIR lowering and the post-codegen\noptimisation passes. Used when chasing codegen bugs or sizing a\nspecific function's wasm output.",
    flags: list.concat(
      xs: [ spec_opt(name: "format", short: "", long: "--format", required: false, help: "output format (text|json)") ],
      ys: pipeline_flags()
    ),
    examples: [
      example(command: "nexus lir foo.nx", comment: "text dump of the LIR"),
      example(command: "nexus lir foo.nx --format json", comment: "JSON LIR for diffing")
    ],
    see_also: [ "ast", "hir", "types" ],
    exit_codes: std_exit_codes(),
    category: CategoryContext
  )
end

export let types_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "types",
    synopsis: "<input.nx> [--transitive] [--format text|json]",
    description: "Dump <input.nx>'s own top-level bindings' inferred types after full\ntypechecking. By default the output is scoped to symbols defined in\n<input.nx> and identifiers appear as bare names. Pass --transitive\nto include imported symbols too; imported identifiers render in the\nmodule-path form used by import statements (e.g. `std:str.load_at`).\nWith --format json the output is keyed by symbol and includes effect\nrows, which is the canonical input to editor hover/`explain` flows.",
    flags: list.concat(
      xs: [
        spec_opt(
          name: "format",
          short: "",
          long: "--format",
          required: false,
          help: "output format (text|json)"
        ),
        spec_opt(
          name: "transitive",
          short: "",
          long: "--transitive",
          required: false,
          help: "include types for symbols imported from other files"
        )
      ],
      ys: pipeline_flags()
    ),
    examples: [
      example(
        command: "nexus types foo.nx",
        comment: "text dump of foo.nx's own bindings (bare names)"
      ),
      example(
        command: "nexus types foo.nx --transitive",
        comment: "include imported symbols (rendered as std:str.load_at etc.)"
      ),
      example(
        command: "nexus types src/main.nx --format json",
        comment: "JSON for editor integration"
      )
    ],
    see_also: [ "typecheck", "explain" ],
    exit_codes: std_exit_codes(),
    category: CategoryContext
  )
end

export let caps_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "caps",
    synopsis: "<symbol> <input.nx> [--format text|json]",
    description: "Dump the transitive capability closure of one named function: every\ncapability (Fs / Net / Console / Random / Clock / Proc / Env) reached\nby any function transitively called from <symbol>. Useful for agents\nor reviewers asking 'does this function touch the filesystem?' before\nan edit. Symbol resolution accepts either the canonical qualified form\n(`<sanitized_path>#<name>`) or the bare suffix.",
    flags: list.concat(
      xs: [ spec_opt(name: "format", short: "", long: "--format", required: false, help: "output format (text|json)") ],
      ys: pipeline_flags()
    ),
    examples: [
      example(command: "nexus caps main src/main.nx", comment: "caps reached from driver's main"),
      example(
        command: "nexus caps lint_file src/tools/lint.nx --format json",
        comment: "JSON dump of a library symbol"
      )
    ],
    see_also: [ "explain", "types" ],
    exit_codes: [
      exit_code(code: 0, meaning: "symbol resolved and closure printed"),
      exit_code(code: 1, meaning: "symbol not found in the named file"),
      exit_code(code: 2, meaning: "invalid CLI usage (E4002 / E4004)")
    ],
    category: CategoryContext
  )
end

export let repl_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "repl",
    synopsis: "",
    description: "Launch the interactive REPL. Each input line is parsed, typechecked,\nand evaluated against a persistent session; bindings established at one\nprompt are visible at the next. Press Ctrl-D to exit.",
    flags: [],
    examples: [ example(command: "nexus repl", comment: "start the REPL") ],
    see_also: [ "build"],
    exit_codes: std_exit_codes(),
    category: CategoryBuild
  )
end

export let mcp_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "mcp",
    synopsis: "",
    description: "Serve the Model Context Protocol over stdio. Exposes Nexus tooling\n(typecheck, explain, context, types) as JSON-RPC methods so an LLM\nclient can drive the compiler without spawning per-call subprocesses.",
    flags: [],
    examples: [ example(command: "nexus mcp", comment: "start the JSON-RPC server on stdio") ],
    see_also: [ "explain", "context" ],
    exit_codes: std_exit_codes(),
    category: CategoryTooling
  )
end

export let explain_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "explain",
    synopsis: "<symbol> [--file FILE] [--format text|json]",
    description: "Look up a symbol's signature, kind, defining file, and docstring.\nWith --file FILE the lookup is scoped to that source file; without it\nthe lookup spans the project (driven by `nexus context`).\n\nThe JSON output drives editor hover providers.",
    flags: [
      spec_opt(
        name: "file",
        short: "",
        long: "--file",
        required: false,
        help: "scope lookup to this source file"
      ),
      spec_opt(
        name: "format",
        short: "",
        long: "--format",
        required: false,
        help: "output format (text|json)"
      )
    ],
    examples: [
      example(
        command: "nexus explain Option --file nxlib/stdlib/option.nx",
        comment: "explain a type from a specific file"
      ),
      example(
        command: "nexus explain parse_global_args --format json",
        comment: "machine-readable explain for an editor"
      )
    ],
    see_also: [ "context", "types" ],
    exit_codes: std_exit_codes(),
    category: CategoryContext
  )
end

export let context_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "context",
    synopsis: "<file> [--format text|json]",
    description: "Emit the project's symbol context (top-level definitions, exports,\nand import edges) as a single document. Drives editor outline views\nand the MCP server's symbol catalogue.",
    flags: [
      spec_opt(
        name: "format",
        short: "",
        long: "--format",
        required: false,
        help: "output format (text|json)"
      )
    ],
    examples: [
      example(command: "nexus context src/main.nx", comment: "text-format project context"),
      example(
        command: "nexus context src/main.nx --format json",
        comment: "JSON context for tooling"
      )
    ],
    see_also: [ "explain", "mcp" ],
    exit_codes: std_exit_codes(),
    category: CategoryContext
  )
end

export let bench_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "bench",
    synopsis: "[--dir DIR] [--iters N] [--nexus-bin PATH] [--wasmtime-bin PATH] [--baseline PATH]",
    description: "Run every `bench_*.nx` under DIR (default `examples/feature/`). Each bench\nmust print a single integer (milliseconds) as its last stdout line. The\nrunner executes each bench N times (default 5), computes median and p95,\nand emits one NDJSON line per bench to stdout:\n  {\"name\":\"arith\",\"median_ms\":42,\"p95_ms\":45,\"iters\":5}\n\nWith --baseline PATH the runner reads the baseline JSON array and fails\n(exit 3) if any bench's median_ms drifts more than ±20% from its\ncorresponding baseline entry.\n\nWASI threads note: bench files in the suite use sequential code only.\nParallel-thunk benches are inherently noisy across hardware and should\nlive outside this discovery prefix.",
    flags: [
      spec_opt(
        name: "dir",
        short: "",
        long: "--dir",
        required: false,
        help: "bench discovery directory (default: examples/feature/)"
      ),
      spec_opt(
        name: "iters",
        short: "",
        long: "--iters",
        required: false,
        help: "iterations per bench (default: 5)"
      ),
      spec_opt(
        name: "nexus-bin",
        short: "",
        long: "--nexus-bin",
        required: false,
        help: "path to the nexus binary (default: ./nexus)"
      ),
      spec_opt(
        name: "wasmtime-bin",
        short: "",
        long: "--wasmtime-bin",
        required: false,
        help: "path to the wasmtime binary (default: wasmtime)"
      ),
      spec_opt(
        name: "baseline",
        short: "",
        long: "--baseline",
        required: false,
        help: "baseline JSON path; exit 3 if any bench drifts >±20%"
      )
    ],
    examples: [
      example(command: "nexus bench", comment: "run all bench_*.nx under examples/feature/"),
      example(command: "nexus bench --iters 10", comment: "10 iterations per bench"),
      example(
        command: "nexus bench --baseline bench-baseline.json",
        comment: "gate on ±20% drift from baseline"
      )
    ],
    see_also: [ "test", "build" ],
    exit_codes: [
      exit_code(code: 0, meaning: "all benches ran (and baseline check passed)"),
      exit_code(code: 1, meaning: "at least one bench failed to compile or run"),
      exit_code(code: 2, meaning: "invalid CLI usage"),
      exit_code(code: 3, meaning: "baseline drift gate: at least one bench exceeded ±20%")
    ],
    category: CategoryTooling
  )
end

export let test_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "test",
    synopsis: "[path] [--junit FILE]",
    description: "Run every `*_test.nx` under `path` (defaults to `tests/`). Each test\nis compiled and executed in a fresh wasmtime invocation; results are\nreported as one PASS/FAIL line per test plus a totals summary.\n\n--junit emits a JUnit XML report.",
    flags: [
      spec_opt(
        name: "junit",
        short: "",
        long: "--junit",
        required: false,
        help: "write a JUnit XML report to this path"
      )
    ],
    examples: [
      example(command: "nexus test", comment: "run every test under tests/"),
      example(command: "nexus test tests/typecheck", comment: "run a subset by directory"),
      example(
        command: "nexus test --junit out.xml",
        comment: "emit a JUnit XML report alongside the run"
      )
    ],
    see_also: [ "build", "fmt" ],
    exit_codes: [
      exit_code(code: 0, meaning: "all tests passed"),
      exit_code(code: 1, meaning: "at least one test failed (see PASS/FAIL summary)"),
      exit_code(code: 2, meaning: "invalid CLI usage")
    ],
    category: CategoryBuild
  )
end

export let fmt_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "fmt",
    synopsis: "[--check] <file>|- [<file>...]",
    description: "Format Nexus source files in place. Pass `-` to read from stdin and\nwrite to stdout. With --check the formatter only verifies the input is\nalready well-formed, leaving files untouched and exiting non-zero on\ndiscrepancy (useful as a CI / pre-commit gate).",
    flags: [
      spec_flag(
        name: "check",
        short: "",
        long: "--check",
        help: "check-only mode; do not modify files"
      )
    ],
    examples: [
      example(command: "nexus fmt src/main.nx", comment: "format a single file in place"),
      example(command: "cat foo.nx | nexus fmt -", comment: "format stdin → stdout"),
      example(
        command: "nexus fmt --check src/",
        comment: "verify all files under src/ are well-formed"
      )
    ],
    see_also: [ "test"],
    exit_codes: [
      exit_code(code: 0, meaning: "files were already (or are now) well-formatted"),
      exit_code(code: 1, meaning: "--check mismatch or unparseable input"),
      exit_code(code: 2, meaning: "invalid CLI usage")
    ],
    category: CategoryBuild
  )
end

export let grep_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "grep",
    synopsis: "<pattern> [<path>...]",
    description: "Search `.nx` source files for AST nodes matching a pattern.\nPattern syntax: `[<kind>] <name>` where kind is one of `let`, `fn`,\n`call`, or `var` (default: `call`), and name is a literal identifier\nor a `$`-prefixed wildcard (e.g. `$_` matches any name).\nPaths default to the current directory; directories are searched\nrecursively for `.nx` files.",
    flags: [],
    examples: [
      example(
        command: "nexus grep 'let helper' src/",
        comment: "find the let-binding named 'helper' under src/"
      ),
      example(command: "nexus grep 'fn $_' src/", comment: "find every fn binding in src/"),
      example(
        command: "nexus grep 'call Fs.open_read' src/",
        comment: "find every call to Fs.open_read"
      ),
      example(
        command: "nexus grep 'var $_' src/main.nx",
        comment: "find every variable reference in one file"
      )
    ],
    see_also: [ "ast"],
    exit_codes: [
      exit_code(code: 0, meaning: "at least one match was found"),
      exit_code(code: 1, meaning: "no matches"),
      exit_code(code: 2, meaning: "invalid pattern or CLI usage")
    ],
    category: CategoryContext
  )
end

export let skill_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "skill",
    category: CategoryTooling,
    synopsis: "--emit [--out PATH] | --check [--out PATH]",
    description: "Auto-regenerate the CLI-reference markdown from the compiler's\nauthoritative spec tables (`subcommand_specs()` / `global_help_specs()`\nin src/main.nx). The intent is to keep the LLM context harness\n(skills/nexus-lang, AGENTS.md) in lockstep with the actual subcommand\nand flag inventory — handy when adding or renaming a subcommand.\n\nDefault output path: docs/cli-reference.md. With --check the on-disk\nfile is read and compared against the freshly-rendered output; mismatch\nexits 1 (suitable as a CI gate).",
    flags: [
      spec_flag(
        name: "emit",
        short: "",
        long: "--emit",
        help: "regenerate the CLI-reference document (default action)"
      ),
      spec_flag(
        name: "check",
        short: "",
        long: "--check",
        help: "verify the on-disk file matches; exit 1 on drift"
      ),
      spec_opt(
        name: "out",
        short: "",
        long: "--out",
        required: false,
        help: "output path (default: docs/cli-reference.md)"
      )
    ],
    examples: [
      example(
        command: "nexus skill --emit",
        comment: "regenerate docs/cli-reference.md from compiler state"
      ),
      example(
        command: "nexus skill --emit --out skills/nexus-lang/references/cli.md",
        comment: "redirect to a different path (e.g. inside the skill bundle)"
      ),
      example(
        command: "nexus skill --check",
        comment: "CI gate — exits 1 if docs/cli-reference.md is stale"
      )
    ],
    see_also: [ "help", "explain" ],
    exit_codes: [
      exit_code(code: 0, meaning: "emitted successfully or --check matched"),
      exit_code(code: 1, meaning: "--check detected drift, or write/read failed"),
      exit_code(code: 2, meaning: "invalid CLI usage")
    ]
  )
end

export let help_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "help",
    synopsis: "[<subcommand>]",
    description: "With no argument, print the top-level usage overview (the same output\nas `nexus --help`). With a subcommand name, print that subcommand's\nstructured help (the same output as `nexus <sub> --help`).",
    flags: [],
    examples: [
      example(command: "nexus help", comment: "top-level overview"),
      example(command: "nexus help build", comment: "structured help for `nexus build`")
    ],
    see_also: [ "build", "test" ],
    exit_codes: [ exit_code(code: 0, meaning: "help printed") ],
    category: CategoryTooling
  )
end

export let lint_subspec = fn () -> SubcommandSpec do
  return subspec(
    name: "lint",
    synopsis: "[--check|--fix|--fix-diff] FILE [FILE...]",
    description: "Run the Nexus linter over the given source files. Reports style and\ncorrectness issues (L0001 empty-inject, L0002 unused-require-cap,\nL0100 cognitive-complexity). With --check the exit code is non-zero on\nany finding.\n\nAuto-fix modes (the heavier front-end is only engaged in these modes;\nplain lint and --check remain AST-only and fast):\n  --fix       apply all fix-its in place, looping to a fixpoint. Covers\n              both lint rules (L-codes) and compiler diagnostics\n              (E2005 LazyBindingUnused, E2007 LinearUnused).\n  --fix-diff  show a before/after diff for every fix-it without writing.\n\nSee also: `nexus fmt` for whitespace normalisation (separate concern).",
    flags: [
      spec_flag(
        name: "check",
        short: "",
        long: "--check",
        help: "exit non-zero on any finding (CI mode)"
      ),
      spec_flag(
        name: "fix",
        short: "",
        long: "--fix",
        help: "apply fix-its in place (lint rules + E2005/E2007; loops to fixpoint)"
      ),
      spec_flag(
        name: "fix-diff",
        short: "",
        long: "--fix-diff",
        help: "show before/after diff without writing"
      )
    ],
    examples: [
      example(command: "nexus lint src/main.nx", comment: "lint a single file"),
      example(command: "nexus lint --check src/", comment: "CI gate — fails on any finding"),
      example(
        command: "nexus lint --fix src/main.nx",
        comment: "apply all fix-its in main.nx in place"
      ),
      example(
        command: "nexus lint --fix-diff src/main.nx",
        comment: "preview fix-its without modifying files"
      )
    ],
    see_also: [ "fmt" ],
    exit_codes: [
      exit_code(code: 0, meaning: "no findings (or findings accepted / all fix-its applied)"),
      exit_code(code: 1, meaning: "--check: at least one finding; --fix: non-fixable error"),
      exit_code(code: 2, meaning: "invalid CLI usage")
    ],
    category: CategorySafety
  )
end

/** Per-subcommand spec table. Order is the canonical sort order used by
 *  the top-level overview. */
export let subcommand_specs = fn () -> [ SubcommandSpec ] do
  return [
    build_subspec(),
    typecheck_subspec(),
    ast_subspec(),
    hir_subspec(),
    lir_subspec(),
    types_subspec(),
    caps_subspec(),
    repl_subspec(),
    mcp_subspec(),
    explain_subspec(),
    context_subspec(),
    test_subspec(),
    bench_subspec(),
    fmt_subspec(),
    grep_subspec(),
    lint_subspec(),
    skill_subspec(),
    help_subspec()
  ]
end

export let lookup_subcommand_spec = fn (
  specs: [ SubcommandSpec ],
  name: string
) -> Option<SubcommandSpec> do
  match specs do
    | [] -> return None
    | s :: rest ->
      let SubcommandSpec(
        name: n,
        synopsis: _,
        description: _,
        flags: _,
        examples: _,
        see_also: _,
        exit_codes: _,
        category: _
      ) = s
      if n == name then return Some(val: s) end
        return lookup_subcommand_spec(specs: rest, name)
  end
end

/** Spec table for the top-level `nexus help` overview.
 *  Only TRULY global flags belong here — i.e. flags accepted by every
 *  subcommand. Per-subcommand flags live in their respective `*_subspec()`
 *  entries and are rendered by `nexus <sub> --help` / `nexus help <sub>`.
 *
 *  Note: `cli_specs()` in main.nx still lists every flag because it is fed to
 *  `parse_permissive` for the one-shot global-argv parse. Help rendering uses
 *  this smaller, correctly partitioned table.
 */
export let global_help_specs = fn () -> [ ArgSpec ] do
  return [
    // Subcommands (mirrors subcommand_specs() shape)
    spec_subcommand(
      name: "build",
      help: "<input.nx> [-o output.wasm]"
    ),
    spec_subcommand(name: "typecheck", help: "<input.nx>"),
    spec_subcommand(name: "ast", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "hir", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "lir", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "types", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "caps", help: "<symbol> <input.nx> [--format=text|json]"),
    spec_subcommand(name: "repl", help: "interactive REPL"),
    spec_subcommand(name: "mcp", help: "JSON-RPC tool server (stdio)"),
    spec_subcommand(name: "explain", help: "<symbol> [--file FILE] [--format text|json]"),
    spec_subcommand(name: "context", help: "<file> [--format text|json]"),
    spec_subcommand(name: "test", help: "[path] [--junit FILE]"),
    spec_subcommand(name: "bench", help: "[--dir DIR] [--iters N] [--baseline PATH]"),
    spec_subcommand(name: "fmt", help: "[--check] FILE|- [FILE...]"),
    spec_subcommand(name: "grep", help: "<pattern> [path...]"),
    spec_subcommand(name: "lint", help: "[--check|--fix|--fix-diff] FILE [FILE...]"),
    spec_subcommand(name: "skill", help: "--emit [--out PATH] | --check"),
    spec_subcommand(name: "help", help: "[subcommand]"),
    // Truly global flags only. Run `nexus <sub> --help` for sub-local flags.
    spec_flag(name: "verbose", short: "", long: "--verbose", help: "enable per-pass timing output")
  ]
end

/** True-global flags only for `render_subcommand_overview` "Options:" block. */
export let global_help_flag_specs = fn () -> [ ArgSpec ] do
  return [
    spec_flag(name: "verbose", short: "", long: "--verbose", help: "enable per-pass timing output")
  ]
end

/** Full argparse spec for one-shot global-argv parse.
 *  Includes every flag so `parse_permissive` recognises them all. Help
 *  rendering uses `global_help_specs()` instead (trimmed to truly-global
 * flags only, per).
 */
export let cli_specs = fn () -> [ ArgSpec ] do
  return [
    spec_subcommand(
      name: "build",
      help: "<input.nx> [-o output.wasm]"
    ),
    spec_subcommand(name: "typecheck", help: "<input.nx>"),
    spec_subcommand(name: "ast", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "hir", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "lir", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "types", help: "<input.nx> [--format=text|json]"),
    spec_subcommand(name: "caps", help: "<symbol> <input.nx> [--format=text|json]"),
    spec_subcommand(name: "repl", help: "interactive REPL"),
    spec_subcommand(name: "mcp", help: "JSON-RPC tool server (stdio)"),
    spec_subcommand(name: "explain", help: "<symbol> [--file FILE] [--format text|json]"),
    spec_subcommand(name: "context", help: "<file> [--format text|json]"),
    spec_subcommand(name: "test", help: "[path] [--junit FILE]"),
    spec_subcommand(name: "bench", help: "[--dir DIR] [--iters N] [--baseline PATH]"),
    spec_subcommand(name: "fmt", help: "[--check] FILE|- [FILE...]"),
    spec_subcommand(name: "grep", help: "<pattern> [path...]"),
    spec_subcommand(name: "lint", help: "[--check|--fix|--fix-diff] FILE [FILE...]"),
    spec_subcommand(name: "skill", help: "--emit [--out PATH] | --check"),
    spec_subcommand(name: "help", help: "[subcommand]"),
    spec_flag(name: "verbose", short: "", long: "--verbose", help: "enable per-pass timing output"),
    spec_opt(
      name: "output",
      short: "-o",
      long: "--output",
      required: false,
      help: "output wasm path"
    ),
    spec_opt(
      name: "format",
      short: "",
      long: "--format",
      required: false,
      help: "diagnostic format (text|json)"
    ),
    spec_opt(
      name: "explain-capabilities",
      short: "",
      long: "--explain-capabilities",
      required: false,
      help: "capability reporting (yes|none|wasmtime)"
    ),
    spec_opt(
      name: "explain-capabilities-format",
      short: "",
      long: "--explain-capabilities-format",
      required: false,
      help: "capability report format (text|json)"
    ),
    spec_flag(
      name: "coverage",
      short: "",
      long: "--coverage",
      help: "emit coverage counters and custom section"
    ),
    spec_opt(
      name: "profile-out",
      short: "",
      long: "--profile-out",
      required: false,
      help: "write per-call-site profile JSONL to FILE (static const-arg analysis)"
    ),
    spec_flag(
      name: "dump-imports",
      short: "",
      long: "--dump-imports",
      help: "print the import graph and exit"
    ),
    spec_flag(
      name: "p3",
      short: "",
      long: "--p3",
      help: "emit WASI preview3 compatible wasm (non-shared memory, sequential lazy)"
    ),
    spec_flag(
      name: "p3-component",
      short: "",
      long: "--p3-component",
      help: "wrap output in a component model binary with future<T> canon ABI (implies --p3)"
    ),
    spec_flag(
      name: "p2-component",
      short: "",
      long: "--p2-component",
      help: "wrap output in a WASI preview2 component binary (wasi:cli/run@0.2.0)"
    ),
    // ── static-check (typecheck + lint) flags ──
    spec_flag(
      name: "no-lint",
      short: "",
      long: "--no-lint",
      help: "skip the lint pass after typecheck"
    ),
    spec_opt(
      name: "lint-level",
      short: "",
      long: "--lint-level",
      required: false,
      help: "lint finding severity on build (warn|error); default error gates the build, warn opts out"
    ),
    spec_opt(
      name: "deny",
      short: "",
      long: "--deny",
      required: false,
      help: "promote named lint rule codes to build-gating errors (comma-separated, e.g. L0002)"
    ),
  ]
end
