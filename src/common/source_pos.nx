/**
 * source_pos: shared `(pos, line, col)` triple for byte-level scanners.
 *
 * Used by the frontend lexer's `LexerState` and the LSP semantic-token
 * comment scanner's `ScanState` — both maintained the same triple
 * inline before this extraction (issue nexus-8jnq.8 part 1). `pos` is a
 * byte offset; `line` and `col` are 1-based. Distinct from `Span` in
 * `src/common/token.nx`, which carries the same shape under different
 * field names (`offset, line, col`) and lives at the token boundary.
 */

/** Public type SourcePos. */
export type SourcePos = SourcePos(pos: i64, line: i64, col: i64)
