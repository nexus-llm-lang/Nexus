/**
 * naming: conventional-name mangling for handler functions.
 *
 * Owns:
 * - The `__handler_<binding>_<method>` mangling used by port-call lowering
 *   (src/ir/mir/port.nx) and by reachability filtering (src/ir/hir/reachability.nx).
 *
 * Does not own:
 * - Any other name conventions (top-level qualification, module-path sanitizing,
 *   etc. — see src/ir/rdrname.nx for those).
 */
import * as bb from "stdlib/bytebuffer.nx"
import * as str from "stdlib/string.nx"

export let handler_func_name = fn (handler_name: string, method_name: string) -> string do
  return bb.concat(parts: ["__handler_", handler_name, "_", method_name])
end

export let handler_prefix_len = fn (handler_name: string) -> i64 do
  return str.length(s: bb.concat(parts: ["__handler_", handler_name, "_"]))
end
