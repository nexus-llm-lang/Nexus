/**
 * common/listrev: monomorphic reversal helpers safe for hot codegen paths.
 *
 * `rev_strings` is the single canonical implementation of the
 * tail-recursive `[string]` reverser that used to be duplicated across
 * seven IR / backend modules (backend/codegen, backend/wasm/collect,
 * ir/mir/{mir,lambda_lift,port}, ir/lir/{lir,match_tree}). The body is
 * the same accumulator pattern in every copy; consolidating it removes
 * ~30 lines of churn and one synchronization burden when the
 * monomorphic-reverse convention is eventually replaced by
 * `std:list.reverse` (see `src/common/mono_reverse.nx` for the broader
 * note on why the typed `rev_<Type>` helpers still exist).
 *
 * The signature carries no `throws` clause: callers in throwing
 * contexts compose freely because Nexus's effect row is open at the
 * call site — the inner row stays empty and unifies with whatever the
 * caller declares.
 */

/** Public function rev_strings. */
export let rev_strings = fn (lst: [string], out: [string]) -> [string] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_strings(lst: rest, out: x :: out)
  end
end
