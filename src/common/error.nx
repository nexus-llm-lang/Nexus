/**
 * error: Structured exception types for the Nexus self-hosting compiler.
 *
 * Each error kind is a distinct exception with typed fields — not a pre-formatted
 * string. Sub-exceptions are grouped per phase (ParseError, TypeError, etc.) and
 * the top-level CompileError group catches everything.
 *
 * catch case UnexpectedToken(...) ->   // precise: one parse error kind
 * catch case ParseError ->             // coarse: any parse error
 * catch case CompileError ->           // broadest: any compiler error
 *
 * ─── Error-contract rule (nexus-8jnq.6) ────────────────────────────────────
 *
 * Lookup-helper return shapes follow one rule:
 *   1. Hot paths (per AST node / IR atom / match arm)  → i64 with `-1` sentinel
 *      (document the sentinel inline at the call site).
 *   2. Cold paths (one-shot config / dispatch lookups) → Option<T>.
 *   3. Invariant violations (lookup that "must" succeed; failure = corrupted
 *      state) → throws { SpecificError }. Never use the generic `Exn`.
 *   4. Never combine Option<T> AND `throws` for the not-found signal — pick
 *      one. Two grand-fathered exception families remain:
 *      a. Helpers whose body is a pure Option-returning iteration but whose
 *         row inherits an unrelated invariant-violation propagated from a
 *         throwing sub-helper (e.g. lir_find_active_column → lir_list_nth_pat).
 *         The Option is the not-found signal; the throws is an orthogonal ICE.
 *      b. LSP JSON `optional_*` parsers in src/lsp/protocol.nx, which have a
 *         genuine tri-state outcome (absent | present-valid | present-malformed)
 *         dictated by the LSP wire protocol. None = absent; Some = present and
 *         well-typed; throws { LspProtocolThrow } = malformed JSON.
 *      Both families are documented at the function-doc level.
 */

import { Span } from "src/common/token.nx"
import * as str from "std:str"
import { FileNotFound } from "std:fs"

// ─── Parse exceptions ───────────────────────────────────────────────────────

export exception UnexpectedToken(expected: string, got: string, span: Span)
export exception UnexpectedEof(expected: string, span: Span)

/** Raised by drivers after a multi-error `parse_collect` run when the */
/** caller (e.g. `nexus build`) wants the pipeline to stop. The `count` */
/** field carries the number of accumulated diagnostics so the top-level */
/** error handler can render a brief summary alongside the per-diag */
/** stderr lines already emitted (issue nexus-in6i). */
export exception ParseErrorsCollected(count: i64)

export exception group ParseError = UnexpectedToken | UnexpectedEof | ParseErrorsCollected

// ─── Typecheck exceptions ───────────────────────────────────────────────────

export exception TypeMismatch(func_name: string, detail: string, span: Span)
export exception MissingMain
export exception MainNotFunction
export exception MainNotUnit
/** `main` declares a throws-row that the HIR main-wrap pass cannot synthesise */
/** a top-level handler for: `Exn` (which would swallow every variant), an open */
/** row (rest is Some), or a row containing non-named entries. Narrow */
/** exception groups and concrete exception variants are accepted because the */
/** pass projects them to a closed catch-all + `__nx_exit(1)`. */
export exception MainThrowsTooBroad(detail: string)

export exception LazyBindingUnused(name: string, span: Span)
export exception LazyBindingDoubleUse(name: string, span: Span)

/** nexus-5y83: same-name top-level `let` redeclaration. The HIR-to-WASM */
/** pipeline does not handle lexical shadowing of top-level function names: */
/** the second definition silently overwrites the first in the type env, */
/** while a downstream lir_opt pass mis-resolves `return_call` to itself and */
/** corrupts UNRELATED functions' return atoms with `default_atom(typ)`. */
/** Reject the redeclaration at typecheck time to eliminate the bug class. */
export exception DuplicateTopLevelBinding(name: string, span: Span)

/** %T binding lints (issue nexus-7eex.3): linearity discipline for `%T` */
/** bindings. `LinearUnused` fires when a linear binding leaves scope */
/** without being consumed; `LinearReuse` is reserved for double-use of a */
/** linear local (the structural pass currently relies on consume-removes- */
/** from-set semantics, so a reuse manifests as Unused at the next site; */
/** the constructor is kept as a distinct kind for diagnostic clarity). */
/** `LinearMismatch` fires when an if/match/while/for/try-catch arm */
/** finishes with a different live-linear set than its sibling arms — a */
/** linear that survives one path but not another would silently leak. */
/** `LinearLeakAcrossThrowableCall` is the issue nexus-7eex.2 check: a */
/** stmt-level call whose callee may raise must not leave any linear live */
/** that a catch arm would not be obliged to consume. */
export exception LinearUnused(name: string, span: Span)
export exception LinearReuse(name: string, span: Span)
export exception LinearMismatch(detail: string, span: Span)
export exception LinearLeakAcrossThrowableCall(callee: string, leaked: [string], span: Span)

/** Typecheck invariant violation: the throws-row passed to */
/** `catch_param_type_from_row` / `project_exn_from_row_types` was neither */
/** a `TyRow` / `TyVar` nor an Exn-rooted entry. Reaching this arm means */
/** a prior phase produced a malformed throws-row; surface as ICE rather */
/** than fabricating a Span(0,0,0)-bearing TypeMismatch (issue nexus-tho8). */
/** Raised exclusively by src/typecheck/infer.nx, hence grouped under TypeError. */
export exception ThrowsRowInvariantBroken(detail: string)

export exception group TypeError = TypeMismatch | MissingMain | MainNotFunction | MainNotUnit | MainThrowsTooBroad
  | LazyBindingUnused | LazyBindingDoubleUse
  | LinearUnused | LinearReuse | LinearMismatch | LinearLeakAcrossThrowableCall
  | ThrowsRowInvariantBroken
  | DuplicateTopLevelBinding

// ─── HIR exceptions ─────────────────────────────────────────────────────────

export exception InvalidSymbolTag(tag: i64)

// ─── Codegen exceptions ─────────────────────────────────────────────────────

export exception SymbolNotFound(name: string, kind: string, context: string)

/** Raised when codegen encounters a stack-switching IR node (LirExprSuspend, */
/** LirExprResume, LirExprContNew). The IR types exist as placeholders; codegen */
/** for the with-kont (`with @k`) path is not yet implemented. */
export exception StackSwitchingNotImplemented(node: string)

export exception group CodegenError = SymbolNotFound | StackSwitchingNotImplemented

// ─── Driver exceptions ──────────────────────────────────────────────────────

export exception CyclicImport(path: string)
export exception InvalidUsage(detail: string)
export exception WriteFailed(path: string)

export exception group DriverError = CyclicImport | InvalidUsage | WriteFailed

// ─── File-context wrappers ─────────────────────────────────────────────────
//
// Attach file-path context to any inner compile error. `detail` is the
// already-formatted inner message (see format_error), so these wrappers
// chain naturally: InTargetFile('root', InImport('b', InImport('c', '...'))).

export exception InImport(path: string, detail: string)
export exception InTargetFile(path: string, detail: string)

export exception group FileContextError = InImport | InTargetFile

// ─── HIR-phase group (declared after its members are in scope) ─────────────
//
// Members are the union of:
//   - Pure HIR ICE invariants (InvalidSymbolTag).
//   - HIR-phase user-facing errors raised from src/ir/*
//     (LazyBindingUnused, LazyBindingDoubleUse, CyclicImport, SymbolNotFound).
//   - The InImport file-context wrapper, raised by src/ir/imports.nx as the
//     catch-and-rebrand boundary that attaches file-path context to any
//     inner compile error encountered while loading an imported module.
//
// Several members appear in additional groups by design (multi-membership):
// SymbolNotFound is also raised by src/backend/codegen/* and lives in
// CodegenError; LazyBindingUnused / LazyBindingDoubleUse are linearity-phase
// diagnostics and live in TypeError; CyclicImport is also classified as a
// DriverError. The duplication is intentional: each group captures the phase
// that raises its members, and a single variant can be raised by more than
// one phase.

export exception group HirError =
    InvalidSymbolTag
  | LazyBindingUnused | LazyBindingDoubleUse
  | SymbolNotFound
  | CyclicImport
  | InImport

// ─── MIR exceptions ─────────────────────────────────────────────────────────

export exception MirPortHandlerNotFound(port_name: string, method_name: string)

export exception group MirError = MirPortHandlerNotFound

// ─── LIR exceptions ─────────────────────────────────────────────────────────

export exception LirFieldOnNonVariable(field: string)
export exception LirFieldOnNonRecord(field: string, variable: string)
export exception LirFieldNotInRecord(field: string)
export exception LirAtomEntryNotFound(id: i64)

export exception group LirError =
    LirFieldOnNonVariable | LirFieldOnNonRecord | LirFieldNotInRecord | LirAtomEntryNotFound

// ─── Top-level group ────────────────────────────────────────────────────────

export exception group CompileError =
  UnexpectedToken | UnexpectedEof | ParseErrorsCollected
  | TypeMismatch | MissingMain | MainNotFunction | MainNotUnit | MainThrowsTooBroad
  | LazyBindingUnused | LazyBindingDoubleUse
  | LinearUnused | LinearReuse | LinearMismatch | LinearLeakAcrossThrowableCall
  | DuplicateTopLevelBinding
  | InvalidSymbolTag
  | ThrowsRowInvariantBroken
  | SymbolNotFound
  | CyclicImport | InvalidUsage | WriteFailed
  | InImport | InTargetFile
  | MirPortHandlerNotFound
  | LirFieldOnNonVariable | LirFieldOnNonRecord | LirFieldNotInRecord | LirAtomEntryNotFound
  | StackSwitchingNotImplemented

// ─── Formatting helpers ─────────────────────────────────────────────────────
//
// Style:
//   - numeric error codes per phase: E0xxx internal, E1xxx lex/parse,
//     E2xxx typecheck, E3xxx codegen, E4xxx driver, E5xxx MIR, E6xxx LIR.
//   - identifiers, paths, and signatures are single-quoted for visibility.
//   - internal invariants include a bug-report hint so users know to file it.
//   - spans render as "at line L, column C" for consistency with diagnostics.

let ice_suffix = " (this is a bug in nexus; please report it)"

let with_code = fn (body: string, c: string) -> string do
  return body ++ " [" ++ c ++ "]"
end

let quote = fn (s: string) -> string do
  return "'" ++ s ++ "'"
end

/** Strip the canonical-name prefix (sanitized_source_path#) so diagnostics */
/** show the user-written bare name rather than the internal qname. */
let unqualify = fn (s: string) -> string do
  let idx = str.index_of(s, sub: "#")
  if idx < 0 then return s end
  return str.substring(s, start: idx + 1, len: str.length(s) - idx - 1)
end

let join_names = fn (names: [string]) -> string do
  match names do
    | [] -> return "{}"
    | n :: [] -> return quote(s: "%" ++ n)
    | n :: rest -> return quote(s: "%" ++ n) ++ ", " ++ join_names(names: rest)
  end
end

let main_signature_hint = fn () -> string do
  return "; expected " ++ quote(s: "let main = fn () -> unit")
    ++ " or " ++ quote(s: "let main = fn (args: [string]) -> unit")
end

let format_at = fn (span: Span) -> string do
  match span do | Span(offset: _, line: l, col: c) ->
    return " at line " ++ str.from_i64(val: l) ++ ", column " ++ str.from_i64(val: c)
  end
end

export let format_error = fn (err: Exn) -> string do
  match err do
    // ── Parse (E1xxx) ──
    | UnexpectedToken(expected: e, got: g, span: sp) ->
      with_code(body: "parse error: expected " ++ e ++ ", got " ++ quote(s: g) ++ format_at(span: sp), c: "E1001")
    | UnexpectedEof(expected: e, span: sp) ->
      with_code(body: "parse error: expected " ++ e ++ ", got end of input" ++ format_at(span: sp), c: "E1002")
    | ParseErrorsCollected(count: n) ->
      with_code(body: "parse failed: " ++ str.from_i64(val: n) ++ " errors", c: "E1004")
    // ── Typecheck (E2xxx) ──
    | TypeMismatch(func_name: f, detail: d, span: sp) ->
      with_code(body: "type error in " ++ quote(s: f) ++ ": " ++ d ++ format_at(span: sp), c: "E2001")
    | MissingMain ->
      with_code(body: "type error: no " ++ quote(s: "main") ++ " function defined" ++ main_signature_hint(), c: "E2002")
    | MainNotFunction ->
      with_code(body: "type error: " ++ quote(s: "main") ++ " is not a function" ++ main_signature_hint(), c: "E2003")
    | MainNotUnit ->
      with_code(body: "type error: " ++ quote(s: "main") ++ " must return " ++ quote(s: "unit") ++ main_signature_hint(), c: "E2004")
    | MainThrowsTooBroad(detail: d) ->
      with_code(body: "type error: " ++ quote(s: "main") ++ " throws-row is too broad to wrap: " ++ d
        ++ "; declare a narrow exception group instead, or remove the throws clause", c: "E2007")
    | LazyBindingUnused(name: n, span: sp) ->
      with_code(body: "linearity error: lazy binding " ++ quote(s: "@" ++ n) ++ " is never forced" ++ format_at(span: sp), c: "E2005")
    | LazyBindingDoubleUse(name: n, span: sp) ->
      with_code(body: "linearity error: lazy binding " ++ quote(s: "@" ++ n) ++ " is forced more than once" ++ format_at(span: sp), c: "E2006")
    | LinearUnused(name: n, span: sp) ->
      with_code(body: "linearity error: linear binding " ++ quote(s: "%" ++ n) ++ " is never consumed" ++ format_at(span: sp), c: "E2007")
    | LinearReuse(name: n, span: sp) ->
      with_code(body: "linearity error: linear binding " ++ quote(s: "%" ++ n) ++ " is consumed more than once" ++ format_at(span: sp), c: "E2008")
    | LinearMismatch(detail: d, span: sp) ->
      with_code(body: "linearity error: linear set mismatch: " ++ d ++ format_at(span: sp), c: "E2009")
    | LinearLeakAcrossThrowableCall(callee: f, leaked: ls, span: sp) ->
      with_code(body: "linearity error: linear value cannot live across throwable call to " ++ quote(s: f) ++ ": " ++ join_names(names: ls) ++ " would leak if the call raises" ++ format_at(span: sp), c: "E0540")
    | DuplicateTopLevelBinding(name: n, span: sp) ->
      with_code(body: "type error: top-level binding " ++ quote(s: unqualify(s: n)) ++ " is already defined in this file; same-name redeclaration is not supported (rename the second binding)" ++ format_at(span: sp), c: "E2010")
    // ── HIR invariants (E0xxx) — always ICE ──
    | InvalidSymbolTag(tag: t) ->
      with_code(body: "internal compiler error: invalid symbol tag " ++ str.from_i64(val: t), c: "E0001") ++ ice_suffix
    | ThrowsRowInvariantBroken(detail: d) ->
      with_code(body: "internal compiler error: throws-row invariant broken in typecheck: " ++ d, c: "E0004") ++ ice_suffix
    // ── Codegen (E3xxx) ──
    | SymbolNotFound(name: n, kind: k, context: c) ->
      with_code(body: "codegen error: " ++ k ++ " " ++ quote(s: n) ++ " not found (in " ++ c ++ ")", c: "E3001")
    // ── Driver (E4xxx) ──
    | CyclicImport(path: p) ->
      with_code(body: "error: cyclic import detected: " ++ quote(s: p), c: "E4001")
    | InvalidUsage(detail: d) ->
      with_code(body: "error: invalid usage: " ++ d, c: "E4002")
    | WriteFailed(path: p) ->
      with_code(body: "error: failed to write " ++ quote(s: p), c: "E4003")
    // ── File-context wrappers (no code; context only) ──
    | InTargetFile(path: p, detail: d) ->
      p ++ ": " ++ d
    | InImport(path: p, detail: d) ->
      "in imported module " ++ quote(s: p) ++ ": " ++ d
    // ── Stdlib I/O exceptions passing through the compiler ──
    | FileNotFound(path: p) ->
      with_code(body: "error: file not found: " ++ quote(s: p), c: "E4004")
    // ── MIR (E5xxx) ──
    | MirPortHandlerNotFound(port_name: pn, method_name: mn) ->
      with_code(body: "mir error: no handler bound for port " ++ quote(s: pn) ++ " (method " ++ quote(s: mn) ++ ")", c: "E5001")
    // ── LIR (E6xxx) ──
    | LirFieldOnNonVariable(field: f) ->
      with_code(body: "lir error: field access " ++ quote(s: "." ++ f) ++ " on non-variable atom", c: "E6001")
    | LirFieldOnNonRecord(field: f, variable: v) ->
      with_code(body: "lir error: field access " ++ quote(s: "." ++ f) ++ " on non-record semantic type for variable " ++ quote(s: v), c: "E6002")
    | LirFieldNotInRecord(field: f) ->
      with_code(body: "lir error: field " ++ quote(s: f) ++ " not present in record type", c: "E6003")
    | LirAtomEntryNotFound(id: i) ->
      with_code(body: "lir error: scrutinee id " ++ str.from_i64(val: i) ++ " not found in atom table", c: "E6004")
    | StackSwitchingNotImplemented(node: n) ->
      with_code(body: "codegen error: stack-switching IR node " ++ quote(s: n) ++ " has no codegen path; delimited-continuation lowering for " ++ quote(s: "with @k") ++ " handlers is not implemented", c: "E3002")
    | RuntimeError(val: msg) -> msg
    // Catch-all for exceptions outside CompileError: stdlib (arena, hashmap,
    // bytebuffer), runtime panics, etc. If you see "uncategorized compiler
    // exception", the new exception should get a dedicated arm above with an
    // error code. ICE suffix tags it for a bug report so users know raising
    // this path without an arm is unintended.
    | _ ->
      with_code(body: "internal compiler error: uncategorized compiler exception", c: "E0099") ++ ice_suffix
  end
end
