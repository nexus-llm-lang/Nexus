/**
 * error: Structured exception types for the Nexus self-hosting compiler.
 *
 * Each error kind is a distinct exception with typed fields — not a pre-formatted
 * string. Sub-exceptions are grouped per phase (ParseError, TypeError, etc.) and
 * the top-level CompileError group catches everything.
 *
 * catch case UnexpectedToken(...) ->   // precise: one parse error kind
 * catch case ParseError ->             // coarse: any parse error
 * catch case CompileError ->           // broadest: any compiler error
 *
 * Phase-local group files (contain ONLY exception group declarations;
 * individual exception types are defined below so the seed compiler's
 * wf_throw and constructor-lookup checks find them in enum_defs):
 *   src/ir/hir/errors.nx     — HirError group
 *   src/typecheck/errors.nx  — TypeError group + all T-rule / linearity diagnostics
 *   src/backend/errors.nx    — CodegenError group + SymbolKind + SymbolNotFound +
 *                               StackSwitchingNotImplemented
 *   src/ir/mir/errors.nx     — MirError group + MirCapHandlerNotFound + MirHandlerNotInMapping
 *   src/ir/lir/errors.nx     — LirError group + all Lir* field exceptions
 *
 * This file owns: all individual exception definitions (parse, HIR, driver,
 * file-context, and the HIR sub-exceptions that appear directly in throws rows),
 * plus ParseError / DriverError / FileContextError / HirError / CompileError
 * groups and all error formatting.
 *
 * ─── Error-contract rule ────────────────────────────────────────────────────
 *
 * Lookup-helper return shapes follow one rule:
 *   1. Hot paths (per AST node / IR atom / match arm)  → i64 with `-1` sentinel
 *      (document the sentinel inline at the call site).
 *   2. Cold paths (one-shot config / dispatch lookups) → Option<T>.
 *   3. Invariant violations (lookup that "must" succeed; failure = corrupted
 *      state) → throws { SpecificError }. Never use the generic `Exn`.
 *   4. Never combine Option<T> AND `throws` for the not-found signal — pick
 *      one. Two grand-fathered exception families remain:
 *      a. Helpers whose body is a pure Option-returning iteration but whose
 *         row inherits an unrelated invariant-violation propagated from a
 *         throwing sub-helper (e.g. lir_find_active_column → lir_list_nth_pat).
 *         The Option is the not-found signal; the throws is an orthogonal ICE.
 *      b. LSP JSON `optional_*` parsers in src/lsp/protocol.nx, which have a
 *         genuine tri-state outcome (absent | present-valid | present-malformed)
 *         dictated by the LSP wire protocol. None = absent; Some = present and
 *         well-typed; throws { LspProtocolThrow } = malformed JSON.
 *      Both families are documented at the function-doc level.
 */

import { Span } from "src/common/token.nx"
import * as str from "std:str"
import { FileNotFound } from "std:fs"
import { Option, Some, None } from "std:option"
import {
  TypeError,
  TypeMismatch, MissingMain, MainNotFunction, MainNotUnit, MainThrowsTooBroad,
  MainRequiresTooBroad, MainWrongParams, MainExported,
  LazyBindingUnused, LazyBindingDoubleUse,
  LinearUnused, LinearReuse, LinearMismatch, LinearLeakAcrossThrowableCall,
  ThrowsRowInvariantBroken,
  DuplicateTopLevelBinding, UnusedTypeParam, KindClashTypeParam,
  UnknownCapability, UnknownThrowVariant,
  UnknownConstructor, UnknownField,
  DuplicateInjectCap, HandlerRequireNotSubset,
  DuplicateRecordLabel, DuplicatePatternLabel,
  UnreachableCode, RefEscapes, RefInnerLinear,
  UnknownVariable,
  ReservedDeclarationName, DuplicateDeclaration, InvalidGroupMember
} from "src/typecheck/errors.nx"
import {
  SymbolKind, SkFunction, SkExternal, SkIntrinsic, SkIntrinsicArg, SkBinaryOp,
  SkVariable, SkClosureArity, SkArmTag, SkArmTagIndex, SkSuspendTag,
  SkCallArgLabel, SkInjectHandler,
  SymbolNotFound, StackSwitchingNotImplemented, WasmMergeUnsupported,
  CodegenError
} from "src/backend/errors.nx"
import {
  MirCapHandlerNotFound, MirMultiArgSuspend, MirHandlerNotInMapping, MirError
} from "src/ir/mir/errors.nx"
import {
  LirFieldOnNonVariable, LirFieldOnNonRecord, LirFieldNotInRecord, LirAtomEntryNotFound,
  LirError
} from "src/ir/lir/errors.nx"
import { DuplicateParamLabel } from "src/frontend/errors.nx"
import { CyclicImport, ImportNotExported, InImport } from "src/ir/shared/errors.nx"

/** Public exception InvalidSymbolTag. */
export exception InvalidSymbolTag(tag: i64)

/** Public exception UnexpectedToken. */
export exception UnexpectedToken(expected: string, got: string, span: Span)
/** Public exception UnexpectedEof. */
export exception UnexpectedEof(expected: string, span: Span)

/** Raised by drivers after a multi-error `parse_collect` run when the
 *  caller (e.g. `nexus build`) wants the pipeline to stop. The `count`
 *  field carries the number of accumulated diagnostics so the top-level
 *  error handler can render a brief summary alongside the per-diag
 * stderr lines already emitted.
 */
export exception ParseErrorsCollected(count: i64)

/** Public exception group ParseError. */
export exception group ParseError = UnexpectedToken | UnexpectedEof | ParseErrorsCollected | DuplicateParamLabel

/** Public exception InvalidUsage. */
export exception InvalidUsage(detail: string)
/** Public exception WriteFailed. */
export exception WriteFailed(path: string)
/** Raised when a required capability was stripped by a --no-* sandbox flag. */
export exception SandboxRefusal(capability: string, flag: string)

/** Attach file-path context to errors in the target compilation unit. */
export exception InTargetFile(path: string, detail: string)

/** Public exception group DriverError.
 *  Covers all error conditions that the top-level driver (src/main.nx) needs
 *  to dispatch to a specific exit code.  `FileNotFound` is included so that
 *  functions that mix usage-validation with I/O walks can declare a single
 *  `throws { DriverError }` instead of the cross-umbrella form
 *  `throws { InvalidUsage, FileNotFound }`.
 *  Exit-code mapping in main.nx:
 *    InvalidUsage    → exit 2
 *    SandboxRefusal  → exit 3
 *    everything else → exit 1
 */
export exception group DriverError = CyclicImport | InvalidUsage | WriteFailed | SandboxRefusal | ImportNotExported | FileNotFound

/** Public exception group FileContextError. */
export exception group FileContextError = InImport | InTargetFile

/** Public exception group HirError. */
export exception group HirError =
    InvalidSymbolTag
  | LazyBindingUnused | LazyBindingDoubleUse
  | SymbolNotFound
  | CyclicImport
  | ImportNotExported
  | InImport
  | MainExported

/** Public exception group CompileError. */
export exception group CompileError =
  UnexpectedToken | UnexpectedEof | ParseErrorsCollected | DuplicateParamLabel
  | TypeMismatch | MissingMain | MainNotFunction | MainNotUnit | MainThrowsTooBroad
  | MainRequiresTooBroad | MainWrongParams | MainExported
  | LazyBindingUnused | LazyBindingDoubleUse
  | LinearUnused | LinearReuse | LinearMismatch | LinearLeakAcrossThrowableCall
  | DuplicateTopLevelBinding
  | UnusedTypeParam | KindClashTypeParam
  | UnknownCapability | UnknownThrowVariant
  | UnknownConstructor | UnknownField
  | InvalidSymbolTag
  | ThrowsRowInvariantBroken
  | SymbolNotFound
  | CyclicImport | InvalidUsage | WriteFailed | SandboxRefusal | ImportNotExported
  | InImport | InTargetFile
  | MirCapHandlerNotFound | MirMultiArgSuspend | MirHandlerNotInMapping
  | LirFieldOnNonVariable | LirFieldOnNonRecord | LirFieldNotInRecord | LirAtomEntryNotFound
  | DuplicateInjectCap | HandlerRequireNotSubset
  | DuplicateRecordLabel | DuplicatePatternLabel
  | StackSwitchingNotImplemented
  | WasmMergeUnsupported
  | UnknownVariable

//
// Style:
//   - numeric error codes per phase: E0xxx internal, E1xxx lex/parse,
//     E2xxx typecheck, E3xxx codegen, E4xxx driver, E5xxx MIR, E6xxx LIR.
//   - identifiers, paths, and signatures are single-quoted for visibility.
//   - internal invariants include a bug-report hint so users know to file it.
//   - spans render as "at line L, column C" for consistency with diagnostics.

let ice_suffix = " (this is a bug in nexus; please report it)"

let with_code = fn (body: string, c: string) -> string do
  return body ++ " [" ++ c ++ "]"
end

let quote = fn (s: string) -> string do
  return "'" ++ s ++ "'"
end

/** Strip the canonical-name prefix (sanitized_source_path#) so diagnostics
 *  show the user-written bare name rather than the internal qname.
 */
let unqualify = fn (s: string) -> string do
  let idx = str.index_of(s, sub: "#")
  if idx < 0 then return s end
  return str.substring(s, start: idx + 1, len: str.length(s) - idx - 1)
end

let join_names = fn (names: [ string ]) -> string do
  match names do
    | [] -> return "{}"
    | n :: [] -> return quote(s: "%" ++ n)
    | n :: rest -> return quote(s: "%" ++ n) ++ ", " ++ join_names(names: rest)
  end
end

let main_signature_hint = fn () -> string do
  return "; expected " ++ quote(s: "let main = fn () -> unit")
    ++ " or " ++ quote(s: "let main = fn (args: [string]) -> unit")
end

let format_at = fn (span: Span) -> string do
  match span do | Span(offset: _, line: l, col: c) ->
    return " at line " ++ str.from_i64(val: l) ++ ", column " ++ str.from_i64(val: c)
  end
end

/** Render a suggestion list as "\n  --> did you mean `name` ?" lines.
 *  Returns empty string when the list is empty.
 */
let format_suggestions = fn (sugs: [ string ]) -> string do
  return format_suggestions_go(sugs, acc: "")
end

let format_suggestions_go = fn (sugs: [ string ], acc: string) -> string do
  match sugs do
    | [] -> return acc
    | s :: rest ->
      return format_suggestions_go(sugs: rest, acc: acc ++ "\n  --> did you mean " ++ quote(s) ++ " ?")
  end
end

let symbol_kind_label = fn (k: SymbolKind) -> string do
  match k do
    | SkFunction -> return "function"
    | SkExternal -> return "external"
    | SkIntrinsic -> return "intrinsic"
    | SkIntrinsicArg -> return "intrinsic arg"
    | SkBinaryOp -> return "binary operator"
    | SkVariable -> return "variable"
    | SkClosureArity -> return "closure arity"
    | SkArmTag -> return "arm tag"
    | SkArmTagIndex -> return "arm tag index"
    | SkSuspendTag -> return "suspend tag"
    | SkCallArgLabel -> return "call argument label"
    | SkInjectHandler -> return "inject handler"
  end
end

/** Public function format_error. */
export let format_error = fn (err: Exn) -> string do
  match err do
    // ── Parse (E1xxx) ──
    | UnexpectedToken(expected: e, got: g, span: sp) ->
      with_code(body: "parse error: expected " ++ e ++ ", got " ++ quote(s: g) ++ format_at(span: sp), c: "E1001")
    | UnexpectedEof(expected: e, span: sp) ->
      with_code(body: "parse error: expected " ++ e ++ ", got end of input" ++ format_at(span: sp), c: "E1002")
    | ParseErrorsCollected(count: n) ->
      with_code(body: "parse failed: " ++ str.from_i64(val: n) ++ " errors", c: "E1004")
    | DuplicateParamLabel(name: n, span: sp) ->
      with_code(body: "parse error: duplicate parameter label " ++ quote(s: n)
        ++ " in function declaration; each parameter must have a distinct name" ++ format_at(span: sp), c: "E1005")
    // ── Typecheck (E2xxx) ──
    | TypeMismatch(func_name: f, detail: d, span: sp) ->
      with_code(body: "type error in " ++ quote(s: f) ++ ": " ++ d ++ format_at(span: sp), c: "E2001")
    | MissingMain ->
      with_code(body: "type error: no " ++ quote(s: "main") ++ " function defined" ++ main_signature_hint(), c: "E2002")
    | MainNotFunction ->
      with_code(body: "type error: " ++ quote(s: "main") ++ " is not a function" ++ main_signature_hint(), c: "E2003")
    | MainNotUnit ->
      with_code(body: "type error: " ++ quote(s: "main") ++ " must return " ++ quote(s: "unit") ++ main_signature_hint(), c: "E2004")
    | MainThrowsTooBroad(detail: d) ->
      with_code(body: "type error: " ++ quote(s: "main") ++ " throws-row is too broad to wrap: " ++ d
        ++ "; declare a narrow exception group instead, or remove the throws clause", c: "E2007")
    | MainRequiresTooBroad(cap_name: p) ->
      with_code(body: "type error: " ++ quote(s: "main") ++ " require-row contains user-declared cap "
        ++ quote(s: p) ++ "; main's require row may only contain system capabilities (PermFs, PermNet, "
        ++ "PermConsole, PermRandom, PermClock, PermProc, PermEnv) — there is no enclosing inject to "
        ++ "provide user caps at the program entry point (P9 wfMain: rho_q ⊆ SysCaps)", c: "E2017")
    | MainWrongParams ->
      with_code(body: "type error: " ++ quote(s: "main") ++ " has an unsupported parameter list"
        ++ main_signature_hint(), c: "E2027")
    | MainExported ->
      with_code(body: "type error: " ++ quote(s: "main") ++ " may not be exported; it is a runtime "
        ++ "entry-point hook, not part of any module's public API (P9 wfMain: main not in exports)", c: "E2018")
    | LazyBindingUnused(name: n, span: sp) ->
      with_code(body: "linearity error: lazy binding " ++ quote(s: "@" ++ n) ++ " is never forced" ++ format_at(span: sp), c: "E2005")
    | LazyBindingDoubleUse(name: n, span: sp) ->
      with_code(body: "linearity error: lazy binding " ++ quote(s: "@" ++ n) ++ " is forced more than once" ++ format_at(span: sp), c: "E2006")
    | LinearUnused(name: n, span: sp) ->
      with_code(body: "linearity error: linear binding " ++ quote(s: "%" ++ n) ++ " is never consumed" ++ format_at(span: sp), c: "E2007")
    | LinearReuse(name: n, span: sp) ->
      with_code(body: "linearity error: linear binding " ++ quote(s: "%" ++ n) ++ " is consumed more than once" ++ format_at(span: sp), c: "E2008")
    | LinearMismatch(detail: d, span: sp) ->
      with_code(body: "linearity error: linear set mismatch: " ++ d ++ format_at(span: sp), c: "E2009")
    | LinearLeakAcrossThrowableCall(callee: f, leaked: ls, span: sp) ->
      with_code(body: "linearity error: linear value cannot live across throwable call to " ++ quote(s: f) ++ ": " ++ join_names(names: ls) ++ " would leak if the call raises" ++ format_at(span: sp), c: "E0540")
    | DuplicateTopLevelBinding(name: n, span: sp) ->
      with_code(body: "type error: top-level binding " ++ quote(s: unqualify(s: n)) ++ " is already defined in this file; same-name redeclaration is not supported (rename the second binding)" ++ format_at(span: sp), c: "E2010")
    | UnusedTypeParam(name: n, func_name: f, span: sp) ->
      with_code(body: "type error: type parameter " ++ quote(s: n) ++ " declared on " ++ quote(s: unqualify(s: f)) ++ " is never used in its signature; kindOf(" ++ n ++ ") is undefined (drop the unused quantifier)" ++ format_at(span: sp), c: "E2011")
    | KindClashTypeParam(name: n, func_name: f, span: sp) ->
      with_code(body: "type error: type parameter " ++ quote(s: n) ++ " on " ++ quote(s: unqualify(s: f)) ++ " is used at both a type position and a row-tail position; kindOf(" ++ n ++ ") is undefined (split into two quantifiers, one per kind)" ++ format_at(span: sp), c: "E2012")
    | UnknownCapability(name: n, suggestions: sugs, span: sp) ->
      with_code(body: "type error: unknown capability " ++ quote(s: n)
        ++ " in require row; expected a system capability ('PermFs', 'PermNet', 'PermConsole', 'PermRandom', 'PermClock', 'PermProc', 'PermEnv') or a cap declared by 'cap'" ++ format_at(span: sp) ++ format_suggestions(sugs), c: "E2013")
    | UnknownThrowVariant(name: n, suggestions: sugs, span: sp) ->
      with_code(body: "type error: unknown throw variant " ++ quote(s: n)
        ++ " in throws row; expected the universal 'Exn' sentinel, a declared exception, or a declared exception group" ++ format_at(span: sp) ++ format_suggestions(sugs), c: "E2014")
    | UnknownConstructor(name: n, suggestions: sugs, span: sp) ->
      with_code(body: "type error: unknown constructor " ++ quote(s: n)
        ++ "; no enum variant with this name is in scope" ++ format_at(span: sp) ++ format_suggestions(sugs), c: "E2025")
    | UnknownField(name: n, suggestions: sugs, span: sp) ->
      with_code(body: "type error: unknown field " ++ quote(s: n)
        ++ " in record type" ++ format_at(span: sp) ++ format_suggestions(sugs), c: "E2026")
    | DuplicateInjectCap(cap_name: p, span: sp) ->
      with_code(body: "type error: inject site lists two handlers for the same cap " ++ quote(s: p)
        ++ "; each cap may appear at most once per inject (T-Inject: ∀i≠j. P_i ≠ P_j)" ++ format_at(span: sp), c: "E2015")
    | HandlerRequireNotSubset(handler_name: h, missing_cap: mc, span: sp) ->
      with_code(body: "type error: handler " ++ quote(s: h) ++ " requires capability " ++ quote(s: mc)
        ++ " which is not in the enclosing function's ambient require row (T-Inject: ∀i. ρ_i ⊆ ρ_q)" ++ format_at(span: sp), c: "E2016")
    | DuplicateRecordLabel(label: l, span: sp) ->
      with_code(body: "type error: duplicate field label " ++ quote(s: l)
        ++ " in record literal; distinct(ℓ̄) premise of T-Record requires each label to appear at most once" ++ format_at(span: sp), c: "E2019")
    | DuplicatePatternLabel(label: l, span: sp) ->
      with_code(body: "type error: duplicate field label " ++ quote(s: l)
        ++ " in record pattern; distinct(ℓ̄) premise of P-Record requires each label to appear at most once" ++ format_at(span: sp), c: "E2020")
    | UnreachableCode(span: sp) ->
      with_code(body: "type error: unreachable code after diverging statement (return / throw)" ++ format_at(span: sp), c: "E2021")
    | RefEscapes(context: ctx, span: sp) ->
      with_code(body: "type error: mutable reference (~σ) escapes its defining scope in "
        ++ ctx ++ "; ref cells are stack-confined and may not appear in return types or be returned (gravity rule: ¬escapesRef(τ))"
        ++ format_at(span: sp), c: "E2022")
    | RefInnerLinear(param: p, span: sp) ->
      with_code(body: "type error: parameter '" ++ p ++ "' has type ~%τ — a mutable reference cell whose inner type is linear; "
        ++ "each deref (~x) would produce a fresh copy of the linear payload, duplicating the resource (wfRef(~σ) ⟺ ¬linear(σ))"
        ++ format_at(span: sp), c: "E2023")
    | UnknownVariable(name: n, suggestions: sugs, span: sp) ->
      with_code(body: "type error: undefined variable " ++ quote(s: n) ++ format_at(span: sp) ++ format_suggestions(sugs), c: "E2024")
    | ReservedDeclarationName(kind: k, name: n, span: sp) ->
      with_code(body: "type error: " ++ k ++ " name " ++ quote(s: n)
        ++ " is reserved by the type system; 'Exn' is the universal exception sentinel and 'PermFs', 'PermNet', 'PermConsole', 'PermRandom', 'PermClock', 'PermProc', 'PermEnv' are system capabilities"
        ++ " (D-Exception/D-Cap: C ∉ {Exn} ∪ SysCaps)" ++ format_at(span: sp), c: "E2028")
    | DuplicateDeclaration(kind: k, name: n, span: sp) ->
      with_code(body: "type error: " ++ k ++ " " ++ quote(s: n)
        ++ " is already declared in this compilation unit; same-name redeclaration is not supported"
        ++ " (D-Exception/D-Cap freshness premise: C ∉ variants(Exn) / X ∉ dom(caps))" ++ format_at(span: sp), c: "E2029")
    | InvalidGroupMember(group_name: g, member: m, reason: r, span: sp) ->
      with_code(body: "type error: exception group " ++ quote(s: g)
        ++ " member " ++ quote(s: m) ++ " is invalid: " ++ r
        ++ " (D-ExceptionGroup: ∀i. C_i ∈ variants(Exn) ∧ distinct(C_1..C_n))" ++ format_at(span: sp), c: "E2030")
    // ── HIR invariants (E0xxx) — always ICE ──
    | InvalidSymbolTag(tag: t) ->
      with_code(body: "internal compiler error: invalid symbol tag " ++ str.from_i64(val: t), c: "E0001") ++ ice_suffix
    | ThrowsRowInvariantBroken(detail: d) ->
      with_code(body: "internal compiler error: throws-row invariant broken in typecheck: " ++ d, c: "E0004") ++ ice_suffix
    // ── Codegen (E3xxx) ──
    | SymbolNotFound(name: n, kind: k, context: c) ->
      with_code(body: "codegen error: " ++ symbol_kind_label(k) ++ " " ++ quote(s: n) ++ " not found (in " ++ c ++ ")", c: "E3001")
    // ── Driver (E4xxx) ──
    | CyclicImport(path: p) ->
      with_code(body: "error: cyclic import detected: " ++ quote(s: p), c: "E4001")
    | InvalidUsage(detail: d) ->
      with_code(body: "error: invalid usage: " ++ d, c: "E4002")
    | WriteFailed(path: p) ->
      with_code(body: "error: failed to write " ++ quote(s: p), c: "E4003")
    | SandboxRefusal(capability: c, flag: f) ->
      with_code(body: "sandbox error: capability " ++ quote(s: c) ++ " is required by the program but was stripped by " ++ f, c: "E4010")
    | ImportNotExported(name: n, module_path: m, suggestions: sugs) ->
      with_code(body: "error: " ++ quote(s: n) ++ " is not exported by module " ++ quote(s: m)
        ++ "; only names with the 'export' prefix are visible to importing modules (D-Export)" ++ format_suggestions(sugs), c: "E4005")
    // ── File-context wrappers (no code; context only) ──
    | InTargetFile(path: p, detail: d) ->
      p ++ ": " ++ d
    | InImport(path: p, detail: d) ->
      "in imported module " ++ quote(s: p) ++ ": " ++ d
    // ── Stdlib I/O exceptions passing through the compiler ──
    | FileNotFound(path: p) ->
      with_code(body: "error: file not found: " ++ quote(s: p), c: "E4004")
    // ── MIR (E5xxx) ──
    | MirCapHandlerNotFound(cap_name: cn, method_name: mn) ->
      with_code(body: "mir error: no handler bound for cap " ++ quote(s: cn) ++ " (method " ++ quote(s: mn) ++ ")", c: "E5001")
    | MirMultiArgSuspend(cap_name: cn, method_name: mn, arg_count: n) ->
      with_code(body: "mir error: cap method " ++ quote(s: cn ++ "." ++ mn) ++ " used with " ++ quote(s: "with @k") ++ " but called with " ++ str.from_i64(val: n) ++ " arguments; multi-arg suspend payload is unspecified", c: "E5002")
    | MirHandlerNotInMapping(handler_name: hn) ->
      with_code(body: "mir error: handler " ++ quote(s: hn) ++ " not found in handler_cap_names mapping; this is an HIR build bug where the inject scope was not wired into the cap-name mapping", c: "E5003")
    // ── LIR (E6xxx) ──
    | LirFieldOnNonVariable(field: f) ->
      with_code(body: "lir error: field access " ++ quote(s: "." ++ f) ++ " on non-variable atom", c: "E6001")
    | LirFieldOnNonRecord(field: f, variable: v) ->
      with_code(body: "lir error: field access " ++ quote(s: "." ++ f) ++ " on non-record semantic type for variable " ++ quote(s: v), c: "E6002")
    | LirFieldNotInRecord(field: f) ->
      with_code(body: "lir error: field " ++ quote(s: f) ++ " not present in record type", c: "E6003")
    | LirAtomEntryNotFound(id: i) ->
      with_code(body: "lir error: scrutinee id " ++ str.from_i64(val: i) ++ " not found in atom table", c: "E6004")
    | StackSwitchingNotImplemented(node: n) ->
      with_code(body: "codegen error: stack-switching IR node " ++ quote(s: n) ++ " has no codegen path; delimited-continuation lowering for " ++ quote(s: "with @k") ++ " handlers is not implemented", c: "E3002")
    | WasmMergeUnsupported(detail: d) ->
      with_code(body: "codegen error: unsupported wasm-merge feature: " ++ d, c: "E3003")
    | RuntimeError(val: msg) -> msg
    // Catch-all for exceptions outside CompileError: stdlib (arena, hashmap,
    // bytebuffer), runtime panics, etc. If you see "uncategorized compiler
    // exception", the new exception should get a dedicated arm above with an
    // error code. ICE suffix tags it for a bug report so users know raising
    // this path without an arm is unintended.
    | _ ->
      with_code(body: "internal compiler error: uncategorized compiler exception", c: "E0099") ++ ice_suffix
  end
end

//
// `CompilerDiagnostic` is the JSON-serializable shape that backs `--format=json`.
// Built from a raw Exn via `diagnostic_from_exn`; rendered to NDJSON via
// `format_diagnostic_json`. The text path keeps using `format_error` directly,
// so backward-compatibility is preserved when `--format` is unspecified.
//
// Future (out of scope V1): SARIF emit, fix-it suggestion arrays, and
// migrating every direct `throw` site in typecheck/linearity through this
// pipeline. Tracked as.2.

/** Structured diagnostic record. `file` may be empty when the raising
 *  phase doesn't know its source path (e.g. unit-test invocations).
 *  `line`/`column` mirror the underlying `Span`; both are 0 when the
 *  exception has no span (MissingMain, ParseErrorsCollected, ICEs).
 */
export type CompilerDiagnostic = CompilerDiagnostic(code: string, severity: string, file: string, line: i64, column: i64, message: string)

/** Backward scan: return the highest index in `s` at which `sub`
 *  appears, or -1 if absent. Inlined here because std:str does not
 *  expose `last_index_of`.
 */
let last_index_of_in = fn (s: string, sub: string) -> i64 do
  let n = str.length(s)
  let m = str.length(s: sub)
  if m == 0 then return n end
  if m > n then return 0 - 1 end
  return last_index_of_loop(s, sub, m, i: n - m)
end

let last_index_of_loop = fn (s: string, sub: string, m: i64, i: i64) -> i64 do
  if i < 0 then return 0 - 1 end
  let window = str.substring(s, start: i, len: m)
  if window == sub then return i end
  return last_index_of_loop(s, sub, m, i: i - 1)
end

/** Forward scan for the next `target` byte at or after `start`. Returns
 *  -1 if absent.
 */
let index_of_byte_from = fn (s: string, start: i64, target: char) -> i64 do
  let n = str.length(s)
  return index_of_byte_loop(s, n, i: start, target)
end

let index_of_byte_loop = fn (s: string, n: i64, i: i64, target: char) -> i64 do
  if i >= n then return 0 - 1 end
  if str.char_at(s, idx: i) == target then return i end
  return index_of_byte_loop(s, n, i: i + 1, target)
end

/** Extract the E-code from an already-formatted error message. The code
 *  lives inside the last `[Exxxx]` bracket pair appended by
 *  `with_code`; if the arm produced no code (file-context wrappers,
 *  RuntimeError pass-through, catch-all), return empty string.
 */
let extract_code = fn (msg: string) -> string do
  let last_idx = last_index_of_in(s: msg, sub: "[E")
  if last_idx < 0 then return "" end
  let close_idx = index_of_byte_from(s: msg, start: last_idx, target: ']')
  if close_idx < 0 then return "" end
  return str.substring(s: msg, start: last_idx + 1, len: close_idx - last_idx - 1)
end

/** Strip the trailing `[Exxxx]` tag (and any surrounding whitespace) so
 *  the JSON `message` field carries the human prose only. The ICE suffix
 *  is also dropped — it is recoverable from the code (E00xx).
 */
let strip_code_tag = fn (msg: string) -> string do
  let last_idx = last_index_of_in(s: msg, sub: " [E")
  if last_idx < 0 then return msg end
  return str.substring(s: msg, start: 0, len: last_idx)
end

/** Pull the Span out of an exception, if it carries one. Returns None
 *  for spanless variants (MissingMain, ICEs, file-context wrappers).
 */
let span_of_exn = fn (err: Exn) -> Option<Span> do
  match err do
    | UnexpectedToken(expected: _, got: _, span: sp) -> return Some(val: sp)
    | UnexpectedEof(expected: _, span: sp) -> return Some(val: sp)
    | TypeMismatch(func_name: _, detail: _, span: sp) -> return Some(val: sp)
    | LazyBindingUnused(name: _, span: sp) -> return Some(val: sp)
    | LazyBindingDoubleUse(name: _, span: sp) -> return Some(val: sp)
    | LinearUnused(name: _, span: sp) -> return Some(val: sp)
    | LinearReuse(name: _, span: sp) -> return Some(val: sp)
    | LinearMismatch(detail: _, span: sp) -> return Some(val: sp)
    | LinearLeakAcrossThrowableCall(callee: _, leaked: _, span: sp) -> return Some(val: sp)
    | DuplicateTopLevelBinding(name: _, span: sp) -> return Some(val: sp)
    | UnusedTypeParam(name: _, func_name: _, span: sp) -> return Some(val: sp)
    | KindClashTypeParam(name: _, func_name: _, span: sp) -> return Some(val: sp)
    | UnknownCapability(name: _, suggestions: _, span: sp) -> return Some(val: sp)
    | UnknownThrowVariant(name: _, suggestions: _, span: sp) -> return Some(val: sp)
    | UnknownConstructor(name: _, suggestions: _, span: sp) -> return Some(val: sp)
    | UnknownField(name: _, suggestions: _, span: sp) -> return Some(val: sp)
    | DuplicateParamLabel(name: _, span: sp) -> return Some(val: sp)
    | RefEscapes(context: _, span: sp) -> return Some(val: sp)
    | RefInnerLinear(param: _, span: sp) -> return Some(val: sp)
    | UnknownVariable(name: _, suggestions: _, span: sp) -> return Some(val: sp)
    | ReservedDeclarationName(kind: _, name: _, span: sp) -> return Some(val: sp)
    | DuplicateDeclaration(kind: _, name: _, span: sp) -> return Some(val: sp)
    | InvalidGroupMember(group_name: _, member: _, reason: _, span: sp) -> return Some(val: sp)
    | _ -> return None
  end
end

/** Build a `CompilerDiagnostic` from an `Exn` plus the source file path. The
 *  `severity` is hard-coded to "error" in V1 — every variant the
 *  compiler raises today is fatal. Warnings will land with a separate
 *  infra change.
 */
export let diagnostic_from_exn = fn (err: Exn, file: string) -> CompilerDiagnostic do
  let full = format_error(err)
  let code = extract_code(msg: full)
  let body = strip_code_tag(msg: full)
  let { line, column } = match span_of_exn(err) do
    | Some(val: sp) -> match sp do | Span(offset: _, line: l, col: c) -> { line: l, column: c } end
    | None -> { line: 0, column: 0 }
  end
  return CompilerDiagnostic(code: code, severity: "error", file: file, line: line, column: column, message: body)
end

/** JSON-string escape. Mirrors the subset stdlib's `json.serialize_string`
 *  handles, kept inline here to avoid a new dependency edge from
 *  `src/common/` to `std:json` (the JSON encoder is on the user side,
 *  not a compiler-internal helper). Escapes `"`, `\`, and ASCII control
 *  characters; other bytes pass through verbatim.
 */
let json_escape = fn (s: string) -> string do
  return json_escape_loop(s, i: 0, n: str.length(s), acc: "")
end

let json_escape_loop = fn (s: string, i: i64, n: i64, acc: string) -> string do
  if i >= n then return acc end
  let ch = str.char_at(s, idx: i)
  let esc = if ch == '"' then "\\\""
    else if ch == '\\' then "\\\\"
    else if ch == '\n' then "\\n"
    else if ch == '\r' then "\\r"
    else if ch == '\t' then "\\t"
    else str.from_char(ch)
  end
  return json_escape_loop(s, i: i + 1, n, acc: acc ++ esc)
end

/** Render a `CompilerDiagnostic` as a single-line JSON object string (NDJSON).
 *  Field order: code, severity, file, line, column, message — stable so
 *  downstream `jq` selectors don't break across compiler versions.
 */
export let format_diagnostic_json = fn (diag: CompilerDiagnostic) -> string do
  match diag do | CompilerDiagnostic(code: c, severity: sv, file: f, line: ln, column: col, message: msg) ->
    return "{\"code\":\"" ++ json_escape(s: c)
      ++ "\",\"severity\":\"" ++ json_escape(s: sv)
      ++ "\",\"file\":\"" ++ json_escape(s: f)
      ++ "\",\"line\":" ++ str.from_i64(val: ln)
      ++ ",\"column\":" ++ str.from_i64(val: col)
      ++ ",\"message\":\"" ++ json_escape(s: msg) ++ "\"}"
  end
end

/** Summary-trailer object emitted after the per-diag NDJSON lines under
 *  `--format=json`. Mirrors what `ParseErrorsCollected`'s text rendering
 *  would print ("parse failed: N errors [E1004]") but as a structured
 *  record so tools can `jq '.count'` to skip the human prose entirely.
 */
export let format_summary_json = fn (count: i64) -> string do
  return "{\"code\":\"E1004\",\"severity\":\"error\",\"message\":\"parse failed: "
    ++ str.from_i64(val: count) ++ " errors\",\"count\":" ++ str.from_i64(val: count) ++ "}"
end
