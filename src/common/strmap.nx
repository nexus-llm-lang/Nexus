/**
 * strmap: a tiny pure-Nexus hash map from string keys to arbitrary values.
 *
 * Backed by n_buckets fixed buckets, each a cons-list of (key, value) entries — no
 * FFI, so every operation stays inside the arena (the std:stringmap port
 * marshals keys across the canonical-ABI boundary into a never-freed callee
 * heap, which is the wrong trade for a compile-time symbol table; see
 *). Lookup is O(n_buckets + bucket-depth) instead of the O(N) list scan
 * it replaces; that is the win for the reachability call-graph index, where
 * the same names are looked up thousands of times per `collect_reachable`.
 *
 * The map is persistent (functional): `insert` returns a fresh map sharing
 * the untouched buckets. Keys are compared byte-wise via `==`.
 */
import * as str from "std:str"

let n_buckets = 8

type SmEnt<V> = SmEnt(k: string, v: V)

/** Public type StrMap. */
export type StrMap<V> = StrMap(buckets: [ [ SmEnt<V> ] ])

let hash_go = fn (s: string, i: i64, n: i64, acc: i64) -> i64 do
  if i >= n then return acc end
  return hash_go(s, i: i + 1, n, acc: (acc * 33 + str.char_code(s, idx: i)) % n_buckets)
end

/** Bucket index for `s`: a rolling djb2 reduced mod n_buckets each step (so it never
 *  overflows and never goes negative).
 */
let bucket_of = fn (s: string) -> i64 do
  return hash_go(s, i: 0, n: str.length(s), acc: 0)
end

let nil_buckets = fn <V>(n: i64) -> [ [ SmEnt<V> ] ] do
  if n <= 0 then return [] end
  return [] :: nil_buckets(n: n - 1)
end

/** An empty map. */
export let empty = fn <V>() -> StrMap<V> do
  return StrMap(buckets: nil_buckets(n: n_buckets))
end

let bucket_at = fn <V>(bs: [ [ SmEnt<V> ] ], k: i64) -> [ SmEnt<V> ] do
  match bs do
    | [] -> return []
    | b :: rest -> if k <= 0 then return b else return bucket_at(bs: rest, k: k - 1) end
  end
end

let set_bucket = fn <V>(bs: [ [ SmEnt<V> ] ], k: i64, nb: [ SmEnt<V> ]) -> [ [ SmEnt<V> ] ] do
  match bs do
    | [] -> return []
    | b :: rest -> if k <= 0 then return nb :: rest else return b :: set_bucket(bs: rest, k: k - 1, nb) end
  end
end

/** Insert or shadow `k -> v`. Earlier entries for `k` are left in the bucket
 *  but never observed, since lookup returns the most recent (head-most) one.
 */
export let insert = fn <V>(m: StrMap<V>, k: string, v: V) -> StrMap<V> do
  let StrMap(buckets: bs) = m
  let bi = bucket_of(s: k)
  return StrMap(buckets: set_bucket(bs, k: bi, nb: SmEnt(k, v) :: bucket_at(bs, k: bi)))
end

let scan_bucket = fn <V>(b: [ SmEnt<V> ], k: string) -> Option<V> do
  match b do
    | [] -> return None
    | SmEnt(k: bk, v: bv) :: rest -> if bk == k then return Some(val: bv) else return scan_bucket(b: rest, k) end
  end
end

/** Look up `k`, returning `Some(v)` for the most recently inserted binding. */
export let get = fn <V>(m: StrMap<V>, k: string) -> Option<V> do
  let StrMap(buckets: bs) = m
  return scan_bucket(b: bucket_at(bs, k: bucket_of(s: k)), k)
end

/** Whether `k` has a binding. */
export let contains = fn <V>(m: StrMap<V>, k: string) -> bool do
  match get(m, k) do
    | Some(_) -> return true
    | None -> return false
  end
end
