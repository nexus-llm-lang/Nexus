/**
 * driver: Self-hosting compiler CLI entry point.
 *
 * Reads a Nexus source file, processes imports with cycle detection,
 * and compiles through the full pipeline:
 *   Lex → Parse → HIR → MIR → LIR → WASM
 */

import * as lexer from "src/frontend/lexer.nx"
import { ParseDiagnostics }, * as parser from "src/frontend/parser.nx"
import * as arena from "std:runtime/arena"
import * as bb from "std:bytebuffer"
import { InvalidUsage, WriteFailed, ParseErrorsCollected, InTargetFile, format_summary_json }, * as err from "src/common/error.nx"
import { get_defs, dump_import_graph } from "src/ir/shared/imports.nx"
import { iterative_resolve } from "src/ir/hir/demand.nx"
import * as reach from "src/ir/hir/reachability.nx"
import * as canon_match from "src/ir/hir/canonicalize_match.nx"
import * as main_wrap from "src/ir/main_wrap.nx"
import { HirProgram } from "src/ir/hir/types.nx"
import { expand_groups_in_functions, expand_groups_in_handler_bindings } from "src/ir/hir/build/accum.nx"
import * as mir from "src/ir/mir/mir.nx"
import { SpecializeResult }, * as specialize_inject from "src/ir/mir/specialize_inject.nx"
import * as func_lower from "src/ir/lir/func_lower.nx"
import * as lir_opt from "src/ir/lir/opt.nx"
import { EffectClassCounts }, * as emap from "src/ir/shared/effect_map.nx"
import { RaiseSiteCounts }, * as effect_analysis from "src/backend/effect_analysis.nx"
import * as memo_plan from "src/backend/memo_plan.nx"
import * as codegen from "src/backend/codegen.nx"
import * as tc from "src/typecheck/check.nx"
import * as tcwf from "src/typecheck/tcwf.nx"
import * as linearity from "src/ir/shared/linearity.nx"
import * as tc_linearity from "src/typecheck/linearity.nx"
import * as repl_mod from "src/tools/repl.nx"
import * as mcp_mod from "src/mcp/main.nx"
import { ParsedExplainSubcommand }, * as explain_mod from "src/explain/main.nx"
import { ParsedContextSubcommand }, * as context_mod from "src/context/main.nx"
import { ManifestMode, KeepManifest, StripManifest } from "src/common/manifest.nx"
import * as lazy_host from "std:lazy_host"
import { Fs }, * as fs_mod from "std:fs"
import { Console }, * as stdio from "std:stdio"
import { Clock }, * as clock_mod from "std:clock"
import * as str from "std:str"
import { Proc }, * as proc from "std:proc"
import * as list from "std:list"
import { Option, Some, None } from "std:option"
import { run_test_subcommand, strip_test_subcommand, ParsedTestSubcommand } from "src/tools/test_runner.nx"
import { run_bench_subcommand, strip_bench_subcommand, ParsedBenchSubcommand } from "src/tools/bench.nx"
import { run_fmt_subcommand, strip_fmt_subcommand, ParsedFmtSubcommand } from "src/tools/fmt.nx"
import { strip_hir_subcommand, ParsedHirSubcommand, strip_lir_subcommand, ParsedLirSubcommand } from "src/tools/ir_dump.nx"
import { strip_ast_subcommand, ParsedAstSubcommand } from "src/tools/ast_dump.nx"
import { strip_types_subcommand, ParsedTypesSubcommand } from "src/tools/types_dump.nx"
import { strip_caps_subcommand, ParsedCapsSubcommand } from "src/tools/caps_dump.nx"
import { strip_grep_subcommand, ParsedGrepSubcommand, run_grep_subcommand } from "src/tools/grep.nx"
import { strip_lint_subcommand, ParsedLintSubcommand, run_lint_subcommand } from "src/tools/lint.nx"
import { strip_skill_subcommand, ParsedSkillSubcommand, run_skill_subcommand } from "src/tools/skill_emit.nx"
import { ParsedFixSubcommand, strip_fix_subcommand } from "src/tools/fix.nx"
import {
  SubcommandHit,
  detect_subcommand
} from "std:argparse"

import { ExplainCaps, ExplainYes, ExplainNone, ExplainWasmtime, ExplainFormat, FormatText, FormatJson,
         SandboxOpts, find_main_caps, exec_run_artifact, check_no_cap_stripped } from "src/cli/format.nx"
import { GlobalFlags, parse_global_args } from "src/cli/args.nx"
import { SandboxRefusal } from "src/common/error.nx"
import { print_parse_diags, print_build_result } from "src/cli/output.nx"
import { HirBuildResult, CapsWriteResult, OutputMode, BareBinary, PolyglotLauncher,
         build_hir, get_enum_defs, get_type_defs, extract_function_names,
         str_nth, resolve_output_path, write_emit,
         write_emit_p3_component, write_emit_p3_component_raw } from "src/pipeline.nx"
import { run_ast_dump_subcommand, run_hir_dump_subcommand, run_lir_dump_subcommand,
         run_types_dump_subcommand, run_caps_dump_subcommand } from "src/cli/dump_runners.nx"
import { run_fix_subcommand } from "src/cli/build.nx"
import { ParsedTypecheckSubcommand, strip_typecheck_subcommand,
         ParsedRunSubcommand, strip_run_subcommand } from "src/cli/subcommands.nx"
import { subcommand_specs, global_help_specs, global_help_flag_specs, cli_specs } from "src/cli/specs.nx"
import { compute_elision_pct, print_subcommand_help, try_dispatch_help, print_usage } from "src/cli/help.nx"


let main = fn (args: [string]) -> unit require { PermClock, PermConsole, PermFs, PermProc } do
  inject stdio.system_handler, fs_mod.system_handler, clock_mod.system_handler, proc.system_handler do
  try
    if try_dispatch_help(args) then proc.exit(status: 0) end
    match args do
      | _ :: tok :: _ ->
        if tok == "help" || tok == "--help" || tok == "-h" then
          print_usage()
          proc.exit(status: 0)
        end
      | _ -> ()
    end
    if list.length(xs: args) < 2 then
      print_usage()
      proc.exit(status: 0)
    end
    match detect_subcommand(args, kw: "repl") do | SubcommandHit(present: p_repl, _) ->
      if p_repl then
        repl_mod.run(max_iters: -1)
        return ()
      end
    end
    match detect_subcommand(args, kw: "mcp") do | SubcommandHit(present: p_mcp, _) ->
      if p_mcp then
        mcp_mod.run_mcp_server(max_iters: -1)
        return ()
      end
    end
    match explain_mod.strip_explain_subcommand(xs: args) do | ParsedExplainSubcommand(remaining: args_after_explain_sub, is_explain) ->
      if is_explain then
        let explain_args = match args_after_explain_sub do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = explain_mod.run_explain_subcommand(args: explain_args)
        proc.exit(status: exit_code)
      end
    end
    match context_mod.strip_context_subcommand(xs: args) do | ParsedContextSubcommand(remaining: args_after_context_sub, is_context) ->
      if is_context then
        let context_args = match args_after_context_sub do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = context_mod.run_context_subcommand(args: context_args)
        proc.exit(status: exit_code)
      end
    end
    let gf = parse_global_args(args)
    let GlobalFlags(positionals, remaining: args_after_run, verbose, output: opt_output, diag_format, explain, explain_format: format, coverage: coverage_enabled, output_mode, manifest_mode, dump_imports: dump_imports_flag, p3: p3_enabled, p3_component: p3_component_enabled, sandbox, record: _, replay: _) = gf
    let polyglot_mode = if let PolyglotLauncher = output_mode then true else false end
    let remain_manifest = if let KeepManifest = manifest_mode then true else false end
    match strip_test_subcommand(xs: positionals) do | ParsedTestSubcommand(remaining: args_after_test, is_test) ->
      if is_test then
        let test_args = match args_after_test do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_test_subcommand(args: test_args)
        proc.exit(status: exit_code)
      end
    end
    match strip_bench_subcommand(xs: positionals) do | ParsedBenchSubcommand(remaining: args_after_bench, is_bench) ->
      if is_bench then
        let bench_args = match args_after_bench do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_bench_subcommand(args: bench_args)
        proc.exit(status: exit_code)
      end
    end
    match strip_fmt_subcommand(xs: positionals) do | ParsedFmtSubcommand(remaining: args_after_fmt, is_fmt) ->
      if is_fmt then
        let fmt_args = match args_after_fmt do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_fmt_subcommand(args: fmt_args)
        proc.exit(status: exit_code)
      end
    end
    match strip_grep_subcommand(xs: positionals) do | ParsedGrepSubcommand(remaining: args_after_grep, is_grep) ->
      if is_grep then
        let grep_args = match args_after_grep do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_grep_subcommand(args: grep_args)
        proc.exit(status: exit_code)
      end
    end
    match strip_lint_subcommand(xs: positionals) do | ParsedLintSubcommand(remaining: args_after_lint, is_lint) ->
      if is_lint then
        let lint_args = match args_after_lint do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_lint_subcommand(args: lint_args)
        proc.exit(status: exit_code)
      end
    end
    match strip_fix_subcommand(xs: positionals) do | ParsedFixSubcommand(remaining: args_after_fix, is_fix) ->
      if is_fix then
        let fix_args = match args_after_fix do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_fix_subcommand(args: fix_args)
        proc.exit(status: exit_code)
      end
    end
    match strip_skill_subcommand(xs: positionals) do | ParsedSkillSubcommand(remaining: args_after_skill, is_skill) ->
      if is_skill then
        let skill_args = match args_after_skill do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_skill_subcommand(args: skill_args, global_specs: global_help_specs(), sub_specs: subcommand_specs())
        proc.exit(status: exit_code)
      end
    end
    match strip_ast_subcommand(xs: positionals) do | ParsedAstSubcommand(remaining: args_after_ast, is_ast) ->
      if is_ast then
        let ast_args = match args_after_ast do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_ast_dump_subcommand(args: ast_args, format: diag_format, verbose)
        proc.exit(status: exit_code)
      end
    end
    match strip_hir_subcommand(xs: positionals) do | ParsedHirSubcommand(remaining: args_after_hir, is_hir) ->
      if is_hir then
        let hir_args = match args_after_hir do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_hir_dump_subcommand(args: hir_args, format: diag_format, verbose)
        proc.exit(status: exit_code)
      end
    end
    match strip_lir_subcommand(xs: positionals) do | ParsedLirSubcommand(remaining: args_after_lir, is_lir) ->
      if is_lir then
        let lir_args = match args_after_lir do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_lir_dump_subcommand(args: lir_args, format: diag_format, verbose)
        proc.exit(status: exit_code)
      end
    end
    match strip_types_subcommand(xs: positionals) do | ParsedTypesSubcommand(remaining: args_after_types, is_types) ->
      if is_types then
        let types_args = match args_after_types do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_types_dump_subcommand(args: types_args, format: diag_format, verbose)
        proc.exit(status: exit_code)
      end
    end
    match strip_caps_subcommand(xs: positionals) do | ParsedCapsSubcommand(remaining: args_after_caps, is_caps) ->
      if is_caps then
        let caps_args = match args_after_caps do
          | [] -> []
          | _ :: rest -> rest
        end
        let exit_code = run_caps_dump_subcommand(args: caps_args, format: diag_format, verbose)
        proc.exit(status: exit_code)
      end
    end
    let tc_hit = detect_subcommand(args: positionals, kw: "typecheck")
    let SubcommandHit(present: typecheck_only, remaining: positionals_after_tc) = tc_hit
    let run_hit = detect_subcommand(args: positionals_after_tc, kw: "run")
    let SubcommandHit(present: run_mode, remaining: positionals_after_run) = run_hit
    let run_args = args_after_run
    if run_mode && typecheck_only then
      throw InvalidUsage(detail: "`run` is incompatible with `typecheck`")
    end
    if remain_manifest && !polyglot_mode then
      throw InvalidUsage(detail: "--remain-manifest requires --polyglot")
    end
    if polyglot_mode && typecheck_only then
      throw InvalidUsage(detail: "--polyglot is incompatible with `typecheck`")
    end
    if polyglot_mode && run_mode then
      throw InvalidUsage(detail: "--polyglot is incompatible with `run`")
    end
    let clean_args = if typecheck_only || run_mode || dump_imports_flag then positionals_after_run
      else
        let bld_hit = detect_subcommand(args: positionals_after_run, kw: "build")
        match bld_hit do | SubcommandHit(present: has_build, remaining: positionals_after_build) ->
          if !has_build then
            throw InvalidUsage(detail: "missing subcommand: did you mean 'build'?")
          end
          positionals_after_build
        end
      end
    let run_output_path = "./.nexus-run.wasm"
    let argc = list.length(xs: clean_args)
    if dump_imports_flag then
      if argc < 2 then
        throw InvalidUsage(detail: "usage: nexus --dump-imports <input.nx>")
      end
      dump_import_graph(input_path: str_nth(xs: clean_args, n: 1))
      return ()
    end
    if argc < 2 then
      print_usage()
      throw InvalidUsage(detail: "missing input file argument")
    end

    let input_path = str_nth(xs: clean_args, n: 1)
    let output_path = if run_mode then run_output_path else resolve_output_path(opt_output, xs: clean_args, argc) end

    if verbose then
      if typecheck_only then
        Console.eprintln(val: "nexus: typechecking " ++ input_path)
      else
        Console.eprintln(val: "nexus: compiling " ++ input_path ++ " -> " ++ output_path)
      end
    end

    try
    let t0 = Clock.now()
    let src = Fs.read_to_string(path: input_path)
    let t1 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] read source (" ++ str.from_i64(val: t1 - t0) ++ "ms)") end

    let pipeline_mark = arena.heap_mark()

    let tokens = lexer.tokenize(src)
    let t2 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] lex (" ++ str.from_i64(val: t2 - t1) ++ "ms)") end

    let ParseDiagnostics(prog: prog, diags: parse_diags) = parser.parse_collect(tokens, file: input_path)
    print_parse_diags(diags: parse_diags, format: diag_format)
    let n_parse_diags = list.length(xs: parse_diags)
    if n_parse_diags > 0 then
      match diag_format do
        | FormatJson -> Console.eprintln(val: format_summary_json(count: n_parse_diags))
        | FormatText -> ()
      end
      throw ParseErrorsCollected(count: n_parse_diags)
    end
    let t3 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] parse (" ++ str.from_i64(val: t3 - t2) ++ "ms)") end

    let hir_result = build_hir(prog, source_file: input_path, verbose)
    let HirBuildResult(program: hir_raw, import_cache: _) = hir_result
    let t4 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] HIR (" ++ str.from_i64(val: t4 - t3) ++ "ms)") end

    tcwf.check_program_wf_rows(prog: hir_raw)

    let hir_resolved = match hir_raw do
      | HirProgram(caps: hp, functions: hf, externals: he, handler_bindings: hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds, visible_enum_names: hven) ->
        let resolved = iterative_resolve(funcs: hf, hb, max_rounds: 100)
        let expanded_fs = expand_groups_in_functions(funcs: resolved, groups: heg)
        let expanded_hb = expand_groups_in_handler_bindings(bindings: hb, groups: heg)
        let trimmed_reach = reach.collect_reachable_no_thread_start(functions: expanded_fs, handler_bindings: expanded_hb)
        let final_fs = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then expanded_fs
          else reach.filter_reachable_functions(functions: expanded_fs, reachable: trimmed_reach)
        end
        let final_reach = if reach.any_canonical_lazy_spawn(names: trimmed_reach) then
            reach.collect_reachable(functions: final_fs, handler_bindings: expanded_hb)
          else trimmed_reach
        end
        let filtered_exts = reach.filter_reachable_externals(externals: he, reachable: final_reach)
        HirProgram(caps: hp, functions: final_fs, externals: filtered_exts, handler_bindings: expanded_hb, enum_defs: hed, exception_groups: heg, value_binding_names: hvbns, type_defs: htds, visible_enum_names: hven)
    end
    let t4b = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] resolve (" ++ str.from_i64(val: t4b - t4) ++ "ms)") end

    let hir_canon = canon_match.canonicalize_program(prog: hir_resolved)
    let t4bc = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] canonicalize-match (" ++ str.from_i64(val: t4bc - t4b) ++ "ms)") end

    let hir = main_wrap.wrap_main_if_needed(prog: hir_canon)

    linearity.check_program(prog: hir)
    let t4c = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] linearity (" ++ str.from_i64(val: t4c - t4b) ++ "ms)") end

    let enum_defs = get_enum_defs(hir)
    let type_defs = get_type_defs(hir)
    let local_names = main_wrap.user_main_name() :: extract_function_names(defs: get_defs(prog), source: input_path)
    let hir_checked = tc.check_program(hir, local_names, require_main: !typecheck_only)
    let t5 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] typecheck (" ++ str.from_i64(val: t5 - t4c) ++ "ms)") end

    tc_linearity.check_program(prog: hir_checked)
    let t5b = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] tc-linearity (" ++ str.from_i64(val: t5b - t5) ++ "ms)") end

    if typecheck_only then
      if verbose then
        Console.eprintln(val: "nexus: typecheck-only " ++ input_path ++ " (total " ++ str.from_i64(val: t5b - t0) ++ "ms)")
      end
      arena.heap_reset(mark: pipeline_mark)
      return ()
    end

    let mir = mir.lower_hir_to_mir(hir: hir_checked)
    let t6 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] MIR (" ++ str.from_i64(val: t6 - t5) ++ "ms)") end

    let SpecializeResult(specialized: spec_count, total_calls: total_count) = specialize_inject.analyze_specialization(mir)
    let t6b = Clock.now()
    if verbose then
      Console.eprintln(val: "[nexus] inject-specialize ("
        ++ str.from_i64(val: t6b - t6) ++ "ms, "
        ++ str.from_i64(val: spec_count) ++ "/"
        ++ str.from_i64(val: total_count) ++ " handler calls specialized)")
    end

    let lir = func_lower.lower_mir_to_lir(mir: mir, enum_defs: enum_defs, type_defs: type_defs)
    let t7 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] LIR (" ++ str.from_i64(val: t7 - t6) ++ "ms)") end

    let %effect_map = effect_analysis.analyze_effects(program: lir)
    let t7b = Clock.now()
    if verbose then
      Console.eprintln(val: "[nexus] effect-analysis ("
        ++ str.from_i64(val: t7b - t7) ++ "ms, "
        ++ str.from_i64(val: emap.effect_map_size(em: &effect_map)) ++ " functions)")
      let EffectClassCounts(pure, can_throw, impure_no_throw, total) = emap.classify_effect_map(em: &effect_map)
      Console.eprintln(val: "[nexus] effect-summary: "
        ++ str.from_i64(val: pure) ++ " pure, "
        ++ str.from_i64(val: can_throw) ++ " throw, "
        ++ str.from_i64(val: impure_no_throw) ++ " impure ("
        ++ str.from_i64(val: total) ++ " total)")
    end

    let lir_opt = lir_opt.optimize_lir_with_effects(program: lir, effects: &effect_map)
    let t8 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] optimize (" ++ str.from_i64(val: t8 - t7b) ++ "ms)") end

    if verbose then
      let RaiseSiteCounts(emitted: bt_emit, elided: bt_skip, total: bt_total) =
        effect_analysis.count_raise_sites(program: lir_opt, em: &effect_map)
      let pct = compute_elision_pct(skip: bt_skip, total: bt_total)
      Console.eprintln(val: "[nexus] backtrace: "
        ++ str.from_i64(val: bt_emit) ++ " capture-call sites emitted, "
        ++ str.from_i64(val: bt_skip) ++ " skipped ("
        ++ str.from_i64(val: pct) ++ "% elision)")
    end

    let memo = memo_plan.plan_memoization(program: lir_opt, em: &effect_map)
    let t8c = Clock.now()
    if verbose then
      Console.eprintln(val: "[nexus] memo-plan ("
        ++ str.from_i64(val: t8c - t8) ++ "ms, "
        ++ str.from_i64(val: memo_plan.memo_plan_size(plan: memo)) ++ " eligible)")
    end

    let str_base = 32
    let coverage_flag = (if coverage_enabled then 1 else 0 end) | (if p3_enabled then 2 else 0 end) | (if p3_component_enabled then 4 else 0 end)
    let %wasm_buf = codegen.compile_lir_to_wasm_with_coverage(program: lir_opt, string_data_base: str_base,
                                                  effect_map: &effect_map,
                                                  coverage_flag)
    emap.free_effect_map(em: %effect_map)
    let t9 = Clock.now()
    if verbose then Console.eprintln(val: "[nexus] codegen (" ++ str.from_i64(val: t9 - t8c) ++ "ms)") end

    let CapsWriteResult(caps: caps, ok: ok) = if p3_component_enabled then
        // Streaming component-model write: capture the raw wasm ptr,
        // free the buffer, reset the arena to reclaim compilation memory,
        // then stream sections to fd using only small intermediate buffers.
        let caps_now = find_main_caps(defs: get_defs(prog))
        let cw_ptr = bb.raw_data_ptr(buf: &wasm_buf)
        let cw_len = bb.length(buf: &wasm_buf)
        bb.free(buf: %wasm_buf)
        arena.heap_reset(mark: pipeline_mark)
        let ok_now = write_emit_p3_component_raw(core_ptr: cw_ptr, core_len: cw_len, output_path)
        CapsWriteResult(caps: caps_now, ok: ok_now)
      else if polyglot_mode then
        let caps_now = find_main_caps(defs: get_defs(prog))
        let ok_now = write_emit(%wasm_buf, output_path, caps: caps_now, output: PolyglotLauncher, manifest: manifest_mode, verbose)
        CapsWriteResult(caps: caps_now, ok: ok_now)
      else
        let @caps_thunk = find_main_caps(defs: get_defs(prog))
        let caps_task = lazy_host.host_spawn(a: caps_thunk)
        let ok_par = write_emit(%wasm_buf, output_path, caps: [], output: BareBinary, manifest: manifest_mode, verbose)
        let caps_par = lazy_host.host_join(handle: caps_task)
        CapsWriteResult(caps: caps_par, ok: ok_par)
      end
    let t10 = Clock.now()

    if ok then
      if verbose then
        Console.eprintln(val: "[nexus] write (" ++ str.from_i64(val: t10 - t9) ++ "ms)")
        Console.eprintln(val: "nexus: wrote " ++ output_path ++ " (total " ++ str.from_i64(val: t10 - t0) ++ "ms)")
      end
      if !run_mode then
        print_build_result(output_name: output_path, caps, explain, format, output_is_polyglot: polyglot_mode)
      end
    else
      throw WriteFailed(path: output_path)
    end

    arena.heap_reset(mark: pipeline_mark)

    if run_mode then
      check_no_cap_stripped(caps, sb: sandbox)
      let exit_code = exec_run_artifact(wasm_path: output_path, source: input_path, caps, user_args: run_args, verbose, sandbox)
      proc.exit(status: exit_code)
    end
    catch inner ->
      match inner do
        | SandboxRefusal(capability: _, flag: _) -> throw inner
        | _ -> throw InTargetFile(path: input_path, detail: err.format_error(err: inner))
      end
    end
  catch
    | InvalidUsage(detail: d) ->
      Console.eprintln(val: err.format_error(err: InvalidUsage(detail: d)))
      proc.exit(status: 2)
    | SandboxRefusal(capability: c, flag: f) ->
      Console.eprintln(val: err.format_error(err: SandboxRefusal(capability: c, flag: f)))
      proc.exit(status: 3)
    | e ->
      Console.eprintln(val: err.format_error(err: e))
      proc.exit(status: 1)
  end
  end
end
