/**
 * pipeline: Shared HIR-build utilities.
 *
 * Covers: build_hir (parse → import-resolution → HIR), helper types
 * HirBuildResult / CapsWriteResult, emit helpers (write_and_free /
 * write_emit), and small utilities (str_nth, resolve_output_path).
 */

import { Program } from "src/syntax/ast.nx"
import { HirError } from "src/diagnostics/error.nx"
import * as resolve from "src/ir/shared/resolve.nx"
import {
  CacheEntry,
  ImportResult,
  get_defs,
  process_imports,
  scan_collisions_with_cache,
  CollisionScan,
  CollisionInfo,
  append_entries
} from "src/ir/shared/imports.nx"
import { RenameEntry } from "src/ir/shared/symtab.nx"
import { HirProgram } from "src/ir/hir/types.nx"
import { empty_accum, accum_to_program } from "src/ir/hir/build/accum.nx"
import { process_defs } from "src/ir/hir/build/defs.nx"
import * as bb from "std:bytebuffer"
import * as task from "std:concurrency/task"
import { Fs } from "std:fs"
import { Console } from "std:stdio"
import { IndexOutOfBounds } from "std:list"
import { Option, Some, None } from "std:option"
import { fd_open_write_path, fd_close_n } from "std:runtime/sysio"
import { write_p3_component_to_fd, write_p3_component_raw_to_fd,
         build_p2_component } from "src/backend/wasm/section/component_model.nx"

/** `col_defaults` carries the colliding-constructor DEFAULT rename entries
 *  (`bare -> first-defining-enum canonical`) that this build applied as the
 *  lowest-priority fallback. It is the ONLY root/closure-dependent input to an
 *  imported module's body type-check, so the single-run typecheck cache keys its
 *  marker namespace on a digest of these entries: two roots may share a cached
 *  imported-body result only when their default rename maps match. Empty for the
 *  overwhelmingly common collision-free build (maximal cross-root reuse). */
export type HirBuildResult = HirBuildResult(
  program: HirProgram,
  import_cache: [ CacheEntry ],
  col_defaults: [ RenameEntry ]
)

// Bundled result of the capability extraction + wasm write phase. Cap
// extraction and the wasm write run in parallel via `std:task`; both
// funnel through this record so the surrounding driver code reads
// `caps` / `ok` uniformly.
export type CapsWriteResult = CapsWriteResult(caps: [ string ], ok: bool)

// ─── Parallel-job capability ──────────────────────────────────────────────────
//
// `Job` surfaces "this code forks a parallel worker" in the effect row. The
// build driver's fork/join (cap-extraction running concurrently with the wasm
// write) runs under `inject job_worker do ... end`, and the helper that issues
// the submit/await — `build_caps_and_write` — carries `require { Job }`, so the
// parallelism is visible in its type rather than buried in a bare
// `task.host_spawn`/`task.host_join` pair.
//
// The cap is monomorphic over `[string]` (the cap-extraction result type): the
// surface language has no generic capabilities (`cap Job<T>` is a parse error),
// and this build driver only ever forks one `@[string]` task. The `%Task<[string]>`
// handle threads through `submit`/`await` linearly — the linearity checker still
// rejects a submit without a matching await.
//
// The handler implements `submit`/`await` directly over `task.host_spawn` /
// `task.host_join`, so the underlying execution is unchanged: real OS-thread
// (WASI threads) parallelism, NOT the cooperative single-threaded scheduler.
// No `with @k` — a fork/join is not a suspension point, so a plain handler is
// the honest shape.
export cap Job do
  fn submit(work: @[ string ]) -> %task.Task<[ string ]>
  fn await(h: %task.Task<[ string ]>) -> [ string ]
end

export let job_worker = handler Job do
  fn submit(work: @[ string ]) -> %task.Task<[ string ]> do
    return task.host_spawn(a: work)
  end
  fn await(h: %task.Task<[ string ]>) -> [ string ] do
    return task.host_join(handle: h)
  end
end

// Fork the cap-extraction thunk onto a worker thread, run the wasm write on
// this thread in parallel, then join. `require { Job }` makes the parallel
// dependency part of this fn's type; discharge it with `inject job_worker`.
export let build_caps_and_write = fn (
  caps_thunk: @[ string ],
  wasm_buf: %ByteBuffer,
  output_path: string
) -> CapsWriteResult require { Job } do
  let caps_task = Job.submit(work: caps_thunk)
  let ok_par = write_emit(%wasm_buf, output_path)
  let caps_par = Job.await(h: caps_task)
  return CapsWriteResult(caps: caps_par, ok: ok_par)
end

export let build_hir = fn (
  prog: Program,
  source_file: string,
  verbose: bool
) -> HirBuildResult require { Console, Fs } throws { HirError } do
  let defs = get_defs(prog)
  let imports = resolve.extract_imports(defs)
  // scan the whole program for constructor names declared by two+
  // distinct enums; only those are routed through the import-binding rename map
  // (everything else stays bare, preserving legacy behaviour). The scan builds a
  // parse-only cache (one parse per file) which we SEED into process_imports so
  // the main pass reuses it instead of re-parsing — keeping peak memory at one
  // set of ASTs (the old separate pre-scan re-parse pushed self-compile past the
  // 4GB wasm linear-memory ceiling).
  let CollisionScan(
    info: colliding,
    cache: scan_cache
  ) = scan_collisions_with_cache(entry_defs: defs, entry_source: source_file)
  let CollisionInfo(names: col_names, default_entries: col_defaults) = colliding
  let result = process_imports(
    imports,
    accum: empty_accum(),
    import_stack: [],
    visited: [],
    cache: scan_cache,
    caller_entries: [],
    colliding,
    depth: 1,
    verbose
  )
  let ImportResult(accum, visited: _, cache: import_cache, caller_entries) = result
  let self_entries = resolve.build_entry_self_entries(
    defs,
    source: source_file,
    colliding: col_names,
    acc: []
  )
    // self/import bindings win; default fallback appended last (lowest priority).
    let entries = append_entries(
      xs: append_entries(xs: self_entries, ys: caller_entries),
      ys: col_defaults
    )
    let accum2 = process_defs(
      defs: defs,
      entries: entries,
      accum: accum,
      source_file: source_file,
      is_defining: 1
    )
    return HirBuildResult(program: accum_to_program(accum: accum2), import_cache, col_defaults)
end

// Intentional narrow row: only IndexOutOfBounds can escape from this
// leaf helper. The caller (resolve_output_path) does not need to handle
// any broader fault set — keeping the row tight prevents accidental
// widening at pipeline call-sites.
export let str_nth = fn (xs: [ string ], n: i64) -> string throws { IndexOutOfBounds } do
  match xs do
    | [] -> throw IndexOutOfBounds(op: "str_nth", index: n)
    | v :: rest ->
      if n == 0 then return v end
      return str_nth(xs: rest, n: n - 1)
  end
end

/** Resolve the output path: prefer `-o`/`--output` value, otherwise fall back to
 *  the positional `[output]` arg or the default `main.wasm`.
 */
// Intentional narrow row: positional-arg access is the only fault that
// can occur here. IndexOutOfBounds surfaces when argc >= 3 but xs is
// shorter than expected — a precondition violation, not a general I/O
// fault. Keeping this row single-exception makes callers precise.
export let resolve_output_path = fn (
  opt_output: Option<string>,
  xs: [ string ],
  argc: i64
) -> string throws { IndexOutOfBounds } do
  match opt_output do
    | Some(val: o) -> return o
    | None ->
      if argc >= 3 then return str_nth(xs, n: 2) end
      return "out.wasm"
  end
end

let write_and_free = fn (buf: %ByteBuffer, path: string) -> bool do
  let ok = bb.write_file(&buf, path)
  bb.free(%buf)
  return ok
end

/** Emit the raw merged wasm. Consumes `wasm_buf` and frees it; the boolean
 *  return matches `write_and_free`.
 */
export let write_emit = fn (wasm_buf: %ByteBuffer, output_path: string) -> bool do
  return write_and_free(buf: %wasm_buf, path: output_path)
end

/** Write a component-model wrapper around the given core wasm ByteBuffer,
 *  streaming sections directly to a file to avoid OOM on the nexus.wasm arena.
 *  Frees `core_wasm`.
 */
export let write_emit_p3_component = fn (core_wasm: %ByteBuffer, output_path: string) -> bool do
  let fd = fd_open_write_path(path: output_path)
  if fd < 0 then
    bb.free(buf: %core_wasm)
    return false
  end
  write_p3_component_to_fd(core_wasm: %core_wasm, fd)
  fd_close_n(fd)
  return true
end

/** Write a WASI preview2 component wrapping the given core wasm ByteBuffer.
 *  The core wasm must export "wasi:cli/run@0.2.6#run" (i32 result) and "memory".
 *  has_server: when true, adds wasi:sockets TCP imports and p2sock_bridge (Net.listen/accept/respond).
 *  Frees `core_wasm`.
 */
export let write_emit_p2_component = fn (
  core_wasm: %ByteBuffer,
  has_fs: bool,
  has_net: bool,
  has_server: bool,
  output_path: string
) -> bool do
  let %component = build_p2_component(core_wasm: %core_wasm,
                                       wasi_iface: "wasi:cli/run@0.2.0",
                                       run_func_export: "wasi:cli/run@0.2.6#run",
                                       has_fs,
                                       has_net,
                                       has_server)
  return write_and_free(buf: %component, path: output_path)
end

/** Write a component-model wrapper using a raw memory pointer to core wasm bytes.
 *  Safe to call after `arena.heap_reset` as long as the pointer is still valid.
 */
export let write_emit_p3_component_raw = fn (
  core_ptr: i64,
  core_len: i64,
  output_path: string
) -> bool do
  let fd = fd_open_write_path(path: output_path)
  if fd < 0 then return false end
  write_p3_component_raw_to_fd(core_ptr, core_len, fd)
  fd_close_n(fd)
  return true
end
