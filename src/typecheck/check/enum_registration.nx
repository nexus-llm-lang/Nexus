/**
 * typecheck/check/enum_registration: enum constructor registration.
 *
 * Registers enum constructors (D-Export constructor visibility) into the
 * CheckState environment for enums whose names are visible in the importing
 * module. Split out of registration.nx (behaviour-preserving relocation).
 */

import * as list from "std:list"
import {
  TypeExpr,
  TyUserDefined,
  TyVar,
  TyArrow,
  TyRow,
  NamedType,
  EnumDef,
  VariantDef,
  VariantField
} from "src/types/type_expr.nx"
import { CheckState } from "src/typecheck/types.nx"
import * as tctypes from "src/typecheck/types.nx"
import { enum_name_visible } from "src/typecheck/check/occurs.nx"
import { NominalEnv, qualify_named_types } from "src/typecheck/check/nominal_id.nx"
import * as str from "std:str"

// ─── Register enum constructors ─────────────────────────────────────────────

// Only register constructors for enums whose names appear in `visible_names`.
// Non-visible enums are kept in `enum_defs` for codegen (VariantIndex field
// layout) but their constructors must not enter the type environment of the
// importing module.
export let register_enum_constructors = fn (
  state: CheckState,
  defs: [ EnumDef ],
  visible_names: [ string ],
  nominal: NominalEnv
) -> CheckState do
  match defs do
    | [] -> return state
    | EnumDef(
      name: ename,
      is_public: _,
      is_opaque: _,
      type_params: tps,
      variants: vs,
      layout_variants: _,
      module: emod
    ) :: rest ->
      let st1 = if enum_name_visible(name: ename, names: visible_names) then
        register_variants(
          state,
          enum_name: ename,
          type_params: tps,
          variants: vs,
          decl_module: emod,
          nominal
        )
      else
        state
      end
      return register_enum_constructors(state: st1, defs: rest, visible_names, nominal)
  end
end

export let is_local = fn (name: string, local_names: [ string ]) -> bool do
  match local_names do
    | [] -> return false
    | n :: rest ->
      if n == name then return true end
      return is_local(name, local_names: rest)
  end
end

let register_variants = fn (
  state: CheckState,
  enum_name: string,
  type_params: [ string ],
  variants: [ VariantDef ],
  decl_module: string,
  nominal: NominalEnv
) -> CheckState do
  match variants do
    | [] -> return state
    | VariantDef(name: vname, fields) :: rest ->
      /** Result type carries the enum's module-qualified nominal identity so a
       *  constructor application is assignable only where the SAME enum (same
       *  declaring module) is expected. Field types are qualified from the
       *  declaring module's view so an inner reference to another same-name
       *  enum resolves to the right declaration. */
      let enum_type = build_enum_type_from_params(name: enum_name, params: type_params, decl_module)
      let ctor_type = match fields do
        | [] -> enum_type
        | _ ->
          let param_types = qualify_named_types(
            nts: variant_fields_to_named_types(fields, idx: 0),
            ref_module: decl_module, env: nominal, vars: type_params
          )
          TyArrow(
            params: param_types, ret: enum_type,
            requires: TyRow(types: [], rest: None),
            throw_row: TyRow(types: [], rest: None)
          )
      end
      let st1 = tctypes.state_put_global(state, name: vname, scheme: tctypes.mono(typ: ctor_type))
      return register_variants(
        state: st1,
        enum_name,
        type_params,
        variants: rest,
        decl_module,
        nominal
      )
  end
end

let build_enum_type_from_params = fn (
  name: string,
  params: [ string ],
  decl_module: string
) -> TypeExpr do
  let qname = if str.length(s: decl_module) > 0 then decl_module ++ "#" ++ name else name end
  match params do
    | [] -> return TyUserDefined(name: qname, args: [])
    | _ -> return TyUserDefined(name: qname, args: params_to_vars(params))
  end
end

let params_to_vars = fn (params: [ string ]) -> [ TypeExpr ] do
  return params_to_vars_go(params, acc: [])
end

let params_to_vars_go = fn (params: [ string ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | p :: rest ->
      return params_to_vars_go(params: rest, acc: TyVar(name: p) :: acc)
  end
end

let variant_fields_to_named_types = fn (fields: [ VariantField ], idx: i64) -> [ NamedType ] do
  return variant_fields_to_named_types_go(fields, idx, acc: [])
end

let variant_fields_to_named_types_go = fn (
  fields: [ VariantField ],
  idx: i64,
  acc: [ NamedType ]
) -> [ NamedType ] do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | VariantField(name: mname, typ: t) :: rest ->
      let fname = match mname do
        | Some(val: n) -> n
        | None -> "_" ++ str.from_i64(val: idx)
      end
      return variant_fields_to_named_types_go(
        fields: rest,
        idx: idx + 1,
        acc: NamedType(name: fname, typ: t) :: acc
      )
  end
end
