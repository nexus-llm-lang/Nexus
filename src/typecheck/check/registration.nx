/**
 * typecheck/check/registration: Pass-1 signature registration.
 *
 * Registers externals, functions, and caps into the CheckState environment,
 * and performs the D-Let-Top alias fix-up. Handler-binding registration /
 * validation lives in check/handler_validation.nx, and enum-constructor
 * registration lives in check/enum_registration.nx.
 *
 * Validates at introduction sites:
 *   - Per-fn/external wfCap / wfThrow / wfRef
 *   - D-External / T-Lambda gravity rule (¬escapesRef)
 *   - kindOf binding-site quantifier enforcement
 *   - same-name top-level redeclaration rejection
 */

import * as list from "std:list"
import * as bb from "std:bytebuffer"
import * as str from "std:str"
import { Option, Some, None } from "std:option"
import {
  TypeExpr,
  TyArrow,
  TyRow,
  TyUserDefined,
  TyVar,
  TyI64,
  TyF64,
  TyBool,
  TyChar,
  TyString,
  NamedType,
  RecordDef
} from "src/types/type_expr.nx"
import {
  HirFunction,
  HirParam,
  HirExternal,
  HirCap,
  HirCapMethod,
  HirCallArg,
  ExceptionGroupEntry,
  EagerBody,
  HirStmt,
  HirStmtKind,
  HirExpr,
  HirExprKind,
  HirNamedExpr,
  HirMatchCase
} from "src/ir/hir/types.nx"
import { Literal, LitInt, LitFloat, LitBool, LitChar, LitString } from "src/types/vocab.nx"
import { Span } from "src/types/span.nx"
import { TypeError, DuplicateTopLevelBinding } from "src/typecheck/errors.nx"
import { CheckState, Scheme, SubstEntry } from "src/typecheck/types.nx"
import * as tctypes from "src/typecheck/types.nx"
import * as tcwf from "src/typecheck/tcwf.nx"
import {
  str_list_contains,
  enforce_kindof_quantifiers, named_type_typs,
  convert_ud_to_var, convert_named_types
} from "src/typecheck/check/occurs.nx"

// ─── Shared helpers ──────────────────────────────────────────────────────────

export let hir_params_to_named_types = fn (params: [ HirParam ]) -> [ NamedType ] do
  return hir_params_to_named_types_go(params, acc: [])
end

let hir_params_to_named_types_go = fn (params: [ HirParam ], acc: [ NamedType ]) -> [ NamedType ] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: l, name: _, sigil: _, typ: t) :: rest ->
      return hir_params_to_named_types_go(params: rest, acc: NamedType(name: l, typ: t) :: acc)
  end
end

// ─── Register externals ────────────────────────────────────────────────────

export let register_externals = fn (
  state: CheckState,
  exts: [ HirExternal ],
  tdefs: [ RecordDef ]
) -> CheckState throws { TypeError } do
  match exts do
    | [] -> return state
    | HirExternal(
      name: n,
      wasm_module: _,
      wasm_name: _,
      type_params: tps,
      params,
      ret_type: ret,
      throw_row: thr
    ) :: rest ->
      let param_types = hir_params_to_named_types(params)
      // kindOf binding-site enforcement (spec §Polymorphism Introduction / kindOf).
      // Externals carry no Span, so we attribute the diagnostic to the
      // externals header (Span(0,0,0)) — the func_name plus the type-param
      // name in the message is enough to locate the malformed declaration.
      // The σ pieces for an external arrow are exactly (params, ret, throws);
      // there is no `requires` slot (always `{}` for FFI declarations).
      let ext_parts = thr :: (ret :: named_type_typs(nts: param_types))
      enforce_kindof_quantifiers(
        tps,
        parts: ext_parts,
        func_name: n,
        span: Span(offset: 0, line: 0, col: 0)
      )
      // D-External gravity rule: ¬escapesRef(τ_r).
      // Spec: type-system-formal.md §"Gravity Rule" + §D-External.
      tcwf.enforce_no_escapes_ref(
        typ: ret,
        context: "return type of external '" ++ n ++ "'",
        span: Span(offset: 0, line: 0, col: 0),
        borrow_escapes: true
      )
      // D-External wfRef at parameter annotation sites
      // (spec §mutable-reference-well-formedness / wfRef).
      tcwf.enforce_wf_ref_params(params: param_types, span: Span(offset: 0, line: 0, col: 0), tdefs)
      // Convert TyUserDefined("T",[]) → TyVar("T") for declared type params,
      // then register as a polymorphic Scheme so each call site instantiates
      // T to a fresh metavar. Without this `external f: <T>(val: T) -> unit`
      // freezes T as a frozen non-int type and rejects int-literal callers.
      let arrow = TyArrow(
        params: convert_named_types(nts: param_types, vars: tps),
        ret: convert_ud_to_var(typ: ret, vars: tps),
        requires: TyRow(types: [], rest: None),
        throw_row: convert_ud_to_var(typ: thr, vars: tps)
      )
      let env = tctypes.env_insert(
        env: tctypes.state_env(state),
        name: n,
        scheme: Scheme(vars: tps, typ: arrow)
      )
      return register_externals(state: tctypes.state_with_env(state, env), exts: rest, tdefs)
  end
end

// ─── Register functions ─────────────────────────────────────────────────────

// track names registered so far to reject same-name redeclaration.
// Downstream lir_opt mis-resolves `return_call` for shadowed top-level lets
// and corrupts UNRELATED functions' return atoms; rejecting at typecheck
// eliminates the bug class entirely.
export let register_functions = fn (
  state: CheckState,
  funcs: [ HirFunction ],
  caps: [ HirCap ],
  exception_groups: [ ExceptionGroupEntry ],
  tdefs: [ RecordDef ]
) -> CheckState throws { TypeError } do
  return register_functions_go(state, funcs, seen: [], caps, exception_groups, tdefs)
end

let register_functions_go = fn (
  state: CheckState,
  funcs: [ HirFunction ],
  seen: [ string ],
  caps: [ HirCap ],
  exception_groups: [ ExceptionGroupEntry ],
  tdefs: [ RecordDef ]
) -> CheckState throws { TypeError } do
  match funcs do
    | [] -> return state
    | HirFunction(
      name: n,
      type_params: tps,
      params,
      ret_type: ret,
      throw_row: tw,
      body: fbody,
      span: sp,
      file: _,
      requires: req
    ) :: rest ->
      if str_list_contains(xs: seen, s: n) then
        throw DuplicateTopLevelBinding(name: n, span: sp)
      end
      // Introduction-site well-formedness checks (T-Lambda fn arrow):
      // wfCap on the require row and wfThrow on the throws row. Per spec
      // §1 (wfCap/wfThrow), these are checked here so a typo (`require { Logr }`
      // for `Logger`) is rejected at the source location rather than
      // surviving as an uninhabitable row entry until a use site looks
      // it up — issues (wfCap) and (wfThrow).
      tcwf.wf_cap(row: req, caps, span: sp)
      tcwf.wf_throw(
        row: tw,
        vidx_: tctypes.state_variant_index(state),
        groups: exception_groups,
        span: sp,
        type_params: tps
      )
      // T-Lambda / T-Let-PolyFn gravity rule: ¬escapesRef(τ_r).
      // Checked at the declaration site so a typo such as `fn () -> ref(i64)`
      // is rejected at the binding, not at a downstream return statement.
      // Spec: type-system-formal.md §"Gravity Rule" + §T-Lambda.
      tcwf.enforce_no_escapes_ref(typ: ret, context: "return type of '" ++ n ++ "'", span: sp, borrow_escapes: true)
      let param_types = hir_params_to_named_types(params)
      // wfRef at parameter annotation sites
      // (spec §mutable-reference-well-formedness / wfRef):
      // each parameter type ~σ is rejected if σ is structurally linear.
      tcwf.enforce_wf_ref_params(params: param_types, span: sp, tdefs)
      // kindOf binding-site enforcement
      // (spec §Polymorphism Introduction / kindOf). σ for a top-level fn is its
      // parameter types, return type, throws-row, and require row. All four
      // components are checked so that type parameters appearing in any slot
      // are accounted for.
      let parts = tw :: (ret :: (req :: named_type_typs(nts: param_types)))
      enforce_kindof_quantifiers(tps, parts, func_name: n, span: sp)
      // Generic-cap soundness (nexus-3ibql): pin each generic-cap entry of this
      // function's require row to the element type it COMMITS to in its body. A
      // bare `require { Box }` whose body calls `Box.wrap(x: n)` with `n: i64`
      // is using Box at i64 — its published contract must say `Box<i64>` so that
      // a caller under a `Box<string>` handler is rejected (the call-site
      // coverage unifies the entry's args). When the element type is itself one
      // of the function's type params (a generic helper `fn <T> ... Box.wrap(x:
      // x)`), the entry becomes `Box<T>`, staying polymorphic so each call
      // instantiates it to the handler in scope. convert_ud_to_var below maps
      // those param args to TyVars. Bodies whose generic-cap argument types
      // cannot be resolved syntactically (complex expressions) keep the bare
      // `Box` entry (element-agnostic, conservatively accepted), so this never
      // over-rejects existing programs.
      let body_stmts = match fbody do | EagerBody(stmts: s) -> s | _ -> [] end
      let req_pinned = refine_require_generic_caps(
        req, body: body_stmts, params, caps, fn_tps: tps)
      let arrow = TyArrow(
        params: convert_named_types(nts: param_types, vars: tps),
        ret: convert_ud_to_var(typ: ret, vars: tps),
        requires: convert_ud_to_var(typ: req_pinned, vars: tps),
        throw_row: convert_ud_to_var(typ: tw, vars: tps)
      )
      let env = tctypes.env_insert(
        env: tctypes.state_env(state),
        name: n,
        scheme: Scheme(vars: tps, typ: arrow)
      )
      return register_functions_go(
        state: tctypes.state_with_env(state, env),
        funcs: rest,
        seen: n :: seen,
        caps,
        exception_groups,
        tdefs
      )
  end
end

// ─── Register caps ─────────────────────────────────────────────────────────
//
// D-Cap introduction-site wfCap/wfThrow (spec §D-Cap):
// `∀j∈J. wfCap(α_j) ∧ wfThrow(β_j)` for each declared method signature.
// HirCapMethod now carries the full require/throw rows from the source
// FunctionSig, so we can enforce these premises here at registration time.
export let register_caps = fn (
  state: CheckState,
  caps: [ HirCap ],
  exception_groups: [ ExceptionGroupEntry ]
) -> CheckState throws { TypeError } do
  return register_caps_go(state, caps, all_caps: caps, exception_groups)
end

let register_caps_go = fn (
  state: CheckState,
  caps: [ HirCap ],
  all_caps: [ HirCap ],
  exception_groups: [ ExceptionGroupEntry ]
) -> CheckState throws { TypeError } do
  match caps do
    | [] -> return state
    | HirCap(name: cap_qname, type_params: tps, methods) :: rest ->
      // Pass the full caps list so that wf_cap can resolve user-declared caps
      // named in method require rows (e.g. `require { B }` where B is a cap).
      check_cap_method_rows(methods, state, exception_groups, caps: all_caps)
      // Generic caps (`cap Foo<T>`) register their call-site method schemes
      // POLYMORPHICALLY from the declaration, mirroring generic functions:
      // each `Foo.method(...)` call instantiates the quantified params fresh,
      // so one generic producer can be reused at several element types. The
      // handler-arm registration (register_handler_methods) is suppressed for
      // generic caps so this poly scheme is the one that resolves at call sites.
      // Monomorphic caps keep their existing handler-arm-only registration
      // (tps == [] → skip here, behaviour unchanged).
      let state1 = match tps do
        | [] -> state
        | _ -> register_cap_method_schemes(state, cap_qname, tps, methods)
      end
      return register_caps_go(state: state1, caps: rest, all_caps, exception_groups)
  end
end

// Register each method of a GENERIC cap as a polymorphic env scheme keyed on
// `<cap_qname>.<method>`, quantified over the cap's type parameters. Mirrors
// the generic-function registration (register_functions_go): user-defined names
// matching a type param are converted to TyVar and bound by Scheme.vars, so a
// call site instantiates fresh and unifies against the actual argument types.
let register_cap_method_schemes = fn (
  state: CheckState,
  cap_qname: string,
  tps: [ string ],
  methods: [ HirCapMethod ]
) -> CheckState do
  match methods do
    | [] -> return state
    | HirCapMethod(
      name: mname,
      requires: mreq,
      span: _,
      throw_row: mtw,
      typ_params: mparams,
      typ_ret: mret
    ) :: rest ->
      // T-CapCall env'd require row: {cap_name} ∪ α. The cap name is the BARE
      // identifier (T-Inject extends ρ_q with bare cap names), so strip the
      // qualifier before adding the row entry.
      let bare_cap = tcwf.base_name_of(qualified: cap_qname)
      // Generic-cap soundness (nexus-3ibql): carry the cap's type params as
      // args on the require-row entry (`Box<T>`), so a `Box.wrap(x:n)` call
      // instantiates the row to `Box<i64>`. convert_ud_to_var below turns the
      // param args into TyVars, and the call-site coverage (T-CapCall x ∈ ρ_q)
      // unifies them against the ambient generic-cap row — pinning the element
      // type a function commits to onto its require contract. Without the args,
      // a function laundering a generic-cap call through `require { Box }`
      // escapes the handler-instantiation check (the tzvf9 shadow only reaches
      // the inject body's DIRECT scope, not a called helper typed standalone).
      let method_requires = build_method_requires(bare_cap, alpha: mreq, tps)
      let param_nts = hir_params_to_named_types(params: mparams)
      let arrow = TyArrow(
        params: convert_named_types(nts: param_nts, vars: tps),
        ret: convert_ud_to_var(typ: mret, vars: tps),
        requires: convert_ud_to_var(typ: method_requires, vars: tps),
        throw_row: convert_ud_to_var(typ: mtw, vars: tps)
      )
      let method_qname = bb.concat(parts: [ cap_qname, ".", mname ])
      let env1 = tctypes.env_insert(
        env: tctypes.state_env(state),
        name: method_qname,
        scheme: Scheme(vars: tps, typ: arrow)
      )
      return register_cap_method_schemes(
        state: tctypes.state_with_env(state, env: env1),
        cap_qname, tps, methods: rest
      )
  end
end

// Build {bare_cap} ∪ α as a require row (α = method's declared require row).
// For a generic cap, the cap entry carries the cap's type params as args
// (`Box<T>`); `convert_ud_to_var(..., vars: tps)` at the caller then rewrites
// those args to TyVars. Monomorphic caps (tps == []) keep `Box` with no args.
let build_method_requires = fn (bare_cap: string, alpha: TypeExpr, tps: [ string ]) -> TypeExpr do
  let cap_entry = TyUserDefined(name: bare_cap, args: tps_as_ud_args(tps))
  match alpha do
    | TyRow(types: ts, rest: tail) ->
      if row_contains_cap(name: bare_cap, ts) then return alpha end
      return TyRow(types: cap_entry :: ts, rest: tail)
    | _ -> return TyRow(types: [ cap_entry ], rest: None)
  end
end

// Render a cap's type-param names as positional `TyUserDefined(name, args: [])`
// type args. convert_ud_to_var(..., vars: tps) later rewrites each to TyVar.
let tps_as_ud_args = fn (tps: [ string ]) -> [ TypeExpr ] do
  match tps do
    | [] -> return []
    | t :: rest -> return TyUserDefined(name: t, args: []) :: tps_as_ud_args(tps: rest)
  end
end

// ─── Generic-cap require-row instantiation pinning (nexus-3ibql) ─────────────
//
// A function declaring `require { Box }` for a GENERIC cap `Box<T>` commits, in
// its body, to a specific element type wherever it calls a `Box.method(...)`.
// `Box.wrap(x: n)` with `n: i64` uses Box at i64; the published require contract
// must therefore say `Box<i64>` so the call-site coverage (T-CapCall x ∈ ρ_q)
// can reject a caller running under a `Box<string>` handler — the laundering
// path the inject-body shadow (handler_validation.apply_injected_handler_instances)
// does NOT cover because a helper is type-checked standalone, decoupled from any
// inject. When the committed element type is itself one of the function's own
// type params (a generic helper `fn <T> ... Box.wrap(x: x)` with `x: T`), the
// entry becomes `Box<T>` and stays polymorphic, so each call instantiates it to
// the handler actually in scope. Element types that cannot be resolved from the
// body syntactically (cap-call arg is a complex expression) leave the entry
// element-agnostic (`Box`), conservatively accepted — never an over-rejection.

/** Refine each generic-cap entry of a function's require row by reading the
 *  element type the body commits to. `req` is the RAW declared row (cap type
 *  params still as `TyUserDefined name`); the caller applies convert_ud_to_var
 *  afterwards, so a derived `Box<T>` (T a fn type param) becomes `Box<TyVar T>`. */
let refine_require_generic_caps = fn (
  req: TypeExpr,
  body: [ HirStmt ],
  params: [ HirParam ],
  caps: [ HirCap ],
  fn_tps: [ string ]
) -> TypeExpr do
  match req do
    | TyRow(types: ts, rest: tail) ->
      let ts1 = refine_cap_entries(ts, body, params, caps)
      return TyRow(types: ts1, rest: tail)
    | _ -> return req
  end
end

let refine_cap_entries = fn (
  ts: [ TypeExpr ],
  body: [ HirStmt ],
  params: [ HirParam ],
  caps: [ HirCap ]
) -> [ TypeExpr ] do
  match ts do
    | [] -> return []
    | TyUserDefined(name: cname, args: []) :: rest ->
      let cap_tps = cap_generic_tps(caps, bare: tcwf.base_name_of(qualified: cname))
      let refined = match cap_tps do
        | [] -> TyUserDefined(name: cname, args: [])
        | _ ->
          match derive_cap_instantiation(
            bare: tcwf.base_name_of(qualified: cname), cap_tps, body, params, caps) do
            | Some(val: arg_types) -> TyUserDefined(name: cname, args: arg_types)
            | None -> TyUserDefined(name: cname, args: [])
          end
      end
      return refined :: refine_cap_entries(ts: rest, body, params, caps)
    | other :: rest -> return other :: refine_cap_entries(ts: rest, body, params, caps)
  end
end

/** type_params of a generic cap matched by BARE name (base_name_of). Empty for
 *  monomorphic caps or names not matching a declared cap. */
let cap_generic_tps = fn (caps: [ HirCap ], bare: string) -> [ string ] do
  match caps do
    | [] -> return []
    | HirCap(name: cn, type_params: tps, methods: _) :: rest ->
      if tcwf.base_name_of(qualified: cn) == bare then return tps end
      return cap_generic_tps(caps: rest, bare)
  end
end

/** Derive the cap's type-param instantiation (one TypeExpr per cap type param)
 *  from the first body call to one of this cap's methods whose argument types
 *  resolve, binding the cap type params against the call's argument types.
 *  Returns None when no body call pins all the cap's type params. */
let derive_cap_instantiation = fn (
  bare: string,
  cap_tps: [ string ],
  body: [ HirStmt ],
  params: [ HirParam ],
  caps: [ HirCap ]
) -> Option<[ TypeExpr ]> do
  let methods = cap_methods_of(caps, bare)
  // Collect ALL call sites with a SINGLE-accumulator walk (mirrors the
  // known-good shape of reachability.collect_calls_*), then filter for this
  // cap's methods afterwards — keeping the recursive walk minimal so the
  // self-hosting seed compiles it correctly.
  let all_calls = collect_all_calls_stmts(stmts: body, acc: [])
  let cap_calls = filter_cap_calls(all_calls, bare, methods, acc: [])
  return first_full_binding(cap_calls, cap_tps, methods, params)
end

/** Keep only call sites whose func resolves to a method of THIS cap, as
 *  (method-name, args) pairs. */
let filter_cap_calls = fn (
  all: [ AllCall ], bare: string, methods: [ HirCapMethod ], acc: [ CapCall ]
) -> [ CapCall ] do
  match all do
    | [] -> return list.reverse(xs: acc)
    | AllCall(func: f, args) :: rest ->
      match cap_method_of_call(f, bare, methods) do
        | Some(val: mname) -> return filter_cap_calls(all: rest, bare, methods, acc: CapCall(method: mname, args) :: acc)
        | None -> return filter_cap_calls(all: rest, bare, methods, acc)
      end
  end
end

/** Walk the call sites collected for this cap and return the first that binds
 *  every cap type param (so the entry is fully concrete / fully polymorphic). */
let first_full_binding = fn (
  calls: [ CapCall ],
  cap_tps: [ string ],
  methods: [ HirCapMethod ],
  params: [ HirParam ]
) -> Option<[ TypeExpr ]> do
  match calls do
    | [] -> return None
    | CapCall(method: m, args) :: rest ->
      match lookup_method(methods, name: m) do
        | None -> return first_full_binding(calls: rest, cap_tps, methods, params)
        | Some(val: meth) ->
          let bindings = bindings_from_call(meth, args, cap_tps, params)
          match all_tps_bound(cap_tps, bindings) do
            | Some(val: arg_types) -> return Some(val: arg_types)
            | None -> return first_full_binding(calls: rest, cap_tps, methods, params)
          end
      end
  end
end

/** Bind cap type params against a single call's argument types. The method's
 *  declared param types carry the cap type params as `TyUserDefined name`; we
 *  convert them to TyVar, then structurally match each against the resolved
 *  argument type (param ref → its declared type, literal → its primitive type).
 *  Unresolvable arguments contribute no binding. */
let bindings_from_call = fn (
  meth: HirCapMethod,
  args: [ HirCallArg ],
  cap_tps: [ string ],
  params: [ HirParam ]
) -> [ SubstEntry ] do
  let HirCapMethod(name: _, requires: _, span: _, throw_row: _, typ_params: mparams, typ_ret: _) = meth
  let mnts = convert_named_types(nts: hir_params_to_named_types(params: mparams), vars: cap_tps)
  return match_args_to_params(mnts, args, params, acc: [])
end

let match_args_to_params = fn (
  mnts: [ NamedType ],
  args: [ HirCallArg ],
  params: [ HirParam ],
  acc: [ SubstEntry ]
) -> [ SubstEntry ] do
  match mnts do
    | [] -> return acc
    | NamedType(name: plabel, typ: ptype) :: mrest ->
      match find_arg_by_label(args, label: plabel) do
        | None -> return match_args_to_params(mnts: mrest, args, params, acc)
        | Some(val: arg_expr) ->
          match resolve_arg_type(arg_expr, params) do
            | None -> return match_args_to_params(mnts: mrest, args, params, acc)
            | Some(val: at) ->
              let acc1 = match_type_pat(pat: ptype, concrete: at, acc)
              return match_args_to_params(mnts: mrest, args, params, acc: acc1)
          end
      end
  end
end

/** Structurally collect `TyVar name → concrete` bindings (cap type param → arg
 *  type). Mirrors handler_validation.collect_tp_bindings; kept local to avoid a
 *  cross-module export churn. */
let match_type_pat = fn (pat: TypeExpr, concrete: TypeExpr, acc: [ SubstEntry ]) -> [ SubstEntry ] do
  match pat do
    | TyVar(name: nm) -> return SubstEntry(var: nm, typ: concrete) :: acc
    | _ -> return acc
  end
end

let find_arg_by_label = fn (args: [ HirCallArg ], label: string) -> Option<HirExpr> do
  match args do
    | [] -> return None
    | HirCallArg(label: l, value: v) :: rest ->
      if l == label then return Some(val: v) end
      return find_arg_by_label(args: rest, label)
  end
end

/** Resolve a cap-call argument expression to a type usable for binding the cap
 *  element. Only the unambiguous cases: a reference to one of the function's
 *  params (→ its declared type) and a literal (→ its defaulted primitive type).
 *  Anything else is left unresolved (→ None → element-agnostic entry). */
let resolve_arg_type = fn (arg: HirExpr, params: [ HirParam ]) -> Option<TypeExpr> do
  let HirExpr(node: k, span: _) = arg
  match k do
    | Variable(name: vn, sigil: _) -> return param_type(params, name: vn)
    | Borrow(name: vn, sigil: _) -> return param_type(params, name: vn)
    | Literal(lit: l) -> return Some(val: literal_type(l))
    | _ -> return None
  end
end

let param_type = fn (params: [ HirParam ], name: string) -> Option<TypeExpr> do
  match params do
    | [] -> return None
    | HirParam(label: _, name: pn, sigil: _, typ: t) :: rest ->
      if pn == name then return Some(val: t) end
      return param_type(params: rest, name)
  end
end

let literal_type = fn (l: Literal) -> TypeExpr do
  match l do
    | LitInt(_) -> return TyI64
    | LitFloat(_) -> return TyF64
    | LitBool(_) -> return TyBool
    | LitChar(_) -> return TyChar
    | LitString(_) -> return TyString
    | _ -> return TyI64
  end
end

/** Apply the collected bindings to the cap's type params, in declaration order.
 *  Returns the per-param arg-type list iff every cap type param is bound. */
let all_tps_bound = fn (cap_tps: [ string ], bindings: [ SubstEntry ]) -> Option<[ TypeExpr ]> do
  return all_tps_bound_go(cap_tps, bindings, acc: [])
end

let all_tps_bound_go = fn (
  cap_tps: [ string ],
  bindings: [ SubstEntry ],
  acc: [ TypeExpr ]
) -> Option<[ TypeExpr ]> do
  match cap_tps do
    | [] -> return Some(val: list.reverse(xs: acc))
    | t :: rest ->
      match lookup_binding(bindings, var: t) do
        | None -> return None
        | Some(val: ty) -> return all_tps_bound_go(cap_tps: rest, bindings, acc: ty :: acc)
      end
  end
end

let lookup_binding = fn (bindings: [ SubstEntry ], var: string) -> Option<TypeExpr> do
  match bindings do
    | [] -> return None
    | SubstEntry(var: v, typ: t) :: rest ->
      if v == var then return Some(val: t) end
      return lookup_binding(bindings: rest, var)
  end
end

let cap_methods_of = fn (caps: [ HirCap ], bare: string) -> [ HirCapMethod ] do
  match caps do
    | [] -> return []
    | HirCap(name: cn, type_params: _, methods) :: rest ->
      if tcwf.base_name_of(qualified: cn) == bare then return methods end
      return cap_methods_of(caps: rest, bare)
  end
end

let lookup_method = fn (methods: [ HirCapMethod ], name: string) -> Option<HirCapMethod> do
  match methods do
    | [] -> return None
    | HirCapMethod(name: n, requires: r, span: sp, throw_row: tw, typ_params: tp, typ_ret: tr) :: rest ->
      if n == name then return Some(val: HirCapMethod(name: n, requires: r, span: sp, throw_row: tw, typ_params: tp, typ_ret: tr)) end
      return lookup_method(methods: rest, name)
  end
end

// ─── Cap-call site collection (body walk) ───────────────────────────────────
// A `Box.wrap(...)` call is a plain `Call(func: "<cap-qualified>.wrap", args)`.
// We collect the (method-name, args) pairs for calls whose func name resolves
// to one of this generic cap's methods, walking the full statement/expr tree so
// a cap call nested in a let-rhs / if / match is found.

type CapCall = CapCall(method: string, args: [ HirCallArg ])

// All call sites of a body as (func-name, args) pairs. A single-accumulator
// walk (only `acc` threaded) mirrors reachability.collect_calls_* so the
// self-hosting seed compiles the mutual recursion correctly.
type AllCall = AllCall(func: string, args: [ HirCallArg ])

let collect_all_calls_stmts = fn (stmts: [ HirStmt ], acc: [ AllCall ]) -> [ AllCall ] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: s, span: _) :: rest ->
      return collect_all_calls_stmts(stmts: rest, acc: collect_all_calls_stmt_kind(s, acc))
  end
end

let collect_all_calls_stmt_kind = fn (s: HirStmtKind, acc: [ AllCall ]) -> [ AllCall ] do
  match s do
    | Let(name: _, sigil: _, typ: _, value: v) -> return collect_all_calls_expr(v, acc)
    | Expr(expr: e) | Return(expr: e) -> return collect_all_calls_expr(e, acc)
    | Assign(target: t, value: v) ->
      return collect_all_calls_expr(t, acc: collect_all_calls_expr(v, acc))
    | Try(body: b, catch_param: _, catch_body: cb) ->
      return collect_all_calls_stmts(stmts: b, acc: collect_all_calls_stmts(stmts: cb, acc))
  end
end

let collect_all_calls_expr = fn (e: HirExpr, acc: [ AllCall ]) -> [ AllCall ] do
  let HirExpr(node: k, span: _) = e
  match k do
    | Literal(_) | Variable(_) | Borrow(_) | ExternalRef(_) -> return acc
    | BinOp(left: l, op: _, right: r) ->
      return collect_all_calls_expr(l, acc: collect_all_calls_expr(r, acc))
    | UnOp(op: _, operand: o) -> return collect_all_calls_expr(o, acc)
    | Call(func: f, args) ->
      return AllCall(func: f, args) :: collect_all_calls_args(args, acc)
    | CallExpr(callee: c, args) ->
      return collect_all_calls_expr(c, acc: collect_all_calls_args(args, acc))
    | Ctor(variant: _, args, labels: _, sigil: _) -> return collect_all_calls_expr_list(args, acc)
    | Record(fields: fs) -> return collect_all_calls_named(fs, acc)
    | Array(elems: es) -> return collect_all_calls_expr_list(es, acc)
    | Index(target: t, index: i) ->
      return collect_all_calls_expr(t, acc: collect_all_calls_expr(i, acc))
    | FieldAccess(target: t, field: _) -> return collect_all_calls_expr(t, acc)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let a1 = collect_all_calls_stmts(stmts: tb, acc)
      let a2 = match eb do | Some(val: ss) -> collect_all_calls_stmts(stmts: ss, acc: a1) | None -> a1 end
      return collect_all_calls_expr(c, acc: a2)
    | Match(target: t, cases: cs) ->
      return collect_all_calls_expr(t, acc: collect_all_calls_cases(cs, acc))
    | While(cond: c, body: b) ->
      return collect_all_calls_expr(c, acc: collect_all_calls_stmts(stmts: b, acc))
    | For(var: _, start: s, end_expr: en, body: b) ->
      return collect_all_calls_expr(s, acc: collect_all_calls_expr(en, acc: collect_all_calls_stmts(stmts: b, acc)))
    | Lambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: _) ->
      // A lambda body opens a fresh scope whose bindings are not in this
      // function's param env; skip (conservative: agnostic for the enclosing fn).
      return acc
    | Raise(expr: e2) | Force(expr: e2) -> return collect_all_calls_expr(e2, acc)
    | Thunk(body: b) -> return collect_all_calls_expr(b, acc)
    | Handler(cap_name: _, requires: _, arms: _) -> return acc
    | Inject(handlers: _, body: b) -> return collect_all_calls_stmts(stmts: b, acc)
  end
end

let collect_all_calls_args = fn (args: [ HirCallArg ], acc: [ AllCall ]) -> [ AllCall ] do
  match args do
    | [] -> return acc
    | HirCallArg(label: _, value: v) :: rest ->
      return collect_all_calls_args(args: rest, acc: collect_all_calls_expr(v, acc))
  end
end

let collect_all_calls_named = fn (fs: [ HirNamedExpr ], acc: [ AllCall ]) -> [ AllCall ] do
  match fs do
    | [] -> return acc
    | HirNamedExpr(name: _, value: v) :: rest ->
      return collect_all_calls_named(fs: rest, acc: collect_all_calls_expr(v, acc))
  end
end

let collect_all_calls_expr_list = fn (es: [ HirExpr ], acc: [ AllCall ]) -> [ AllCall ] do
  match es do
    | [] -> return acc
    | e :: rest -> return collect_all_calls_expr_list(es: rest, acc: collect_all_calls_expr(e, acc))
  end
end

let collect_all_calls_cases = fn (cs: [ HirMatchCase ], acc: [ AllCall ]) -> [ AllCall ] do
  match cs do
    | [] -> return acc
    | HirMatchCase(pattern: _, body: b) :: rest ->
      return collect_all_calls_cases(cs: rest, acc: collect_all_calls_stmts(stmts: b, acc))
  end
end

/** If a call's func name is `<X>.<method>` where the dotted suffix is a method
 *  of THIS cap and the prefix's bare name equals the cap's bare name, return the
 *  method name. Cap call funcs are stored qualified (`<cap-qualified>.wrap`). */
let cap_method_of_call = fn (func: string, bare: string, methods: [ HirCapMethod ]) -> Option<string> do
  match last_dot_split(func) do
    | None -> return None
    | Some(val: DotSplit(prefix: pre, suffix: meth)) ->
      if tcwf.base_name_of(qualified: pre) != bare then return None end
      match lookup_method(methods, name: meth) do
        | Some(_) -> return Some(val: meth)
        | None -> return None
      end
  end
end

type DotSplit = DotSplit(prefix: string, suffix: string)

/** Split a dotted name at its LAST '.'. None when there is no '.'. */
let last_dot_split = fn (s: string) -> Option<DotSplit> do
  let n = str.length(s)
  let idx = last_index_of_dot(s, i: n - 1)
  if idx < 0 then return None end
  let pre = str.substring(s, start: 0, len: idx)
  let suf = str.substring(s, start: idx + 1, len: n - idx - 1)
  return Some(val: DotSplit(prefix: pre, suffix: suf))
end

// 46 = ASCII '.'
let last_index_of_dot = fn (s: string, i: i64) -> i64 do
  if i < 0 then return 0 - 1 end
  if str.char_code(s, idx: i) == 46 then return i end
  return last_index_of_dot(s, i: i - 1)
end

let row_contains_cap = fn (name: string, ts: [ TypeExpr ]) -> bool do
  match ts do
    | [] -> return false
    | TyUserDefined(name: n, args: _) :: rest ->
      if n == name then return true end
      return row_contains_cap(name, ts: rest)
    | _ :: rest -> return row_contains_cap(name, ts: rest)
  end
end

let check_cap_method_rows = fn (
  methods: [ HirCapMethod ],
  state: CheckState,
  exception_groups: [ ExceptionGroupEntry ],
  caps: [ HirCap ]
) -> unit throws { TypeError } do
  match methods do
    | [] -> return ()
    | HirCapMethod(
      name: _,
      requires: req,
      span: sp,
      throw_row: tw,
      typ_params: _,
      typ_ret: _
    ) :: rest ->
      // Pass the full caps list so user-declared caps are accepted in require rows.
      tcwf.wf_cap(row: req, caps, span: sp)
      // Cap methods declare no generic row quantifiers, so a pipe-tail can
      // never be a legitimate row variable here.
      tcwf.wf_throw(
        row: tw,
        vidx_: tctypes.state_variant_index(state),
        groups: exception_groups,
        span: sp,
        type_params: []
      )
      return check_cap_method_rows(methods: rest, state, exception_groups, caps)
  end
end

// ─── D-Let-Top alias fix-up ──────────────────────────────────────────────────

/** alias_src_name: if `func` is an alias pattern (zero type-params, zero
 *  params, body = [return Variable(src)]), return Some(src). Otherwise None.
 *
 *  This detects `let g = inc` desugared as HirFunction(name: "g", params: [],
 *  body: EagerBody([Return(Variable("inc"))])).
 */
export let alias_src_name = fn (func: HirFunction) -> Option<string> do
  match func do
    | HirFunction(
      type_params: [],
      params: [],
      body: body,
      name: _,
      ret_type: _,
      throw_row: _,
      span: _,
      file: _,
      requires: _
    ) ->
      match body do
        | EagerBody(stmts: stmts) ->
          match stmts do
            | [ HirStmt(node: Return(expr: HirExpr(node: Variable(name: src, sigil: _), span: _)), span: _) ] ->
              return Some(val: src)
            | _ -> return None
          end
        | _ -> return None
      end
    | _ -> return None
  end
end

/** resolve_alias_registrations: Pass 1a — fix up env entries for top-level
 *  alias functions (D-Let-Top → T-Let-Alias).
 *
 *  register_functions_go registers `g` with a placeholder arrow derived from
 *  HirFunction.ret_type (TyI64). This second pass detects alias-pattern
 *  functions and overwrites their env entry with the scheme of the source name.
 *
 *  Note: HIR functions list is in reversed source order (prepend in HIR build),
 *  but all real functions are registered by Pass 1 before this runs, so a
 *  single-level alias `let g = inc` resolves correctly regardless of order.
 */
export let resolve_alias_registrations = fn (
  state: CheckState,
  funcs: [ HirFunction ]
) -> CheckState do
  match funcs do
    | [] -> return state
    | func :: rest ->
      let HirFunction(
        name: n,
        type_params: _,
        params: _,
        ret_type: _,
        throw_row: _,
        body: _,
        span: _,
        file: _,
        requires: _
      ) = func
      let st1 = match alias_src_name(func) do
        | None -> state
        | Some(val: src) ->
          match tctypes.env_lookup(env: tctypes.state_env(state), name: src) do
            | None -> state
            | Some(val: src_scheme) ->
              let env2 = tctypes.env_insert(
                env: tctypes.state_env(state),
                name: n,
                scheme: src_scheme
              )
              tctypes.state_with_env(state, env: env2)
          end
      end
      return resolve_alias_registrations(state: st1, funcs: rest)
  end
end
