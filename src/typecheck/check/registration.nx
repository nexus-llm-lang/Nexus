/**
 * typecheck/check/registration: Pass-1 signature registration.
 *
 * Registers externals, functions, and caps into the CheckState environment,
 * and performs the D-Let-Top alias fix-up. Handler-binding registration /
 * validation lives in check/handler_validation.nx, and enum-constructor
 * registration lives in check/enum_registration.nx.
 *
 * Validates at introduction sites:
 *   - Per-fn/external wfCap / wfThrow / wfRef
 *   - D-External / T-Lambda gravity rule (¬escapesRef)
 *   - kindOf binding-site quantifier enforcement
 *   - same-name top-level redeclaration rejection
 */

import * as list from "std:list"
import * as bb from "std:bytebuffer"
import { Option, Some, None } from "std:option"
import {
  TypeExpr,
  TyArrow,
  TyRow,
  TyVar,
  TyUserDefined,
  NamedType,
  RecordDef
} from "src/types/type_expr.nx"
import {
  HirFunction,
  HirParam,
  HirExternal,
  HirCap,
  HirCapMethod,
  ExceptionGroupEntry,
  EagerBody,
  HirStmt,
  HirExpr
} from "src/ir/hir/types.nx"
import { Span } from "src/types/span.nx"
import { TypeError, DuplicateTopLevelBinding } from "src/typecheck/errors.nx"
import { CheckState, Scheme } from "src/typecheck/types.nx"
import * as tctypes from "src/typecheck/types.nx"
import * as tcwf from "src/typecheck/tcwf.nx"
import {
  str_list_contains,
  enforce_kindof_quantifiers, named_type_typs,
  convert_ud_to_var, convert_named_types
} from "src/typecheck/check/occurs.nx"

// ─── Shared helpers ──────────────────────────────────────────────────────────

export let hir_params_to_named_types = fn (params: [ HirParam ]) -> [ NamedType ] do
  return hir_params_to_named_types_go(params, acc: [])
end

let hir_params_to_named_types_go = fn (params: [ HirParam ], acc: [ NamedType ]) -> [ NamedType ] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: l, name: _, sigil: _, typ: t) :: rest ->
      return hir_params_to_named_types_go(params: rest, acc: NamedType(name: l, typ: t) :: acc)
  end
end

/** Reserved generalized row-variable name used to open the require row of an
 *  external's thunk parameters. Added to the external's scheme quantifiers so
 *  each call site instantiates a fresh tail (no cross-call-site sharing). The
 *  name is namespaced to avoid colliding with any source-level type parameter. */
let ext_require_tail_name = "__ext_require_tail"

/** True when any parameter is a thunk-shaped (nullary-arrow) type whose require
 *  row was opened by `open_thunk_param_require_rows`. */
let params_have_thunk = fn (params: [ NamedType ]) -> bool do
  match params do
    | [] -> return false
    | NamedType(name: _, typ: TyArrow(params: [], ret: _, requires: _, throw_row: _)) :: _ ->
      return true
    | _ :: rest -> return params_have_thunk(params: rest)
  end
end

/** D-External require-row erasure on thunk parameters. An external is an FFI
 *  boundary that is OPAQUE to the effect system: it receives a bare function
 *  pointer and neither discharges nor propagates effects itself. Whatever
 *  eventually forces a thunk argument runs it under the handlers in scope at
 *  that point — e.g. `__nx_sched_spawn` enqueues a continuation the cooperative
 *  `scheduler` inject resumes (installing `Coop`), while `Console` and any other
 *  ambient caps remain in dynamic scope. So the require row a thunk argument
 *  carries is discharged downstream, not at the external call.
 *
 *  Open the require row of every thunk-shaped (nullary-arrow) parameter to a
 *  fresh generalized empty-head row `{ | tail_name }`, erasing the declared cap
 *  requirement so any caller require row unifies at this FFI boundary. Non-thunk
 *  parameters (and ordinary multi-arg function-valued parameters) are left
 *  untouched, keeping require-row checking intact at all ordinary call sites. */
let open_thunk_param_require_rows = fn (
  params: [ NamedType ],
  tail_name: string
) -> [ NamedType ] do
  match params do
    | [] -> return []
    | NamedType(name: pn, typ: TyArrow(params: [], ret: r, requires: _, throw_row: tw)) :: rest ->
      let opened = TyArrow(
        params: [],
        ret: r,
        requires: TyRow(types: [], rest: Some(val: TyVar(name: tail_name))),
        throw_row: tw
      )
      return NamedType(name: pn, typ: opened)
        :: open_thunk_param_require_rows(params: rest, tail_name)
    | other :: rest ->
      return other :: open_thunk_param_require_rows(params: rest, tail_name)
  end
end

// ─── Register externals ────────────────────────────────────────────────────

export let register_externals = fn (
  state: CheckState,
  exts: [ HirExternal ],
  tdefs: [ RecordDef ]
) -> CheckState throws { TypeError } do
  match exts do
    | [] -> return state
    | HirExternal(
      name: n,
      wasm_module: _,
      wasm_name: _,
      type_params: tps,
      params,
      ret_type: ret,
      throw_row: thr
    ) :: rest ->
      let param_types = hir_params_to_named_types(params)
      // kindOf binding-site enforcement (spec §Polymorphism Introduction / kindOf).
      // Externals carry no Span, so we attribute the diagnostic to the
      // externals header (Span(0,0,0)) — the func_name plus the type-param
      // name in the message is enough to locate the malformed declaration.
      // The σ pieces for an external arrow are exactly (params, ret, throws);
      // there is no `requires` slot (always `{}` for FFI declarations).
      let ext_parts = thr :: (ret :: named_type_typs(nts: param_types))
      enforce_kindof_quantifiers(
        tps,
        parts: ext_parts,
        func_name: n,
        span: Span(offset: 0, line: 0, col: 0)
      )
      // D-External gravity rule: ¬escapesRef(τ_r).
      // Spec: type-system-formal.md §"Gravity Rule" + §D-External.
      tcwf.enforce_no_escapes_ref(
        typ: ret,
        context: "return type of external '" ++ n ++ "'",
        span: Span(offset: 0, line: 0, col: 0),
        borrow_escapes: true
      )
      // D-External wfRef at parameter annotation sites
      // (spec §mutable-reference-well-formedness / wfRef).
      tcwf.enforce_wf_ref_params(params: param_types, span: Span(offset: 0, line: 0, col: 0), tdefs)
      // Convert TyUserDefined("T",[]) → TyVar("T") for declared type params,
      // then register as a polymorphic Scheme so each call site instantiates
      // T to a fresh metavar. Without this `external f: <T>(val: T) -> unit`
      // freezes T as a frozen non-int type and rejects int-literal callers.
      let converted_params = convert_named_types(nts: param_types, vars: tps)
      let opened_params = open_thunk_param_require_rows(
        params: converted_params,
        tail_name: ext_require_tail_name
      )
      let scheme_vars = if params_have_thunk(params: converted_params) then
        ext_require_tail_name :: tps
      else
        tps
      end
      let arrow = TyArrow(
        params: opened_params,
        ret: convert_ud_to_var(typ: ret, vars: tps),
        requires: TyRow(types: [], rest: None),
        throw_row: convert_ud_to_var(typ: thr, vars: tps)
      )
      let st1 = tctypes.state_put_global(
        state,
        name: n,
        scheme: Scheme(vars: scheme_vars, typ: arrow)
      )
      return register_externals(state: st1, exts: rest, tdefs)
  end
end

// ─── Register functions ─────────────────────────────────────────────────────

// track names registered so far to reject same-name redeclaration.
// Downstream lir_opt mis-resolves `return_call` for shadowed top-level lets
// and corrupts UNRELATED functions' return atoms; rejecting at typecheck
// eliminates the bug class entirely.
export let register_functions = fn (
  state: CheckState,
  funcs: [ HirFunction ],
  caps: [ HirCap ],
  exception_groups: [ ExceptionGroupEntry ],
  tdefs: [ RecordDef ]
) -> CheckState throws { TypeError } do
  return register_functions_go(state, funcs, seen: [], caps, exception_groups, tdefs)
end

let register_functions_go = fn (
  state: CheckState,
  funcs: [ HirFunction ],
  seen: [ string ],
  caps: [ HirCap ],
  exception_groups: [ ExceptionGroupEntry ],
  tdefs: [ RecordDef ]
) -> CheckState throws { TypeError } do
  match funcs do
    | [] -> return state
    | HirFunction(
      name: n,
      type_params: tps,
      params,
      ret_type: ret,
      throw_row: tw,
      body: _,
      span: sp,
      file: _,
      requires: req
    ) :: rest ->
      if str_list_contains(xs: seen, s: n) then
        throw DuplicateTopLevelBinding(name: n, span: sp)
      end
      // Introduction-site well-formedness checks (T-Lambda fn arrow):
      // wfCap on the require row and wfThrow on the throws row. Per spec
      // §1 (wfCap/wfThrow), these are checked here so a typo (`require { Logr }`
      // for `Logger`) is rejected at the source location rather than
      // surviving as an uninhabitable row entry until a use site looks
      // it up — issues (wfCap) and (wfThrow).
      tcwf.wf_cap(row: req, caps, span: sp)
      tcwf.wf_throw(
        row: tw,
        vidx_: tctypes.state_variant_index(state),
        groups: exception_groups,
        span: sp,
        type_params: tps
      )
      // T-Lambda / T-Let-PolyFn gravity rule: ¬escapesRef(τ_r).
      // Checked at the declaration site so a typo such as `fn () -> ref(i64)`
      // is rejected at the binding, not at a downstream return statement.
      // Spec: type-system-formal.md §"Gravity Rule" + §T-Lambda.
      tcwf.enforce_no_escapes_ref(
        typ: ret,
        context: "return type of '" ++ n ++ "'",
        span: sp,
        borrow_escapes: true
      )
      let param_types = hir_params_to_named_types(params)
      // wfRef at parameter annotation sites
      // (spec §mutable-reference-well-formedness / wfRef):
      // each parameter type ~σ is rejected if σ is structurally linear.
      tcwf.enforce_wf_ref_params(params: param_types, span: sp, tdefs)
      // kindOf binding-site enforcement
      // (spec §Polymorphism Introduction / kindOf). σ for a top-level fn is its
      // parameter types, return type, throws-row, and require row. All four
      // components are checked so that type parameters appearing in any slot
      // are accounted for.
      let parts = tw :: (ret :: (req :: named_type_typs(nts: param_types)))
      enforce_kindof_quantifiers(tps, parts, func_name: n, span: sp)
      // Generic-cap soundness (nexus-3ibql): a bare `require { Box }` for a
      // GENERIC cap `Box<T>` is published here element-AGNOSTIC; the element type
      // each function COMMITS to in its body (its `Box<i64>` contract) is then
      // derived by real inference in a dedicated call-graph-ordered pre-pass
      // (cap_contract.derive_generic_cap_contracts), which re-publishes the
      // scheme. Pass-1 stays purely structural so forward/transitive references
      // are resolved by the fixpoint rather than a syntactic body scan.
      let arrow = TyArrow(
        params: convert_named_types(nts: param_types, vars: tps),
        ret: convert_ud_to_var(typ: ret, vars: tps),
        requires: convert_ud_to_var(typ: req, vars: tps),
        throw_row: convert_ud_to_var(typ: tw, vars: tps)
      )
      let st1 = tctypes.state_put_global(
        state,
        name: n,
        scheme: Scheme(vars: tps, typ: arrow)
      )
      return register_functions_go(
        state: st1,
        funcs: rest,
        seen: n :: seen,
        caps,
        exception_groups,
        tdefs
      )
  end
end

// ─── Register caps ─────────────────────────────────────────────────────────
//
// D-Cap introduction-site wfCap/wfThrow (spec §D-Cap):
// `∀j∈J. wfCap(α_j) ∧ wfThrow(β_j)` for each declared method signature.
// HirCapMethod now carries the full require/throw rows from the source
// FunctionSig, so we can enforce these premises here at registration time.
export let register_caps = fn (
  state: CheckState,
  caps: [ HirCap ],
  exception_groups: [ ExceptionGroupEntry ]
) -> CheckState throws { TypeError } do
  return register_caps_go(state, caps, all_caps: caps, exception_groups)
end

let register_caps_go = fn (
  state: CheckState,
  caps: [ HirCap ],
  all_caps: [ HirCap ],
  exception_groups: [ ExceptionGroupEntry ]
) -> CheckState throws { TypeError } do
  match caps do
    | [] -> return state
    | HirCap(name: cap_qname, type_params: tps, methods) :: rest ->
      // Pass the full caps list so that wf_cap can resolve user-declared caps
      // named in method require rows (e.g. `require { B }` where B is a cap).
      check_cap_method_rows(methods, state, exception_groups, caps: all_caps)
      // Generic caps (`cap Foo<T>`) register their call-site method schemes
      // POLYMORPHICALLY from the declaration, mirroring generic functions:
      // each `Foo.method(...)` call instantiates the quantified params fresh,
      // so one generic producer can be reused at several element types. The
      // handler-arm registration (register_handler_methods) is suppressed for
      // generic caps so this poly scheme is the one that resolves at call sites.
      // Monomorphic caps keep their existing handler-arm-only registration
      // (tps == [] → skip here, behaviour unchanged).
      let state1 = match tps do
        | [] -> state
        | _ -> register_cap_method_schemes(state, cap_qname, tps, methods)
      end
      return register_caps_go(state: state1, caps: rest, all_caps, exception_groups)
  end
end

// Register each method of a GENERIC cap as a polymorphic env scheme keyed on
// `<cap_qname>.<method>`, quantified over the cap's type parameters. Mirrors
// the generic-function registration (register_functions_go): user-defined names
// matching a type param are converted to TyVar and bound by Scheme.vars, so a
// call site instantiates fresh and unifies against the actual argument types.
let register_cap_method_schemes = fn (
  state: CheckState,
  cap_qname: string,
  tps: [ string ],
  methods: [ HirCapMethod ]
) -> CheckState do
  match methods do
    | [] -> return state
    | HirCapMethod(
      name: mname,
      requires: mreq,
      span: _,
      throw_row: mtw,
      typ_params: mparams,
      typ_ret: mret
    ) :: rest ->
      // T-CapCall env'd require row: {cap_name} ∪ α. The cap name is the BARE
      // identifier (T-Inject extends ρ_q with bare cap names), so strip the
      // qualifier before adding the row entry.
      let bare_cap = tcwf.base_name_of(qualified: cap_qname)
      // Generic-cap soundness (nexus-3ibql): carry the cap's type params as
      // args on the require-row entry (`Box<T>`), so a `Box.wrap(x:n)` call
      // instantiates the row to `Box<i64>`. convert_ud_to_var below turns the
      // param args into TyVars, and the call-site coverage (T-CapCall x ∈ ρ_q)
      // unifies them against the ambient generic-cap row — pinning the element
      // type a function commits to onto its require contract. Without the args,
      // a function laundering a generic-cap call through `require { Box }`
      // escapes the handler-instantiation check (the tzvf9 shadow only reaches
      // the inject body's DIRECT scope, not a called helper typed standalone).
      let method_requires = build_method_requires(bare_cap, alpha: mreq, tps)
      let param_nts = hir_params_to_named_types(params: mparams)
      let arrow = TyArrow(
        params: convert_named_types(nts: param_nts, vars: tps),
        ret: convert_ud_to_var(typ: mret, vars: tps),
        requires: convert_ud_to_var(typ: method_requires, vars: tps),
        throw_row: convert_ud_to_var(typ: mtw, vars: tps)
      )
      let method_qname = bb.concat(parts: [ cap_qname, ".", mname ])
      let st1 = tctypes.state_put_global(
        state,
        name: method_qname,
        scheme: Scheme(vars: tps, typ: arrow)
      )
      return register_cap_method_schemes(
        state: st1,
        cap_qname, tps, methods: rest
      )
  end
end

// Build {bare_cap} ∪ α as a require row (α = method's declared require row).
// For a generic cap, the cap entry carries the cap's type params as args
// (`Box<T>`); `convert_ud_to_var(..., vars: tps)` at the caller then rewrites
// those args to TyVars. Monomorphic caps (tps == []) keep `Box` with no args.
let build_method_requires = fn (bare_cap: string, alpha: TypeExpr, tps: [ string ]) -> TypeExpr do
  let cap_entry = TyUserDefined(name: bare_cap, args: tps_as_ud_args(tps))
  match alpha do
    | TyRow(types: ts, rest: tail) ->
      if row_contains_cap(name: bare_cap, ts) then return alpha end
      return TyRow(types: cap_entry :: ts, rest: tail)
    | _ -> return TyRow(types: [ cap_entry ], rest: None)
  end
end

// Render a cap's type-param names as positional `TyUserDefined(name, args: [])`
// type args. convert_ud_to_var(..., vars: tps) later rewrites each to TyVar.
let tps_as_ud_args = fn (tps: [ string ]) -> [ TypeExpr ] do
  match tps do
    | [] -> return []
    | t :: rest -> return TyUserDefined(name: t, args: []) :: tps_as_ud_args(tps: rest)
  end
end

let row_contains_cap = fn (name: string, ts: [ TypeExpr ]) -> bool do
  match ts do
    | [] -> return false
    | TyUserDefined(name: n, args: _) :: rest ->
      if n == name then return true end
      return row_contains_cap(name, ts: rest)
    | _ :: rest -> return row_contains_cap(name, ts: rest)
  end
end

let check_cap_method_rows = fn (
  methods: [ HirCapMethod ],
  state: CheckState,
  exception_groups: [ ExceptionGroupEntry ],
  caps: [ HirCap ]
) -> unit throws { TypeError } do
  match methods do
    | [] -> return ()
    | HirCapMethod(
      name: _,
      requires: req,
      span: sp,
      throw_row: tw,
      typ_params: _,
      typ_ret: _
    ) :: rest ->
      // Pass the full caps list so user-declared caps are accepted in require rows.
      tcwf.wf_cap(row: req, caps, span: sp)
      // Cap methods declare no generic row quantifiers, so a pipe-tail can
      // never be a legitimate row variable here.
      tcwf.wf_throw(
        row: tw,
        vidx_: tctypes.state_variant_index(state),
        groups: exception_groups,
        span: sp,
        type_params: []
      )
      return check_cap_method_rows(methods: rest, state, exception_groups, caps)
  end
end

// ─── D-Let-Top alias fix-up ──────────────────────────────────────────────────

/** alias_src_name: if `func` is an alias pattern (zero type-params, zero
 *  params, body = [return Variable(src)]), return Some(src). Otherwise None.
 *
 *  This detects `let g = inc` desugared as HirFunction(name: "g", params: [],
 *  body: EagerBody([Return(Variable("inc"))])).
 */
export let alias_src_name = fn (func: HirFunction) -> Option<string> do
  match func do
    | HirFunction(
      type_params: [],
      params: [],
      body: body,
      name: _,
      ret_type: _,
      throw_row: _,
      span: _,
      file: _,
      requires: _
    ) ->
      match body do
        | EagerBody(stmts: stmts) ->
          match stmts do
            | [ HirStmt(node: Return(expr: HirExpr(node: Variable(name: src, sigil: _), span: _)), span: _) ] ->
              return Some(val: src)
            | _ -> return None
          end
        | _ -> return None
      end
    | _ -> return None
  end
end

/** resolve_alias_registrations: Pass 1a — fix up env entries for top-level
 *  alias functions (D-Let-Top → T-Let-Alias).
 *
 *  register_functions_go registers `g` with a placeholder arrow derived from
 *  HirFunction.ret_type (TyI64). This second pass detects alias-pattern
 *  functions and overwrites their env entry with the scheme of the source name.
 *
 *  Note: HIR functions list is in reversed source order (prepend in HIR build),
 *  but all real functions are registered by Pass 1 before this runs, so a
 *  single-level alias `let g = inc` resolves correctly regardless of order.
 */
export let resolve_alias_registrations = fn (
  state: CheckState,
  funcs: [ HirFunction ]
) -> CheckState do
  match funcs do
    | [] -> return state
    | func :: rest ->
      let HirFunction(
        name: n,
        type_params: _,
        params: _,
        ret_type: _,
        throw_row: _,
        body: _,
        span: _,
        file: _,
        requires: _
      ) = func
      let st1 = match alias_src_name(func) do
        | None -> state
        | Some(val: src) ->
          match tctypes.state_lookup_scheme(state, name: src) do
            | None -> state
            | Some(val: src_scheme) ->
              tctypes.state_put_global(state, name: n, scheme: src_scheme)
          end
      end
      return resolve_alias_registrations(state: st1, funcs: rest)
  end
end
