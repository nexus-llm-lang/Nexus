/**
 * typecheck/check/occurs: kindOf helpers and type-expression conversion.
 *
 * - occurs_tau / occurs_rho: binding-site kindOf predicates (spec §Polymorphism Introduction / occurs_τ, occurs_ρ)
 * - enforce_kindof_quantifiers: reject unused / clashing quantifiers
 * - convert_ud_to_var / convert_named_types / ...: TyUserDefined → TyVar
 * - str_list_contains / enum_name_visible: shared string predicates
 */

import * as list from "std:list"
import { TypeExpr, TyUnit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyLazy, TyBorrow, TyArray, TyList, TyRecord, TyRow, TyHandler, NamedType } from "src/common/ast.nx"
import { HirParam } from "src/ir/hir/types.nx"
import { Span } from "src/common/token.nx"
import { TypeError, UnusedTypeParam, KindClashTypeParam } from "src/typecheck/errors.nx"

// ─── String helpers ──────────────────────────────────────────────────────────

export let str_list_contains = fn (xs: [string], s: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true end
      return str_list_contains(xs: rest, s)
  end
end

export let enum_name_visible = fn (name: string, names: [string]) -> bool do
  match names do
    | [] -> return false
    | n :: rest ->
      if n == name then return true end
      return enum_name_visible(name, names: rest)
  end
end

// ─── kindOf binding-site enforcement ─────────────────────────────────────────
//
// Spec: type-system-formal.md §"Polymorphism Introduction" (kindOf).
// For each declared quantifier X in a top-level `fn <X1,...,Xn>(...)` signature,
// the spec defines
//
//   kindOf(X, σ) = { Type   if  occurs_τ(X, σ) ∧ ¬occurs_ρ(X, σ)
//                  { Row    if  occurs_ρ(X, σ) ∧ ¬occurs_τ(X, σ)
//                  { undefined otherwise   ── unused (both false) OR clash (both true)
//
// and explicitly classifies the *undefined* cases as static errors raised
// at the binding site (T-Let-PolyFn), surfacing as "malformed quantifier
// list" rather than as a downstream unification failure at a use site.
//
// The two recursive predicates below implement the occurs_τ / occurs_ρ
// clauses from §"Polymorphism Introduction" (spec §kindOf position predicates).
// `occurs_tau` covers every place a τ is expected (incl. row entries);
// `occurs_rho` surfaces *only* row-tail occurrences of X. The driver is
// `enforce_kindof_quantifiers`, which folds over the declared `tps` and
// raises `UnusedTypeParam` / `KindClashTypeParam` for the malformed ones.
//
// Both predicates accept arbitrary signature TypeExprs (pre-conversion —
// quantifier names show up as `TyUserDefined(X, [])` at this point, not
// `TyVar(X)`, because `convert_ud_to_var` has not yet run).

let occurs_tau = fn (x: string, typ: TypeExpr) -> bool do
  match typ do
    // occurs_τ(X, X) = true (spec §Polymorphism Introduction / occurs_τ, base identity clause).
    // At binding-site time the quantifier still appears under its surface
    // name `TyUserDefined(X, [])`.
    | TyUserDefined(name: n, args: []) ->
      return n == x
    // occurs_τ(X, x<τ̄>) = ∃i. occurs_τ(X, τᵢ) — generic application
    // (right disjunct). Recurse into the argument list.
    | TyUserDefined(name: _, args: targs) ->
      return occurs_tau_in_list(x, types: targs)
    // occurs_τ(X, (ℓ̄:τ̄) → τr ; ρq ; ρe) — arrow case (spec §Polymorphism
    // Introduction / occurs_τ, arrow clause). Recurses into every parameter
    // type, the return, and (via occurs_τ^ρ) into the row entries of both
    // requires and throws.
    | TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      if occurs_tau_in_named(x, nts: ps) then return true end
      if occurs_tau(x, typ: r) then return true end
      if occurs_tau(x, typ: req) then return true end
      return occurs_tau(x, typ: thr)
    // occurs_τ(X, %τ) = occurs_τ(X, @τ) = occurs_τ(X, &τ) = occurs_τ(X, τ) —
    // sigil/wrapper clause (spec §Polymorphism Introduction / occurs_τ, sigil clause).
    // We have an extra TyRef constructor — same recursive rule applies.
    | TyList(elem: e) -> return occurs_tau(x, typ: e)
    | TyArray(elem: e) -> return occurs_tau(x, typ: e)
    | TyRef(inner: i) -> return occurs_tau(x, typ: i)
    | TyLinear(inner: i) -> return occurs_tau(x, typ: i)
    | TyLazy(inner: i) -> return occurs_tau(x, typ: i)
    | TyBorrow(inner: i) -> return occurs_tau(x, typ: i)
    // occurs_τ(X, {ℓ̄:τ̄}) = ∃i. occurs_τ(X, τᵢ) — record / generic-app
    // left disjunct (spec §Polymorphism Introduction / occurs_τ, record clause).
    | TyRecord(fields: fs) -> return occurs_tau_in_named(x, nts: fs)
    // occurs_τ^ρ({τ̄}) and occurs_τ^ρ({τ̄ | Y}) both look at the row entries
    // via occurs_τ (spec §Polymorphism Introduction / occurs_τ^ρ, closed+open row
    // clauses). The rest tail is handled separately by `occurs_rho`, not
    // here — so we do NOT recurse into `rest`.
    | TyRow(types: ts, rest: _) -> return occurs_tau_in_list(x, types: ts)
    // TyHandler's `requires` field is a row; recurse via occurs_τ.
    | TyHandler(name: _, requires: req) -> return occurs_tau(x, typ: req)
    // Base types and unrelated names contribute nothing (spec §Polymorphism
    // Introduction / occurs_τ, base/unrelated clause).
    | _ -> return false
  end
end

let occurs_tau_in_list = fn (x: string, types: [TypeExpr]) -> bool do
  match types do
    | [] -> return false
    | t :: rest ->
      if occurs_tau(x, typ: t) then return true end
      return occurs_tau_in_list(x, types: rest)
  end
end

let occurs_tau_in_named = fn (x: string, nts: [NamedType]) -> bool do
  match nts do
    | [] -> return false
    | NamedType(name: _, typ: t) :: rest ->
      if occurs_tau(x, typ: t) then return true end
      return occurs_tau_in_named(x, nts: rest)
  end
end

// occurs_ρ surfaces only row-tail occurrences of X (spec §Polymorphism
// Introduction / occurs_ρ, tail-occurrence clauses). We recurse through
// every type-bearing constructor that might *contain* a row, and inspect
// the row's `rest` slot for a TyUserDefined(X, []) tail.
let occurs_rho = fn (x: string, typ: TypeExpr) -> bool do
  match typ do
    // Arrow: recurse into params (their types may contain inner rows),
    // return, and most importantly the two row positions (requires/throws).
    | TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      if occurs_rho_in_named(x, nts: ps) then return true end
      if occurs_rho(x, typ: r) then return true end
      if occurs_rho(x, typ: req) then return true end
      return occurs_rho(x, typ: thr)
    | TyList(elem: e) -> return occurs_rho(x, typ: e)
    | TyArray(elem: e) -> return occurs_rho(x, typ: e)
    | TyRef(inner: i) -> return occurs_rho(x, typ: i)
    | TyLinear(inner: i) -> return occurs_rho(x, typ: i)
    | TyLazy(inner: i) -> return occurs_rho(x, typ: i)
    | TyBorrow(inner: i) -> return occurs_rho(x, typ: i)
    | TyRecord(fields: fs) -> return occurs_rho_in_named(x, nts: fs)
    // The load-bearing case: a row {τ̄ | X} matches the occurs_ρ open-tail
    // clause (spec §Polymorphism Introduction / occurs_ρ) — `rest` is
    // `Some(TyUserDefined(X, []))`. We also recurse into the row's
    // entries because each entry is itself a TypeExpr that may transport
    // a nested row (e.g. a closure-typed capability whose own throws-row
    // mentions X as a tail).
    | TyRow(types: ts, rest: r) ->
      if occurs_rho_in_list(x, types: ts) then return true end
      match r do
        | Some(val: t) ->
          match t do
            | TyUserDefined(name: n, args: []) -> return n == x
            | _ -> return occurs_rho(x, typ: t)
          end
        | None -> return false
      end
    | TyHandler(name: _, requires: req) -> return occurs_rho(x, typ: req)
    // A TyUserDefined<...> can contain nested rows in its type arguments
    // (e.g. `Option<() -> unit require { Foo | X }>`). Recurse so the
    // tail is still discovered.
    | TyUserDefined(name: _, args: targs) -> return occurs_rho_in_list(x, types: targs)
    // Base types, plain TyVar, etc.: no row tail possible.
    | _ -> return false
  end
end

let occurs_rho_in_list = fn (x: string, types: [TypeExpr]) -> bool do
  match types do
    | [] -> return false
    | t :: rest ->
      if occurs_rho(x, typ: t) then return true end
      return occurs_rho_in_list(x, types: rest)
  end
end

let occurs_rho_in_named = fn (x: string, nts: [NamedType]) -> bool do
  match nts do
    | [] -> return false
    | NamedType(name: _, typ: t) :: rest ->
      if occurs_rho(x, typ: t) then return true end
      return occurs_rho_in_named(x, nts: rest)
  end
end

// Spec §Polymorphism Introduction / kindOf enforcement. Walks every declared
// quantifier X in `tps` and inspects the (still-pre-conversion) signature
// pieces. Raises `UnusedTypeParam` (kindOf=undefined, unused case) or
// `KindClashTypeParam` (kindOf=undefined, clash case) at the binding site span.
//
// `signature_parts` is the list of TypeExprs that together form σ —
// callers pass the params (as their NamedType list — folded into a
// TyRecord for uniform recursion), the return type, and the throws row.
// The requires row is part of TyArrow for top-level functions but lives
// implicitly in `TyRow(types: [], rest: None)` for externals, so callers
// pass exactly the σ pieces that exist for their declaration form.
export let enforce_kindof_quantifiers = fn (tps: [string], parts: [TypeExpr], func_name: string, span: Span) -> unit throws { TypeError } do
  match tps do
    | [] -> return ()
    | x :: rest ->
      let in_tau = occurs_tau_in_list(x, types: parts)
      let in_rho = occurs_rho_in_list(x, types: parts)
      // kindOf=undefined, unused case (spec §Polymorphism Introduction /
      // kindOf, "undefined — unused"): X appears nowhere in σ. Diagnostic
      // must surface at the binding site, NOT silently pass.
      if !in_tau then
        if !in_rho then
          throw UnusedTypeParam(name: x, func_name, span)
        end
      end
      // kindOf=undefined, clash case (spec §Polymorphism Introduction /
      // kindOf, "undefined — kind clash"): X is used at BOTH a type position
      // and a row tail. The unifier would otherwise pick one kind and report
      // a confusing downstream mismatch at the first use site that disagrees.
      // We reject upfront at the binding.
      if in_tau then
        if in_rho then
          throw KindClashTypeParam(name: x, func_name, span)
        end
      end
      return enforce_kindof_quantifiers(tps: rest, parts, func_name, span)
  end
end

// Convert the function's param list (NamedType, where `typ` is what
// matters for kindOf — the parameter *name* never contributes) into a
// flat list of TypeExprs for `enforce_kindof_quantifiers`.
export let named_type_typs = fn (nts: [NamedType]) -> [TypeExpr] do
  return named_type_typs_go(nts, acc: [])
end

let named_type_typs_go = fn (nts: [NamedType], acc: [TypeExpr]) -> [TypeExpr] do
  match nts do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: _, typ: t) :: rest ->
      return named_type_typs_go(nts: rest, acc: t :: acc)
  end
end

// ─── Generic type parameter resolution ──────────────────────────────────────
// Convert TyUserDefined("T", []) → TyVar("T") when "T" is a type parameter.

export let convert_ud_to_var = fn (typ: TypeExpr, vars: [string]) -> TypeExpr do
  match typ do
    | TyUserDefined(name: n, args: []) ->
      if str_list_contains(xs: vars, s: n) then return TyVar(name: n) end
      return typ
    | TyUserDefined(name: n, args: targs) ->
      return TyUserDefined(name: n, args: convert_type_list(types: targs, vars))
    | TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return TyArrow(
        params: convert_named_types(nts: ps, vars),
        ret: convert_ud_to_var(typ: r, vars),
        requires: convert_ud_to_var(typ: req, vars),
        throw_row: convert_ud_to_var(typ: thr, vars)
      )
    | TyList(elem: e) -> return TyList(elem: convert_ud_to_var(typ: e, vars))
    | TyArray(elem: e) -> return TyArray(elem: convert_ud_to_var(typ: e, vars))
    | TyRef(inner: i) -> return TyRef(inner: convert_ud_to_var(typ: i, vars))
    | TyLinear(inner: i) -> return TyLinear(inner: convert_ud_to_var(typ: i, vars))
    | TyLazy(inner: i) -> return TyLazy(inner: convert_ud_to_var(typ: i, vars))
    | TyBorrow(inner: i) -> return TyBorrow(inner: convert_ud_to_var(typ: i, vars))
    | TyRecord(fields: fs) -> return TyRecord(fields: convert_named_types(nts: fs, vars))
    | TyRow(types: ts, rest: r) ->
      let new_rest = match r do
        | Some(val: t) -> Some(val: convert_ud_to_var(typ: t, vars))
        | None -> None
      end
      return TyRow(types: convert_type_list(types: ts, vars), rest: new_rest)
    | TyHandler(name: n, requires: req) ->
      return TyHandler(name: n, requires: convert_ud_to_var(typ: req, vars))
    | _ -> return typ
  end
end

export let convert_named_types = fn (nts: [NamedType], vars: [string]) -> [NamedType] do
  return convert_named_types_go(nts, vars, acc: [])
end

let convert_named_types_go = fn (nts: [NamedType], vars: [string], acc: [NamedType]) -> [NamedType] do
  match nts do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: n, typ: t) :: rest ->
      return convert_named_types_go(nts: rest, vars, acc: NamedType(name: n, typ: convert_ud_to_var(typ: t, vars)) :: acc)
  end
end

export let convert_type_list = fn (types: [TypeExpr], vars: [string]) -> [TypeExpr] do
  return convert_type_list_go(types, vars, acc: [])
end

let convert_type_list_go = fn (types: [TypeExpr], vars: [string], acc: [TypeExpr]) -> [TypeExpr] do
  match types do
    | [] -> return list.reverse(xs: acc)
    | t :: rest ->
      return convert_type_list_go(types: rest, vars, acc: convert_ud_to_var(typ: t, vars) :: acc)
  end
end

export let convert_hir_params = fn (params: [HirParam], vars: [string]) -> [HirParam] do
  return convert_hir_params_go(params, vars, acc: [])
end

let convert_hir_params_go = fn (params: [HirParam], vars: [string], acc: [HirParam]) -> [HirParam] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: l, name: n, sigil: s, typ: t) :: rest ->
      return convert_hir_params_go(params: rest, vars, acc: HirParam(label: l, name: n, sigil: s, typ: convert_ud_to_var(typ: t, vars)) :: acc)
  end
end
