/**
 * typecheck/check/handler_validation: T-Handler registration + validation.
 *
 * Registers handler bindings into the CheckState environment and validates:
 *   - T-Handler arm/method 1-1 correspondence (validate_handler_arm_sets,
 *     validate_inline_handler_arm_set)
 *   - T-Handler arm signature cross-validation (throw_row / ret_type / params)
 *   - Per-arm wfThrow / wfRef at introduction sites
 *
 * Split out of registration.nx (behaviour-preserving relocation).
 */

import * as bb from "std:bytebuffer"
import * as naming from "src/ir/support/naming.nx"
import {
  TypeExpr,
  TyUserDefined,
  TyArrow,
  TyRow,
  TyVar,
  TyHandler,
  NamedType,
  RecordDef
} from "src/types/type_expr.nx"
import {
  HirFunction,
  HirParam,
  HirCap,
  HirCapMethod,
  HirHandlerBindingEntry,
  HirHandlerBinding,
  HirHandlerArm,
  ExceptionGroupEntry
} from "src/ir/hir/types.nx"
import { Span } from "src/types/span.nx"
import { TypeError, TypeMismatch, MultiArgSuspendArm } from "src/typecheck/errors.nx"
import { CheckState, EnvEntry } from "src/typecheck/types.nx"
import * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as tcwf from "src/typecheck/tcwf.nx"
import { str_list_contains, convert_ud_to_var, convert_named_types } from "src/typecheck/check/occurs.nx"
import { hir_params_to_named_types } from "src/typecheck/check/registration.nx"
import { SubstEntry } from "src/typecheck/types.nx"
import * as str from "std:str"
import * as list from "std:list"

// ─── Register handler bindings ──────────────────────────────────────────────

export let register_handler_bindings = fn (
  state: CheckState,
  hbs: [ HirHandlerBindingEntry ],
  caps: [ HirCap ],
  exception_groups: [ ExceptionGroupEntry ],
  tdefs: [ RecordDef ]
) -> CheckState throws { TypeError } do
  match hbs do
    | [] -> return state
    | HirHandlerBindingEntry(
      name: n,
      binding: HirHandlerBinding(cap_name: pname, requires: handler_req, arms)
    ) :: rest ->
      let handler_type = TyHandler(name: pname, requires: handler_req)
      let env1 = tctypes.env_insert(
        env: tctypes.state_env(state),
        name: n,
        scheme: tctypes.mono(typ: handler_type)
      )
      let prefix_len = naming.handler_prefix_len(handler_name: n)
      // T-CapCall require-row enforcement: the env'd cap-method arrow must carry
      // the method's env'd require row `{cap_name} ∪ α` (spec §T-CapCall), not a
      // hardcoded `{}`. Thread the full caps list (includes imports) so the
      // per-method α can be resolved from its HirCapMethod declaration.
      let cap_methods = lookup_cap_methods_tw(caps, cap_name: pname)
      // Generic caps register their call-site method schemes polymorphically from
      // the cap declaration (registration.register_cap_method_schemes). Suppress
      // the monomorphic handler-arm registration for them so the poly scheme is
      // the one that resolves at call sites; otherwise this (concrete) arm scheme
      // would shadow it and defeat per-call-site instantiation.
      let cap_is_generic = match lookup_cap_type_params(caps, cap_name: pname) do
        | [] -> false
        | _ -> true
      end
      // Monomorphic caps: register the arm scheme directly under `<cap>.<method>`
      // (the call-site scheme). Generic caps: the plain key stays owned by the
      // poly `forall T` scheme (registration.register_cap_method_schemes); instead
      // record THIS handler binding's concrete instantiation under a per-handler
      // key so `inject <handler>` can shadow the poly scheme with it (soundness —
      // prevents a generic call at one type under a handler for another type).
      let env2 = if cap_is_generic then
          register_handler_methods(
            env: env1, cap_name: pname, prefix_len, arms, cap_methods,
            key_prefix: handler_instance_key_prefix(handler_name: n))
        else register_handler_methods(env: env1, cap_name: pname, prefix_len, arms, cap_methods, key_prefix: "") end
      // Per-arm wfThrow at the T-Handler introduction site: each arm body
      // is a HirFunction whose `throw_row` was preserved through HIR, so a
      // typo like `throws { BogusVariant }` on an arm is rejected here.
      // The arm's `requires` row is currently empty (handler arms don't
      // declare per-arm caps), so wfCap there is a no-op until that
      // syntax exists.
      check_handler_arm_throw_rows(arms, state, exception_groups, tdefs)
      // T-Handler arm signature cross-validation: validate throw_row, ret_type,
      // and params of each arm against the corresponding cap method declaration.
      validate_handler_arm_throw_rows(handler_name: n, cap_name: pname, arms, caps, prefix_len)
      let st1 = tctypes.state_with_env(state, env: env2)
      return register_handler_bindings(state: st1, hbs: rest, caps, exception_groups, tdefs)
  end
end

let check_handler_arm_throw_rows = fn (
  arms: [ HirHandlerArm ],
  state: CheckState,
  exception_groups: [ ExceptionGroupEntry ],
  tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(
      arm: HirFunction(
        name: _,
        type_params: arm_tps,
        params: arm_params,
        ret_type: _,
        throw_row: tw,
        body: _,
        span: sp,
        file: _,
        requires: req
      ),
      cont_binder: _
    ) :: rest ->
      tcwf.wf_cap(row: req, caps: [], span: sp)
      tcwf.wf_throw(
        row: tw,
        vidx_: tctypes.state_variant_index(state),
        groups: exception_groups,
        span: sp,
        type_params: arm_tps
      )
      // T-Handler wfRef at parameter annotation sites
      // (spec §mutable-reference-well-formedness / wfRef).
      let arm_param_types = hir_params_to_named_types(params: arm_params)
      tcwf.enforce_wf_ref_params(params: arm_param_types, span: sp, tdefs)
      return check_handler_arm_throw_rows(arms: rest, state, exception_groups, tdefs)
  end
end

// ─── T-Handler arm/cap signature cross-validation ───────────────────────────
// Spec T-Handler: each arm's throw_row, params, and ret_type must match the
// corresponding cap method's declaration.
//
// We use structural type equality (subst.type_eq) rather than unification.

let validate_handler_arm_throw_rows = fn (
  handler_name: string,
  cap_name: string,
  arms: [ HirHandlerArm ],
  caps: [ HirCap ],
  prefix_len: i64
) -> unit throws { TypeError } do
  let cap_methods = lookup_cap_methods_tw(caps, cap_name)
  let cap_tps = lookup_cap_type_params(caps, cap_name)
  return validate_arm_sig_go(handler_name, cap_name, arms, cap_methods, prefix_len, cap_tps)
end

// ─── Generic cap instantiation (cap Foo<T>) ─────────────────────────────────
// Given a generic cap method declaration (with type params appearing as
// `TyUserDefined name` in its param/ret/throw slots) and a concrete handler arm
// signature, derive the param→concrete substitution from the arm and apply it
// to the method, so the structural equality checks in validate_arm_sig_go see a
// fully-instantiated method. The handler arm is therefore the instantiation
// site: `handler Yield do fn emit(v: i64) ...` instantiates `Yield<T>` at i64.

/** Collect `TyVar name → concrete` bindings by structurally matching a pattern
 *  type (cap-decl method type, type params already converted to TyVar) against a
 *  concrete arm type. Unknown / mismatched shapes contribute no binding; the
 *  downstream type_eq check rejects a genuinely wrong arm. */
let collect_tp_bindings = fn (
  pat: TypeExpr, concrete: TypeExpr, acc: [ SubstEntry ]
) -> [ SubstEntry ] do
  match pat do
    | TyVar(name: nm) -> return SubstEntry(var: nm, typ: concrete) :: acc
    | TyList(elem: pe) ->
      match concrete do
        | TyList(elem: ce) -> return collect_tp_bindings(pat: pe, concrete: ce, acc)
        | _ -> return acc
      end
    | TyArray(elem: pe) ->
      match concrete do
        | TyArray(elem: ce) -> return collect_tp_bindings(pat: pe, concrete: ce, acc)
        | _ -> return acc
      end
    | TyRef(inner: pi) ->
      match concrete do
        | TyRef(inner: ci) -> return collect_tp_bindings(pat: pi, concrete: ci, acc)
        | _ -> return acc
      end
    | TyBorrow(inner: pi) ->
      match concrete do
        | TyBorrow(inner: ci) -> return collect_tp_bindings(pat: pi, concrete: ci, acc)
        | _ -> return acc
      end
    | TyLinear(inner: pi) ->
      match concrete do
        | TyLinear(inner: ci) -> return collect_tp_bindings(pat: pi, concrete: ci, acc)
        | _ -> return acc
      end
    | _ -> return acc
  end
end

/** Collect bindings from two parallel NamedType lists (pattern vs concrete). */
let collect_tp_bindings_nts = fn (
  pats: [ NamedType ], concretes: [ NamedType ], acc: [ SubstEntry ]
) -> [ SubstEntry ] do
  match pats do
    | [] -> return acc
    | NamedType(name: _, typ: pt) :: prest ->
      match concretes do
        | [] -> return acc
        | NamedType(name: _, typ: ct) :: crest ->
          let acc1 = collect_tp_bindings(pat: pt, concrete: ct, acc)
          return collect_tp_bindings_nts(pats: prest, concretes: crest, acc: acc1)
      end
  end
end

/** Rebuild [HirParam] from substituted NamedTypes, preserving the original
 *  params' labels / names / sigils (only the type slot changes). */
let named_types_to_hir_params = fn (nts: [ NamedType ], orig: [ HirParam ]) -> [ HirParam ] do
  match nts do
    | [] -> return []
    | NamedType(name: _, typ: t) :: nrest ->
      match orig do
        | [] -> return []
        | HirParam(label: l, name: nm, sigil: sg, typ: _) :: orest ->
          let rest1 = named_types_to_hir_params(nts: nrest, orig: orest)
          return HirParam(label: l, name: nm, sigil: sg, typ: t) :: rest1
      end
  end
end

/** Instantiate a (possibly generic) cap method against a concrete handler arm.
 *  For monomorphic caps (cap_tps == []) the method is returned unchanged. */
let instantiate_cap_method_for_arm = fn (
  method: HirCapMethod,
  cap_tps: [ string ],
  arm_params: [ HirParam ],
  arm_ret: TypeExpr,
  arm_tw: TypeExpr,
  kb: Option<string>
) -> HirCapMethod do
  match cap_tps do
    | [] -> return method
    | _ ->
      let HirCapMethod(
        name: mname, requires: mreq, span: msp, throw_row: mtw,
        typ_params: mparams, typ_ret: mret
      ) = method
      // The arm's user params exclude the continuation binder (last param).
      let arm_user_params = match kb do
        | Some(_) -> list_init(xs: arm_params)
        | None -> arm_params
      end
      // Convert the cap-decl method types' type params (TyUserDefined name) to
      // TyVar once, via the proven occurs/subst helpers (same path generic fns use).
      let mparam_nts = hir_params_to_named_types(params: mparams)
      let mparam_nts_var = convert_named_types(nts: mparam_nts, vars: cap_tps)
      let mret_var = convert_ud_to_var(typ: mret, vars: cap_tps)
      let mtw_var = convert_ud_to_var(typ: mtw, vars: cap_tps)
      // Derive bindings from param types and the return type against the arm.
      let arm_nts = hir_params_to_named_types(params: arm_user_params)
      let b0 = collect_tp_bindings_nts(pats: mparam_nts_var, concretes: arm_nts, acc: [])
      let bindings = collect_tp_bindings(pat: mret_var, concrete: arm_ret, acc: b0)
      // Apply the substitution to the converted method types.
      let new_param_nts = subst.apply_named_types(subst: bindings, nts: mparam_nts_var)
      let new_params = named_types_to_hir_params(nts: new_param_nts, orig: mparams)
      let new_ret = subst.subst_apply(subst: bindings, typ: mret_var)
      let new_tw = subst.subst_apply(subst: bindings, typ: mtw_var)
      return HirCapMethod(
        name: mname, requires: mreq, span: msp, throw_row: new_tw,
        typ_params: new_params, typ_ret: new_ret
      )
  end
end

let validate_arm_sig_go = fn (
  handler_name: string,
  cap_name: string,
  arms: [ HirHandlerArm ],
  cap_methods: [ HirCapMethod ],
  prefix_len: i64,
  cap_tps: [ string ]
) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(
      arm: HirFunction(
        name: n,
        type_params: _,
        params: arm_params,
        ret_type: arm_ret,
        throw_row: arm_tw,
        body: _,
        span: sp,
        file: _,
        requires: _
      ),
      cont_binder: kb
    ) :: rest ->
      let original = str.substring(s: n, start: prefix_len, len: str.length(s: n) - prefix_len)
      match lookup_cap_method(methods: cap_methods, name: original) do
        | None ->
          // Cap method not found: already caught by validate_handler_arm_sets; skip.
          return validate_arm_sig_go(handler_name, cap_name, arms: rest, cap_methods, prefix_len, cap_tps)
        | Some(val: method0) ->
          // GENERIC CAP INSTANTIATION (`cap Foo<T>` + `handler Foo do fn m(v: i64) ...`):
          // the handler arm signature IS the instantiation. Derive the cap's type
          // params from the concrete arm signature, then substitute into the
          // cap-method declaration before the structural equality checks below.
          // The arm's concrete types thus drive `T := i64` (or `:= string`, ...),
          // and a single generic cap can be handled at any element type without a
          // separate `<i64>` annotation. Monomorphic caps (cap_tps == []) leave
          // the method unchanged.
          let method = instantiate_cap_method_for_arm(
            method: method0, cap_tps, arm_params, arm_ret, arm_tw, kb)
          let HirCapMethod(
            name: _,
            requires: _,
            span: _,
            throw_row: method_tw,
            typ_params: method_params,
            typ_ret: method_ret
          ) = method
          // Validate throw_row.
          if !subst.type_eq(a: arm_tw, b: method_tw) then
            let detail = bb.concat(parts: [
              "handler '", handler_name, "' arm '", original,
              "' throws row does not match cap '", cap_name,
              "' method declaration (T-Handler: arm throws must equal cap method throws)"
            ])
            throw TypeMismatch(func_name: handler_name, detail, span: sp)
          end
          // Validate ret_type.
          if !subst.type_eq(a: arm_ret, b: method_ret) then
            let detail = bb.concat(parts: [
              "handler '", handler_name, "' arm '", original,
              "' return type does not match cap '", cap_name,
              "' method declaration (T-Handler: arm return type must equal cap method return type)"
            ])
            throw TypeMismatch(func_name: handler_name, detail, span: sp)
          end
          // Validate params.
          // Strip the continuation binder (last param) when present.
          let user_params = match kb do
            | Some(_) -> list_init(xs: arm_params)
            | None -> arm_params
          end
          let arm_param_nts = hir_params_to_named_types(params: user_params)
          let method_param_nts = hir_params_to_named_types(params: method_params)
          if !check_named_types_eq(a: arm_param_nts, b: method_param_nts) then
            let detail = bb.concat(parts: [
              "handler '", handler_name, "' arm '", original,
              "' parameter types do not match cap '", cap_name,
              "' method declaration (T-Handler: arm params must equal cap method params)"
            ])
            throw TypeMismatch(func_name: handler_name, detail, span: sp)
          end
          // A `with @k` arm lowers to a wasm `suspend`, which packs exactly one
          // payload value across the suspend/resume boundary. A cap method with
          // two or more parameters therefore has no defined multi-arg suspend
          // ABI. Reject here at typecheck (E5002) so MIR build never reaches
          // `throw MirMultiArgSuspend` for well-typed input — that MIR throw
          // unwinds across the compiler's own stack-switching resume frame and
          // hits an upstream wasmtime fiber-stack bug, crashing the compiler.
          let is_kont_arm = match kb do | Some(_) -> true | None -> false end
          let method_arg_count = list.length(xs: method_params)
          if is_kont_arm && method_arg_count > 1 then
            throw MultiArgSuspendArm(
              cap_name,
              method_name: original,
              arg_count: method_arg_count,
              span: sp
            )
          end
          return validate_arm_sig_go(handler_name, cap_name, arms: rest, cap_methods, prefix_len, cap_tps)
      end
  end
end

let lookup_cap_methods_tw = fn (caps: [ HirCap ], cap_name: string) -> [ HirCapMethod ] do
  match caps do
    | [] -> return []
    | HirCap(name: n, methods) :: rest ->
      if n == cap_name then return methods end
      return lookup_cap_methods_tw(caps: rest, cap_name)
  end
end

/** type_params of the named cap (empty for monomorphic caps / not found). */
let lookup_cap_type_params = fn (caps: [ HirCap ], cap_name: string) -> [ string ] do
  match caps do
    | [] -> return []
    | HirCap(name: n, type_params: tps, methods: _) :: rest ->
      if n == cap_name then return tps end
      return lookup_cap_type_params(caps: rest, cap_name)
  end
end

let lookup_cap_method = fn (methods: [ HirCapMethod ], name: string) -> Option<HirCapMethod> do
  match methods do
    | [] -> return None
    | HirCapMethod(
      name: n,
      requires: mreq,
      span: msp,
      throw_row: mtw,
      typ_params: mp,
      typ_ret: mr
    ) :: rest ->
      if n == name then return Some(val: HirCapMethod(name: n, requires: mreq, span: msp, throw_row: mtw, typ_params: mp, typ_ret: mr)) end
      return lookup_cap_method(methods: rest, name)
  end
end

// Structural equality on NamedType lists: same length, same labels, same types.
let check_named_types_eq = fn (a: [ NamedType ], b: [ NamedType ]) -> bool do
  match a do
    | [] -> return if let [] = b then true else false end
    | NamedType(name: na, typ: ta) :: ra ->
      match b do
        | [] -> return false
        | NamedType(name: nb, typ: tb) :: rb ->
          if na == nb && subst.type_eq(a: ta, b: tb) then
            return check_named_types_eq(a: ra, b: rb)
          end
          return false
      end
  end
end

/** Close the implicit-open tail of a cap-method throw row. An absent `throws`
 *  clause parses to `TyRow([], Some(TyVar("__implicit")))`; for a cap method —
 *  a declaration site whose published contract is the cap signature — that
 *  means "raises nothing", so strip the open tail to a closed row while keeping
 *  any concrete labels. Already-closed rows and genuine inference-variable tails
 *  pass through unchanged. Kept in sync with check.nx::close_implicit_throw_row.
 */
let close_implicit_throw_row = fn (row: TypeExpr) -> TypeExpr do
  match row do
    | TyRow(types: ts, rest: Some(val: TyVar(name: nm))) ->
      if nm == "__implicit" then return TyRow(types: ts, rest: None) end
      return row
    | _ -> return row
  end
end

let register_handler_methods = fn (
  env: [ EnvEntry ],
  cap_name: string,
  prefix_len: i64,
  arms: [ HirHandlerArm ],
  cap_methods: [ HirCapMethod ],
  // Env-key prefix. "" registers under the plain `<cap>.<method>` key (the
  // monomorphic-cap path, where the handler-arm scheme IS the call-site scheme).
  // For GENERIC caps the plain key is suppressed (the poly `forall T` scheme owns
  // it); instead we register the concrete arm-derived scheme under a
  // per-handler-binding key (`__handlerinst::<handler>::`) so that an `inject`
  // of that specific handler can shadow `<cap>.<method>` with THIS handler's
  // instantiation. Ties the generic call site to the injected handler (soundness;
  // a mismatched call type vs handler type then fails to unify → rejected).
  key_prefix: string
) -> [ EnvEntry ] do
  match arms do
    | [] -> return env
    | HirHandlerArm(
      arm: HirFunction(name: n, type_params: _, params, ret_type: ret, throw_row: tw, _),
      cont_binder: kb
    ) :: rest ->
      let original_name = str.substring(s: n, start: prefix_len, len: str.length(s: n) - prefix_len)
      let method_name = bb.concat(parts: [ key_prefix, cap_name, ".", original_name ])
      let user_params = match kb do
        | Some(_) -> list_init(xs: params)
        | None -> params
      end
      let param_types = hir_params_to_named_types(params: user_params)
      // T-CapCall: env'd require row for this method is `{cap_name} ∪ α`.
      let method_requires = build_cap_method_requires(cap_name, method_name: original_name, cap_methods)
      // A cap method is a declaration site: an absent `throws` clause means the
      // method publishes no exceptions, so the env'd arrow must carry a CLOSED
      // throw row rather than the legacy open `__implicit` tail. Otherwise a
      // cap call from a `throws {}` context (e.g. another handler arm body whose
      // row is pinned closed) is spuriously rejected as "callee may throw
      // anything". This mirrors the arm-body pinning in check.nx
      // (close_implicit_throw_row) and the cap-method side of the same contract.
      let method_throw_row = close_implicit_throw_row(row: tw)
      let arrow = TyArrow(
        params: param_types, ret,
        requires: method_requires,
        throw_row: method_throw_row
      )
      let env1 = tctypes.env_insert(env, name: method_name, scheme: tctypes.mono(typ: arrow))
      return register_handler_methods(env: env1, cap_name, prefix_len, arms: rest, cap_methods, key_prefix)
  end
end

/** Env-key prefix under which a generic-cap handler binding's CONCRETE
 *  arm-derived call-site schemes are stored. An `inject <handler>` then copies
 *  these into the plain `<cap>.<method>` key inside the inject body, shadowing
 *  the polymorphic `forall T` scheme with the specific injected instantiation. */
export let handler_instance_key_prefix = fn (handler_name: string) -> string do
  return bb.concat(parts: [ "__handlerinst::", handler_name, "::" ])
end

/** Inside an `inject` body, shadow each injected generic-cap handler's method
 *  call-site scheme with the CONCRETE instantiation recorded for that handler
 *  binding (under `handler_instance_key_prefix`). This binds a generic-cap call
 *  (`Box.wrap(...)`) to the element type of the handler actually in scope, so a
 *  call at one type under a handler for a DIFFERENT type fails to unify and is
 *  rejected (soundness: prevents the generic-cap type confusion / OOB).
 *  Monomorphic-cap handlers have no `__handlerinst::` entries → no-op for them. */
export let apply_injected_handler_instances = fn (
  env: [ EnvEntry ],
  handler_names: [ string ]
) -> [ EnvEntry ] do
  match handler_names do
    | [] -> return env
    | h :: rest ->
      let prefix = handler_instance_key_prefix(handler_name: h)
      let env1 = shadow_handler_instances(env, prefix, src: env)
      return apply_injected_handler_instances(env: env1, handler_names: rest)
  end
end

/** Scan `src` for entries keyed `<prefix><cap>.<method>` and re-insert each under
 *  the plain `<cap>.<method>` key in `env`, shadowing any existing (poly) scheme.
 *  `src` is the original env (read-only) so newly-prepended entries aren't rescanned. */
let shadow_handler_instances = fn (
  env: [ EnvEntry ],
  prefix: string,
  src: [ EnvEntry ]
) -> [ EnvEntry ] do
  match src do
    | [] -> return env
    | EnvEntry(name: k, scheme: sc) :: rest ->
      if str_has_prefix(s: k, prefix) then
        let plain = str.substring(s: k, start: str.length(s: prefix), len: str.length(s: k) - str.length(s: prefix))
        let env1 = tctypes.env_insert(env, name: plain, scheme: sc)
        return shadow_handler_instances(env: env1, prefix, src: rest)
      end
      return shadow_handler_instances(env, prefix, src: rest)
  end
end

let str_has_prefix = fn (s: string, prefix: string) -> bool do
  let pl = str.length(s: prefix)
  if str.length(s: s) < pl then return false end
  return str.substring(s, start: 0, len: pl) == prefix
end

/** Build the env'd require row for a cap method: {cap_name} ∪ α (spec §T-CapCall).
 *  α is looked up from the matching HirCapMethod; absent declarations default to
 *  an empty closed row. cap_name is the bare cap identifier (T-Inject extends ρ_q
 *  with bare cap names via base_name_of), so the qualifier is stripped before the
 *  row entry is emitted. */
let build_cap_method_requires = fn (
  cap_name: string,
  method_name: string,
  cap_methods: [ HirCapMethod ]
) -> TypeExpr do
  let alpha = match lookup_cap_method(methods: cap_methods, name: method_name) do
    | Some(val: HirCapMethod(name: _, requires: r, span: _, throw_row: _, typ_params: _, typ_ret: _)) -> r
    | None -> TyRow(types: [], rest: None)
  end
  let bare = tcwf.base_name_of(qualified: cap_name)
  let cap_entry = TyUserDefined(name: bare, args: [])
  match alpha do
    | TyRow(types: ts, rest: tail) ->
      if cap_list_contains_name(name: bare, ts) then return alpha end
      return TyRow(types: cap_entry :: ts, rest: tail)
    | _ -> return TyRow(types: [ cap_entry ], rest: None)
  end
end

let cap_list_contains_name = fn (name: string, ts: [ TypeExpr ]) -> bool do
  match ts do
    | [] -> return false
    | TyUserDefined(name: n, args: _) :: rest ->
      if n == name then return true end
      return cap_list_contains_name(name, ts: rest)
    | _ :: rest -> return cap_list_contains_name(name, ts: rest)
  end
end

let list_init = fn (xs: [ HirParam ]) -> [ HirParam ] do
  match xs do
    | [] | _ :: [] -> return []
    | x :: rest -> return x :: list_init(xs: rest)
  end
end

// ─── T-Handler arm/method 1-1 correspondence ────────────────────────────────
// Spec (type-system-formal.md §T-Handler):
//   { ℓ_j | j ∈ J } = { ℓ | (ℓ = e) ∈ overline{ℓ_j = e_j} }
// The handler literal must supply exactly the methods declared on its cap —
// no missing arm, no extra arm. The earlier impl in this file registered arms
// (register_handler_bindings / register_handler_methods) and type-checked each
// arm body individually (check_handler_arm_bodies) without ever comparing the
// supplied arm-name set against methods(cap). That left a missing arm silently
// admitted (and exposed at runtime as undefined dispatch) and an extra arm
// silently admitted as dead, unroutable code.
//
// We validate set-equality at the top of check_program, before any arm
// signature/body work happens, so a structurally incomplete handler is rejected
// with a TypeMismatch keyed off the handler binding's first failing arm span
// (or the first arm's span if the failure is "missing arm").

/** Spec §T-Handler arm/method 1-1 correspondence for an inline handler
 *  expression (arms carry bare method names, not mangled __handler_* names).
 *  Called from infer_expr's Handler case so missing/extra arms are rejected
 *  at the construction site regardless of whether the handler is top-level or
 *  written inside a function body.
 */
export let validate_inline_handler_arm_set = fn (
  caps: [ HirCap ],
  cap_name: string,
  handler_name: string,
  arms: [ HirHandlerArm ],
  span: Span
) -> unit throws { TypeError } do
  let cap_methods = lookup_cap_methods(caps, cap_name)
  // prefix_len = 0: inline arm names are bare method names (no mangling yet).
  let supplied = collect_arm_original_names(arms, prefix_len: 0)
  let arm_span = first_arm_span(arms)
  // Use `span` (the Handler expression span) when there are no arms at all.
  let err_span = match arms do | [] -> span | _ -> arm_span end
  check_no_extra_arm(handler_name, cap_name, supplied, cap_methods, arms, prefix_len: 0)
  check_no_missing_arm(handler_name, cap_name, supplied, cap_methods, arm_span: err_span)
end

/** Spec §T-Handler arm/method 1-1 correspondence: rejects
 *  handlers that supply an extra arm or omit a declared cap method. Public
 *  for direct unit-test against handcrafted (caps, hbs) pairs without
 *  building a full HirProgram.
 */
export let validate_handler_arm_sets = fn (
  caps: [ HirCap ],
  hbs: [ HirHandlerBindingEntry ]
) -> unit throws { TypeError } do
  match hbs do
    | [] -> return ()
    | HirHandlerBindingEntry(
      name: hname,
      binding: HirHandlerBinding(cap_name: pname, requires: _, arms)
    ) :: rest ->
      let cap_methods = lookup_cap_methods(caps, cap_name: pname)
      let prefix_len = naming.handler_prefix_len(handler_name: hname)
      let supplied = collect_arm_original_names(arms, prefix_len)
      let arm_span = first_arm_span(arms)
      check_no_extra_arm(
        handler_name: hname,
        cap_name: pname,
        supplied,
        cap_methods,
        arms,
        prefix_len
      )
      check_no_missing_arm(handler_name: hname, cap_name: pname, supplied, cap_methods, arm_span)
      return validate_handler_arm_sets(caps, hbs: rest)
  end
end

let lookup_cap_methods = fn (caps: [ HirCap ], cap_name: string) -> [ string ] do
  match caps do
    | [] -> return []
    | HirCap(name: n, methods) :: rest ->
      if n == cap_name then return cap_method_names(methods) end
      return lookup_cap_methods(caps: rest, cap_name)
  end
end

let cap_method_names = fn (methods: [ HirCapMethod ]) -> [ string ] do
  match methods do
    | [] -> return []
    | HirCapMethod(
      name: n,
      requires: _,
      span: _,
      throw_row: _,
      typ_params: _,
      typ_ret: _
    ) :: rest -> return n :: cap_method_names(methods: rest)
  end
end

let collect_arm_original_names = fn (arms: [ HirHandlerArm ], prefix_len: i64) -> [ string ] do
  match arms do
    | [] -> return []
    | HirHandlerArm(arm: HirFunction(name: n, _), cont_binder: _) :: rest ->
      let original = str.substring(s: n, start: prefix_len, len: str.length(s: n) - prefix_len)
      return original :: collect_arm_original_names(arms: rest, prefix_len)
  end
end

let first_arm_span = fn (arms: [ HirHandlerArm ]) -> Span do
  match arms do
    | [] -> return Span(offset: 0, line: 0, col: 0)
    | HirHandlerArm(
      arm: HirFunction(
        name: _,
        type_params: _,
        params: _,
        ret_type: _,
        throw_row: _,
        body: _,
        span,
        file: _
      ),
      cont_binder: _
    ) :: _ -> return span
  end
end

let check_no_extra_arm = fn (
  handler_name: string,
  cap_name: string,
  supplied: [ string ],
  cap_methods: [ string ],
  arms: [ HirHandlerArm ],
  prefix_len: i64
) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(
      arm: HirFunction(
        name: n,
        type_params: _,
        params: _,
        ret_type: _,
        throw_row: _,
        body: _,
        span,
        file: _
      ),
      cont_binder: _
    ) :: rest ->
      let original = str.substring(s: n, start: prefix_len, len: str.length(s: n) - prefix_len)
      if str_list_contains(xs: cap_methods, s: original) then
        return check_no_extra_arm(
          handler_name,
          cap_name,
          supplied,
          cap_methods,
          arms: rest,
          prefix_len
        )
      end
      let detail = bb.concat(parts: [
        "handler '", handler_name, "' for cap '", cap_name,
        "' supplies arm '", original,
        "' which is not declared as a method of cap '", cap_name,
        "' (T-Handler arm/method 1-1 correspondence: no extra arm)"
      ])
      throw TypeMismatch(func_name: handler_name, detail, span)
  end
end

let check_no_missing_arm = fn (
  handler_name: string,
  cap_name: string,
  supplied: [ string ],
  cap_methods: [ string ],
  arm_span: Span
) -> unit throws { TypeError } do
  match cap_methods do
    | [] -> return ()
    | m :: rest ->
      if str_list_contains(xs: supplied, s: m) then
        return check_no_missing_arm(handler_name, cap_name, supplied, cap_methods: rest, arm_span)
      end
      let detail = bb.concat(parts: [
        "handler '", handler_name, "' for cap '", cap_name,
        "' is missing arm for declared method '", m,
        "' (T-Handler arm/method 1-1 correspondence: no missing arm)"
      ])
      throw TypeMismatch(func_name: handler_name, detail, span: arm_span)
  end
end
