/**
 * typecheck/infer/literals: leaf inference rules — literals, variables, borrows.
 *
 * Extracted from src/typecheck/infer.nx. These four entry
 * points are leaves (no call-back into infer_expr) and so escape the
 * infer_stmt ↔ infer_expr cycle that pins the rest of the module together.
 *
 * Also hosts `instantiate_scheme` and `freshen_type_params`: scheme
 * instantiation is invoked from infer_variable / infer_call / infer_constructor
 * and the pattern-bind path, but the work itself is pure — no expression
 * recursion involved.
 */

import { Span } from "src/syntax/token.nx"
import {
  TypeExpr, TyIntLit, TyFloatLit, TyBool, TyChar, TyString, TyUnit,
  TyRef, TyLinear, TyLazy, TyBorrow,
  Literal, LitInt, LitFloat, LitBool, LitChar, LitString, LitUnit,
  Sigil, SigilImmutable, SigilMutable
} from "src/syntax/ast.nx"
import {
  SubstEntry, Scheme, CheckState, FreshResult, EnvEntry,
  InferExprResult, InferExprOk, InferExprErr
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import { TypeError, UnknownVariable } from "src/typecheck/errors.nx"
import { Option, Some, None } from "std:option"
import { suggest_names } from "src/diagnostics/levenshtein.nx"

/** T-Lit: assign each literal its primitive type (TyIntLit / TyFloatLit / TyBool / TyChar / TyString / TyUnit) — width defaulting is deferred to later unification. */
export let infer_literal = fn (
  state: CheckState,
  lit: Literal,
  span: Span
) -> InferExprResult throws { TypeError } do
  let typ = match lit do
    | LitInt(_) -> TyIntLit
    | LitFloat(_) -> TyFloatLit
    | LitBool(_) -> TyBool
    | LitChar(_) -> TyChar
    | LitString(_) -> TyString
    | LitUnit -> TyUnit
  end
  return InferExprOk(state, subst: subst.subst_empty(), typ)
end

/** Result of `instantiate_scheme`: the threaded `state` (consumed fresh-var counter) and the freshly-instantiated `typ`. */
export type InstantiateResult = InstantiateResult(state: CheckState, typ: TypeExpr)

/** Result of allocating fresh type vars for a scheme's bound params; `param_subst` maps each param name to a fresh `?α`. */
export type FreshenResult = FreshenResult(state: CheckState, param_subst: [ SubstEntry ])

/** Allocate one fresh type var per param name, returning a substitution mapping `[α₁,…,αₙ]` to fresh `?β`s. */
export let freshen_type_params = fn (
  state: CheckState,
  params: [ string ]
) -> FreshenResult throws { TypeError } do
  match params do
    | [] -> return FreshenResult(state, param_subst: subst.subst_empty())
    | p :: rest ->
      let FreshResult(state: st1, typ: tv) = tctypes.tc_fresh_var(state)
      let FreshenResult(state: st2, param_subst: ps) = freshen_type_params(state: st1, params: rest)
      return FreshenResult(state: st2, param_subst: SubstEntry(var: p, typ: tv) :: ps)
  end
end

/** T-Var instantiation: freshen the scheme's bound vars and apply the resulting substitution to its body. */
export let instantiate_scheme = fn (
  state: CheckState,
  scheme: Scheme
) -> InstantiateResult throws { TypeError } do
  match scheme do
    | Scheme(vars: [], typ: t) -> return InstantiateResult(state, typ: t)
    | Scheme(vars: vs, typ: t) ->
      let fr = freshen_type_params(state, params: vs)
      let FreshenResult(state: st1, param_subst: psubst) = fr
      return InstantiateResult(state: st1, typ: subst.subst_apply(subst: psubst, typ: t))
  end
end

/** Collect all binding names from the environment. */
let env_names = fn (env: [ EnvEntry ]) -> [ string ] do
  return env_names_go(env, acc: [])
end

let env_names_go = fn (env: [ EnvEntry ], acc: [ string ]) -> [ string ] do
  match env do
    | [] -> return acc
    | EnvEntry(name: n, scheme: _) :: rest ->
      return env_names_go(env: rest, acc: n :: acc)
  end
end

/** T-Var: look `name` up in the env, instantiate its scheme, and apply T-DerefRef when the source sigil is `~` (mutable-ref read). Errors on unbound names or `~` on non-ref bindings. */
export let infer_variable = fn (
  state: CheckState,
  name: string,
  sigil: Sigil,
  span: Span
) -> InferExprResult throws { TypeError } do
  match tctypes.env_lookup(env: tctypes.state_env(state), name) do
    | Some(val: sch) ->
      let InstantiateResult(state: st1, typ: t) = instantiate_scheme(state, scheme: sch)
      // T-DerefRef: `~x` at use site reads through the mutable
      // cell, yielding the inner value type. A `~`-sigil applied to a non-Ref
      // binding is a modality mismatch.
      if let SigilMutable = sigil then
        match t do
          | TyRef(inner: i) -> return InferExprOk(state: st1, subst: subst.subst_empty(), typ: i)
          | _ -> return InferExprErr(
            message: "cannot dereference '~" ++ name ++ "': binding is not a mutable ref",
            span
          )
        end
      end
      return InferExprOk(state: st1, subst: subst.subst_empty(), typ: t)
    | None ->
      let candidates = env_names(env: tctypes.state_env(state))
      let sugs = suggest_names(typo: name, candidates)
      throw UnknownVariable(name, suggestions: sugs, span)
  end
end

/** T-Borrow: type `&name` by looking up the binding, stripping any outer linear / lazy / borrow / ref wrapper, and re-wrapping in TyBorrow.
 *
 * Enforces the spec premise `x :^ω`: only unrestricted (q = ω) bindings may be
 * borrowed at non-argument positions. Linear (`%σ`) and lazy (`@σ`) bindings
 * have q = 1 and are rejected here.
 *
 * The argument-position carve-out (T-App-BorrowLin) is handled by the caller
 * (`check_call_args_walk`) which bypasses `infer_borrow` and calls
 * `infer_borrow_arg_position` instead when the argument node is syntactically
 * `&x` and the binding may be linear.
 */
export let infer_borrow = fn (
  state: CheckState,
  name: string,
  span: Span
) -> InferExprResult throws { TypeError } do
  match infer_variable(state, name, sigil: SigilImmutable, span) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s, typ: t) ->
      // T-Borrow x:^ω premise: reject linear (q = 1) and lazy (q = 1) bindings.
      // A `%σ` or `@σ` binding borrowed outside argument position would create a
      // long-lived `&σ` value with no natural discharge point, violating the
      // ownership model. See spec §T-Borrow.
      match t do
        | TyLinear(_) ->
          return InferExprErr(
            message: "cannot borrow '" ++ name ++ "': binding is linear (q = 1); T-Borrow requires x :^ω. Borrowing a linear binding is only permitted in argument position (e.g. `f(p: &" ++ name ++ ")`), where T-App discharges the borrow on return. See spec type-system-formal.md §T-Borrow.",
            span
          )
        | TyLazy(_) ->
          return InferExprErr(
            message: "cannot borrow '" ++ name ++ "': binding is lazy/one-shot (q = 1); T-Borrow requires x :^ω. Borrowing a lazy binding is only permitted in argument position. See spec type-system-formal.md §T-Borrow.",
            span
          )
        | _ -> ()
      end
      // Strip Linear/Borrow/Ref wrapper, then wrap in Borrow.
      // stripBorrow(τ) per spec §stripBorrow: τ ∈ {%σ, &σ, ~σ} -> σ, else τ
      // (identity). Borrowing a `~τ` binding yields `&τ` of the cell's
      // contents, not `&(~τ)`. stripBorrow deliberately does NOT peel @
      // (thunk): a thunk's result does not exist until T-Force forces it, so
      // a thunk must be forced (`let v = @x`) before its value can be
      // borrowed. (This expression-position path already rejected `@σ`
      // bindings above via the x:^ω premise, so the @ case is unreachable
      // here; not peeling it keeps stripBorrow coherent with the spec.)
      let inner = match t do
        | TyLinear(inner: u) | TyBorrow(inner: u) | TyRef(inner: u) -> u
        | _ -> t
      end
      return InferExprOk(state: st1, subst: s, typ: TyBorrow(inner))
  end
end

/** T-App-BorrowLin (argument-position carve-out): type `&name` in argument position
 * without enforcing T-Borrow's `x :^ω` premise.
 *
 * When a call argument is syntactically `&x` and the parameter expects `&σ`,
 * the borrow is discharged on call return — linear `x` survives the call
 * unconsumed. This is the T-App-BorrowLin rule from spec §T-App.
 *
 * This function must only be called from `check_call_args_walk` when the argument
 * node is syntactically `Borrow(name, _)`. Never call this from expression position.
 */
export let infer_borrow_arg_position = fn (
  state: CheckState,
  name: string,
  span: Span
) -> InferExprResult throws { TypeError } do
  match infer_variable(state, name, sigil: SigilImmutable, span) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s, typ: t) ->
      // No x:^ω check here — T-App-BorrowLin explicitly permits linear
      // bindings in argument position (borrow discharged on call return).
      // stripBorrow per spec §stripBorrow: peel {%σ, &σ, ~σ} -> σ, else
      // identity. It deliberately does NOT peel @ (thunk): stripBorrow(@σ) =
      // @σ, so this produces `&(@σ)`, which fails to unify against a `&σ`
      // parameter slot in `check_call_args_walk` — rejecting a borrow of an
      // unforced thunk at the type level (the thunk must be forced first).
      let inner = match t do
        | TyLinear(inner: u) | TyBorrow(inner: u) | TyRef(inner: u) -> u
        | _ -> t
      end
      return InferExprOk(state: st1, subst: s, typ: TyBorrow(inner))
  end
end
