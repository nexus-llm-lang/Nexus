/**
 * typecheck/infer/statements: pure leaf helpers for statement and pattern inference.
 *
 * Hosts self-contained clusters that do NOT recurse through infer_expr /
 * infer_stmts:
 *   - Pattern binding (`bind_pattern` and its helper tree): type-directed
 *     pattern decomposition producing env-entry sets; self-recursive but
 *     not expression-recursive.
 *   - Let-binding helpers (`LetMutLinearKind`, `let_mut_linear_kind`,
 *     `alias_poly_scheme`, `poly_scheme`, `wrap_ref`): pure predicates
 *     and env-shaping helpers for the `infer_let` entry point.
 *   - Try/catch helpers (`catch_param_type_from_row`,
 *     `project_exn_from_row_types`): row-to-type projection for catch
 *     parameter binding.
 *   - Numeric defaulting (`default_numeric_literals`, `default_named_types`):
 *     post-inference literal coercion.
 *   - `append_env`: disjoint-union helper used by match, ctor-pattern, and
 *     record-pattern binding.
 *
 * The outer `infer_let` / `infer_return` / `infer_try` / `infer_stmt` entry
 * points stay in src/typecheck/infer.nx because they call back into infer_expr.
 *
 * Extracted from src/typecheck/infer.nx.
 */

import { Span } from "src/types/span.nx"
import {
  Sigil,
  SigilImmutable,
  SigilMutable,
  SigilLazy,
  SigilLinear,
  Literal,
  LitInt,
  LitFloat,
  LitBool,
  LitChar,
  LitString,
  LitUnit
} from "src/types/vocab.nx"
import {
  TypeExpr,
  TyI32,
  TyI64,
  TyF32,
  TyF64,
  TyBool,
  TyChar,
  TyString,
  TyUnit,
  TyIntLit,
  TyFloatLit,
  TyUserDefined,
  TyVar,
  TyArrow,
  TyRef,
  TyLinear,
  TyLazy,
  TyBorrow,
  TyArray,
  TyList,
  TyRecord,
  TyRow,
  NamedType,
  RecordDef,
  VariantField,
  VariantDef,
  EnumDef
} from "src/types/type_expr.nx"
import {
  HirPatternKind, PLit, PVar, PCtor, PRec, PWild, POr,
  HirPatternField, HirRecordPatField,
  HirExprKind
} from "src/ir/hir/types.nx"
import {
  Subst, Scheme, EnvEntry, EnumEntry, CheckState,
  InferExprResult, InferExprOk, InferExprErr,
  UnifyOk, UnifyErr,
  BindResult, BindOk, BindErr,
  EnumVariantInfo, TypeDefEntry
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as unify from "src/typecheck/unify.nx"
import { FreshenResult, freshen_type_params } from "src/typecheck/infer/literals.nx"
import { build_enum_type } from "src/typecheck/infer/constructor.nx"
import {
  lookup_named_type, find_linear_field, type_carries_linear
} from "src/typecheck/infer/collections.nx"
import { TypeError, ThrowsRowInvariantBroken, DuplicatePatternLabel } from "src/typecheck/errors.nx"
import { suggest_names } from "src/diagnostics/levenshtein.nx"
import { Map }, * as map from "std:collection/map"
import * as list from "std:list"
import { Option, Some, None } from "std:option"
import { is_auto_droppable } from "src/ir/shared/type_pred.nx"

/** Render a suggestion list as "\n  --> did you mean 'x' ?" inline text for BindErr messages. */
let inline_suggestions = fn (sugs: [ string ]) -> string do
  return inline_suggestions_go(sugs, acc: "")
end

let inline_suggestions_go = fn (sugs: [ string ], acc: string) -> string do
  match sugs do
    | [] -> return acc
    | s :: rest ->
      return inline_suggestions_go(sugs: rest, acc: acc ++ "\n  --> did you mean '" ++ s ++ "' ?")
  end
end

/** Collect field names from a [NamedType] list (for suggestions). */
let named_type_field_names = fn (nts: [ NamedType ]) -> [ string ] do
  return named_type_field_names_go(nts, acc: [])
end

let named_type_field_names_go = fn (nts: [ NamedType ], acc: [ string ]) -> [ string ] do
  match nts do
    | [] -> return acc
    | NamedType(
      name: n,
      typ: _
    ) :: rest -> return named_type_field_names_go(nts: rest, acc: n :: acc)
  end
end

/** Collect all variant names from enum entries in state (for constructor suggestions). */
let state_all_variant_names = fn (state: CheckState) -> [ string ] do
  return state_all_variant_names_go(entries: tctypes.state_enums(state), acc: [])
end

let state_all_variant_names_go = fn (entries: [ EnumEntry ], acc: [ string ]) -> [ string ] do
  match entries do
    | [] -> return acc
    | EnumEntry(name: _, def: ed) :: rest ->
      let EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs) = ed
      let acc2 = state_all_variant_names_variants(vs, acc)
        return state_all_variant_names_go(entries: rest, acc: acc2)
  end
end

let state_all_variant_names_variants = fn (vs: [ VariantDef ], acc: [ string ]) -> [ string ] do
  match vs do
    | [] -> return acc
    | VariantDef(
      name: n,
      fields: _
    ) :: rest -> return state_all_variant_names_variants(vs: rest, acc: n :: acc)
  end
end

/** Prepend `extra` entries onto `base`. Used by match-case, ctor-pattern, and record-pattern binding. */
export let append_env = fn (
  base: [ EnvEntry ],
  extra: [ EnvEntry ]
) -> [ EnvEntry ] throws { TypeError } do
  match extra do
    | [] -> return base
    | entry :: rest ->
      return append_env(base: entry :: base, extra: rest)
  end
end

/** Match `pattern` against `target_type`, returning the env extensions and substitution produced by the binding (or a `BindErr` on shape mismatch). */
export let bind_pattern = fn (
  state: CheckState,
  pattern: HirPatternKind,
  target_type: TypeExpr,
  pat_span: Span
) -> BindResult throws { TypeError } do
  return bind_pattern_b(state, pattern, target_type, pat_span, borrowed: false)
end

/** Borrow-aware pattern binding. `borrowed` is true when the scrutinee whose
 *  fields are being bound was reached through a `&` borrow (or is itself a
 *  `&T`). A borrowed value is not owned, so destructuring it never transfers
 *  ownership of its fields: a wildcard `_` discarding a borrowed linear field
 *  (e.g. `let EffectMap(entries, lookup: _) = em` where `em: &EffectMap`) is
 *  not a silent-leak violation — the field stays owned by the borrow's owner.
 *  The flag propagates into nested constructor / record fields so a borrowed
 *  scrutinee keeps every projected field borrowed. */
let bind_pattern_b = fn (
  state: CheckState,
  pattern: HirPatternKind,
  target_type: TypeExpr,
  pat_span: Span,
  borrowed: bool
) -> BindResult throws { TypeError } do
  match pattern do
    | PWild ->
      // P-Wild: spec premise linear(τ) ∧ ¬autoDrop(τ) → error.
      // A wildcard silently discards its scrutinee; if the scrutinee is a
      // non-auto-droppable linear type (e.g. %Handle) that is a linearity
      // violation — the resource escapes without being consumed.
      if borrowed || type_is_borrowed(typ: target_type) then
        return BindOk(state, subst: subst.subst_empty(), env: [])
      end
      let tdefs = tctypes.state_typedefs(state)
      // P-Wild: spec premise linear(τ) ∧ ¬autoDrop(τ) → error.
      // `linear` is structural (spec §Linearity), so a linear payload reached
      // through a record alias or a named type's TYPE ARGUMENT (e.g.
      // `Box<%Handle>`) is just as much a silent-discard violation as a bare
      // `%Handle`. Use the canonical structural probe rather than an
      // outer-wrapper-only check.
      let is_linear_type = type_carries_linear(typ: target_type, tdefs, depth: 0)
      if is_linear_type && !is_auto_droppable(t: target_type) then
        return BindErr(message: "wildcard pattern `_` cannot discard linear type `" ++ tctypes.type_to_string(typ: target_type) ++ "` (P-Wild: linear(τ) ∧ ¬autoDrop(τ) → error); bind to a name and consume it explicitly")
      end
      return BindOk(state, subst: subst.subst_empty(), env: [])
    | PVar(name, sigil: _) ->
      return BindOk(
        state, subst: subst.subst_empty(),
        env: [ EnvEntry(name, scheme: tctypes.mono(typ: target_type)) ]
      )
    | PLit(lit) ->
      let lit_type = match lit do
        | LitInt(_) -> TyIntLit
        | LitFloat(_) -> TyFloatLit
        | LitBool(_) -> TyBool
        | LitChar(_) -> TyChar
        | LitString(_) -> TyString
        | LitUnit -> TyUnit
      end
      let tdefs = tctypes.state_typedefs(state)
      match unify.unify(t1: lit_type, t2: target_type, tdefs) do
        | UnifyErr(message: m) -> return BindErr(message: "literal pattern: " ++ m)
        | UnifyOk(subst: s) -> return BindOk(state, subst: s, env: [])
      end
    | PCtor(variant, fields, sigil: _) ->
      return bind_constructor_pattern(state, variant, fields, target_type, borrowed)
    | PRec(fields, is_partial: _) ->
      return bind_record_pattern(state, fields, target_type, pat_span, borrowed)
    | POr(alts) ->
      match alts do
        | [] -> return BindErr(message: "empty or-pattern")
        | first :: rest ->
          match bind_pattern_b(state, pattern: first, target_type, pat_span, borrowed) do
            | BindErr(message: m) -> return BindErr(message: "or-pattern: " ++ m)
            | BindOk(state: st1, subst: s1, env: ref_env) ->
              return bind_or_alts_validate(
                state: st1,
                alts: rest,
                target_type,
                ref_env,
                acc_subst: s1,
                borrowed
              )
          end
      end
  end
end

/** True when `typ`'s outermost modality wrapper is a `&` borrow. A borrowed
 *  value is accessed without ownership, so its linear payload need not be
 *  consumed on a wildcard discard. */
let type_is_borrowed = fn (typ: TypeExpr) -> bool do
  match typ do
    | TyBorrow(inner: _) -> return true
    | _ -> return false
  end
end

let bind_or_alts_validate = fn (
  state: CheckState, alts: [ HirPatternKind ], target_type: TypeExpr,
  ref_env: [ EnvEntry ], acc_subst: Subst, borrowed: bool
) -> BindResult throws { TypeError } do
  // hoist the haystack into a map once per call so
  // env_keys_match / unify_or_envs do O(1) lookups instead of O(N) per name.
  let ref_map = env_to_map(env: ref_env)
  return bind_or_alts_validate_go(state, alts, target_type, ref_env, ref_map, acc_subst, borrowed)
end

let bind_or_alts_validate_go = fn (
  state: CheckState, alts: [ HirPatternKind ], target_type: TypeExpr,
  ref_env: [ EnvEntry ], ref_map: Map<string, Scheme>, acc_subst: Subst,
  borrowed: bool
) -> BindResult throws { TypeError } do
  match alts do
    | [] -> return BindOk(state, subst: acc_subst, env: ref_env)
    | alt :: rest ->
      match bind_pattern_b(
        state,
        pattern: alt,
        target_type,
        pat_span: Span(offset: 0, line: 0, col: 0),
        borrowed
      ) do
        | BindErr(message: m) -> return BindErr(message: "or-pattern alternative: " ++ m)
        | BindOk(state: st1, subst: s1, env: alt_env) ->
          let alt_map = env_to_map(env: alt_env)
          if env_keys_match(a: ref_env, a_map: ref_map, b: alt_env, b_map: alt_map) then
            match unify_or_envs(
              state: st1,
              first: ref_env,
              alt_map,
              acc: subst.subst_compose(s1: acc_subst, s2: s1)
            ) do
              | BindErr(message: m) -> return BindErr(message: m)
              | BindOk(state: st2, subst: s2, env: _) ->
                return bind_or_alts_validate_go(
                  state: st2,
                  alts: rest,
                  target_type,
                  ref_env,
                  ref_map,
                  acc_subst: s2,
                  borrowed
                )
            end
          else
            return BindErr(message: "or-pattern alternatives bind different variable sets")
          end
      end
  end
end

let env_to_map = fn (env: [ EnvEntry ]) -> Map<string, Scheme> throws { TypeError } do
  return env_to_map_go(env, acc: map.string_map())
end

let env_to_map_go = fn (
  env: [ EnvEntry ],
  acc: Map<string, Scheme>
) -> Map<string, Scheme> throws { TypeError } do
  match env do
    | [] -> return acc
    | EnvEntry(name: n, scheme: s) :: rest ->
      return env_to_map_go(env: rest, acc: map.insert(m: acc, k: n, v: s))
  end
end

// Two envs share the same key set iff |a| = |b| and every key in `a` is
// present in `b_map`. Pre-built maps make the membership check O(1).
let env_keys_match = fn (
  a: [ EnvEntry ],
  a_map: Map<string, Scheme>,
  b: [ EnvEntry ],
  b_map: Map<string, Scheme>
) -> bool throws { TypeError } do
  if list.length(xs: a) != list.length(xs: b) then return false end
  return all_keys_in_map(
    needles: a,
    haystack: b_map
  ) && all_keys_in_map(needles: b, haystack: a_map)
end

let all_keys_in_map = fn (
  needles: [ EnvEntry ],
  haystack: Map<string, Scheme>
) -> bool throws { TypeError } do
  match needles do
    | [] -> return true
    | EnvEntry(name: n, scheme: _) :: rest ->
      if map.contains(m: haystack, k: n) then
        return all_keys_in_map(needles: rest, haystack)
      else
        return false
      end
  end
end

let has_env_key = fn (name: string, env: [ EnvEntry ]) -> bool do
  match env do
    | [] -> return false
    | EnvEntry(name: n, scheme: _) :: rest ->
      if n == name then return true else return has_env_key(name, env: rest) end
  end
end

// Disjoint-union helper: walks `extra` and returns the first name that
// already exists in `base`. Spec rule P-Ctor / P-Record: the per-field
// binding sets must satisfy `⨄_i (Γ_i \ Γ)`, i.e. no name introduced by
// one field pattern may be reintroduced by a sibling. `_` (PWild) yields
// no entries and so naturally short-circuits this check.
let find_env_overlap = fn (base: [ EnvEntry ], extra: [ EnvEntry ]) -> Option<string> do
  match extra do
    | [] -> return None
    | EnvEntry(name: n, scheme: _) :: rest ->
      if has_env_key(name: n, env: base) then
        return Some(val: n)
      else
        return find_env_overlap(base, extra: rest)
      end
  end
end

// `alt_map` replaces a linear-scan `find_env_entry` (was O(M)
// per name; total O(M²)). The caller pre-builds it once per or-alternative.
let unify_or_envs = fn (
  state: CheckState, first: [ EnvEntry ], alt_map: Map<string, Scheme>, acc: Subst
) -> BindResult throws { TypeError } do
  match first do
    | [] -> return BindOk(state, subst: acc, env: [])
    | EnvEntry(name: n, scheme: rs) :: rest_first ->
      match map.get(m: alt_map, k: n) do
        | None -> return BindErr(message: "or-pattern: missing binding `" ++ n ++ "` in alternative")
        | Some(val: as_) ->
          let tdefs = tctypes.state_typedefs(state)
          let rt = scheme_typ(s: rs)
          let at = scheme_typ(s: as_)
          match unify.unify(t1: rt, t2: at, tdefs) do
            | UnifyErr(message: m) ->
              return BindErr(message: "or-pattern: variable `" ++ n ++ "` has incompatible types across alternatives: " ++ m)
            | UnifyOk(subst: s) ->
              // Spec P-Or: Γ₁ \ Γ = Γ₂ \ Γ requires identity of both type
              // AND usage annotation (q=1 vs q=ω). Unification alone does
              // not enforce this because a TyVar on one side can bind to
              // TyLinear(τ) on the other, silently erasing the discrepancy.
              // We therefore check that linear(rt) = linear(at) after
              // structural type matching succeeds.
              let rt_lin = type_carries_linear(typ: rt, tdefs, depth: 0)
              let at_lin = type_carries_linear(typ: at, tdefs, depth: 0)
              if rt_lin != at_lin then
                return BindErr(message: "or-pattern: variable `" ++ n ++ "` has different linearity across alternatives (one arm binds a linear type, the other does not); P-Or requires identical usage annotations")
              end
              return unify_or_envs(
                state,
                first: rest_first,
                alt_map,
                acc: subst.subst_compose(s1: acc, s2: s)
              )
          end
      end
  end
end

let scheme_typ = fn (s: Scheme) -> TypeExpr throws { TypeError } do
  let Scheme(vars: _, typ: t) = s
  return t
end

let bind_constructor_pattern = fn (
  state: CheckState, variant: string,
  fields: [ HirPatternField ], target_type: TypeExpr, borrowed: bool
) -> BindResult throws { TypeError } do
  // spec strip(τ) peels %/& only — @σ thunks must be forced explicitly.
  match target_type do
    | TyLazy(inner: _, require_row: _, throw_row: _) ->
      return BindErr(message: "cannot pattern-match constructor `" ++ variant ++ "` on thunk type `" ++ tctypes.type_to_string(typ: target_type) ++ "`; force the thunk first (e.g. `match @x do | " ++ variant ++ "(...) -> ... end`)")
    | _ -> ()
  end
  let fields_borrowed = borrowed || type_is_borrowed(typ: target_type)
  let unwrapped = match target_type do
    | TyLinear(inner: i) | TyRef(inner: i) | TyBorrow(inner: i) -> i
    | _ -> target_type
  end
  match tctypes.find_variant_in_state(state, variant) do
    | None ->
      let sugs = suggest_names(typo: variant, candidates: state_all_variant_names(state))
      return BindErr(message: "unknown constructor in pattern: " ++ variant ++ inline_suggestions(sugs))
    | Some(val: EnumVariantInfo(enum_name: ename, type_params: tps, fields: field_types)) ->
      let fr = freshen_type_params(state, params: tps)
      let FreshenResult(state: st1, param_subst: psubst) = fr
      let enum_type = build_enum_type(name: ename, params: tps, param_subst: psubst)
          let tdefs = tctypes.state_typedefs(state: st1)
          match unify.unify(t1: enum_type, t2: unwrapped, tdefs) do
            | UnifyErr(message: m) -> return BindErr(message: "constructor pattern type: " ++ m)
            | UnifyOk(subst: s1) ->
              let full_subst = subst.subst_compose(s1: psubst, s2: s1)
              // Spec P-Ctor {ℓ'} = {ℓ} (set equality): when the constructor's
              // declared fields are all labelled, the surface pattern may list
              // them in any permutation. Canonicalize the pattern field list
              // into the declared field order (binding by LABEL, not position)
              // so `First(aa: a, zz: z)` binds `a`/`z` to the `aa`/`zz` fields,
              // mirroring how P-Record (bind_rec_pat_fields) resolves by name.
              // Positional (unlabelled) constructors keep the positional walk.
              match reorder_ctor_pat_fields(fields, field_types) do
                | CanonErr(message: m) -> return BindErr(message: m)
                | CanonOk(fields: canon_fields) ->
                  return bind_ctor_fields(
                    state: st1,
                    fields: canon_fields,
                    field_types,
                    param_subst: full_subst,
                    subst: s1,
                    env: [],
                    borrowed: fields_borrowed
                  )
              end
          end
  end
end

// Result of canonicalizing a constructor pattern's field list into the
// constructor's declared field order. CanonOk carries the reordered list
// (positional / wildcard-all constructors pass through unchanged).
type CanonResult =
  CanonOk(fields: [ HirPatternField ])
  | CanonErr(message: string)

// Spec P-Ctor {ℓ'} = {ℓ}: reorder the surface pattern fields into the
// constructor's declared field order, binding by LABEL rather than position.
//
// This kicks in ONLY when the pattern's field labels form an exact permutation
// of the constructor's declared labels (set equality, same multiplicity, every
// label a real declared label). In that case `First(aa: a, zz: z)` is reordered
// to declared order so each binder maps to its LABEL's field, mirroring P-Record.
//
// Every other shape passes through UNCHANGED so the existing positional walk in
// bind_ctor_fields preserves its prior behaviour:
//   - wildcard-all `Ctor(_)` (empty field list),
//   - positional constructors (declared fields unnamed),
//   - partial / mixed patterns like `Ctor(present: p, _)` where `_` is a
//     positional remainder rather than a real label,
//   - pun shorthand already written in declared order.
let reorder_ctor_pat_fields = fn (
  fields: [ HirPatternField ], field_types: [ VariantField ]
) -> CanonResult do
  let declared_labels = variant_field_labels(field_types, acc: [])
  let pat_labels = pat_field_labels(fields, acc: [])
  if is_full_label_permutation(pat_labels, declared_labels) then
    return canon_by_label(declared: field_types, pat_fields: fields, acc: [])
  else
    return CanonOk(fields: fields)
  end
end

// Declared field labels, in declared order. Returns [] (treated as "not a
// fully-labelled constructor") if ANY field is positional/unnamed.
let variant_field_labels = fn (field_types: [ VariantField ], acc: [ string ]) -> [ string ] do
  match field_types do
    | [] -> return list.reverse(xs: acc)
    | VariantField(name: None, typ: _) :: _ -> return []
    | VariantField(name: Some(val: n), typ: _) :: rest ->
      return variant_field_labels(field_types: rest, acc: n :: acc)
  end
end

// Pattern field labels, in surface order. Returns [] if any field is unnamed.
let pat_field_labels = fn (fields: [ HirPatternField ], acc: [ string ]) -> [ string ] do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | HirPatternField(name: None, pattern: _) :: _ -> return []
    | HirPatternField(name: Some(val: n), pattern: _) :: rest ->
      return pat_field_labels(fields: rest, acc: n :: acc)
  end
end

// True iff `pat_labels` is a permutation of `declared_labels`: same length,
// and every declared label appears exactly once in the pattern. Both lists are
// non-empty and label-distinct in the cases we care about; a `_` positional
// remainder is not a declared label, so a mixed pattern fails this test and
// falls back to the positional walk.
let is_full_label_permutation = fn (pat_labels: [ string ], declared_labels: [ string ]) -> bool do
  match declared_labels do
    | [] -> return false
    | _ ->
      if list.length(xs: pat_labels) != list.length(xs: declared_labels) then
        return false
      else
        return every_label_present(needles: declared_labels, haystack: pat_labels)
      end
  end
end

let every_label_present = fn (needles: [ string ], haystack: [ string ]) -> bool do
  match needles do
    | [] -> return true
    | n :: rest ->
      if label_in_list(label: n, haystack) then
        return every_label_present(needles: rest, haystack)
      else
        return false
      end
  end
end

// For each declared field (in declared order) pull the matching pattern field
// out of `pat_fields` by label. Errors on a missing label (no pattern field
// for a declared field) or, after all declared fields are consumed, a leftover
// pattern field whose label is not declared (unknown / extra / duplicate).
let canon_by_label = fn (
  declared: [ VariantField ], pat_fields: [ HirPatternField ],
  acc: [ HirPatternField ]
) -> CanonResult do
  match declared do
    | [] ->
      // No more declared fields. Any remaining pattern field is unknown/extra.
      match pat_fields do
        | [] -> return CanonOk(fields: list.reverse(xs: acc))
        | HirPatternField(name: extra_opt, pattern: _) :: _ ->
          let extra = match extra_opt do
            | Some(val: n) -> n
            | None -> "(positional)"
          end
          return CanonErr(message: "constructor pattern has unknown or duplicate field label `"
            ++ extra ++ "`; P-Ctor requires {ℓ'} = {ℓ}")
      end
    | VariantField(name: dname_opt, typ: _) :: rest_declared ->
      let dname = match dname_opt do
        | Some(val: n) -> n
        | None -> ""
      end
      match take_pat_field_by_label(label: dname, fields: pat_fields, seen: []) do
        | None ->
          return CanonErr(message: "constructor pattern is missing field label `"
            ++ dname ++ "`; P-Ctor requires {ℓ'} = {ℓ}")
        | Some(val: TakenPatField(field: f, rest: remaining)) ->
          return canon_by_label(declared: rest_declared, pat_fields: remaining, acc: f :: acc)
      end
  end
end

type TakenPatField = TakenPatField(field: HirPatternField, rest: [ HirPatternField ])

// Remove and return the first pattern field whose label equals `label`,
// preserving the order of the remaining fields. `seen` accumulates the
// already-scanned (non-matching) fields to splice back in.
let take_pat_field_by_label = fn (
  label: string, fields: [ HirPatternField ], seen: [ HirPatternField ]
) -> Option<TakenPatField> do
  match fields do
    | [] -> return None
    | HirPatternField(name: fname_opt, pattern: pat) :: rest ->
      let matches = match fname_opt do
        | Some(val: fname) -> fname == label
        | None -> false
      end
      if matches then
        let remaining = list.concat(xs: list.reverse(xs: seen), ys: rest)
        return Some(val: TakenPatField(
          field: HirPatternField(name: fname_opt, pattern: pat),
          rest: remaining
        ))
      else
        return take_pat_field_by_label(
          label,
          fields: rest,
          seen: HirPatternField(name: fname_opt, pattern: pat) :: seen
        )
      end
  end
end

let bind_ctor_fields = fn (
  state: CheckState, fields: [ HirPatternField ], field_types: [ VariantField ],
  param_subst: Subst, subst: Subst, env: [ EnvEntry ],
  borrowed: bool
) -> BindResult throws { TypeError } do
  match fields do
    | [] -> return BindOk(state, subst, env)
    | HirPatternField(name: fname_opt, pattern: pat) :: rf ->
      match field_types do
        | [] -> return BindErr(message: "too many constructor pattern fields")
        | VariantField(name: vfname_opt, typ: ft) :: rft ->
          // Spec P-Ctor {ℓ'} = {ℓ}: when both the pattern and the constructor
          // field carry a label, they must match at each position — reordered
          // labels (e.g. Point(y: a, x: b) for Point(x, y)) are rejected here.
          match check_ctor_field_label(fname_opt, vfname_opt) do
            | Some(val: err) -> return BindErr(message: err)
            | None -> ()
          end
          let expected = subst.subst_apply(subst: param_subst, typ: ft)
          match bind_pattern_b(
            state,
            pattern: pat,
            target_type: expected,
            pat_span: Span(offset: 0, line: 0, col: 0),
            borrowed
          ) do
            | BindErr(message: m) -> return BindErr(message: m)
            | BindOk(state: st1, subst: ps, env: new_binds) ->
              // Spec P-Ctor: ⨄_i (Γ_i \ Γ) — sibling field patterns must
              // bind disjoint variable sets. Without this check, the last
              // binder for a name silently shadows earlier ones.
              match find_env_overlap(base: env, extra: new_binds) do
                | Some(val: dup) ->
                  let label = match fname_opt do
                    | Some(val: n) -> n
                    | None ->
                      match vfname_opt do
                        | Some(val: n) -> n
                        | None -> "(positional)"
                      end
                  end
                  return BindErr(message: "duplicate variable `" ++ dup ++ "` in constructor pattern (introduced by field `" ++ label ++ "`); sibling fields must bind disjoint names")
                | None ->
                  let sm = subst.subst_compose(s1: subst, s2: ps)
                  return bind_ctor_fields(
                    state: st1, fields: rf, field_types: rft,
                    param_subst, subst: sm,
                    env: append_env(base: env, extra: new_binds),
                    borrowed
                  )
              end
          end
      end
  end
end

// Spec P-Ctor {ℓ'} = {ℓ}: check that a single pattern field label matches
// the constructor's declared label at the same position. Returns Some(error)
// on mismatch (both labels present but different), None if OK.
let check_ctor_field_label = fn (
  fname_opt: Option<string>, vfname_opt: Option<string>
) -> Option<string> do
  match fname_opt do
    | None -> return None
    | Some(val: fname) ->
      match vfname_opt do
        | None -> return None
        | Some(val: vfname) ->
          // Use label_in_list for the comparison to reuse proven string-equality
          // logic rather than a raw `==` on newly-bound strings.
          if label_in_list(label: fname, haystack: vfname :: []) then
            return None
          else
            return Some(val: "constructor pattern field label `" ++ fname
              ++ "` does not match the declared label `" ++ vfname
              ++ "` at this position; P-Ctor requires {ℓ'} = {ℓ}")
          end
      end
  end
end

// Spec P-Record premise distinct(ℓ̄): walk the pattern field list and throw
// DuplicatePatternLabel on the first repeated label. Uses a seen-list to
// avoid depending on the map module (not imported in this module).
// pat_span is the span of the enclosing record pattern, used as a fallback
// location when HirRecordPatField does not carry per-field source positions.
let check_distinct_pat_labels = fn (
  fields: [ HirRecordPatField ], seen: [ string ], pat_span: Span
) -> unit throws { TypeError } do
  match fields do
    | [] -> return ()
    | HirRecordPatField(name: fname, pattern: _) :: rest ->
      match label_in_list(label: fname, haystack: seen) do
        | true -> throw DuplicatePatternLabel(label: fname, span: pat_span)
        | false ->
          return check_distinct_pat_labels(fields: rest, seen: fname :: seen, pat_span)
      end
  end
end

let label_in_list = fn (label: string, haystack: [ string ]) -> bool do
  match haystack do
    | [] -> return false
    | h :: rest ->
      if h == label then return true
      else return label_in_list(label, haystack: rest)
      end
  end
end

let bind_record_pattern = fn (
  state: CheckState, fields: [ HirRecordPatField ], target_type: TypeExpr,
  pat_span: Span, borrowed: bool
) -> BindResult throws { TypeError } do
  // Spec P-Record premise distinct(ℓ̄): reject duplicate field labels before
  // attempting the per-field binding walk.
  check_distinct_pat_labels(fields, seen: [], pat_span)
  // spec strip(τ) peels %/& only — @σ thunks must be forced explicitly.
  match target_type do
    | TyLazy(inner: _, require_row: _, throw_row: _) ->
      return BindErr(message: "cannot pattern-match record on thunk type `" ++ tctypes.type_to_string(typ: target_type) ++ "`; force the thunk first (e.g. `match @x do | {...} -> ... end`)")
    | _ -> ()
  end
  let fields_borrowed = borrowed || type_is_borrowed(typ: target_type)
  // Peel modality wrappers (Linear/Borrow/Ref) so `match h: %T do | {f: x} -> ...`
  // can match on the underlying record.
  let inner = match target_type do
    | TyLinear(inner: i) | TyBorrow(inner: i) | TyRef(inner: i) -> i
    | _ -> target_type
  end
  match inner do
    | TyRecord(fields: rec_fields) ->
      return bind_rec_pat_fields(
        state,
        fields,
        rec_fields,
        subst: subst.subst_empty(),
        env: [],
        borrowed: fields_borrowed
      )
    | TyUserDefined(name: n, args: _) ->
      // Project named record typedef (`p: Point`) to underlying TyRecord.
      // Anonymous record alias for surface types like `type Point = {...}`.
      match tctypes.typedef_lookup(defs: tctypes.state_typedefs(state), name: n) do
        | Some(val: rd) ->
          let RecordDef(name: _, is_public: _, type_params: _, fields: rec_fields) = rd
          return bind_rec_pat_fields(
            state,
            fields,
            rec_fields,
            subst: subst.subst_empty(),
            env: [],
            borrowed: fields_borrowed
          )
        | None -> return BindErr(message: "record pattern on non-record type")
      end
    | _ -> return BindErr(message: "record pattern on non-record type")
  end
end

let bind_rec_pat_fields = fn (
  state: CheckState, fields: [ HirRecordPatField ],
  rec_fields: [ NamedType ], subst: Subst, env: [ EnvEntry ],
  borrowed: bool
) -> BindResult throws { TypeError } do
  match fields do
    | [] -> return BindOk(state, subst, env)
    | HirRecordPatField(name: fname, pattern: pat) :: rest ->
      match lookup_named_type(nts: rec_fields, name: fname) do
        | None ->
          let sugs = suggest_names(typo: fname, candidates: named_type_field_names(nts: rec_fields))
          return BindErr(message: "no field '" ++ fname ++ "' in record pattern" ++ inline_suggestions(sugs))
        | Some(val: ft) ->
          match bind_pattern_b(
            state,
            pattern: pat,
            target_type: ft,
            pat_span: Span(offset: 0, line: 0, col: 0),
            borrowed
          ) do
            | BindErr(message: m) -> return BindErr(message: m)
            | BindOk(state: st1, subst: ps, env: new_binds) ->
              // Spec P-Record: ⨄_i (Γ_i \ Γ) — sibling field patterns
              // must bind disjoint variable sets.
              match find_env_overlap(base: env, extra: new_binds) do
                | Some(val: dup) ->
                  return BindErr(message: "duplicate variable `" ++ dup ++ "` in record pattern (introduced by field `" ++ fname ++ "`); sibling fields must bind disjoint names")
                | None ->
                  let sm = subst.subst_compose(s1: subst, s2: ps)
                  return bind_rec_pat_fields(
                    state: st1, fields: rest, rec_fields,
                    subst: sm, env: append_env(base: env, extra: new_binds),
                    borrowed
                  )
              end
          end
      end
  end
end

/** Classification of a `let ~x = v` RHS type w.r.t. the T-Let premise
 * `μ = ~ ⟹ ¬linear(τ')`.: linearity is structural, so we
 *  must reject not only bare `%T`/`@T` but also TyRecord / TyUserDefined
 *  whose fields transitively carry linear components.
 */
export type LetMutLinearKind =
  LetMutOk
  | LetMutLinearBare           // TyLinear at top level
  | LetMutLinearLazy           // TyLazy at top level
  | LetMutLinearStructural     // Aggregate (record / named record) carrying linear

export let let_mut_linear_kind = fn (typ: TypeExpr, tdefs: [ TypeDefEntry ]) -> LetMutLinearKind do
  match typ do
    | TyLinear(_) -> return LetMutLinearBare
    | TyLazy(_) -> return LetMutLinearLazy
    | _ ->
      if type_carries_linear(typ, tdefs, depth: 8) then
        return LetMutLinearStructural
      end
      return LetMutOk
  end
end

let poly_scheme = fn (vars: [ string ]) -> bool do
  match vars do
    | [] -> return false
    | _ -> return true
  end
end

/** True when every entry in `env` except the one named `except_name`
 *  has multiplicity ω (i.e. its type is not `TyLinear` or `TyLazy`).
 *  This is the env-level `pure(Γ \ {y})` predicate used by T-Let-Alias.
 *  spec type-system-formal.md §Linearity: `pure(Γ) = ∀x:^q S ∈ Γ. q = ω`.
 */
let env_is_pure_except = fn (env: [ EnvEntry ], except_name: string) -> bool do
  match env do
    | [] -> return true
    | EnvEntry(name: n, scheme: Scheme(vars: _, typ: t)) :: rest ->
      if n == except_name then
        return env_is_pure_except(env: rest, except_name)
      end
      match t do
        | TyLinear(_) | TyLazy(_) -> return false
        | _ -> return env_is_pure_except(env: rest, except_name)
      end
  end
end

/** Variable-aliasing carve-out helper. Returns
 *  `Some(Ok(state'))` when the let RHS is a plain immutable, unannotated
 *  reference to a polymorphic binding whose alias site satisfies the
 *  T-Let-Alias spec premise `pure(Γ \ {y})`.
 *  `Some(Err(...))` when the alias shape matches but the pure premise fails —
 *    i.e. there is a live linear binding in scope at the alias site.
 *  `None` for every other shape so `infer_let` falls through to T-Let.
 *
 *  Spec T-Let-Alias (type-system-formal.md §T-Let-Alias):
 *    pure(Γ \ {y}): the env minus y must contain no linear binders.
 *    Without this guard, `let f = poly_fn` at a site where a linear
 *    binding is live would create an alias that could escape the linear
 *    resource past its scope. Downstream P-FnEnd scope-close enforcement
 *    provides a compensating safety net, but the premise is explicitly
 *    required by the spec rule and belongs here at the introduction site.
 */
export let alias_poly_scheme = fn (
  state: CheckState, name: string, sigil: Sigil,
  ann: Option<TypeExpr>, val_node: HirExprKind, span: Span
) -> Option<InferExprResult> do
  match sigil do
    | SigilImmutable -> ()
    | _ -> return None
  end
  match ann do
    | None -> ()
    | Some(_) -> return None
  end
  match val_node do
    | Variable(name: src_name, sigil: SigilImmutable) ->
      match tctypes.state_lookup_scheme(state, name: src_name) do
        | None -> return None
        | Some(val: Scheme(vars: src_vars, typ: src_typ)) ->
          if poly_scheme(vars: src_vars) then
            // T-Let-Alias premise: pure(Γ \ {y}) — no linear binders
            // may be live in scope when aliasing a polymorphic function.
            // Compensated by P-FnEnd but required explicitly at this site.
            if !env_is_pure_except(env: tctypes.state_env(state), except_name: src_name) then
              return Some(val: InferExprErr(
                message: "let " ++ name ++ " = " ++ src_name ++ ": T-Let-Alias requires pure(Γ\\{" ++ src_name ++ "}) — a live linear binding exists in scope at this alias site (spec type-system-formal.md §T-Let-Alias)",
                span
              ))
            end
            let env_aliased = tctypes.env_insert(
              env: tctypes.state_env(state),
              name,
              scheme: Scheme(vars: src_vars, typ: src_typ)
            )
            return Some(val: InferExprOk(
              state: tctypes.state_with_env(state, env: env_aliased),
              subst: subst.subst_empty(),
              typ: TyUnit
            ))
          end
          return None
      end
    | _ -> return None
  end
end

/** Wrap a binding type in TyRef for `~`-sigil lets unless the value is
 *  already a Ref/Linear/Lazy/Borrow.
 */
export let wrap_ref = fn (typ: TypeExpr) -> TypeExpr do
  match typ do
    | TyRef(_) | TyLinear(_) | TyLazy(_) | TyBorrow(_) -> return typ
    | _ -> return TyRef(inner: typ)
  end
end

/** Project the active throws-row onto the type bound to a catch parameter.
 *  Every declared exception variant is registered as a member of the
 *  built-in `Exn` enum, so the universal shape (`Exn` itself), exception
 *  groups (`LirError`), and individual variants all resolve to the `Exn`
 *  enum type. The catch param is therefore typed by walking the row rather
 *  than splicing in the literal `TyUserDefined("Exn", [])`; once row
 *  entries gain a non-Exn-rooted vocabulary the per-entry walk here will
 *  surface that as a TypeMismatch caller-side instead of silently flowing
 *  through (see feedback_no_silent_defaults).
 */
export let catch_param_type_from_row = fn (row: TypeExpr) -> TypeExpr throws { TypeError } do
  match row do
    | TyRow(types: ts, rest: r) -> return project_exn_from_row_types(ts, has_tail: r)
    | TyVar(name: _) ->
      // The whole row was unified to a tail variable (effect-polymorphic).
      // Catch param falls back to the universal Exn type.
      return TyUserDefined(name: "Exn", args: [])
    | _ ->
      // Throws-row that isn't TyRow / TyVar means a typecheck invariant
      // was already broken upstream. Raise an ICE rather than
      // fabricating a span-less TypeMismatch.
      throw ThrowsRowInvariantBroken(
        detail: "catch_param_type_from_row: throws row must be TyRow or TyVar, got "
          ++ tctypes.type_to_string(typ: row)
      )
  end
end

/** Walk row entries, asserting each names an Exn-rooted shape. Closed
 *  empty rows project to `Exn` so a `catch` body inside a function with
 *  `throws {}` still type-checks (the body is statically unreachable but
 *  pattern inference still runs).
 */
let project_exn_from_row_types = fn (
  ts: [ TypeExpr ], has_tail: Option<TypeExpr>
) -> TypeExpr throws { TypeError } do
  match ts do
    | [] -> return TyUserDefined(name: "Exn", args: [])
    | TyUserDefined(name: _, args: _) :: rest | TyVar(name: _) :: rest ->
      return project_exn_from_row_types(ts: rest, has_tail)
    | other :: _ ->
      throw ThrowsRowInvariantBroken(
        detail: "project_exn_from_row_types: row entry must be TyUserDefined or TyVar, got "
          ++ tctypes.type_to_string(typ: other)
      )
  end
end

export let default_numeric_literals = fn (typ: TypeExpr) -> TypeExpr throws { TypeError } do
  match typ do
    | TyIntLit -> return TyI64
    | TyFloatLit -> return TyF64
    | TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return TyArrow(
        params: default_named_types(nts: ps),
        ret: default_numeric_literals(typ: r),
        requires: req,
        throw_row: thr
      )
    | TyArray(elem: e) -> return TyArray(elem: default_numeric_literals(typ: e))
    | TyList(elem: e) -> return TyList(elem: default_numeric_literals(typ: e))
    | TyRecord(fields: fs) -> return TyRecord(fields: default_named_types(nts: fs))
    | _ -> return typ
  end
end

export let default_named_types = fn (nts: [ NamedType ]) -> [ NamedType ] throws { TypeError } do
  return default_named_types_go(nts, acc: [])
end

let default_named_types_go = fn (
  nts: [ NamedType ],
  acc: [ NamedType ]
) -> [ NamedType ] throws { TypeError } do
  match nts do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: n, typ: t) :: rest ->
      return default_named_types_go(
        nts: rest,
        acc: NamedType(name: n, typ: default_numeric_literals(typ: t)) :: acc
      )
  end
end
