/**
 * typecheck/infer/constructor: variant-field sorting, enum-type building, and
 * constructor / ctor-arg inference.
 *
 * Leaf cluster (no infer_expr calls):
 *   - Variant-field insertion-sort by label (`sort_variant_fields`,
 *     `insert_variant_field`, `tc_str_lt`).
 *   - Enum-type builder (`build_enum_type`, `build_type_args`).
 *   - Named-type / variant-name collection helpers (`named_type_names`,
 *     `all_variant_names`): used by infer_constructor for error suggestions.
 *   - Ctor field-label check (`check_ctor_field_label`,
 *     `ctor_label_in_singleton`): T-Ctor {ℓ} = {ℓ'} premise.
 *
 * Callback cluster (receive infer_expr as a parameter):
 *   - `infer_constructor`: looks up the variant, freshens type params,
 *     delegates to `check_ctor_args`.
 *   - `check_ctor_args`: walks constructor field list, calling
 *     `infer_expr_fn` for each argument expression.
 *
 * Extracted from src/typecheck/infer.nx.
 */

import { Span } from "src/types/span.nx"
import { Sigil } from "src/types/vocab.nx"
import {
  TypeExpr,
  TyVar,
  TyArrow,
  TyUserDefined,
  TyUnit,
  VariantField,
  NamedType,
  VariantDef,
  EnumDef
} from "src/types/type_expr.nx"
import { HirExpr } from "src/ir/hir/types.nx"
import {
  SubstEntry, Scheme, EnumEntry, CheckState,
  InferExprResult, InferExprOk, InferExprErr,
  UnifyOk, UnifyErr,
  EnumVariantInfo
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as unify from "src/typecheck/unify.nx"
import { FreshenResult, freshen_type_params } from "src/typecheck/infer/literals.nx"
import { TypeError, UnknownConstructor } from "src/typecheck/errors.nx"
import { suggest_names } from "src/diagnostics/levenshtein.nx"
import * as list from "std:list"
import { Option, Some, None } from "std:option"


let variant_field_name = fn (f: VariantField) -> string throws { TypeError } do
  match f do
    | VariantField(name: Some(val: n), typ: _) -> return n
    | VariantField(name: None, typ: _) -> return ""
  end
end

export let insert_variant_field = fn (
  f: VariantField,
  sorted: [ VariantField ]
) -> [ VariantField ] throws { TypeError } do
  return insert_variant_field_go(f, sorted, acc: [])
end

let insert_variant_field_go = fn (
  f: VariantField,
  sorted: [ VariantField ],
  acc: [ VariantField ]
) -> [ VariantField ] throws { TypeError } do
  match sorted do
    | [] -> return list.concat(xs: list.reverse(xs: acc), ys: [ f ])
    | head :: rest ->
      if tc_str_lt(a: variant_field_name(f), b: variant_field_name(f: head)) then
        return list.concat(xs: list.reverse(xs: acc), ys: f :: sorted)
      else
        return insert_variant_field_go(f, sorted: rest, acc: head :: acc)
      end
  end
end

export let sort_variant_fields = fn (fields: [ VariantField ]) -> [ VariantField ] throws { TypeError } do
  match fields do
    | [] -> return []
    | f :: rest -> return insert_variant_field(f, sorted: sort_variant_fields(fields: rest))
  end
end

export let tc_str_lt = fn (a: string, b: string) -> bool do
  return a < b
end

export let build_enum_type = fn (
  name: string,
  params: [ string ],
  param_subst: [ SubstEntry ]
) -> TypeExpr throws { TypeError } do
  let args = build_type_args(params, param_subst)
  return TyUserDefined(name, args)
end

export let build_type_args = fn (
  params: [ string ],
  param_subst: [ SubstEntry ]
) -> [ TypeExpr ] throws { TypeError } do
  return build_type_args_go(params, param_subst, acc: [])
end

let build_type_args_go = fn (
  params: [ string ],
  param_subst: [ SubstEntry ],
  acc: [ TypeExpr ]
) -> [ TypeExpr ] throws { TypeError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | p :: rest ->
      let resolved = subst.subst_apply(subst: param_subst, typ: TyVar(name: p))
      return build_type_args_go(params: rest, param_subst, acc: resolved :: acc)
  end
end

/** Collect field names from a [NamedType] list (for UnknownField suggestions). */
export let named_type_names = fn (nts: [ NamedType ]) -> [ string ] do
  return named_type_names_go(nts, acc: [])
end

let named_type_names_go = fn (nts: [ NamedType ], acc: [ string ]) -> [ string ] do
  match nts do
    | [] -> return acc
    | NamedType(name: n, typ: _) :: rest -> return named_type_names_go(nts: rest, acc: n :: acc)
  end
end

/** Collect all variant names from the enum definitions in state (for suggestions). */
export let all_variant_names = fn (state: CheckState) -> [ string ] do
  return all_variant_names_go(entries: tctypes.state_enums(state), acc: [])
end

let all_variant_names_go = fn (entries: [ EnumEntry ], acc: [ string ]) -> [ string ] do
  match entries do
    | [] -> return acc
    | EnumEntry(name: _, def: ed) :: rest ->
      let EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs) = ed
      let acc2 = all_variant_names_variants(vs, acc)
        return all_variant_names_go(entries: rest, acc: acc2)
  end
end

let all_variant_names_variants = fn (vs: [ VariantDef ], acc: [ string ]) -> [ string ] do
  match vs do
    | [] -> return acc
    | VariantDef(
      name: n,
      fields: _
    ) :: rest -> return all_variant_names_variants(vs: rest, acc: n :: acc)
  end
end

export let check_ctor_field_label = fn (
  user_labels: [ string ], vfname_opt: Option<string>
) -> Option<string> do
  match user_labels do
    | [] -> return None
    | fname :: _ ->
      match vfname_opt do
        | None -> return None
        | Some(val: vfname) ->
          if ctor_label_in_singleton(label: fname, expected: vfname) then
            return None
          else
            return Some(val: "constructor argument label `" ++ fname
              ++ "` does not match the declared field label `" ++ vfname
              ++ "` at this position; T-Ctor requires {ℓ} = {ℓ'}")
          end
      end
  end
end

export let ctor_label_in_singleton = fn (label: string, expected: string) -> bool do
  return ctor_label_in_singleton_go(label, haystack: expected :: [])
end

let ctor_label_in_singleton_go = fn (label: string, haystack: [ string ]) -> bool do
  match haystack do
    | [] -> return false
    | h :: rest ->
      if h == label then return true
      else return ctor_label_in_singleton_go(label, haystack: rest)
      end
  end
end

/** Infer the type of a constructor expression. Calls `infer_expr_fn` for each
 *  constructor argument. */
export let infer_constructor = fn (
  state: CheckState, variant: string, args: [ HirExpr ], labels: [ string ], sigil: Sigil, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  sigil
  match tctypes.find_variant_in_state(state, variant) do
    | None ->
      let sugs = suggest_names(typo: variant, candidates: all_variant_names(state))
      throw UnknownConstructor(name: variant, suggestions: sugs, span)
    | Some(val: EnumVariantInfo(enum_name: ename, type_params: tps, fields)) ->
      let fr = freshen_type_params(state, params: tps)
      let FreshenResult(state: st1, param_subst: psubst) = fr
      let sorted_fields = sort_variant_fields(fields)
      let enum_type = build_enum_type(name: ename, params: tps, param_subst: psubst)
      return check_ctor_args(
        state: st1,
        fields: sorted_fields,
        args,
        labels,
        param_subst: psubst,
        enum_type,
        subst: subst.subst_empty(),
        span,
        infer_expr_fn
      )
  end
end

let check_ctor_args = fn (
  state: CheckState, fields: [ VariantField ], args: [ HirExpr ], labels: [ string ],
  param_subst: [ SubstEntry ], enum_type: TypeExpr, subst: [ SubstEntry ], span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match fields do
    | [] ->
      match args do
        | [] -> return InferExprOk(state, subst, typ: subst.subst_apply(subst, typ: enum_type))
        | _ -> return InferExprErr(message: "too many constructor arguments", span)
      end
    | VariantField(name: vfname_opt, typ: ftyp) :: rf ->
      match args do
        | [] -> return InferExprErr(message: "missing constructor argument", span)
        | arg :: ra ->
          match check_ctor_field_label(user_labels: labels, vfname_opt: vfname_opt) do
            | Some(val: err) -> return InferExprErr(message: err, span)
            | None -> ()
          end
          let labels_tail = match labels do | [] -> [] | _ :: tl -> tl end
          match infer_expr_fn(state, expr: arg, ret_type: TyUnit) do
            | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
            | InferExprOk(state: st1, subst: s1, typ: at) ->
              let sm = subst.subst_compose(s1: subst, s2: s1)
              let expected = subst.subst_apply(
                subst: subst.subst_compose(s1: param_subst, s2: sm),
                typ: ftyp
              )
              let tdefs = tctypes.state_typedefs(state: st1)
              match unify.unify(t1: at, t2: expected, tdefs) do
                | UnifyOk(subst: s2) ->
                  return check_ctor_args(
                    state: st1, fields: rf, args: ra, labels: labels_tail,
                    param_subst, enum_type,
                    subst: subst.subst_compose(s1: sm, s2), span, infer_expr_fn
                  )
                | UnifyErr(message: m) ->
                  match at do
                    | TyArrow(params: [], ret: ainner, requires: _, throw_row: _) ->
                      match unify.unify(t1: ainner, t2: expected, tdefs) do
                        | UnifyOk(subst: s2) ->
                          return check_ctor_args(
                            state: st1, fields: rf, args: ra, labels: labels_tail,
                            param_subst, enum_type,
                            subst: subst.subst_compose(s1: sm, s2), span, infer_expr_fn
                          )
                        | UnifyErr(_) -> return InferExprErr(message: "ctor field: " ++ m, span)
                      end
                    | _ -> return InferExprErr(message: "ctor field: " ++ m, span)
                  end
              end
          end
      end
  end
end
