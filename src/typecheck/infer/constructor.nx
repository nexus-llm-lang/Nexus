/**
 * typecheck/infer/constructor: pure leaf helpers for constructor-type building.
 *
 * Hosts variant-field sorting (insertion-sort by label), the string
 * comparison helper it depends on, the enum-type builder
 * (`build_enum_type` / `build_type_args`), and the list-reverse helper
 * for VariantField lists. None of these recurse through infer_expr — the
 * entry points `infer_constructor` and `check_ctor_args` stay in
 * src/typecheck/infer.nx because they call back into infer_expr to type
 * constructor arguments.
 *
 * Extracted from src/typecheck/infer.nx.
 */

import {
  TypeExpr, TyVar, TyUserDefined,
  VariantField
} from "src/common/ast.nx"
import { SubstEntry } from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import { TypeError } from "src/typecheck/errors.nx"
import * as str from "std:str"
import * as list from "std:list"

// ─── Variant-field insertion-sort ──────────────────────────────────────────
// HIR builder sorts labeled ctor args alphabetically; this keeps fields in
// the same order so positional checking in check_ctor_args aligns.

let variant_field_name = fn (f: VariantField) -> string throws { TypeError } do
  match f do
    | VariantField(name: Some(val: n), typ: _) -> n
    | VariantField(name: None, typ: _) -> ""
  end
end

export let insert_variant_field = fn (f: VariantField, sorted: [VariantField]) -> [VariantField] throws { TypeError } do
  return insert_variant_field_go(f, sorted, acc: [])
end

let insert_variant_field_go = fn (f: VariantField, sorted: [VariantField], acc: [VariantField]) -> [VariantField] throws { TypeError } do
  match sorted do
    | [] -> return rev_variant_fields(lst: acc, out: [f])
    | head :: rest ->
      if tc_str_lt(a: variant_field_name(f), b: variant_field_name(f: head)) then
        return rev_variant_fields(lst: acc, out: f :: sorted)
      else
        return insert_variant_field_go(f, sorted: rest, acc: head :: acc)
      end
  end
end

export let sort_variant_fields = fn (fields: [VariantField]) -> [VariantField] throws { TypeError } do
  match fields do
    | [] -> return []
    | f :: rest -> return insert_variant_field(f, sorted: sort_variant_fields(fields: rest))
  end
end

let tc_str_lt_loop = fn (a: string, b: string, idx: i64, la: i64, lb: i64) -> bool throws { TypeError } do
  if idx >= la then return idx < lb end
  if idx >= lb then return false end
  let ca = str.char_at(s: a, idx)
  let cb = str.char_at(s: b, idx)
  if ca == cb then
    return tc_str_lt_loop(a, b, idx: idx + 1, la, lb)
  else
    return ca < cb
  end
end

export let tc_str_lt = fn (a: string, b: string) -> bool throws { TypeError } do
  return tc_str_lt_loop(a, b, idx: 0, la: str.length(s: a), lb: str.length(s: b))
end

// ─── Enum-type builder ──────────────────────────────────────────────────────

export let build_enum_type = fn (name: string, params: [string], param_subst: [SubstEntry]) -> TypeExpr throws { TypeError } do
  let args = build_type_args(params, param_subst)
  return TyUserDefined(name, args)
end

export let build_type_args = fn (params: [string], param_subst: [SubstEntry]) -> [TypeExpr] throws { TypeError } do
  return build_type_args_go(params, param_subst, acc: [])
end

let build_type_args_go = fn (params: [string], param_subst: [SubstEntry], acc: [TypeExpr]) -> [TypeExpr] throws { TypeError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | p :: rest ->
      let resolved = subst.subst_apply(subst: param_subst, typ: TyVar(name: p))
      return build_type_args_go(params: rest, param_subst, acc: resolved :: acc)
  end
end

// ─── Local list reverse for VariantField ───────────────────────────────────

export let rev_variant_fields = fn (lst: [VariantField], out: [VariantField]) -> [VariantField] throws { TypeError } do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_variant_fields(lst: rest, out: x :: out)
  end
end
