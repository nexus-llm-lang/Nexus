/**
 * typecheck/infer/closure: pure leaf helpers for lambda / closure typing.
 *
 * Hosts self-contained helpers that do NOT recurse through infer_expr /
 * infer_stmts:
 *   - `build_param_named_types`: flatten HirParam list → NamedType list for
 *     arrow-type construction.
 *   - `add_params_to_env`: seed a new env scope with lambda-parameter bindings.
 *
 * The outer `infer_lambda` / `infer_thunk` / `infer_force` entry points stay
 * in src/typecheck/infer.nx because they call back into infer_stmts / infer_expr.
 *
 * Extracted from src/typecheck/infer.nx.
 */

import {
  HirParam
} from "src/ir/hir/types.nx"
import {
  NamedType
} from "src/common/ast.nx"
import {
  EnvEntry
}, * as tctypes from "src/typecheck/types.nx"
import { TypeError } from "src/typecheck/errors.nx"
import * as list from "std:list"

/** Flatten a HirParam list into a NamedType list, dropping sigil information.
 *  Used by infer_lambda and infer_let to build the TyArrow param vector. */
export let build_param_named_types = fn (params: [ HirParam ]) -> [ NamedType ] throws { TypeError } do
  return build_param_named_types_go(params, acc: [])
end

let build_param_named_types_go = fn (params: [ HirParam ], acc: [ NamedType ]) -> [ NamedType ] throws { TypeError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: _, name: n, sigil: _, typ: t) :: rest ->
      return build_param_named_types_go(params: rest, acc: NamedType(name: n, typ: t) :: acc)
  end
end

/** Extend an env with lambda-parameter bindings (one monomorphic scheme per param). */
export let add_params_to_env = fn (env: [ EnvEntry ], params: [ HirParam ]) -> [ EnvEntry ] throws { TypeError } do
  match params do
    | [] -> return env
    | HirParam(label: _, name: n, sigil: _, typ: t) :: rest ->
      return add_params_to_env(env: tctypes.env_insert(env, name: n, scheme: tctypes.mono(typ: t)), params: rest)
  end
end
