/**
 * typecheck/infer/exprs: expression-form type inference.
 *
 * Owns:
 *   - Record / array / index / field-access inference (infer_record,
 *     infer_array, infer_index, infer_field_access).
 *   - Control-flow expression inference (infer_if, infer_match,
 *     infer_match_cases, infer_while, infer_for).
 *   - Closure / effect expression inference (infer_lambda, infer_raise,
 *     infer_force, infer_thunk).
 *
 * All entry points receive `infer_expr_fn` (and `infer_stmts_fn` where the
 * body needs statement-level inference) as callbacks because these forms
 * recurse through sub-expressions via `infer_expr`.
 *
 * Extracted from src/typecheck/infer.nx.
 */

import { Span } from "src/types/span.nx"
import {
  TypeExpr,
  TyI64,
  TyBool,
  TyUnit,
  TyArray,
  TyRecord,
  TyLazy,
  TyLinear,
  TyBorrow,
  TyRef,
  TyUserDefined,
  TyArrow,
  TyRow,
  TyVar,
  NamedType,
  RecordDef
} from "src/types/type_expr.nx"
import {
  HirExpr,
  HirStmt,
  HirNamedExpr,
  HirMatchCase,
  HirParam,
  HirCallArg
} from "src/ir/hir/types.nx"
import {
  SubstEntry, Scheme, CheckState, FreshResult,
  InferExprResult, InferExprOk, InferExprErr,
  UnifyOk, UnifyErr,
  BindResult, BindOk, BindErr
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as unify from "src/typecheck/unify.nx"
import * as exhaustive from "src/typecheck/exhaustive.nx"
import * as capture from "src/typecheck/capture.nx"
import * as tcwf from "src/typecheck/tcwf.nx"
import { lookup_named_type, find_linear_field } from "src/typecheck/infer/collections.nx"
import { append_env, bind_pattern } from "src/typecheck/infer/statements.nx"
import {
  infer_stmts_tail_diverges,
  check_raise_admitted, exception_name_of_raised, is_residual_rethrow_var,
  check_call_throw_row_admitted,
  check_force_require_row,
  RaiseAdmissionResult, RaiseOk, RaiseRejected
} from "src/typecheck/infer/control_flow.nx"
import { build_param_named_types, add_params_to_env } from "src/typecheck/infer/closure.nx"
import { check_call_args } from "src/typecheck/infer/call.nx"
import { TypeError, DuplicateRecordLabel, UnknownField, RefEscapes } from "src/typecheck/errors.nx"
import { suggest_names } from "src/diagnostics/levenshtein.nx"
import * as list from "std:list"
import { Option, Some, None } from "std:option"

export let infer_record = fn (
  state: CheckState, fields: [ HirNamedExpr ], span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  return infer_record_fields(
    state,
    fields,
    subst: subst.subst_empty(),
    acc: [],
    span,
    infer_expr_fn
  )
end

let infer_record_fields = fn (
  state: CheckState, fields: [ HirNamedExpr ], subst: [ SubstEntry ], acc: [ NamedType ], span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match fields do
    | [] ->
      return InferExprOk(state, subst, typ: TyRecord(fields: list.reverse(xs: acc)))
    | HirNamedExpr(name: n, value: v) :: rest ->
      // Spec T-Record premise distinct(ℓ̄): reject duplicate field labels.
      match lookup_named_type(nts: acc, name: n) do
        | Some(val: _) -> throw DuplicateRecordLabel(label: n, span)
        | None -> ()
      end
      match infer_expr_fn(state, expr: v, ret_type: TyUnit) do
        | InferExprErr(
          message: m,
          span: espan
        ) -> return InferExprErr(message: "record field " ++ n ++ ": " ++ m, span: espan)
        | InferExprOk(state: st1, subst: s1, typ: ft) ->
          let sm = subst.subst_compose(s1: subst, s2: s1)
          return infer_record_fields(
            state: st1, fields: rest, subst: sm,
            acc: NamedType(name: n, typ: ft) :: acc, span, infer_expr_fn
          )
      end
  end
end

export let infer_array = fn (
  state: CheckState, elems: [ HirExpr ], span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match elems do
    | [] ->
      let FreshResult(state: st, typ: tv) = tctypes.tc_fresh_var(state)
      return InferExprOk(state: st, subst: subst.subst_empty(), typ: TyArray(elem: tv))
    | first :: rest ->
      match infer_expr_fn(state, expr: first, ret_type: TyUnit) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
        | InferExprOk(state: st1, subst: s1, typ: t1) ->
          return unify_array_elems(
            state: st1,
            elems: rest,
            subst: s1,
            elem_type: t1,
            span,
            infer_expr_fn
          )
      end
  end
end

let unify_array_elems = fn (
  state: CheckState, elems: [ HirExpr ], subst: [ SubstEntry ], elem_type: TypeExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match elems do
    | [] -> return InferExprOk(
      state,
      subst,
      typ: TyArray(elem: subst.subst_apply(subst, typ: elem_type))
    )
    | e :: rest ->
      match infer_expr_fn(state, expr: e, ret_type: TyUnit) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
        | InferExprOk(state: st1, subst: s1, typ: et) ->
          let sm = subst.subst_compose(s1: subst, s2: s1)
          let tdefs = tctypes.state_typedefs(state: st1)
          match unify.unify(t1: et, t2: subst.subst_apply(subst: sm, typ: elem_type), tdefs) do
            | UnifyErr(message: m) -> return InferExprErr(message: "array element: " ++ m, span)
            | UnifyOk(subst: s2) ->
              return unify_array_elems(
                state: st1,
                elems: rest,
                subst: subst.subst_compose(s1: sm, s2),
                elem_type,
                span,
                infer_expr_fn
              )
          end
      end
  end
end

export let infer_index = fn (
  state: CheckState, target: HirExpr, index: HirExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match infer_expr_fn(state, expr: target, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: tt) ->
      match infer_expr_fn(state: st1, expr: index, ret_type: TyUnit) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
        | InferExprOk(state: st2, subst: s2, typ: it) ->
          let sm = subst.subst_compose(s1, s2)
          let tdefs = tctypes.state_typedefs(state: st2)
          match unify.unify(t1: it, t2: TyI64, tdefs) do
            | UnifyErr(message: m) -> return InferExprErr(message: "index must be i64: " ++ m, span)
            | UnifyOk(subst: s3) ->
              let sf = subst.subst_compose(s1: sm, s2: s3)
              let arr_t = subst.subst_apply(subst: sf, typ: tt)
              // Peel TyBorrow / TyLinear / TyLazy wrappers so `arr_borrow[idx]`
              // works whenever the underlying type is `[| T |]`. Same shape as
              // the read-side of the Index arm in infer_stmt's Assign handler
              //
              match arr_t do
                | TyArray(elem: e)
                | TyBorrow(inner: TyArray(elem: e))
                | TyLinear(inner: TyArray(elem: e))
                | TyLazy(
                  inner: TyArray(elem: e),
                  require_row: _,
                  throw_row: _
                ) -> return InferExprOk(state: st2, subst: sf, typ: e)
                | _ -> return InferExprErr(message: "cannot index non-array type", span)
              end
          end
      end
  end
end

// T-Proj premise `¬linear(τ)`: a record whose any field carries a linear
// type is itself structurally
// linear. Projection on such a record would consume `r` via the sub-
// derivation while exposing only one field — silently dropping the
// other linear obligations. Reject at projection so the linear field
// must be decomposed via record-pattern destructuring (P-Record's `⨄`
// binds every linear field).

export let infer_field_access = fn (
  state: CheckState, target: HirExpr, field: string, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match infer_expr_fn(state, expr: target, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: tt) ->
      let resolved = subst.subst_apply(subst: s1, typ: tt)
      // T-Proj: expand typedef aliases to their underlying record fields.
      // When the resolved type is TyUserDefined(name, args), look up the
      // typedef, substitute type params, and project the requested field.
      let fs = match resolved do
        | TyRecord(fields: fs) -> Some(val: fs)
        | TyUserDefined(name: n, args: targs) ->
          match tctypes.typedef_lookup(defs: tctypes.state_typedefs(state: st1), name: n) do
            | Some(val: RecordDef(name: _, is_public: _, type_params: tps, fields: rec_fields)) ->
              let param_subst = unify.build_param_subst(params: tps, args: targs)
              Some(val: subst.apply_named_types(subst: param_subst, nts: rec_fields))
            | None -> None
          end
        | _ -> None
      end
      match fs do
        | None -> return InferExprErr(message: "field access on non-record type", span)
        | Some(val: rec_fields) ->
          match lookup_named_type(nts: rec_fields, name: field) do
            | Some(val: ft) ->
              match find_linear_field(
                fields: rec_fields,
                tdefs: tctypes.state_typedefs(state: st1),
                depth: 8
              ) do
                | Some(val: leaker) ->
                  return InferExprErr(
                    message: "T-Proj: cannot project field `" ++ field ++ "` on structurally-linear record (linear field `" ++ leaker ++ "` would be silently dropped); destructure via record pattern instead",
                    span
                  )
                | None -> return InferExprOk(state: st1, subst: s1, typ: ft)
              end
            | None ->
              let sugs = suggest_names(
                typo: field,
                candidates: named_type_names_list(nts: rec_fields)
              )
              throw UnknownField(name: field, suggestions: sugs, span)
          end
      end
  end
end

/** Collect field names from a [NamedType] list (for suggestions). */
let named_type_names_list = fn (nts: [ NamedType ]) -> [ string ] do
  return named_type_names_list_go(nts, acc: [])
end

let named_type_names_list_go = fn (nts: [ NamedType ], acc: [ string ]) -> [ string ] do
  match nts do
    | [] -> return acc
    | NamedType(
      name: n,
      typ: _
    ) :: rest -> return named_type_names_list_go(nts: rest, acc: n :: acc)
  end
end

// `if c then T else E end` types as the unified tail-expression type of T
// and E (mirrors `infer_match_cases`), so `let d = if v == K then 1 else 0
// end` correctly binds `d : i64` rather than `unit`. An `if` without `else`
// types as TyUnit (the missing-arm path has no value to unify against), and
// non-tail / empty branches fall back to TyUnit through `infer_stmts`.

export let infer_if = fn (
  state: CheckState, cond: HirExpr, then_b: [ HirStmt ], else_b: Option<[ HirStmt ]>, ret_type: TypeExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError },
  infer_stmts_fn: (
    state: CheckState,
    stmts: [ HirStmt ],
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match infer_expr_fn(state, expr: cond, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: ct) ->
      let tdefs = tctypes.state_typedefs(state: st1)
      match unify.unify(t1: ct, t2: TyBool, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(
          message: "if condition must be bool: " ++ m,
          span
        )
        | UnifyOk(subst: s2) ->
          let sm = subst.subst_compose(s1, s2)
          let env1 = subst.subst_apply_env(subst: sm, env: tctypes.state_env(state: st1))
          let st2 = tctypes.state_with_env(state: st1, env: env1)
          match infer_stmts_fn(state: st2, stmts: then_b, ret_type) do
            | InferExprErr(
              message: m,
              span: espan
            ) -> return InferExprErr(message: "if then: " ++ m, span: espan)
            | InferExprOk(state: st3, subst: s3, typ: then_t) ->
              let sm2 = subst.subst_compose(s1: sm, s2: s3)
              // T-If: close the then-block scope — bindings introduced
              // inside the then branch must not leak into the else branch or outer scope.
              // Mirrors the env pop in infer_match_cases / infer_try.
              let st3_closed = tctypes.state_with_env(
                state: st3,
                env: tctypes.state_env(state: st2)
              )
              match else_b do
                | None ->
                  let st_out = tctypes.state_with_env(state: st3, env: tctypes.state_env(state))
                  return InferExprOk(state: st_out, subst: sm2, typ: TyUnit)
                | Some(val: else_stmts) ->
                  match infer_stmts_fn(state: st3_closed, stmts: else_stmts, ret_type) do
                    | InferExprErr(
                      message: m,
                      span: espan
                    ) -> return InferExprErr(message: "if else: " ++ m, span: espan)
                    | InferExprOk(state: st4, subst: s4, typ: else_t) ->
                      let sm3 = subst.subst_compose(s1: sm2, s2: s4)
                      let tdefs2 = tctypes.state_typedefs(state: st4)
                      let then_applied = subst.subst_apply(subst: sm3, typ: then_t)
                      let else_applied = subst.subst_apply(subst: sm3, typ: else_t)
                      match unify.unify(t1: then_applied, t2: else_applied, tdefs: tdefs2) do
                        | UnifyErr(message: m) ->
                          return InferExprErr(
                            message: "if branches: type mismatch — then `" ++ tctypes.type_to_string(typ: then_applied) ++ "`, else `" ++ tctypes.type_to_string(typ: else_applied) ++ "`: " ++ m,
                            span
                          )
                        | UnifyOk(subst: s5) ->
                          let final_subst = subst.subst_compose(s1: sm3, s2: s5)
                          let result = subst.subst_apply(subst: final_subst, typ: else_applied)
                          // T-If: close the else-block scope before returning to outer env.
                          let st_out = tctypes.state_with_env(
                            state: st4,
                            env: tctypes.state_env(state)
                          )
                          return InferExprOk(state: st_out, subst: final_subst, typ: result)
                      end
                  end
              end
          end
      end
  end
end

export let infer_match = fn (
  state: CheckState, target: HirExpr, cases: [ HirMatchCase ], ret_type: TypeExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError },
  infer_stmts_fn: (
    state: CheckState,
    stmts: [ HirStmt ],
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match infer_expr_fn(state, expr: target, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: tt) ->
      let scrutinee = subst.subst_apply(subst: s1, typ: tt)
      match exhaustive.check_match_exhaustive(
        cases,
        scrutinee_type: scrutinee,
        enum_defs: tctypes.state_enums(state: st1),
        type_defs: tctypes.state_typedefs(state: st1)
      ) do
        | exhaustive.Exhaustive ->
          return infer_match_cases(
            state: st1,
            cases,
            target_type: tt,
            subst: s1,
            ret_type,
            result_type: None,
            span,
            infer_stmts_fn
          )
        | exhaustive.NonExhaustive(witness: w) ->
          return InferExprErr(
            message: "non-exhaustive match on `" ++ tctypes.type_to_string(typ: scrutinee) ++ "`: missing pattern for `" ++ w ++ "`",
            span
          )
        | exhaustive.RedundantArm(witness: w) ->
          return InferExprErr(
            message: "redundant match on `" ++ tctypes.type_to_string(typ: scrutinee) ++ "`: " ++ w,
            span
          )
        | exhaustive.ExnNoCatchAll ->
          // T-Match requires a syntactic catch-all when matching an `Exn`-typed
          // value: there is no residual channel, so an unmatched value is a stuck
          // dispatch. This holds even inside a catch body — the selective `catch`
          // desugar (src/ir/hir/convert/core.nx) appends its own synthetic
          // `| __exn_v -> throw __exn_v` re-throw arm, which IS a catch-all, so
          // that match passes here. A USER's bare `match e do ...` on an `Exn`
          // value inside a catch body has no such arm and is correctly rejected
          // (nexus-tgv4k, nexus-7hbia).
          return InferExprErr(
            message: "match on `Exn` must include a catch-all arm (`_ -> ...` or a variable pattern) to cover future exception constructors",
            span
          )
      end
  end
end

export let infer_match_cases = fn (
  state: CheckState, cases: [ HirMatchCase ],
  target_type: TypeExpr, subst: [ SubstEntry ], ret_type: TypeExpr,
  result_type: Option<TypeExpr>, span: Span,
  infer_stmts_fn: (
    state: CheckState,
    stmts: [ HirStmt ],
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match cases do
    | [] ->
      let final_type = match result_type do
        | Some(val: t) -> t
        | None -> TyUnit
      end
      return InferExprOk(state, subst, typ: final_type)
    | HirMatchCase(pattern: pat, body) :: rest ->
      let tt = subst.subst_apply(subst, typ: target_type)
      match bind_pattern(state, pattern: pat, target_type: tt, pat_span: span) do
        | BindErr(message: m) -> return InferExprErr(message: "match pattern: " ++ m, span)
        | BindOk(state: st1, subst: ps, env: bindings) ->
          let sm = subst.subst_compose(s1: subst, s2: ps)
          let case_env = append_env(base: tctypes.state_env(state: st1), extra: bindings)
          let st2 = tctypes.state_with_env(
            state: st1,
            env: subst.subst_apply_env(subst: sm, env: case_env)
          )
          match infer_stmts_fn(state: st2, stmts: body, ret_type) do
            | InferExprErr(
              message: m,
              span: espan
            ) -> return InferExprErr(message: "match case: " ++ m, span: espan)
            | InferExprOk(state: st3, subst: bs, typ: case_type) ->
              let all_subst = subst.subst_compose(s1: sm, s2: bs)
              let new_result = match result_type do
                | None -> case_type
                | Some(val: prev) ->
                  let tdefs = tctypes.state_typedefs(state: st3)
                  let applied_prev = subst.subst_apply(subst: all_subst, typ: prev)
                  match unify.unify(t1: applied_prev, t2: case_type, tdefs) do
                    | UnifyOk(_) -> case_type
                    | UnifyErr(_) ->
                      return InferExprErr(
                        message: "Match case type mismatch: expected `" ++ tctypes.type_to_string(typ: applied_prev) ++ "`, found `" ++ tctypes.type_to_string(typ: case_type) ++ "`",
                        span
                      )
                  end
              end
              // Pop case-local pattern bindings before threading to the next case.
              let st4 = tctypes.state_with_env(state: st3, env: tctypes.state_env(state))
              return infer_match_cases(
                state: st4, cases: rest,
                target_type, subst: all_subst,
                ret_type, result_type: Some(val: new_result), span, infer_stmts_fn
              )
          end
      end
  end
end

export let infer_while = fn (
  state: CheckState, cond: HirExpr, body: [ HirStmt ], ret_type: TypeExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError },
  infer_stmts_fn: (
    state: CheckState,
    stmts: [ HirStmt ],
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match infer_expr_fn(state, expr: cond, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: ct) ->
      let tdefs = tctypes.state_typedefs(state: st1)
      match unify.unify(t1: ct, t2: TyBool, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(
          message: "while cond must be bool: " ++ m,
          span
        )
        | UnifyOk(subst: s2) ->
          let sm = subst.subst_compose(s1, s2)
          let st2 = tctypes.state_with_env(
            state: st1,
            env: subst.subst_apply_env(subst: sm, env: tctypes.state_env(state: st1))
          )
          match infer_stmts_fn(state: st2, stmts: body, ret_type) do
            | InferExprErr(
              message: m,
              span: espan
            ) -> return InferExprErr(message: "while body: " ++ m, span: espan)
            | InferExprOk(state: st3, subst: s3, typ: _) ->
              // T-While: close the body scope — bindings introduced
              // inside the loop body must not leak into the outer scope.
              // Mirrors the env pop in infer_match_cases / infer_try.
              let st_out = tctypes.state_with_env(state: st3, env: tctypes.state_env(state))
              return InferExprOk(
                state: st_out,
                subst: subst.subst_compose(s1: sm, s2: s3),
                typ: TyUnit
              )
          end
      end
  end
end

export let infer_for = fn (
  state: CheckState, var: string, start: HirExpr, end_e: HirExpr, body: [ HirStmt ], ret_type: TypeExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError },
  infer_stmts_fn: (
    state: CheckState,
    stmts: [ HirStmt ],
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match infer_expr_fn(state, expr: start, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: st_t) ->
      let tdefs = tctypes.state_typedefs(state: st1)
      match unify.unify(t1: st_t, t2: TyI64, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(message: "for start must be i64: " ++ m, span)
        | UnifyOk(subst: s2) ->
          let sm = subst.subst_compose(s1, s2)
          match infer_expr_fn(state: st1, expr: end_e, ret_type: TyUnit) do
            | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
            | InferExprOk(state: st2, subst: s3, typ: et_t) ->
              let sm2 = subst.subst_compose(s1: sm, s2: s3)
              match unify.unify(t1: et_t, t2: TyI64, tdefs) do
                | UnifyErr(message: m) -> return InferExprErr(
                  message: "for end must be i64: " ++ m,
                  span
                )
                | UnifyOk(subst: s4) ->
                  let sm3 = subst.subst_compose(s1: sm2, s2: s4)
                  let body_env = tctypes.env_insert(
                    env: subst.subst_apply_env(subst: sm3, env: tctypes.state_env(state: st2)),
                    name: var,
                    scheme: tctypes.mono(typ: TyI64)
                  )
                  let st3 = tctypes.state_with_env(state: st2, env: body_env)
                  match infer_stmts_fn(state: st3, stmts: body, ret_type) do
                    | InferExprErr(
                      message: m,
                      span: espan
                    ) -> return InferExprErr(message: "for body: " ++ m, span: espan)
                    | InferExprOk(state: st4, subst: s5, typ: _) ->
                      // T-For: close the body scope — the loop variable
                      // and any bindings introduced inside the for body must not leak
                      // into the outer scope.  Mirrors T-While and T-If.
                      let st_out = tctypes.state_with_env(state: st4, env: tctypes.state_env(state))
                      return InferExprOk(
                        state: st_out,
                        subst: subst.subst_compose(s1: sm3, s2: s5),
                        typ: TyUnit
                      )
                  end
              end
          end
      end
  end
end

export let infer_lambda = fn (
  state: CheckState, type_params: [ string ], params: [ HirParam ], ret_type: TypeExpr, requires: TypeExpr, throw_row: TypeExpr, body: [ HirStmt ], span: Span,
  infer_stmts_fn: (
    state: CheckState,
    stmts: [ HirStmt ],
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  // spec narrative §T-Let-PolyFn restricts polymorphic
  // schemes to top-level `fn`. An inner `let f = fn <T>(...)` would
  // otherwise silently drop the quantifier list, leaving T as a rigid
  // TyUserDefined that fails to unify at the first call site (user would
  // see "cannot unify int literal with non-integer type"). Reject
  // explicitly so the diagnostic points at the real problem.
  // Top-level functions never route through infer_lambda — they are
  // registered with `Scheme(vars: tps, ...)` by `register_functions`
  // (src/typecheck/check.nx) and checked via `check_function`, so this
  // restriction only fires for inner lambdas.
  match type_params do
    | [] -> ()
    | _ ->
      return InferExprErr(
        message: "inner lambda `fn <...>(...)` carries type parameters: polymorphic schemes are only allowed on top-level `let f = fn <T>(...)` declarations (spec type-system-formal.md §T-Let-PolyFn). Hoist this lambda to a top-level binding to make it polymorphic, or drop the `<...>` quantifier list.",
        span
      )
  end
  // T-Lambda gravity rule: ¬escapesRef(τ_r) — the declared return type must
  // not expose a mutable reference cell. Inner lambdas (fn at expression
  // position) with e.g. `-> ref(i64)` are rejected here.
  // Spec: type-system-formal.md §"Gravity Rule" table + §T-Lambda.
  tcwf.enforce_no_escapes_ref(typ: ret_type, context: "return type of lambda", span, borrow_escapes: true)
  let param_types = build_param_named_types(params)
  // T-Lambda wfRef at parameter annotation sites
  // (spec §mutable-reference-well-formedness / wfRef):
  // each parameter type ~σ is rejected if σ is structurally linear.
  tcwf.enforce_wf_ref_params(params: param_types, span, tdefs: tctypes.state_record_defs(state))
  let outer_env = tctypes.state_env(state)
  let body_env = add_params_to_env(env: outer_env, params)
  // T-Lambda: a lambda is a NEW function — its body's raises / calls / forces
  // must be charged against the LAMBDA's own throws-row, not the enclosing
  // fn's active row.  Type the body under a fresh COLLECTING throw-row var so
  // that raise (T-Raise), call (T-App) and force (T-Force) pin their surfaced
  // exceptions into it (the unified inference-row pinning), then reconcile the
  // collected row with the lambda's declared row below.  Without this an
  // unannotated lambda body's `throw E` was admitted via the enclosing fn's
  // (possibly open) row and the arrow's `__implicit` row absorbed the narrower
  // declared slot at a later unify — laundering a wider-throwing body into a
  // narrower declared arrow row (a P5 containment hole, the lambda-return
  // residual of the unbound-throws-row class).  The enclosing fn's row is
  // restored after the body so the lambda's effects are NOT charged to it.
  let outer_throw = tctypes.state_throw_row(state)
  let FreshResult(state: st_thr, typ: tv_thr) = tctypes.tc_fresh_var(state)
  let body_env_state = tctypes.state_with_env(st_thr, env: body_env)
  let st1 = tctypes.state_with_throw_row(state: body_env_state, throw_row: tv_thr)
  match infer_stmts_fn(state: st1, stmts: body, ret_type) do
    | InferExprErr(
      message: m,
      span: espan
    ) -> return InferExprErr(message: "lambda body: " ++ m, span: espan)
    | InferExprOk(state: st2pre, subst: s1, typ: body_typ) ->
      let st2 = tctypes.state_with_throw_row(state: st2pre, throw_row: outer_throw)
      // T-Lambda: τ_r ≠ unit ⟹ tail(s†) = ⊥.
      // The body must supply the return value by one of two means:
      //   (a) the last statement is a non-unit expression whose type provides
      //       the implicit return value (body_typ ≠ TyUnit), or
      //   (b) every control-flow path ends with an explicit `return`/`throw`
      //       (infer_stmts_tail_diverges = true).
      // If neither holds — i.e. the body "falls off the end" with unit but
      // the declared ret_type is non-unit — reject with E2001.
      let body_is_unit = if let TyUnit = body_typ then true else false end
      let ret_is_unit = if let TyUnit = ret_type then true else false end
      if !ret_is_unit && body_is_unit && !infer_stmts_tail_diverges(stmts: body, depth: 64) then
        return InferExprErr(
          message: "lambda return type is non-unit but body does not end with a `return` or `throw` on all paths (spec T-Lambda: τ_r ≠ unit ⟹ tail(s†) = ⊥)",
          span
        )
      end
      // T-Lambda tail-return type check: when the body provides an implicit
      // return value (non-unit, non-diverging), unify body_typ against the
      // declared return type.  This catches bare `@τ` thunk tokens used as
      // tail returns where the lambda declares a plain `τ` return type
      // (spec nexus-16rto: @-token leaks through without this check).
      // Uses the same E2001 code as explicit `return` type mismatches.
      if !body_is_unit && !infer_stmts_tail_diverges(stmts: body, depth: 64) then
        let applied_body = subst.subst_apply(subst: s1, typ: body_typ)
        let applied_ret = subst.subst_apply(subst: s1, typ: ret_type)
        let tdefs = tctypes.state_typedefs(state: st2)
        match unify.unify(t1: applied_body, t2: applied_ret, tdefs) do
          | UnifyOk(subst: _) -> ()
          | UnifyErr(message: m) ->
            return InferExprErr(
              message: "implicit tail return type mismatch: " ++ m,
              span
            )
        end
      end
      let scan = capture.scan_lambda_captures(body, outer_env, params)
      match scan do
        | capture.CaptureScan(
          linear: _,
          ref_hit: Some(val: capture.RefCaptureHit(name: rn, span: rsp))
        ) ->
          return InferExprErr(
            message: "lambda captures mutable ref binding " ++ rn ++ " (refs are stack-confined)",
            span: rsp
          )
        | capture.CaptureScan(linear: lin, ref_hit: None) ->
          // Reconcile the body's COLLECTED throws-row with the lambda's
          // declared row.  An unannotated lambda's declared row is the
          // `__implicit` open sentinel: adopt the collected row as the arrow's
          // throws-row so the actual throws are reflected (and reject later if
          // narrowed at a deferred slot).  A lambda that DECLARES a closed
          // throws row must have its body's collected throws admitted by that
          // row (T-Lambda: the body may raise no more than the declared row);
          // the declared row stays as the arrow's row.
          let collected = subst.subst_apply(subst: s1, typ: tv_thr)
          match reconcile_lambda_throw_row(state: st2, collected, declared: throw_row, span) do
            | InferExprErr(message: m, span: esp) -> return InferExprErr(message: m, span: esp)
            | InferExprOk(state: st3, subst: s_recon, typ: effective_thr) ->
              let s_all = subst.subst_compose(s1, s2: s_recon)
              let arrow = TyArrow(
                params: param_types,
                ret: ret_type,
                requires,
                throw_row: effective_thr
              )
              let wrapped = if lin then TyLinear(inner: arrow) else arrow end
              return InferExprOk(
                state: st3,
                subst: s_all,
                typ: subst.subst_apply(subst: s_all, typ: wrapped)
              )
          end
      end
  end
end

/** T-Lambda throws-row reconciliation.  Given the body's COLLECTED throws-row
 *  (pinned by raise / call / force during body inference) and the lambda's
 *  declared row, returns the effective arrow throws-row (in `typ`):
 *   - declared `__implicit` open (unannotated lambda): adopt `collected`, so a
 *     later unify at a narrower deferred slot rejects the surplus exceptions.
 *   - declared closed row: the collected throws must be admitted by it
 *     (otherwise the body raises more than the annotation permits); the
 *     declared row is kept.
 *   - any other declared shape (a genuine effect-variable etc.): keep declared. */
let reconcile_lambda_throw_row = fn (
  state: CheckState, collected: TypeExpr, declared: TypeExpr, span: Span
) -> InferExprResult throws { TypeError } do
  match declared do
    | TyRow(types: _, rest: Some(val: TyVar(name: "__implicit"))) ->
      return InferExprOk(state, subst: subst.subst_empty(), typ: collected)
    | TyRow(types: _, rest: None) ->
      let groups = tctypes.state_exception_groups(state)
      let fn_pure_set = tctypes.state_fn_pure_set(state)
      match check_call_throw_row_admitted(
        callee_row: collected,
        caller_row: declared,
        groups,
        func: "lambda body",
        fn_pure_set
      ) do
        | RaiseRejected(message: m) -> return InferExprErr(message: "lambda body: " ++ m, span)
        | RaiseOk -> return InferExprOk(state, subst: subst.subst_empty(), typ: declared)
      end
    | _ -> return InferExprOk(state, subst: subst.subst_empty(), typ: declared)
  end
end

// Result of pinning a raised variant into an inference-row variable: the
// advanced state (fresh-var supply bumped) plus the extra substitution that
// records the row constraint (empty when no pinning applied).
type PinResult = PinResult(state: CheckState, subst: [ SubstEntry ])

/** T-Raise row-pinning for inference-row contexts.
 *
 *  When the active throws-row is still an unsolved inference variable — which
 *  happens inside a suspended thunk body (T-LetThunk types `e` under a fresh
 *  `throw_row` so the body's effects are collected rather than charged to the
 *  enclosing fn) — a `throw C` must EXTEND that row to include `C`, exactly as
 *  a declared closed row already lists its members. Otherwise the thunk's
 *  deferred throws-row escapes as an unbound variable and a later thunk-vs-thunk
 *  unification can bind it to a NARROWER declared row, dropping the actually
 *  raised exception (a P5 containment hole).
 *
 *  Pinning is applied in two shapes and skipped otherwise (so ordinary
 *  function bodies are untouched):
 *   - bare `TyVar` active row (the collecting thunk row before any throw):
 *     bind it to an OPEN row `{ C | ?r }` with a fresh tail `?r`, keeping it
 *     extensible for further throws in the same body.
 *   - open row `{ ... | ?t }` whose tail `?t` is a genuine inference variable
 *     (NOT the `__implicit` absent-annotation sentinel): unify against
 *     `{ C | ?r }` so `C` accumulates into the head while the row stays open.
 *
 *  Closed rows (declared `throws { ... }` / `throws {}`), the `__implicit`
 *  open-tail sentinel, and non-row active rows are left as-is: their admission
 *  is already decided by check_raise_admitted.
 */
let pin_raised_into_row = fn (state: CheckState, name: string, row: TypeExpr) -> PinResult do
  match row do
    | TyVar(name: rn) ->
      if rn == "__implicit" then return PinResult(state, subst: subst.subst_empty()) end
      let FreshResult(state: st1, typ: tail) = tctypes.tc_fresh_var(state)
      let open_row = TyRow(types: [ TyUserDefined(name, args: []) ], rest: Some(val: tail))
      return PinResult(state: st1, subst: subst.subst_single(var: rn, typ: open_row))
    | TyRow(types: _, rest: Some(val: tail)) ->
      match tail do
        | TyVar(name: "__implicit") -> return PinResult(state, subst: subst.subst_empty())
        | TyVar(name: _) ->
          let FreshResult(state: st1, typ: ftail) = tctypes.tc_fresh_var(state)
          let open_row = TyRow(types: [ TyUserDefined(name, args: []) ], rest: Some(val: ftail))
          let tdefs = tctypes.state_typedefs(state: st1)
          match unify.unify(t1: row, t2: open_row, tdefs) do
            | UnifyOk(subst: s) -> return PinResult(state: st1, subst: s)
            | UnifyErr(_) -> return PinResult(state, subst: subst.subst_empty())
          end
        | _ -> return PinResult(state, subst: subst.subst_empty())
      end
    | _ -> return PinResult(state, subst: subst.subst_empty())
  end
end

/** Collect the concrete `TyUserDefined` members of a (possibly open) surfaced
 *  throws row.  Tail variables and non-row shapes contribute nothing — only
 *  the literal exception names a forced thunk can raise are pinnable. */
let surfaced_row_members = fn (row: TypeExpr) -> [ TypeExpr ] do
  match row do
    | TyRow(types: ts, rest: _) -> return only_user_defined(ts)
    | _ -> return []
  end
end

let only_user_defined = fn (ts: [ TypeExpr ]) -> [ TypeExpr ] do
  match ts do
    | [] -> return []
    | t :: rest ->
      match t do
        | TyUserDefined(name: _, args: _) -> return t :: only_user_defined(ts: rest)
        | _ -> return only_user_defined(ts: rest)
      end
  end
end

/** Pin a forced thunk's surfaced throws (T-Force) into the active throws-row
 *  the same way infer_raise (T-Raise) and infer_call (T-App) pin raised /
 *  callee exceptions.  When the active row is the still-unsolved collecting
 *  row of a suspended thunk body or an unannotated lambda body, the surfaced
 *  variants must EXTEND it; otherwise the collecting row escapes unbound and a
 *  later thunk-vs-thunk (or arrow-vs-arrow) unification can bind it to a
 *  narrower declared row, dropping the exceptions the force can surface (a P5
 *  containment hole — the force-path residual of the unbound-throws-row class).
 *
 *  Mirrors pin_callee_row_into_caller: only a collecting var or an open caller
 *  row whose tail is a genuine inference variable (not the `__implicit`
 *  absent-annotation sentinel) is extended; closed / non-row caller rows are
 *  left as-is (admission already decided by check_call_throw_row_admitted). */
let pin_surfaced_throws_into_row = fn (
  state: CheckState, surfaced_row: TypeExpr, active_row: TypeExpr
) -> PinResult do
  let members = surfaced_row_members(row: surfaced_row)
  if list.is_empty(xs: members) then return PinResult(state, subst: subst.subst_empty()) end
  match active_row do
    | TyVar(name: rn) ->
      if rn == "__implicit" then return PinResult(state, subst: subst.subst_empty()) end
      let FreshResult(state: st1, typ: tail) = tctypes.tc_fresh_var(state)
      let open_row = TyRow(types: members, rest: Some(val: tail))
      return PinResult(state: st1, subst: subst.subst_single(var: rn, typ: open_row))
    | TyRow(types: _, rest: Some(val: tail)) ->
      match tail do
        | TyVar(name: "__implicit") -> return PinResult(state, subst: subst.subst_empty())
        | TyVar(name: _) ->
          let FreshResult(state: st1, typ: ftail) = tctypes.tc_fresh_var(state)
          let open_row = TyRow(types: members, rest: Some(val: ftail))
          let tdefs = tctypes.state_typedefs(state: st1)
          match unify.unify(t1: active_row, t2: open_row, tdefs) do
            | UnifyOk(subst: s) -> return PinResult(state: st1, subst: s)
            | UnifyErr(_) -> return PinResult(state, subst: subst.subst_empty())
          end
        | _ -> return PinResult(state, subst: subst.subst_empty())
      end
    | _ -> return PinResult(state, subst: subst.subst_empty())
  end
end

/** Decide whether the active require row is a still-unsolved COLLECTING row
 *  (the fresh require var of a suspended thunk body / unannotated lambda body)
 *  rather than a fn's declared concrete require row.  When collecting, a force
 *  of a thunk that requires extra capabilities must DEFER those into the
 *  collecting row (extend it), not discharge them eagerly against the
 *  constructing fn's ambient — otherwise a valid thunk-of-a-thunk whose outer
 *  require row legitimately defers the inner's capabilities is wrongly rejected
 *  (the require-row dual of the throws hole, an over-rejection in the SAFE
 *  direction).  Mirrors the throws-collecting var: a bare TyVar or an open row
 *  with a genuine inference-variable tail. */
let require_row_is_collecting = fn (row: TypeExpr) -> bool do
  match row do
    | TyVar(name: rn) -> return rn != "__implicit"
    | TyRow(types: _, rest: Some(val: tail)) ->
      match tail do
        | TyVar(name: "__implicit") -> return false
        | TyVar(name: _) -> return true
        | _ -> return false
      end
    | _ -> return false
  end
end

/** Pin a forced thunk's surfaced require capabilities into the active
 *  collecting require row (the dual of pin_surfaced_throws_into_row). */
let pin_surfaced_require_into_row = fn (
  state: CheckState, surfaced_row: TypeExpr, active_row: TypeExpr
) -> PinResult do
  let members = surfaced_row_members(row: surfaced_row)
  if list.is_empty(xs: members) then return PinResult(state, subst: subst.subst_empty()) end
  match active_row do
    | TyVar(name: rn) ->
      let FreshResult(state: st1, typ: tail) = tctypes.tc_fresh_var(state)
      let open_row = TyRow(types: members, rest: Some(val: tail))
      return PinResult(state: st1, subst: subst.subst_single(var: rn, typ: open_row))
    | TyRow(types: _, rest: Some(val: tail)) ->
      match tail do
        | TyVar(name: _) ->
          let FreshResult(state: st1, typ: ftail) = tctypes.tc_fresh_var(state)
          let open_row = TyRow(types: members, rest: Some(val: ftail))
          let tdefs = tctypes.state_typedefs(state: st1)
          match unify.unify(t1: active_row, t2: open_row, tdefs) do
            | UnifyOk(subst: s) -> return PinResult(state: st1, subst: s)
            | UnifyErr(_) -> return PinResult(state, subst: subst.subst_empty())
          end
        | _ -> return PinResult(state, subst: subst.subst_empty())
      end
    | _ -> return PinResult(state, subst: subst.subst_empty())
  end
end

export let infer_raise = fn (
  state: CheckState, inner: HirExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match infer_expr_fn(state, expr: inner, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t) ->
      // T-Throw-Val: unify(τ, Exn) — the thrown value must have type Exn.
      // Constructor applications (T-Throw-Ctor / T-Throw-CtorNullary) satisfy
      // this trivially because their result type is already Exn via D-Exception.
      let tdefs = tctypes.state_typedefs(state: st1)
      let sc = match unify.unify(t1: t, t2: TyUserDefined(name: "Exn", args: []), tdefs) do
        | UnifyErr(_) -> return InferExprErr(
            message: "throw: payload must have type Exn, got " ++ tctypes.type_to_string(typ: t),
            span)
        | UnifyOk(subst: s2) -> subst.subst_compose(s1, s2)
      end
      // T-Raise: the raised value's exception identity must be admitted by
      // the active throws-row ρ_q. Rows containing TyUserDefined("Exn", _)
      // accept any Exn variant.  Narrow rows like `throws { LirError }`
      // accept only declared members.
      let row = subst.subst_apply(subst: sc, typ: tctypes.state_throw_row(state: st1))
      let groups = tctypes.state_exception_groups(state: st1)
      let exn_name_opt = exception_name_of_raised(state: st1, expr: inner)
      // Synthetic residual re-throw arm `| __exn_v -> throw __exn_v` appended by
      // the selective-`catch` desugar (src/ir/hir/convert/core.nx). It propagates
      // the catch's RESIDUAL — the body-throw variants minus the caught ones —
      // which is ⊆ the enclosing declared row by the T-TryCatch augmentation
      // invariant (body row = outer ∪ caught). So admit it unconditionally rather
      // than checking `Exn` (the catch param's universal type) against the narrow
      // outer row, which would spuriously reject (nexus-7hbia, nexus-c3lk0).
      let is_synthetic_residual_rethrow = is_residual_rethrow_var(expr: inner)
      if !(is_synthetic_residual_rethrow) then
        match check_raise_admitted(name_opt: exn_name_opt, row, groups) do
          | RaiseOk -> ()
          | RaiseRejected(message: m) -> return InferExprErr(message: m, span)
        end
      end
      // T-Raise (inference-row pinning): when the active throws-row is still an
      // unsolved inference variable (the collecting row of a suspended thunk
      // body), extend it to include the raised variant so the thunk's deferred
      // throws-row carries the exception rather than escaping unbound and later
      // unifying away against a narrower declared row.
      // For a constructor raise (`throw C(...)` or nullary `throw C`) pin
      // the collecting row with the raised variant name `C`.  For T-Throw-Val
      // (`throw e` where e : Exn from a catch binding) `exception_name_of_raised`
      // returns `Some("Exn")` — pin the sentinel so the deferred row carries
      // `Exn`, which (like a closed `{Exn}` row) fails to narrow into a
      // strictly smaller declared row at a later thunk-vs-thunk unification.
      // For opaque expressions (calls, projections) name_opt = None: pin `Exn`
      // conservatively.
      let PinResult(state: st_pin, subst: pin_s) = match exn_name_opt do
        | Some(val: nm) -> pin_raised_into_row(state: st1, name: nm, row)
        | None -> pin_raised_into_row(state: st1, name: "Exn", row)
      end
      let sc2 = subst.subst_compose(s1: sc, s2: pin_s)
      // Raise diverges; the result type is unconstrained (fresh tyvar so the
      // surrounding context can pick whatever it needs).
      let FreshResult(state: st2, typ: tv) = tctypes.tc_fresh_var(state: st_pin)
      return InferExprOk(state: st2, subst: sc2, typ: tv)
  end
end

// Helper: closed empty row `{}`.
let lazy_empty_row = fn () -> TypeExpr do
  return TyRow(types: [], rest: None)
end

export let infer_force = fn (
  state: CheckState, inner: HirExpr, ret_type: TypeExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match infer_expr_fn(state, expr: inner, ret_type) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t) ->
      match t do
        | TyLazy(inner: u, require_row: rq, throw_row: thr) ->
          // T-Force: discharge the thunk's deferred throw_row against the
          // caller's active throw_row.  A `throws {}` caller (closed empty row)
          // must not force a thunk whose throw_row is non-empty.
          let surfaced_thr = subst.subst_apply(subst: s1, typ: thr)
          let caller_row = subst.subst_apply(subst: s1, typ: tctypes.state_throw_row(state: st1))
          let groups = tctypes.state_exception_groups(state: st1)
          let fn_pure_set = tctypes.state_fn_pure_set(state: st1)
          match check_call_throw_row_admitted(
            callee_row: surfaced_thr,
            caller_row,
            groups,
            func: "force",
            fn_pure_set
          ) do
            | RaiseRejected(message: m2) -> return InferExprErr(message: m2, span)
            | RaiseOk ->
              // T-Force (inference-row pinning): when the active throws-row is
              // still an unsolved collecting var (a suspended thunk body or an
              // unannotated lambda body), extend it to include the forced
              // thunk's surfaced exceptions so they are not later unified away
              // against a narrower declared row at the deferred-narrowing slot.
              let PinResult(state: st_pt, subst: pin_t) =
                pin_surfaced_throws_into_row(
                  state: st1,
                  surfaced_row: surfaced_thr,
                  active_row: caller_row
                )
              let s_pt = subst.subst_compose(s1, s2: pin_t)
              // T-Force spec §T-Force: discharge thunk's require_row against the
              // ambient require_row.  Every capability needed by the thunk at
              // force time must already be in the forcing context's ambient row.
              let ambient_rq = subst.subst_apply(
                subst: s_pt,
                typ: tctypes.state_require_row(state: st_pt)
              )
              let resolved_rq = subst.subst_apply(subst: s_pt, typ: rq)
              // Require-row dual: when the ambient require row is a still-
              // unsolved COLLECTING var (a suspended thunk / unannotated lambda
              // body), the forced thunk's required capabilities are DEFERRED
              // into that collecting row rather than discharged eagerly against
              // the constructing fn's declared ambient (which would wrongly
              // reject a valid thunk-of-a-thunk that legitimately defers the
              // inner's capabilities).  Discharge eagerly only against a
              // concrete declared ambient row.
              if require_row_is_collecting(row: ambient_rq) then
                let PinResult(state: st_pr, subst: pin_r) =
                  pin_surfaced_require_into_row(
                    state: st_pt,
                    surfaced_row: resolved_rq,
                    active_row: ambient_rq
                  )
                let s_pr = subst.subst_compose(s1: s_pt, s2: pin_r)
                return InferExprOk(
                  state: st_pr,
                  subst: s_pr,
                  typ: subst.subst_apply(subst: s_pr, typ: u)
                )
              end
              match check_force_require_row(
                thunk_require_row: resolved_rq,
                ambient_require_row: ambient_rq
              ) do
                | Some(val: missing) ->
                  return InferExprErr(
                    message: "force: thunk requires capability '" ++ missing
                      ++ "' which is not in the ambient require row (T-Force: ρ_q' ⊆ ρ_q)",
                    span
                  )
                | None -> return InferExprOk(
                  state: st_pt,
                  subst: s_pt,
                  typ: subst.subst_apply(subst: s_pt, typ: u)
                )
              end
          end
        | _ ->
          // T-Force spec: unify(τ, @β) with fresh β, so that unresolved ?α
          // gets pinned to TyLazy(?β) rather than falling through to an error.
          let FreshResult(state: st2, typ: tv) = tctypes.tc_fresh_var(state: st1)
          // Fresh require_row and throw_row variables for the thunk shape.
          let FreshResult(state: st3, typ: tv_rq) = tctypes.tc_fresh_var(state: st2)
          let FreshResult(state: st4, typ: tv_thr) = tctypes.tc_fresh_var(state: st3)
          let tdefs = tctypes.state_typedefs(state: st4)
          match unify.unify(
            t1: t,
            t2: TyLazy(inner: tv, require_row: tv_rq, throw_row: tv_thr),
            tdefs
          ) do
            | UnifyErr(_) -> return InferExprErr(
                message: "force: expected lazy type '@T', got non-lazy value",
                span)
            | UnifyOk(subst: s2) ->
              let sc = subst.subst_compose(s1, s2)
              let resolved_thr = subst.subst_apply(subst: sc, typ: tv_thr)
              // Check the resolved throw_row against the caller's throw_row.
              let caller_row = subst.subst_apply(
                subst: sc,
                typ: tctypes.state_throw_row(state: st4)
              )
              let groups = tctypes.state_exception_groups(state: st4)
              let fn_pure_set = tctypes.state_fn_pure_set(state: st4)
              match check_call_throw_row_admitted(
                callee_row: resolved_thr,
                caller_row,
                groups,
                func: "force",
                fn_pure_set
              ) do
                | RaiseRejected(message: m2) -> return InferExprErr(message: m2, span)
                | RaiseOk ->
                  // T-Force (inference-row pinning): mirror the TyLazy arm —
                  // pin the surfaced throws into a collecting active row.
                  let PinResult(state: st_pt, subst: pin_t) =
                    pin_surfaced_throws_into_row(
                      state: st4,
                      surfaced_row: resolved_thr,
                      active_row: caller_row
                    )
                  let sc_pt = subst.subst_compose(s1: sc, s2: pin_t)
                  // T-Force spec §T-Force: discharge thunk's require_row.
                  let ambient_rq = subst.subst_apply(
                    subst: sc_pt,
                    typ: tctypes.state_require_row(state: st_pt)
                  )
                  let resolved_rq = subst.subst_apply(subst: sc_pt, typ: tv_rq)
                  // Require-row dual: defer into a collecting ambient.
                  if require_row_is_collecting(row: ambient_rq) then
                    let PinResult(state: st_pr, subst: pin_r) =
                      pin_surfaced_require_into_row(
                        state: st_pt,
                        surfaced_row: resolved_rq,
                        active_row: ambient_rq
                      )
                    let sc_pr = subst.subst_compose(s1: sc_pt, s2: pin_r)
                    return InferExprOk(
                      state: st_pr,
                      subst: sc_pr,
                      typ: subst.subst_apply(subst: sc_pr, typ: tv)
                    )
                  end
                  match check_force_require_row(
                    thunk_require_row: resolved_rq,
                    ambient_require_row: ambient_rq
                  ) do
                    | Some(val: missing) ->
                      return InferExprErr(
                        message: "force: thunk requires capability '" ++ missing
                          ++ "' which is not in the ambient require row (T-Force: ρ_q' ⊆ ρ_q)",
                        span
                      )
                    | None ->
                      return InferExprOk(
                        state: st_pt,
                        subst: sc_pt,
                        typ: subst.subst_apply(subst: sc_pt, typ: tv)
                      )
                  end
              end
          end
      end
  end
end

export let infer_thunk = fn (
  state: CheckState, body: HirExpr, ret_type: TypeExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  span
  // T-LetThunk: type e in an isolated collecting context (fresh throw_row and
  // require_row) so the body's effects are NOT charged to the enclosing fn.
  // The enclosing fn's throw_row and require_row are restored after typing e,
  // and the captured fresh rows become the thunk type's deferred rows.
  let FreshResult(state: st0, typ: tv_thr) = tctypes.tc_fresh_var(state)
  let FreshResult(state: st0b, typ: tv_rq) = tctypes.tc_fresh_var(state: st0)
  let body_state = tctypes.state_with_throw_row(state: st0b, throw_row: tv_thr)
  let body_state2 = tctypes.state_with_require_row(state: body_state, require_row: tv_rq)
  let outer_throw = tctypes.state_throw_row(state)
  let outer_req = tctypes.state_require_row(state)
  match infer_expr_fn(state: body_state2, expr: body, ret_type) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t) ->
      let st1r = tctypes.state_with_throw_row(state: st1, throw_row: outer_throw)
      let st1r2 = tctypes.state_with_require_row(state: st1r, require_row: outer_req)
      // nexus-0u4tw row-pinning: when the thunk body's inferred type is
      // already a TyLazy carrying concrete deferred rows, the outer
      // auto-thunk's collecting rows (tv_rq, tv_thr) must absorb those rows
      // rather than leave them buried under an extra layer. Without this,
      // `let @s = mk()` (where mk: fn() -> @(τ throws {E})) desugars to
      // `let @s = Thunk(mk())` and the inner `{E}` is hidden inside the
      // outer thunk type — force-once peels only the outer, exposing the
      // inner thunk as a value with non-empty deferred rows that no
      // subsequent force surfaces at the typecheck level (P5 leak).
      // Pin the collecting rows to the inner thunk's rows so the rows are
      // visible at the binder and surface when the outer thunk is forced.
      let resolved_t = subst.subst_apply(subst: s1, typ: t)
      let s_pinned = match resolved_t do
        | TyLazy(inner: _, require_row: inner_rq, throw_row: inner_thr) ->
          let tdefs = tctypes.state_typedefs(state: st1r2)
          let s_thr = match unify.unify(t1: tv_thr, t2: inner_thr, tdefs) do
            | UnifyOk(subst: s) -> s
            | UnifyErr(_) -> subst.subst_empty()
          end
          let s_rq = match unify.unify(t1: tv_rq, t2: inner_rq, tdefs) do
            | UnifyOk(subst: s) -> s
            | UnifyErr(_) -> subst.subst_empty()
          end
          subst.subst_compose(s1: s_thr, s2: s_rq)
        | _ -> subst.subst_empty()
      end
      let s_final = subst.subst_compose(s1, s2: s_pinned)
      // nexus-5djpx (T-LetThunk annotation row-pinning, fy025 sibling): resolve
      // the collecting rows through the accumulated substitution BEFORE handing
      // the thunk type back. The body's raises pin concrete labels into
      // `tv_thr`/`tv_rq` via `s_final`, but the returned `TyLazy` referenced the
      // bare fresh vars — so the downstream annotation unify in `infer_let_eval`
      // (`let @t : @(τ throws {})`) saw an *unbound* throw_row and silently
      // bound it to the annotation's narrower row, widening the body's deferred
      // throws away (runtime then escapes the declared `throws {}`). Surfacing
      // the resolved rows makes the unify see `{E}` vs `{}` and reject, mirroring
      // the T-Force concrete-label surfacing of nexus-fy025.
      let resolved_thr = subst.subst_apply(subst: s_final, typ: tv_thr)
      let resolved_rq = subst.subst_apply(subst: s_final, typ: tv_rq)
      return InferExprOk(
        state: st1r2,
        subst: s_final,
        typ: TyLazy(inner: t, require_row: resolved_rq, throw_row: resolved_thr)
      )
  end
end

// T-App on an expression callee (T-Proj + T-App for record-field calls, or
// postfix-call `(expr)(args)`). Infers the callee expression, peels any
// modality wrappers, checks it is an arrow type, and delegates argument
// checking to check_call_args.  Enforces the throw-row side-condition exactly
// as infer_call does for named-call sites.
export let infer_call_expr = fn (
  state: CheckState, callee: HirExpr, args: [ HirCallArg ], span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match infer_expr_fn(state, expr: callee, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: callee_raw) ->
      // Peel `%` modality wrapper (linear-capture lambda) or perform T-Force
      // elaboration for `@` (lazy thunk callee, spec §T-App thunk-callee).
      let callee_type = match callee_raw do
        | TyLinear(inner: u) -> u
        | TyLazy(inner: u, require_row: lazy_rq, throw_row: lazy_thr) ->
          // T-Force: surface deferred throw_row and check deferred require_row.
          let lazy_caller_row = tctypes.state_throw_row(state: st1)
          let groups_ce = tctypes.state_exception_groups(state: st1)
          let fn_pure_set_ce = tctypes.state_fn_pure_set(state: st1)
          match check_call_throw_row_admitted(
            callee_row: lazy_thr,
            caller_row: lazy_caller_row,
            groups: groups_ce,
            func: "(callee force)",
            fn_pure_set: fn_pure_set_ce
          ) do
            | RaiseRejected(message: m) -> return InferExprErr(message: "force callee: " ++ m, span)
            | RaiseOk ->
              let ambient_rq = tctypes.state_require_row(state: st1)
              match check_force_require_row(
                thunk_require_row: lazy_rq,
                ambient_require_row: ambient_rq
              ) do
                | Some(val: missing) ->
                  return InferExprErr(
                    message: "force callee: thunk requires capability '" ++ missing
                      ++ "' which is not in the ambient require row",
                    span
                  )
                | None -> ()
              end
          end
          u
        | _ -> callee_raw
      end
      match callee_type do
        | TyArrow(params, ret, requires: _, throw_row: callee_thr) ->
          match check_call_args(state: st1, params, args, ret, subst: s1, span, infer_expr_fn) do
            | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
            | InferExprOk(state: st2, subst: s_all, typ: rt) ->
              // Throw-row side-condition: same enforcement as infer_call.
              let callee_row = subst.subst_apply(subst: s_all, typ: callee_thr)
              let caller_row = subst.subst_apply(
                subst: s_all,
                typ: tctypes.state_throw_row(state: st2)
              )
              let groups = tctypes.state_exception_groups(state: st2)
              let fn_pure_set = tctypes.state_fn_pure_set(state: st2)
              match check_call_throw_row_admitted(
                callee_row,
                caller_row,
                groups,
                func: "(callee)",
                fn_pure_set
              ) do
                | RaiseOk -> return InferExprOk(state: st2, subst: s_all, typ: rt)
                | RaiseRejected(message: m) -> return InferExprErr(message: m, span)
              end
          end
        | _ ->
          return InferExprErr(
            message: "callee expression is not a function (got "
              ++ tctypes.type_to_string(typ: callee_type) ++ ")",
            span
          )
      end
  end
end
