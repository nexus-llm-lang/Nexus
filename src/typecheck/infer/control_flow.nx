/**
 * typecheck/infer/control_flow: pure leaf helpers for control-flow inference.
 *
 * Hosts three self-contained clusters that do NOT recurse through
 * infer_expr / infer_stmts:
 *   - Raise row-admission check (`RaiseAdmissionResult`, `check_raise_admitted`,
 *     `row_admits_exception`, `exception_name_of_raised`): decides whether a
 *     throw or callee throws-row is covered by the ambient row.
 *   - Divergence predicates (`stmt_diverges`, `infer_expr_diverges_depth`, etc.):
 *     structural T-Seq ⊥ checks used by infer_stmts to detect unreachable code.
 *   - Inject-site checks (`check_handlers_bound`, `check_inject_uniqueness`,
 *     `check_inject_require_subset`): T-Inject premise validation that does not
 *     recurse into expression inference.
 *
 * The outer if/match/while/for/lambda/try/inject entry points stay in
 * src/typecheck/infer.nx because they call back into infer_expr / infer_stmts.
 *
 * Extracted from src/typecheck/infer.nx.
 */

import { Span } from "src/types/span.nx"
import {
  TypeExpr,
  TyArrow,
  TyLinear,
  TyList,
  TyArray,
  TyRow,
  TyHandler,
  TyLazy,
  TyUnit,
  TyUserDefined,
  TyVar
} from "src/types/type_expr.nx"
import {
  HirExpr, HirExprKind, HirStmt, HirStmtKind, HirMatchCase,
  HirPatternKind, PVar, PCtor, PWild, PLit, PRec, POr,
  HirPatternField, HirRecordPatField,
  ExceptionGroupEntry
} from "src/ir/hir/types.nx"
import {
  CheckState, InferExprResult, InferExprOk, InferExprErr, Scheme,
  TypeDefEntry, UnifyOk, UnifyErr,
  EnumVariantInfo, Subst
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as unify from "src/typecheck/unify.nx"
import { TypeError, DuplicateInjectCap, HandlerRequireNotSubset } from "src/typecheck/errors.nx"
import { Option, Some, None } from "std:option"
import * as list from "std:list"
import * as str from "std:str"

export type RaiseAdmissionResult =
  RaiseOk
  | RaiseRejected(message: string)

/** Decide whether raising `name_opt` is admitted by row `row`.
 *  `name_opt = None` means the raised expression has a statically opaque
 *  Exn-typed shape (a call, projection, etc.) whose variant cannot be
 *  determined syntactically; we accept conservatively in that case —
 *  unless the active throws-row is closed empty (`throws {}`), which
 *  permits no exceptions whatsoever.  Variable nodes are now resolved by
 *  `exception_name_of_raised` (via the variant index) and no longer produce
 *  `None`; they arrive here as `Some("Exn")` for catch-bound rethrows or
 *  `Some(variant)` for nullary exception constructors.
 *
 *  Row semantics (T-Raise):
 *  - Open row with an IMPLICIT or INFERENCE tail
 *    (`TyRow(_, rest: Some(TyVar("__implicit" | "?N")))`): effect-polymorphic
 *    by omission (absent `throws` clause) or an as-yet-unsolved inference
 *    variable.  Any throw is admitted.  Functions in `src/` that predate
 *    row-typed throws declarations parse to
 *    `TyRow([], rest: Some(TyVar("__implicit")))` via `parse_optional_throws`
 *    and fall here.
 *  - Open row with a RIGID tail (`throws R` where `R` is a generalized type
 *    parameter): the tail is a universally-quantified row variable, NOT an
 *    absorber.  A caller may instantiate `R := {}`, so a CONCRETE throw whose
 *    exception is not covered by an explicit head label would escape past a
 *    closed `throws {}` caller (P5 hole).  Only a body that is pure or merely
 *    re-throws a parameter's effect (an opaque `None` raise) satisfies
 *    `throws R`; a concrete `throw Boom` is rejected.
 *  - Closed non-empty row `TyRow([X, ...], rest: None)`: only declared
 *    members (or the universal `Exn` sentinel) are admitted.
 *  - Closed empty row `TyRow([], rest: None)`: the function explicitly
 *    declared `throws {}` — no exceptions are permitted and every throw
 *    site is an error (P5 enforcement).
 *  - Bare `TyVar` row (NOT a TyRow): a `throws R` clause where `R` is a
 *    generalized type parameter parses as a bare type, since
 *    `parse_row_or_type` routes a bare identifier through `parse_type`. A
 *    rigid such var is treated as an empty rigid open row (concrete throw
 *    rejected). An unsolved inference var (`?N`) admits conservatively.
 *  - Other non-row types: admit conservatively.
 */
export let check_raise_admitted = fn (
  name_opt: Option<string>, row: TypeExpr, groups: [ ExceptionGroupEntry ]
) -> RaiseAdmissionResult throws { TypeError } do
  match row do
    | TyRow(types: row_types, rest: Some(val: tail)) ->
      if row_tail_is_rigid(tail) then
        return check_raise_admitted_rigid(name_opt, row_types, groups)
      end
      return RaiseOk
    | TyRow(types: row_types, rest: None) ->
      return check_raise_admitted_closed(name_opt, row_types, groups)
    | _ ->
      if row_tail_is_rigid(tail: row) then
        return check_raise_admitted_rigid(name_opt, row_types: [], groups)
      end
      return RaiseOk
  end
end

/** True when an open throws-row tail is a RIGID generalized row quantifier
 *  (a declared `throws R` type parameter) rather than the legacy `__implicit`
 *  sentinel (absent throws clause) or a fresh inference variable (`?N`).
 *  Rigid tails do NOT absorb concrete throws; inference / implicit tails do. */
let row_tail_is_rigid = fn (tail: TypeExpr) -> bool do
  match tail do
    | TyVar(name: n) ->
      if n == "__implicit" then return false end
      if str.starts_with(s: n, prefix: "?") then return false end
      return true
    | _ -> return false
  end
end

/** Raise admission under a rigid open row `{ ...head | R }`. A concrete throw
 *  is admitted only if an explicit head label covers it (the rigid tail `R`
 *  contributes nothing, since a caller may instantiate `R := {}`). An opaque
 *  (`None`) raise — a re-thrown parameter effect — is admitted conservatively:
 *  its variant is not statically known and it is the legitimate
 *  effect-polymorphic form. */
let check_raise_admitted_rigid = fn (
  name_opt: Option<string>, row_types: [ TypeExpr ], groups: [ ExceptionGroupEntry ]
) -> RaiseAdmissionResult throws { TypeError } do
  match name_opt do
    | None -> return RaiseOk
    | Some(val: name) ->
      if row_admits_exception(name, row_types, groups) then
        return RaiseOk
      end
      return RaiseRejected(
        message: "throw " ++ name
          ++ ": exception not in throws row (a generalized `throws R` row variable"
          ++ " does not admit a concrete throw — a caller may instantiate R := {})"
      )
  end
end

let check_raise_admitted_closed = fn (
  name_opt: Option<string>, row_types: [ TypeExpr ], groups: [ ExceptionGroupEntry ]
) -> RaiseAdmissionResult throws { TypeError } do
  match name_opt do
    | None ->
      // Unknown throw target: reject when the row is provably empty (throws {}).
      if list.is_empty(xs: row_types) then
        return RaiseRejected(
          message: "throw: function declares throws {}, no exceptions are permitted"
        )
      end
      return RaiseOk
    | Some(val: name) ->
      if row_admits_exception(name, row_types, groups) then
        return RaiseOk
      end
      if list.is_empty(xs: row_types) then
        return RaiseRejected(
          message: "throw " ++ name ++ ": function declares throws {}, no exceptions are permitted"
        )
      end
      return RaiseRejected(message: "throw " ++ name ++ ": exception not in throws row")
  end
end

/** True when the row's head literally contains `name`, contains "Exn"
 *  (universal), or contains an exception group whose members include `name`.
 */
export let row_admits_exception = fn (
  name: string, row_types: [ TypeExpr ], groups: [ ExceptionGroupEntry ]
) -> bool throws { TypeError } do
  match row_types do
    | [] -> return false
    | t :: rest ->
      match t do
        | TyUserDefined(name: n, args: _) ->
          if n == "Exn" then return true end
          if n == name then return true end
          if group_contains(group_name: n, member: name, groups) then return true end
          return row_admits_exception(name, row_types: rest, groups)
        | _ -> return row_admits_exception(name, row_types: rest, groups)
      end
  end
end

/** True when every concrete (named) member of `caught_row` is admitted by the
 *  declared `row_types`. The caught row is the actual exception row a catch-all
 *  try body threw: its TyUserDefined members are the only exceptions the
 *  catch binder can hold, so a rethrow `throw <binder>` is sound exactly when
 *  all of them are already in the enclosing declared throws row. An open row
 *  tail does not widen the admitted set — only the body's actual named throws
 *  are considered (a fresh tail var carries no concrete exception). A bare
 *  group label in the caught row is admitted iff the declared row admits every
 *  one of its members. */
/** Remove from a captured throws-row the variant names already discharged by
 *  the catch arms preceding the catch-all (`drop_names`). The captured row is
 *  the pinned form `{E1 | {E2 | ?tail}}` (or a flat `{E1, E2 | ?tail}`); this
 *  walks every nested `TyRow` and drops named `TyUserDefined` entries whose name
 *  appears in `drop_names`, preserving the tail. The result is the row a
 *  `throw <binder>` in the catch-all arm can still carry at runtime. */
export let subtract_caught_from_row = fn (
  caught_row: TypeExpr, drop_names: [ string ]
) -> TypeExpr do
  match caught_row do
    | TyRow(types: ts, rest: r) ->
      let kept = filter_out_named(types: ts, drop_names)
      let rest_filtered = match r do
        | Some(val: tail) -> Some(val: subtract_caught_from_row(caught_row: tail, drop_names))
        | None -> None
      end
      return TyRow(types: kept, rest: rest_filtered)
    | _ -> return caught_row
  end
end

let filter_out_named = fn (types: [ TypeExpr ], drop_names: [ string ]) -> [ TypeExpr ] do
  match types do
    | [] -> return []
    | t :: rest ->
      let keep = match t do
        | TyUserDefined(name: n, args: _) -> !name_in_list(needle: n, haystack: drop_names)
        | _ -> true
      end
      if keep then
        return t :: filter_out_named(types: rest, drop_names)
      end
      return filter_out_named(types: rest, drop_names)
  end
end

let name_in_list = fn (needle: string, haystack: [ string ]) -> bool do
  match haystack do
    | [] -> return false
    | h :: rest ->
      if h == needle then return true end
      return name_in_list(needle, haystack: rest)
  end
end

export let catch_rethrow_admits = fn (
  caught_row: TypeExpr, row_types: [ TypeExpr ], groups: [ ExceptionGroupEntry ]
) -> bool throws { TypeError } do
  match caught_row do
    | TyRow(types: caught_types, rest: r) ->
      if !all_caught_admitted(caught: caught_types, row_types, groups) then return false end
      match r do
        | Some(val: tail) -> return catch_rethrow_admits(caught_row: tail, row_types, groups)
        | None -> return true
      end
    | TyUserDefined(name: _, args: _) ->
      return all_caught_admitted(caught: [ caught_row ], row_types, groups)
    | TyVar(name: _) -> return true
    | _ -> return false
  end
end

let all_caught_admitted = fn (
  caught: [ TypeExpr ], row_types: [ TypeExpr ], groups: [ ExceptionGroupEntry ]
) -> bool throws { TypeError } do
  match caught do
    | [] -> return true
    | t :: rest ->
      match t do
        | TyUserDefined(name: n, args: _) ->
          let admitted = match lookup_group_members(name: n, groups) do
            | Some(val: members) -> caller_admits_all_members(
              members,
              caller_types: row_types,
              groups
            )
            | None -> row_admits_exception(name: n, row_types, groups)
          end
          if !admitted then return false end
          return all_caught_admitted(caught: rest, row_types, groups)
        | _ -> return all_caught_admitted(caught: rest, row_types, groups)
      end
  end
end

let group_contains = fn (
  group_name: string, member: string, groups: [ ExceptionGroupEntry ]
) -> bool throws { TypeError } do
  match groups do
    | [] -> return false
    | ExceptionGroupEntry(name: gn, members) :: rest ->
      if gn == group_name then
        return member_in_strings(needle: member, haystack: members)
      end
      return group_contains(group_name, member, groups: rest)
  end
end

let member_in_strings = fn (needle: string, haystack: [ string ]) -> bool throws { TypeError } do
  match haystack do
    | [] -> return false
    | h :: rest ->
      if h == needle then return true end
      return member_in_strings(needle, haystack: rest)
  end
end

/** Find the member set of a declared exception group, or `None` when `name`
 *  is not a group (a plain exception constructor or the universal `Exn`). */
let lookup_group_members = fn (
  name: string, groups: [ ExceptionGroupEntry ]
) -> Option<[ string ]> throws { TypeError } do
  match groups do
    | [] -> return None
    | ExceptionGroupEntry(name: gn, members) :: rest ->
      if gn == name then return Some(val: members) end
      return lookup_group_members(name, groups: rest)
  end
end

/** True when every member name in `members` is admitted by the caller row
 *  (each must be a literal entry, the universal `Exn`, or a member of a
 *  group the caller lists). Used to expand a GROUP label appearing in a
 *  callee throws-row against a caller that listed the members individually. */
let caller_admits_all_members = fn (
  members: [ string ], caller_types: [ TypeExpr ], groups: [ ExceptionGroupEntry ]
) -> bool throws { TypeError } do
  match members do
    | [] -> return true
    | m :: rest ->
      if row_admits_exception(name: m, row_types: caller_types, groups) then
        return caller_admits_all_members(members: rest, caller_types, groups)
      end
      return false
  end
end

/** Recover the exception identity from a throw's payload expression.
 *
 *  T-Throw-Ctor: `throw Foo(args...)` — HIR Ctor node — ⇒ Some("Foo").
 *
 *  T-Throw-CtorNullary vs T-Throw-Val: both are syntactically `Variable` nodes.
 *  Distinguish by looking up the variable name in the variant index:
 *    - If the name is a known variant of the `Exn` enum (a nullary exception
 *      constructor) ⇒ Some(name).  The precise variant is emitted into the row,
 *      preserving T-Throw-CtorNullary precision.
 *    - Otherwise the variable carries an `Exn`-typed value from the surrounding
 *      context (e.g. a catch-bound rethrow `catch e -> throw e`).  Per
 *      T-Throw-Val the throws row receives the catch-all sentinel `Exn`.
 *      ⇒ Some("Exn").
 *
 *  Non-Ctor / non-Variable nodes (calls, projections, etc.) whose type has
 *  already been unified with Exn but whose variant cannot be statically
 *  determined ⇒ None (conservative admission).
 */
export let exception_name_of_raised = fn (state: CheckState, expr: HirExpr) -> Option<string> do
  let HirExpr(node, span: _) = expr
  match node do
    | Ctor(variant, args: _, labels: _, sigil: _) -> return Some(val: variant)
    | Variable(name: vname, sigil: _) ->
      return match tctypes.find_variant_in_state(state, variant: vname) do
        | Some(val: EnumVariantInfo(enum_name: ename, type_params: _, fields: _)) ->
          if ename == "Exn" then Some(val: vname) else Some(val: "Exn") end
        | None -> Some(val: "Exn")
      end
    | _ -> return None
  end
end

/** True when `expr` is the binder variable of the synthetic residual re-throw
 *  arm appended to a selective-`catch` desugar (src/ir/hir/convert/core.nx):
 *  `| __exn_v -> throw __exn_v`. The arm propagates the catch's RESIDUAL, which
 *  the T-TryCatch augmentation invariant guarantees is ⊆ the enclosing declared
 *  throws-row — so `infer_raise` may admit it without re-checking `Exn` (the
 *  catch param's universal type) against a narrow outer row. The name is an
 *  internal `__`-reserved sentinel mirroring the `__exn` catch param. */
export let is_residual_rethrow_var = fn (expr: HirExpr) -> bool do
  let HirExpr(node, span: _) = expr
  match node do
    | Variable(name: n, sigil: _) -> return n == "__exn_v"
    | _ -> return false
  end
end

/** True when a HirExprKind is structurally divergent for T-Seq purposes:
 *  throws, or every branch of a match/if reduces to divergent.
 *  Depth-bounded to prevent pathological cycles (64 is sufficient for
 *  any realistic nesting from the surface language).
 */
export let infer_expr_diverges_depth = fn (en: HirExprKind, depth: i64) -> bool do
  if depth <= 0 then return false end
  match en do
    | Raise(_) -> return true
    | Match(target: _, cases: cs) -> return infer_all_cases_diverge(cases: cs, depth: depth - 1)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      return infer_if_chain_diverges(cond: c, then_branch: tb, else_branch: eb, depth)
    // inject in expression position diverges when its body's tail diverges —
    // mirrors the Inject statement case in infer_stmt_kind_diverges. So
    // `let x = inject H do … return v end` (body tail-diverges) is recognised
    // as a divergent let, matching the statement form's dead-code analysis.
    | Inject(handlers: _, body: ib) ->
      return infer_stmts_tail_diverges(stmts: ib, depth: depth - 1)
    | _ -> return false
  end
end

/** True when an `if`/`else if`/… chain diverges on every branch.
 *
 *  Each then-branch is a genuinely nested block and consumes one unit of the
 *  nesting budget. The else-branch is the chain CONTINUATION: when it is a
 *  bare `else if` (a single `Expr(If(…))` statement) the chain is walked
 *  iteratively at the SAME depth, so an `else if … else if …` chain costs one
 *  unit total rather than one-per-link — mirroring `infer_all_cases_diverge`,
 *  which walks sibling match arms without decrementing. A non-`if` else block
 *  is an ordinary nested block and is charged a unit. This keeps the bound on
 *  genuine NESTING (deep then-branches / nested blocks still decrement) while
 *  making flat decision-chain LENGTH irrelevant.
 */
export let infer_if_chain_diverges = fn (
  cond: HirExpr,
  then_branch: [ HirStmt ],
  else_branch: Option<[ HirStmt ]>,
  depth: i64
) -> bool do
  if depth <= 0 then return false end
  if !infer_stmts_tail_diverges(stmts: then_branch, depth: depth - 1) then return false end
  match else_branch do
    | None -> return false
    | Some(val: ebs) ->
      match ebs do
        | HirStmt(
          node: Expr(expr: HirExpr(node: If(cond: c2, then_branch: tb2, else_branch: eb2), span: _)),
          span: _
        ) :: [] ->
          return infer_if_chain_diverges(cond: c2, then_branch: tb2, else_branch: eb2, depth)
        | _ -> return infer_stmts_tail_diverges(stmts: ebs, depth: depth - 1)
      end
  end
end

/** True when all match-case bodies are divergent (used by infer_expr_diverges_depth). */
export let infer_all_cases_diverge = fn (cases: [ HirMatchCase ], depth: i64) -> bool do
  match cases do
    | [] -> return true
    | HirMatchCase(pattern: _, body: b) :: rest ->
      if !infer_stmts_tail_diverges(stmts: b, depth) then return false end
      return infer_all_cases_diverge(cases: rest, depth)
  end
end

/** True when the last statement of a block is divergent.
 *
 *  `depth` bounds genuine NESTING recursion (match arms, if/try branches),
 *  not the length of a straight statement list. Advancing along the linear
 *  `_ :: rest` spine to reach the tail statement therefore preserves the
 *  budget — only the nesting recursions in `infer_stmt_kind_diverges` /
 *  `infer_expr_diverges_depth` / `infer_all_cases_diverge` decrement it.
 *  (Decrementing per list element spuriously bailed on long flat bodies, e.g.
 *  a function with hundreds of leading statements ending in `return`.)
 */
export let infer_stmts_tail_diverges = fn (stmts: [ HirStmt ], depth: i64) -> bool do
  if depth <= 0 then return false end
  match stmts do
    | [] -> return false
    | HirStmt(node: nd, span: _) :: [] ->
      return infer_stmt_kind_diverges(s: nd, depth)
    | _ :: rest ->
      return infer_stmts_tail_diverges(stmts: rest, depth)
  end
end

/** T-Seq dead-code predicate: returns true when a statement definitely
 *  diverges (control never reaches the next statement in the sequence).
 *  Recognises (spec tail(s) = ⊥):
 *   - `return e`                              — Return stmt
 *   - `throw Exn(...)`                        — Expr stmt whose top node is Raise
 *   - `let x = throw e'`                      — Let whose RHS is a Raise or other divergent expr
 *   - `let x = if c then THROW else THROW end` — Let with divergent if/match RHS
 *   - `if c then THROW else THROW end`        — Expr stmt, if with both arms divergent
 *   - `match e { p -> THROW | ... }`          — Expr stmt, match with all arms divergent
 */
export let stmt_diverges = fn (s: HirStmtKind) -> bool do
  return infer_stmt_kind_diverges(s, depth: 64)
end

export let infer_stmt_kind_diverges = fn (s: HirStmtKind, depth: i64) -> bool do
  if depth <= 0 then return false end
  match s do
    | Return(_) -> return true
    | Expr(expr: HirExpr(node: en, span: _)) ->
      return infer_expr_diverges_depth(en, depth: depth - 1)
    | Let(name: _, sigil: _, typ: _, value: HirExpr(node: rhs, span: _)) ->
      return infer_expr_diverges_depth(en: rhs, depth: depth - 1)
    // try { s* } catch p -> { s* }: diverges when the tail of both the try
    // body and the catch body diverge (every control-flow exit is covered).
    | Try(body: tb, catch_param: _, catch_body: cb) ->
      return infer_stmts_tail_diverges(stmts: tb, depth: depth - 1) &&
             infer_stmts_tail_diverges(stmts: cb, depth: depth - 1)
    | _ -> return false
  end
end

export let check_handlers_bound = fn (
  state: CheckState,
  handlers: [ string ],
  span: Span
) -> InferExprResult throws { TypeError } do
  match handlers do
    | [] -> return InferExprOk(state, subst: subst.subst_empty(), typ: TyUnit)
    | h :: rest ->
      match tctypes.state_lookup_scheme(state, name: h) do
        | None -> return InferExprErr(message: "inject: unbound handler '" ++ h ++ "'", span)
        | Some(val: Scheme(vars: _, typ: ht)) ->
          // spec T-Inject: strip(τ) does not peel @, so a
          // thunk handler @σ does not unify with `handler P ρ`. Surface a
          // suggestion to force the thunk explicitly.
          match ht do
            | TyLazy(inner: _, require_row: _, throw_row: _) ->
              return InferExprErr(
                message: "inject: handler '" ++ h ++ "' has thunk type `" ++ tctypes.type_to_string(typ: ht) ++ "`; force it explicitly (e.g. `inject @" ++ h ++ " do ... end`)",
                span
              )
            | _ -> return check_handlers_bound(state, handlers: rest, span)
          end
      end
  end
end

/** Look up a handler name in the env and return its TyHandler cap name.
 *  Returns None if the binding does not resolve to a TyHandler (non-handler
 *  bindings are already rejected by check_handlers_bound before this runs).
 */
let handler_cap_name = fn (state: CheckState, h: string) -> Option<string> do
  match tctypes.state_lookup_scheme(state, name: h) do
    | None -> return None
    | Some(val: Scheme(vars: _, typ: ht)) ->
      match ht do
        | TyHandler(name: pname, requires: _) -> return Some(val: pname)
        | _ -> return None
      end
  end
end

/** Check that no two handlers in the inject list target the same cap.
 *  Enforces T-Inject premise ∀i≠j. P_i ≠ P_j.
 *  `seen` accumulates cap names already encountered.
 */
export let check_inject_uniqueness = fn (
  state: CheckState,
  handlers: [ string ],
  seen: [ string ],
  span: Span
) -> unit throws { TypeError } do
  match handlers do
    | [] -> return ()
    | h :: rest ->
      match handler_cap_name(state: state, h) do
        | None ->
          // Not a TyHandler — check_handlers_bound already caught this or it
          // is a non-handler type that will be rejected elsewhere; skip.
          return check_inject_uniqueness(state, handlers: rest, seen, span)
        | Some(val: pname) ->
          if list.str_member(xs: seen, s: pname) then
            throw DuplicateInjectCap(cap_name: pname, span)
          end
          return check_inject_uniqueness(state, handlers: rest, seen: pname :: seen, span)
      end
  end
end

/** Check whether a capability name appears in a require row.
 *  Row entries in a cap/require row are TyUserDefined(name: cap_name, args: []).
 */
let row_contains_cap = fn (cap_name: string, row: TypeExpr) -> bool do
  match row do
    | TyRow(types: ts, rest: _) -> return cap_entry_list_contains(cap_name: cap_name, ts)
    | _ -> return false
  end
end

let cap_entry_list_contains = fn (cap_name: string, ts: [ TypeExpr ]) -> bool do
  match ts do
    | [] -> return false
    | TyUserDefined(name: n, args: _) :: rest ->
      if n == cap_name then return true end
      return cap_entry_list_contains(cap_name: cap_name, ts: rest)
    | _ :: rest -> return cap_entry_list_contains(cap_name: cap_name, ts: rest)
  end
end

/** Check that every capability in `handler_row` is also present in `ambient_row`.
 *  Returns None on success; Some(missing_cap_name) on first violation.
 */
let first_missing_cap = fn (handler_row: TypeExpr, ambient_row: TypeExpr) -> Option<string> do
  match handler_row do
    | TyRow(types: ts, rest: _) -> return first_missing_cap_in_list(ts: ts, ambient_row)
    | _ -> return None
  end
end

let first_missing_cap_in_list = fn (ts: [ TypeExpr ], ambient_row: TypeExpr) -> Option<string> do
  match ts do
    | [] -> return None
    | TyUserDefined(name: cname, args: _) :: rest ->
      if row_contains_cap(cap_name: cname, row: ambient_row) then
        return first_missing_cap_in_list(ts: rest, ambient_row)
      end
      return Some(val: cname)
    | _ :: rest -> return first_missing_cap_in_list(ts: rest, ambient_row)
  end
end

/** T-Force premise: check that every capability in the thunk's deferred
 *  require_row is present in the ambient require_row at the force site.
 *  Returns None on success; Some(missing_cap_name) on first violation.
 *  Implements spec §T-Force premise `unify(ρ_q, open(ρ_q'))`: every named
 *  entry of the thunk's require row must be a member of the ambient row.
 *  Open/variable tails in the thunk row are treated conservatively (admitted).
 */
export let check_force_require_row = fn (
  thunk_require_row: TypeExpr,
  ambient_require_row: TypeExpr
) -> Option<string> do
  return first_missing_cap(handler_row: thunk_require_row, ambient_row: ambient_require_row)
end

/** Result of the generic-cap argument coverage check (nexus-3ibql). The Ok case
 *  carries the substitution produced by unifying the callee's concrete cap args
 *  against the ambient cap args. In the normal checking phase the ambient args
 *  are concrete, so that subst binds nothing; during the contract-derivation
 *  pre-pass (cap_contract.nx) the ambient args are fresh type variables, so the
 *  subst PINS them to the element type the callee commits — that is how the
 *  function's committed `Box<i64>` is captured by inference. */
export type CapArgResult =
  CapArgOk(subst: Subst)
  | CapArgMismatch(cap_name: string, message: string)

/** T-CapCall generic-cap soundness: for every cap entry of the CALLEE require
 *  row that carries concrete element-type args (`Box<i64>`), find the same-named
 *  entry of the AMBIENT require row and, when it ALSO carries args (`Box<string>`
 *  from an inject providing a concrete handler), UNIFY them. A failure means the
 *  function commits the cap to a different element type than the handler in
 *  scope — the laundered generic-cap type confusion — and is rejected. Either
 *  side carrying no args is element-agnostic and admitted (the cap was required
 *  bare, or the handler instantiation could not be recovered). The unifying
 *  substitution is accumulated and returned on success. */
export let check_cap_args_covered = fn (
  callee_row: TypeExpr,
  ambient_row: TypeExpr,
  tdefs: [ TypeDefEntry ]
) -> CapArgResult do
  match callee_row do
    | TyRow(
      types: ts,
      rest: _
    ) -> return cap_args_go(ts, ambient_row, tdefs, acc: subst.subst_empty())
    | _ -> return CapArgOk(subst: subst.subst_empty())
  end
end

/** The require row of a (possibly linear/lazy-wrapped, possibly list/array-
 *  nested) arrow type, else None. Descending through list/array layers recovers
 *  the element-arrow require row of a CONTAINER slot whose element is a
 *  cap-bearing closure. Both list spellings are covered: `[τ]` (`TyList`) and the
 *  nominal `List<τ>` / `Array<τ>` (`TyUserDefined`) that list literals desugar to
 *  via `Cons`. */
let cap_arrow_require_row = fn (typ: TypeExpr) -> Option<TypeExpr> do
  match typ do
    | TyArrow(params: _, ret: _, requires: rq, throw_row: _) -> return Some(val: rq)
    | TyLinear(inner: i) -> return cap_arrow_require_row(typ: i)
    | TyLazy(inner: i, require_row: _, throw_row: _) -> return cap_arrow_require_row(typ: i)
    | TyList(elem: e) -> return cap_arrow_require_row(typ: e)
    | TyArray(elem: e) -> return cap_arrow_require_row(typ: e)
    | TyUserDefined(name: n, args: targs) ->
      if n == "List" || n == "Array" then
        match targs do
          | e :: _ -> return cap_arrow_require_row(typ: e)
          | [] -> return None
        end
      end
      return None
    | _ -> return None
  end
end

/** True when a require row names no capability entry at all (no `Box`/`Box<τ>`
 *  user-defined entry). A bare-cap or concrete-cap arrow stored into a container
 *  slot WILL be invoked under that cap's ambient handler when later extracted and
 *  called, so its committed element must be covered; an empty row carries no such
 *  obligation. */
let cap_row_names_a_cap = fn (row: TypeExpr) -> bool do
  match row do
    | TyRow(types: ts, rest: _) -> return cap_entries_name_a_cap(ts)
    | _ -> return false
  end
end

let cap_entries_name_a_cap = fn (ts: [ TypeExpr ]) -> bool do
  match ts do
    | [] -> return false
    | TyUserDefined(name: _, args: _) :: _ -> return true
    | _ :: rest -> return cap_entries_name_a_cap(ts: rest)
  end
end

/** Generic-cap soundness for a cap-bearing closure LAUNDERED through a container
 *  slot (constructor field / variant payload / list element — list literals
 *  desugar to `Cons` constructors, so all three share this path). The arrow-unify
 *  require-row subtyping admits a concrete `Box<i64>` argument into a bare-`Box`
 *  field slot, ERASING the element commitment at the construction boundary; the
 *  later extraction (`let Wrapper(g: f) = w; f(s: n)`) reads the field at its
 *  bare-`Box` declared type and invokes the closure under whatever handler is
 *  ambient — so a `Box<i64>` commitment can run under a `Box<string>` handler.
 *  Mirroring the direct-call (T-CapCall) and value-parameter-forwarder coverage,
 *  cover the stored closure's concrete cap element args against the ambient row at
 *  the construction site. Fires only when (a) the declared slot type is an arrow
 *  whose require row NAMES a cap, and (b) the stored value's own require row
 *  carries CONCRETE element args; bare-on-bare is element-agnostic and admitted
 *  (no over-rejection of polymorphic helpers). */
export let check_stored_fn_caps_covered = fn (
  declared_resolved: TypeExpr,
  arg_typ: TypeExpr,
  ambient_row: TypeExpr,
  tdefs: [ TypeDefEntry ]
) -> CapArgResult do
  match cap_arrow_require_row(typ: declared_resolved) do
    | None -> return CapArgOk(subst: subst.subst_empty())
    | Some(val: drow) ->
      if cap_row_names_a_cap(row: drow) == false then
        return CapArgOk(subst: subst.subst_empty())
      end
      match cap_arrow_require_row(typ: arg_typ) do
        | None -> return CapArgOk(subst: subst.subst_empty())
        | Some(val: arg_row) ->
          return check_cap_args_covered(callee_row: arg_row, ambient_row, tdefs)
      end
  end
end

let cap_args_go = fn (
  ts: [ TypeExpr ], ambient_row: TypeExpr, tdefs: [ TypeDefEntry ], acc: Subst
) -> CapArgResult do
  match ts do
    | [] -> return CapArgOk(subst: acc)
    | TyUserDefined(name: cname, args: cargs) :: rest ->
      match cargs do
        | [] -> return cap_args_go(ts: rest, ambient_row, tdefs, acc)
        | _ ->
          match ambient_cap_args(name: cname, row: ambient_row) do
            | None -> return cap_args_go(ts: rest, ambient_row, tdefs, acc)
            | Some(val: aargs) ->
              match aargs do
                | [] -> return cap_args_go(ts: rest, ambient_row, tdefs, acc)
                | _ ->
                  match unify_arg_lists(a: aargs, b: cargs, tdefs) do
                    | UnifyErr(message: m) ->
                      return CapArgMismatch(
                        cap_name: cname,
                        message: "capability '" ++ cname
                          ++ "' is used at an element type incompatible with the handler in scope: "
                          ++ m
                      )
                    | UnifyOk(subst: s) ->
                      return cap_args_go(
                        ts: rest, ambient_row, tdefs,
                        acc: subst.subst_compose(s1: acc, s2: s)
                      )
                  end
              end
          end
      end
    | _ :: rest -> return cap_args_go(ts: rest, ambient_row, tdefs, acc)
  end
end

/** Args of the first same-named cap entry in the ambient row, or None. */
let ambient_cap_args = fn (name: string, row: TypeExpr) -> Option<[ TypeExpr ]> do
  match row do
    | TyRow(types: ts, rest: _) -> return ambient_cap_args_in(name, ts)
    | _ -> return None
  end
end

let ambient_cap_args_in = fn (name: string, ts: [ TypeExpr ]) -> Option<[ TypeExpr ]> do
  match ts do
    | [] -> return None
    | TyUserDefined(name: n, args: a) :: rest ->
      if n == name then return Some(val: a) end
      return ambient_cap_args_in(name, ts: rest)
    | _ :: rest -> return ambient_cap_args_in(name, ts: rest)
  end
end

/** Unify two parallel type-arg lists; first failure short-circuits. Arity
 *  mismatch is treated as a failure (different cap instantiations). The
 *  substitutions of each position are composed so the full pinning is returned
 *  (load-bearing for the contract-derivation pass capturing a fresh ambient var).
 *  The AMBIENT args are passed as `a` (the `t1` side of each unify) so a still-
 *  fresh ambient var becomes the BOUND variable: when the callee commits its
 *  element only through a later return-type unification (`?callee := string`
 *  after the cap call), the composed subst still chases the ambient var to the
 *  committed type. Passing the callee args as `a` would instead bind
 *  `?callee := ?ambient`, and the subsequent `?callee := string` entry would be
 *  dropped by the duplicate-skipping merge, leaving the ambient var unpinned. */
let unify_arg_lists = fn (
  a: [ TypeExpr ], b: [ TypeExpr ], tdefs: [ TypeDefEntry ]
) -> tctypes.UnifyResult do
  match a do
    | [] -> return if let [] = b then UnifyOk(subst: subst.subst_empty()) else UnifyErr(message: "cap type-argument count mismatch") end
    | at :: arest ->
      match b do
        | [] -> return UnifyErr(message: "cap type-argument count mismatch")
        | bt :: brest ->
          match unify.unify(t1: at, t2: bt, tdefs) do
            | UnifyErr(message: m) -> return UnifyErr(message: m)
            | UnifyOk(subst: s_head) ->
              match unify_arg_lists(
                a: subst.subst_apply_each(subst: s_head, typs: arest),
                b: subst.subst_apply_each(subst: s_head, typs: brest),
                tdefs
              ) do
                | UnifyErr(message: m) -> return UnifyErr(message: m)
                | UnifyOk(subst: s_rest) -> return UnifyOk(subst: subst.subst_compose(s1: s_head, s2: s_rest))
              end
          end
      end
  end
end

/** Check that each handler's require row is a subset of the ambient require row.
 *  Enforces T-Inject premise ∀i. ρ_i ⊆ ρ_q.
 */
export let check_inject_require_subset = fn (
  state: CheckState,
  handlers: [ string ],
  ambient: TypeExpr,
  span: Span
) -> unit throws { TypeError } do
  match handlers do
    | [] -> return ()
    | h :: rest ->
      match tctypes.state_lookup_scheme(state, name: h) do
        | None -> return check_inject_require_subset(state, handlers: rest, ambient, span)
        | Some(val: Scheme(vars: _, typ: ht)) ->
          match ht do
            | TyHandler(name: _, requires: handler_req) ->
              match first_missing_cap(handler_row: handler_req, ambient_row: ambient) do
                | None -> return check_inject_require_subset(state, handlers: rest, ambient, span)
                | Some(val: missing) ->
                  throw HandlerRequireNotSubset(handler_name: h, missing_cap: missing, span)
              end
            | _ -> return check_inject_require_subset(state, handlers: rest, ambient, span)
          end
      end
  end
end

/** Decide whether calling a function whose declared throws-row is `callee_row`
 *  is admitted by the caller's active `caller_row`. Row-subsumption: every
 *  concrete exception listed in the callee row must appear in the caller row
 *  (literally, as a member of an exception group, or via the universal `Exn`).
 *
 *  Admit rules (parallel to check_raise_admitted):
 *  - Callee row = closed empty `TyRow([], None)`: callee declared no
 *  throws; always admitted.
 *  - Callee row open with `__implicit` tail: callee has NO `throws` annotation
 *  (the parser encodes the absent clause as `TyRow([], Some(TyVar("__implicit")))`).
 *  This means the callee's actual throws set is unknown at compile time.
 *  P5 requires that a `throws {}` caller admits no exceptions at all, so
 *  calling an unannotated callee from `throws {}` must be rejected.  For
 *  all other caller rows (open, or closed non-empty) the call is admitted
 *  conservatively (existing behaviour for partial annotation coverage).
 *  - Callee row open with a genuine effect-variable tail (a fresh `?N` var
 *  introduced by instantiating a `<R>`-bound type parameter): this is a
 *  true effect-polymorphic callee — always admitted (the surrounding
 *  unification will pin the variable to the call-site row).
 *  - Callee row closed with entries: caller must cover every listed exception.
 *  - Caller row open (rest = Some(_)): admits any closed callee.
 *  - Caller row = closed empty `TyRow([], None)`: caller declared no
 *  throws; admit (narrow enforcement activates only when caller declares
 *  an explicit row).
 *  - Either side reduced to a TyVar / non-row shape: admit conservatively.
 */
export let check_call_throw_row_admitted = fn (
  callee_row: TypeExpr, caller_row: TypeExpr,
  groups: [ ExceptionGroupEntry ], func: string,
  fn_pure_set: [ string ]
) -> RaiseAdmissionResult throws { TypeError } do
  match callee_row do
    // Callee has no throws: always admitted.
    | TyRow(types: [], rest: None) -> return RaiseOk
    // Callee row is open — distinguish unannotated from effect-polymorphic.
    | TyRow(types: callee_open_types, rest: Some(val: tail)) ->
      match tail do
        // __implicit: absent `throws` annotation — callee throws set unknown.
        // A caller declaring `throws {}` (closed empty) permits no exceptions
        // at all; admitting an unannotated callee whose actual throws set is
        // unknown violates P5 (exception containment).  Reject in that strict
        // case UNLESS the callee is in `fn_pure_set` (statically proven
        // non-throwing from its HIR body — see build_fn_pure_set in check.nx).
        // Non-empty closed rows and open caller rows admit conservatively.
        | TyVar(name: "__implicit") ->
          match caller_row do
            | TyRow(types: [], rest: None) ->
              // If the callee is provably pure (fn_pure_set), admit it even
              // under throws {}: a function with no Raise and no calls to
              // throwing functions cannot escape any exception.
              if list.str_member(xs: fn_pure_set, s: func) then
                return RaiseOk
              end
              return RaiseRejected(
                message: "call " ++ func ++ ": callee has no throws annotation (may throw anything); caller declares a closed throws row"
              )
            | _ -> return RaiseOk
          end
        // Genuine effect-polymorphic tail (fresh ?N var from <R> instantiation):
        // unification will constrain the variable for the tail — but any CONCRETE
        // exception labels already present in the open row must still be checked
        // against the caller's declared throws row.  A thunk-deferred row
        // TyRow([E], Some(?N)) carries a concrete E that must not silently escape
        // through a `throws {}` caller.
        // Only rows with NO concrete labels (TyRow([], Some(?N))) are purely
        // polymorphic and admitted unconditionally.
        | _ ->
          if list.is_empty(xs: callee_open_types) then
            return RaiseOk
          end
          match caller_row do
            // Open caller row: admits any callee (conservative).
            | TyRow(types: _, rest: Some(_)) -> return RaiseOk
            // Closed caller row: check the concrete labels.
            | TyRow(types: caller_types, rest: None) ->
              return check_each_callee_member_admitted(
                callee_types: callee_open_types,
                caller_types,
                groups,
                func
              )
            | _ -> return RaiseOk
          end
      end
    | TyRow(types: callee_types, rest: None) ->
      match caller_row do
        // Open caller row (includes implicit absent-throws rows parsed as
        // TyRow([], Some(TyVar("__implicit")))): admits any callee.
        | TyRow(types: _, rest: Some(_)) -> return RaiseOk
        // Caller declared an explicit closed row (including `throws {}`):
        // enforce that every callee exception is covered.
        | TyRow(types: caller_types, rest: None) ->
          return check_each_callee_member_admitted(callee_types, caller_types, groups, func)
        | _ -> return RaiseOk
      end
    | _ -> return RaiseOk
  end
end

/** Verify each TyUserDefined entry in `callee_types` is admitted by
 *  `caller_types`. Non-TyUserDefined entries (e.g. TyVar arising from
 *  freshly instantiated polymorphic effect parameters) skip — those are
 *  resolved by surrounding unification, not by this row-subsumption check.
 */
export let check_each_callee_member_admitted = fn (
  callee_types: [ TypeExpr ], caller_types: [ TypeExpr ],
  groups: [ ExceptionGroupEntry ], func: string
) -> RaiseAdmissionResult throws { TypeError } do
  match callee_types do
    | [] -> return RaiseOk
    | t :: rest ->
      match t do
        | TyUserDefined(name: n, args: _) ->
          // Direct admission: caller lists `n` literally, lists a group that
          // contains `n`, or lists the universal `Exn`.
          if row_admits_exception(name: n, row_types: caller_types, groups) then
            return check_each_callee_member_admitted(callee_types: rest, caller_types, groups, func)
          end
          // `n` may itself be a GROUP label in the callee row. Expand it: the
          // caller subsumes the group iff it admits every member of the group.
          match lookup_group_members(name: n, groups) do
            | Some(val: members) ->
              if caller_admits_all_members(members, caller_types, groups) then
                return check_each_callee_member_admitted(
                  callee_types: rest,
                  caller_types,
                  groups,
                  func
                )
              end
              return RaiseRejected(
                message: "call " ++ func ++ ": exception group " ++ n ++ " raised by callee not fully admitted by caller's throws row"
              )
            | None ->
              return RaiseRejected(
                message: "call " ++ func ++ ": exception " ++ n ++ " raised by callee not admitted by caller's throws row"
              )
          end
        | _ -> return check_each_callee_member_admitted(
          callee_types: rest,
          caller_types,
          groups,
          func
        )
      end
  end
end

// ---------------------------------------------------------------------------
// T-TryCatch body-row helpers (used by infer_try_impl in stmt_eval.nx)
// ---------------------------------------------------------------------------

/** True when the catch is a catch-all (handles every exception):
 *  - Legacy single-variable catch: `catch e -> ...` or `catch _ -> ...`
 *    desugars (hir convert/core.nx) to `catch_param = <user-var>` (the bare
 *    binder name, e.g. "e" or "_") with a non-`match` body. The binder catches
 *    EVERY exception unconditionally — per spec hasCatchAll(p̄) any variable
 *    pattern is a catch-all (type-system-formal.md §T-TryCatch) — so the
 *    residual throws-row is emptied. Such a catch is distinguished from the
 *    multi-arm desugar by `catch_param != "__exn"`.
 *  - Multi-arm match (`catch_param == "__exn"`): catch-all only when its match
 *    has an explicit wildcard / variable arm (excluding the synthetic re-throw).
 */
export let catch_is_catch_all = fn (catch_param: string, catch_body: [ HirStmt ]) -> bool do
  // Legacy single-variable catch (binder catches everything). The multi-arm
  // desugar always uses the reserved synthetic param "__exn"; any other
  // catch_param is a user binder that handles every exception.
  if !(catch_param == "__exn") then return true end
  // Multi-arm path: catch_body = [Expr(Match(target: __exn, cases: [...]))]
  return match_body_has_wildcard_arm(stmts: catch_body)
end

let match_body_has_wildcard_arm = fn (stmts: [ HirStmt ]) -> bool do
  match stmts do
    | HirStmt(
      node: Expr(expr: HirExpr(node: Match(target: _, cases: cs), span: _)),
      span: _
    ) :: [] ->
      return cases_have_wildcard(cases: cs)
    | _ -> return false
  end
end

let cases_have_wildcard = fn (cases: [ HirMatchCase ]) -> bool do
  match cases do
    | [] -> return false
    | HirMatchCase(pattern: p, body: b) :: rest ->
      match p do
        | PWild -> return true
        // The synthetic residual re-throw arm `| __exn_v -> throw __exn_v`
        // (appended by the selective-`catch` desugar) is NOT a user catch-all:
        // treating it as one would open the try-body throws-row and drop the
        // residual-narrowing semantics. Skip it so the catch stays SELECTIVE
        | PVar(name: vn, sigil: _) ->
          if is_synthetic_rethrow_arm(name: vn, body: b) then
            return cases_have_wildcard(cases: rest)
          end
          return true
        | _ -> return cases_have_wildcard(cases: rest)
      end
  end
end

/** Name of the variable bound by the catch-all arm of a catch body — the
 *  variable a `throw <name>` re-throw inside the catch may legitimately carry.
 *
 *  - Legacy single-variable catch (`catch e -> ...`, `catch_param != "__exn"`):
 *    the binder is the catch param itself.
 *  - Multi-arm desugar (`catch_param == "__exn"`): the catch body is
 *    `[ Expr(Match(__exn, cases)) ]`; the catch-all is the first `PVar` arm that
 *    is not the synthetic residual re-throw arm (`__exn_v`). Its binder is the
 *    user variable (e.g. `err` in `| err -> throw err`).
 *
 *  Returns `None` when there is no user catch-all PVar arm (a bare `_` wildcard
 *  binds nothing rethrowable, so it yields `None`). */
export let catch_all_binder_name = fn (
  catch_param: string,
  catch_body: [ HirStmt ]
) -> Option<string> do
  if !(catch_param == "__exn") then return Some(val: catch_param) end
  match catch_body do
    | HirStmt(
      node: Expr(expr: HirExpr(node: Match(target: _, cases: cs), span: _)),
      span: _
    ) :: [] ->
      return catch_all_arm_var(cases: cs)
    | _ -> return None
  end
end

let catch_all_arm_var = fn (cases: [ HirMatchCase ]) -> Option<string> do
  match cases do
    | [] -> return None
    | HirMatchCase(pattern: p, body: b) :: rest ->
      match p do
        | PVar(name: vn, sigil: _) ->
          if is_synthetic_rethrow_arm(name: vn, body: b) then
            return catch_all_arm_var(cases: rest)
          end
          return Some(val: vn)
        | _ -> return catch_all_arm_var(cases: rest)
      end
  end
end

/** Caught variant types of the arms that PRECEDE the catch-all arm — the
 *  variants already discharged before control reaches `throw <binder>`. These
 *  are subtracted from the captured try-body row so the re-throw binder's
 *  effective row is exactly what can still escape. Only irrefutable PCtor arms
 *  (which always discharge their variant) contribute. */
export let caught_before_catch_all = fn (
  catch_param: string,
  catch_body: [ HirStmt ]
) -> [ TypeExpr ] do
  if !(catch_param == "__exn") then return [] end
  match catch_body do
    | HirStmt(
      node: Expr(expr: HirExpr(node: Match(target: _, cases: cs), span: _)),
      span: _
    ) :: [] ->
      return caught_before_catch_all_cases(cases: cs, acc: [])
    | _ -> return []
  end
end

let caught_before_catch_all_cases = fn (
  cases: [ HirMatchCase ], acc: [ TypeExpr ]
) -> [ TypeExpr ] do
  match cases do
    | [] -> return acc
    | HirMatchCase(pattern: p, body: b) :: rest ->
      match p do
        | PWild -> return acc
        | PVar(name: vn, sigil: _) ->
          if is_synthetic_rethrow_arm(name: vn, body: b) then
            return caught_before_catch_all_cases(cases: rest, acc)
          end
          return acc
        | PCtor(variant: v, fields: fs, sigil: _) ->
          if ctor_fields_irrefutable(fields: fs) then
            return caught_before_catch_all_cases(
              cases: rest,
              acc: TyUserDefined(name: v, args: []) :: acc
            )
          end
          return caught_before_catch_all_cases(cases: rest, acc)
        | _ -> return caught_before_catch_all_cases(cases: rest, acc)
      end
  end
end

/** True when a match case is the synthetic residual re-throw arm
 *  `| __exn_v -> throw __exn_v` produced by the selective-`catch` desugar.
 *  The arm body is `throw __exn_v`, i.e. a single `Expr(Raise(Variable __exn_v))`
 *  statement — so we must unwrap the `Raise` before checking the rethrown var
 *  (`is_residual_rethrow_var` inspects the *payload* expression, not the Raise
 *  node). */
let is_synthetic_rethrow_arm = fn (name: string, body: [ HirStmt ]) -> bool do
  if !(name == "__exn_v") then return false end
  match body do
    | HirStmt(node: Expr(expr: HirExpr(node: Raise(expr: payload), span: _)), span: _) :: [] ->
      return is_residual_rethrow_var(expr: payload)
    | _ -> return false
  end
end

/** Collect the `TypeExpr` entries for the exception variants that the catch
 *  body explicitly handles via PCtor patterns.  Used to augment the try body's
 *  effective throws-row (so throw sites for those variants are admitted).
 *
 *  For a single-variable catch (`catch e -> ...`) the caller should already
 *  have checked `catch_is_catch_all` and used an open row; this function only
 *  fires on the selective-catch path.  Returns `[]` for anything that is not
 *  a PCtor arm — wildcard / PVar arms are handled by `catch_is_catch_all`.
 */
export let collect_caught_types = fn (
  catch_param: string,
  catch_body: [ HirStmt ]
) -> [ TypeExpr ] do
  catch_param
  return collect_caught_types_from_stmts(stmts: catch_body)
end

let collect_caught_types_from_stmts = fn (stmts: [ HirStmt ]) -> [ TypeExpr ] do
  match stmts do
    | HirStmt(
      node: Expr(expr: HirExpr(node: Match(target: _, cases: cs), span: _)),
      span: _
    ) :: [] ->
      return collect_caught_types_from_cases(cases: cs, acc: [])
    | _ -> return []
  end
end

/** True when a pattern always matches its scrutinee — i.e. it imposes no
 *  value test and so can never fall through. Only such patterns make a
 *  catch arm subtract its constructor from the residual throws-row.
 *
 *  Irrefutable: `_` (PWild), a plain binder (PVar), a record pattern whose
 *  every field is irrefutable, and an or-pattern with at least one
 *  irrefutable alternative (which alone covers every value).
 *
 *  Refutable: a literal (PLit), a nested constructor (PCtor) — a ctor test
 *  may fail at runtime even for a single-variant type, so it is treated
 *  conservatively as refutable here. */
let pattern_is_irrefutable = fn (p: HirPatternKind) -> bool do
  match p do
    | PWild -> return true
    | PVar(name: _, sigil: _) -> return true
    | PRec(fields: fs, is_partial: _) -> return rec_fields_irrefutable(fields: fs)
    | POr(alts: alts) -> return any_alt_irrefutable(alts)
    | _ -> return false
  end
end

let ctor_fields_irrefutable = fn (fields: [ HirPatternField ]) -> bool do
  match fields do
    | [] -> return true
    | HirPatternField(name: _, pattern: fp) :: rest ->
      if pattern_is_irrefutable(p: fp) then
        return ctor_fields_irrefutable(fields: rest)
      end
      return false
  end
end

let rec_fields_irrefutable = fn (fields: [ HirRecordPatField ]) -> bool do
  match fields do
    | [] -> return true
    | HirRecordPatField(name: _, pattern: fp) :: rest ->
      if pattern_is_irrefutable(p: fp) then
        return rec_fields_irrefutable(fields: rest)
      end
      return false
  end
end

let any_alt_irrefutable = fn (alts: [ HirPatternKind ]) -> bool do
  match alts do
    | [] -> return false
    | a :: rest ->
      if pattern_is_irrefutable(p: a) then return true end
      return any_alt_irrefutable(alts: rest)
  end
end

let collect_caught_types_from_cases = fn (
  cases: [ HirMatchCase ],
  acc: [ TypeExpr ]
) -> [ TypeExpr ] do
  match cases do
    | [] -> return acc
    | HirMatchCase(pattern: p, body: _) :: rest ->
      match p do
        | PCtor(variant: v, fields: fs, sigil: _) ->
          if ctor_fields_irrefutable(fields: fs) then
            return collect_caught_types_from_cases(
              cases: rest,
              acc: TyUserDefined(name: v, args: []) :: acc
            )
          end
          return collect_caught_types_from_cases(cases: rest, acc)
        | _ -> return collect_caught_types_from_cases(cases: rest, acc)
      end
  end
end

/** Build the effective throws-row that the try body is checked under.
 *
 *  For a catch-all: return an open row (admits everything).
 *  For a selective catch: return the outer declared row augmented with the
 *  caught variant types.  The augmentation allows throw sites for caught
 *  variants to pass through `check_raise_admitted` even when the outer row
 *  is closed empty (`throws {}`).
 *
 *  After the body type-checks under this augmented row, the residual
 *  (what escapes the try/catch) is exactly what was admitted by `outer_row`
 *  alone — because the extra caught variants are all handled by the catch arms.
 */
export let build_try_body_row = fn (outer_row: TypeExpr, caught_types: [ TypeExpr ]) -> TypeExpr do
  match outer_row do
    | TyRow(types: outer_types, rest: r) ->
      return TyRow(types: append_types(prefix: caught_types, suffix: outer_types), rest: r)
    | _ ->
      // Non-row outer (e.g. unsolved TyVar): preserve as-is; throw-checking
      // will be conservative (admits anything from a non-row).
      return outer_row
  end
end

let append_types = fn (prefix: [ TypeExpr ], suffix: [ TypeExpr ]) -> [ TypeExpr ] do
  return append_types_go(prefix, suffix, acc: [])
end

let append_types_go = fn (
  prefix: [ TypeExpr ],
  suffix: [ TypeExpr ],
  acc: [ TypeExpr ]
) -> [ TypeExpr ] do
  match prefix do
    | [] ->
      // Append suffix items (they are already in the right order).
      return append_suffix(suffix, acc)
    | t :: rest ->
      return append_types_go(prefix: rest, suffix, acc: t :: acc)
  end
end

let append_suffix = fn (suffix: [ TypeExpr ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match suffix do
    | [] -> return list.reverse(xs: acc)
    | t :: rest -> return append_suffix(suffix: rest, acc: t :: acc)
  end
end
