/**
 * typecheck/infer/effects: pure leaf helpers for handler / inject effect typing.
 *
 * Hosts self-contained helpers that do NOT recurse through infer_expr /
 * infer_stmts:
 *   - `scan_handler_arms_for_ref_capture`: T-Handler no-ref-capture premise scan
 *     over handler arm bodies at construction site (where outer env is still live).
 *   - `inject_cap_entries_acc` / `extend_require_row`: T-Inject ρ_q' extension —
 *     collect TyHandler cap names from the injected handler list and prepend them
 *     to the ambient require row.
 *
 * The outer `infer_raise` / Handler arm in `infer_expr` / Inject arm in
 * `infer_stmt` stay in src/typecheck/infer.nx because they call back into
 * infer_expr / infer_stmts.
 *
 * Extracted from src/typecheck/infer.nx.
 */

import {
  HirHandlerArm,
  HirFunction,
  HirCap,
  HirCapMethod,
  EagerBody,
  LazyBody,
  EnvEntry
} from "src/ir/hir/types.nx"
import {
  TypeExpr, TyRow, TyArrow, TyVar, TyUserDefined, TyHandler, NamedType,
  TyList, TyArray, TyRef, TyLinear, TyBorrow
} from "src/types/type_expr.nx"
import { CheckState, Scheme, SubstEntry }, * as tctypes from "src/typecheck/types.nx"
import * as capture from "src/typecheck/capture.nx"
import { base_name_of } from "src/typecheck/tcwf.nx"
import { hir_params_to_named_types } from "src/typecheck/check/registration.nx"
import { handler_instance_key_prefix } from "src/typecheck/check/handler_validation.nx"
import { convert_named_types, convert_ud_to_var } from "src/typecheck/check/occurs.nx"
import * as bb from "std:bytebuffer"
import { Option, Some, None } from "std:option"
import * as list from "std:list"

// Handler-arm capture scan (T-Handler no-ref-capture): §T-Handler carries the same
// `∀y ∈ fv(e_j). Γ(y) ≠ ~σ` premise as T-Lambda. Inline handler expressions
// reach infer_expr with the construction-site env intact; later passes
// (synthesize_handler, check_handler_arm_bodies) hoist the arm to a top-level
// HirFunction and lose that env. Scan here where it is still available and reject
// the first ref-capture hit across all arms — mirroring infer_lambda's
// RefCaptureHit handling.

/** Scan handler arms for ref-captures at the construction site (T-Handler premise).
 *  Returns the first capture hit found, or None if all arms are clean. */
export let scan_handler_arms_for_ref_capture = fn (
  arms: [ HirHandlerArm ],
  outer_env: [ EnvEntry ]
) -> Option<capture.RefCaptureHit> do
  match arms do
    | [] -> return None
    | HirHandlerArm(
      arm: HirFunction(name: _, type_params: _, params: ps, ret_type: _, throw_row: _, body: bd, _),
      cont_binder: _
    ) :: rest ->
      let body_stmts = match bd do | EagerBody(stmts: ss) -> ss | LazyBody(_) -> [] end
      let scan = capture.scan_lambda_captures(body: body_stmts, outer_env, params: ps)
      match scan do
        | capture.CaptureScan(linear: _, ref_hit: Some(val: hit)) -> return Some(val: hit)
        | capture.CaptureScan(
          linear: _,
          ref_hit: None
        ) -> return scan_handler_arms_for_ref_capture(arms: rest, outer_env)
      end
  end
end

// Handler cross-arm linear-capture uniqueness (T-Handler premise):
//   ∀ y ∈ dom(Γ_cap). |{ j ∈ J | y ∈ fv(e_j) }| = 1
//
// A handler value's closure environment binds each captured name exactly once.
// If arm_i and arm_j both capture the same linear %y, both arms' T-Lambda
// derivations would consume the same resource, admitting double-consumption.
// Scan each arm's body for linear captures; any name that appears in more than
// one arm's fv set violates the uniqueness premise.

let str_member_effects = fn (xs: [ string ], target: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == target then return true end
      return str_member_effects(xs: rest, target)
  end
end

/** Check whether any name in `names` appears in the accumulated `seen` set.
 *  Returns the first such duplicate name, or None if all names are fresh. */
let find_cross_arm_dup = fn (names: [ string ], seen: [ string ]) -> Option<string> do
  match names do
    | [] -> return None
    | n :: rest ->
      if str_member_effects(xs: seen, target: n) then return Some(val: n)
      else return find_cross_arm_dup(names: rest, seen)
      end
  end
end

/** Collect all linear capture names across all arms into `seen`, returning the
 *  first name that appears in more than one arm.  `seen` is the union of all
 *  prior arms' linear capture sets.  Returns None when no arm introduces a
 *  duplicate. */
let check_arms_linear_cross = fn (
  arms: [ HirHandlerArm ],
  outer_env: [ EnvEntry ],
  seen: [ string ]
) -> Option<string> do
  match arms do
    | [] -> return None
    | HirHandlerArm(
      arm: HirFunction(name: _, type_params: _, params: ps, ret_type: _, throw_row: _, body: bd, _),
      cont_binder: _
    ) :: rest ->
      let body_stmts = match bd do | EagerBody(stmts: ss) -> ss | LazyBody(_) -> [] end
      let arm_names = capture.collect_linear_capture_names(body: body_stmts, outer_env, params: ps)
      match find_cross_arm_dup(names: arm_names, seen) do
        | Some(val: dup) -> return Some(val: dup)
        | None ->
          // Extend `seen` with this arm's linear names and continue.
          let seen1 = list.concat(xs: arm_names, ys: seen)
          return check_arms_linear_cross(arms: rest, outer_env, seen: seen1)
      end
  end
end

/** Scan handler arms for cross-arm linear captures at the construction site
 *  (T-Handler cross-arm uniqueness premise).  Returns the name of the first
 *  linear binding captured by more than one arm, or None when all arms have
 *  disjoint linear capture sets. */
export let scan_handler_arms_for_linear_cross = fn (
  arms: [ HirHandlerArm ],
  outer_env: [ EnvEntry ]
) -> Option<string> do
  return check_arms_linear_cross(arms, outer_env, seen: [])
end

// T-Inject: extend require_row with injected cap names.
// T-Inject: ρ_q' = merge(ρ_q, {P̄}).  Walk the handler list, collect
// the TyHandler cap names, and prepend them to the ambient require row.
// Returns the extended row; the caller threads it into the body state.

let inject_cap_entries_acc = fn (
  state: CheckState,
  handlers: [ string ],
  acc: [ TypeExpr ]
) -> [ TypeExpr ] do
  match handlers do
    | [] -> return acc
    | h :: rest ->
      match tctypes.state_lookup_scheme(state, name: h) do
        | None -> return inject_cap_entries_acc(state, handlers: rest, acc)
        | Some(val: Scheme(vars: _, typ: ht)) ->
          match ht do
            | TyHandler(name: pname, requires: _) ->
              // TyHandler.name is the qualified cap name (e.g.
              // "nxlib_stdlib_io_stdio_nx#Console").  The ambient require_row
              // and every handler `require { ... }` row carry bare names
              // ("Console"), so strip the module prefix before extending the
              // ambient row.  Without this, a nested `inject polite` whose
              // handler requires bare "Console" cannot find the qualified
              // "nxlib_...#Console" added by the outer inject, producing a
              // false E2016 (T-Inject: ρ_i ⊄ ρ_q).
              let bare = base_name_of(qualified: pname)
              // Generic-cap soundness (nexus-3ibql): when this handler is for a
              // GENERIC cap, carry its CONCRETE element instantiation as args on
              // the ambient entry (`Box<string>`). The instantiation is read off
              // the handler binding's per-arm concrete signature (recorded under
              // `__handlerinst::<h>::`). The call-site coverage (T-CapCall x ∈
              // ρ_q) then unifies a called function's `Box<i64>` requirement
              // against this `Box<string>` and rejects the mismatch — the spec's
              // forward-pointer "T-CapCall reads σ̄ off the injected handler"
              // (type-system-formal §T-CapCall). Monomorphic caps / handlers
              // whose instantiation cannot be recovered keep the bare entry.
              let elem_args = handler_cap_args(state, handler_name: h, cap_qname: pname, bare)
              return inject_cap_entries_acc(
                state,
                handlers: rest,
                acc: TyUserDefined(name: bare, args: elem_args) :: acc
              )
            | _ -> return inject_cap_entries_acc(state, handlers: rest, acc)
          end
      end
  end
end

// ─── Generic-cap handler instantiation recovery (nexus-3ibql) ───────────────
//
// Recover the element-type instantiation (one TypeExpr per cap type param) of a
// GENERIC-cap handler binding, read off its per-arm concrete signature stored
// under `__handlerinst::<h>::<cap>.<method>` (handler_validation). Returns [] for
// monomorphic caps or when the instantiation cannot be recovered (→ bare entry).

let handler_cap_args = fn (
  state: CheckState, handler_name: string, cap_qname: string, bare: string
) -> [ TypeExpr ] do
  match lookup_cap_decl(caps: tctypes.state_caps(state), bare) do
    | None -> return []
    | Some(val: HirCap(name: _, type_params: cap_tps, methods)) ->
      match cap_tps do
        | [] -> return []
        | _ -> return recover_handler_instantiation(
          state,
          handler_name,
          cap_qname,
          cap_tps,
          methods
        )
      end
  end
end

let lookup_cap_decl = fn (caps: [ HirCap ], bare: string) -> Option<HirCap> do
  match caps do
    | [] -> return None
    | HirCap(name: cn, type_params: tps, methods) :: rest ->
      if base_name_of(qualified: cn) == bare then return Some(val: HirCap(name: cn, type_params: tps, methods)) end
      return lookup_cap_decl(caps: rest, bare)
  end
end

/** Find the first cap method whose `__handlerinst::<h>::<cap>.<method>` scheme is
 *  bound, then match its CONCRETE arm param types against the cap method's
 *  declared params (cap type params → TyVar) to bind the cap type params. Returns
 *  the per-cap-param arg-type list iff every cap type param is bound. */
let recover_handler_instantiation = fn (
  state: CheckState,
  handler_name: string,
  cap_qname: string,
  cap_tps: [ string ],
  methods: [ HirCapMethod ]
) -> [ TypeExpr ] do
  let prefix = handler_instance_key_prefix(handler_name)
  match first_inst_binding(state, prefix, cap_qname, cap_tps, methods) do
    | Some(val: args) -> return args
    | None -> return []
  end
end

let first_inst_binding = fn (
  state: CheckState,
  prefix: string,
  cap_qname: string,
  cap_tps: [ string ],
  methods: [ HirCapMethod ]
) -> Option<[ TypeExpr ]> do
  match methods do
    | [] -> return None
    | HirCapMethod(
      name: mname,
      requires: _,
      span: _,
      throw_row: _,
      typ_params: mparams,
      typ_ret: mret
    ) :: rest ->
      let key = bb.concat(parts: [ prefix, cap_qname, ".", mname ])
      match tctypes.state_lookup_scheme(state, name: key) do
        | Some(val: Scheme(vars: _, typ: TyArrow(params: arm_params, ret: arm_ret, requires: _, throw_row: _))) ->
          let decl_nts = convert_named_types(
            nts: hir_params_to_named_types(params: mparams),
            vars: cap_tps
          )
          let param_bindings = match_nts(pats: decl_nts, concretes: arm_params, acc: [])
          let decl_ret = convert_ud_to_var(typ: mret, vars: cap_tps)
          let bindings = match_type(pat: decl_ret, concrete: arm_ret, acc: param_bindings)
          match all_bound(cap_tps, bindings, acc: []) do
            | Some(val: args) -> return Some(val: args)
            | None -> return first_inst_binding(state, prefix, cap_qname, cap_tps, methods: rest)
          end
        | _ -> return first_inst_binding(state, prefix, cap_qname, cap_tps, methods: rest)
      end
  end
end

/** Match two parallel NamedType lists (cap-method-decl pattern vs concrete arm),
 *  collecting `cap-type-param TyVar → concrete` bindings. Only the direct
 *  `TyVar` pattern positions contribute, sufficient for `wrap(x: T)`. */
let match_nts = fn (
  pats: [ NamedType ], concretes: [ NamedType ], acc: [ SubstEntry ]
) -> [ SubstEntry ] do
  match pats do
    | [] -> return acc
    | NamedType(name: _, typ: pt) :: prest ->
      match concretes do
        | [] -> return acc
        | NamedType(name: _, typ: ct) :: crest ->
          let acc1 = if let TyVar(name: nm) = pt then SubstEntry(
            var: nm,
            typ: ct
          ) :: acc else acc end
          return match_nts(pats: prest, concretes: crest, acc: acc1)
      end
  end
end

/** Structurally match a declared-type pattern (cap type params rendered as
 *  `TyVar`) against an arm's concrete type, collecting `cap-type-param → concrete`
 *  bindings. Used to recover a generic-cap handler's element instantiation when
 *  the cap type param occurs in a method's RETURN position (`fn make(...) -> T`)
 *  rather than an argument; without it the inject ambient row stays
 *  element-agnostic and a return-channel laundered call escapes coverage. */
let match_type = fn (pat: TypeExpr, concrete: TypeExpr, acc: [ SubstEntry ]) -> [ SubstEntry ] do
  match pat do
    | TyVar(name: nm) -> return SubstEntry(var: nm, typ: concrete) :: acc
    | TyList(elem: pe) ->
      match concrete do
        | TyList(elem: ce) -> return match_type(pat: pe, concrete: ce, acc)
        | _ -> return acc
      end
    | TyArray(elem: pe) ->
      match concrete do
        | TyArray(elem: ce) -> return match_type(pat: pe, concrete: ce, acc)
        | _ -> return acc
      end
    | TyRef(inner: pi) ->
      match concrete do
        | TyRef(inner: ci) -> return match_type(pat: pi, concrete: ci, acc)
        | _ -> return acc
      end
    | TyLinear(inner: pi) ->
      match concrete do
        | TyLinear(inner: ci) -> return match_type(pat: pi, concrete: ci, acc)
        | _ -> return acc
      end
    | TyBorrow(inner: pi) ->
      match concrete do
        | TyBorrow(inner: ci) -> return match_type(pat: pi, concrete: ci, acc)
        | _ -> return acc
      end
    | TyUserDefined(name: pn, args: pargs) ->
      match concrete do
        | TyUserDefined(name: cn, args: cargs) ->
          if pn == cn then return match_type_list(pats: pargs, concretes: cargs, acc) end
          return acc
        | _ -> return acc
      end
    | _ -> return acc
  end
end

let match_type_list = fn (
  pats: [ TypeExpr ],
  concretes: [ TypeExpr ],
  acc: [ SubstEntry ]
) -> [ SubstEntry ] do
  match pats do
    | [] -> return acc
    | p :: prest ->
      match concretes do
        | [] -> return acc
        | c :: crest -> return match_type_list(
          pats: prest,
          concretes: crest,
          acc: match_type(pat: p, concrete: c, acc)
        )
      end
  end
end

let all_bound = fn (
  cap_tps: [ string ],
  bindings: [ SubstEntry ],
  acc: [ TypeExpr ]
) -> Option<[ TypeExpr ]> do
  match cap_tps do
    | [] -> return Some(val: list.reverse(xs: acc))
    | t :: rest ->
      match lookup_subst(bindings, var: t) do
        | None -> return None
        | Some(val: ty) -> return all_bound(cap_tps: rest, bindings, acc: ty :: acc)
      end
  end
end

let lookup_subst = fn (bindings: [ SubstEntry ], var: string) -> Option<TypeExpr> do
  match bindings do
    | [] -> return None
    | SubstEntry(var: v, typ: t) :: rest ->
      if v == var then return Some(val: t) end
      return lookup_subst(bindings: rest, var)
  end
end

/** Extend the ambient require row with the cap names of each injected handler.
 *  Implements T-Inject ρ_q' = merge(ρ_q, {P̄}). */
export let extend_require_row = fn (
  state: CheckState,
  handlers: [ string ],
  ambient: TypeExpr
) -> TypeExpr do
  let caps = inject_cap_entries_acc(state, handlers, acc: [])
  match ambient do
    | TyRow(types: existing, rest: r) ->
      return TyRow(types: list.concat(xs: caps, ys: existing), rest: r)
    | _ -> return ambient
  end
end
