/**
 * typecheck/infer/collections: pure helpers backing record / field-access
 * inference.
 *
 * Hosts the parts that don't recurse through infer_expr — the
 * NamedType-list reverse used at record/array materialisation, the
 * NamedType lookup used by record projection and pattern binding, and
 * the linear-field walk that guards T-Proj (field access on a
 * structurally-linear record would silently drop sibling linear
 * obligations).
 *
 * The outer record / array / index / field-access entry points stay in
 * src/typecheck/infer.nx because they call back into infer_expr to type
 * their sub-expressions.
 *
 * Extracted from src/typecheck/infer.nx.
 */

import {
  TypeExpr, TyLinear, TyLazy, TyRecord, TyUserDefined,
  TyRef, TyBorrow, TyList, TyArray,
  NamedType, RecordDef
} from "src/syntax/ast.nx"
import { TypeDefEntry }, * as tctypes from "src/typecheck/types.nx"
import { TypeError } from "src/typecheck/errors.nx"
import { Option, Some, None } from "std:option"

/** Linear lookup of `name` in a NamedType list (record fields / ctor args), returning the bound type or None. */
export let lookup_named_type = fn (nts: [ NamedType ], name: string) -> Option<TypeExpr> do
  match nts do
    | [] -> return None
    | NamedType(name: n, typ: t) :: rest ->
      if n == name then
        return Some(val: t)
      end
      return lookup_named_type(nts: rest, name)
  end
end

// Structural-linearity probe (T-Proj guard): walk record fields and report
// the name of the first field that carries a linear type (TyLinear /
// TyLazy), looking through anonymous TyRecord nesting and named-type
// aliases (RecordDef).
//
// Cycle handling — §Linearity defines the predicate as a least fixpoint
// with a visited set V threaded through:
//   linear'(x⟨σ̄⟩, V) = false                                 if x ∈ V
//                    = ⋁_F linear'(F, V ∪ {x})  for F ∈ unfold(x⟨σ̄⟩)
// We thread a `[string]` of named-type names along every recursive call.
// Only nominal type lookup (TyUserDefined) extends V — wrapper / list /
// record-field traversals thread V unchanged.

let lin_visited_has = fn (visited: [ string ], name: string) -> bool do
  match visited do
    | [] -> return false
    | n :: rest ->
      if n == name then return true end
      return lin_visited_has(visited: rest, name)
  end
end

/** Return the name of the first record field whose type is linear (TyLinear/TyLazy) or contains a linear component, or None. Public entry-point that starts the visited-set fixpoint walk with `V = []`. */
export let find_linear_field = fn (
  fields: [ NamedType ], tdefs: [ tctypes.TypeDefEntry ], depth: i64
) -> Option<string> do
  // `depth` is retained for ABI compatibility but the visited-set walk
  // is the actual cycle guard; the parameter is ignored.
  let _ignore_depth: i64 = depth
  return find_linear_field_visited(fields, tdefs, visited: [])
end

let find_linear_field_visited = fn (
  fields: [ NamedType ], tdefs: [ tctypes.TypeDefEntry ], visited: [ string ]
) -> Option<string> do
  match fields do
    | [] -> return None
    | NamedType(name: fname, typ: ft) :: rest ->
      if type_carries_linear_visited(typ: ft, tdefs, visited) then
        return Some(val: fname)
      end
      return find_linear_field_visited(fields: rest, tdefs, visited)
  end
end

/** True if `typ` is structurally linear (TyLinear/TyLazy) or transitively
 *  contains a linear component through records / aliases / wrappers.
 *  Public entry-point that starts the visited-set fixpoint walk with
 * `V = []`.: spec linearity is entirely structural — we
 *  look through `~τ` (TyRef) / `&τ` (TyBorrow) wrappers and array/list
 *  element types in addition to TyRecord fields and TyUserDefined
 *  record-typedef fields.
 */
export let type_carries_linear = fn (
  typ: TypeExpr, tdefs: [ tctypes.TypeDefEntry ], depth: i64
) -> bool do
  // `depth` is retained for ABI compatibility but the visited-set walk
  // is the actual cycle guard; the parameter is ignored.
  let _ignore_depth: i64 = depth
  return type_carries_linear_visited(typ, tdefs, visited: [])
end

let type_carries_linear_visited = fn (
  typ: TypeExpr, tdefs: [ tctypes.TypeDefEntry ], visited: [ string ]
) -> bool do
  match typ do
    // %σ, @σ are linear by the outermost-wrapper clause.
    | TyLinear(_) | TyLazy(_) -> return true
    // Wrapper / list / record-field traversals thread V unchanged.
    | TyRef(inner: i) | TyBorrow(inner: i) -> return type_carries_linear_visited(
      typ: i,
      tdefs,
      visited
    )
    | TyArray(elem: e) | TyList(elem: e) -> return type_carries_linear_visited(
      typ: e,
      tdefs,
      visited
    )
    | TyRecord(fields: fs) ->
      match find_linear_field_visited(fields: fs, tdefs, visited) do
        | Some(_) -> return true
        | None -> return false
      end
    | TyUserDefined(name: n, args: _) ->
      // x ∈ V → false (minimum fixpoint base case).
      if lin_visited_has(visited, name: n) then return false end
      match tctypes.typedef_lookup(defs: tdefs, name: n) do
        | Some(val: RecordDef(name: _, is_public: _, type_params: _, fields: rec_fields)) ->
          // Recurse into unfolded body with V ∪ {x}.
          match find_linear_field_visited(fields: rec_fields, tdefs, visited: n :: visited) do
            | Some(_) -> return true
            | None -> return false
          end
        | None -> return false
      end
    | _ -> return false
  end
end
