/**
 * typecheck/infer/collections: pure helpers backing record / field-access
 * inference.
 *
 * Hosts the parts that don't recurse through infer_expr — the
 * NamedType-list reverse used at record/array materialisation, the
 * NamedType lookup used by record projection and pattern binding, and
 * the linear-field walk that guards T-Proj (field access on a
 * structurally-linear record would silently drop sibling linear
 * obligations).
 *
 * The outer record / array / index / field-access entry points stay in
 * src/typecheck/infer.nx because they call back into infer_expr to type
 * their sub-expressions.
 *
 * Extracted from src/typecheck/infer.nx (nexus-95iz.8).
 */

import {
  TypeExpr, TyLinear, TyLazy, TyRecord, TyUserDefined,
  NamedType, RecordDef
} from "src/common/ast.nx"
import { TypeDefEntry }, * as tctypes from "src/typecheck/types.nx"
import { TypeError } from "src/common/error.nx"
import { Option, Some, None } from "std:option"

// ─── NamedType list utilities ───────────────────────────────────────────────

export let reverse_named_types = fn (nts: [NamedType], out: [NamedType]) -> [NamedType] throws { TypeError } do
  match nts do
    | [] -> return out
    | h :: rest ->
      return reverse_named_types(nts: rest, out: h :: out)
  end
end

export let lookup_named_type = fn (nts: [NamedType], name: string) -> Option<TypeExpr> throws { TypeError } do
  match nts do
    | [] -> return None
    | NamedType(name: n, typ: t) :: rest ->
      if n == name then
        return Some(val: t)
      end
      return lookup_named_type(nts: rest, name)
  end
end

// ─── Structural-linearity probe (T-Proj guard) ──────────────────────────────
//
// Walk record fields; report the name of the first field that carries a
// linear type (TyLinear / TyLazy), looking through anonymous TyRecord
// nesting and named-type aliases (RecordDef). `depth` caps recursion in
// case a typedef has a cycle.

export let find_linear_field = fn (
  fields: [NamedType], tdefs: [tctypes.TypeDefEntry], depth: i64
) -> Option<string> throws { TypeError } do
  match fields do
    | [] -> return None
    | NamedType(name: fname, typ: ft) :: rest ->
      if type_carries_linear(typ: ft, tdefs, depth) then
        return Some(val: fname)
      end
      return find_linear_field(fields: rest, tdefs, depth)
  end
end

export let type_carries_linear = fn (
  typ: TypeExpr, tdefs: [tctypes.TypeDefEntry], depth: i64
) -> bool throws { TypeError } do
  if depth <= 0 then return false end
  match typ do
    | TyLinear(_) | TyLazy(_) -> return true
    | TyRecord(fields: fs) ->
      match find_linear_field(fields: fs, tdefs, depth: depth - 1) do
        | Some(_) -> return true
        | None -> return false
      end
    | TyUserDefined(name: n, args: _) ->
      match tctypes.typedef_lookup(defs: tdefs, name: n) do
        | Some(val: RecordDef(name: _, is_public: _, type_params: _, fields: rec_fields)) ->
          match find_linear_field(fields: rec_fields, tdefs, depth: depth - 1) do
            | Some(_) -> return true
            | None -> return false
          end
        | None -> return false
      end
    | _ -> return false
  end
end
