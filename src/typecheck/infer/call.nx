/**
 * typecheck/infer/call: function-call type inference.
 *
 * Owns:
 *   - `infer_call`: looks up the callee type, instantiates its scheme, and
 *     delegates to `check_call_args` / `check_call_args_walk`.
 *   - `check_call_args`: validates argument labels and dispatches to the
 *     per-argument walk.
 *   - `check_call_args_walk`: walks parameter/argument pairs, calling
 *     `infer_expr_fn` per argument and unifying types; handles linearity
 *     weakening (T-App-BorrowLin, %-weakening, @-weakening, auto-force).
 *
 * All three entry points receive `infer_expr_fn` as a callback because the
 * argument expressions must be inferred recursively via `infer_expr`.
 *
 * Extracted from src/typecheck/infer.nx.
 */

import { Span } from "src/types/span.nx"
import {
  TypeExpr,
  TyUnit,
  TyLinear,
  TyLazy,
  TyBorrow,
  TyArrow,
  TyList,
  TyArray,
  TyRow,
  TyVar,
  TyUserDefined,
  NamedType
} from "src/types/type_expr.nx"
import { HirExpr, HirExprKind, HirCallArg } from "src/ir/hir/types.nx"
import {
  SubstEntry, CheckState, FreshResult,
  InferExprResult, InferExprOk, InferExprErr,
  UnifyOk, UnifyErr
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as unify from "src/typecheck/unify.nx"
import { Option, Some, None } from "std:option"
import * as list from "std:list"
import {
  InstantiateResult,
  instantiate_scheme, infer_borrow_arg_position
} from "src/typecheck/infer/literals.nx"
import {
  ArgLabelCheck, ArgLabelOk, ArgLabelErr,
  validate_arg_labels, reorder_args_by_params,
  check_bset_no_consume_borrow_conflict
} from "src/typecheck/infer/call_args.nx"
import {
  RaiseAdmissionResult, RaiseOk, RaiseRejected,
  check_call_throw_row_admitted, check_force_require_row,
  CapArgResult, CapArgOk, CapArgMismatch, check_cap_args_covered
} from "src/typecheck/infer/control_flow.nx"
import { TypeError } from "src/typecheck/errors.nx"
import { peel_value_binding_arrows } from "src/typecheck/infer/peel.nx"

// Result of pinning a callee throws-row into an inference-row caller variable:
// the advanced state (fresh-var supply bumped) plus the extra substitution
// (empty when no pinning applies).
type CallPinResult = CallPinResult(state: CheckState, subst: [ SubstEntry ])

/** T-App effect-row pinning for inference-row callers.
 *
 *  Mirrors the raise-site pinning (see infer_raise / pin_raised_into_row): when
 *  the caller's active throws-row is still an unsolved inference variable — as
 *  inside a suspended thunk body, whose collecting row is a fresh `throw_row` —
 *  a call to a function that declares a closed throws-row must EXTEND the
 *  caller row to include those exceptions. Otherwise the thunk's deferred
 *  throws-row escapes unbound and a later thunk-vs-thunk unification can bind
 *  it to a narrower declared row, dropping the exceptions the call can raise.
 *
 *  Only closed callee rows contribute concrete members; an open caller row
 *  whose tail is the `__implicit` absent-annotation sentinel, and closed /
 *  non-row caller rows, are left untouched (admission is already decided by
 *  check_call_throw_row_admitted).
 */
let pin_callee_row_into_caller = fn (
  state: CheckState, callee_row: TypeExpr, caller_row: TypeExpr
) -> CallPinResult do
  match callee_row do
    | TyRow(types: callee_types, rest: None) ->
      match caller_row do
        | TyVar(name: rn) ->
          if rn == "__implicit" then return CallPinResult(state, subst: subst.subst_empty()) end
          let FreshResult(state: st1, typ: tail) = tctypes.tc_fresh_var(state)
          let open_row = TyRow(types: callee_types, rest: Some(val: tail))
          return CallPinResult(state: st1, subst: subst.subst_single(var: rn, typ: open_row))
        | TyRow(types: _, rest: Some(val: tail)) ->
          match tail do
            | TyVar(name: "__implicit") -> return CallPinResult(state, subst: subst.subst_empty())
            | TyVar(name: _) ->
              let FreshResult(state: st1, typ: ftail) = tctypes.tc_fresh_var(state)
              let open_row = TyRow(types: callee_types, rest: Some(val: ftail))
              let tdefs = tctypes.state_typedefs(state: st1)
              match unify.unify(t1: caller_row, t2: open_row, tdefs) do
                | UnifyOk(subst: s) -> return CallPinResult(state: st1, subst: s)
                | UnifyErr(_) -> return CallPinResult(state, subst: subst.subst_empty())
              end
            | _ -> return CallPinResult(state, subst: subst.subst_empty())
          end
        | _ -> return CallPinResult(state, subst: subst.subst_empty())
      end
    | _ -> return CallPinResult(state, subst: subst.subst_empty())
  end
end

// Collect the TyUserDefined entries from a require row (capability names).
let req_row_members = fn (row: TypeExpr) -> [ TypeExpr ] do
  match row do
    | TyRow(types: ts, rest: _) -> return only_user_defined_caps(ts)
    | _ -> return []
  end
end

let only_user_defined_caps = fn (ts: [ TypeExpr ]) -> [ TypeExpr ] do
  match ts do
    | [] -> return []
    | t :: rest ->
      match t do
        | TyUserDefined(name: _, args: _) -> return t :: only_user_defined_caps(ts: rest)
        | _ -> return only_user_defined_caps(ts: rest)
      end
  end
end

// True when the ambient require row is a collecting inference variable —
// i.e., we are inside a thunk body whose require row has not yet been
// discharged to a concrete ambient.  Only the `__implicit` sentinel (absent
// require annotation) is excluded; any other TyVar is a live collecting slot.
let require_row_is_collecting = fn (row: TypeExpr) -> bool do
  match row do
    | TyVar(name: rn) -> return rn != "__implicit"
    | TyRow(types: _, rest: Some(val: tail)) ->
      match tail do
        | TyVar(name: "__implicit") -> return false
        | TyVar(name: _) -> return true
        | _ -> return false
      end
    | _ -> return false
  end
end

/** T-App require-row pinning for collecting-variable ambient require rows.
 *
 *  When a call site is inside a `@`-thunk body, the ambient require row is
 *  a fresh collecting variable (not yet constrained to a concrete row).
 *  Charging the callee's required capabilities against the collecting variable
 *  would fail (the variable is not a TyRow yet).  Instead we pin the callee's
 *  capabilities INTO the collecting variable, extending it — exactly as
 *  pin_callee_row_into_caller does for throws-row inference variables.
 *
 *  The extended collecting row is then carried on the TyLazy thunk type and
 *  discharged against the concrete ambient at the force site (T-Force), where
 *  inject-provided capabilities are correctly in scope.
 */
let pin_callee_req_into_ambient = fn (
  state: CheckState, callee_req: TypeExpr, ambient_req: TypeExpr
) -> CallPinResult do
  let members = req_row_members(row: callee_req)
  if list.is_empty(xs: members) then return CallPinResult(state, subst: subst.subst_empty()) end
  match ambient_req do
    | TyVar(name: rn) ->
      if rn == "__implicit" then return CallPinResult(state, subst: subst.subst_empty()) end
      let FreshResult(state: st1, typ: tail) = tctypes.tc_fresh_var(state)
      let open_row = TyRow(types: members, rest: Some(val: tail))
      return CallPinResult(state: st1, subst: subst.subst_single(var: rn, typ: open_row))
    | TyRow(types: _, rest: Some(val: tail)) ->
      match tail do
        | TyVar(name: "__implicit") -> return CallPinResult(state, subst: subst.subst_empty())
        | TyVar(name: _) ->
          let FreshResult(state: st1, typ: ftail) = tctypes.tc_fresh_var(state)
          let open_row = TyRow(types: members, rest: Some(val: ftail))
          let tdefs = tctypes.state_typedefs(state: st1)
          match unify.unify(t1: ambient_req, t2: open_row, tdefs) do
            | UnifyOk(subst: s) -> return CallPinResult(state: st1, subst: s)
            | UnifyErr(_) -> return CallPinResult(state, subst: subst.subst_empty())
          end
        | _ -> return CallPinResult(state, subst: subst.subst_empty())
      end
    | _ -> return CallPinResult(state, subst: subst.subst_empty())
  end
end

export let infer_call = fn (
  state: CheckState, func: string, args: [ HirCallArg ], span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match tctypes.state_lookup_scheme(state, name: func) do
    | None -> return InferExprErr(message: "unbound function: " ++ func, span)
    | Some(val: sch) ->
      let InstantiateResult(state: st1, typ: func_type_raw) = instantiate_scheme(state, scheme: sch)
      let func_type = match func_type_raw do
            | TyLinear(inner: u) -> u
            | TyLazy(inner: u, require_row: lazy_rq, throw_row: lazy_thr) ->
              // T-Force: surface deferred throw_row into the ambient throw check.
              let lazy_caller_row = tctypes.state_throw_row(state: st1)
              let groups1 = tctypes.state_exception_groups(state: st1)
              let fn_pure_set1 = tctypes.state_fn_pure_set(state: st1)
              match check_call_throw_row_admitted(
                callee_row: lazy_thr,
                caller_row: lazy_caller_row,
                groups: groups1,
                func,
                fn_pure_set: fn_pure_set1
              ) do
                | RaiseRejected(message: m) -> return InferExprErr(
                  message: "force " ++ func ++ ": " ++ m,
                  span
                )
                | RaiseOk ->
                  // T-Force: check deferred require_row against ambient.
                  let ambient_rq = tctypes.state_require_row(state: st1)
                  match check_force_require_row(
                    thunk_require_row: lazy_rq,
                    ambient_require_row: ambient_rq
                  ) do
                    | Some(val: missing) ->
                      return InferExprErr(
                        message: "force " ++ func ++ ": thunk requires capability '" ++ missing
                          ++ "' which is not in the ambient require row",
                        span
                      )
                    | None -> ()
                  end
              end
              u
            | _ -> func_type_raw
          end
          match func_type do
            | TyArrow(params, ret, requires: callee_req, throw_row: callee_thr) ->
              match check_call_args(
                state: st1,
                params,
                args,
                ret,
                subst: subst.subst_empty(),
                span,
                infer_expr_fn
              ) do
                | InferExprErr(message: m, span: esp) -> return InferExprErr(message: m, span: esp)
                | InferExprOk(state: st2, subst: s_all, typ: rt) ->
                  // T-App effect side-condition: every concrete exception
                  // raisable by the callee must be admitted by the caller's
                  // active throws-row. Without this the typechecker tracks
                  // throw_row but never enforces it for calls — narrowing
                  // a function to `throws { LirError }` then calling a
                  // `throws { TypeError }` callee would type-check while violating
                  // the narrow contract. Mirrors the row-subsumption logic
                  // used for direct raises (see check_raise_admitted).
                  let callee_row = subst.subst_apply(subst: s_all, typ: callee_thr)
                  let caller_row = subst.subst_apply(
                    subst: s_all,
                    typ: tctypes.state_throw_row(state: st2)
                  )
                  let groups = tctypes.state_exception_groups(state: st2)
                  let fn_pure_set = tctypes.state_fn_pure_set(state: st2)
                  match check_call_throw_row_admitted(
                    callee_row,
                    caller_row,
                    groups,
                    func,
                    fn_pure_set
                  ) do
                    | RaiseRejected(message: m) -> return InferExprErr(message: m, span)
                    | RaiseOk ->
                      // T-App capability side-condition: every capability named in
                      // the callee's require row must be covered by the ambient
                      // require row of the calling function.
                      //
                      // When the ambient require row is a collecting inference
                      // variable (inside a @-thunk body), the check must be
                      // deferred to the force site — the same discipline as
                      // throws-row deferral for @-thunks.  Pin the callee's
                      // required capabilities into the collecting variable so they
                      // are carried on the TyLazy thunk type and verified at the
                      // force site (T-Force) where inject-provided capabilities
                      // are in scope.
                      //
                      // When the ambient is a concrete row (inside a normal fn),
                      // charge the callee's require row eagerly as before.
                      let callee_req_applied = subst.subst_apply(subst: s_all, typ: callee_req)
                      let ambient_req = tctypes.state_require_row(state: st2)
                      // Defer path: inside a @-thunk body, pin callee's caps into
                      // the collecting require variable and skip the eager check.
                      if require_row_is_collecting(row: ambient_req) then
                        let CallPinResult(state: st3, subst: pin_rq_s) =
                          pin_callee_req_into_ambient(
                            state: st2,
                            callee_req: callee_req_applied,
                            ambient_req
                          )
                        let s_with_rq = subst.subst_compose(s1: s_all, s2: pin_rq_s)
                        let CallPinResult(state: st4, subst: pin_s) =
                          pin_callee_row_into_caller(state: st3, callee_row, caller_row)
                        let s_pinned = subst.subst_compose(s1: s_with_rq, s2: pin_s)
                        return InferExprOk(
                          state: st4,
                          subst: s_pinned,
                          typ: subst.subst_apply(subst: pin_s, typ: rt)
                        )
                      end
                      // Eager path: ambient is a concrete row; check coverage now.
                      match check_force_require_row(
                        thunk_require_row: callee_req_applied,
                        ambient_require_row: ambient_req
                      ) do
                        | Some(val: missing) ->
                          return InferExprErr(
                            message: "call " ++ func ++ ": callee requires capability '"
                              ++ missing ++ "' which is not in the ambient require row",
                            span
                          )
                        | None ->
                          // T-CapCall generic-cap soundness (nexus-3ibql): the
                          // cap NAMES are covered; now verify the element-type
                          // instantiation a callee commits to (`Box<i64>`) is
                          // compatible with the handler in scope (`Box<string>`
                          // from the enclosing inject). A mismatch is the
                          // laundered generic-cap type confusion.
                          match check_cap_args_covered(
                            callee_row: callee_req_applied,
                            ambient_row: ambient_req,
                            tdefs: tctypes.state_typedefs(state: st2)
                          ) do
                            | CapArgMismatch(cap_name: _, message: m) ->
                              return InferExprErr(message: "call " ++ func ++ ": " ++ m, span)
                            | CapArgOk(subst: cap_s) ->
                              // The coverage subst binds nothing in the normal
                              // checking phase (ambient cap args are concrete);
                              // during the contract-derivation pass (cap_contract.nx)
                              // it PINS the fresh ambient cap variable to the element
                              // type the callee commits, so the derived require row
                              // resolves to `Box<i64>`. Compose it so it reaches the
                              // derivation pass's body substitution.
                              let s_cov = subst.subst_compose(s1: s_all, s2: cap_s)
                              match check_fn_value_arg_caps_covered(
                                state: st2,
                                params,
                                args,
                                ambient_row: ambient_req,
                                subst: s_cov,
                                infer_expr_fn
                              ) do
                                | CapArgMismatch(cap_name: _, message: m) ->
                                  return InferExprErr(message: "call " ++ func ++ ": " ++ m, span)
                                | CapArgOk(subst: _) -> ()
                              end
                              // T-App (inference-row pinning): if the caller's
                              // active throws-row is still an unsolved variable (a
                              // collecting thunk row), extend it to include the
                              // callee's declared exceptions so they are not later
                              // unified away against a narrower declared row.
                              let CallPinResult(state: st3, subst: pin_s) =
                                pin_callee_row_into_caller(state: st2, callee_row, caller_row)
                              let s_pinned = subst.subst_compose(s1: s_cov, s2: pin_s)
                              return InferExprOk(
                                state: st3,
                                subst: s_pinned,
                                typ: subst.subst_apply(subst: pin_s, typ: rt)
                              )
                          end
                      end
                  end
              end
            | _ ->
              return InferExprErr(message: func ++ " is not a function", span)
          end
  end
end

export let check_call_args = fn (
  state: CheckState, params: [ NamedType ], args: [ HirCallArg ],
  ret: TypeExpr, subst: [ SubstEntry ], span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  // validate that every call-arg label matches a parameter
  // name (and vice versa) BEFORE the positional walk. The MIR→LIR
  // lowering sorts both call args and params alphabetically by label (see
  // sort_lir_call_args / sort_lir_params in src/ir/lir/lir.nx). A pun like
  // `f(x, y)` against `fn (a, b)` would otherwise pass through positional-
  // walk, then the sort would place x/y into a/b slots in wrong alphabetic
  // order — a silent wrong-slot runtime miscompile. Reordering by label IS
  // allowed: declared `fn (a, b)` accepts `f(b: 10, a: 52)` because the
  // sort brings both sides into alignment.
  match validate_arg_labels(args, params) do
    | ArgLabelErr(message: m) -> return InferExprErr(message: m, span)
    | ArgLabelOk ->
      let ordered = reorder_args_by_params(args, params)
      // T-App B-set premise (spec §T-App): if any arg is Borrow(&x) and
      // another arg is a consuming use of x (Variable(x), non-Borrow), then
      // x is NOT in B — it must go through the ⊗-split path, and the &x
      // falls through to T-Borrow → x:^ω check → reject. Pre-scan the
      // ordered args before the walk to detect this violation early.
      match check_bset_no_consume_borrow_conflict(args: ordered) do
        | ArgLabelErr(message: m) -> return InferExprErr(message: m, span)
        | ArgLabelOk -> return check_call_args_walk(
          state,
          params,
          args: ordered,
          ret,
          subst,
          span,
          infer_expr_fn
        )
      end
  end
end

/** Generic-cap soundness for HIGHER-ORDER value-parameter forwarders. A function
 *  value committed to a concrete element type (`need_i64 : require { Box<i64> }`)
 *  may be passed to a parameter declared with a bare generic-cap require row
 *  (`g : (s: i64) -> i64 require { Box }`); the arrow-unify require-row subtyping
 *  (unify.row_remove_bare_cap) admits `Box<i64> ⊆ bare Box`, ERASING the element
 *  type at the parameter boundary. A callee that itself carries that cap invokes
 *  the value parameter under the AMBIENT handler in scope, so the value's
 *  committed element type must be covered by that ambient handler — otherwise an
 *  `i64` commitment runs under a `Box<string>` handler (the laundered, transitive
 *  type confusion). For every function-valued argument whose matching parameter
 *  type carries a generic-cap require row, recover the argument's own require row
 *  and cover its concrete cap element args against the ambient row, MATCHING the
 *  direct-call and named-call coverage checks. Bare argument rows are
 *  element-agnostic and admitted (no over-rejection of polymorphic helpers). */
let check_fn_value_arg_caps_covered = fn (
  state: CheckState,
  params: [ NamedType ],
  args: [ HirCallArg ],
  ambient_row: TypeExpr,
  subst: [ SubstEntry ],
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> CapArgResult throws { TypeError } do
  match params do
    | [] -> return CapArgOk(subst: subst.subst_empty())
    | NamedType(name: pname, typ: ptyp) :: rp ->
      match args do
        | [] -> return CapArgOk(subst: subst.subst_empty())
        | HirCallArg(label: _, value: arg_val) :: ra ->
          let p_resolved = subst.subst_apply(subst, typ: ptyp)
          match arrow_require_row(typ: p_resolved) do
            | None -> return check_fn_value_arg_caps_covered(
                state, params: rp, args: ra, ambient_row, subst, infer_expr_fn
              )
            | Some(val: prow) ->
              if row_has_no_cap(row: prow) then
                return check_fn_value_arg_caps_covered(
                  state, params: rp, args: ra, ambient_row, subst, infer_expr_fn
                )
              end
              match probe_arg_type(state, arg_val, infer_expr_fn) do
                | None -> return check_fn_value_arg_caps_covered(
                    state, params: rp, args: ra, ambient_row, subst, infer_expr_fn
                  )
                | Some(val: ProbeArgType(state: st1, subst: s_arg, typ: arg_t)) ->
                  let arg_resolved = subst.subst_apply(subst: s_arg, typ: arg_t)
                  match arrow_require_row(typ: arg_resolved) do
                    | None -> return check_fn_value_arg_caps_covered(
                        state, params: rp, args: ra, ambient_row, subst, infer_expr_fn
                      )
                    | Some(val: arg_row) ->
                      match check_cap_args_covered(
                        callee_row: arg_row,
                        ambient_row,
                        tdefs: tctypes.state_typedefs(state: st1)
                      ) do
                        | CapArgMismatch(cap_name: cn, message: m) ->
                          return CapArgMismatch(cap_name: cn, message: m)
                        | CapArgOk(subst: _) -> return check_fn_value_arg_caps_covered(
                            state, params: rp, args: ra, ambient_row, subst, infer_expr_fn
                          )
                      end
                  end
              end
          end
      end
  end
end

type ProbeArgType = ProbeArgType(state: CheckState, subst: [ SubstEntry ], typ: TypeExpr)

/** Read-only probe of an argument expression's type for the higher-order
 *  coverage check. The probe state and its substitution are discarded by the
 *  caller (only the recovered type is consulted), so this never affects the main
 *  argument walk's linearity / substitution flow. Any inference error is
 *  swallowed: the argument is checked for real by `check_call_args_walk`, and a
 *  probe failure simply skips the optional coverage refinement. */
let probe_arg_type = fn (
  state: CheckState,
  arg_val: HirExpr,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> Option<ProbeArgType> do
  try
    match infer_expr_fn(state, expr: arg_val, ret_type: TyUnit) do
      | InferExprErr(message: _, span: _) -> return None
      | InferExprOk(state: st1, subst: s_arg, typ: arg_t) ->
        return Some(val: ProbeArgType(state: st1, subst: s_arg, typ: arg_t))
    end
  catch
    | _ -> return None
  end
end

/** The require row of a (possibly linear/lazy-wrapped, possibly list/array-
 *  nested) arrow type, else None. Descending through `TyList`/`TyArray` recovers
 *  the element-arrow require row of a CONTAINER parameter/argument
 *  (`[ (s: i64) -> i64 require { Box } ]`), so a cap-bearing closure laundered as
 *  a list element is covered at the call boundary exactly as a bare arrow
 *  parameter is. */
let arrow_require_row = fn (typ: TypeExpr) -> Option<TypeExpr> do
  match typ do
    | TyArrow(params: _, ret: _, requires: rq, throw_row: _) -> return Some(val: rq)
    | TyLinear(inner: i) -> return arrow_require_row(typ: i)
    | TyLazy(inner: i, require_row: _, throw_row: _) -> return arrow_require_row(typ: i)
    | TyList(elem: e) -> return arrow_require_row(typ: e)
    | TyArray(elem: e) -> return arrow_require_row(typ: e)
    | TyUserDefined(name: n, args: targs) ->
      if n == "List" || n == "Array" then
        match targs do
          | e :: _ -> return arrow_require_row(typ: e)
          | [] -> return None
        end
      end
      return None
    | _ -> return None
  end
end

/** True when a require row names no capability entry at all. A parameter arrow
 *  whose require row names a cap (bare `Box` or concrete `Box<τ>`) WILL invoke
 *  the passed function value under that cap's ambient handler, so the argument's
 *  own commitment must be covered; an empty row carries no such obligation. */
let row_has_no_cap = fn (row: TypeExpr) -> bool do
  match row do
    | TyRow(types: ts, rest: _) -> return entries_have_no_cap(ts)
    | _ -> return true
  end
end

let entries_have_no_cap = fn (ts: [ TypeExpr ]) -> bool do
  match ts do
    | [] -> return true
    | TyUserDefined(name: _, args: _) :: _ -> return false
    | _ :: rest -> return entries_have_no_cap(ts: rest)
  end
end

export let check_call_args_walk = fn (
  state: CheckState, params: [ NamedType ], args: [ HirCallArg ],
  ret: TypeExpr, subst: [ SubstEntry ], span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match params do
    | [] ->
      match args do
        | [] -> return InferExprOk(state, subst, typ: subst.subst_apply(subst, typ: ret))
        | _ -> return InferExprErr(message: "too many arguments", span)
      end
    | NamedType(name: pname, typ: ptyp) :: rp ->
      match args do
        | [] -> return InferExprErr(message: "missing argument: " ++ pname, span)
        | HirCallArg(label: _, value: val) :: ra ->
          // T-App-BorrowLin (spec §T-App): when the argument is syntactically
          // `&x`, bypass T-Borrow's x:^ω check and use the arg-position form
          // that permits linear/lazy targets. The borrow is discharged on call
          // return; the linear binding `x` survives the call unconsumed.
          let HirExpr(node: val_node, span: val_sp) = val
          // T-App-BorrowLin gate: only invoke `infer_borrow_arg_position`
          // (which skips T-Borrow's x:^ω check) when the *expected* param
          // type is syntactically `&σ`.  For a non-borrow param `P ≠ &σ`,
          // a `&x` argument must route through `infer_expr` → ordinary
          // T-Borrow, which enforces x:^ω and therefore rejects linear `x`.
          // Without this guard, `&_` silently passed to e.g. `i64` params:
          // infer_borrow_arg_position produced TyBorrow(i64), U-Borrow
          // auto-derefed it to i64 during unification, and LinearUnused
          // was silently skipped for `_`-named bindings (see LinearUnused check in linearity.nx).
          let p_resolved = subst.subst_apply(subst, typ: ptyp)
          let arg_result = match val_node do
            | Borrow(name: borrow_target, sigil: _) ->
              match p_resolved do
                | TyBorrow(_) ->
                  infer_borrow_arg_position(state, name: borrow_target, span: val_sp)
                | _ ->
                  infer_expr_fn(state, expr: val, ret_type: TyUnit)
              end
            | _ ->
              infer_expr_fn(state, expr: val, ret_type: TyUnit)
          end
          match arg_result do
            | InferExprErr(
              message: m,
              span: espan
            ) -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m, span: espan)
            | InferExprOk(state: st1, subst: s1, typ: arg_t) ->
              let s_merged = subst.subst_compose(s1: subst, s2: s1)
              let expected = subst.subst_apply(subst: s_merged, typ: ptyp)
              let tdefs = tctypes.state_typedefs(state: st1)
              match unify.unify(t1: arg_t, t2: expected, tdefs) do
                | UnifyOk(subst: s2) ->
                  let s_all = subst.subst_compose(s1: s_merged, s2)
                  return check_call_args_walk(
                    state: st1,
                    params: rp,
                    args: ra,
                    ret,
                    subst: s_all,
                    span,
                    infer_expr_fn
                  )
                | UnifyErr(message: m) ->
                  // Linearity-weakening at call sites: permit passing a plain
                  // value `T` where the parameter is `%T` or `@T` by re-unifying
                  // against the inner type. The wrapper is reintroduced
                  // lexically by the param sigil; the value's modality is
                  // preserved by the linear-capture / lazy-capture machinery
                  // downstream.
                  //
                  // a borrow `&x` is syntactically non-linear
                  // (linear(&σ) = false per spec §Linearity), so the weakening
                  // would naively strip %T → T and admit &x against %T —
                  // letting the callee consume the underlying owner of x
                  // while the caller still believes it's live ('borrow-to-
                  // ownership smuggling'). T-App-BorrowLin already covers the
                  // legitimate &x → &σ case; the only remaining shape for an
                  // &x argument is %σ (or @σ), which we reject here.
                  match expected do
                    | TyLinear(inner: pinner) ->
                      match arg_t do
                        | TyBorrow(_) ->
                          return InferExprErr(
                            message: "arg " ++ pname ++ ": cannot pass borrow '&x' where parameter expects linear '%T'; borrows cannot satisfy ownership-consuming parameters (spec §U-Borrow / §T-App weakening;)",
                            span
                          )
                        | _ -> ()
                      end
                      match unify.unify(t1: arg_t, t2: pinner, tdefs) do
                        | UnifyOk(subst: s2) ->
                          let s_all = subst.subst_compose(s1: s_merged, s2)
                          return check_call_args_walk(
                            state: st1,
                            params: rp,
                            args: ra,
                            ret,
                            subst: s_all,
                            span,
                            infer_expr_fn
                          )
                        | UnifyErr(message: _) -> return InferExprErr(
                          message: "arg " ++ pname ++ ": " ++ m,
                          span
                        )
                      end
                    | TyLazy(inner: pinner, require_row: _, throw_row: _) ->
                      match arg_t do
                        | TyBorrow(_) ->
                          return InferExprErr(
                            message: "arg " ++ pname ++ ": cannot pass borrow '&x' where parameter expects lazy '@T'; borrows cannot satisfy one-shot lazy parameters (spec §U-Borrow;)",
                            span
                          )
                        | _ -> ()
                      end
                      match unify.unify(t1: arg_t, t2: pinner, tdefs) do
                        | UnifyOk(subst: s2) ->
                          let s_all = subst.subst_compose(s1: s_merged, s2)
                          return check_call_args_walk(
                            state: st1,
                            params: rp,
                            args: ra,
                            ret,
                            subst: s_all,
                            span,
                            infer_expr_fn
                          )
                        | UnifyErr(message: _) -> return InferExprErr(
                          message: "arg " ++ pname ++ ": " ++ m,
                          span
                        )
                      end
                    | _ ->
                      // Auto-force at call sites: top-level `let
                      // x = e` is registered with type `TyArrow(params: [],
                      // ret: T)` — a nullary-thunk shape — but MIR lowers a
                      // bare `Variable(x)` reference to a plain value read
                      // (no auto-call inserted; see ctx_value_binding_names
                      // in src/ir/mir/mir.nx). Existing call paths (`x()`, `x + 1`
                      // via `infer_call`'s callee-peel) already see through
                      // this thunk shape. The missing symmetric site is the
                      // labeled-call-arg position: passing such an `x` to a
                      // parameter expecting bare `T` would otherwise fail with
                      // a misleading "[E2001] expected arrow type" diagnostic.
                      // Peel `TyArrow(params: [], ret: T)` (and `TyLazy(T)`
                      // for handler-arm-style lazy bindings), re-unify against
                      // the param type. Mirrors the param-side
                      // `TyLinear`/`TyLazy` weakening above, in the opposite
                      // direction.
                      match arg_t do
                        | TyLazy(inner: ainner, require_row: _, throw_row: _) ->
                          match unify.unify(t1: ainner, t2: expected, tdefs) do
                            | UnifyOk(subst: s2) ->
                              let s_all = subst.subst_compose(s1: s_merged, s2)
                              return check_call_args_walk(
                                state: st1,
                                params: rp,
                                args: ra,
                                ret,
                                subst: s_all,
                                span,
                                infer_expr_fn
                              )
                            | UnifyErr(message: _) -> return InferExprErr(
                              message: "arg " ++ pname ++ ": " ++ m,
                              span
                            )
                          end
                        | TyLinear(inner: TyLazy(inner: ainner, require_row: _, throw_row: _)) ->
                          match unify.unify(t1: ainner, t2: expected, tdefs) do
                            | UnifyOk(subst: s2) ->
                              let s_all = subst.subst_compose(s1: s_merged, s2)
                              return check_call_args_walk(
                                state: st1,
                                params: rp,
                                args: ra,
                                ret,
                                subst: s_all,
                                span,
                                infer_expr_fn
                              )
                            | UnifyErr(message: _) -> return InferExprErr(
                              message: "arg " ++ pname ++ ": " ++ m,
                              span
                            )
                          end
                        | TyLinear(inner: ainner) ->
                          // T-Let wrapSigil: `let %b = Ctor(...)` gives `b` type
                          // `TyLinear(T)` in the env. At call sites, param sigils are NOT
                          // reflected in the Arrow type (build_param_named_types ignores sigil),
                          // so a `%param: T` param appears with bare type `T`. When arg_t is
                          // `TyLinear(T)` but expected is the bare `T`, strip the Linear wrapper
                          // and re-unify. Linearity enforcement is handled by linearity.nx (which
                          // tracks sigil, not the wrapper), not by the Arrow param type.
                          match unify.unify(t1: ainner, t2: expected, tdefs) do
                            | UnifyOk(subst: s2) ->
                              let s_all = subst.subst_compose(s1: s_merged, s2)
                              return check_call_args_walk(
                                state: st1,
                                params: rp,
                                args: ra,
                                ret,
                                subst: s_all,
                                span,
                                infer_expr_fn
                              )
                            | UnifyErr(message: _) -> return InferExprErr(
                              message: "arg " ++ pname ++ ": " ++ m,
                              span
                            )
                          end
                        | TyArrow(params: [], ret: aret, requires: _, throw_row: _) ->
                          match unify.unify(t1: aret, t2: expected, tdefs) do
                            | UnifyOk(subst: s2) ->
                              let s_all = subst.subst_compose(s1: s_merged, s2)
                              return check_call_args_walk(
                                state: st1,
                                params: rp,
                                args: ra,
                                ret,
                                subst: s_all,
                                span,
                                infer_expr_fn
                              )
                            | UnifyErr(message: _) -> return InferExprErr(
                              message: "arg " ++ pname ++ ": " ++ m,
                              span
                            )
                          end
                        | _ ->
                          match peel_value_binding_arrows(actual: arg_t, expected, tdefs) do
                            | Some(val: UnifyOk(subst: s2)) ->
                              let s_all = subst.subst_compose(s1: s_merged, s2)
                              return check_call_args_walk(
                                state: st1,
                                params: rp,
                                args: ra,
                                ret,
                                subst: s_all,
                                span,
                                infer_expr_fn
                              )
                            | _ -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m, span)
                          end
                      end
                  end
              end
          end
      end
  end
end
