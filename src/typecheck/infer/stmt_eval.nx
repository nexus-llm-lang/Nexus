/**
 * typecheck/infer/stmt_eval: statement-kind type inference.
 *
 * Owns:
 *   - `infer_stmt_impl`: dispatches a single HIR statement kind to
 *     Let / Expr / Return / Assign / Try / Inject arms.
 *   - `infer_let_impl`: T-Let family (T-Let-Mutable, T-Let-Lazy, T-Let-Alias,
 *     T-Let-wrapSigil). Handles the borrow-at-let-rhs rejection and the
 *     poly-alias carve-out before falling through to `infer_expr_fn`.
 *   - `infer_return_impl`: T-Return with gravity-rule check and linearity
 *     weakening.
 *   - `infer_try_impl`: T-TryCatch — catch-param type projection and
 *     in_catch_body flag.
 *
 * All entry points receive `infer_expr_fn` and `infer_stmts_fn` as callbacks
 * because they recurse through sub-expressions and statement lists.
 *
 * Extracted from src/typecheck/infer.nx.
 */

import { Span } from "src/types/span.nx"
import { Sigil, SigilMutable, SigilLinear, SigilLazy, BinaryOp } from "src/types/vocab.nx"
import {
  TypeExpr,
  TyUnit,
  TyI64,
  TyLinear,
  TyLazy,
  TyRef,
  TyBorrow,
  TyArray,
  TyArrow,
  TyRow
} from "src/types/type_expr.nx"
import { HirExpr, HirExprKind, HirStmt, HirStmtKind } from "src/ir/hir/types.nx"
import {
  SubstEntry, Scheme, CheckState, FreshResult,
  InferExprResult, InferExprOk, InferExprErr,
  UnifyOk, UnifyErr
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as unify from "src/typecheck/unify.nx"
import * as tcwf from "src/typecheck/tcwf.nx"
import { InstantiateResult, instantiate_scheme } from "src/typecheck/infer/literals.nx"
import {
  LetMutLinearKind, LetMutOk, LetMutLinearBare, LetMutLinearLazy, LetMutLinearStructural,
  let_mut_linear_kind, alias_poly_scheme, wrap_ref,
  catch_param_type_from_row,
  default_numeric_literals
} from "src/typecheck/infer/statements.nx"
import {
  check_handlers_bound, check_inject_uniqueness, check_inject_require_subset,
  catch_is_catch_all, collect_caught_types, build_try_body_row
} from "src/typecheck/infer/control_flow.nx"
import { extend_require_row } from "src/typecheck/infer/effects.nx"
import { apply_injected_handler_instances } from "src/typecheck/check/handler_validation.nx"
import { build_param_named_types } from "src/typecheck/infer/closure.nx"
import * as capture from "src/typecheck/capture.nx"
import { TypeError, LinearUnused } from "src/typecheck/errors.nx"
import { Option, Some, None } from "std:option"

export let infer_stmt_impl = fn (
  state: CheckState, stmt: HirStmtKind, ret_type: TypeExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError },
  infer_stmts_fn: (
    state: CheckState,
    stmts: [ HirStmt ],
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError },
  infer_binop_fn: (
    state: CheckState,
    left: HirExpr,
    op: BinaryOp,
    right: HirExpr,
    span: Span,
    expected: Option<TypeExpr>
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match stmt do
    | Let(name, sigil, typ: ann, value) ->
      return infer_let_impl(
        state,
        name,
        sigil,
        ann,
        value,
        ret_type,
        span,
        infer_expr_fn,
        infer_binop_fn
      )
    | Expr(expr) ->
      return infer_expr_fn(state, expr, ret_type)
    | Return(expr) ->
      return infer_return_impl(state, expr, ret_type, span, infer_expr_fn, infer_binop_fn)
    | Assign(target, value) ->
      let HirExpr(node: target_node, span: _) = target
      match target_node do
        | Variable(name: n, sigil: _) ->
          match tctypes.env_lookup(env: tctypes.state_env(state), name: n) do
            | None -> return InferExprErr(message: "assign: unbound variable '" ++ n ++ "'", span)
            | Some(val: sch) ->
              let InstantiateResult(
                state: st0,
                typ: target_type
              ) = instantiate_scheme(state, scheme: sch)
              let inner_t = if let TyRef(inner: i) = target_type then i else
                    return InferExprErr(
                      message: "assign '" ++ n ++ "': target is not a mutable ref (`~τ` required)",
                      span
                    )
                  end
                  match infer_expr_fn(state: st0, expr: value, ret_type) do
                    | InferExprErr(
                      message: m,
                      span: espan
                    ) -> return InferExprErr(message: "assign: " ++ m, span: espan)
                    | InferExprOk(state: st1, subst: s1, typ: t_value) ->
                      let tdefs = tctypes.state_typedefs(state: st1)
                      match unify.unify(
                        t1: t_value,
                        t2: subst.subst_apply(subst: s1, typ: inner_t),
                        tdefs
                      ) do
                        | UnifyErr(message: m) -> return InferExprErr(
                          message: "assign '" ++ n ++ "': " ++ m,
                          span
                        )
                        | UnifyOk(subst: s2) -> return InferExprOk(
                          state: st1,
                          subst: subst.subst_compose(s1, s2),
                          typ: TyUnit
                        )
                      end
                  end
          end
        | Index(target: arr, index: idx) ->
          match infer_expr_fn(state, expr: arr, ret_type) do
            | InferExprErr(
              message: m,
              span: espan
            ) -> return InferExprErr(message: "assign: " ++ m, span: espan)
            | InferExprOk(state: st0, subst: s0, typ: t_arr) ->
              match infer_expr_fn(state: st0, expr: idx, ret_type) do
                | InferExprErr(
                  message: m,
                  span: espan
                ) -> return InferExprErr(message: "assign index: " ++ m, span: espan)
                | InferExprOk(state: st1, subst: s1, typ: t_idx) ->
                  let tdefs1 = tctypes.state_typedefs(state: st1)
                  match unify.unify(t1: t_idx, t2: TyI64, tdefs: tdefs1) do
                    | UnifyErr(message: m) -> return InferExprErr(
                      message: "assign index: " ++ m,
                      span
                    )
                    | UnifyOk(subst: s2) ->
                      let t_arr_a = subst.subst_apply(subst: s2, typ: t_arr)
                      let elem_t = match t_arr_a do
                        | TyArray(elem: e)
                        | TyBorrow(inner: TyArray(elem: e))
                        | TyLinear(inner: TyArray(elem: e))
                        | TyLazy(inner: TyArray(elem: e), require_row: _, throw_row: _) -> e
                        | _ -> return InferExprErr(message: "assign: target is not an array", span)
                      end
                      match infer_expr_fn(state: st1, expr: value, ret_type) do
                        | InferExprErr(
                          message: m,
                          span: espan
                        ) -> return InferExprErr(message: "assign value: " ++ m, span: espan)
                        | InferExprOk(state: st2, subst: s3, typ: t_value) ->
                          let tdefs2 = tctypes.state_typedefs(state: st2)
                          match unify.unify(
                            t1: t_value,
                            t2: subst.subst_apply(subst: s3, typ: elem_t),
                            tdefs: tdefs2
                          ) do
                            | UnifyErr(message: m) -> return InferExprErr(
                              message: "assign element: " ++ m,
                              span
                            )
                            | UnifyOk(subst: s4) ->
                              let s01 = subst.subst_compose(s1: s0, s2: s1)
                              let s23 = subst.subst_compose(s1: s2, s2: s3)
                              let s0123 = subst.subst_compose(s1: s01, s2: s23)
                              let s_all = subst.subst_compose(s1: s0123, s2: s4)
                              return InferExprOk(state: st2, subst: s_all, typ: TyUnit)
                          end
                      end
                  end
              end
          end
        | _ -> return InferExprErr(
          message: "assign: target must be a variable or indexed access (parser invariant)",
          span
        )
      end
    | Try(body, catch_param: cp, catch_body: cb) ->
      return infer_try_impl(
        state,
        body,
        catch_param: cp,
        catch_body: cb,
        ret_type,
        span,
        infer_stmts_fn
      )
  end
end

/** Shared T-Inject body typing for the inject expression (Inject member of
 *  HirExprKind — the SOLE inject HIR form). Runs the T-Inject premise checks
 *  (handlers bound, ∀i≠j. P_i ≠ P_j, ∀i. ρ_i ⊆ ρ_q), extends the ambient
 *  require row with the injected caps, shadows generic-cap call-site schemes
 *  with their concrete handler instantiations, types the body, and closes the
 *  block scope. Returns the body's trailing-value type as `typ`; a
 *  statement-position inject (which reaches the inject expression via
 *  HirStmtKind::Expr) discards it, a value-position inject surfaces it. */
export let infer_inject_body = fn (
  state: CheckState,
  handlers: [ string ],
  body: [ HirStmt ],
  ret_type: TypeExpr,
  span: Span,
  infer_stmts_fn: (
    state: CheckState,
    stmts: [ HirStmt ],
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  match check_handlers_bound(state, handlers, span) do
    | InferExprErr(message: m, span: esp) -> return InferExprErr(message: m, span: esp)
    | InferExprOk(_) ->
      check_inject_uniqueness(state, handlers, seen: [], span)
      let ambient_req = tctypes.state_require_row(state)
      check_inject_require_subset(state, handlers, ambient: ambient_req, span)
      let body_req = extend_require_row(state, handlers, ambient: ambient_req)
      let body_state0 = tctypes.state_with_require_row(state, require_row: body_req)
      let shadowed_env = apply_injected_handler_instances(
        env: tctypes.state_env(state: body_state0), handler_names: handlers)
      let body_state = tctypes.state_with_env(state: body_state0, env: shadowed_env)
      match infer_stmts_fn(state: body_state, stmts: body, ret_type) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
        | InferExprOk(state: st1, subst: s1, typ: t) ->
          let st2 = tctypes.state_with_env(state: st1, env: tctypes.state_env(state))
          return InferExprOk(state: st2, subst: s1, typ: t)
      end
  end
end

/** Expression-form inject: type as the body's trailing-value type. Reuses the
 *  shared T-Inject body typing; the returned `typ` is the inject expression's
 *  type (usable in `let x = inject …`, `return inject …`, argument position). */
export let infer_inject_expr = fn (
  state: CheckState,
  handlers: [ string ],
  body: [ HirStmt ],
  ret_type: TypeExpr,
  span: Span,
  infer_stmts_fn: (
    state: CheckState,
    stmts: [ HirStmt ],
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  return infer_inject_body(state, handlers, body, ret_type, span, infer_stmts_fn)
end

export let infer_let_impl = fn (
  state: CheckState, name: string, sigil: Sigil, ann: Option<TypeExpr>, value: HirExpr, ret_type: TypeExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError },
  infer_binop_fn: (
    state: CheckState,
    left: HirExpr,
    op: BinaryOp,
    right: HirExpr,
    span: Span,
    expected: Option<TypeExpr>
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  let HirExpr(node: val_node, span: val_span) = value
  match val_node do
    | Borrow(name: target, sigil: _) ->
      match tctypes.env_lookup(env: tctypes.state_env(state), name: target) do
        | Some(val: Scheme(vars: _, typ: tgt_t)) ->
          match tgt_t do
            | TyLinear(_) ->
              return InferExprErr(
                message: "let " ++ name ++ ": cannot borrow '" ++ target ++ "' at let-rhs position: binding is linear (q = 1); T-Borrow requires the target to be ^ω. Borrowing a linear binding is only permitted in argument position (e.g. `f(p: &" ++ target ++ ")`), where T-App discharges the borrow on return. See spec type-system-formal.md §T-Borrow.",
                span
              )
            | TyLazy(_) ->
              return InferExprErr(
                message: "let " ++ name ++ ": cannot borrow '" ++ target ++ "' at let-rhs position: binding is lazy/one-shot (q = 1); T-Borrow requires the target to be ^ω. Borrowing a lazy binding is only permitted in argument position. See spec type-system-formal.md §T-Borrow.",
                span
              )
            | _ -> ()
          end
        | None -> ()
      end
    | _ -> ()
  end
  match val_node do
    | Thunk(body: thunk_body) ->
      match capture.scan_thunk_captures(body: thunk_body, outer_env: tctypes.state_env(state)) do
        | capture.CaptureScan(
          linear: _,
          ref_hit: Some(val: capture.RefCaptureHit(name: rn, span: rsp))
        ) ->
          return InferExprErr(
            message: "thunk captures mutable ref binding " ++ rn ++ " (refs are stack-confined)",
            span: rsp
          )
        | _ -> ()
      end
    | _ -> ()
  end
  match alias_poly_scheme(state, name, sigil, ann, val_node, span) do
    | Some(val: result) -> return result
    | None -> ()
  end
  let st0 = if let Lambda(
    type_params: _,
    params,
    ret_type: ret,
    requires: req,
    throw_row: tw,
    body: _
  ) = val_node then
    let arrow = TyArrow(params: build_param_named_types(params), ret, requires: req, throw_row: tw)
    let env1 = tctypes.env_insert(
      env: tctypes.state_env(state),
      name,
      scheme: tctypes.mono(typ: arrow)
    )
    tctypes.state_with_env(state, env: env1)
  else state end
  let rhs_result = match val_node do
    | BinOp(left: bl, op: bop, right: br) ->
      infer_binop_fn(state: st0, left: bl, op: bop, right: br, span: val_span, expected: ann)
    | _ ->
      infer_expr_fn(state: st0, expr: value, ret_type)
  end
  match rhs_result do
    | InferExprErr(
      message: m,
      span: espan
    ) -> return InferExprErr(message: "let " ++ name ++ ": " ++ m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t1) ->
      let effective_ann = match ann do
        | Some(val: expected) ->
          if let SigilLazy = sigil then
            if let TyLazy(_) = expected then Some(val: expected) else Some(val: TyLazy(inner: expected, require_row: TyRow(types: [], rest: None), throw_row: TyRow(types: [], rest: None))) end
          else Some(val: expected) end
        | None -> None
      end
      let inferred_type = match effective_ann do
        | Some(val: expected) ->
          let tdefs = tctypes.state_typedefs(state: st1)
          match unify.unify(t1, t2: expected, tdefs) do
            | UnifyErr(message: m) ->
              return InferExprErr(message: "let " ++ name ++ ": " ++ m, span)
            | UnifyOk(_) ->
              expected
          end
        | None -> default_numeric_literals(typ: t1)
      end
      if let SigilMutable = sigil then
        let tdefs_for_lin = tctypes.state_typedefs(state: st1)
        let lin_kind = let_mut_linear_kind(typ: inferred_type, tdefs: tdefs_for_lin)
        match lin_kind do
          | LetMutLinearBare ->
            return InferExprErr(
              message: "let ~" ++ name ++ ": mutable-ref binding cannot hold linear value of type `" ++ tctypes.type_to_string(typ: inferred_type) ++ "` (T-Let premise: μ = ~ ⟹ ¬linear(τ'))",
              span
            )
          | LetMutLinearLazy ->
            return InferExprErr(
              message: "let ~" ++ name ++ ": mutable-ref binding cannot hold linear (one-shot) value of type `" ++ tctypes.type_to_string(typ: inferred_type) ++ "` (T-Let premise: μ = ~ ⟹ ¬linear(τ'))",
              span
            )
          | LetMutLinearStructural ->
            return InferExprErr(
              message: "let ~" ++ name ++ ": mutable-ref binding cannot hold value of type `" ++ tctypes.type_to_string(typ: inferred_type) ++ "` because it transitively carries a linear (%T / @T) component (T-Let premise: μ = ~ ⟹ ¬linear(τ');)",
              span
            )
          | LetMutOk -> ()
        end
      end
      let final_type = match sigil do
        | SigilMutable -> wrap_ref(typ: inferred_type)
        | SigilLinear ->
          match inferred_type do
            | TyLinear(_) -> inferred_type
            | _ -> TyLinear(inner: inferred_type)
          end
        | SigilLazy ->
          match inferred_type do
            | TyLazy(_) -> inferred_type
            | _ -> TyLazy(
              inner: inferred_type,
              require_row: TyRow(types: [], rest: None),
              throw_row: TyRow(types: [], rest: None)
            )
          end
        | _ -> inferred_type
      end
      let env2 = tctypes.env_insert(
        env: subst.subst_apply_env(subst: s1, env: tctypes.state_env(state: st1)),
        name, scheme: tctypes.mono(typ: final_type)
      )
      return InferExprOk(
        state: tctypes.state_with_env(state: st1, env: env2),
        subst: s1,
        typ: TyUnit
      )
  end
end

export let infer_return_impl = fn (
  state: CheckState, expr: HirExpr, ret_type: TypeExpr, span: Span,
  infer_expr_fn: (
    state: CheckState,
    expr: HirExpr,
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError },
  infer_binop_fn: (
    state: CheckState,
    left: HirExpr,
    op: BinaryOp,
    right: HirExpr,
    span: Span,
    expected: Option<TypeExpr>
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  let HirExpr(node: expr_node, span: expr_span) = expr
  let infer_result = match expr_node do
    | BinOp(left: bl, op: bop, right: br) ->
      infer_binop_fn(
        state,
        left: bl,
        op: bop,
        right: br,
        span: expr_span,
        expected: Some(val: ret_type)
      )
    | _ ->
      infer_expr_fn(state, expr, ret_type)
  end
  match infer_result do
    | InferExprErr(
      message: m,
      span: espan
    ) -> return InferExprErr(message: "return: " ++ m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t1) ->
      tcwf.enforce_no_escapes_ref(typ: t1, context: "return statement", span, borrow_escapes: false)
      let expected = subst.subst_apply(subst: s1, typ: ret_type)
      let tdefs = tctypes.state_typedefs(state: st1)
      let unify_result = match unify.unify(t1, t2: expected, tdefs) do
        | UnifyOk(subst: s2) -> UnifyOk(subst: s2)
        | UnifyErr(message: m) ->
          match expected do
            | TyLinear(inner: pinner) ->
              match unify.unify(t1, t2: pinner, tdefs) do
                | UnifyOk(subst: s2) -> UnifyOk(subst: s2)
                | UnifyErr(_) -> UnifyErr(message: m)
              end
            | TyLazy(inner: pinner, require_row: _, throw_row: _) ->
              match unify.unify(t1, t2: pinner, tdefs) do
                | UnifyOk(subst: s2) -> UnifyOk(subst: s2)
                | UnifyErr(_) -> UnifyErr(message: m)
              end
            | _ ->
              match t1 do
                | TyArrow(params: [], ret: tinner, requires: _, throw_row: _) ->
                  match unify.unify(t1: tinner, t2: expected, tdefs) do
                    | UnifyOk(subst: s2) -> UnifyOk(subst: s2)
                    | UnifyErr(_) -> UnifyErr(message: m)
                  end
                | _ -> UnifyErr(message: m)
              end
          end
      end
      match unify_result do
        | UnifyErr(message: m) -> return InferExprErr(message: "return type mismatch: " ++ m, span)
        | UnifyOk(subst: s2) ->
          let FreshResult(state: st2, typ: tv) = tctypes.tc_fresh_var(state: st1)
          return InferExprOk(state: st2, subst: subst.subst_compose(s1, s2), typ: tv)
      end
  end
end

export let infer_try_impl = fn (
  state: CheckState, body: [ HirStmt ], catch_param: string, catch_body: [ HirStmt ], ret_type: TypeExpr, span: Span,
  infer_stmts_fn: (
    state: CheckState,
    stmts: [ HirStmt ],
    ret_type: TypeExpr
  ) -> InferExprResult throws { TypeError }
) -> InferExprResult throws { TypeError } do
  let outer_row = tctypes.state_throw_row(state)
  let is_catch_all = catch_is_catch_all(catch_param, catch_body)
  let body_throw_row = if is_catch_all then
    TyRow(types: [], rest: Some(val: outer_row))
  else
    let caught_types = collect_caught_types(catch_param, catch_body)
    build_try_body_row(outer_row, caught_types)
  end
  let body_state = tctypes.state_with_throw_row(state, throw_row: body_throw_row)
  match infer_stmts_fn(state: body_state, stmts: body, ret_type) do
    | InferExprErr(
      message: m,
      span: espan
    ) -> return InferExprErr(message: "try body: " ++ m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: _) ->
      let st1r = tctypes.state_with_throw_row(state: st1, throw_row: outer_row)
      let row_for_param = subst.subst_apply(subst: s1, typ: body_throw_row)
      let param_ty = catch_param_type_from_row(row: row_for_param)
      let catch_env = tctypes.env_insert(
        env: tctypes.state_env(state: st1r),
        name: catch_param,
        scheme: tctypes.mono(typ: param_ty)
      )
      let st2 = tctypes.state_with_env(state: st1r, env: catch_env)
      match infer_stmts_fn(state: st2, stmts: catch_body, ret_type) do
        | InferExprErr(
          message: m,
          span: espan
        ) -> return InferExprErr(message: "catch: " ++ m, span: espan)
        | InferExprOk(state: st3, subst: s2, typ: _) ->
          let st4 = tctypes.state_with_env(state: st3, env: tctypes.state_env(state))
          return InferExprOk(state: st4, subst: subst.subst_compose(s1, s2), typ: TyUnit)
      end
  end
end
