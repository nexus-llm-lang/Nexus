/**
 * typecheck/infer/operators: binary / unary operator post-processing.
 *
 * Holds the parts of binop / unop inference that don't recurse into
 * infer_expr — operand-type resolution (`resolve_binop_types`),
 * type-driven unification helpers (`unify_int_binop`, `unify_float_binop`,
 * `unify_cmp_binop`, `unify_float_cmp`, `unify_bool_binop`), the
 * `comparable(τ)` predicate guarding equality / ordering, and the
 * numeric defaulting helpers `select_int_type` / `select_float_type`.
 *
 * The outer `infer_binop` / `infer_unop` wrappers stay in src/typecheck/infer.nx
 * because they call back into infer_expr to type the operands.
 *
 * Extracted from src/typecheck/infer.nx (nexus-95iz.8).
 */

import { Span } from "src/common/token.nx"
import {
  TypeExpr, TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit, TyUserDefined, TyVar, TyList, TyRecord,
  BinaryOp, OpAdd, OpSub, OpMul, OpDiv, OpMod,
  OpFAdd, OpFSub, OpFMul, OpFDiv,
  OpEq, OpNe, OpLt, OpLe, OpGt, OpGe,
  OpFEq, OpFNe, OpFLt, OpFLe, OpFGt, OpFGe,
  OpBitAnd, OpBitOr, OpBitXor, OpShl, OpShr,
  OpAnd, OpOr, OpConcat,
  NamedType, RecordDef
} from "src/common/ast.nx"
import {
  SubstEntry, CheckState,
  InferExprResult, InferExprOk, InferExprErr,
  UnifyOk, UnifyErr,
  TypeDefEntry
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as unify from "src/typecheck/unify.nx"
import { TypeError } from "src/common/error.nx"
import { Option, Some, None } from "std:option"

// ─── Numeric type selection ─────────────────────────────────────────────────
//
// select_int_type / select_float_type: HM numeric literal defaulting site.
//
// Both operands reaching here are already numeric-flex (TyIntLit / TyFloatLit)
// or concrete (TyI32/TyI64 / TyF32/TyF64). When both are flex, no context
// has constrained the width, so we commit to the principal type (TyI64 / TyF64)
// — the same default the rest of HM applies to unresolved integer / float
// literals. This is an intentional commit, not a silent failure: the alternative
// (emit a fresh var and defer) would just leak TyIntLit up the expression tree
// until some outer site had to pick the same default anyway.
/** Pick the concrete integer operand type for a binary int op: prefer an already-concrete TyI32/TyI64 from either side, else default to TyI64 (HM literal defaulting site). */
export let select_int_type = fn (a: TypeExpr, b: TypeExpr) -> TypeExpr throws { TypeError } do
  match a do
    | TyI32 -> return TyI32
    | TyI64 -> return TyI64
    | _ -> ()
  end
  match b do
    | TyI32 -> return TyI32
    | TyI64 -> return TyI64
    | _ -> ()
  end
  return TyI64
end

/** Pick the concrete float operand type for a binary float op: prefer an already-concrete TyF32/TyF64 from either side, else default to TyF64. */
export let select_float_type = fn (a: TypeExpr, b: TypeExpr) -> TypeExpr throws { TypeError } do
  match a do
    | TyF32 -> return TyF32
    | TyF64 -> return TyF64
    | _ -> ()
  end
  match b do
    | TyF32 -> return TyF32
    | TyF64 -> return TyF64
    | _ -> ()
  end
  return TyF64
end

// ─── comparable(τ) — T-Cmp side-condition (spec type-system-formal.md) ────────
//
// Recursive predicate guarding ==, !=, <, <=, >, >=. Accepts base scalars,
// records and lists whose elements are themselves comparable, and named
// (record-typedef) types via tdef expansion. Rejects arrows, handlers, refs,
// borrows, lazy/thunk wrappers, arrays, and linear values — categories whose
// runtime equality is undefined per spec.
//
// Free type variables (TyVar) — both rigid quantifier and unification vars —
// return false per spec § T-Cmp (line 897 of type-system-formal.md): the
// quantifier-bound `α` lacks a comparability bound, and an unresolved `?α`
// must commit to a comparable type before the check can succeed. Previously
// the impl returned true here as a "deferred" pass-through, but no later
// pipeline stage re-runs the check at instantiation sites, so the pass-through
// was unsound (nexus-t9cl.11). Code that meant to compare a polymorphic value
// must constrain T to a concrete comparable type at the use-site.
//
// Unknown TyUserDefined names (no matching record typedef) return false:
// they are either enums (handled by a follow-up that expands sum bodies per
// nexus-t9cl.6) or opaque imports whose equality is not defined externally.
// Returning false matches the spec's `unfold(x⟨σ̄⟩) = opaque ⇒ false` arm and
// avoids silently accepting incomparable values (nexus-t9cl.11).

let comparable_named_type_list = fn (nts: [NamedType], tdefs: [TypeDefEntry]) -> bool do
  match nts do
    | [] -> return true
    | NamedType(name: _, typ: t) :: rest ->
      if comparable(typ: t, tdefs) then
        return comparable_named_type_list(nts: rest, tdefs)
      end
      return false
  end
end

let comparable = fn (typ: TypeExpr, tdefs: [TypeDefEntry]) -> bool do
  match typ do
    | TyI32 | TyI64 | TyF32 | TyF64
    | TyBool | TyChar | TyString | TyUnit
    | TyIntLit | TyFloatLit -> return true
    | TyVar(_) -> return false
    | TyRecord(fields: fs) -> return comparable_named_type_list(nts: fs, tdefs)
    | TyList(elem: e) -> return comparable(typ: e, tdefs)
    | TyUserDefined(name: n, args: _) ->
      // Expand record typedef when known. Unknown names (enums, opaque imports)
      // return false: the spec's unfold arm for an opaque body yields false, and
      // sum-body unfolding is the follow-up tracked by nexus-t9cl.6.
      match tctypes.typedef_lookup(defs: tdefs, name: n) do
        | Some(val: RecordDef(fields: fs, _)) ->
          return comparable_named_type_list(nts: fs, tdefs)
        | None -> return false
      end
    | _ -> return false
  end
end

let comparable_reject_msg = fn (typ: TypeExpr) -> string do
  return "cannot compare values of type `" ++ tctypes.type_to_string(typ) ++ "`: comparison undefined for arrows / handlers / refs / borrows / thunks / arrays"
end

// ─── Type-driven binop unifiers ─────────────────────────────────────────────

let unify_int_binop = fn (state: CheckState, subst: [SubstEntry], lt: TypeExpr, rt: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  let target = select_int_type(a: lt, b: rt)
  let tdefs = tctypes.state_typedefs(state)
  match unify.unify(t1: lt, t2: target, tdefs) do
    | UnifyErr(message: m) -> return InferExprErr(message: "int op lhs: " ++ m, span)
    | UnifyOk(subst: s1) ->
      let sm = subst.subst_compose(s1: subst, s2: s1)
      match unify.unify(t1: subst.subst_apply(subst: sm, typ: rt), t2: target, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(message: "int op rhs: " ++ m, span)
        | UnifyOk(subst: s2) ->
          return InferExprOk(state, subst: subst.subst_compose(s1: sm, s2), typ: target)
      end
  end
end

let unify_float_binop = fn (state: CheckState, subst: [SubstEntry], lt: TypeExpr, rt: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  let target = select_float_type(a: lt, b: rt)
  let tdefs = tctypes.state_typedefs(state)
  match unify.unify(t1: lt, t2: target, tdefs) do
    | UnifyErr(message: m) -> return InferExprErr(message: "float op lhs: " ++ m, span)
    | UnifyOk(subst: s1) ->
      let sm = subst.subst_compose(s1: subst, s2: s1)
      match unify.unify(t1: subst.subst_apply(subst: sm, typ: rt), t2: target, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(message: "float op rhs: " ++ m, span)
        | UnifyOk(subst: s2) ->
          return InferExprOk(state, subst: subst.subst_compose(s1: sm, s2), typ: target)
      end
  end
end

let unify_cmp_binop = fn (state: CheckState, subst: [SubstEntry], lt: TypeExpr, rt: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  let tdefs = tctypes.state_typedefs(state)
  match unify.unify(t1: lt, t2: rt, tdefs) do
    | UnifyErr(message: m) -> return InferExprErr(message: "comparison: " ++ m, span)
    | UnifyOk(subst: s1) ->
      let sm = subst.subst_compose(s1: subst, s2: s1)
      let resolved = subst.subst_apply(subst: sm, typ: lt)
      if comparable(typ: resolved, tdefs) then
        return InferExprOk(state, subst: sm, typ: TyBool)
      end
      return InferExprErr(message: comparable_reject_msg(typ: resolved), span)
  end
end

let unify_float_cmp = fn (state: CheckState, subst: [SubstEntry], lt: TypeExpr, rt: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  let tdefs = tctypes.state_typedefs(state)
  let target = select_float_type(a: lt, b: rt)
  match unify.unify(t1: lt, t2: target, tdefs) do
    | UnifyErr(message: m) -> return InferExprErr(message: "float cmp lhs: " ++ m, span)
    | UnifyOk(subst: s1) ->
      let sm = subst.subst_compose(s1: subst, s2: s1)
      match unify.unify(t1: subst.subst_apply(subst: sm, typ: rt), t2: target, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(message: "float cmp rhs: " ++ m, span)
        | UnifyOk(subst: s2) ->
          let sm2 = subst.subst_compose(s1: sm, s2)
          let resolved = subst.subst_apply(subst: sm2, typ: target)
          if comparable(typ: resolved, tdefs) then
            return InferExprOk(state, subst: sm2, typ: TyBool)
          end
          return InferExprErr(message: comparable_reject_msg(typ: resolved), span)
      end
  end
end

let unify_bool_binop = fn (state: CheckState, subst: [SubstEntry], lt: TypeExpr, rt: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  let tdefs = tctypes.state_typedefs(state)
  match unify.unify(t1: lt, t2: TyBool, tdefs) do
    | UnifyErr(message: m) -> return InferExprErr(message: "logical lhs: " ++ m, span)
    | UnifyOk(subst: s1) ->
      let sm = subst.subst_compose(s1: subst, s2: s1)
      match unify.unify(t1: subst.subst_apply(subst: sm, typ: rt), t2: TyBool, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(message: "logical rhs: " ++ m, span)
        | UnifyOk(subst: s2) ->
          return InferExprOk(state, subst: subst.subst_compose(s1: sm, s2), typ: TyBool)
      end
  end
end

// ─── Binop dispatch ─────────────────────────────────────────────────────────

/** Dispatch a binary op `op` over operand types `lt`/`rt` to its specialised unifier (int / float / cmp / bool / concat) and return the result type plus accumulated substitution. */
export let resolve_binop_types = fn (state: CheckState, subst: [SubstEntry], op: BinaryOp, lt: TypeExpr, rt: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  match op do
    // Integer arithmetic -> result is integer type
    | OpAdd | OpSub | OpMul | OpDiv | OpMod
    | OpBitAnd | OpBitOr | OpBitXor | OpShl | OpShr ->
      return unify_int_binop(state, subst, lt, rt, span)
    // Float arithmetic
    | OpFAdd | OpFSub | OpFMul | OpFDiv ->
      return unify_float_binop(state, subst, lt, rt, span)
    // Integer comparisons -> bool
    | OpEq | OpNe | OpLt | OpLe | OpGt | OpGe ->
      return unify_cmp_binop(state, subst, lt, rt, span)
    // Float comparisons -> bool
    | OpFEq | OpFNe | OpFLt | OpFLe | OpFGt | OpFGe ->
      return unify_float_cmp(state, subst, lt, rt, span)
    // Logical -> bool
    | OpAnd | OpOr ->
      return unify_bool_binop(state, subst, lt, rt, span)
    // String concat
    | OpConcat ->
      let tdefs = tctypes.state_typedefs(state)
      match unify.unify(t1: lt, t2: TyString, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(message: "concat lhs: " ++ m, span)
        | UnifyOk(subst: s1) ->
          let s_merged = subst.subst_compose(s1: subst, s2: s1)
          match unify.unify(t1: subst.subst_apply(subst: s_merged, typ: rt), t2: TyString, tdefs) do
            | UnifyErr(message: m) -> return InferExprErr(message: "concat rhs: " ++ m, span)
            | UnifyOk(subst: s2) ->
              return InferExprOk(state, subst: subst.subst_compose(s1: s_merged, s2), typ: TyString)
          end
      end
  end
end
