/**
 * typecheck/linearity: %T linear-binding lint pass for self-host.
 *
 * Standalone post-typecheck HIR pass. Walks each function body once,
 * threading a `LinState` that tracks:
 *
 *   - `vars`: currently-live linear bindings (names) in the active frame.
 *   - `frame_stack`: snapshots of `vars` taken at each enclosing frame
 *     boundary (function-body entry or `try`-body entry). Linears that
 *     existed at the most recent boundary are excluded from the
 *     throwable-call leak check — they are the catch arm's responsibility
 *     (Strategy A, nexus-7eex.1) or the call-site contract's responsibility
 *     for function-param linears (nexus-7eex.2).
 *
 * Lints implemented (issue nexus-7eex.3):
 *   1. let-bound %T use-once: a linear binding must be referenced exactly
 *      once in its scope. Zero refs → LinearUnused; second ref → LinearReuse.
 *   5. Function-param %T use-once: a parameter typed `%T` must be consumed
 *      exactly once in the body. Same Unused/Reuse signaling.
 *   3. if/match branch consistency: every non-diverging arm must end with
 *      the same `vars` set.
 *   6. Throwable-call leak: a `Call` at statement level whose callee has a
 *      non-empty throws row must not leave any uncovered linear live (issue
 *      nexus-7eex.2). The Strategy A try/catch interaction (nexus-7eex.1)
 *      flows naturally from the frame_stack push at try-body entry.
 *
 * Lints deferred (follow-up nexus-7eex.4 candidate):
 *   2. Lambda-capture linearization: already present in `src/typecheck/
 *      capture.nx` (T-Lambda's CaptureScan). The closure-typing form there
 *      already wraps the lambda type in TyLinear when a capture is linear.
 *      This pass does not duplicate that.
 *   4. Array-element move-out rejection: requires per-Index typing in
 *      infer.nx (the structural HIR walk here cannot recover the element
 *      type without re-inferring). Tracked separately.
 *
 * Linearity detection on bindings:
 *   - `let %x = ...` — sigil is SigilLinear (carried on HirStmt.Let).
 *   - `let x: %T = ...` — type annotation is TyLinear / TyLazy / TyArray.
 *   - `let x = call_returning_linear()` — sig-map lookup of the callee's
 *     return type recovers the linear classification when no annotation
 *     was provided.
 *   - Function param `(x: %T)` — same classifier on the param type.
 *   - Pattern bindings under match — `%v` patterns and patterns whose
 *     binders draw from a linear scrutinee are handled by `bind_pattern`.
 */

import { Span } from "src/common/token.nx"
import {
  TypeExpr, TyLinear, TyLazy, TyArray, TyBorrow, TyRef, TyUserDefined,
  TyRow, TyVar, TyList, TyRecord,
  NamedType, RecordDef,
  Sigil, SigilLinear, SigilLazy, SigilImmutable, SigilMutable, SigilBorrow
} from "src/common/ast.nx"
import {
  HirProgram, HirFunction, HirHandlerArm, HirHandlerBindingEntry,
  HirHandlerBinding, EagerBody, LazyBody, HirStmt, HirStmtKind,
  HirExpr, HirExprKind, HirCallArg, HirNamedExpr, HirMatchCase, HirParam,
  HirExternal, HirPatternKind, HirPatternField, HirRecordPatField
} from "src/ir/hir/types.nx"
import {
  TypeError,
  LinearUnused, LinearMismatch, LinearLeakAcrossThrowableCall
} from "src/common/error.nx"
import { Option, Some, None } from "std:option"

// ─── Sig-map: name → callable signature ──────────────────────────────────────

/** One callable signature in the linearity pass's sig-map: name + parameter types + return type + declared throws row (used to detect linear-leak-across-throwable-call). */
export type SigEntry = SigEntry(
  name: string,
  param_types: [TypeExpr],
  ret_type: TypeExpr,
  throw_row: TypeExpr
)

let build_sig_map = fn (prog: HirProgram) -> [SigEntry] do
  match prog do
    | HirProgram(ports: _, functions: fs, externals: exs, handler_bindings: hbs, enum_defs: _, exception_groups: _, _) ->
      let sigs = sigs_from_functions(funcs: fs, acc: [])
      let sigs2 = sigs_from_externals(exts: exs, acc: sigs)
      return sigs_from_handler_bindings(bindings: hbs, acc: sigs2)
  end
end

let sigs_from_functions = fn (funcs: [HirFunction], acc: [SigEntry]) -> [SigEntry] do
  match funcs do
    | [] -> return acc
    | HirFunction(name: n, type_params: _, params: ps, ret_type: rt, throw_row: tw, _) :: rest ->
      let pts = param_types(params: ps, acc: [])
      return sigs_from_functions(funcs: rest, acc: SigEntry(name: n, param_types: pts, ret_type: rt, throw_row: tw) :: acc)
  end
end

let sigs_from_externals = fn (exts: [HirExternal], acc: [SigEntry]) -> [SigEntry] do
  match exts do
    | [] -> return acc
    | HirExternal(name: n, wasm_module: _, wasm_name: _, type_params: _, params: ps, ret_type: rt, throw_row: tw) :: rest ->
      let pts = param_types(params: ps, acc: [])
      return sigs_from_externals(exts: rest, acc: SigEntry(name: n, param_types: pts, ret_type: rt, throw_row: tw) :: acc)
  end
end

let sigs_from_handler_bindings = fn (bindings: [HirHandlerBindingEntry], acc: [SigEntry]) -> [SigEntry] do
  match bindings do
    | [] -> return acc
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, arms)) :: rest ->
      let acc2 = sigs_from_handler_arms(arms, acc)
      return sigs_from_handler_bindings(bindings: rest, acc: acc2)
  end
end

let sigs_from_handler_arms = fn (arms: [HirHandlerArm], acc: [SigEntry]) -> [SigEntry] do
  match arms do
    | [] -> return acc
    | HirHandlerArm(arm: HirFunction(name: n, type_params: _, params: ps, ret_type: rt, throw_row: tw, _), cont_binder: _) :: rest ->
      let pts = param_types(params: ps, acc: [])
      return sigs_from_handler_arms(arms: rest, acc: SigEntry(name: n, param_types: pts, ret_type: rt, throw_row: tw) :: acc)
  end
end

let param_types = fn (params: [HirParam], acc: [TypeExpr]) -> [TypeExpr] do
  match params do
    | [] -> return rev_type_list(lst: acc, out: [])
    | HirParam(label: _, name: _, sigil: _, typ: t) :: rest -> return param_types(params: rest, acc: t :: acc)
  end
end

let rev_type_list = fn (lst: [TypeExpr], out: [TypeExpr]) -> [TypeExpr] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_type_list(lst: rest, out: x :: out)
  end
end

let sig_lookup = fn (sigs: [SigEntry], name: string) -> Option<SigEntry> do
  match sigs do
    | [] -> return None
    | SigEntry(name: n, param_types: pts, ret_type: rt, throw_row: tw) :: rest ->
      if n == name then return Some(val: SigEntry(name: n, param_types: pts, ret_type: rt, throw_row: tw)) end
      return sig_lookup(sigs: rest, name)
  end
end

// ─── Linearity classification on TypeExpr ────────────────────────────────────

/** True when `t` is "auto-droppable". Per spec type-system-formal.md
 *  §autoDrop (and semantics.md §3.1) only the primitive scalar types and
 *  `string`/`unit` auto-drop at scope end; composites must be explicitly
 *  consumed. The wrappers `%`/`&`/`~` peel and recurse into the inner type
 *  (these wrappers do not change auto-droppability of the underlying value).
 *
 *  Note (nexus-t9cl.10): `@T` (TyLazy) is explicitly NOT auto-droppable —
 *  forcing it triggers side effects; dropping silently would lose them.
 *  The spec `autoDrop` definition strips `%`/`&`/`~` but treats `@`
 *  pessimistically; this impl matches that intent.
 *
 *  Note (nexus-t9cl.10): arrays `[|σ|]` are NOT auto-droppable here either.
 *  Although spec t9cl.2/.3 wording mentions array inclusion, the per-binding
 *  lint treats arrays as composites: an unconsumed array binding raises
 *  LinearUnused so the user explicitly drops it. Module-level "structurally
 *  contains linear" probes go through `is_linear_binding_type` instead.
 */
let is_auto_droppable = fn (t: TypeExpr) -> bool do
  match t do
    | TyI32 | TyI64 | TyF32 | TyF64
    | TyIntLit | TyFloatLit
    | TyBool | TyChar | TyString | TyUnit -> return true
    | TyLazy(_) -> return false
    | TyLinear(inner: i) | TyBorrow(inner: i) | TyRef(inner: i) -> return is_auto_droppable(t: i)
    | _ -> return false
  end
end

/** True when `t` carries linearity that must be tracked: `%T` (Linear), `@T`
 *  (Lazy — one-shot continuation). Per spec type-system-formal.md §Linearity
 *  "Linearity is entirely structural" (nexus-t9cl.12), so we recurse through
 *  `~τ` (TyRef) / `&τ` (TyBorrow) wrappers, `TyRecord` field lists, and
 *  `TyUserDefined` record-typedef field lists. The per-binding lint
 *  deliberately ignores array containment — arrays of plain values are
 *  auto-droppable — so `TyArray` is not traversed here.
 *
 *  Cycle handling (nexus-t9cl.16) — spec type-system-formal.md §Linearity
 *  lines 365-381 define the predicate as a least fixpoint with a visited
 *  set V threaded through:
 *    linear'(x⟨σ̄⟩, V) = false                                 if x ∈ V        (line 372: cycle case)
 *                     = ⋁_{F ∈ unfold(x⟨σ̄⟩)} linear'(F, V ∪ {x})  otherwise (line 373)
 *  Only nominal type lookup adds to V (line 373's `V ∪ {x}`); all other
 *  clauses thread V unchanged (spec line 376 "thread V unchanged"). The
 *  prior implementation capped recursion at depth=8 — a fuel counter,
 *  which spec line 381 explicitly contrasts with the visited-set memo
 *  table. Fuel caused false negatives at non-cyclic depth ≥ 9 because
 *  every wrapper-step decremented the counter; visited-set only counts
 *  *named* unfolds, so deeply-nested-but-finite chains traverse to
 *  completion.
 */
let is_linear_binding_type = fn (t: TypeExpr, tdefs: [RecordDef]) -> bool do
  return is_linear_binding_type_visited(t, tdefs, visited: [])
end

let is_linear_binding_type_visited = fn (t: TypeExpr, tdefs: [RecordDef], visited: [string]) -> bool do
  match t do
    // Spec line 350: %σ, @σ are linear by the outermost-wrapper clause.
    | TyLinear(inner: _) | TyLazy(inner: _) -> return true
    // Spec line 376: wrapper-step threads V unchanged (no nominal unfold here).
    | TyRef(inner: i) | TyBorrow(inner: i) -> return is_linear_binding_type_visited(t: i, tdefs, visited)
    | TyList(elem: e) -> return is_linear_binding_type_visited(t: e, tdefs, visited)
    | TyRecord(fields: fs) -> return any_named_type_linear(fields: fs, tdefs, visited)
    | TyUserDefined(name: n, args: _) ->
      // Spec line 372: x ∈ V → false (minimum fixpoint base case).
      if str_member(xs: visited, target: n) then return false end
      match lin_typedef_lookup(defs: tdefs, name: n) do
        | Some(val: RecordDef(name: _, is_public: _, type_params: _, fields: rec_fields)) ->
          // Spec line 373: recurse into unfolded body with V ∪ {x}.
          return any_named_type_linear(fields: rec_fields, tdefs, visited: n :: visited)
        | None -> return false
      end
    | _ -> return false
  end
end

let any_named_type_linear = fn (fields: [NamedType], tdefs: [RecordDef], visited: [string]) -> bool do
  match fields do
    | [] -> return false
    | NamedType(name: _, typ: ft) :: rest ->
      if is_linear_binding_type_visited(t: ft, tdefs, visited) then return true end
      return any_named_type_linear(fields: rest, tdefs, visited)
  end
end

let lin_typedef_lookup = fn (defs: [RecordDef], name: string) -> Option<RecordDef> do
  match defs do
    | [] -> return None
    | RecordDef(name: n, is_public: ip, type_params: tp, fields: f) :: rest ->
      if n == name then return Some(val: RecordDef(name: n, is_public: ip, type_params: tp, fields: f)) end
      return lin_typedef_lookup(defs: rest, name)
  end
end

// ─── Linearity state ─────────────────────────────────────────────────────────

/** One snapshot of `vars` at a frame boundary. Wraps a `[string]` so the
 *  surrounding LinState can carry a list of these without nesting list-of-
 *  list type syntax (Nexus requires a nominal type for nested generics).
 */
export type LinFrame = LinFrame(vars: [string])

/** Live linear bindings + enclosing frame snapshots. `frame_stack` is a
 *  stack of `vars` snapshots at function-body entry and `try`-body entry.
 *  The top is the "covered" set for the throwable-call leak check.
 */
export type LinState = LinState(vars: [string], frame_stack: [LinFrame])

let lin_empty = fn () -> LinState do
  return LinState(vars: [], frame_stack: [])
end

let lin_add = fn (st: LinState, name: string) -> LinState do
  let LinState(vars: vs, frame_stack: fs) = st
  return LinState(vars: name :: vs, frame_stack: fs)
end

let lin_remove = fn (st: LinState, name: string) -> LinState do
  let LinState(vars: vs, frame_stack: fs) = st
  return LinState(vars: remove_one(xs: vs, target: name), frame_stack: fs)
end

let remove_one = fn (xs: [string], target: string) -> [string] do
  match xs do
    | [] -> return []
    | x :: rest ->
      if x == target then return rest end
      return x :: remove_one(xs: rest, target)
  end
end

let lin_member = fn (st: LinState, name: string) -> bool do
  let LinState(vars: vs, frame_stack: _) = st
  return str_member(xs: vs, target: name)
end

let str_member = fn (xs: [string], target: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == target then return true end
      return str_member(xs: rest, target)
  end
end

/** Set equality of two linear-var sets — order-insensitive. */
let vars_equal = fn (a: [string], b: [string]) -> bool do
  if length(xs: a) != length(xs: b) then return false end
  return all_in(needles: a, haystack: b) && all_in(needles: b, haystack: a)
end

let length = fn (xs: [string]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + length(xs: rest)
  end
end

let all_in = fn (needles: [string], haystack: [string]) -> bool do
  match needles do
    | [] -> return true
    | n :: rest ->
      if !str_member(xs: haystack, target: n) then return false end
      return all_in(needles: rest, haystack)
  end
end

let lin_push_frame = fn (st: LinState) -> LinState do
  let LinState(vars: vs, frame_stack: fs) = st
  return LinState(vars: vs, frame_stack: LinFrame(vars: copy(xs: vs)) :: fs)
end

let lin_pop_frame = fn (st: LinState) -> LinState do
  let LinState(vars: vs, frame_stack: fs) = st
  match fs do
    | [] -> return st
    | _ :: rest -> return LinState(vars: vs, frame_stack: rest)
  end
end

let lin_top_frame = fn (st: LinState) -> Option<[string]> do
  let LinState(vars: _, frame_stack: fs) = st
  match fs do
    | [] -> return None
    | LinFrame(vars: top) :: _ -> return Some(val: top)
  end
end

let copy = fn (xs: [string]) -> [string] do
  match xs do
    | [] -> return []
    | x :: rest -> return x :: copy(xs: rest)
  end
end

let join_simple = fn (xs: [string]) -> string do
  match xs do
    | [] -> return "{}"
    | x :: [] -> return "{" ++ x ++ "}"
    | x :: rest -> return "{" ++ x ++ "," ++ join_inner(xs: rest) ++ "}"
  end
end

let join_inner = fn (xs: [string]) -> string do
  match xs do
    | [] -> return ""
    | x :: [] -> return x
    | x :: rest -> return x ++ "," ++ join_inner(xs: rest)
  end
end

let lin_set_vars = fn (st: LinState, vs: [string]) -> LinState do
  let LinState(vars: _, frame_stack: fs) = st
  return LinState(vars: vs, frame_stack: fs)
end

// ─── Lambda-capture consumption ──────────────────────────────────────────────

let collect_param_names = fn (params: [HirParam], acc: [string]) -> [string] do
  match params do
    | [] -> return acc
    | HirParam(label: _, name: n, sigil: _, typ: _) :: rest ->
      return collect_param_names(params: rest, acc: n :: acc)
  end
end

let consume_all = fn (st: LinState, names: [string]) -> LinState do
  match names do
    | [] -> return st
    | n :: rest ->
      let st1 = if lin_member(st, name: n) then lin_remove(st, name: n) else st end
      return consume_all(st: st1, names: rest)
  end
end

/** Walk a lambda body (statements) and collect every outer-linear name
 *  referenced as a free variable inside it. `bound` is the running set of
 *  names introduced by inner binders (lambda params, lets, match patterns,
 *  for/try-catch binders) — references shadowed by these are not captures.
 */
let collect_captured_linears = fn (
  body: [HirStmt], outer_linears: [string], bound: [string], acc: [string]
) -> [string] do
  return cap_scan_stmts(stmts: body, outer: outer_linears, bound, acc)
end

let cap_add_unique = fn (xs: [string], n: string) -> [string] do
  if str_member(xs, target: n) then return xs end
  return n :: xs
end

let cap_scan_stmts = fn (
  stmts: [HirStmt], outer: [string], bound: [string], acc: [string]
) -> [string] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: nd, span: _) :: rest ->
      match nd do
        | Let(name: n, sigil: _, typ: _, value: v) ->
          let acc1 = cap_scan_expr(expr: v, outer, bound, acc)
          return cap_scan_stmts(stmts: rest, outer, bound: n :: bound, acc: acc1)
        | Expr(expr: e) | Return(expr: e) ->
          return cap_scan_stmts(stmts: rest, outer, bound, acc: cap_scan_expr(expr: e, outer, bound, acc))
        | Assign(target: t, value: v) ->
          let acc1 = cap_scan_expr(expr: t, outer, bound, acc)
          let acc2 = cap_scan_expr(expr: v, outer, bound, acc: acc1)
          return cap_scan_stmts(stmts: rest, outer, bound, acc: acc2)
        | Try(body: b, catch_param: cp, catch_body: cb) ->
          let acc1 = cap_scan_stmts(stmts: b, outer, bound, acc)
          let acc2 = cap_scan_stmts(stmts: cb, outer, bound: cp :: bound, acc: acc1)
          return cap_scan_stmts(stmts: rest, outer, bound, acc: acc2)
        | Inject(handlers: _, body: b) ->
          return cap_scan_stmts(stmts: rest, outer, bound, acc: cap_scan_stmts(stmts: b, outer, bound, acc))
      end
  end
end

let cap_scan_expr = fn (
  expr: HirExpr, outer: [string], bound: [string], acc: [string]
) -> [string] do
  let HirExpr(node: nd, span: _) = expr
  match nd do
    | Literal(_) -> return acc
    | Variable(name: n, sigil: _) ->
      if str_member(xs: bound, target: n) then return acc end
      if str_member(xs: outer, target: n) then return cap_add_unique(xs: acc, n) end
      return acc
    | Borrow(name: _, sigil: _) ->
      // Borrow does not consume the binding, so ignore for capture-consumption.
      return acc
    | BinOp(left: l, op: _, right: r) ->
      let acc1 = cap_scan_expr(expr: l, outer, bound, acc)
      return cap_scan_expr(expr: r, outer, bound, acc: acc1)
    | UnOp(op: _, operand: o) -> return cap_scan_expr(expr: o, outer, bound, acc)
    | Call(func: f, args: cargs) ->
      let acc0 = if str_member(xs: bound, target: f) then acc
        else if str_member(xs: outer, target: f) then cap_add_unique(xs: acc, n: f)
        else acc end
      return cap_scan_call_args(args: cargs, outer, bound, acc: acc0)
    | Ctor(variant: _, args: cargs, sigil: _) -> return cap_scan_exprs(exprs: cargs, outer, bound, acc)
    | Record(fields: fs) -> return cap_scan_named(fields: fs, outer, bound, acc)
    | Array(elems: es) -> return cap_scan_exprs(exprs: es, outer, bound, acc)
    | Index(target: t, index: i) ->
      let acc1 = cap_scan_expr(expr: t, outer, bound, acc)
      return cap_scan_expr(expr: i, outer, bound, acc: acc1)
    | FieldAccess(target: t, field: _) -> return cap_scan_expr(expr: t, outer, bound, acc)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let acc1 = cap_scan_expr(expr: c, outer, bound, acc)
      let acc2 = cap_scan_stmts(stmts: tb, outer, bound, acc: acc1)
      match eb do
        | None -> return acc2
        | Some(val: ebs) -> return cap_scan_stmts(stmts: ebs, outer, bound, acc: acc2)
      end
    | Match(target: t, cases: cs) ->
      let acc1 = cap_scan_expr(expr: t, outer, bound, acc)
      return cap_scan_match_cases(cases: cs, outer, bound, acc: acc1)
    | While(cond: c, body: b) ->
      let acc1 = cap_scan_expr(expr: c, outer, bound, acc)
      return cap_scan_stmts(stmts: b, outer, bound, acc: acc1)
    | For(var: v, start: s, end_expr: e, body: b) ->
      let acc1 = cap_scan_expr(expr: s, outer, bound, acc)
      let acc2 = cap_scan_expr(expr: e, outer, bound, acc: acc1)
      return cap_scan_stmts(stmts: b, outer, bound: v :: bound, acc: acc2)
    | Lambda(type_params: _, params: ps, ret_type: _, body: b) ->
      // Inner lambda: its own params shadow within its body, but free
      // references to outer linears still capture-consume.
      let inner_bound = collect_param_names(params: ps, acc: bound)
      return cap_scan_stmts(stmts: b, outer, bound: inner_bound, acc)
    | Raise(expr: e) | Force(expr: e) -> return cap_scan_expr(expr: e, outer, bound, acc)
    | Thunk(body: b) -> return cap_scan_expr(expr: b, outer, bound, acc)
    | ExternalRef(_) | Handler(_) -> return acc
  end
end

let cap_scan_exprs = fn (
  exprs: [HirExpr], outer: [string], bound: [string], acc: [string]
) -> [string] do
  match exprs do
    | [] -> return acc
    | e :: rest ->
      return cap_scan_exprs(exprs: rest, outer, bound, acc: cap_scan_expr(expr: e, outer, bound, acc))
  end
end

let cap_scan_call_args = fn (
  args: [HirCallArg], outer: [string], bound: [string], acc: [string]
) -> [string] do
  match args do
    | [] -> return acc
    | HirCallArg(label: _, value: v) :: rest ->
      return cap_scan_call_args(args: rest, outer, bound, acc: cap_scan_expr(expr: v, outer, bound, acc))
  end
end

let cap_scan_named = fn (
  fields: [HirNamedExpr], outer: [string], bound: [string], acc: [string]
) -> [string] do
  match fields do
    | [] -> return acc
    | HirNamedExpr(name: _, value: v) :: rest ->
      return cap_scan_named(fields: rest, outer, bound, acc: cap_scan_expr(expr: v, outer, bound, acc))
  end
end

let cap_scan_match_cases = fn (
  cases: [HirMatchCase], outer: [string], bound: [string], acc: [string]
) -> [string] do
  match cases do
    | [] -> return acc
    | HirMatchCase(pattern: p, body: bs) :: rest ->
      let pat_bound = cap_pattern_binders(pat: p, acc: bound)
      let acc1 = cap_scan_stmts(stmts: bs, outer, bound: pat_bound, acc)
      return cap_scan_match_cases(cases: rest, outer, bound, acc: acc1)
  end
end

let cap_pattern_binders = fn (pat: HirPatternKind, acc: [string]) -> [string] do
  match pat do
    | PLit(_) | PWild | POr(alts: _) -> return acc
    | PVar(name: n, sigil: _) -> return n :: acc
    | PCtor(variant: _, fields: fs, sigil: _) -> return cap_pattern_field_binders(fields: fs, acc)
    | PRec(fields: fs, is_partial: _) -> return cap_pattern_record_binders(fields: fs, acc)
  end
end

let cap_pattern_field_binders = fn (
  fields: [HirPatternField], acc: [string]
) -> [string] do
  match fields do
    | [] -> return acc
    | HirPatternField(name: _, pattern: p) :: rest ->
      return cap_pattern_field_binders(fields: rest, acc: cap_pattern_binders(pat: p, acc))
  end
end

let cap_pattern_record_binders = fn (
  fields: [HirRecordPatField], acc: [string]
) -> [string] do
  match fields do
    | [] -> return acc
    | HirRecordPatField(name: _, pattern: p) :: rest ->
      return cap_pattern_record_binders(fields: rest, acc: cap_pattern_binders(pat: p, acc))
  end
end

// ─── Sig-map-aware linearity classification ──────────────────────────────────

/** Determine whether the value-RHS of a `let x = expr` would yield a linear
 *  binding. Classification, in priority order:
 *  1. Sigil annotation on the let (`%`/`@`) → linear.
 *  2. Type annotation on the let (`x: %T` / `x: @T`) → linear.
 *  3. Otherwise inspect the value expression: a Call to a function whose
 *  return type is `%T` / `@T` produces a linear binding even when the
 *  user wrote `let x = …` without a sigil.
 */
let let_binds_linear = fn (
  sigil: Sigil, ann: Option<TypeExpr>, value: HirExpr, sigs: [SigEntry], tdefs: [RecordDef]
) -> bool do
  match sigil do
    | SigilLinear | SigilLazy -> return true
    | _ ->
      match ann do
        | Some(val: t) -> if is_linear_binding_type(t, tdefs) then return true end
        | None -> ()
      end
      let HirExpr(node: vnode, span: _) = value
      match vnode do
        | Call(func: f, args: _) ->
          match sig_lookup(sigs, name: f) do
            | Some(val: SigEntry(name: _, param_types: _, ret_type: rt, throw_row: _)) ->
              return is_linear_binding_type(t: rt, tdefs)
            | None -> return false
          end
        | _ -> return false
      end
  end
end

// ─── Throwability classification ────────────────────────────────────────────

/** True when `eff_row` is a non-empty throws row (i.e., the call may raise).
 *  A bare type variable / Unit row is treated as non-throwable: the caller
 *  has not committed to a concrete throws set yet, so the per-call check
 *  at the binder site of an as-yet-unresolved arrow does not fire.
 */
let row_is_throwable = fn (eff_row: TypeExpr) -> bool do
  match eff_row do
    | TyRow(types: ts, rest: _) ->
      match ts do
        | [] -> return false
        | _ :: _ -> return true
      end
    | TyUnit | TyVar(_) | _ -> return false
  end
end

// ─── Entry point ─────────────────────────────────────────────────────────────

/** Run the linearity pass over every function and handler-arm in `prog`: each linear binding consumed exactly once, no leaks across throwable calls. Raises TypeError on the first violation. */
export let check_program = fn (prog: HirProgram) -> unit throws { TypeError } do
  let sigs = build_sig_map(prog)
  match prog do | HirProgram(ports: _, functions: fs, externals: _, handler_bindings: hbs, enum_defs: _, exception_groups: _, value_binding_names: _, type_defs: tdefs) ->
    check_functions(funcs: fs, sigs, tdefs)
    return check_handler_bindings(bindings: hbs, sigs, tdefs)
  end
end

let check_functions = fn (funcs: [HirFunction], sigs: [SigEntry], tdefs: [RecordDef]) -> unit throws { TypeError } do
  match funcs do
    | [] -> return ()
    | f :: rest ->
      check_function(func: f, sigs, tdefs)
      return check_functions(funcs: rest, sigs, tdefs)
  end
end

let check_handler_bindings = fn (
  bindings: [HirHandlerBindingEntry], sigs: [SigEntry], tdefs: [RecordDef]
) -> unit throws { TypeError } do
  match bindings do
    | [] -> return ()
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, arms)) :: rest ->
      check_handler_arms(arms, sigs, tdefs)
      return check_handler_bindings(bindings: rest, sigs, tdefs)
  end
end

let check_handler_arms = fn (arms: [HirHandlerArm], sigs: [SigEntry], tdefs: [RecordDef]) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(arm: f, cont_binder: _) :: rest ->
      check_function(func: f, sigs, tdefs)
      return check_handler_arms(arms: rest, sigs, tdefs)
  end
end

let check_function = fn (func: HirFunction, sigs: [SigEntry], tdefs: [RecordDef]) -> unit throws { TypeError } do
  match func do | HirFunction(name: _, type_params: _, params: ps, ret_type: _, throw_row: _, body: b, span: sp, file: _) ->
    match b do
      | EagerBody(stmts) ->
        // Seed live set with linear params; push frame snapshot so the
        // body's throwable-call check excludes them (call-site contract).
        let initial_vars = collect_linear_params(params: ps, tdefs, acc: [])
        let st0 = lin_set_vars(st: lin_empty(), vs: initial_vars)
        let st1 = lin_push_frame(st: st0)
        let st2 = check_stmts(stmts, st: st1, sigs, tdefs)
        // Function-end consumption check: any linear param or local left
        // live raises Unused.
        return require_empty_or_droppable(
          vars: lin_state_vars(st: st2),
          params: ps,
          span: sp
        )
      | LazyBody(_) -> return ()
    end
  end
end

let lin_state_vars = fn (st: LinState) -> [string] do
  let LinState(vars: vs, frame_stack: _) = st
  return vs
end

/** Param is linear when *either* sigil or type marks it: mirrors
 *  `let_binds_linear` for `let`-bindings. Rejects the silent-discard
 *  where `fn (%x: T)` (sigil-only) was previously dropped by HIR
 *  conversion (issue nexus-djn1).
 */
let param_binds_linear = fn (sig: Sigil, t: TypeExpr, tdefs: [RecordDef]) -> bool do
  match sig do
    | SigilLinear | SigilLazy -> return true
    | _ -> return is_linear_binding_type(t, tdefs)
  end
end

let collect_linear_params = fn (params: [HirParam], tdefs: [RecordDef], acc: [string]) -> [string] do
  match params do
    | [] -> return acc
    | HirParam(label: _, name: n, sigil: s, typ: t) :: rest ->
      if param_binds_linear(sig: s, t, tdefs) then
        return collect_linear_params(params: rest, tdefs, acc: n :: acc)
      end
      return collect_linear_params(params: rest, tdefs, acc)
  end
end

let require_empty_or_droppable = fn (
  vars: [string], params: [HirParam], span: Span
) -> unit throws { TypeError } do
  match vars do
    | [] -> return ()
    | n :: rest ->
      // A linear param of an auto-droppable inner (e.g., %i64) was added
      // for symmetry but doesn't need consumption. Skip those silently here;
      // a warning for them belongs to a separate diagnostics pass.
      if param_inner_is_auto_droppable(params, name: n) then
        return require_empty_or_droppable(vars: rest, params, span)
      end
      raise LinearUnused(name: n, span)
  end
end

let param_inner_is_auto_droppable = fn (params: [HirParam], name: string) -> bool do
  match params do
    | [] -> return false
    | HirParam(label: _, name: pn, sigil: _, typ: t) :: rest ->
      if pn == name then
        match t do
          | TyLinear(inner: i) -> return is_auto_droppable(t: i)
          | _ -> return false
        end
      end
      return param_inner_is_auto_droppable(params: rest, name)
  end
end

// ─── Statement walk ──────────────────────────────────────────────────────────

let check_stmts = fn (
  stmts: [HirStmt], st: LinState, sigs: [SigEntry], tdefs: [RecordDef]
) -> LinState throws { TypeError } do
  match stmts do
    | [] -> return st
    | HirStmt(node: nd, span: sp) :: rest ->
      let st1 = check_stmt(stmt: nd, st, sigs, tdefs, span: sp, at_stmt_level: true)
      return check_stmts(stmts: rest, st: st1, sigs, tdefs)
  end
end

/** True when a Call RHS returns a non-auto-droppable value (nexus-x5ww). */
let call_ret_non_droppable = fn (value: HirExpr, sigs: [SigEntry]) -> bool do
  let HirExpr(node: vn, span: _) = value
  match vn do
    | Call(func: f, args: _) ->
      match sig_lookup(sigs, name: f) do
        | Some(val: SigEntry(name: _, param_types: _, ret_type: rt, throw_row: _)) -> return !is_auto_droppable(t: rt)
        | None -> return false
      end
    | _ -> return false
  end
end

let check_stmt = fn (
  stmt: HirStmtKind, st: LinState, sigs: [SigEntry], tdefs: [RecordDef], span: Span, at_stmt_level: bool
) -> LinState throws { TypeError } do
  match stmt do
    | Let(name: n, sigil: sig, typ: ann, value: v) ->
      // Walk RHS first so any linear use inside it is consumed before the
      // new binding is added.
      let st1 = check_expr(expr: v, st, sigs, tdefs, at_stmt_level: false)
      let binds_lin = let_binds_linear(sigil: sig, ann, value: v, sigs, tdefs)
      if n == "_" then
        // nexus-x5ww: reject `let _ = e` when e is non-auto-droppable linear.
        if binds_lin && call_ret_non_droppable(value: v, sigs) then raise LinearUnused(name: "_", span) end
        return st1
      end
      if binds_lin then return lin_add(st: st1, name: n) end
      return st1
    | Expr(expr: e) ->
      // Top-of-Stmt expression: a root Call here triggers the throwable-
      // call leak check (issue nexus-7eex.2). Nested calls inside larger
      // expressions are not at stmt level — they consume their inputs and
      // close the leak window via the surrounding consumer.
      return check_expr(expr: e, st, sigs, tdefs, at_stmt_level)
    | Return(expr: e) ->
      // After return, the function exits; the unused-linear check fires at
      // function level. We still walk e to consume linears used in it.
      return check_expr(expr: e, st, sigs, tdefs, at_stmt_level: false)
    | Assign(target: t, value: v) ->
      let st1 = check_expr(expr: t, st, sigs, tdefs, at_stmt_level: false)
      return check_expr(expr: v, st: st1, sigs, tdefs, at_stmt_level: false)
    | Try(body: b, catch_param: _, catch_body: cb) ->
      // Push pre-try snapshot for Strategy A: anything alive at this point
      // is the catch arm's responsibility on raise. Throwable-call check
      // inside the body excludes those vars from "leaked".
      let pre_try_vars = lin_state_vars(st)
      let st_try = lin_push_frame(st)
      let st_after_try = check_stmts(stmts: b, st: st_try, sigs, tdefs)
      let st_after_try2 = lin_pop_frame(st: st_after_try)
      // Catch arm starts from pre-try snapshot (Strategy A, nexus-7eex.1),
      // not from the post-success state. The catch arm must finish with
      // the same linear-var set as the post-success state (per-arm
      // consistency — "Linear mismatch across catch arms").
      let st_catch_in = lin_set_vars(st: st_after_try2, vs: pre_try_vars)
      let st_catch_out = check_stmts(stmts: cb, st: st_catch_in, sigs, tdefs)
      let post_catch_vars = lin_state_vars(st: st_catch_out)
      let post_try_vars = lin_state_vars(st: st_after_try2)
      if !vars_equal(a: post_try_vars, b: post_catch_vars) then
        raise LinearMismatch(detail: "try/catch arms diverge on linear set", span)
      end
      return lin_set_vars(st: st_after_try2, vs: post_try_vars)
    | Inject(handlers: _, body: b) -> return check_stmts(stmts: b, st, sigs, tdefs)
  end
end

// ─── Expression walk ─────────────────────────────────────────────────────────

let check_expr = fn (
  expr: HirExpr, st: LinState, sigs: [SigEntry], tdefs: [RecordDef], at_stmt_level: bool
) -> LinState throws { TypeError } do
  let HirExpr(node: nd, span: sp) = expr
  return check_expr_kind(expr: nd, st, sigs, tdefs, span: sp, at_stmt_level)
end

let check_expr_kind = fn (
  expr: HirExprKind, st: LinState, sigs: [SigEntry], tdefs: [RecordDef], span: Span, at_stmt_level: bool
) -> LinState throws { TypeError } do
  match expr do
    | Literal(_) -> return st
    | Variable(name: n, sigil: _) ->
      if lin_member(st, name: n) then return lin_remove(st, name: n) end
      return st
    | Borrow(name: _, sigil: _) ->
      return st
    | BinOp(left: l, op: _, right: r) ->
      let st1 = check_expr(expr: l, st, sigs, tdefs, at_stmt_level: false)
      return check_expr(expr: r, st: st1, sigs, tdefs, at_stmt_level: false)
    | UnOp(op: _, operand: o) ->
      return check_expr(expr: o, st, sigs, tdefs, at_stmt_level: false)
    | Call(func: f, args: cargs) ->
      let st1 = check_call_args(args: cargs, st, sigs, tdefs)
      // If `f` itself is a linear-bound variable (let %g = …), consume it
      // here too: the function name is Linear/Lazy and a call uses it.
      let st2 = if lin_member(st: st1, name: f) then lin_remove(st: st1, name: f) else st1 end
      // Throwable-call leak check — only at stmt level (nexus-7eex.2).
      if at_stmt_level then
        check_throwable_leak(func: f, st: st2, sigs, span)
      end
      return st2
    | Ctor(variant: _, args: cargs, sigil: _) ->
      return check_exprs(exprs: cargs, st, sigs, tdefs)
    | Record(fields: fs) ->
      return check_named_exprs(fields: fs, st, sigs, tdefs)
    | Array(elems: es) ->
      return check_exprs(exprs: es, st, sigs, tdefs)
    | Index(target: t, index: i) ->
      // Move-out rejection: indexing a linear-element array would move the
      // element out. Implementing this requires per-Index typing; left to
      // a future linearity follow-up. The structural walk still recurses.
      let st1 = check_expr(expr: t, st, sigs, tdefs, at_stmt_level: false)
      return check_expr(expr: i, st: st1, sigs, tdefs, at_stmt_level: false)
    | FieldAccess(target: t, field: _) ->
      return check_expr(expr: t, st, sigs, tdefs, at_stmt_level: false)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let st1 = check_expr(expr: c, st, sigs, tdefs, at_stmt_level: false)
      let then_diverges = stmts_diverge(stmts: tb)
      let st_then = check_stmts(stmts: tb, st: st1, sigs, tdefs)
      match eb do
        | None ->
          if then_diverges then
            // Then-branch always exits; only the fall-through path matters.
            return st1
          end
          // Without an else, the linear set must be the same on both paths
          // (the no-else path is just `st1`).
          let v1 = lin_state_vars(st: st1)
          let vt = lin_state_vars(st: st_then)
          if !vars_equal(a: v1, b: vt) then
            raise LinearMismatch(detail: "if-without-else branches diverge on linear set: pre=" ++ join_simple(xs: v1) ++ " then=" ++ join_simple(xs: vt), span)
          end
          return st1
        | Some(val: ebs) ->
          let else_diverges = stmts_diverge(stmts: ebs)
          let st_else = check_stmts(stmts: ebs, st: st1, sigs, tdefs)
          if then_diverges && else_diverges then
            return lin_set_vars(st: st1, vs: [])
          end
          if then_diverges then return st_else end
          if else_diverges then return st_then end
          if !vars_equal(a: lin_state_vars(st: st_then), b: lin_state_vars(st: st_else)) then
            raise LinearMismatch(detail: "if/else branches diverge on linear set: then=" ++ join_simple(xs: lin_state_vars(st: st_then)) ++ " else=" ++ join_simple(xs: lin_state_vars(st: st_else)), span)
          end
          return st_then
      end
    | Match(target: t, cases: cs) ->
      let st1 = check_expr(expr: t, st, sigs, tdefs, at_stmt_level: false)
      return check_match_cases(cases: cs, st: st1, sigs, tdefs, span)
    | While(cond: c, body: b) ->
      // T-While (nexus-t9cl.13 / spec t9cl.8): the cond expression is
      // evaluated an unbounded number of times (once per iteration plus the
      // final false). A linear binding may only be consumed once, so the
      // cond must NOT consume any linear binding live before the loop.
      // We snapshot the pre-cond live set and reject if check_expr on
      // the cond removes any linear from it.
      let pre_vars = lin_state_vars(st)
      let st_cond = check_expr(expr: c, st, sigs, tdefs, at_stmt_level: false)
      let post_cond_vars = lin_state_vars(st: st_cond)
      if !vars_equal(a: pre_vars, b: post_cond_vars) then
        raise LinearMismatch(detail: "while-cond consumes linear binding(s); the cond runs an unbounded number of times so any linear consume in it is unsound (pre=" ++ join_simple(xs: pre_vars) ++ " post-cond=" ++ join_simple(xs: post_cond_vars) ++ ")", span)
      end
      let st_body = check_stmts(stmts: b, st: st_cond, sigs, tdefs)
      // While body must preserve linear set (it may run zero times).
      if !vars_equal(a: lin_state_vars(st: st_cond), b: lin_state_vars(st: st_body)) then
        raise LinearMismatch(detail: "while body diverges on linear set", span)
      end
      return st_cond
    | For(var: _, start: s, end_expr: e, body: b) ->
      let st1 = check_expr(expr: s, st, sigs, tdefs, at_stmt_level: false)
      let st2 = check_expr(expr: e, st: st1, sigs, tdefs, at_stmt_level: false)
      let st_body = check_stmts(stmts: b, st: st2, sigs, tdefs)
      if !vars_equal(a: lin_state_vars(st: st2), b: lin_state_vars(st: st_body)) then
        raise LinearMismatch(detail: "for body diverges on linear set", span)
      end
      return st2
    | Lambda(type_params: _, params: ps, ret_type: _, body: b) ->
      // Lambda body is its own frame; outer linears captured by the lambda
      // are tracked via `src/typecheck/capture.nx`. Walk the body in a
      // fresh state seeded only with the lambda's own linear params.
      let lparams = collect_linear_params(params: ps, tdefs, acc: [])
      let lst0 = lin_set_vars(st: lin_empty(), vs: lparams)
      let lst1 = lin_push_frame(st: lst0)
      let lst2 = check_stmts(stmts: b, st: lst1, sigs, tdefs)
      // A lambda body that leaves linear params unconsumed is a type error
      // at construction time.
      require_empty_or_droppable(vars: lin_state_vars(st: lst2), params: ps, span)
      // Outer linear bindings referenced (free) inside the body are
      // consumed by the closure capture (one consume per captured linear
      // when the lambda's type is wrapped in `%`).
      let pnames = collect_param_names(params: ps, acc: [])
      let outer_linears = lin_state_vars(st)
      let captured = collect_captured_linears(
        body: b, outer_linears, bound: pnames, acc: []
      )
      return consume_all(st, names: captured)
    | Raise(expr: e) ->
      // After raise, control transfers to the catch arm; remaining stmts
      // are unreachable. Walk the raised value to consume any linears in it
      // (rare, but the value can reference linear bindings).
      return check_expr(expr: e, st, sigs, tdefs, at_stmt_level: false)
    | Force(expr: e) ->
      // `force(@x)` consumes the lazy. The inner Variable visit handles
      // consumption.
      return check_expr(expr: e, st, sigs, tdefs, at_stmt_level: false)
    | Thunk(body: b) ->
      // The thunk body runs deferred; we don't track linears across the
      // deferral here (the @T binder check in src/ir/linearity.nx covers
      // the lazy-binding-specific case).
      return check_expr(expr: b, st, sigs, tdefs, at_stmt_level: false)
    | ExternalRef(_) | Handler(_) -> return st
  end
end

let check_exprs = fn (
  exprs: [HirExpr], st: LinState, sigs: [SigEntry], tdefs: [RecordDef]
) -> LinState throws { TypeError } do
  match exprs do
    | [] -> return st
    | e :: rest ->
      let st1 = check_expr(expr: e, st, sigs, tdefs, at_stmt_level: false)
      return check_exprs(exprs: rest, st: st1, sigs, tdefs)
  end
end

let check_call_args = fn (
  args: [HirCallArg], st: LinState, sigs: [SigEntry], tdefs: [RecordDef]
) -> LinState throws { TypeError } do
  match args do
    | [] -> return st
    | HirCallArg(label: _, value: v) :: rest ->
      let st1 = check_expr(expr: v, st, sigs, tdefs, at_stmt_level: false)
      return check_call_args(args: rest, st: st1, sigs, tdefs)
  end
end

let check_named_exprs = fn (
  fields: [HirNamedExpr], st: LinState, sigs: [SigEntry], tdefs: [RecordDef]
) -> LinState throws { TypeError } do
  match fields do
    | [] -> return st
    | HirNamedExpr(name: _, value: v) :: rest ->
      let st1 = check_expr(expr: v, st, sigs, tdefs, at_stmt_level: false)
      return check_named_exprs(fields: rest, st: st1, sigs, tdefs)
  end
end

// ─── Match-case branch consistency ───────────────────────────────────────────

let check_match_cases = fn (
  cases: [HirMatchCase], st: LinState, sigs: [SigEntry], tdefs: [RecordDef], span: Span
) -> LinState throws { TypeError } do
  return check_match_cases_go(cases, st, sigs, tdefs, span, ref_set: None)
end

let check_match_cases_go = fn (
  cases: [HirMatchCase], st: LinState, sigs: [SigEntry], tdefs: [RecordDef], span: Span,
  ref_set: Option<[string]>
) -> LinState throws { TypeError } do
  match cases do
    | [] ->
      match ref_set do
        | None -> return lin_set_vars(st, vs: [])
        | Some(val: vs) -> return lin_set_vars(st, vs)
      end
    | HirMatchCase(pattern: p, body: b) :: rest ->
      // Pattern binders that introduce linear vars (`%v` patterns) are
      // added before walking the body. Other binders (immutable) do not
      // become linear bindings.
      let case_state = lin_set_vars(st, vs: lin_state_vars(st))
      let case_state2 = bind_pattern_linear(pat: p, st: case_state)
      let case_diverges = stmts_diverge(stmts: b)
      let case_out = check_stmts(stmts: b, st: case_state2, sigs, tdefs)
      if case_diverges then
        return check_match_cases_go(cases: rest, st, sigs, tdefs, span, ref_set)
      end
      let case_vars = lin_state_vars(st: case_out)
      match ref_set do
        | None ->
          return check_match_cases_go(cases: rest, st, sigs, tdefs, span, ref_set: Some(val: case_vars))
        | Some(val: rv) ->
          if !vars_equal(a: rv, b: case_vars) then
            raise LinearMismatch(detail: "match arms diverge on linear set", span)
          end
          return check_match_cases_go(cases: rest, st, sigs, tdefs, span, ref_set)
      end
  end
end

let bind_pattern_linear = fn (pat: HirPatternKind, st: LinState) -> LinState throws { TypeError } do
  match pat do
    | PLit(_) | PWild -> return st
    | PVar(name: n, sigil: s) ->
      match s do
        | SigilLinear | SigilLazy -> return lin_add(st, name: n)
        | _ -> return st
      end
    | PCtor(variant: _, fields: fs, sigil: _) -> return bind_pattern_fields(fields: fs, st)
    | PRec(fields: fs, is_partial: _) -> return bind_pattern_rec_fields(fields: fs, st)
    | POr(alts) -> return bind_pattern_or(alts, st)
  end
end

let bind_pattern_fields = fn (
  fields: [HirPatternField], st: LinState
) -> LinState throws { TypeError } do
  match fields do
    | [] -> return st
    | HirPatternField(name: _, pattern: p) :: rest ->
      let st1 = bind_pattern_linear(pat: p, st)
      return bind_pattern_fields(fields: rest, st: st1)
  end
end

let bind_pattern_rec_fields = fn (
  fields: [HirRecordPatField], st: LinState
) -> LinState throws { TypeError } do
  match fields do
    | [] -> return st
    | HirRecordPatField(name: _, pattern: p) :: rest ->
      let st1 = bind_pattern_linear(pat: p, st)
      return bind_pattern_rec_fields(fields: rest, st: st1)
  end
end

let bind_pattern_or = fn (
  alts: [HirPatternKind], st: LinState
) -> LinState throws { TypeError } do
  // Or-patterns require all alternatives to bind the same linear-name set.
  // Use the first alt as the canonical binder set.
  match alts do
    | [] -> return st
    | a :: _ -> return bind_pattern_linear(pat: a, st)
  end
end

// ─── Throwable-call leak check ───────────────────────────────────────────────

/** At a stmt-level Call to `func`, any linear in `st.vars` that is *not*
 *  covered by the top frame snapshot would leak if the call raises. Raise
 *  `LinearLeakAcrossThrowableCall` listing the offending linears.
 */
let check_throwable_leak = fn (
  func: string, st: LinState, sigs: [SigEntry], span: Span
) -> unit throws { TypeError } do
  match sig_lookup(sigs, name: func) do
    | None -> return ()
    | Some(val: SigEntry(name: _, param_types: _, ret_type: _, throw_row: tw)) ->
      if !row_is_throwable(eff_row: tw) then return () end
      let leaked = uncovered_linears(st)
      match leaked do
        | [] -> return ()
        | _ :: _ -> raise LinearLeakAcrossThrowableCall(callee: func, leaked, span)
      end
  end
end

let uncovered_linears = fn (st: LinState) -> [string] do
  let vs = lin_state_vars(st)
  match lin_top_frame(st) do
    | None -> return vs
    | Some(val: covered) -> return filter_not_in(xs: vs, exclude: covered, acc: [])
  end
end

let filter_not_in = fn (
  xs: [string], exclude: [string], acc: [string]
) -> [string] do
  match xs do
    | [] -> return acc
    | x :: rest ->
      if str_member(xs: exclude, target: x) then
        return filter_not_in(xs: rest, exclude, acc)
      end
      return filter_not_in(xs: rest, exclude, acc: x :: acc)
  end
end

// ─── Divergence detection ────────────────────────────────────────────────────

/** True when `stmts` ends with a control-flow exit (return / raise). Used
 *  to skip linear-set reconciliation on branches that never reach the join.
 *
 *  Recurses into:
 *  - `StmtLetPattern` desugar form `Stmt::Expr(Match(scrutinee, [case]))`
 *  where the single case body is the remainder of the original block —
 *  so divergence of the desugared body is divergence of the wrapping
 *  match's first case body.
 *  - `if X then ... return ... else ... return ... end` lifted to an
 *  expression: each branch must diverge.
 *
 *  Uses HIR depth as the recursion bound to keep the structural walk
 *  terminating; the inlined helper is `stmts_diverge_depth` and the public
 *  surface (`stmts_diverge`) seeds depth=64 — enough for typical desugar
 *  nesting and a hard ceiling against pathological cycles.
 */
let stmts_diverge = fn (stmts: [HirStmt]) -> bool do
  return stmts_diverge_depth(stmts, depth: 64)
end

let stmts_diverge_depth = fn (stmts: [HirStmt], depth: i64) -> bool do
  if depth <= 0 then return false end
  match last_stmt(stmts) do
    | None -> return false
    | Some(val: HirStmt(node: nd, span: _)) ->
      match nd do
        | Return(_) -> return true
        | Expr(expr: HirExpr(node: en, span: _)) ->
          return hir_expr_diverges(en, depth: depth - 1)
        // nexus-t9cl.14 / spec[tail]: `let p = raise e'` is divergent —
        // the bound name is unreachable. The same applies to a `let`
        // whose RHS is itself a divergent expression (raise / match
        // where every arm diverges / if where both branches diverge).
        // Without this, downstream branch-arm divergence (then_diverges,
        // all_cases_diverge_depth) sees an "ordinary let" and treats
        // that arm as non-divergent — leading to a spurious
        // "Linear mismatch across branches" or to a missed leak check.
        | Let(name: _, sigil: _, typ: _, value: HirExpr(node: rhs, span: _)) ->
          return hir_expr_diverges(rhs, depth: depth - 1)
        | _ -> return false
      end
  end
end

/** True when a HirExprKind is structurally divergent: it raises, returns,
 *  or every branch of a match/if it reduces to diverges. Shared between
 *  `stmts_diverge_depth` (tail-of-block) and `Let(_, ..., value: <expr>)`
 *  to apply the same rule for both `let p = raise e'` and bare `raise e'`.
 */
let hir_expr_diverges = fn (en: HirExprKind, depth: i64) -> bool do
  if depth <= 0 then return false end
  match en do
    | Raise(_) -> return true
    | Match(target: _, cases: cs) -> return all_cases_diverge_depth(cases: cs, depth: depth - 1)
    | If(cond: _, then_branch: tb, else_branch: eb) ->
      match eb do
        | None -> return false
        | Some(val: ebs) -> return stmts_diverge_depth(stmts: tb, depth: depth - 1) && stmts_diverge_depth(stmts: ebs, depth: depth - 1)
      end
    | _ -> return false
  end
end

let all_cases_diverge_depth = fn (cases: [HirMatchCase], depth: i64) -> bool do
  match cases do
    | [] -> return true
    | HirMatchCase(pattern: _, body: b) :: rest ->
      if !stmts_diverge_depth(stmts: b, depth) then return false end
      return all_cases_diverge_depth(cases: rest, depth)
  end
end

let cases_kinds = fn (cases: [HirMatchCase]) -> string do
  match cases do
    | [] -> return ""
    | HirMatchCase(pattern: _, body: b) :: [] -> return last_stmt_kind(stmts: b)
    | HirMatchCase(pattern: _, body: b) :: rest -> return last_stmt_kind(stmts: b) ++ "," ++ cases_kinds(cases: rest)
  end
end

let last_stmt = fn (stmts: [HirStmt]) -> Option<HirStmt> do
  match stmts do
    | [] -> return None
    | s :: [] -> return Some(val: s)
    | _ :: rest -> return last_stmt(stmts: rest)
  end
end

let last_stmt_kind = fn (stmts: [HirStmt]) -> string do
  match last_stmt(stmts) do
    | None -> return "empty"
    | Some(val: HirStmt(node: nd, span: _)) ->
      match nd do
        | Let(_) -> return "Let"
        | Expr(expr: HirExpr(node: en, span: _)) ->
          match en do
            | Raise(_) -> return "Expr(Raise)"
            | Call(func: f, args: _) -> return "Expr(Call:" ++ f ++ ")"
            | Match(target: _, cases: cs) ->
              return "Expr(Match-cases=" ++ cases_kinds(cases: cs) ++ ")"
            | If(_) -> return "Expr(If)"
            | _ -> return "Expr(other)"
          end
        | Return(_) -> return "Return"
        | Assign(_) -> return "Assign"
        | Try(_) -> return "Try"
        | Inject(_) -> return "Inject"
      end
  end
end
