/**
 * typecheck/linearity/state: LinState + frame ops for the linearity pass.
 *
 * LinState is the mutable-by-threading state threaded through the linearity
 * walker: a set of live linear variable names, a stack of frame snapshots for
 * throwable-call leak detection, and a must_consume set for cont_binder arms.
 */

import { Option, Some, None } from "std:option"
import { HirExpr } from "src/ir/hir/types.nx"

// ─── Linearity state ─────────────────────────────────────────────────────────

/** One `let name = ctor-expr` binding recorded for the enclosing function
 *  body. Lets the match-case linearity check recover the scrutinee's
 *  CONSTRUCTION expression (the only structural source of generic
 *  instantiation, since the name-based linearity pass carries no inferred
 *  type-args). `ctor_env` below is set once at function entry and never
 *  mutated by the threading helpers — a read-only view of the body's lets. */
export type CtorBinding = CtorBinding(name: string, value: HirExpr)

/** One snapshot of `vars` at a frame boundary. Wraps a `[string]` so the
 *  surrounding LinState can carry a list of these without nesting list-of-
 *  list type syntax (Nexus requires a nominal type for nested generics).
 */
export type LinFrame = LinFrame(vars: [ string ])

/** One entry of the local catch-stack (flow-sensitive throw
 *  analysis). `caught` holds the constructor names this `try` catches; the
 *  catch-all sentinel `"Exn"` is present when a `_`/variable catch arm exists.
 *  A `throw v` whose `v` is locally covered by some frame on the catch-stack
 *  is handled by the existing T-TryCatch reconciliation and does NOT trigger
 *  the strict divergent-arm leak check. */
export type CatchFrame = CatchFrame(caught: [ string ])

/** Live linear bindings + enclosing frame snapshots. `frame_stack` is a
 *  stack of `vars` snapshots at function-body entry and `try`-body entry.
 *  The top is the "covered" set for the throwable-call leak check.
 *  `must_consume` names bindings (e.g. with-@k cont_binders) that must be
 *  consumed on EVERY exit path, including early `return` — unlike regular
 *  linear params whose end-of-function check covers only the fall-through
 *  path.
 *  `consumed` is the set of linear names already consumed on the current
 *  execution path. Used by the `Variable` walker to detect double-use
 *  (LinearReuse): when a name is in `consumed` but not in `vars`, it was
 *  a linear binding that has already been consumed once.
 *  `caught_set` is the program-wide caught_variants(Π) (constant for the
 *  whole walk); `catch_stack` is the per-path stack of enclosing local
 * try/catch frames. Both feed the divergent-throw dispatch.
 */
export type LinState = LinState(
  vars: [ string ],
  frame_stack: [ LinFrame ],
  must_consume: [ string ],
  consumed: [ string ],
  caught_set: [ string ],
  catch_stack: [ CatchFrame ],
  cur_fn: string,
  ctor_env: [ CtorBinding ]
)

export let lin_empty = fn () -> LinState do
  return LinState(
    vars: [], frame_stack: [], must_consume: [], consumed: [],
    caught_set: [], catch_stack: [], cur_fn: "", ctor_env: []
  )
end

export let lin_get_cur_fn = fn (st: LinState) -> string do
  let LinState(vars: _, frame_stack: _, must_consume: _, consumed: _, caught_set: _, catch_stack: _, cur_fn: f, ctor_env: _) = st
  return f
end

/** Set the read-only ctor-binding env for the enclosing function body.
 *  Called once at function entry; the threading helpers preserve it. */
export let lin_set_ctor_env = fn (st: LinState, env: [ CtorBinding ]) -> LinState do
  let LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: _) = st
  return LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: env)
end

/** Look up the construction expression bound to `name` in the function body,
 *  if any. None when `name` is not a let-bound ctor/record/etc. binding. */
export let lin_lookup_ctor = fn (st: LinState, name: string) -> Option<HirExpr> do
  let LinState(vars: _, frame_stack: _, must_consume: _, consumed: _, caught_set: _, catch_stack: _, cur_fn: _, ctor_env: ce) = st
  return lin_ctor_env_find(env: ce, name)
end

let lin_ctor_env_find = fn (env: [ CtorBinding ], name: string) -> Option<HirExpr> do
  match env do
    | [] -> return None
    | CtorBinding(name: n, value: v) :: rest ->
      if n == name then return Some(val: v) end
      return lin_ctor_env_find(env: rest, name)
  end
end

export let lin_add = fn (st: LinState, name: string) -> LinState do
  let LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce) = st
  // Remove from consumed when a new binding shadows a previously consumed name.
  return LinState(
    vars: name :: vs,
    frame_stack: fs,
    must_consume: mc,
    consumed: remove_one(xs: co, target: name),
    caught_set: cs,
    catch_stack: ks,
    cur_fn: cf,
    ctor_env: ce
  )
end

/** Clear `name` from the consumed set without adding it to vars. Used when a
 *  NEW non-linear binding shadows a previously consumed linear name, so the
 *  old consumed entry does not falsely trigger LinearReuse in the new scope.
 */
export let lin_clear_consumed = fn (st: LinState, name: string) -> LinState do
  let LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce) = st
  return LinState(
    vars: vs,
    frame_stack: fs,
    must_consume: mc,
    consumed: remove_one(xs: co, target: name),
    caught_set: cs,
    catch_stack: ks,
    cur_fn: cf,
    ctor_env: ce
  )
end

export let lin_remove = fn (st: LinState, name: string) -> LinState do
  let LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce) = st
  return LinState(
    vars: remove_one(xs: vs, target: name),
    frame_stack: fs,
    must_consume: mc,
    consumed: name :: co,
    caught_set: cs,
    catch_stack: ks,
    cur_fn: cf,
    ctor_env: ce
  )
end

let remove_one = fn (xs: [ string ], target: string) -> [ string ] do
  match xs do
    | [] -> return []
    | x :: rest ->
      if x == target then return rest end
      return x :: remove_one(xs: rest, target)
  end
end

export let lin_member = fn (st: LinState, name: string) -> bool do
  let LinState(vars: vs, frame_stack: _, must_consume: _, consumed: _, caught_set: _, catch_stack: _, cur_fn: _, ctor_env: _) = st
  return str_member(xs: vs, target: name)
end

/** True when `name` was a linear binding already consumed on this path. */
export let lin_consumed_member = fn (st: LinState, name: string) -> bool do
  let LinState(vars: _, frame_stack: _, must_consume: _, consumed: co, caught_set: _, catch_stack: _, cur_fn: _, ctor_env: _) = st
  return str_member(xs: co, target: name)
end

export let str_member = fn (xs: [ string ], target: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == target then return true end
      return str_member(xs: rest, target)
  end
end

/** Set equality of two linear-var sets — order-insensitive. */
export let vars_equal = fn (a: [ string ], b: [ string ]) -> bool do
  if length(xs: a) != length(xs: b) then return false end
  return all_in(needles: a, haystack: b) && all_in(needles: b, haystack: a)
end

let length = fn (xs: [ string ]) -> i64 do
  match xs do
    | [] -> return 0
    | _ :: rest -> return 1 + length(xs: rest)
  end
end

let all_in = fn (needles: [ string ], haystack: [ string ]) -> bool do
  match needles do
    | [] -> return true
    | n :: rest ->
      if !str_member(xs: haystack, target: n) then return false end
      return all_in(needles: rest, haystack)
  end
end

export let lin_push_frame = fn (st: LinState) -> LinState do
  let LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce) = st
  return LinState(
    vars: vs,
    frame_stack: LinFrame(vars: copy(xs: vs)) :: fs,
    must_consume: mc,
    consumed: co,
    caught_set: cs,
    catch_stack: ks,
    cur_fn: cf,
    ctor_env: ce
  )
end

export let lin_pop_frame = fn (st: LinState) -> LinState do
  let LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce) = st
  match fs do
    | [] -> return st
    | _ :: rest -> return LinState(vars: vs, frame_stack: rest, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce)
  end
end

export let lin_top_frame = fn (st: LinState) -> Option<[ string ]> do
  let LinState(vars: _, frame_stack: fs, must_consume: _, consumed: _, caught_set: _, catch_stack: _, cur_fn: _, ctor_env: _) = st
  match fs do
    | [] -> return None
    | LinFrame(vars: top) :: _ -> return Some(val: top)
  end
end

// ─── Caught-variant set + local catch-stack ───────────────────

/** The program-wide caught_variants(Π). Set once at function-check entry. */
export let lin_get_caught_set = fn (st: LinState) -> [ string ] do
  let LinState(vars: _, frame_stack: _, must_consume: _, consumed: _, caught_set: cs, catch_stack: _, cur_fn: _, ctor_env: _) = st
  return cs
end

export let lin_set_caught_set = fn (st: LinState, cs: [ string ]) -> LinState do
  let LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: _, catch_stack: ks, cur_fn: cf, ctor_env: ce) = st
  return LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce)
end

/** Push a local try/catch frame onto the catch-stack. */
export let lin_push_catch = fn (st: LinState, frame: CatchFrame) -> LinState do
  let LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce) = st
  return LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: frame :: ks, cur_fn: cf, ctor_env: ce)
end

/** Pop the innermost local try/catch frame. No-op on empty stack. */
export let lin_pop_catch = fn (st: LinState) -> LinState do
  let LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce) = st
  match ks do
    | [] -> return st
    | _ :: rest -> return LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: rest, cur_fn: cf, ctor_env: ce)
  end
end

/** True when some frame on the local catch-stack catches variant `v`
 *  (exact constructor or via the catch-all "Exn" sentinel). When true, the
 *  throw transfers to a local catch arm and the existing T-TryCatch
 *  reconciliation governs linearity — the strict divergent-arm check is
 *  skipped. */
export let lin_throw_caught_locally = fn (st: LinState, v: string) -> bool do
  let LinState(vars: _, frame_stack: _, must_consume: _, consumed: _, caught_set: _, catch_stack: ks, cur_fn: _, ctor_env: _) = st
  return catch_stack_covers(frames: ks, v)
end

let catch_stack_covers = fn (frames: [ CatchFrame ], v: string) -> bool do
  match frames do
    | [] -> return false
    | CatchFrame(caught: c) :: rest ->
      if str_member(xs: c, target: "Exn") then return true end
      if str_member(xs: c, target: v) then return true end
      return catch_stack_covers(frames: rest, v)
  end
end

let copy = fn (xs: [ string ]) -> [ string ] do
  match xs do
    | [] -> return []
    | x :: rest -> return x :: copy(xs: rest)
  end
end

export let join_simple = fn (xs: [ string ]) -> string do
  match xs do
    | [] -> return "{}"
    | x :: [] -> return "{" ++ x ++ "}"
    | x :: rest -> return "{" ++ x ++ "," ++ join_inner(xs: rest) ++ "}"
  end
end

let join_inner = fn (xs: [ string ]) -> string do
  match xs do
    | [] -> return ""
    | x :: [] -> return x
    | x :: rest -> return x ++ "," ++ join_inner(xs: rest)
  end
end

export let lin_set_vars = fn (st: LinState, vs: [ string ]) -> LinState do
  let LinState(vars: _, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce) = st
  return LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce)
end

/** Return the set of names that must be consumed on every exit path
 *  (currently seeded only by with-@k cont_binder arms).
 */
export let lin_get_must_consume = fn (st: LinState) -> [ string ] do
  let LinState(vars: _, frame_stack: _, must_consume: mc, consumed: _, caught_set: _, catch_stack: _, cur_fn: _, ctor_env: _) = st
  return mc
end

/** Return the first name in `mc` that is still live (in `live`), or None. */
export let find_live_must_consume = fn (mc: [ string ], live: [ string ]) -> Option<string> do
  match mc do
    | [] -> return None
    | n :: rest ->
      if str_member(xs: live, target: n) then return Some(val: n) end
      return find_live_must_consume(mc: rest, live)
  end
end

export let lin_state_vars = fn (st: LinState) -> [ string ] do
  let LinState(vars: vs, frame_stack: _, must_consume: _, consumed: _, caught_set: _, catch_stack: _, cur_fn: _, ctor_env: _) = st
  return vs
end

export let lin_state_consumed = fn (st: LinState) -> [ string ] do
  let LinState(vars: _, frame_stack: _, must_consume: _, consumed: co, caught_set: _, catch_stack: _, cur_fn: _, ctor_env: _) = st
  return co
end

/** Restore both `vars` and `consumed` to saved values. Used by the try-catch
 *  handler to reset the catch arm's starting state to the pre-try snapshot,
 *  preventing try-body consumed bindings from polluting reuse detection in
 *  the catch arm.
 */
export let lin_restore_state = fn (st: LinState, vs: [ string ], co: [ string ]) -> LinState do
  let LinState(vars: _, frame_stack: fs, must_consume: mc, consumed: _, caught_set: cset, catch_stack: ks, cur_fn: cf, ctor_env: ce) = st
  return LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cset, catch_stack: ks, cur_fn: cf, ctor_env: ce)
end

export let filter_not_in = fn (
  xs: [ string ], exclude: [ string ], acc: [ string ]
) -> [ string ] do
  match xs do
    | [] -> return acc
    | x :: rest ->
      if str_member(xs: exclude, target: x) then
        return filter_not_in(xs: rest, exclude, acc)
      end
      return filter_not_in(xs: rest, exclude, acc: x :: acc)
  end
end

/** Keep only items from `xs` that are also in `keep`. Dual of filter_not_in. */
export let filter_in = fn (xs: [ string ], keep: [ string ], acc: [ string ]) -> [ string ] do
  match xs do
    | [] -> return acc
    | x :: rest ->
      if str_member(xs: keep, target: x) then
        return filter_in(xs: rest, keep, acc: x :: acc)
      end
      return filter_in(xs: rest, keep, acc)
  end
end

/** Concatenate two string lists (no dedup — caller ensures disjointness). */
export let append_consumed = fn (xs: [ string ], ys: [ string ]) -> [ string ] do
  match ys do
    | [] -> return xs
    | y :: rest -> return append_consumed(xs: y :: xs, ys: rest)
  end
end

/** Record, into `st`'s consumed set, every name in `pre_live` that is no
 *  longer in `st`'s live set — i.e. the linears a just-walked RHS consumed.
 *  Most consumption is already recorded directly by `check_expr`, but a linear
 *  consumed inside an `if`/`match` EXPRESSION branch is dropped from BOTH the
 *  live and consumed sets when the branch walk joins (the join returns the
 *  pre-branch consumed set with only the live vars updated). Folding the
 *  live-set delta into consumed at the binding boundary restores the invariant
 *  that a later liveness-INDEPENDENT classifier (the match-site generic-field
 *  demotion check) can recognise a construction-consumed linear laundered
 *  through a branch. The delta is disjoint from the existing consumed set (a
 *  name cannot be both live and already-consumed), so `append_consumed` is safe
 *  (no dedup needed). */
export let lin_record_consumed_since = fn (st: LinState, pre_live: [ string ]) -> LinState do
  let LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: co, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce) = st
  let newly_gone = filter_not_in(xs: pre_live, exclude: vs, acc: [])
  let delta = filter_not_in(xs: newly_gone, exclude: co, acc: [])
  let merged = append_consumed(xs: co, ys: delta)
  return LinState(vars: vs, frame_stack: fs, must_consume: mc, consumed: merged, caught_set: cs, catch_stack: ks, cur_fn: cf, ctor_env: ce)
end
