  collect_param_names, consume_all, collect_captured_linears,
  row_is_throwable, scan_stmts_until_throw
} from "src/typecheck/linearity/capture.nx"
import {
  is_linear_scrutinee, bind_pattern_linear,
  bind_pattern_fields, bind_pattern_fields_for_variant,
  lin_pattern_field_is_linear, lin_drop_first_vfield,
  bind_pattern_rec_fields, bind_pattern_or
} from "src/typecheck/linearity/pattern.nx"
import {
  stmts_diverge, stmts_diverge_depth, hir_expr_diverges,
  all_cases_diverge_depth, last_stmt, divergence_throw_variant
} from "src/typecheck/linearity/diverge.nx"
import {
  lookup_param_type_by_label, pt_shares_tyvar_with_rt
} from "src/typecheck/linearity/borrow_types.nx"
import { check_borrow_escape_form_b } from "src/typecheck/linearity/borrow_escape.nx"

// ─── Construction-env collection (for generic-field instantiation) ──────────

/** Walk a statement list and record every `let name = value` into a flat
 *  CtorBinding env. Descends into nested blocks (if/while/for/match/try/inject
 *  bodies and lambda bodies) so a scrutinee constructed in an inner block is
 *  still recoverable. The env is read-only after construction; shadowing is
 *  resolved by first-match in `lin_lookup_ctor` (outer-most binding wins),
 *  which is sound here because the env only ever DEMOTES a conservatively-
 *  linear classification — a stale/shadowed entry can at worst keep the
 *  current conservative behavior, never under-track. */
let collect_ctor_bindings = fn (stmts: [ HirStmt ], acc: [ CtorBinding ]) -> [ CtorBinding ] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: nd, span: _) :: rest ->
      let acc1 = collect_ctor_bindings_stmt(stmt: nd, acc)
      return collect_ctor_bindings(stmts: rest, acc: acc1)
  end
end

let collect_ctor_bindings_stmt = fn (stmt: HirStmtKind, acc: [ CtorBinding ]) -> [ CtorBinding ] do
  match stmt do
    | Let(name: n, sigil: _, typ: _, value: v) ->
      let acc1 = CtorBinding(name: n, value: v) :: acc
      return collect_ctor_bindings_expr(expr: v, acc: acc1)
    | Expr(expr: e) -> return collect_ctor_bindings_expr(expr: e, acc)
    | Return(expr: e) -> return collect_ctor_bindings_expr(expr: e, acc)
    | Assign(target: _, value: v) -> return collect_ctor_bindings_expr(expr: v, acc)
    | Try(body: b, catch_param: _, catch_body: cb) ->
      let acc1 = collect_ctor_bindings(stmts: b, acc)
      return collect_ctor_bindings(stmts: cb, acc: acc1)
    | Inject(handlers: _, body: b) -> return collect_ctor_bindings(stmts: b, acc)
  end
end

let collect_ctor_bindings_expr = fn (expr: HirExpr, acc: [ CtorBinding ]) -> [ CtorBinding ] do
  let HirExpr(node: nd, span: _) = expr
  match nd do
    | If(cond: _, then_branch: tb, else_branch: eb) ->
      let acc1 = collect_ctor_bindings(stmts: tb, acc)
      match eb do
        | Some(val: e) -> return collect_ctor_bindings(stmts: e, acc: acc1)
        | None -> return acc1
      end
    | Match(target: _, cases: cs) -> return collect_ctor_bindings_cases(cases: cs, acc)
    | While(cond: _, body: b) -> return collect_ctor_bindings(stmts: b, acc)
    | For(var: _, start: _, end_expr: _, body: b) -> return collect_ctor_bindings(stmts: b, acc)
    | Lambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: b) ->
      return collect_ctor_bindings(stmts: b, acc)
    | _ -> return acc
  end
end

let collect_ctor_bindings_cases = fn (cases: [ HirMatchCase ], acc: [ CtorBinding ]) -> [ CtorBinding ] do
  match cases do
    | [] -> return acc
    | HirMatchCase(pattern: _, body: b) :: rest ->
      let acc1 = collect_ctor_bindings(stmts: b, acc)
      return collect_ctor_bindings_cases(cases: rest, acc: acc1)
  end
end

/** For a match scrutinee `target` and the matched `variant`, compute the set
 *  of field NAMES whose generic (TyVar) slot was instantiated to a NON-linear
 *  argument at the scrutinee's construction site — i.e. fields that should NOT
 *  inherit the scrutinee's linearity (approach (a): substitute the variant's
 *  declared type-parameter against the scrutinee's structural type-args).
 *
 *  Only fields filled by a NON-linear construction arg are demoted; a TyVar
 *  slot filled by a linear arg (e.g. `Mix(payload:%p, gen:%q)`) is left to the
 *  conservative `lin_field_is_tyvar` inheritance so genuine linear payloads
 *  routed through generic slots stay tracked (preserves xim2n / 2djm4).
 *
 *  Returns [] when the construction expression is unavailable (scrutinee is a
 *  param, field access, nested expression, …) — falling back to the existing
 *  conservative behavior, never under-tracking. */
let compute_demoted_tyvar_fields = fn (
  target: HirExpr, variant: string, st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> [ string ] do
  let HirExpr(node: tn, span: _) = target
  match tn do
    | Variable(name: m, sigil: _) ->
      match lin_lookup_ctor(st, name: m) do
        | None -> return []
        | Some(val: ce) ->
          let HirExpr(node: cn, span: _) = ce
          match cn do
            | Ctor(variant: cv, args: cargs, labels: clabels, sigil: _) ->
              // The construction must be for the same constructor we are
              // matching (otherwise the labels/args don't correspond).
              if cv != variant then return [] end
              return collect_nonlinear_ctor_fields(
                labels: clabels, args: cargs, st, sigs, tdefs, enum_defs, acc: []
              )
            | _ -> return []
          end
      end
    | _ -> return []
  end
end

/** Pair construction labels with args; a field whose construction arg is
 *  NON-linear is collected as demotable. */
let collect_nonlinear_ctor_fields = fn (
  labels: [ string ], args: [ HirExpr ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ], acc: [ string ]
) -> [ string ] do
  match labels do
    | [] -> return acc
    | lbl :: rest_labels ->
      match args do
        | [] -> return acc
        | a :: rest_args ->
          let arg_linear = ctor_arg_is_linear(arg: a, st, sigs, tdefs, enum_defs)
          let acc1 = if arg_linear then acc else lbl :: acc end
          return collect_nonlinear_ctor_fields(
            labels: rest_labels, args: rest_args, st, sigs, tdefs, enum_defs, acc: acc1
          )
      end
  end
end

/** Intrinsic (liveness-independent) linearity of a constructor ARGUMENT
 *  expression. Unlike `let_binds_linear`'s `Variable` case — which reads the
 *  CURRENT live set — this classifier must work at the MATCH site, where the
 *  construction already consumed its linear args (so they are no longer live).
 *  A linear-/lazy-sigil variable is classified by its SIGIL; a bare variable by
 *  live-OR-consumed membership; compound args (Ctor/Array/Record) recurse with
 *  this same liveness-independent classifier (their nested args were also
 *  consumed by the construction). ANY linear transitive component → linear.
 *  Calls/other shapes defer to `let_binds_linear`. When uncertain, the
 *  delegation/recursion errs toward `true`, keeping the field tracked. */
let ctor_arg_is_linear = fn (
  arg: HirExpr, st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  let HirExpr(node: an, span: _) = arg
  match an do
    | Variable(name: vn, sigil: s) ->
      match s do
        | SigilLinear | SigilLazy -> return true
        | _ ->
          // A non-sigil variable: linear iff it was a live linear binding at
          // the match site OR a previously-consumed linear (consumed by the
          // construction itself). Both shapes mean the slot carried a linear.
          if lin_member(st, name: vn) then return true end
          return lin_consumed_member(st, name: vn)
      end
    // A borrow `&x` is never an owned linear — it does not transfer ownership.
    | Borrow(name: _, sigil: _) -> return false
    | Literal(_) -> return false
    // Compound args: recurse with the SAME liveness-independent classifier so a
    // nested linear variable already consumed by the construction (e.g. a list
    // literal `[b]` desugared to `Cons(Nil(), b)`, or `Some(%b)`) is still
    // recognised as carrying a linear. Delegating to `let_binds_linear` here is
    // unsound: its nested `Variable` case reads CURRENT liveness, and the
    // construction has already consumed those args. ANY linear component makes
    // the carrier linear (spec §Linearity: transitive linear(τ)).
    | Ctor(variant: cv, args: cargs, labels: _, sigil: csig) ->
      match csig do
        | SigilLinear | SigilLazy -> return true
        | _ ->
          if lin_ctor_enum_is_linear(defs: enum_defs, variant: cv) then return true end
          return any_ctor_arg_is_linear(args: cargs, st, sigs, tdefs, enum_defs)
      end
    | Array(elems: es) -> return any_ctor_arg_is_linear(args: es, st, sigs, tdefs, enum_defs)
    | Record(fields: fs) -> return any_record_field_is_linear(fields: fs, st, sigs, tdefs, enum_defs)
    // A Call result is classified LIVENESS-INDEPENDENTLY here: this call is
    // itself an argument of the enclosing construction, so any linear value it
    // launders (e.g. `Mix(gen: pick(x: %p))`) was ALREADY consumed by that
    // construction and is no longer live at the match site. Delegating to
    // `let_binds_linear` would read the (now-stale) live set for the call's
    // args and wrongly classify the result non-linear, demoting a field that in
    // fact carries a linear payload → silent drop / double-use (the c642e3d7
    // pre-7umo8 behavior correctly rejected this). We instead classify the call
    // statically and recurse into its args with THIS same liveness-independent
    // classifier. When the result is not PROVABLY non-linear (an opaque/closure
    // call whose return type we cannot resolve), we err toward `true` — keeping
    // the field tracked, the conservative-and-sound direction.
    | Call(func: f, args: cargs) ->
      return ctor_call_result_is_linear(
        func: f, cargs, st, sigs, tdefs, enum_defs
      )
    | CallExpr(callee: _, args: _) ->
      // Closure / field call: return type is unknown at this level, so the
      // result is NOT provably non-linear. Keep the field tracked.
      return true
    // A branch EXPRESSION (`if … then a else b end`) whose value is the
    // enclosing construction's argument. The construction has already consumed
    // any linear that one of its branches laundered (e.g.
    // `Mix(gen: if c then pick(x: %p) else … end)`), so the branch trailing
    // values must be classified with THIS liveness-independent classifier — not
    // `let_binds_linear`, whose `If`/`Match` cases fall through to `false`,
    // demoting a generic field that in fact carries a linear payload → silent
    // drop / double-use (the sibling of the 44873d2d direct-`Call` fix). ANY
    // branch yielding a linear makes the whole expression carry a linear (the
    // conservative-and-sound direction; the branches are alternatives, so a
    // linear flows out along whichever branch is taken).
    | If(cond: _, then_branch: tb, else_branch: eb) ->
      if block_trailing_value_is_linear(stmts: tb, st, sigs, tdefs, enum_defs) then return true end
      match eb do
        | Some(val: ebs) -> return block_trailing_value_is_linear(stmts: ebs, st, sigs, tdefs, enum_defs)
        | None -> return false
      end
    // A `match … do | p -> a | … end` branch expression — same reasoning as the
    // `If` arm: classify every arm's trailing value with this liveness-
    // independent classifier; any linear-yielding arm carries a linear out.
    | Match(target: _, cases: cs) ->
      return any_case_trailing_value_is_linear(cases: cs, st, sigs, tdefs, enum_defs)
    | _ ->
      // Other expression shapes: defer to the structural classifier. These do
      // not launder a construction-consumed linear through a generic slot, so
      // their liveness reads remain meaningful.
      return let_binds_linear(
        sigil: SigilImmutable, ann: None, value: arg, sigs, tdefs, enum_defs, pre_st: st
      )
  end
end

/** Liveness-INDEPENDENT linearity of a `Call(func, args)` appearing as a
 *  construction argument (so its own linear args were already consumed by the
 *  enclosing construction). Linear iff:
 *    (a) the callee's declared return type is itself statically linear, or
 *    (b) some call arg flows (by label) into a parameter whose type shares a
 *        callee type-parameter slot with the return type AND that arg is linear
 *        under `ctor_arg_is_linear` (the same liveness-independent classifier),
 *        i.e. a linear payload is laundered through the result's TyVar slot, or
 *    (c) the callee signature is unresolved — the result is not provably
 *        non-linear, so we conservatively keep it tracked.
 *  Returns false ONLY for a resolved signature with a provably non-linear
 *  return type and no linear payload flowing through a shared TyVar slot. */
let ctor_call_result_is_linear = fn (
  func: string, cargs: [ HirCallArg ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match sig_lookup(sigs, name: func) do
    | None ->
      // (c) Unresolved callee → not provably non-linear → keep tracked.
      return true
    | Some(val: SigEntry(name: _, type_params: tps, param_labels: pls, param_types: pts, ret_type: rt, throw_row: _)) ->
      // (a) Statically-linear return type.
      if is_linear_binding_type(t: rt, tdefs, enum_defs) then return true end
      // No declared type parameters → no TyVar slot can carry a laundered
      // linear; with a non-linear `rt` the result is provably non-linear.
      match tps do
        | [] -> return false
        | _ ->
          // (b) Param→result-slot flow with a liveness-independent arg check.
          return any_ctor_call_arg_propagates_linear(
            args: cargs, type_params: tps, param_labels: pls,
            param_types: pts, ret_type: rt, st, sigs, tdefs, enum_defs
          )
      end
  end
end

let any_ctor_call_arg_propagates_linear = fn (
  args: [ HirCallArg ], type_params: [ string ], param_labels: [ string ],
  param_types: [ TypeExpr ], ret_type: TypeExpr, st: LinState,
  sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match args do
    | [] -> return false
    | HirCallArg(label: l, value: v) :: rest ->
      match lookup_param_type_by_label(labels: param_labels, types: param_types, target: l) do
        | Some(val: pt) ->
          if pt_shares_tyvar_with_rt(pt, rt: ret_type, type_params) then
            // Classify the propagated arg with the SAME liveness-independent
            // classifier — its linear was consumed by the outer construction.
            if ctor_arg_is_linear(arg: v, st, sigs, tdefs, enum_defs) then return true end
          end
        | None -> ()
      end
      return any_ctor_call_arg_propagates_linear(
        args: rest, type_params, param_labels, param_types, ret_type, st, sigs, tdefs, enum_defs
      )
  end
end

let any_ctor_arg_is_linear = fn (
  args: [ HirExpr ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match args do
    | [] -> return false
    | a :: rest ->
      if ctor_arg_is_linear(arg: a, st, sigs, tdefs, enum_defs) then return true end
      return any_ctor_arg_is_linear(args: rest, st, sigs, tdefs, enum_defs)
  end
end

let any_record_field_is_linear = fn (
  fields: [ HirNamedExpr ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match fields do
    | [] -> return false
    | HirNamedExpr(name: _, value: v) :: rest ->
      if ctor_arg_is_linear(arg: v, st, sigs, tdefs, enum_defs) then return true end
      return any_record_field_is_linear(fields: rest, st, sigs, tdefs, enum_defs)
  end
end

/** Liveness-INDEPENDENT linearity of a branch-body block's VALUE. A block used
 *  as a branch of an `if`/`match` EXPRESSION yields its trailing statement's
 *  expression; classify that expression with `ctor_arg_is_linear` (the same
 *  liveness-independent classifier the enclosing construction context uses). A
 *  block whose trailing statement is not value-producing (e.g. an assignment,
 *  or it diverges) contributes no linear value along that branch → false. */
let block_trailing_value_is_linear = fn (
  stmts: [ HirStmt ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match last_stmt(stmts: stmts) do
    | None -> return false
    | Some(val: HirStmt(node: sk, span: _)) ->
      match sk do
        | Expr(expr: e) -> return ctor_arg_is_linear(arg: e, st, sigs, tdefs, enum_defs)
        | Return(expr: e) -> return ctor_arg_is_linear(arg: e, st, sigs, tdefs, enum_defs)
        | _ -> return false
      end
  end
end

/** ANY `match` arm whose trailing value is linear under the liveness-
 *  independent classifier makes the whole `match` expression carry a linear. */
let any_case_trailing_value_is_linear = fn (
  cases: [ HirMatchCase ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match cases do
    | [] -> return false
    | HirMatchCase(pattern: _, body: b) :: rest ->
      if block_trailing_value_is_linear(stmts: b, st, sigs, tdefs, enum_defs) then return true end
      return any_case_trailing_value_is_linear(cases: rest, st, sigs, tdefs, enum_defs)
  end
end

// ─── Sig-map-aware linearity classification ─────────────────────────────────

/** Determine whether the value-RHS of a `let x = expr` would yield a linear
 *  binding. Classification, in priority order:
 *  1. Sigil annotation on the let (`%`/`@`) → linear.
 *  2. Type annotation on the let (`x: %T` / `x: @T`) → linear.
 *  3. Otherwise inspect the value expression:
 *     a. Call to a function whose return type is `%T` / `@T`.
 *     b. Ctor whose owning enum has any variant with a direct linear field.
 *     c. Ctor whose any arg expression itself produces a linear value —
 *        catches the inferred-generic case `let p = Pair(fst: 0, snd: %b)`
 *        where Pair has no shallow-linear variant field but the runtime
 *        arg `b` is linear. Spec §Linearity: linear(Pair<%T,U>) = true.
 *     d. Variable that was live in the pre-check linear set (alias of linear).
 *     e. Array literal — always linear.
 *     f. Record literal `{ k1: e1, ... }` whose any field expression itself
 *        produces a linear value — parallel to (c) for record types. Catches
 *        `let r = { val: %b }` where the record type's field is generic
 *        (TyVar) but the runtime field expression is linear. Spec §Linearity:
 *        linear({ val: %T, .. }) = true.
 */
let let_binds_linear = fn (
  sigil: Sigil, ann: Option<TypeExpr>, value: HirExpr, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ], pre_st: LinState
) -> bool do
  match sigil do
    | SigilLinear | SigilLazy -> return true
    | _ ->
      match ann do
        | Some(val: t) -> if is_linear_binding_type(t, tdefs, enum_defs) then return true end
        | None -> ()
      end
      let HirExpr(node: vnode, span: _) = value
      match vnode do
        | Call(func: f, args: cargs) ->
          match sig_lookup(sigs, name: f) do
            | Some(val: SigEntry(name: _, type_params: tps, param_labels: pls, param_types: pts, ret_type: rt, throw_row: _)) ->
              // (a) Callee return type is itself linear (e.g. `bb.empty() -> %ByteBuffer`).
              if is_linear_binding_type(t: rt, tdefs, enum_defs) then return true end
              // (b) Param→result-slot flow: for any call arg paired (by
              //     label) to a parameter whose type mentions a callee
              //     type-parameter that also occurs in `rt`, if the runtime
              //     arg itself binds linear, the call's result carries the
              //     linear payload through that type-variable slot. The
              //     `type_params` gate restricts the check to true generics
              //     and avoids conflating concrete nominal names (e.g. `Bb`)
              //     with type-variable references — the linearity pass runs
              //     BEFORE typecheck's `convert_ud_to_var`, so both `TyVar`
              //     and `TyUserDefined(α, [])` are TyVar candidates in the
              //     raw HIR. Targeted check that avoids over-tracking calls
              //     like `take_bb(b: %x) -> i64` where the linear is
              //     consumed by the callee (no type-param flow into rt).
              return any_call_arg_propagates_linear(
                args: cargs,
                type_params: tps,
                param_labels: pls,
                param_types: pts,
                ret_type: rt,
                sigs,
                tdefs,
                enum_defs,
                pre_st
              )
            | None -> return false
          end
        | CallExpr(callee: _, args: _) ->
          // Closure/field call: return type unknown at this level; conservative.
          return false
        | Ctor(variant: v, args: cargs, labels: _, sigil: _) ->
          if lin_ctor_enum_is_linear(defs: enum_defs, variant: v) then return true end
          // (c) above: inferred-generic case. The variant has no shallow-
          // linear field declaration (e.g. `Pair<A,B>` with TyVar slots),
          // but the runtime arg flowing into a TyVar slot is itself linear
          // → the result Pair value carries a linear payload and must be
          // use-once-tracked. Recurse with sigil=SigilImmutable, ann=None
          // so only the value-shape contributes (the outer let's sigil
          // already handled the explicit cases above).
          return any_ctor_arg_linear(args: cargs, sigs, tdefs, enum_defs, pre_st)
        | Record(fields: fs) ->
          // (f) above: inferred-generic case for record literals. The
          // declared record type's field is TyVar (or otherwise non-shallow-
          // linear), but the runtime field expression itself binds linear —
          // the resulting record carries a linear payload and must be use-
          // once-tracked. Parallel to the Ctor branch above.
          return any_record_field_linear(fields: fs, sigs, tdefs, enum_defs, pre_st)
        | Variable(name: v, sigil: _) ->
          return lin_member(pre_st, name: v)
        | Array(_) -> return true
        | Lambda(type_params: _, params: lps, ret_type: _, requires: _, throw_row: _, body: lb) ->
          // A lambda that captures an outer linear binding is itself one-shot
          // (linear): calling it twice would double-free the captured linear.
          // Detect captures the same way the Lambda arm of check_expr_kind
          // does: collect all outer linear names referenced as free vars in
          // the body. If any are captured, the resulting closure is linear.
          let lpnames = collect_param_names(params: lps, acc: [])
          let outer_lins = lin_state_vars(st: pre_st)
          let captured_lins = collect_captured_linears(
            body: lb,
            outer_linears: outer_lins,
            bound: lpnames,
            acc: []
          )
          match captured_lins do
            | [] -> return false
            | _ :: _ -> return true
          end
        // An `if`/`match` EXPRESSION whose value is bound (e.g.
        // `let w = Mix(gen: if c then pick(x: %p) else … end)`): the bound
        // value is linear iff some branch's trailing value is linear. Without
        // this arm the `If`/`Match` falls through to `| _ -> return false`, so
        // a `let` whose RHS launders a linear through a branch expression is
        // not tracked as linear — and the scrutinee-linear gate at the match
        // site never demotes/keeps its generic fields, silently dropping the
        // payload (the binding-site half of the 44873d2d generic-field fix).
        // The branches are alternatives → ANY linear branch makes the binding
        // linear. Classification reads the LIVE set (`pre_st`): at the binding
        // site the laundered linear args are still live (the construction has
        // not yet consumed them), so the liveness-dependent classifier is the
        // correct one here (unlike the post-consumption match site).
        | If(cond: _, then_branch: tb, else_branch: eb) ->
          if block_trailing_value_binds_linear(stmts: tb, sigs, tdefs, enum_defs, pre_st) then return true end
          match eb do
            | Some(val: ebs) -> return block_trailing_value_binds_linear(stmts: ebs, sigs, tdefs, enum_defs, pre_st)
            | None -> return false
          end
        | Match(target: _, cases: cs) ->
          return any_case_trailing_value_binds_linear(cases: cs, sigs, tdefs, enum_defs, pre_st)
        | _ -> return false
      end
  end
end

/** Liveness-DEPENDENT companion of `block_trailing_value_is_linear`: the VALUE
 *  of a branch-body block used as a bound `if`/`match` expression. Classifies
 *  the trailing statement's expression with `let_binds_linear` (reading the
 *  LIVE set `pre_st`, since the binding site has not yet consumed the laundered
 *  linear). Non-value-producing trailing statements contribute no linear. */
let block_trailing_value_binds_linear = fn (
  stmts: [ HirStmt ], sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ], pre_st: LinState
) -> bool do
  match last_stmt(stmts: stmts) do
    | None -> return false
    | Some(val: HirStmt(node: sk, span: _)) ->
      match sk do
        | Expr(expr: e) ->
          return let_binds_linear(sigil: SigilImmutable, ann: None, value: e, sigs, tdefs, enum_defs, pre_st)
        | Return(expr: e) ->
          return let_binds_linear(sigil: SigilImmutable, ann: None, value: e, sigs, tdefs, enum_defs, pre_st)
        | _ -> return false
      end
  end
end

/** ANY `match` arm whose trailing value binds linear under `let_binds_linear`
 *  makes the whole `match` expression's value linear. */
let any_case_trailing_value_binds_linear = fn (
  cases: [ HirMatchCase ], sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ], pre_st: LinState
) -> bool do
  match cases do
    | [] -> return false
    | HirMatchCase(pattern: _, body: b) :: rest ->
      if block_trailing_value_binds_linear(stmts: b, sigs, tdefs, enum_defs, pre_st) then return true end
      return any_case_trailing_value_binds_linear(cases: rest, sigs, tdefs, enum_defs, pre_st)
  end
end

let any_ctor_arg_linear = fn (
  args: [ HirExpr ], sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ], pre_st: LinState
) -> bool do
  match args do
    | [] -> return false
    | a :: rest ->
      if let_binds_linear(
        sigil: SigilImmutable,
        ann: None,
        value: a,
        sigs,
        tdefs,
        enum_defs,
        pre_st
      ) then return true end
      return any_ctor_arg_linear(args: rest, sigs, tdefs, enum_defs, pre_st)
  end
end

let any_record_field_linear = fn (
  fields: [ HirNamedExpr ], sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ], pre_st: LinState
) -> bool do
  match fields do
    | [] -> return false
    | HirNamedExpr(name: _, value: v) :: rest ->
      if let_binds_linear(
        sigil: SigilImmutable,
        ann: None,
        value: v,
        sigs,
        tdefs,
        enum_defs,
        pre_st
      ) then return true end
      return any_record_field_linear(fields: rest, sigs, tdefs, enum_defs, pre_st)
  end
end

/** Param→result-slot linear propagation check for a Call. For each call arg
 *  paired (by label) to its declared parameter type `pt`:
 *    - If `pt` shares any callee-declared `type_params` slot with `rt` AND
 *      the arg expression itself binds linear (recursive
 *      `let_binds_linear`), the call result carries the linear payload
 *      through that TyVar slot — the outer let must track it.
 *  Avoids over-tracking calls like `take_bb(b: %x) -> i64` (rt has no
 *  callee-tyvar flow) or `bb.free(buf: %x) -> bool` (rt has no tyvars). */
let any_call_arg_propagates_linear = fn (
  args: [ HirCallArg ],
  type_params: [ string ],
  param_labels: [ string ],
  param_types: [ TypeExpr ],
  ret_type: TypeExpr,
  sigs: [ SigEntry ],
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ],
  pre_st: LinState
) -> bool do
  // Fast path: no declared type parameters → no flow possible.
  match type_params do
    | [] -> return false
    | _ -> ()
  end
  return any_call_arg_propagates_linear_go(
    args, type_params, param_labels, param_types, ret_type, sigs, tdefs, enum_defs, pre_st
  )
end

let any_call_arg_propagates_linear_go = fn (
  args: [ HirCallArg ],
  type_params: [ string ],
  param_labels: [ string ],
  param_types: [ TypeExpr ],
  ret_type: TypeExpr,
  sigs: [ SigEntry ],
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ],
  pre_st: LinState
) -> bool do
  match args do
    | [] -> return false
    | HirCallArg(label: l, value: v) :: rest ->
      match lookup_param_type_by_label(labels: param_labels, types: param_types, target: l) do
        | Some(val: pt) ->
          if pt_shares_tyvar_with_rt(pt, rt: ret_type, type_params) then
            if let_binds_linear(
              sigil: SigilImmutable,
              ann: None,
              value: v,
              sigs,
              tdefs,
              enum_defs,
              pre_st
            ) then return true end
          end
        | None -> ()
      end
      return any_call_arg_propagates_linear_go(
        args: rest,
        type_params,
        param_labels,
        param_types,
        ret_type,
        sigs,
        tdefs,
        enum_defs,
        pre_st
      )
  end
end

// ─── Entry point ─────────────────────────────────────────────────────────────

/** Run the linearity pass over every function and handler-arm in `prog`: each linear binding consumed exactly once, no leaks across throwable calls. Raises TypeError on the first violation. */
export let check_program = fn (prog: HirProgram) -> unit throws { TypeError } do
  let sigs = build_sig_map(prog)
  // whole-program caught-variant set. Computed once and threaded
  // (via LinState.caught_set) into every function check; consulted at each
  // divergent throw to decide strict-vs-relaxed leak checking.
  let caught_set = compute_caught_variants(prog)
  let HirProgram(
    caps: _,
    functions: fs,
    externals: _,
    handler_bindings: hbs,
    enum_defs: edefs,
    exception_groups: _,
    value_binding_names: _,
    type_defs: tdefs,
    visible_enum_names: _
  ) = prog
  check_functions(funcs: fs, sigs, tdefs, enum_defs: edefs, caught_set)
    return check_handler_bindings(bindings: hbs, sigs, tdefs, enum_defs: edefs, caught_set)
end

let check_functions = fn (
  funcs: [ HirFunction ],
  sigs: [ SigEntry ],
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ],
  caught_set: [ string ]
) -> unit throws { TypeError } do
  match funcs do
    | [] -> return ()
    | f :: rest ->
      check_function(func: f, sigs, tdefs, enum_defs, caught_set)
      return check_functions(funcs: rest, sigs, tdefs, enum_defs, caught_set)
  end
end

let check_handler_bindings = fn (
  bindings: [ HirHandlerBindingEntry ], sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ], caught_set: [ string ]
) -> unit throws { TypeError } do
  match bindings do
    | [] -> return ()
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      check_handler_arms(arms, sigs, tdefs, enum_defs, caught_set)
      return check_handler_bindings(bindings: rest, sigs, tdefs, enum_defs, caught_set)
  end
end

let check_handler_arms = fn (
  arms: [ HirHandlerArm ],
  sigs: [ SigEntry ],
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ],
  caught_set: [ string ]
) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(arm: f, cont_binder: kb) :: rest ->
      check_function_with_kont(func: f, kont: kb, sigs, tdefs, enum_defs, caught_set)
      return check_handler_arms(arms: rest, sigs, tdefs, enum_defs, caught_set)
  end
end

let check_function = fn (
  func: HirFunction,
  sigs: [ SigEntry ],
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ],
  caught_set: [ string ]
) -> unit throws { TypeError } do
  return check_function_with_kont(func, kont: None, sigs, tdefs, enum_defs, caught_set)
end

/** Check one function body for linearity. When `kont` is `Some(k)`, the
 *  cont_binder `k` is seeded into the live set and into `must_consume` so
 *  that the path-sensitive check (a) detects `k` left live at function end
 *  and (b) detects `k` not consumed before any early `return` (the latter
 *  via the must_consume check in check_stmt Return).
 */
let check_function_with_kont = fn (
  func: HirFunction,
  kont: Option<string>,
  sigs: [ SigEntry ],
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ],
  caught_set: [ string ]
) -> unit throws { TypeError } do
  let HirFunction(
    name: fn_name,
    type_params: _,
    params: ps,
    ret_type: _,
    throw_row: _,
    body: b,
    span: sp,
    file: _,
    requires: _
  ) = func
  // The mangled `name` already encodes the originating file path, so it alone
  // pinpoints the (file#function) site in the strict divergent-arm diagnostic.
  let cur_fn_label = fn_name
  match b do
      | EagerBody(stmts) ->
        // reject a returned record/ADT holding a
        // borrow of a local linear (use-after-free; owner-locality heuristic).
        check_borrow_escape_form_b(fn_name: cur_fn_label, params: ps, stmts, sigs, enum_defs, tdefs)
        // Seed live set with linear params; push frame snapshot so the
        // body's throwable-call check excludes them (call-site contract).
        let initial_vars = collect_linear_params(params: ps, tdefs, enum_defs, acc: [])
        // When a cont_binder k is present it must be consumed on every exit
        // path (including early `return`). Two cases:
        //   (a) synthesized handler binding arms: synthesize_handler has
        //       already added k as a SigilLazy param, so k is already in
        //       initial_vars — only add k to must_consume, not to vars again.
        //   (b) inline handler expressions: k is NOT a param (no
        //       synthesize_handler call); add k to both vars and must_consume.
        let kont_vars = match kont do | None -> [] | Some(val: k) -> k :: [] end
        // Seed k into the live set only when it is NOT already present via params.
        let all_vars = match kont do
          | None -> initial_vars
          | Some(val: k) ->
            if str_member(xs: initial_vars, target: k) then initial_vars
            else k :: initial_vars
            end
        end
        let st0 = LinState(
          vars: all_vars,
          frame_stack: [],
          must_consume: kont_vars,
          consumed: [],
          caught_set,
          catch_stack: [],
          cur_fn: cur_fn_label,
          // Record every `let name = <ctor/record/…>` in the body so a match
          // on a locally-constructed scrutinee can recover its construction
          // expression and read off how each generic field was instantiated
          // (the linearity pass carries no inferred type-args).
          ctor_env: collect_ctor_bindings(stmts, acc: [])
        )
        let st1 = lin_push_frame(st: st0)
        let st2 = check_stmts(stmts, st: st1, sigs, tdefs, enum_defs)
        // Function-end consumption check: any linear param or local left
        // live raises Unused.
        return require_empty_or_droppable(vars: lin_state_vars(st: st2), params: ps, span: sp)
      | LazyBody(_) -> return ()
    end
end

/** Param is linear when *either* sigil or type marks it: mirrors
 *  `let_binds_linear` for `let`-bindings. Rejects the silent-discard
 *  where `fn (%x: T)` (sigil-only) was previously dropped by HIR
 * conversion.
 */
let param_binds_linear = fn (
  sig: Sigil,
  t: TypeExpr,
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ]
) -> bool do
  match sig do
    | SigilLinear | SigilLazy -> return true
    | _ -> return is_linear_binding_type(t, tdefs, enum_defs)
  end
end

let collect_linear_params = fn (
  params: [ HirParam ],
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ],
  acc: [ string ]
) -> [ string ] do
  match params do
    | [] -> return acc
    | HirParam(label: _, name: n, sigil: s, typ: t) :: rest ->
      if param_binds_linear(sig: s, t, tdefs, enum_defs) then
        return collect_linear_params(params: rest, tdefs, enum_defs, acc: n :: acc)
      end
      return collect_linear_params(params: rest, tdefs, enum_defs, acc)
  end
end

let require_empty_or_droppable = fn (
  vars: [ string ], params: [ HirParam ], span: Span
) -> unit throws { TypeError } do
  match vars do
    | [] -> return ()
    | n :: rest ->
      // A linear param of an auto-droppable inner (e.g., %i64) was added
      // for symmetry but doesn't need consumption. Skip those silently here;
      // a warning for them belongs to a separate diagnostics pass.
      if param_inner_is_auto_droppable(params, name: n) then
        return require_empty_or_droppable(vars: rest, params, span)
      end
      throw LinearUnused(name: n, span)
  end
end

let param_inner_is_auto_droppable = fn (params: [ HirParam ], name: string) -> bool do
  match params do
    | [] -> return false
    | HirParam(label: _, name: pn, sigil: _, typ: t) :: rest ->
      if pn == name then
        match t do
          | TyLinear(inner: i) -> return is_auto_droppable(t: i)
          | _ -> return false
        end
      end
      return param_inner_is_auto_droppable(params: rest, name)
  end
end

/** Check that linear bindings introduced inside a divergent arm are consumed
 *  before divergence.  `arm_out` is the LinState after walking the arm body;
 *  `outer_vars` is the live-var set that existed BEFORE entering the arm (i.e.
 *  `lin_state_vars(st)` at the point of entry).  Any variable that is in
 *  `arm_out.vars` but was NOT in `outer_vars` was introduced inside the arm
 *  scope and must be consumed — otherwise it silently leaks past a `return` /
 *  `throw`. */
let check_divergent_arm_unused = fn (
  arm_out: LinState, outer_vars: [ string ], span: Span
) -> unit throws { TypeError } do
  let arm_vars = lin_state_vars(st: arm_out)
  let inner_leaked = filter_not_in(xs: arm_vars, exclude: outer_vars, acc: [])
  return require_empty_or_droppable(vars: inner_leaked, params: [], span)
end

/** Like `check_divergent_arm_unused` but also checks outer-scope linear vars.
 *  Used in all-divergent contexts (every arm returns/throws): since every
 *  execution path exits via a divergent arm, outer-scope linears that were
 *  not consumed in an arm constitute a real leak. */
let check_divergent_arm_linears = fn (arm_out: LinState, span: Span) -> unit throws { TypeError } do
  // In an all-divergent arm, ALL remaining live vars (both inner-scope and
  // outer-scope) must have been consumed before the arm's return/throw.
  return require_empty_or_droppable_fn(
    vars: lin_state_vars(st: arm_out), params: [], span, fn_label: lin_get_cur_fn(st: arm_out)
  )
end

/** Like require_empty_or_droppable but embeds the enclosing function label in
 * the leak diagnostic, so the strict divergent-arm leaks point at
 *  the exact (file#function) site even though the linearity diagnostic prefix
 *  is always the compile-entry path. */
let require_empty_or_droppable_fn = fn (
  vars: [ string ], params: [ HirParam ], span: Span, fn_label: string
) -> unit throws { TypeError } do
  match vars do
    | [] -> return ()
    | n :: rest ->
      if param_inner_is_auto_droppable(params, name: n) then
        return require_empty_or_droppable_fn(vars: rest, params, span, fn_label)
      end
      throw LinearUnused(name: n ++ " in " ++ fn_label, span)
  end
end

/** decide whether a divergent (then-only) `if … end` arm gets the
 *  STRICT leak check (all live linears, including outer-scope, must be
 *  consumed) or the RELAXED one (only inner-scope leaks). `st` is the
 *  pre-arm state (carries the program-wide caught_set and the local
 *  catch-stack).
 *
 *  Strict when the arm:
 *   • diverges by `return` (the function continuation is abandoned — any live
 *     linear leaks, no upstream can reclaim it); OR
 *   • diverges by `throw v` where `v` is NOT caught by a local try/catch frame
 *     AND `v` is in the whole-program caught_variants set (incl. "Exn"
 *     subsumption) — i.e. some upstream catch may receive it, so the
 *     abandoned linear is a real leak.
 *
 *  Relaxed when the throw is caught locally (existing T-TryCatch handles it)
 *  or when `v ∉ caught_variants(Π)` (propagates to process exit → resource
 *  reclaimed by termination). */
let divergent_arm_is_strict = fn (then_branch: [ HirStmt ], st: LinState) -> bool do
  match divergence_throw_variant(stmts: then_branch) do
    // return-style (or non-throw) divergence → always strict.
    | None -> return true
    | Some(val: v) ->
      // Caught by an enclosing local try/catch → existing reconciliation;
      // no extra strict check here.
      if lin_throw_caught_locally(st, v) then return false end
      // Escapes the function: strict iff some upstream catch may receive it.
      return caught_covers(caught: lin_get_caught_set(st), v)
  end
end

// ─── Statement walk ──────────────────────────────────────────────────────────

let check_stmts = fn (
  stmts: [ HirStmt ], st: LinState, sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> LinState throws { TypeError } do
  match stmts do
    | [] -> return st
    | HirStmt(node: nd, span: sp) :: rest ->
      let st1 = check_stmt(stmt: nd, st, sigs, tdefs, enum_defs, span: sp, at_stmt_level: true)
      return check_stmts(stmts: rest, st: st1, sigs, tdefs, enum_defs)
  end
end

let check_stmt = fn (
  stmt: HirStmtKind, st: LinState, sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ], span: Span, at_stmt_level: bool
) -> LinState throws { TypeError } do
  match stmt do
    | Let(name: n, sigil: sig, typ: ann, value: v) ->
      // Walk RHS first so any linear use inside it is consumed before the
      // new binding is added. Pass pre-check st so Variable-alias detection
      // can see whether the RHS variable was live before being consumed.
      let st1_raw = check_expr(expr: v, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      // Record any linear consumed by the RHS that the live-set delta shows is
      // gone but that direct consumption-tracking missed — specifically a linear
      // laundered through an `if`/`match` EXPRESSION branch, whose consumed-ness
      // the branch-join drops. Keeping it in the consumed set lets the later
      // match-site generic-field demotion check (a liveness-independent
      // classifier) recognise it (e.g. `let w = Mix(gen: if c then f(%p) ...)`).
      let st1 = lin_record_consumed_since(st: st1_raw, pre_live: lin_state_vars(st))
      let binds_lin = let_binds_linear(
        sigil: sig,
        ann,
        value: v,
        sigs,
        tdefs,
        enum_defs,
        pre_st: st
      )
      if binds_lin then return lin_add(st: st1, name: n) end
      // Even for non-linear bindings, clear `n` from consumed so a previously
      // consumed linear with the same name doesn't falsely fire LinearReuse
      // in the new binding's scope (shadowing).
      return lin_clear_consumed(st: st1, name: n)
    | Expr(expr: e) ->
      // Top-of-Stmt expression: a root Call here triggers the throwable-
      // call leak check. Nested calls inside larger
      // expressions are not at stmt level — they consume their inputs and
      // close the leak window via the surrounding consumer.
      return check_expr(expr: e, st, sigs, tdefs, enum_defs, at_stmt_level)
    | Return(expr: e) ->
      // Walk the returned expression so any linear uses inside it are consumed.
      let st1 = check_expr(expr: e, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      // must_consume vars (cont_binders from with-@k handler arms) must be
      // consumed on every exit path, including early returns. After walking
      // the return-expression any must_consume var still live has leaked.
      match find_live_must_consume(
        mc: lin_get_must_consume(st: st1),
        live: lin_state_vars(st: st1)
      ) do
        | Some(val: leaked) -> throw LinearUnused(name: leaked, span)
        | None -> ()
      end
      return st1
    | Assign(target: t, value: v) ->
      let st1 = check_expr(expr: t, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      return check_expr(expr: v, st: st1, sigs, tdefs, enum_defs, at_stmt_level: false)
    | Try(body: b, catch_param: cp, catch_body: cb) ->
      // Push pre-try snapshot for Strategy A: anything alive at this point
      // is the catch arm's responsibility on throw. Throwable-call check
      // inside the body excludes those vars from "leaked".
      let pre_try_vars = lin_state_vars(st)
      let pre_try_consumed = lin_state_consumed(st)
      // push a local catch frame for the TRY-BODY walk only, so a
      // divergent `throw v` inside the body whose `v` this try catches is
      // recognised as locally handled (the existing T-TryCatch reconciliation
      // governs its linearity) and does NOT trigger the strict divergent-arm
      // leak check. Group expansion is handled by the whole-program caught_set;
      // the local frame uses the unexpanded constructor/catch-all names, which
      // covers the dominant cases (catch-all `_`/var → "Exn"; exact ctor).
      let local_caught = caught_variants_of_try(
        catch_param: cp,
        catch_body: cb,
        groups: [],
        acc: []
      )
      let st_try0 = lin_push_frame(st)
      let st_try = lin_push_catch(st: st_try0, frame: CatchFrame(caught: local_caught))
      // Pre-scan: lightweight walk up to the first throwable call or raise to
      // find outer linears consumed BEFORE any possible throw. Uses a
      // scan-only pass (no full linearity check) to avoid calling check_stmt
      // from within the SCC at this step.
      // Consumptions after the first throw point are on the success
      // continuation only and remain available in catch arms.
      // scan_stmts_until_throw returns the subset of pre_try_vars consumed
      // before the first throw. No filter needed (scan only tracks pre_try_vars).
      let outer_consumed_before_throw = scan_stmts_until_throw(
        stmts: b, outer_vars: pre_try_vars, consumed: [], sigs
      )
      // Full try body check (the pre-scan covers only up to the throw point;
      // this walk checks the remainder and enforces all linearity rules).
      let st_after_try = check_stmts(stmts: b, st: st_try, sigs, tdefs, enum_defs)
      // Pop both the throwable-call frame snapshot and the local catch frame:
      // the catch body and the outer continuation are NOT guarded by this try.
      let st_after_try1 = lin_pop_frame(st: st_after_try)
      let st_after_try2 = lin_pop_catch(st: st_after_try1)
      // Build catch arm entry state: pre-try vars minus those consumed before
      // the first throw, consumed set extended with those consumed before throw.
      let catch_vars = filter_not_in(
        xs: pre_try_vars,
        exclude: outer_consumed_before_throw,
        acc: []
      )
      let catch_consumed = append_consumed(xs: pre_try_consumed, ys: outer_consumed_before_throw)
      let st_catch_in = lin_restore_state(st: st_after_try2, vs: catch_vars, co: catch_consumed)
      let st_catch_out = check_stmts(stmts: cb, st: st_catch_in, sigs, tdefs, enum_defs)
      let post_catch_vars = lin_state_vars(st: st_catch_out)
      let post_try_vars = lin_state_vars(st: st_after_try2)
      // Before checking arm consistency, detect linears introduced INSIDE
      // the try body that were not consumed. These must fire E2007
      // (LinearUnused) rather than E2009 (LinearMismatch) — the programmer's
      // problem is an unconsumed binding, not a mismatch between arms.
      let try_inner_leaked = filter_not_in(xs: post_try_vars, exclude: pre_try_vars, acc: [])
      require_empty_or_droppable(vars: try_inner_leaked, params: [], span)
      // spec §T-TryCatch ρ_residual escape: when the try-body has
      // a throw point whose variant ESCAPES this catch (ρ_residual ≠ ∅), there
      // is an uncaught-throw path that exits the try (and the enclosing
      // function) WITHOUT running any catch arm. On that path the only outer
      // linears reclaimed are those the try-body consumed BEFORE the escape
      // point; any outer linear still live there leaks. Spec models this by
      // adding a synthetic `residual` member to the reachable-path set A with
      // `Δ_residual = linConsumed(s̄_pre-throw, Γ)` — here `pre_try_vars ⊆
      // outer_consumed_before_throw`. This is independent of whether the
      // try-body diverges: it covers BOTH the all-divergent under-rejection
      // (p4d) and the survivor-with-residual case (p11, body has a success
      // tail yet still leaks on the escape). When the catch covers every
      // body-throw (residual = ∅) the gate is silent — every throw runs a
      // catch arm and the normal arm-reconciliation / catch-arm consumption
      // suffices (cf. operationally-safe p4b).
      if try_body_has_residual_escape(stmts: b, local_caught, sigs) then
        let residual_leaked = filter_not_in(
          xs: pre_try_vars, exclude: outer_consumed_before_throw, acc: []
        )
        require_empty_or_droppable(vars: residual_leaked, params: [], span)
      end
      // When the try body is divergent (always raises/returns/unreachable),
      // there is no normal-completion path out of the body — only the catch
      // arms run for the program's outer continuation. The post_try_vars vs
      // post_catch_vars equality is then vacuous (the try tail is unreachable);
      // skip it and propagate the catch arm's output state. Leak-by-omission on
      // the catch arm itself remains caught by the function-end consumption
      // check; the residual-escape leg above already ran.
      let try_body_diverges = stmts_diverge(stmts: b)
      if try_body_diverges then
        // divergence-by-THROW dispatches to a catch arm (caught
        // locally → catch-arm consumption covers the outer linears), but
        // divergence-by-RETURN abandons the function continuation WITHOUT
        // running any catch arm. On a return-style divergence the catch arm is
        // unreachable, so its consumption must NOT be credited for the outer
        // linears: any outer linear still live at the try-body's return point
        // leaks. `divergence_throw_variant` returns None for return-style
        // divergence (and Some(v) for throw-style); gate the leak check on it
        // so the catch-all `_` arm can no longer mask the normal-exit leak.
        match divergence_throw_variant(stmts: b) do
          | None ->
            let return_surviving = filter_in(xs: post_try_vars, keep: pre_try_vars, acc: [])
            require_empty_or_droppable(vars: return_surviving, params: [], span)
          | Some(_) -> ()
        end
        return lin_set_vars(st: st_after_try2, vs: post_catch_vars)
      end
      if !vars_equal(a: post_try_vars, b: post_catch_vars) then
        throw LinearMismatch(detail: "try/catch arms diverge on linear set", span)
      end
      return lin_set_vars(st: st_after_try2, vs: post_try_vars)
    | Inject(handlers: _, body: b) -> return check_stmts(stmts: b, st, sigs, tdefs, enum_defs)
  end
end

// ─── Expression walk ─────────────────────────────────────────────────────────

let check_expr = fn (
  expr: HirExpr, st: LinState, sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ], at_stmt_level: bool
) -> LinState throws { TypeError } do
  let HirExpr(node: nd, span: sp) = expr
  return check_expr_kind(expr: nd, st, sigs, tdefs, enum_defs, span: sp, at_stmt_level)
end

let check_expr_kind = fn (
  expr: HirExprKind, st: LinState, sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ], span: Span, at_stmt_level: bool
) -> LinState throws { TypeError } do
  match expr do
    | Literal(_) -> return st
    | Variable(name: n, sigil: _) ->
      if lin_member(st, name: n) then return lin_remove(st, name: n) end
      if lin_consumed_member(st, name: n) then throw LinearReuse(name: n, span) end
      return st
    | Borrow(name: n, sigil: _) ->
      // T-App-BorrowLin liveness premise: a borrow `&x` of a linear binding
      // requires the target to still be LIVE (x:^1 ∈ Γ) — the borrow does not
      // consume it, but borrowing an already-moved binding is use-after-move.
      // A live linear binding stays in `vars`; once moved it is in `consumed`.
      // Non-linear bindings appear in neither set and borrow freely.
      if lin_consumed_member(st, name: n) then throw BorrowOfConsumed(name: n, span) end
      return st
    | BinOp(left: l, op: _, right: r) ->
      let st1 = check_expr(expr: l, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      return check_expr(expr: r, st: st1, sigs, tdefs, enum_defs, at_stmt_level: false)
    | UnOp(op: _, operand: o) ->
      return check_expr(expr: o, st, sigs, tdefs, enum_defs, at_stmt_level: false)
    | Call(func: f, args: cargs) ->
      let st1 = check_call_args(args: cargs, st, sigs, tdefs, enum_defs)
      // If `f` itself is a linear-bound variable (let %g = …, or a closure
      // that captured a linear), consume it here too. Detect double-call
      // (second invocation of a one-shot closure) as LinearReuse.
      if lin_consumed_member(st: st1, name: f) then throw LinearReuse(name: f, span) end
      let st2 = if lin_member(st: st1, name: f) then lin_remove(st: st1, name: f) else st1 end
      // Throwable-call leak check — only at stmt level.
      if at_stmt_level then
        check_throwable_leak(func: f, st: st2, sigs, span)
      end
      return st2
    | CallExpr(callee: c, args: cargs) ->
      // Closure/field call: check callee expression (may consume a linear),
      // then check arguments. Conservative: assume potentially throwable.
      let st1 = check_expr(expr: c, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      return check_call_args(args: cargs, st: st1, sigs, tdefs, enum_defs)
    | Ctor(variant: _, args: cargs, labels: _, sigil: _) ->
      return check_exprs(exprs: cargs, st, sigs, tdefs, enum_defs)
    | Record(fields: fs) ->
      return check_named_exprs(fields: fs, st, sigs, tdefs, enum_defs)
    | Array(elems: es) ->
      return check_exprs(exprs: es, st, sigs, tdefs, enum_defs)
    | Index(target: t, index: i) ->
      // Array indexing is a borrow-like operation: the array stays live after
      // a[i] read or a[i] <- v write. Do NOT consume the array target here.
      // Move-out of linear-element arrays (a[i] consuming elem) requires
      // per-Index typing; left to a future linearity follow-up.
      // Only recurse into the index expression (may itself use linears).
      t
      return check_expr(expr: i, st, sigs, tdefs, enum_defs, at_stmt_level: false)
    | FieldAccess(target: t, field: _) ->
      return check_expr(expr: t, st, sigs, tdefs, enum_defs, at_stmt_level: false)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let st1 = check_expr(expr: c, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      let then_diverges = stmts_diverge(stmts: tb)
      let st_then = check_stmts(stmts: tb, st: st1, sigs, tdefs, enum_defs)
      match eb do
        | None ->
          if then_diverges then
            // Then-branch always exits; only the fall-through path matters for
            // the outer continuation. flow-sensitive dispatch:
            //   • return-divergence, OR a throw whose variant is catchable
            //     whole-program (and not caught by a local try/catch frame) →
            //     STRICT: every live linear (outer-scope included) must be
            //     consumed before the divergence, else it leaks on this path.
            //   • throw that propagates to process exit (variant ∉ caught_set)
            //     or is caught locally → RELAXED: only inner-scope linears
            //     introduced inside the arm must be consumed.
            if divergent_arm_is_strict(then_branch: tb, st: st1) then
              check_divergent_arm_linears(arm_out: st_then, span)
            else
              check_divergent_arm_unused(
                arm_out: st_then,
                outer_vars: lin_state_vars(st: st1),
                span
              )
            end
            return st1
          end
          // Without an else, the linear set must be the same on both paths
          // (the no-else path is just `st1`).
          let v1 = lin_state_vars(st: st1)
          let vt = lin_state_vars(st: st_then)
          if !vars_equal(a: v1, b: vt) then
            throw LinearMismatch(
              detail: "if-without-else branches diverge on linear set: pre=" ++ join_simple(xs: v1) ++ " then=" ++ join_simple(xs: vt),
              span
            )
          end
          return st1
        | Some(val: ebs) ->
          let else_diverges = stmts_diverge(stmts: ebs)
          let st_else = check_stmts(stmts: ebs, st: st1, sigs, tdefs, enum_defs)
          // Both arms (divergent or not) must consume all inner-scope linears they
          // introduce. Project each arm's exit state onto outer_vars to get the
          // outer-projected remaining (linears NOT consumed by that arm).
          let outer_vars = lin_state_vars(st: st1)
          check_divergent_arm_unused(arm_out: st_then, outer_vars, span)
          check_divergent_arm_unused(arm_out: st_else, outer_vars, span)
          let outer_rem_then = filter_in(xs: lin_state_vars(st: st_then), keep: outer_vars, acc: [])
          let outer_rem_else = filter_in(xs: lin_state_vars(st: st_else), keep: outer_vars, acc: [])
          // Consistency rules:
          // - Non-divergent vs non-divergent: require equality.
          // - Non-divergent vs divergent: require div_rem ⊆ non_div_rem.
          // - Both divergent: require equality AND require all outer linears consumed.
          if then_diverges && else_diverges then
            // All-diverged: both arms must agree on outer consumption.
            if !vars_equal(a: outer_rem_then, b: outer_rem_else) then
              throw LinearMismatch(detail: "match arms diverge on outer-linear consumption", span)
            end
            // Additionally, all outer linears must have been consumed: the join
            // point is unreachable, so any outer linear still live is a real leak.
            check_divergent_arm_linears(arm_out: st_then, span)
            return lin_set_vars(st: st1, vs: [])
          end
          if then_diverges then
            // Then diverges, else does not: then_rem ⊆ else_rem.
            if !outer_rem_subset_of(a: outer_rem_then, b: outer_rem_else) then
              throw LinearMismatch(detail: "match arms diverge on outer-linear consumption", span)
            end
            return lin_set_vars(st: st1, vs: outer_rem_else)
          end
          if else_diverges then
            // Else diverges, then does not: else_rem ⊆ then_rem.
            if !outer_rem_subset_of(a: outer_rem_else, b: outer_rem_then) then
              throw LinearMismatch(detail: "match arms diverge on outer-linear consumption", span)
            end
            return lin_set_vars(st: st1, vs: outer_rem_then)
          end
          // Neither diverges: require equality.
          if !vars_equal(a: outer_rem_then, b: outer_rem_else) then
            throw LinearMismatch(detail: "match arms diverge on outer-linear consumption", span)
          end
          return lin_set_vars(st: st1, vs: outer_rem_then)
      end
    | Match(target: t, cases: cs) ->
      // P-Var: determine if the scrutinee is a live linear variable *before*
      // it is consumed by check_expr below. A plain `| x ->` pattern that
      // receives a linear scrutinee must track x as linear (q = 1) even
      // though x carries no % sigil itself.
      let scrutinee_linear = is_linear_scrutinee(target: t, st)
      let st1 = check_expr(expr: t, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      // Thread the scrutinee expression `t` so each PCtor arm can recover the
      // scrutinee's construction (via st1's ctor_env) and demote generic
      // (TyVar) fields instantiated to a non-linear arg (approach (a)).
      return check_match_cases(cases: cs, st: st1, sigs, tdefs, enum_defs, span, scrutinee_linear, scrutinee: t)
    | While(cond: c, body: b) ->
      // T-While (/ spec t9cl.8): the cond expression is
      // evaluated an unbounded number of times (once per iteration plus the
      // final false). A linear binding may only be consumed once, so the
      // cond must NOT consume any linear binding live before the loop.
      // We snapshot the pre-cond live set and reject if check_expr on
      // the cond removes any linear from it.
      let pre_vars = lin_state_vars(st)
      let st_cond = check_expr(expr: c, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      let post_cond_vars = lin_state_vars(st: st_cond)
      if !vars_equal(a: pre_vars, b: post_cond_vars) then
        throw LinearMismatch(
          detail: "while-cond consumes linear binding(s); the cond runs an unbounded number of times so any linear consume in it is unsound (pre=" ++ join_simple(xs: pre_vars) ++ " post-cond=" ++ join_simple(xs: post_cond_vars) ++ ")",
          span
        )
      end
      let st_body = check_stmts(stmts: b, st: st_cond, sigs, tdefs, enum_defs)
      // While body must preserve linear set (it may run zero times).
      if !vars_equal(a: lin_state_vars(st: st_cond), b: lin_state_vars(st: st_body)) then
        throw LinearMismatch(detail: "while body diverges on linear set", span)
      end
      return st_cond
    | For(var: _, start: s, end_expr: e, body: b) ->
      let st1 = check_expr(expr: s, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      let st2 = check_expr(expr: e, st: st1, sigs, tdefs, enum_defs, at_stmt_level: false)
      let st_body = check_stmts(stmts: b, st: st2, sigs, tdefs, enum_defs)
      if !vars_equal(a: lin_state_vars(st: st2), b: lin_state_vars(st: st_body)) then
        throw LinearMismatch(detail: "for body diverges on linear set", span)
      end
      return st2
    | Lambda(type_params: _, params: ps, ret_type: _, requires: _, throw_row: _, body: b) ->
      // Lambda body is its own frame; outer linears captured by the lambda
      // are tracked via `src/typecheck/capture.nx`. Walk the body in a
      // fresh state seeded only with the lambda's own linear params.
      let lparams = collect_linear_params(params: ps, tdefs, enum_defs, acc: [])
      let lst0 = lin_set_vars(st: lin_empty(), vs: lparams)
      let lst1 = lin_push_frame(st: lst0)
      let lst2 = check_stmts(stmts: b, st: lst1, sigs, tdefs, enum_defs)
      // A lambda body that leaves linear params unconsumed is a type error
      // at construction time.
      require_empty_or_droppable(vars: lin_state_vars(st: lst2), params: ps, span)
      // Outer linear bindings referenced (free) inside the body are
      // consumed by the closure capture (one consume per captured linear
      // when the lambda's type is wrapped in `%`).
      let pnames = collect_param_names(params: ps, acc: [])
      let outer_linears = lin_state_vars(st)
      let captured = collect_captured_linears(body: b, outer_linears, bound: pnames, acc: [])
      return consume_all(st, names: captured)
    | Raise(expr: e) ->
      // After throw, control transfers to the catch arm; remaining stmts
      // are unreachable. Walk the raised value to consume any linears in it
      // (rare, but the value can reference linear bindings).
      return check_expr(expr: e, st, sigs, tdefs, enum_defs, at_stmt_level: false)
    | Force(expr: e) ->
      // `force(@x)` consumes the lazy. The inner Variable visit handles
      // consumption.
      return check_expr(expr: e, st, sigs, tdefs, enum_defs, at_stmt_level: false)
    | Thunk(body: b) ->
      // The thunk body runs deferred; we don't track linears across the
      // deferral here (the @T binder check in src/ir/linearity.nx covers
      // the lazy-binding-specific case).
      return check_expr(expr: b, st, sigs, tdefs, enum_defs, at_stmt_level: false)
    | ExternalRef(_) -> return st
    | Handler(cap_name: _, requires: _, arms) ->
      // Check each inline handler arm for linearity. Arms with a cont_binder
      // (`with @k`) need path-sensitive checking — k must be consumed on every
      // exit path. check_function_with_kont handles both the inline case (k
      // not yet a param) and the synthesized-binding case (k already a param).
      check_handler_arms(arms, sigs, tdefs, enum_defs, caught_set: lin_get_caught_set(st))
      return st
  end
end

let check_exprs = fn (
  exprs: [ HirExpr ], st: LinState, sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> LinState throws { TypeError } do
  match exprs do
    | [] -> return st
    | e :: rest ->
      let st1 = check_expr(expr: e, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      return check_exprs(exprs: rest, st: st1, sigs, tdefs, enum_defs)
  end
end

let check_call_args = fn (
  args: [ HirCallArg ], st: LinState, sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> LinState throws { TypeError } do
  match args do
    | [] -> return st
    | HirCallArg(label: _, value: v) :: rest ->
      let st1 = check_expr(expr: v, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      return check_call_args(args: rest, st: st1, sigs, tdefs, enum_defs)
  end
end

let check_named_exprs = fn (
  fields: [ HirNamedExpr ], st: LinState, sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> LinState throws { TypeError } do
  match fields do
    | [] -> return st
    | HirNamedExpr(name: _, value: v) :: rest ->
      let st1 = check_expr(expr: v, st, sigs, tdefs, enum_defs, at_stmt_level: false)
      return check_named_exprs(fields: rest, st: st1, sigs, tdefs, enum_defs)
  end
end

// ─── Match-case branch consistency ───────────────────────────────────────────

let check_match_cases = fn (
  cases: [ HirMatchCase ], st: LinState, sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ], span: Span,
  scrutinee_linear: bool, scrutinee: HirExpr
) -> LinState throws { TypeError } do
  return check_match_cases_go(
    cases,
    st,
    sigs,
    tdefs,
    enum_defs,
    span,
    join_ref: None,
    div_rems: [],
    scrutinee_linear,
    scrutinee
  )
end

// ─── Branch-consistency helpers ───────────────────────────────────────────────

/** True when every element of `a` appears in `b` (a ⊆ b). */
let outer_rem_subset_of = fn (a: [ string ], b: [ string ]) -> bool do
  // filter_in keeps items of `a` that are also in `b`; if result equals `a`, then a ⊆ b.
  return vars_equal(a: filter_in(xs: a, keep: b, acc: []), b: a)
end

/** Check that all accumulated divergent arm outer-rems are subsets of `join_rem`. */
let check_div_rems_subset = fn (
  div_rems: [ [ string ] ], join_rem: [ string ], span: Span
) -> unit throws { TypeError } do
  match div_rems do
    | [] -> return ()
    | dr :: rest ->
      if !outer_rem_subset_of(a: dr, b: join_rem) then
        throw LinearMismatch(detail: "match arms diverge on outer-linear consumption", span)
      end
      return check_div_rems_subset(div_rems: rest, join_rem, span)
  end
end

/** Check that all accumulated divergent arm outer-rems are equal to `ref_rem`.
 *  Used in the all-diverged case. */
let check_div_rems_equal = fn (
  div_rems: [ [ string ] ], ref_rem: [ string ], span: Span
) -> unit throws { TypeError } do
  match div_rems do
    | [] -> return ()
    | dr :: rest ->
      if !vars_equal(a: dr, b: ref_rem) then
        throw LinearMismatch(detail: "match arms diverge on outer-linear consumption", span)
      end
      return check_div_rems_equal(div_rems: rest, ref_rem, span)
  end
end

let check_match_cases_go = fn (
  cases: [ HirMatchCase ], st: LinState, sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ], span: Span,
  join_ref: Option<[ string ]>, div_rems: [ [ string ] ], scrutinee_linear: bool, scrutinee: HirExpr
) -> LinState throws { TypeError } do
  // `join_ref` = outer-projected remaining agreed upon by non-divergent arms seen so far.
  // `div_rems` = list of outer-projected remainders from divergent arms seen so far.
  // Divergent arms must consume AT LEAST the outer linears the join state consumed,
  // i.e. div_rem ⊆ join_rem (subset check).
  // Non-divergent arms must all agree (equality), and accumulated div_rems must be subsets.
  // All-diverged case: all div_rems must be equal to each other.
  let outer_vars = lin_state_vars(st)
  match cases do
    | [] ->
      match join_ref do
        | None ->
          // All arms diverged (or no arms). Check all div_rems are equal.
          match div_rems do
            | [] ->
              // No arms at all — vacuously OK, outer_vars unchanged.
              return lin_set_vars(st, vs: outer_vars)
            | ref_rem :: rest_rems ->
              check_div_rems_equal(div_rems: rest_rems, ref_rem, span)
              // All-diverged: the join point is unreachable. Outer linears still
              // live in any arm are a real leak — require ref_rem (the agreed
              // remainder) to be empty (all outer linears consumed in every arm).
              require_empty_or_droppable(vars: ref_rem, params: [], span)
              return lin_set_vars(st, vs: [])
          end
        | Some(val: jr) ->
          // Mixed: check any remaining div_rems are subsets of join state.
          check_div_rems_subset(div_rems, join_rem: jr, span)
          return lin_set_vars(st, vs: jr)
      end
    | HirMatchCase(pattern: p, body: b) :: rest ->
      // Pattern binders that introduce linear vars (`%v` patterns, or plain
      // patterns that receive a linear scrutinee) are added before walking
      // the body. scrutinee_linear propagates to bind_pattern_linear so that
      // `| x ->` patterns on a linear scrutinee track x as linear (P-Var).
      let case_state = lin_set_vars(st, vs: outer_vars)
      // approach (a): for a PCtor arm on a linear scrutinee, recover the
      // scrutinee's construction and demote generic (TyVar) fields whose
      // construction arg was non-linear, so they are NOT required to be
      // consumed. Linear-arg'd generic fields stay tracked (conservative).
      let demoted = match p do
        | PCtor(variant: pv, fields: _, sigil: _) ->
          if scrutinee_linear then
            compute_demoted_tyvar_fields(target: scrutinee, variant: pv, st, sigs, tdefs, enum_defs)
          else
            []
          end
        | _ -> []
      end
      let case_state2 = bind_pattern_linear(
        pat: p,
        st: case_state,
        scrutinee_linear,
        tdefs,
        enum_defs,
        demoted_fields: demoted
      )
      let case_out = check_stmts(stmts: b, st: case_state2, sigs, tdefs, enum_defs)
      // Every arm (divergent or not) must have consumed all inner-scope linears.
      check_divergent_arm_unused(arm_out: case_out, outer_vars, span)
      // Outer-projected remaining: outer linears still live after this arm.
      let case_outer_rem = filter_in(xs: lin_state_vars(st: case_out), keep: outer_vars, acc: [])
      let case_diverges = stmts_diverge(stmts: b)
      if case_diverges then
        // Divergent arm: immediate subset check against any known join_ref,
        // then accumulate into div_rems.
        match join_ref do
          | None -> ()
          | Some(val: jr) ->
            if !outer_rem_subset_of(a: case_outer_rem, b: jr) then
              throw LinearMismatch(detail: "match arms diverge on outer-linear consumption", span)
            end
        end
        return check_match_cases_go(
          cases: rest,
          st,
          sigs,
          tdefs,
          enum_defs,
          span,
          join_ref,
          div_rems: case_outer_rem :: div_rems,
          scrutinee_linear,
          scrutinee
        )
      else
        // Non-divergent arm: check equality with any existing join_ref.
        // Also check all accumulated div_rems are subsets of this arm's rem.
        match join_ref do
          | None ->
            // First non-divergent arm: validate all previously seen div_rems are subsets.
            check_div_rems_subset(div_rems, join_rem: case_outer_rem, span)
            return check_match_cases_go(
              cases: rest,
              st,
              sigs,
              tdefs,
              enum_defs,
              span,
              join_ref: Some(val: case_outer_rem),
              div_rems: [],
              scrutinee_linear,
              scrutinee
            )
          | Some(val: jr) ->
            if !vars_equal(a: jr, b: case_outer_rem) then
              throw LinearMismatch(detail: "match arms diverge on outer-linear consumption", span)
            end
            // div_rems accumulated since last non-divergent arm must all be subsets.
            check_div_rems_subset(div_rems, join_rem: case_outer_rem, span)
            return check_match_cases_go(
              cases: rest,
              st,
              sigs,
              tdefs,
              enum_defs,
              span,
              join_ref,
              div_rems: [],
              scrutinee_linear,
              scrutinee
            )
        end
      end
  end
end

// ─── Throwable-call leak check ───────────────────────────────────────────────

/** At a stmt-level Call to `func`, any linear in `st.vars` that is *not*
 *  covered by the top frame snapshot would leak if the call raises. Raise
 *  `LinearLeakAcrossThrowableCall` listing the offending linears.
 */
let check_throwable_leak = fn (
  func: string, st: LinState, sigs: [ SigEntry ], span: Span
) -> unit throws { TypeError } do
  match sig_lookup(sigs, name: func) do
    | None -> return ()
    | Some(val: SigEntry(name: _, param_labels: _, param_types: _, ret_type: _, throw_row: tw)) ->
      if !row_is_throwable(eff_row: tw) then return () end
      let leaked = uncovered_linears(st)
      match leaked do
        | [] -> return ()
        | _ :: _ -> throw LinearLeakAcrossThrowableCall(callee: func, leaked, span)
      end
  end
end

let uncovered_linears = fn (st: LinState) -> [ string ] do
  let vs = lin_state_vars(st)
  match lin_top_frame(st) do
    | None -> return vs
    | Some(val: covered) -> return filter_not_in(xs: vs, exclude: covered, acc: [])
  end
end
