/**
 * typecheck/linearity/sig_map: callable signature map for the linearity pass.
 *
 * Builds a flat list of SigEntry records from the program's functions,
 * externals and handler-binding arms. Used by the walk to classify whether a
 * call site is throwable and whether a let-RHS call returns a linear value.
 */

import * as list from "std:list"
import { TypeExpr } from "src/syntax/ast.nx"
import {
  HirProgram, HirFunction, HirHandlerArm, HirHandlerBindingEntry,
  HirHandlerBinding, HirExternal, HirParam
} from "src/ir/hir/types.nx"
import { Option, Some, None } from "std:option"

// ─── Sig-map: name → callable signature ──────────────────────────────────────

/** One callable signature in the linearity pass's sig-map: name + declared
 *  type parameter names + parameter labels (positional with `param_types`) +
 *  parameter types + return type + declared throws row. `param_labels` and
 *  `type_params` together enable the "param→result-slot linear propagation"
 *  check for generic callees: pair call args to params by label, then test
 *  whether the param's type mentions any `type_params` that also occur in
 *  `ret_type` — flagging the result as linear when the linear arg's TyVar
 *  slot survives into the return type (e.g. `mk<A,B>(a:A, b:B) -> Pair<A,B>`
 *  with `b = %x`). Without `type_params` we'd conflate concrete nominal
 *  names (e.g. `Bb`) with type-variable references at the linearity pass,
 *  which runs BEFORE typecheck's `convert_ud_to_var`. */
export type SigEntry = SigEntry(
  name: string,
  type_params: [ string ],
  param_labels: [ string ],
  param_types: [ TypeExpr ],
  ret_type: TypeExpr,
  throw_row: TypeExpr
)

export let build_sig_map = fn (prog: HirProgram) -> [ SigEntry ] do
  let HirProgram(
      caps: _,
      functions: fs,
      externals: exs,
      handler_bindings: hbs,
      enum_defs: _,
      exception_groups: _,
      _
    ) = prog
  let sigs = sigs_from_functions(funcs: fs, acc: [])
      let sigs2 = sigs_from_externals(exts: exs, acc: sigs)
      return sigs_from_handler_bindings(bindings: hbs, acc: sigs2)
end

let sigs_from_functions = fn (funcs: [ HirFunction ], acc: [ SigEntry ]) -> [ SigEntry ] do
  match funcs do
    | [] -> return acc
    | HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, throw_row: tw, _) :: rest ->
      let pls = param_labels(params: ps, acc: [])
      let pts = param_types(params: ps, acc: [])
      return sigs_from_functions(
        funcs: rest,
        acc: SigEntry(
          name: n,
          type_params: tps,
          param_labels: pls,
          param_types: pts,
          ret_type: rt,
          throw_row: tw
        ) :: acc
      )
  end
end

let sigs_from_externals = fn (exts: [ HirExternal ], acc: [ SigEntry ]) -> [ SigEntry ] do
  match exts do
    | [] -> return acc
    | HirExternal(
      name: n,
      wasm_module: _,
      wasm_name: _,
      type_params: tps,
      params: ps,
      ret_type: rt,
      throw_row: tw
    ) :: rest ->
      let pls = param_labels(params: ps, acc: [])
      let pts = param_types(params: ps, acc: [])
      return sigs_from_externals(
        exts: rest,
        acc: SigEntry(
          name: n,
          type_params: tps,
          param_labels: pls,
          param_types: pts,
          ret_type: rt,
          throw_row: tw
        ) :: acc
      )
  end
end

let sigs_from_handler_bindings = fn (
  bindings: [ HirHandlerBindingEntry ],
  acc: [ SigEntry ]
) -> [ SigEntry ] do
  match bindings do
    | [] -> return acc
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      let acc2 = sigs_from_handler_arms(arms, acc)
      return sigs_from_handler_bindings(bindings: rest, acc: acc2)
  end
end

let sigs_from_handler_arms = fn (arms: [ HirHandlerArm ], acc: [ SigEntry ]) -> [ SigEntry ] do
  match arms do
    | [] -> return acc
    | HirHandlerArm(
      arm: HirFunction(name: n, type_params: tps, params: ps, ret_type: rt, throw_row: tw, _),
      cont_binder: _
    ) :: rest ->
      let pls = param_labels(params: ps, acc: [])
      let pts = param_types(params: ps, acc: [])
      return sigs_from_handler_arms(
        arms: rest,
        acc: SigEntry(
          name: n,
          type_params: tps,
          param_labels: pls,
          param_types: pts,
          ret_type: rt,
          throw_row: tw
        ) :: acc
      )
  end
end

let param_labels = fn (params: [ HirParam ], acc: [ string ]) -> [ string ] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(
      label: l,
      name: _,
      sigil: _,
      typ: _
    ) :: rest -> return param_labels(params: rest, acc: l :: acc)
  end
end

let param_types = fn (params: [ HirParam ], acc: [ TypeExpr ]) -> [ TypeExpr ] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(
      label: _,
      name: _,
      sigil: _,
      typ: t
    ) :: rest -> return param_types(params: rest, acc: t :: acc)
  end
end

export let sig_lookup = fn (sigs: [ SigEntry ], name: string) -> Option<SigEntry> do
  match sigs do
    | [] -> return None
    | SigEntry(
      name: n,
      type_params: tps,
      param_labels: pls,
      param_types: pts,
      ret_type: rt,
      throw_row: tw
    ) :: rest ->
      if n == name then return Some(val: SigEntry(name: n, type_params: tps, param_labels: pls, param_types: pts, ret_type: rt, throw_row: tw)) end
      return sig_lookup(sigs: rest, name)
  end
end
