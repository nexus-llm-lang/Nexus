/**
 * typecheck/linearity/borrow_escape: Form-B borrow-escape detection.
 *
 * A `&σ` borrow stored in a record/ADT field escapes its owner when the
 * aggregate is RETURNED and the borrowed owner is a binding owned by THIS
 * function (a local LINEAR `let %x` / `%`-param
 * or a local NON-LINEAR `let x`). The recursive carrier walk
 * chases a borrow buried in nested record/sum carriers.
 *
 * The borrow-bearing type resolution it relies on (`ret_type_bears_borrow`)
 * lives in borrow_types.nx; this module is the HIR-expression walk built on
 * top of it. Entry point: `check_borrow_escape_form_b`, called by walk.nx's
 * per-function check.
 */

import { Span } from "src/types/span.nx"
import { Sigil, SigilImmutable, SigilMutable, SigilLinear, SigilLazy } from "src/types/vocab.nx"
import { EnumDef, RecordDef } from "src/types/type_expr.nx"
import {
  HirStmt, HirStmtKind, HirExpr, HirExprKind, HirCallArg, HirNamedExpr, HirParam,
  HirMatchCase, HirPatternKind, HirPatternField, HirRecordPatField
} from "src/ir/hir/types.nx"
import { TypeError, RefEscapes } from "src/typecheck/errors.nx"
import { Option, Some, None } from "std:option"
import { SigEntry, sig_lookup } from "src/typecheck/linearity/sig_map.nx"
import { str_member, append_consumed } from "src/typecheck/linearity/state.nx"
import { ret_type_bears_borrow } from "src/typecheck/linearity/borrow_types.nx"

// ─── Form-B borrow-escape: record/ADT holding a borrow of a LOCAL linear ─────
//
// A `&σ` borrow stored in a record/ADT field
// escapes its owner when the record is RETURNED and the borrowed owner is a
// LINEAR binding that this function must consume by function-end:
//
//   type Wrap = Wrap(b: &ByteBuffer)
//   let mk = fn (c: &ByteBuffer) -> Wrap do return Wrap(b: c) end   // launders
//   let leak = fn () -> Wrap do
//     let %b1 = bb.empty()
//     let w  = mk(c: &b1)   // w holds a borrow of the local linear %b1
//     bb.free(buf: %b1)     // owner freed; w.b now dangles
//     return w              // ← escape: the borrowed local cannot outlive leak
//   end
//
// A DIRECT `Wrap(b: &b1)` over a linear `b1` is already rejected at T-Borrow
// (E2001, infer_borrow): Ctor/Record fields are NOT argument position. The
// residual hole is the CALL-LAUNDERED path: a callee whose declared return
// type contains a `&σ` field, invoked with a borrow of a local linear, then
// returned. We detect exactly that, owner-locally:
//
//   • A `let w = Call(f, args)` taints `w` when `f`'s declared return type is
//     borrow-bearing (contains a TyBorrow, one resolution level into the
//     returned record/enum def) AND some arg is `&x` for a LINEAR binding `x`
//     live in THIS body (a `let %x` local OR a `%`-param — both are owned by
//     this function and consumed by function-end, so a borrow of either cannot
//     outlive the function).
//   • A `return e` is rejected when `e` is a tainted name, or is directly such
//     a borrow-laundering Call.
//
// CompileCtx/CodegenCtx idiom stays legal: it constructs the ctx via a DIRECT
// `CompileCtx(internal_func_map: &internal_func_map, ...)` (not a laundering
// call) and NEVER returns the ctx (it is consumed in-scope, freed before the
// function returns). Borrows of NON-linear `&`-typed parameters (the genuine
// CompileCtx-as-parameter shape) are not flagged: only linear owners trip this.

/** Local linear binding names: `%`-params + `let %x` bindings in the body.
 *  Both are owned by this function (must be consumed by function-end), so a
 *  borrow of either cannot soundly escape via the return. */
let collect_owned_linears = fn (
  params: [ HirParam ],
  stmts: [ HirStmt ],
  acc: [ string ]
) -> [ string ] do
  let acc1 = collect_linear_param_names(params, acc)
  return collect_local_linear_lets(stmts, acc: acc1)
end

let collect_linear_param_names = fn (params: [ HirParam ], acc: [ string ]) -> [ string ] do
  match params do
    | [] -> return acc
    | HirParam(label: _, name: pn, sigil: psig, typ: _) :: rest ->
      let acc1 = match psig do | SigilLinear | SigilLazy -> pn :: acc | _ -> acc end
      return collect_linear_param_names(params: rest, acc: acc1)
  end
end

let collect_local_linear_lets = fn (stmts: [ HirStmt ], acc: [ string ]) -> [ string ] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: nd, span: _) :: rest ->
      let acc1 = match nd do
        | Let(name: n, sigil: sg, typ: _, value: _) ->
          match sg do | SigilLinear | SigilLazy -> n :: acc | _ -> acc end
        | _ -> acc
      end
      return collect_local_linear_lets(stmts: rest, acc: acc1)
  end
end

/** Local NON-LINEAR `let x =...` binding names in the body.
 *  Parameters are deliberately EXCLUDED: a `&`-typed parameter is a non-local
 *  owner whose lifetime outlives this frame (the CompileCtx-as-parameter
 *  idiom), so a borrow of it may legally escape. Only a `let`-bound local —
 *  whose backing storage is THIS frame — cannot soundly escape via a returned
 *  record/ADT field. */
let collect_local_nonlinear_lets = fn (stmts: [ HirStmt ], acc: [ string ]) -> [ string ] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: nd, span: _) :: rest ->
      let acc1 = match nd do
        | Let(name: n, sigil: sg, typ: _, value: _) ->
          match sg do | SigilImmutable | SigilMutable -> n :: acc | _ -> acc end
        | _ -> acc
      end
      return collect_local_nonlinear_lets(stmts: rest, acc: acc1)
  end
end

/** Local `let`-bound borrow aliases: a `let b = &owner` whose owner is a
 *  binding owned by THIS frame (a local linear in `owned` OR a local
 *  non-linear in `nl_locals`). `b` then *is* a borrow of a frame-owned local,
 *  so capturing `b` in a returned closure escapes the borrow just as a direct
 *  `&owner` capture would. Borrows of a `&`-typed PARAMETER (a non-local owner
 *  that outlives this frame) are deliberately excluded: they may legally
 *  escape, matching the record-field rule. */
let collect_borrow_aliases = fn (
  stmts: [ HirStmt ], frame_locals: [ string ], acc: [ string ]
) -> [ string ] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: nd, span: _) :: rest ->
      let acc1 = match nd do
        | Let(name: n, sigil: _, typ: _, value: HirExpr(node: Borrow(name: owner, sigil: _), span: _)) ->
          if str_member(xs: frame_locals, target: owner) then n :: acc else acc end
        | _ -> acc
      end
      return collect_borrow_aliases(stmts: rest, frame_locals, acc: acc1)
  end
end

/** True iff some call arg is `&x` for `x ∈ owned`. */
let call_borrows_owned_linear = fn (args: [ HirCallArg ], owned: [ string ]) -> bool do
  match args do
    | [] -> return false
    | HirCallArg(label: _, value: HirExpr(node: vn, span: _)) :: rest ->
      let hit = match vn do
        | Borrow(name: bn, sigil: _) -> str_member(xs: owned, target: bn)
        | _ -> false
      end
      if hit then return true end
      return call_borrows_owned_linear(args: rest, owned)
  end
end

/** Is `expr` a Call whose declared return type bears a `&σ` AND which is
 *  passed a borrow of an owned linear? This is the laundering construction. */
let is_borrow_laundering_call = fn (
  expr: HirExprKind, owned: [ string ], sigs: [ SigEntry ],
  enum_defs: [ EnumDef ], tdefs: [ RecordDef ]
) -> bool do
  match expr do
    | Call(func: f, args: cargs) ->
      if !call_borrows_owned_linear(args: cargs, owned) then return false end
      match sig_lookup(sigs, name: f) do
        | None -> return false
        | Some(val: SigEntry(name: _, type_params: _, param_labels: _, param_types: _, ret_type: rt, throw_row: _)) ->
          return ret_type_bears_borrow(t: rt, enum_defs, tdefs, resolve: true)
      end
    | _ -> return false
  end
end

// ─── Non-linear local owner ────────────────────────────────────
//
// A borrow of a LOCAL NON-LINEAR `let` binding stored in a record/ADT field
// that ESCAPES (is returned) is a use-after-scope: the local's backing storage
// is this frame, so the returned aggregate's borrow field dangles after the
// function returns. Unlike the linear case, a DIRECT `{ b: &x }` / `Ctor(b: &x)`
// over a non-linear local is NOT rejected at T-Borrow (only linear borrows are
// banned outside argument position), so we must detect both the direct
// construction AND the call-laundered form here.
//
// Parameter owners are excluded (see collect_local_nonlinear_lets): the
// CompileCtx-as-parameter idiom returns a record borrowing a `&`-parameter and
// is sound. Only `let`-bound locals are screened.

/** True iff `expr` directly is `&x` for `x ∈ locals`, OR is a nested
 *  record/ADT construction that (transitively) holds such a borrow. The
 *  recursion lets a borrow buried inside `{ i: { b: &x } }` or `Wrap(i: {b:&x})`
 * be detected, not just the flat single-level field. */
let expr_holds_borrow_of_member = fn (expr: HirExprKind, locals: [ string ]) -> bool do
  match expr do
    | Borrow(name: bn, sigil: _) -> return str_member(xs: locals, target: bn)
    | Record(fields: fs) -> return named_exprs_borrow_member(fields: fs, locals)
    | Ctor(
      variant: _,
      args: cargs,
      labels: _,
      sigil: _
    ) -> return exprs_borrow_member(args: cargs, locals)
    | _ -> return false
  end
end

/** True iff some Record field value (transitively) holds `&x` for `x ∈ locals`. */
let named_exprs_borrow_member = fn (fields: [ HirNamedExpr ], locals: [ string ]) -> bool do
  match fields do
    | [] -> return false
    | HirNamedExpr(name: _, value: HirExpr(node: vn, span: _)) :: rest ->
      if expr_holds_borrow_of_member(expr: vn, locals) then return true end
      return named_exprs_borrow_member(fields: rest, locals)
  end
end

/** True iff some Ctor positional arg (transitively) holds `&x` for `x ∈ locals`. */
let exprs_borrow_member = fn (args: [ HirExpr ], locals: [ string ]) -> bool do
  match args do
    | [] -> return false
    | HirExpr(node: vn, span: _) :: rest ->
      if expr_holds_borrow_of_member(expr: vn, locals) then return true end
      return exprs_borrow_member(args: rest, locals)
  end
end

/** True iff some call arg is `&x` for `x ∈ locals` (laundering over locals). */
let call_borrows_member = fn (args: [ HirCallArg ], locals: [ string ]) -> bool do
  match args do
    | [] -> return false
    | HirCallArg(label: _, value: HirExpr(node: vn, span: _)) :: rest ->
      let hit = match vn do
        | Borrow(name: bn, sigil: _) -> str_member(xs: locals, target: bn)
        | _ -> false
      end
      if hit then return true end
      return call_borrows_member(args: rest, locals)
  end
end

// ─── Closure-captured borrow of a frame-owned local ─────────────────────────
//
// A `&σ` borrow also escapes when it is captured by a RETURNED CLOSURE: the
// closure's free variables outlive this frame via the returned arrow value, so
// a captured borrow of a frame-owned local dangles after the function returns —
// the exact owner-locality violation the record-field rule already screens.
//
//   let leak = fn () -> (() -> i64) do
//     let x = 1
//     let b = &x                          // b borrows frame-local x
//     let g = fn () -> i64 do return b end // closure captures borrow-alias b
//     return g                            // ← escape: borrow of x outlives leak
//   end
//
// The lambda's `escapesRef` return type is borrow-FREE (it returns `i64`), so
// the type-level gravity rule never fires; we must inspect the captured free
// variables directly. A capture is unsafe when the lambda body references a
// `Borrow(local)` of a frame-owned binding, OR a `Variable(b)` for a
// borrow-alias `b` (`let b = &local`). Borrows of a `&`-param (owner outlives
// the frame) are NOT in frame_locals/borrow_aliases, so closures forwarding a
// borrowed parameter stay accepted (positive companion test).
//
// Shadowing is honoured: the lambda's own params and any inner `let` that
// rebinds a name hide the outer binding, so they are not treated as captures.

/** True iff `name` names a frame-owned borrow capture (a frame-local that is
 *  directly borrowed, or a borrow-alias variable) AND is not shadowed. */
let is_frame_borrow_var = fn (
  name: string, is_borrow: bool, frame_locals: [ string ],
  borrow_aliases: [ string ], shadowed: [ string ]
) -> bool do
  if str_member(xs: shadowed, target: name) then return false end
  if is_borrow then return str_member(xs: frame_locals, target: name) end
  return str_member(xs: borrow_aliases, target: name)
end

/** Walk a lambda body's statements; true if any captures a borrow of a
 *  frame-owned local. `shadowed` grows with the lambda's inner `let` bindings. */
let lambda_stmts_capture = fn (
  stmts: [ HirStmt ], frame_locals: [ string ], borrow_aliases: [ string ], shadowed: [ string ]
) -> bool do
  match stmts do
    | [] -> return false
    | HirStmt(node: nd, span: _) :: rest ->
      match nd do
        | Let(name: ln, sigil: _, typ: _, value: lv) ->
          if lambda_expr_captures(expr: lv, frame_locals, borrow_aliases, shadowed) then return true end
          // A `let ln = ...` inside the lambda shadows any outer `ln` for the
          // remaining statements.
          return lambda_stmts_capture(stmts: rest, frame_locals, borrow_aliases, shadowed: ln :: shadowed)
        | Expr(expr: e) ->
          if lambda_expr_captures(expr: e, frame_locals, borrow_aliases, shadowed) then return true end
          return lambda_stmts_capture(stmts: rest, frame_locals, borrow_aliases, shadowed)
        | Return(expr: e) ->
          if lambda_expr_captures(expr: e, frame_locals, borrow_aliases, shadowed) then return true end
          return lambda_stmts_capture(stmts: rest, frame_locals, borrow_aliases, shadowed)
        | Assign(target: t, value: v) ->
          if lambda_expr_captures(expr: t, frame_locals, borrow_aliases, shadowed) then return true end
          if lambda_expr_captures(expr: v, frame_locals, borrow_aliases, shadowed) then return true end
          return lambda_stmts_capture(stmts: rest, frame_locals, borrow_aliases, shadowed)
        | Try(body: tb, catch_param: cp, catch_body: cb) ->
          if lambda_stmts_capture(stmts: tb, frame_locals, borrow_aliases, shadowed) then return true end
          if lambda_stmts_capture(stmts: cb, frame_locals, borrow_aliases, shadowed: cp :: shadowed) then return true end
          return lambda_stmts_capture(stmts: rest, frame_locals, borrow_aliases, shadowed)
      end
  end
end

/** Walk a lambda body's expression; true if it references a frame-owned borrow
 *  capture (directly, or nested in any sub-expression / inner block). */
let lambda_expr_captures = fn (
  expr: HirExpr, frame_locals: [ string ], borrow_aliases: [ string ], shadowed: [ string ]
) -> bool do
  match expr do
    | HirExpr(node: en, span: _) ->
      match en do
        | Variable(name: vn, sigil: _) ->
          return is_frame_borrow_var(name: vn, is_borrow: false, frame_locals, borrow_aliases, shadowed)
        | Borrow(name: bn, sigil: _) ->
          return is_frame_borrow_var(name: bn, is_borrow: true, frame_locals, borrow_aliases, shadowed)
        | BinOp(left: l, op: _, right: r) ->
          if lambda_expr_captures(expr: l, frame_locals, borrow_aliases, shadowed) then return true end
          return lambda_expr_captures(expr: r, frame_locals, borrow_aliases, shadowed)
        | UnOp(op: _, operand: o) ->
          return lambda_expr_captures(expr: o, frame_locals, borrow_aliases, shadowed)
        | Call(func: _, args: cargs) ->
          return lambda_args_capture(args: cargs, frame_locals, borrow_aliases, shadowed)
        | CallExpr(callee: c, args: cargs) ->
          if lambda_expr_captures(expr: c, frame_locals, borrow_aliases, shadowed) then return true end
          return lambda_args_capture(args: cargs, frame_locals, borrow_aliases, shadowed)
        | Ctor(variant: _, args: cargs, labels: _, sigil: _) ->
          return lambda_exprs_capture(args: cargs, frame_locals, borrow_aliases, shadowed)
        | Record(fields: fs) ->
          return lambda_named_capture(fields: fs, frame_locals, borrow_aliases, shadowed)
        | Array(elems: es) ->
          return lambda_exprs_capture(args: es, frame_locals, borrow_aliases, shadowed)
        | Index(target: t, index: i) ->
          if lambda_expr_captures(expr: t, frame_locals, borrow_aliases, shadowed) then return true end
          return lambda_expr_captures(expr: i, frame_locals, borrow_aliases, shadowed)
        | FieldAccess(target: t, field: _) ->
          return lambda_expr_captures(expr: t, frame_locals, borrow_aliases, shadowed)
        | If(cond: c, then_branch: tb, else_branch: eb) ->
          if lambda_expr_captures(expr: c, frame_locals, borrow_aliases, shadowed) then return true end
          if lambda_stmts_capture(stmts: tb, frame_locals, borrow_aliases, shadowed) then return true end
          match eb do
            | Some(val: es) -> return lambda_stmts_capture(stmts: es, frame_locals, borrow_aliases, shadowed)
            | None -> return false
          end
        | Match(target: t, cases: cs) ->
          if lambda_expr_captures(expr: t, frame_locals, borrow_aliases, shadowed) then return true end
          return lambda_cases_capture(cases: cs, frame_locals, borrow_aliases, shadowed)
        | While(cond: c, body: wb) ->
          if lambda_expr_captures(expr: c, frame_locals, borrow_aliases, shadowed) then return true end
          return lambda_stmts_capture(stmts: wb, frame_locals, borrow_aliases, shadowed)
        | For(var: fv, start: s, end_expr: e, body: fb) ->
          if lambda_expr_captures(expr: s, frame_locals, borrow_aliases, shadowed) then return true end
          if lambda_expr_captures(expr: e, frame_locals, borrow_aliases, shadowed) then return true end
          return lambda_stmts_capture(stmts: fb, frame_locals, borrow_aliases, shadowed: fv :: shadowed)
        // A nested lambda still captures the SAME outer frame's locals; its own
        // params shadow them. Descend with the inner params added to `shadowed`.
        | Lambda(type_params: _, params: lps, ret_type: _, requires: _, throw_row: _, body: lb) ->
          return lambda_stmts_capture(stmts: lb, frame_locals, borrow_aliases, shadowed: add_param_names(params: lps, acc: shadowed))
        | Raise(expr: e) -> return lambda_expr_captures(expr: e, frame_locals, borrow_aliases, shadowed)
        | Force(expr: e) -> return lambda_expr_captures(expr: e, frame_locals, borrow_aliases, shadowed)
        | Thunk(body: e) -> return lambda_expr_captures(expr: e, frame_locals, borrow_aliases, shadowed)
        | Inject(handlers: _, body: ib) ->
          return lambda_stmts_capture(stmts: ib, frame_locals, borrow_aliases, shadowed)
        | _ -> return false
      end
  end
end

let lambda_args_capture = fn (
  args: [ HirCallArg ], frame_locals: [ string ], borrow_aliases: [ string ], shadowed: [ string ]
) -> bool do
  match args do
    | [] -> return false
    | HirCallArg(label: _, value: v) :: rest ->
      if lambda_expr_captures(expr: v, frame_locals, borrow_aliases, shadowed) then return true end
      return lambda_args_capture(args: rest, frame_locals, borrow_aliases, shadowed)
  end
end

let lambda_exprs_capture = fn (
  args: [ HirExpr ], frame_locals: [ string ], borrow_aliases: [ string ], shadowed: [ string ]
) -> bool do
  match args do
    | [] -> return false
    | e :: rest ->
      if lambda_expr_captures(expr: e, frame_locals, borrow_aliases, shadowed) then return true end
      return lambda_exprs_capture(args: rest, frame_locals, borrow_aliases, shadowed)
  end
end

let lambda_named_capture = fn (
  fields: [ HirNamedExpr ], frame_locals: [ string ], borrow_aliases: [ string ], shadowed: [ string ]
) -> bool do
  match fields do
    | [] -> return false
    | HirNamedExpr(name: _, value: v) :: rest ->
      if lambda_expr_captures(expr: v, frame_locals, borrow_aliases, shadowed) then return true end
      return lambda_named_capture(fields: rest, frame_locals, borrow_aliases, shadowed)
  end
end

let lambda_cases_capture = fn (
  cases: [ HirMatchCase ], frame_locals: [ string ], borrow_aliases: [ string ], shadowed: [ string ]
) -> bool do
  match cases do
    | [] -> return false
    | HirMatchCase(pattern: pat, body: cb) :: rest ->
      // Pattern-bound names shadow outer captures within the arm body.
      let sh = add_pattern_names(pat, acc: shadowed)
      if lambda_stmts_capture(stmts: cb, frame_locals, borrow_aliases, shadowed: sh) then return true end
      return lambda_cases_capture(cases: rest, frame_locals, borrow_aliases, shadowed)
  end
end

/** Append a parameter list's names onto a shadow set. */
let add_param_names = fn (params: [ HirParam ], acc: [ string ]) -> [ string ] do
  match params do
    | [] -> return acc
    | HirParam(label: _, name: pn, sigil: _, typ: _) :: rest ->
      return add_param_names(params: rest, acc: pn :: acc)
  end
end

/** Append a pattern's bound variable names onto a shadow set. */
let add_pattern_names = fn (pat: HirPatternKind, acc: [ string ]) -> [ string ] do
  match pat do
    | PVar(name: n, sigil: _) -> return n :: acc
    | PCtor(variant: _, fields: fs, sigil: _) -> return add_pat_field_names(fields: fs, acc: acc)
    | PRec(fields: rfs, is_partial: _) -> return add_rec_pat_field_names(fields: rfs, acc: acc)
    | POr(alts: alts) -> return add_pattern_names_list(pats: alts, acc: acc)
    | _ -> return acc
  end
end

let add_pat_field_names = fn (fields: [ HirPatternField ], acc: [ string ]) -> [ string ] do
  match fields do
    | [] -> return acc
    | HirPatternField(name: _, pattern: p) :: rest ->
      return add_pat_field_names(fields: rest, acc: add_pattern_names(pat: p, acc: acc))
  end
end

let add_rec_pat_field_names = fn (fields: [ HirRecordPatField ], acc: [ string ]) -> [ string ] do
  match fields do
    | [] -> return acc
    | HirRecordPatField(name: _, pattern: p) :: rest ->
      return add_rec_pat_field_names(fields: rest, acc: add_pattern_names(pat: p, acc: acc))
  end
end

let add_pattern_names_list = fn (pats: [ HirPatternKind ], acc: [ string ]) -> [ string ] do
  match pats do
    | [] -> return acc
    | p :: rest -> return add_pattern_names_list(pats: rest, acc: add_pattern_names(pat: p, acc: acc))
  end
end

/** True iff `expr` is a lambda whose captured free variables include a borrow
 *  of a binding owned by THIS frame — the closure-escape analog of a returned
 *  record/ADT field holding such a borrow. */
let lambda_captures_frame_borrow = fn (
  expr: HirExprKind, frame_locals: [ string ], borrow_aliases: [ string ]
) -> bool do
  match expr do
    | Lambda(type_params: _, params: lps, ret_type: _, requires: _, throw_row: _, body: lb) ->
      return lambda_stmts_capture(stmts: lb, frame_locals, borrow_aliases, shadowed: add_param_names(params: lps, acc: []))
    | _ -> return false
  end
end

/** Is `expr` a record/ADT construction (direct or call-laundered) that stores
 *  a borrow of a LOCAL NON-LINEAR binding in `locals`? Mirrors
 *  is_borrow_laundering_call but covers the DIRECT Record/Ctor forms too, since
 *  a direct `{ b: &x }` over a non-linear local is not screened at T-Borrow. */
let constructs_borrow_of_nonlinear_local = fn (
  expr: HirExprKind, locals: [ string ], sigs: [ SigEntry ],
  enum_defs: [ EnumDef ], tdefs: [ RecordDef ]
) -> bool do
  match expr do
    | Record(fields: fs) -> return named_exprs_borrow_member(fields: fs, locals)
    | Ctor(
      variant: _,
      args: cargs,
      labels: _,
      sigil: _
    ) -> return exprs_borrow_member(args: cargs, locals)
    | Call(func: f, args: cargs) ->
      if !call_borrows_member(args: cargs, locals) then return false end
      match sig_lookup(sigs, name: f) do
        | None -> return false
        | Some(val: SigEntry(name: _, type_params: _, param_labels: _, param_types: _, ret_type: rt, throw_row: _)) ->
          return ret_type_bears_borrow(t: rt, enum_defs, tdefs, resolve: true)
      end
    | _ -> return false
  end
end

/** Build the set of `let`-bound names tainted by a borrow-laundering call
 *  (linear owners), a record/ADT construction holding a borrow of a local
 *  non-linear, OR a closure capturing a borrow of a frame-owned local. Any
 *  taint marks the binding as escape-unsafe. */
let collect_tainted_names = fn (
  stmts: [ HirStmt ], owned: [ string ], nl_locals: [ string ], frame_locals: [ string ],
  borrow_aliases: [ string ], sigs: [ SigEntry ],
  enum_defs: [ EnumDef ], tdefs: [ RecordDef ], acc: [ string ]
) -> [ string ] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: nd, span: _) :: rest ->
      let acc1 = match nd do
        | Let(name: n, sigil: _, typ: _, value: HirExpr(node: vn, span: _)) ->
          if is_borrow_laundering_call(expr: vn, owned, sigs, enum_defs, tdefs) then n :: acc
          else if constructs_borrow_of_nonlinear_local(
            expr: vn,
            locals: nl_locals,
            sigs,
            enum_defs,
            tdefs
          ) then n :: acc
          else if lambda_captures_frame_borrow(expr: vn, frame_locals, borrow_aliases) then n :: acc
          // Alias of an already-tainted name: `let w2 = w1`.
          else match vn do
            | Variable(name: src, sigil: _) ->
              if str_member(xs: acc, target: src) then n :: acc else acc end
            | _ -> acc
          end end
        | _ -> acc
      end
      return collect_tainted_names(stmts: rest, owned, nl_locals, frame_locals, borrow_aliases, sigs, enum_defs, tdefs, acc: acc1)
  end
end

/** Reject any `return e` whose `e` is a tainted name, a direct laundering call
 *  (linear owner), or a direct record/ADT construction holding a borrow of a
 * local non-linear. Recurses into nested blocks (Try / Inject). */
let check_borrow_escape_stmts = fn (
  stmts: [ HirStmt ], tainted: [ string ], owned: [ string ], nl_locals: [ string ],
  frame_locals: [ string ], borrow_aliases: [ string ], sigs: [ SigEntry ],
  enum_defs: [ EnumDef ], tdefs: [ RecordDef ], fn_name: string
) -> unit throws { TypeError } do
  match stmts do
    | [] -> return ()
    | HirStmt(node: nd, span: sp) :: rest ->
      match nd do
        | Return(expr: HirExpr(node: en, span: esp)) ->
          let escapes = match en do
            | Variable(name: rn, sigil: _) -> str_member(xs: tainted, target: rn)
            | _ ->
              if is_borrow_laundering_call(expr: en, owned, sigs, enum_defs, tdefs) then true
              else if lambda_captures_frame_borrow(expr: en, frame_locals, borrow_aliases) then true
              else constructs_borrow_of_nonlinear_local(
                expr: en,
                locals: nl_locals,
                sigs,
                enum_defs,
                tdefs
              ) end
          end
          if escapes then
            throw RefEscapes(
              context: "the returned value of '" ++ fn_name
                ++ "' (a record/ADT field holds a borrow of a local binding owned by this function — the borrow escapes and dangles after the function returns, a use-after-free)",
              span: esp
            )
          end
        | Try(body: tb, catch_param: _, catch_body: cb) ->
          check_borrow_escape_stmts(
            stmts: tb,
            tainted,
            owned,
            nl_locals,
            frame_locals,
            borrow_aliases,
            sigs,
            enum_defs,
            tdefs,
            fn_name
          )
          check_borrow_escape_stmts(
            stmts: cb,
            tainted,
            owned,
            nl_locals,
            frame_locals,
            borrow_aliases,
            sigs,
            enum_defs,
            tdefs,
            fn_name
          )
        // A statement-position inject is HirStmtKind::Expr(Inject(...)); descend
        // into its body so a `return tainted` inside the inject is still caught
        // (the old dedicated stmt-Inject arm did this).
        | Expr(expr: HirExpr(node: Inject(handlers: _, body: ib), span: _)) ->
          check_borrow_escape_stmts(
            stmts: ib,
            tainted,
            owned,
            nl_locals,
            frame_locals,
            borrow_aliases,
            sigs,
            enum_defs,
            tdefs,
            fn_name
          )
        | _ -> ()
      end
      return check_borrow_escape_stmts(
        stmts: rest,
        tainted,
        owned,
        nl_locals,
        frame_locals,
        borrow_aliases,
        sigs,
        enum_defs,
        tdefs,
        fn_name
      )
  end
end

/** Entry: detect a returned record/ADT holding a borrow of a local binding
 *  owned by this function — a local LINEAR (ymx7u, call-laundered) or a local
 *  NON-LINEAR (quuuq, direct or call-laundered). */
export let check_borrow_escape_form_b = fn (
  fn_name: string, params: [ HirParam ], stmts: [ HirStmt ], sigs: [ SigEntry ],
  enum_defs: [ EnumDef ], tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  let owned = collect_owned_linears(params, stmts, acc: [])
  let nl_locals = collect_local_nonlinear_lets(stmts, acc: [])
  // Bindings owned by THIS frame (linear + non-linear locals) and the `let`
  // borrow-aliases (`let b = &owner`) over them; both feed the returned-closure
  // capture check. No frame-owned locals ⇒ nothing can escape, so we bail early.
  let frame_locals = append_consumed(xs: owned, ys: nl_locals)
  match frame_locals do
    | [] -> return ()
    | _ ->
      let borrow_aliases = collect_borrow_aliases(stmts, frame_locals, acc: [])
      let tainted = collect_tainted_names(
        stmts,
        owned,
        nl_locals,
        frame_locals,
        borrow_aliases,
        sigs,
        enum_defs,
        tdefs,
        acc: []
      )
      return check_borrow_escape_stmts(
        stmts,
        tainted,
        owned,
        nl_locals,
        frame_locals,
        borrow_aliases,
        sigs,
        enum_defs,
        tdefs,
        fn_name
      )
  end
end
