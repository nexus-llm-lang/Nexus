/**
 * typecheck/linearity/capture: lambda-capture consumption scanning.
 *
 * Walks a lambda body to collect every outer-linear name referenced as a
 * free variable (i.e. not shadowed by an inner binder). Used by the Lambda
 * arm of check_expr_kind in walk.nx.
 */

import {
  HirStmt, HirStmtKind,
  HirExpr, HirExprKind, HirCallArg, HirNamedExpr, HirMatchCase, HirParam,
  HirPatternKind, HirPatternField, HirRecordPatField
} from "src/ir/hir/types.nx"
import { TypeExpr, TyRow, TyUnit, TyVar } from "src/types/type_expr.nx"
import { LinState, lin_member, lin_remove, str_member } from "src/typecheck/linearity/state.nx"
import { SigEntry, sig_lookup } from "src/typecheck/linearity/sig_map.nx"

// ─── Lambda-capture consumption ──────────────────────────────────────────────

export let collect_param_names = fn (params: [ HirParam ], acc: [ string ]) -> [ string ] do
  match params do
    | [] -> return acc
    | HirParam(label: _, name: n, sigil: _, typ: _) :: rest ->
      return collect_param_names(params: rest, acc: n :: acc)
  end
end

export let consume_all = fn (st: LinState, names: [ string ]) -> LinState do
  match names do
    | [] -> return st
    | n :: rest ->
      let st1 = if lin_member(st, name: n) then lin_remove(st, name: n) else st end
      return consume_all(st: st1, names: rest)
  end
end

/** Walk a lambda body (statements) and collect every outer-linear name
 *  referenced as a free variable inside it. `bound` is the running set of
 *  names introduced by inner binders (lambda params, lets, match patterns,
 *  for/try-catch binders) — references shadowed by these are not captures.
 */
export let collect_captured_linears = fn (
  body: [ HirStmt ], outer_linears: [ string ], bound: [ string ], acc: [ string ]
) -> [ string ] do
  return cap_scan_stmts(stmts: body, outer: outer_linears, bound, acc)
end

let cap_add_unique = fn (xs: [ string ], n: string) -> [ string ] do
  if str_member(xs, target: n) then return xs end
  return n :: xs
end

let cap_scan_stmts = fn (
  stmts: [ HirStmt ], outer: [ string ], bound: [ string ], acc: [ string ]
) -> [ string ] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: nd, span: _) :: rest ->
      match nd do
        | Let(name: n, sigil: _, typ: _, value: v) ->
          let acc1 = cap_scan_expr(expr: v, outer, bound, acc)
          return cap_scan_stmts(stmts: rest, outer, bound: n :: bound, acc: acc1)
        | Expr(expr: e) | Return(expr: e) ->
          return cap_scan_stmts(
            stmts: rest,
            outer,
            bound,
            acc: cap_scan_expr(expr: e, outer, bound, acc)
          )
        | Assign(target: t, value: v) ->
          let acc1 = cap_scan_expr(expr: t, outer, bound, acc)
          let acc2 = cap_scan_expr(expr: v, outer, bound, acc: acc1)
          return cap_scan_stmts(stmts: rest, outer, bound, acc: acc2)
        | Try(body: b, catch_param: cp, catch_body: cb) ->
          let acc1 = cap_scan_stmts(stmts: b, outer, bound, acc)
          let acc2 = cap_scan_stmts(stmts: cb, outer, bound: cp :: bound, acc: acc1)
          return cap_scan_stmts(stmts: rest, outer, bound, acc: acc2)
        | Inject(handlers: _, body: b) ->
          return cap_scan_stmts(
            stmts: rest,
            outer,
            bound,
            acc: cap_scan_stmts(stmts: b, outer, bound, acc)
          )
      end
  end
end

let cap_scan_expr = fn (
  expr: HirExpr, outer: [ string ], bound: [ string ], acc: [ string ]
) -> [ string ] do
  let HirExpr(node: nd, span: _) = expr
  match nd do
    | Literal(_) -> return acc
    | Variable(name: n, sigil: _) ->
      if str_member(xs: bound, target: n) then return acc end
      if str_member(xs: outer, target: n) then return cap_add_unique(xs: acc, n) end
      return acc
    | Borrow(name: _, sigil: _) ->
      // Borrow does not consume the binding, so ignore for capture-consumption.
      return acc
    | BinOp(left: l, op: _, right: r) ->
      let acc1 = cap_scan_expr(expr: l, outer, bound, acc)
      return cap_scan_expr(expr: r, outer, bound, acc: acc1)
    | UnOp(op: _, operand: o) -> return cap_scan_expr(expr: o, outer, bound, acc)
    | Call(func: f, args: cargs) ->
      let acc0 = if str_member(xs: bound, target: f) then acc
        else if str_member(xs: outer, target: f) then cap_add_unique(xs: acc, n: f)
        else acc end
      return cap_scan_call_args(args: cargs, outer, bound, acc: acc0)
    | CallExpr(callee: c, args: cargs) ->
      let acc1 = cap_scan_expr(expr: c, outer, bound, acc)
      return cap_scan_call_args(args: cargs, outer, bound, acc: acc1)
    | Ctor(
      variant: _,
      args: cargs,
      labels: _,
      sigil: _
    ) -> return cap_scan_exprs(exprs: cargs, outer, bound, acc)
    | Record(fields: fs) -> return cap_scan_named(fields: fs, outer, bound, acc)
    | Array(elems: es) -> return cap_scan_exprs(exprs: es, outer, bound, acc)
    | Index(target: t, index: i) ->
      let acc1 = cap_scan_expr(expr: t, outer, bound, acc)
      return cap_scan_expr(expr: i, outer, bound, acc: acc1)
    | FieldAccess(target: t, field: _) -> return cap_scan_expr(expr: t, outer, bound, acc)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      let acc1 = cap_scan_expr(expr: c, outer, bound, acc)
      let acc2 = cap_scan_stmts(stmts: tb, outer, bound, acc: acc1)
      match eb do
        | None -> return acc2
        | Some(val: ebs) -> return cap_scan_stmts(stmts: ebs, outer, bound, acc: acc2)
      end
    | Match(target: t, cases: cs) ->
      let acc1 = cap_scan_expr(expr: t, outer, bound, acc)
      return cap_scan_match_cases(cases: cs, outer, bound, acc: acc1)
    | While(cond: c, body: b) ->
      let acc1 = cap_scan_expr(expr: c, outer, bound, acc)
      return cap_scan_stmts(stmts: b, outer, bound, acc: acc1)
    | For(var: v, start: s, end_expr: e, body: b) ->
      let acc1 = cap_scan_expr(expr: s, outer, bound, acc)
      let acc2 = cap_scan_expr(expr: e, outer, bound, acc: acc1)
      return cap_scan_stmts(stmts: b, outer, bound: v :: bound, acc: acc2)
    | Lambda(type_params: _, params: ps, ret_type: _, requires: _, throw_row: _, body: b) ->
      // Inner lambda: its own params shadow within its body, but free
      // references to outer linears still capture-consume.
      let inner_bound = collect_param_names(params: ps, acc: bound)
      return cap_scan_stmts(stmts: b, outer, bound: inner_bound, acc)
    | Raise(expr: e) | Force(expr: e) -> return cap_scan_expr(expr: e, outer, bound, acc)
    | Thunk(body: b) -> return cap_scan_expr(expr: b, outer, bound, acc)
    | ExternalRef(_) | Handler(_) -> return acc
    | Inject(handlers: _, body: b) -> return cap_scan_stmts(stmts: b, outer, bound, acc)
  end
end

let cap_scan_exprs = fn (
  exprs: [ HirExpr ], outer: [ string ], bound: [ string ], acc: [ string ]
) -> [ string ] do
  match exprs do
    | [] -> return acc
    | e :: rest ->
      return cap_scan_exprs(
        exprs: rest,
        outer,
        bound,
        acc: cap_scan_expr(expr: e, outer, bound, acc)
      )
  end
end

let cap_scan_call_args = fn (
  args: [ HirCallArg ], outer: [ string ], bound: [ string ], acc: [ string ]
) -> [ string ] do
  match args do
    | [] -> return acc
    | HirCallArg(label: _, value: v) :: rest ->
      return cap_scan_call_args(
        args: rest,
        outer,
        bound,
        acc: cap_scan_expr(expr: v, outer, bound, acc)
      )
  end
end

let cap_scan_named = fn (
  fields: [ HirNamedExpr ], outer: [ string ], bound: [ string ], acc: [ string ]
) -> [ string ] do
  match fields do
    | [] -> return acc
    | HirNamedExpr(name: _, value: v) :: rest ->
      return cap_scan_named(
        fields: rest,
        outer,
        bound,
        acc: cap_scan_expr(expr: v, outer, bound, acc)
      )
  end
end

let cap_scan_match_cases = fn (
  cases: [ HirMatchCase ], outer: [ string ], bound: [ string ], acc: [ string ]
) -> [ string ] do
  match cases do
    | [] -> return acc
    | HirMatchCase(pattern: p, body: bs) :: rest ->
      let pat_bound = cap_pattern_binders(pat: p, acc: bound)
      let acc1 = cap_scan_stmts(stmts: bs, outer, bound: pat_bound, acc)
      return cap_scan_match_cases(cases: rest, outer, bound, acc: acc1)
  end
end

let cap_pattern_binders = fn (pat: HirPatternKind, acc: [ string ]) -> [ string ] do
  match pat do
    | PLit(_) | PWild | POr(alts: _) -> return acc
    | PVar(name: n, sigil: _) -> return n :: acc
    | PCtor(variant: _, fields: fs, sigil: _) -> return cap_pattern_field_binders(fields: fs, acc)
    | PRec(fields: fs, is_partial: _) -> return cap_pattern_record_binders(fields: fs, acc)
  end
end

let cap_pattern_field_binders = fn (fields: [ HirPatternField ], acc: [ string ]) -> [ string ] do
  match fields do
    | [] -> return acc
    | HirPatternField(name: _, pattern: p) :: rest ->
      return cap_pattern_field_binders(fields: rest, acc: cap_pattern_binders(pat: p, acc))
  end
end

let cap_pattern_record_binders = fn (
  fields: [ HirRecordPatField ], acc: [ string ]
) -> [ string ] do
  match fields do
    | [] -> return acc
    | HirRecordPatField(name: _, pattern: p) :: rest ->
      return cap_pattern_record_binders(fields: rest, acc: cap_pattern_binders(pat: p, acc))
  end
end

// ─── Throw-point detection + pre-throw consumption scan ──────────────────────

/** True when `eff_row` is a non-empty throws row (i.e., the call may throw).
 *  A bare type variable / Unit row is treated as non-throwable: the caller
 *  has not committed to a concrete throws set yet, so the per-call check
 *  at the binder site of an as-yet-unresolved arrow does not fire.
 */
export let row_is_throwable = fn (eff_row: TypeExpr) -> bool do
  match eff_row do
    | TyRow(types: ts, rest: _) ->
      match ts do
        | [] -> return false
        | _ :: _ -> return true
      end
    | TyUnit | TyVar(_) | _ -> return false
  end
end

/** True when the direct value expression `en` is a throwable call or raise.
 *  Nested complex expressions (If, Match) are conservatively treated as
 *  potential throw points so that the pre-scan stops early rather than
 *  accidentally including post-throw consumptions in the pre-throw set.
 */
let throw_expr_has_throw_point = fn (en: HirExprKind, sigs: [ SigEntry ]) -> bool do
  match en do
    // Treat ALL function calls as potential throw points. This is conservative:
    // it may stop the pre-throw scan too early (when the call is actually pure),
    // which only means we fail to detect some pre-throw consumptions. The result
    // is that catch_vars keeps those outer linears available, which is safe (not
    // a false positive — the catch arm may legitimately need them). The
    // alternative of checking sig_lookup + row_is_throwable can silently miss
    // throwable calls when their throw_row is TyVar or the sig-map doesn't
    // include imported functions, causing false positives (E2008).
    | Call(_, _) | CallExpr(_, _) | Raise(_) -> return true
    // Nested constructs may contain throwable calls — stop conservatively.
    | If(_) | Match(_) -> return true
    | _ -> return false
  end
end

/** True when the statement directly contains a throwable call or raise at
 *  the top level of its value expression (for Let/Return) or directly
 *  (for Expr). Does not recurse into nested stmts/exprs beyond the first
 *  call-site level.
 */
let throw_stmt_has_throw_point = fn (nd: HirStmtKind, sigs: [ SigEntry ]) -> bool do
  match nd do
    | Expr(expr: HirExpr(node: en, span: _)) -> return throw_expr_has_throw_point(en, sigs)
    | Let(name: _, sigil: _, typ: _, value: HirExpr(node: en, span: _)) ->
      return throw_expr_has_throw_point(en, sigs)
    | Return(expr: HirExpr(node: en, span: _)) -> return throw_expr_has_throw_point(en, sigs)
    | _ -> return false
  end
end

/** Lightweight scan of try-body stmts to find outer linears consumed before
 *  the first throw point. Reuses cap_scan_expr for correct Variable matching.
 *  Unlike check_stmts (which does full linearity checking), this scan does
 *  NOT call check_stmt — it only tracks Variable references that consume outer
 *  linears. Stops at the first throwable call or raise (inclusive). This
 *  avoids mutual-recursion with walk.nx's SCC.
 */
export let scan_stmts_until_throw = fn (
  stmts: [ HirStmt ], outer_vars: [ string ], consumed: [ string ], sigs: [ SigEntry ]
) -> [ string ] do
  match stmts do
    | [] -> return consumed
    | HirStmt(node: nd, span: _) :: rest ->
      // Scan this statement's expression(s) for outer-linear consumption.
      let consumed1 = match nd do
        | Expr(expr: e) -> cap_scan_expr(expr: e, outer: outer_vars, bound: [], acc: consumed)
        | Let(name: _, sigil: _, typ: _, value: v) ->
          cap_scan_expr(expr: v, outer: outer_vars, bound: [], acc: consumed)
        | Return(expr: e) -> cap_scan_expr(expr: e, outer: outer_vars, bound: [], acc: consumed)
        | _ -> consumed
      end
      if throw_stmt_has_throw_point(nd, sigs) then
        return consumed1
      end
      return scan_stmts_until_throw(stmts: rest, outer_vars, consumed: consumed1, sigs)
  end
end
