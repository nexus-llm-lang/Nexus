/**
 * typecheck/linearity/predicates: linearity-specific predicates over enum/record defs.
 *
 * These helpers resolve per-field and per-variant linearity from the program's
 * type definitions. The canonical type predicates (is_auto_droppable,
 * is_linear_binding_type, is_linear, strip_mod) live in
 * src/ir/shared/type_pred.nx and are re-exported from there; this module
 * only contains predicates that need to walk EnumDef / RecordDef lists.
 */

import {
  TypeExpr,
  TyLinear,
  TyLazy,
  TyArray,
  TyRef,
  TyBorrow,
  TyVar,
  TyUserDefined,
  TyList,
  TyRecord,
  RecordDef,
  EnumDef,
  VariantDef,
  VariantField,
  NamedType
} from "src/types/type_expr.nx"
import { is_linear_binding_type } from "src/ir/shared/type_pred.nx"
import { Option, Some, None } from "std:option"

// ─── Linearity classification on TypeExpr ────────────────────────────────────
// Canonical predicates (is_auto_droppable, is_linear_binding_type) are
// imported from src/ir/shared/type_pred.nx above.

/** Look up the field list for an enum variant named `variant` by scanning all
 *  EnumDef.variants lists. Returns the VariantField list if found. Used by
 *  bind_pattern_fields to determine whether each PCtor field is linear.
 */
let lin_enum_variant_fields = fn (defs: [ EnumDef ], variant: string) -> Option<[ VariantField ]> do
  match defs do
    | [] -> return None
    | EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs) :: rest ->
      match lin_find_variant_in_list(vs, variant) do
        | Some(val: fs) -> return Some(val: fs)
        | None -> return lin_enum_variant_fields(defs: rest, variant)
      end
  end
end

let lin_find_variant_in_list = fn (
  vs: [ VariantDef ],
  variant: string
) -> Option<[ VariantField ]> do
  match vs do
    | [] -> return None
    | VariantDef(name: n, fields: fs) :: rest ->
      if n == variant then return Some(val: fs) end
      return lin_find_variant_in_list(vs: rest, variant)
  end
end

/** Return the TypeExpr for the i-th field of `variant_fields`, matching by
 *  name when `fname` is Some(…) and `variant_fields` has named fields, or by
 *  positional index otherwise. Returns None when no match is found.
 */
export let lin_variant_field_type_at = fn (
  variant_fields: [ VariantField ], fname: Option<string>, idx: i64
) -> Option<TypeExpr> do
  match variant_fields do
    | [] -> return None
    | VariantField(name: vfname, typ: t) :: rest ->
      match fname do
        | Some(val: n) ->
          match vfname do
            | Some(val: vn) ->
              if vn == n then return Some(val: t) end
              return lin_variant_field_type_at(variant_fields: rest, fname, idx: idx + 1)
            | None ->
              if idx == 0 then return Some(val: t) end
              return lin_variant_field_type_at(variant_fields: rest, fname, idx: idx - 1)
          end
        | None ->
          if idx == 0 then return Some(val: t) end
          return lin_variant_field_type_at(variant_fields: rest, fname, idx: idx - 1)
      end
  end
end

/** Return the TypeExpr for record field `fname` by scanning NamedType list.
 *  Used by bind_pattern_rec_fields to determine if a PRec field is linear.
 */
let lin_record_field_type_by_name = fn (fields: [ NamedType ], fname: string) -> Option<TypeExpr> do
  match fields do
    | [] -> return None
    | NamedType(name: n, typ: t) :: rest ->
      if n == fname then return Some(val: t) end
      return lin_record_field_type_by_name(fields: rest, fname)
  end
end

/** True when the named field `fname` of the RECORD type named `variant` is
 *  declared with a linear type. Returns false when the type is not found in
 *  `tdefs` or the field is not linear. Used by bind_pattern_fields_for_variant
 *  to avoid the fallback_linear over-approximation for record constructors.
 */
export let lin_record_type_field_is_linear = fn (
  tdefs: [ RecordDef ], variant: string, fname: string, enum_defs: [ EnumDef ]
) -> bool do
  match tdefs do
    | [] -> return false
    | RecordDef(name: n, is_public: _, type_params: _, fields: fs) :: rest ->
      if n == variant then
        match lin_record_field_type_by_name(fields: fs, fname) do
          | Some(val: ft) -> return is_linear_binding_type(ft, tdefs, enum_defs)
          | None -> return false
        end
      end
      return lin_record_type_field_is_linear(tdefs: rest, variant, fname, enum_defs)
  end
end

/** True when the record type `variant` is declared in tdefs. */
export let lin_record_type_is_known = fn (tdefs: [ RecordDef ], variant: string) -> bool do
  match tdefs do
    | [] -> return false
    | RecordDef(name: n, is_public: _, type_params: _, fields: _) :: rest ->
      if n == variant then return true end
      return lin_record_type_is_known(tdefs: rest, variant)
  end
end

/** Scan all RecordDefs for a record that has a field named `fname` with a
 *  linear type. Conservative: any match wins. Used for PRec patterns where
 *  the scrutinee type is not tracked through the pattern AST.
 */
export let lin_any_record_has_linear_field = fn (
  tdefs: [ RecordDef ], fname: string, enum_defs: [ EnumDef ]
) -> bool do
  match tdefs do
    | [] -> return false
    | RecordDef(name: _, is_public: _, type_params: _, fields: fs) :: rest ->
      match lin_record_field_type_by_name(fields: fs, fname) do
        | Some(val: ft) -> if is_linear_binding_type(ft, tdefs, enum_defs) then return true end
        | None -> ()
      end
      return lin_any_record_has_linear_field(tdefs: rest, fname, enum_defs)
  end
end

/** True when the named field `fname` of variant `variant` is declared with a
 *  linear type (is_linear_binding_type). Returns false when the variant is
 *  not found, when the field is not found, or when the field type is not linear.
 */
export let lin_field_is_linear = fn (
  defs: [ EnumDef ], variant: string, fname: string, tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match defs do
    | [] -> return false
    | EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs) :: rest ->
      if lin_variant_has_name(vs: vs, variant) then
        return lin_named_field_linear_in_variant(vs: vs, variant, fname, tdefs, enum_defs)
      end
      return lin_field_is_linear(defs: rest, variant, fname, tdefs, enum_defs)
  end
end

/** True when the named field `fname` of variant `variant` is declared with a
 *  bare generic-parameter slot, i.e. the field's declared type names one of the
 *  enum's `type_params` directly. Such a slot's concrete (and possibly linear)
 *  type is only fixed at instantiation. The linearity pass is name-based and has
 *  no instantiation map, so a parameter-typed field's linearity is *unknown*
 *  from the declared schema alone. When the matched value is itself a live
 *  linear binding (scrutinee_linear), such a field must conservatively inherit
 *  that linearity — otherwise a linear payload routed through a generic field
 * (`Pair<%T, _>`) silently leaks.
 *
 *  NOTE: the linearity pass runs BEFORE typecheck's `convert_ud_to_var`, so a
 *  generic parameter `A` appears in the raw schema as `TyUserDefined("A", [])`
 *  (a nullary nominal name) — not yet as `TyVar("A")`. Both shapes are accepted
 *  here, gated on membership in the enum's declared `type_params` so concrete
 *  nullary nominal fields (e.g. a field of type `Box`) are NOT misclassified.
 *  Returns false when the variant is not found or the field is not a param slot.
 */
export let lin_field_is_tyvar = fn (
  defs: [ EnumDef ], variant: string, fname: string
) -> bool do
  match defs do
    | [] -> return false
    | EnumDef(name: _, is_public: _, is_opaque: _, type_params: tps, variants: vs) :: rest ->
      if lin_variant_has_name(vs: vs, variant) then
        return lin_named_field_is_tyvar_in_variant(vs: vs, variant, fname, type_params: tps)
      end
      return lin_field_is_tyvar(defs: rest, variant, fname)
  end
end

let lin_named_field_is_tyvar_in_variant = fn (
  vs: [ VariantDef ], variant: string, fname: string, type_params: [ string ]
) -> bool do
  match vs do
    | [] -> return false
    | VariantDef(name: n, fields: fs) :: rest ->
      if n == variant then return lin_check_named_field_is_tyvar(fields: fs, fname, type_params) end
      return lin_named_field_is_tyvar_in_variant(vs: rest, variant, fname, type_params)
  end
end

let lin_check_named_field_is_tyvar = fn (
  fields: [ VariantField ], fname: string, type_params: [ string ]
) -> bool do
  match fields do
    | [] -> return false
    | VariantField(name: vfname, typ: t) :: rest ->
      match vfname do
        | Some(val: n) ->
          if n == fname then return lin_type_is_param_slot(t, type_params) end
          return lin_check_named_field_is_tyvar(fields: rest, fname, type_params)
        | None -> return lin_check_named_field_is_tyvar(fields: rest, fname, type_params)
      end
  end
end

/** True when `t` *depends on* one of `type_params` — i.e. a generic parameter
 *  occurs anywhere in `t`, either as the type itself (a bare slot) or buried
 *  inside a CARRIER (list element, type-argument, record field, ref/borrow
 *  wrapper). Such a type's concrete linearity is fixed only at instantiation,
 *  which the name-based linearity pass cannot see; when the matched value is a
 *  live linear binding, a parameter-dependent field must conservatively inherit
 *  that linearity so a linear payload routed through e.g. `Pair<%T, _>` (bare
 *  slot) OR `Wrap<[%T]>` (carrier `items: [A]`) is tracked at the inner binder.
 *
 *  Recognised forms:
 *    - bare slot:    `TyVar(p)` (post-convert) or `TyUserDefined(p, [])`
 *      (pre-convert raw HIR), gated on membership in `type_params` so a concrete
 *      nullary nominal field (type `Box`) is NOT misclassified;
 *    - carriers:     `[A]` (TyList), `Pair<A,_>` / `C<…, A, …>`
 *      (TyUserDefined with args), `~A`/`&A` (TyRef/TyBorrow), `{ f: A }`
 *      (TyRecord) — true when ANY component is itself parameter-dependent.
 *
 *  Matches the spec's transitive `linear(τ)` (type-system-formal §Linearity:
 *  linear holds if any transitive component — including LIST ELEMENT TYPES and
 *  type arguments — is linear), applied at instantiation time where the slot is
 *  bound to a linear scrutinee. */
let lin_type_is_param_slot = fn (t: TypeExpr, type_params: [ string ]) -> bool do
  match t do
    | TyVar(name: n) -> return lin_str_member(xs: type_params, target: n)
    | TyUserDefined(name: n, args: args) ->
      match args do
        | [] -> return lin_str_member(xs: type_params, target: n)
        // A named CARRIER (e.g. `Pair<A, _>`): parameter-dependent when any
        // type argument is itself parameter-dependent. The carrier name `n`
        // is a concrete type constructor, not a slot, so it is not checked
        // against `type_params`.
        | _ :: _ -> return lin_any_arg_is_param_slot(args, type_params)
      end
    // `[A]` (list carrier) — parameter-dependent iff its element type is.
    | TyList(elem: e) -> return lin_type_is_param_slot(t: e, type_params)
    // `~A`/`&A` wrappers thread through to the inner type.
    | TyRef(inner: i) | TyBorrow(inner: i) -> return lin_type_is_param_slot(t: i, type_params)
    // `{ f: A, … }` record carrier — parameter-dependent iff any field is.
    | TyRecord(fields: fs) -> return lin_any_named_is_param_slot(fields: fs, type_params)
    | _ -> return false
  end
end

let lin_any_arg_is_param_slot = fn (args: [ TypeExpr ], type_params: [ string ]) -> bool do
  match args do
    | [] -> return false
    | a :: rest ->
      if lin_type_is_param_slot(t: a, type_params) then return true end
      return lin_any_arg_is_param_slot(args: rest, type_params)
  end
end

let lin_any_named_is_param_slot = fn (fields: [ NamedType ], type_params: [ string ]) -> bool do
  match fields do
    | [] -> return false
    | NamedType(name: _, typ: ft) :: rest ->
      if lin_type_is_param_slot(t: ft, type_params) then return true end
      return lin_any_named_is_param_slot(fields: rest, type_params)
  end
end

let lin_str_member = fn (xs: [ string ], target: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == target then return true end
      return lin_str_member(xs: rest, target)
  end
end

/** True when any VariantDef in `vs` has name `variant`. Used to distinguish
 *  "variant found, field not linear" from "variant not found".
 */
let lin_variant_has_name = fn (vs: [ VariantDef ], variant: string) -> bool do
  match vs do
    | [] -> return false
    | VariantDef(name: n, fields: _) :: rest ->
      if n == variant then return true end
      return lin_variant_has_name(vs: rest, variant)
  end
end

/** True when variant `variant` in `vs` has a field named `fname` with a
 *  linear declared type. Returns false when variant not found or field not linear.
 */
let lin_named_field_linear_in_variant = fn (
  vs: [ VariantDef ], variant: string, fname: string, tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match vs do
    | [] -> return false
    | VariantDef(name: n, fields: fs) :: rest ->
      if n == variant then
        return lin_check_named_field_linear(fields: fs, fname, tdefs, enum_defs)
      end
      return lin_named_field_linear_in_variant(vs: rest, variant, fname, tdefs, enum_defs)
  end
end

let lin_check_named_field_linear = fn (
  fields: [ VariantField ], fname: string, tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match fields do
    | [] -> return false
    | VariantField(name: vfname, typ: t) :: rest ->
      match vfname do
        | Some(val: n) ->
          if n == fname then return is_linear_binding_type(t, tdefs, enum_defs) end
          return lin_check_named_field_linear(fields: rest, fname, tdefs, enum_defs)
        | None ->
          return lin_check_named_field_linear(fields: rest, fname, tdefs, enum_defs)
      end
  end
end

/** True when variant `variant` is declared in any EnumDef in `defs`. Used to
 *  distinguish "variant found, field not linear" from "variant not found" so
 *  bind_pattern_fields_for_variant can fall back to scrutinee_linear only when
 *  the variant is truly unknown.
 */
export let lin_variant_is_known = fn (defs: [ EnumDef ], variant: string) -> bool do
  match defs do
    | [] -> return false
    | EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs) :: rest ->
      if lin_variant_has_name(vs: vs, variant) then return true end
      return lin_variant_is_known(defs: rest, variant)
  end
end

/** True when `variant` matches an EnumDef TYPE NAME (not a variant/constructor
 *  name). Used for opaque-type patterns where variants are stripped during
 *  import (D-Type-Sum-Opaque): the constructor name equals the type name, but
 *  after stripping, lin_variant_is_known returns false. Matching the enum type
 *  name lets bind_pattern_fields_for_variant treat the fields as non-linear
 *  (since the struct carries only primitive fields) rather than falling back to
 *  scrutinee_linear, which would incorrectly track primitive i64 fields as linear.
 */
export let lin_enum_type_name_is_known = fn (defs: [ EnumDef ], variant: string) -> bool do
  match defs do
    | [] -> return false
    | EnumDef(name: n, is_public: _, is_opaque: _, type_params: _, variants: _) :: rest ->
      if n == variant then return true end
      return lin_enum_type_name_is_known(defs: rest, variant)
  end
end

/** True when the enum containing variant constructor `variant` has any variant
 *  whose field type is directly linear (TyLinear / TyLazy / TyArray). Uses the
 *  same shallow check as lin_variant_fields_any_linear in type_pred.nx: nominal
 *  types (TyUserDefined) are not recursed into, so transitively-linear enums
 *  (e.g. an enum whose field is a nominal type that eventually carries %T) are
 *  not flagged. This is intentional — only direct-linear-field enums require
 *  use-once tracking on the Ctor RHS.
 */
export let lin_ctor_enum_is_linear = fn (defs: [ EnumDef ], variant: string) -> bool do
  match defs do
    | [] -> return false
    | EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs) :: rest ->
      if lin_variant_has_name(vs, variant) then
        return lin_ctor_any_variant_field_linear(variants: vs)
      end
      return lin_ctor_enum_is_linear(defs: rest, variant)
  end
end

let lin_ctor_any_variant_field_linear = fn (variants: [ VariantDef ]) -> bool do
  match variants do
    | [] -> return false
    | VariantDef(name: _, fields: fs) :: rest ->
      if lin_ctor_fields_any_shallow_linear(fields: fs) then return true end
      return lin_ctor_any_variant_field_linear(variants: rest)
  end
end

let lin_ctor_fields_any_shallow_linear = fn (fields: [ VariantField ]) -> bool do
  match fields do
    | [] -> return false
    | VariantField(name: _, typ: t) :: rest ->
      if lin_ctor_field_is_shallow_linear(t) then return true end
      return lin_ctor_fields_any_shallow_linear(fields: rest)
  end
end

let lin_ctor_field_is_shallow_linear = fn (t: TypeExpr) -> bool do
  match t do
    | TyLinear(_) | TyLazy(_) | TyArray(_) -> return true
    | TyRef(inner: i) | TyBorrow(inner: i) -> return lin_ctor_field_is_shallow_linear(t: i)
    | _ -> return false
  end
end
