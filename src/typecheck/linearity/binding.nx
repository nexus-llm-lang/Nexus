/**
 * typecheck/linearity/binding: construction-env collection + match-site
 * (liveness-INDEPENDENT) linearity classification.
 *
 * Collects a flat `CtorBinding` env from a statement list and classifies
 * constructor arguments at a MATCH site, where the construction has already
 * consumed its linear args (so liveness reads are meaningless and a static,
 * liveness-independent classifier is required). The generic-field demotion
 * helper (`compute_demoted_tyvar_fields`) lives here too. Delegates the
 * liveness-DEPENDENT binding-site classification to `let_binds_linear` in
 * classify.nx.
 */

import { SigilImmutable, SigilLinear, SigilLazy } from "src/types/vocab.nx"
import { TypeExpr, RecordDef, EnumDef } from "src/types/type_expr.nx"
import {
  HirStmt, HirStmtKind, HirExpr, HirExprKind,
  HirCallArg, HirNamedExpr, HirMatchCase
} from "src/ir/hir/types.nx"
import { Option, Some, None } from "std:option"
import { is_linear_binding_type } from "src/ir/shared/type_pred.nx"
import { SigEntry, sig_lookup } from "src/typecheck/linearity/sig_map.nx"
import {
  LinState, CtorBinding,
  lin_member, lin_consumed_member, lin_lookup_ctor
} from "src/typecheck/linearity/state.nx"
import { lin_ctor_enum_is_linear } from "src/typecheck/linearity/predicates.nx"
import { last_stmt } from "src/typecheck/linearity/diverge.nx"
import {
  lookup_param_type_by_label, pt_shares_tyvar_with_rt
} from "src/typecheck/linearity/borrow_types.nx"
import { let_binds_linear } from "src/typecheck/linearity/classify.nx"

/** Walk a statement list and record every `let name = value` into a flat
 *  CtorBinding env. Descends into nested blocks (if/while/for/match/try/inject
 *  bodies and lambda bodies) so a scrutinee constructed in an inner block is
 *  still recoverable. The env is read-only after construction; shadowing is
 *  resolved by first-match in `lin_lookup_ctor` (outer-most binding wins),
 *  which is sound here because the env only ever DEMOTES a conservatively-
 *  linear classification — a stale/shadowed entry can at worst keep the
 *  current conservative behavior, never under-track. */
export let collect_ctor_bindings = fn (stmts: [ HirStmt ], acc: [ CtorBinding ]) -> [ CtorBinding ] do
  match stmts do
    | [] -> return acc
    | HirStmt(node: nd, span: _) :: rest ->
      let acc1 = collect_ctor_bindings_stmt(stmt: nd, acc)
      return collect_ctor_bindings(stmts: rest, acc: acc1)
  end
end

let collect_ctor_bindings_stmt = fn (stmt: HirStmtKind, acc: [ CtorBinding ]) -> [ CtorBinding ] do
  match stmt do
    | Let(name: n, sigil: _, typ: _, value: v) ->
      let acc1 = CtorBinding(name: n, value: v) :: acc
      return collect_ctor_bindings_expr(expr: v, acc: acc1)
    | Expr(expr: e) -> return collect_ctor_bindings_expr(expr: e, acc)
    | Return(expr: e) -> return collect_ctor_bindings_expr(expr: e, acc)
    | Assign(target: _, value: v) -> return collect_ctor_bindings_expr(expr: v, acc)
    | Try(body: b, catch_param: _, catch_body: cb) ->
      let acc1 = collect_ctor_bindings(stmts: b, acc)
      return collect_ctor_bindings(stmts: cb, acc: acc1)
  end
end

let collect_ctor_bindings_expr = fn (expr: HirExpr, acc: [ CtorBinding ]) -> [ CtorBinding ] do
  let HirExpr(node: nd, span: _) = expr
  match nd do
    | If(cond: _, then_branch: tb, else_branch: eb) ->
      let acc1 = collect_ctor_bindings(stmts: tb, acc)
      match eb do
        | Some(val: e) -> return collect_ctor_bindings(stmts: e, acc: acc1)
        | None -> return acc1
      end
    | Match(target: _, cases: cs) -> return collect_ctor_bindings_cases(cases: cs, acc)
    | While(cond: _, body: b) -> return collect_ctor_bindings(stmts: b, acc)
    | For(var: _, start: _, end_expr: _, body: b) -> return collect_ctor_bindings(stmts: b, acc)
    | Lambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: b) ->
      return collect_ctor_bindings(stmts: b, acc)
    | Inject(handlers: _, body: b) -> return collect_ctor_bindings(stmts: b, acc)
    | _ -> return acc
  end
end

let collect_ctor_bindings_cases = fn (cases: [ HirMatchCase ], acc: [ CtorBinding ]) -> [ CtorBinding ] do
  match cases do
    | [] -> return acc
    | HirMatchCase(pattern: _, body: b) :: rest ->
      let acc1 = collect_ctor_bindings(stmts: b, acc)
      return collect_ctor_bindings_cases(cases: rest, acc: acc1)
  end
end

/** For a match scrutinee `target` and the matched `variant`, compute the set
 *  of field NAMES whose generic (TyVar) slot was instantiated to a NON-linear
 *  argument at the scrutinee's construction site — i.e. fields that should NOT
 *  inherit the scrutinee's linearity (approach (a): substitute the variant's
 *  declared type-parameter against the scrutinee's structural type-args).
 *
 *  Only fields filled by a NON-linear construction arg are demoted; a TyVar
 *  slot filled by a linear arg (e.g. `Mix(payload:%p, gen:%q)`) is left to the
 *  conservative `lin_field_is_tyvar` inheritance so genuine linear payloads
 *  routed through generic slots stay tracked (preserves xim2n / 2djm4).
 *
 *  Returns [] when the construction expression is unavailable (scrutinee is a
 *  param, field access, nested expression, …) — falling back to the existing
 *  conservative behavior, never under-tracking. */
export let compute_demoted_tyvar_fields = fn (
  target: HirExpr, variant: string, st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> [ string ] do
  let HirExpr(node: tn, span: _) = target
  match tn do
    | Variable(name: m, sigil: _) ->
      match lin_lookup_ctor(st, name: m) do
        | None -> return []
        | Some(val: ce) ->
          let HirExpr(node: cn, span: _) = ce
          match cn do
            | Ctor(variant: cv, args: cargs, labels: clabels, sigil: _) ->
              // The construction must be for the same constructor we are
              // matching (otherwise the labels/args don't correspond).
              if cv != variant then return [] end
              return collect_nonlinear_ctor_fields(
                labels: clabels, args: cargs, st, sigs, tdefs, enum_defs, acc: []
              )
            | _ -> return []
          end
      end
    | _ -> return []
  end
end

/** Pair construction labels with args; a field whose construction arg is
 *  NON-linear is collected as demotable. */
let collect_nonlinear_ctor_fields = fn (
  labels: [ string ], args: [ HirExpr ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ], acc: [ string ]
) -> [ string ] do
  match labels do
    | [] -> return acc
    | lbl :: rest_labels ->
      match args do
        | [] -> return acc
        | a :: rest_args ->
          let arg_linear = ctor_arg_is_linear(arg: a, st, sigs, tdefs, enum_defs)
          let acc1 = if arg_linear then acc else lbl :: acc end
          return collect_nonlinear_ctor_fields(
            labels: rest_labels, args: rest_args, st, sigs, tdefs, enum_defs, acc: acc1
          )
      end
  end
end

/** Intrinsic (liveness-independent) linearity of a constructor ARGUMENT
 *  expression. Unlike `let_binds_linear`'s `Variable` case — which reads the
 *  CURRENT live set — this classifier must work at the MATCH site, where the
 *  construction already consumed its linear args (so they are no longer live).
 *  A linear-/lazy-sigil variable is classified by its SIGIL; a bare variable by
 *  live-OR-consumed membership; compound args (Ctor/Array/Record) recurse with
 *  this same liveness-independent classifier (their nested args were also
 *  consumed by the construction). ANY linear transitive component → linear.
 *  Calls/other shapes defer to `let_binds_linear`. When uncertain, the
 *  delegation/recursion errs toward `true`, keeping the field tracked. */
export let ctor_arg_is_linear = fn (
  arg: HirExpr, st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  let HirExpr(node: an, span: _) = arg
  match an do
    | Variable(name: vn, sigil: s) ->
      match s do
        | SigilLinear | SigilLazy -> return true
        | _ ->
          // A non-sigil variable: linear iff it was a live linear binding at
          // the match site OR a previously-consumed linear (consumed by the
          // construction itself). Both shapes mean the slot carried a linear.
          if lin_member(st, name: vn) then return true end
          return lin_consumed_member(st, name: vn)
      end
    // A borrow `&x` is never an owned linear — it does not transfer ownership.
    | Borrow(name: _, sigil: _) -> return false
    | Literal(_) -> return false
    // Compound args: recurse with the SAME liveness-independent classifier so a
    // nested linear variable already consumed by the construction (e.g. a list
    // literal `[b]` desugared to `Cons(Nil(), b)`, or `Some(%b)`) is still
    // recognised as carrying a linear. Delegating to `let_binds_linear` here is
    // unsound: its nested `Variable` case reads CURRENT liveness, and the
    // construction has already consumed those args. ANY linear component makes
    // the carrier linear (spec §Linearity: transitive linear(τ)).
    | Ctor(variant: cv, args: cargs, labels: _, sigil: csig) ->
      match csig do
        | SigilLinear | SigilLazy -> return true
        | _ ->
          if lin_ctor_enum_is_linear(defs: enum_defs, variant: cv) then return true end
          return any_ctor_arg_is_linear(args: cargs, st, sigs, tdefs, enum_defs)
      end
    | Array(elems: es) -> return any_ctor_arg_is_linear(args: es, st, sigs, tdefs, enum_defs)
    | Record(fields: fs) -> return any_record_field_is_linear(fields: fs, st, sigs, tdefs, enum_defs)
    // A Call result is classified LIVENESS-INDEPENDENTLY here: this call is
    // itself an argument of the enclosing construction, so any linear value it
    // launders (e.g. `Mix(gen: pick(x: %p))`) was ALREADY consumed by that
    // construction and is no longer live at the match site. Delegating to
    // `let_binds_linear` would read the (now-stale) live set for the call's
    // args and wrongly classify the result non-linear, demoting a field that in
    // fact carries a linear payload → silent drop / double-use (the c642e3d7
    // pre-7umo8 behavior correctly rejected this). We instead classify the call
    // statically and recurse into its args with THIS same liveness-independent
    // classifier. When the result is not PROVABLY non-linear (an opaque/closure
    // call whose return type we cannot resolve), we err toward `true` — keeping
    // the field tracked, the conservative-and-sound direction.
    | Call(func: f, args: cargs) ->
      return ctor_call_result_is_linear(
        func: f, cargs, st, sigs, tdefs, enum_defs
      )
    | CallExpr(callee: _, args: _) ->
      // Closure / field call: return type is unknown at this level, so the
      // result is NOT provably non-linear. Keep the field tracked.
      return true
    // A branch EXPRESSION (`if … then a else b end`) whose value is the
    // enclosing construction's argument. The construction has already consumed
    // any linear that one of its branches laundered (e.g.
    // `Mix(gen: if c then pick(x: %p) else … end)`), so the branch trailing
    // values must be classified with THIS liveness-independent classifier — not
    // `let_binds_linear`, whose `If`/`Match` cases fall through to `false`,
    // demoting a generic field that in fact carries a linear payload → silent
    // drop / double-use (the sibling of the 44873d2d direct-`Call` fix). ANY
    // branch yielding a linear makes the whole expression carry a linear (the
    // conservative-and-sound direction; the branches are alternatives, so a
    // linear flows out along whichever branch is taken).
    | If(cond: _, then_branch: tb, else_branch: eb) ->
      if block_trailing_value_is_linear(stmts: tb, st, sigs, tdefs, enum_defs) then return true end
      match eb do
        | Some(val: ebs) -> return block_trailing_value_is_linear(stmts: ebs, st, sigs, tdefs, enum_defs)
        | None -> return false
      end
    // A `match … do | p -> a | … end` branch expression — same reasoning as the
    // `If` arm: classify every arm's trailing value with this liveness-
    // independent classifier; any linear-yielding arm carries a linear out.
    | Match(target: _, cases: cs) ->
      return any_case_trailing_value_is_linear(cases: cs, st, sigs, tdefs, enum_defs)
    | _ ->
      // Other expression shapes: defer to the structural classifier. These do
      // not launder a construction-consumed linear through a generic slot, so
      // their liveness reads remain meaningful.
      return let_binds_linear(
        sigil: SigilImmutable, ann: None, value: arg, sigs, tdefs, enum_defs, pre_st: st
      )
  end
end

/** Liveness-INDEPENDENT linearity of a `Call(func, args)` appearing as a
 *  construction argument (so its own linear args were already consumed by the
 *  enclosing construction). Linear iff:
 *    (a) the callee's declared return type is itself statically linear, or
 *    (b) some call arg flows (by label) into a parameter whose type shares a
 *        callee type-parameter slot with the return type AND that arg is linear
 *        under `ctor_arg_is_linear` (the same liveness-independent classifier),
 *        i.e. a linear payload is laundered through the result's TyVar slot, or
 *    (c) the callee signature is unresolved — the result is not provably
 *        non-linear, so we conservatively keep it tracked.
 *  Returns false ONLY for a resolved signature with a provably non-linear
 *  return type and no linear payload flowing through a shared TyVar slot. */
let ctor_call_result_is_linear = fn (
  func: string, cargs: [ HirCallArg ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match sig_lookup(sigs, name: func) do
    | None ->
      // (c) Unresolved callee → not provably non-linear → keep tracked.
      return true
    | Some(val: SigEntry(name: _, type_params: tps, param_labels: pls, param_types: pts, ret_type: rt, throw_row: _)) ->
      // (a) Statically-linear return type.
      if is_linear_binding_type(t: rt, tdefs, enum_defs) then return true end
      // No declared type parameters → no TyVar slot can carry a laundered
      // linear; with a non-linear `rt` the result is provably non-linear.
      match tps do
        | [] -> return false
        | _ ->
          // (b) Param→result-slot flow with a liveness-independent arg check.
          return any_ctor_call_arg_propagates_linear(
            args: cargs, type_params: tps, param_labels: pls,
            param_types: pts, ret_type: rt, st, sigs, tdefs, enum_defs
          )
      end
  end
end

let any_ctor_call_arg_propagates_linear = fn (
  args: [ HirCallArg ], type_params: [ string ], param_labels: [ string ],
  param_types: [ TypeExpr ], ret_type: TypeExpr, st: LinState,
  sigs: [ SigEntry ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match args do
    | [] -> return false
    | HirCallArg(label: l, value: v) :: rest ->
      match lookup_param_type_by_label(labels: param_labels, types: param_types, target: l) do
        | Some(val: pt) ->
          if pt_shares_tyvar_with_rt(pt, rt: ret_type, type_params) then
            // Classify the propagated arg with the SAME liveness-independent
            // classifier — its linear was consumed by the outer construction.
            if ctor_arg_is_linear(arg: v, st, sigs, tdefs, enum_defs) then return true end
          end
        | None -> ()
      end
      return any_ctor_call_arg_propagates_linear(
        args: rest, type_params, param_labels, param_types, ret_type, st, sigs, tdefs, enum_defs
      )
  end
end

export let any_ctor_arg_is_linear = fn (
  args: [ HirExpr ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match args do
    | [] -> return false
    | a :: rest ->
      if ctor_arg_is_linear(arg: a, st, sigs, tdefs, enum_defs) then return true end
      return any_ctor_arg_is_linear(args: rest, st, sigs, tdefs, enum_defs)
  end
end

let any_record_field_is_linear = fn (
  fields: [ HirNamedExpr ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match fields do
    | [] -> return false
    | HirNamedExpr(name: _, value: v) :: rest ->
      if ctor_arg_is_linear(arg: v, st, sigs, tdefs, enum_defs) then return true end
      return any_record_field_is_linear(fields: rest, st, sigs, tdefs, enum_defs)
  end
end

/** Liveness-INDEPENDENT linearity of a branch-body block's VALUE. A block used
 *  as a branch of an `if`/`match` EXPRESSION yields its trailing statement's
 *  expression; classify that expression with `ctor_arg_is_linear` (the same
 *  liveness-independent classifier the enclosing construction context uses). A
 *  block whose trailing statement is not value-producing (e.g. an assignment,
 *  or it diverges) contributes no linear value along that branch → false. */
let block_trailing_value_is_linear = fn (
  stmts: [ HirStmt ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match last_stmt(stmts: stmts) do
    | None -> return false
    | Some(val: HirStmt(node: sk, span: _)) ->
      match sk do
        | Expr(expr: e) -> return ctor_arg_is_linear(arg: e, st, sigs, tdefs, enum_defs)
        | Return(expr: e) -> return ctor_arg_is_linear(arg: e, st, sigs, tdefs, enum_defs)
        | _ -> return false
      end
  end
end

/** ANY `match` arm whose trailing value is linear under the liveness-
 *  independent classifier makes the whole `match` expression carry a linear. */
let any_case_trailing_value_is_linear = fn (
  cases: [ HirMatchCase ], st: LinState, sigs: [ SigEntry ],
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> bool do
  match cases do
    | [] -> return false
    | HirMatchCase(pattern: _, body: b) :: rest ->
      if block_trailing_value_is_linear(stmts: b, st, sigs, tdefs, enum_defs) then return true end
      return any_case_trailing_value_is_linear(cases: rest, st, sigs, tdefs, enum_defs)
  end
end
