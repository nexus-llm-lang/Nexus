/**
 * typecheck/infer: Hindley-Milner inference over HIR.
 *
 * Owns:
 *   - `infer_expr`: top-level expression dispatcher; arms delegate to sub-files.
 *   - `infer_stmts`: statement-list sequencer; delegates `infer_stmt_impl`
 *     (in stmt_eval.nx) for each statement.
 *   - `infer_binop` / `infer_unop`: binary / unary operator inference (short,
 *     kept here because they call infer_expr directly and add no sub-file value).
 *
 * Does not own:
 *   - Core type-check entry / top-level orchestration (see src/typecheck/check.nx)
 *   - Substitution operations (see src/typecheck/subst.nx)
 *   - Unification (see src/typecheck/unify.nx)
 *   - Type-expression datatypes and builtin type constants (see src/typecheck/types.nx)
 *   - Call inference (see src/typecheck/infer/call.nx)
 *   - Constructor inference (see src/typecheck/infer/constructor.nx)
 *   - Expression-form inference (see src/typecheck/infer/exprs.nx)
 *   - Statement-kind inference (see src/typecheck/infer/stmt_eval.nx)
 *
 * Implementation is split across sub-files in src/typecheck/infer/:
 *   literals.nx    — literal / variable / borrow / scheme instantiation (no infer_expr)
 *   operators.nx   — binary / unary operator type resolution (no infer_expr)
 *   collections.nx — named-type / field lookup helpers (no infer_expr)
 *   call_args.nx   — call-arg label validation and reordering (no infer_expr)
 *   constructor.nx — variant-field sorting, enum-type building, ctor inference
 *   call.nx        — function-call type inference
 *   exprs.nx       — record / array / index / field / if / match / while / for /
 *                    lambda / raise / force / thunk inference
 *   stmt_eval.nx   — let / return / try / inject / assign statement inference
 *   control_flow.nx — divergence predicates, raise admission, inject checks
 *   effects.nx     — handler-arm ref-capture scan, require-row extension
 *   statements.nx  — pattern binding, let-binding helpers, catch-param projection
 *   closure.nx     — parameter type building and env extension
 */

import { Span } from "src/common/token.nx"
import {
  TypeExpr, TyUnit, TyBool, TyHandler,
  BinaryOp, UnaryOp, OpNeg, OpFNeg, OpNot
} from "src/common/ast.nx"
import { HirExprKind, HirExpr, HirStmtKind, HirStmt } from "src/ir/hir/types.nx"
import { validate_inline_handler_arm_set } from "src/typecheck/check/registration.nx"
import {
  CheckState,
  InferExprResult, InferExprOk, InferExprErr,
  UnifyOk, UnifyErr
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as unify from "src/typecheck/unify.nx"
import * as capture from "src/typecheck/capture.nx"
import * as tcwf from "src/typecheck/tcwf.nx"
import { infer_literal, infer_variable, infer_borrow } from "src/typecheck/infer/literals.nx"
import * as operators from "src/typecheck/infer/operators.nx"
import { infer_constructor } from "src/typecheck/infer/constructor.nx"
import { stmt_diverges } from "src/typecheck/infer/control_flow.nx"
import { scan_handler_arms_for_ref_capture } from "src/typecheck/infer/effects.nx"
import { infer_call } from "src/typecheck/infer/call.nx"
import {
  infer_record, infer_array, infer_index, infer_field_access,
  infer_if, infer_match,
  infer_while, infer_for, infer_lambda,
  infer_raise, infer_force, infer_thunk,
  infer_call_expr
} from "src/typecheck/infer/exprs.nx"
import { infer_stmt_impl } from "src/typecheck/infer/stmt_eval.nx"
import { TypeError, UnreachableCode } from "src/typecheck/errors.nx"
import { Option, Some, None } from "std:option"

/** Infer the type of a HIR expression in `state`. `ret_type` is the enclosing function's return type (used to type-check `return`). Threads a substitution and updated state through the result. */
export let infer_expr = fn (
  state: CheckState,
  expr: HirExpr,
  ret_type: TypeExpr
) -> InferExprResult throws { TypeError } do
  let HirExpr(node, span: sp) = expr
  match node do
    | Literal(lit) -> return infer_literal(state, lit, span: sp)
    | Variable(name, sigil) -> return infer_variable(state, name, sigil, span: sp)
    | Borrow(name, sigil: _) -> return infer_borrow(state, name, span: sp)
    | BinOp(left, op, right) ->
      return infer_binop(state, left, op, right, span: sp, expected: None)
    | UnOp(op, operand) ->
      return infer_unop(state, op, operand, span: sp)
    | Call(func, args) ->
      return infer_call(state, func, args, span: sp, infer_expr_fn: infer_expr)
    | CallExpr(callee, args) ->
      return infer_call_expr(state, callee, args, span: sp, infer_expr_fn: infer_expr)
    | Ctor(variant, args, labels, sigil) ->
      return infer_constructor(
        state,
        variant,
        args,
        labels,
        sigil,
        span: sp,
        infer_expr_fn: infer_expr
      )
    | Record(fields) ->
      return infer_record(state, fields, span: sp, infer_expr_fn: infer_expr)
    | Array(elems) ->
      return infer_array(state, elems, span: sp, infer_expr_fn: infer_expr)
    | Index(target, index) ->
      return infer_index(state, target, index, span: sp, infer_expr_fn: infer_expr)
    | FieldAccess(target, field) ->
      return infer_field_access(state, target, field, span: sp, infer_expr_fn: infer_expr)
    | If(cond, then_branch: then_b, else_branch: else_b) ->
      return infer_if(
        state,
        cond,
        then_b,
        else_b,
        ret_type,
        span: sp,
        infer_expr_fn: infer_expr,
        infer_stmts_fn: infer_stmts
      )
    | Match(target, cases) ->
      return infer_match(
        state,
        target,
        cases,
        ret_type,
        span: sp,
        infer_expr_fn: infer_expr,
        infer_stmts_fn: infer_stmts
      )
    | While(cond, body) ->
      return infer_while(
        state,
        cond,
        body,
        ret_type,
        span: sp,
        infer_expr_fn: infer_expr,
        infer_stmts_fn: infer_stmts
      )
    | For(var, start, end_expr: end_e, body) ->
      return infer_for(
        state,
        var,
        start,
        end_e,
        body,
        ret_type,
        span: sp,
        infer_expr_fn: infer_expr,
        infer_stmts_fn: infer_stmts
      )
    | Lambda(type_params: tps, params, ret_type: ret, requires: req, throw_row: tw, body) ->
      return infer_lambda(
        state,
        type_params: tps,
        params,
        ret_type: ret,
        requires: req,
        throw_row: tw,
        body,
        span: sp,
        infer_stmts_fn: infer_stmts
      )
    | Raise(expr: inner) ->
      return infer_raise(state, inner, span: sp, infer_expr_fn: infer_expr)
    | Force(expr: inner) ->
      return infer_force(state, inner, ret_type, span: sp, infer_expr_fn: infer_expr)
    | Thunk(body: b) ->
      return infer_thunk(state, body: b, ret_type, span: sp, infer_expr_fn: infer_expr)
    | ExternalRef(symbol: _, type_params: _, arg_names: _, typ) ->
      return InferExprOk(state, subst: subst.subst_empty(), typ)
    | Handler(cap_name: pname, requires: handler_req, arms: hms) ->
      // Inline handler expressions type as TyHandler(cap, requires).
      // The requires row is now preserved from the source-level `require { ... }`
      // declaration so that inject-site require-subset checking (T-Inject:
      // ∀i. ρ_i ⊆ ρ_q) can verify it against the ambient row at the inject
      // site.  Top-level handler bindings go through register_handler_bindings
      // which still registers an empty requires row; those handlers are
      // looked up by name at inject time and their TyHandler.requires is used
      // for the subset check.
      //
      // spec §T-Handler (type-system-formal.md)
      // requires `∀y ∈ ⋃_j fv(e_j) ∩ dom(Γ). Γ(y) ≠ ~σ` — the same
      // no-ref-capture premise T-Lambda enforces. Handler arms are hoisted
      // out to top-level HirFunctions later (synthesize_handler) and re-
      // checked via check_handler_arm_bodies, but by then the construction-
      // site env is lost. Run the scan here where we still see it, mirroring
      // infer_lambda's RefCaptureHit handling.
      //
      // T-Handler wfCap: the declared `require { … }` row of an inline handler
      // must satisfy wfCap — every named capability must be in SysCaps or a
      // declared cap.  Global handlers are checked in register_handler_bindings
      // (check.nx); inline expression handlers are checked here.
      // We pass `caps: []` here because inline handlers cannot name user caps
      // in their require row (only system capabilities are valid at expression
      // sites without an enclosing cap declaration context) — the same
      // convention used by check_handler_arm_throw_rows for arm-level caps.
      tcwf.wf_cap(row: handler_req, caps: [], span: sp)
      // T-Handler arm/method 1-1 correspondence for inline handler expressions
      // (spec T-Handler). Top-level handlers are validated in check_program via
      // validate_handler_arm_sets before body checking; inline handlers reach
      // infer_expr directly and were previously skipped. We use the cap_name as
      // the synthetic handler_name for error messages.
      validate_inline_handler_arm_set(
        caps: tctypes.state_caps(state),
        cap_name: pname,
        handler_name: pname,
        arms: hms,
        span: sp
      )
      match scan_handler_arms_for_ref_capture(arms: hms, outer_env: tctypes.state_env(state)) do
        | Some(val: capture.RefCaptureHit(name: rn, span: rsp)) ->
          return InferExprErr(
            message: "handler arm captures mutable ref binding " ++ rn ++ " (refs are stack-confined)",
            span: rsp
          )
        | None ->
          return InferExprOk(
            state,
            subst: subst.subst_empty(),
            typ: TyHandler(name: pname, requires: handler_req)
          )
      end
  end
end

// infer_binop: infer a binary op with an optional annotation hint.
// When `expected` is `Some(τ)` and the operands are all-literal sub-expressions,
// the hint is threaded into `select_int_type`/`select_float_type` so that
// `intlit × intlit` resolves to `τ` instead of defaulting to i64/f64.
// To propagate the hint into nested arithmetic (e.g. `2 * 3 - 1`), sub-expressions
// that are themselves BinOps are inferred recursively through `infer_binop` with the
// same expected type, rather than through `infer_expr` (which has no expected parameter).
let infer_binop = fn (
  state: CheckState,
  left: HirExpr,
  op: BinaryOp,
  right: HirExpr,
  span: Span,
  expected: Option<TypeExpr>
) -> InferExprResult throws { TypeError } do
  let HirExpr(node: left_node, span: lspan) = left
  let lt_result = match left_node do
    | BinOp(left: ll, op: lop, right: lr) ->
      infer_binop(state, left: ll, op: lop, right: lr, span: lspan, expected)
    | _ ->
      infer_expr(state, expr: left, ret_type: TyUnit)
  end
  match lt_result do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t1) ->
      let HirExpr(node: right_node, span: rspan) = right
      let rt_result = match right_node do
        | BinOp(left: rl, op: rop, right: rr) ->
          infer_binop(state: st1, left: rl, op: rop, right: rr, span: rspan, expected)
        | _ ->
          infer_expr(state: st1, expr: right, ret_type: TyUnit)
      end
      match rt_result do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
        | InferExprOk(state: st2, subst: s2, typ: t2) ->
          let s12 = subst.subst_compose(s1, s2)
          let lt = subst.subst_apply(subst: s12, typ: t1)
          let rt = subst.subst_apply(subst: s12, typ: t2)
          return operators.resolve_binop_types(state: st2, subst: s12, op, lt, rt, span, expected)
      end
  end
end

/** Infer a binary op with annotation hint `expected`; for use by infer_let_impl when the let-binding has a concrete numeric type annotation. */
export let infer_binop_hinted = fn (
  state: CheckState,
  left: HirExpr,
  op: BinaryOp,
  right: HirExpr,
  span: Span,
  expected: Option<TypeExpr>
) -> InferExprResult throws { TypeError } do
  return infer_binop(state, left, op, right, span, expected)
end

let infer_unop = fn (
  state: CheckState,
  op: UnaryOp,
  operand: HirExpr,
  span: Span
) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: operand, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t) ->
      let tdefs = tctypes.state_typedefs(state: st1)
      let target = match op do
        | OpNeg -> operators.select_int_type(a: t, b: t, expected: None)
        | OpFNeg -> operators.select_float_type(a: t, b: t, expected: None)
        | OpNot -> TyBool
      end
      match unify.unify(t1: t, t2: target, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(message: "unary operand: " ++ m, span)
        | UnifyOk(subst: s2) ->
          return InferExprOk(state: st1, subst: subst.subst_compose(s1, s2), typ: target)
      end
  end
end

/** Infer types for a statement sequence, threading state and accumulating subst; the result type is that of the final statement (or unit if empty). */
export let infer_stmts = fn (
  state: CheckState,
  stmts: [ HirStmt ],
  ret_type: TypeExpr
) -> InferExprResult throws { TypeError } do
  match stmts do
    | [] -> return InferExprOk(state, subst: subst.subst_empty(), typ: TyUnit)
    | HirStmt(node: s, span: sp) :: rest ->
      match infer_stmt(state, stmt: s, ret_type, span: sp) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
        | InferExprOk(state: st1, subst: s1, typ: stmt_type) ->
          match rest do
            | [] ->
              return InferExprOk(state: st1, subst: s1, typ: stmt_type)
            | HirStmt(node: _, span: rest_sp) :: _ ->
              // T-Seq: if τ₁ = ⊥ (the statement diverges), all following
              // statements are unreachable — reject with E2021.
              if stmt_diverges(s) then
                throw UnreachableCode(span: rest_sp)
              end
              let env1 = subst.subst_apply_env(subst: s1, env: tctypes.state_env(state: st1))
              let st2 = tctypes.state_with_env(state: st1, env: env1)
              match infer_stmts(
                state: st2,
                stmts: rest,
                ret_type: subst.subst_apply(subst: s1, typ: ret_type)
              ) do
                | InferExprErr(
                  message: m,
                  span: espan
                ) -> return InferExprErr(message: m, span: espan)
                | InferExprOk(state: st3, subst: s2, typ: t) ->
                  return InferExprOk(state: st3, subst: subst.subst_compose(s1, s2), typ: t)
              end
          end
      end
  end
end

let infer_stmt = fn (
  state: CheckState,
  stmt: HirStmtKind,
  ret_type: TypeExpr,
  span: Span
) -> InferExprResult throws { TypeError } do
  return infer_stmt_impl(
    state,
    stmt,
    ret_type,
    span,
    infer_expr_fn: infer_expr,
    infer_stmts_fn: infer_stmts,
    infer_binop_fn: infer_binop_hinted
  )
end
