/**
 * typecheck/infer: Hindley-Milner inference over HIR.
 *
 * Owns:
 * - Expression / statement / pattern type inference (infer_expr, infer_stmt, infer_pattern)
 * - CheckState threading for fresh type-variable generation
 * - Binary-op, call, constructor, record, array, index type inference
 * - If / match / while / for / lambda / throw / force inference
 * - Effect-row inference (throws, require) and exception-group handling
 * - Handler / port inference
 *
 * Does not own:
 * - Core type-check entry / top-level orchestration (see src/typecheck/check.nx)
 * - Substitution operations (see src/typecheck/subst.nx)
 * - Unification (see src/typecheck/unify.nx)
 * - Type-expression datatypes and builtin type constants (see src/typecheck/types.nx)
 */

import { Span } from "src/common/token.nx"
import {
  TypeExpr, TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyLazy, TyBorrow,
  TyArray, TyList, TyRecord, TyRow, TyHandler, NamedType,
  BinaryOp, OpAdd, OpSub, OpMul, OpDiv, OpMod,
  OpFAdd, OpFSub, OpFMul, OpFDiv,
  OpEq, OpNe, OpLt, OpLe, OpGt, OpGe,
  OpFEq, OpFNe, OpFLt, OpFLe, OpFGt, OpFGe,
  OpBitAnd, OpBitOr, OpBitXor, OpShl, OpShr,
  OpAnd, OpOr, OpConcat,
  UnaryOp, OpNeg, OpFNeg, OpNot,
  Literal,
  Sigil, SigilMutable, SigilLazy, SigilLinear,
  VariantField, RecordDef
} from "src/common/ast.nx"
import {
  HirExprKind, HirExpr, HirStmtKind, HirStmt,
  HirCallArg, HirNamedExpr, HirMatchCase, HirParam,
  HirPatternKind,
  ExceptionGroupEntry, HirPort,
  HirHandlerArm, HirFunction, EagerBody, LazyBody
} from "src/ir/hir/types.nx"
import {
  SubstEntry, Scheme, EnvEntry, CheckState, FreshResult,
  InferExprResult, InferExprOk, InferExprErr,
  UnifyOk, UnifyErr,
  BindResult, BindOk, BindErr,
  EnumVariantInfo
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as unify from "src/typecheck/unify.nx"
import * as capture from "src/typecheck/capture.nx"
import * as exhaustive from "src/typecheck/exhaustive.nx"
import * as tcwf from "src/typecheck/tcwf.nx"
import {
  InstantiateResult, FreshenResult,
  infer_literal, infer_variable, infer_borrow, infer_borrow_arg_position,
  instantiate_scheme, freshen_type_params
}, * as literals from "src/typecheck/infer/literals.nx"
import * as operators from "src/typecheck/infer/operators.nx"
import {
  reverse_named_types, lookup_named_type,
  find_linear_field, type_carries_linear
}, * as collections from "src/typecheck/infer/collections.nx"
import {
  ArgLabelCheck, ArgLabelOk, ArgLabelErr,
  validate_arg_labels, reorder_args_by_params,
  check_bset_no_consume_borrow_conflict
} from "src/typecheck/infer/call_args.nx"
import {
  sort_variant_fields, build_enum_type
} from "src/typecheck/infer/constructor.nx"
import {
  RaiseAdmissionResult, RaiseOk, RaiseRejected,
  check_raise_admitted, row_admits_exception, exception_name_of_raised,
  stmt_diverges, infer_stmts_tail_diverges,
  check_handlers_bound, check_inject_uniqueness, check_inject_require_subset
} from "src/typecheck/infer/control_flow.nx"
import {
  append_env, bind_pattern,
  LetMutLinearKind, LetMutOk, LetMutLinearBare, LetMutLinearLazy, LetMutLinearStructural,
  let_mut_linear_kind, alias_poly_scheme, wrap_ref,
  catch_param_type_from_row,
  default_numeric_literals
} from "src/typecheck/infer/statements.nx"
import { TypeError, DuplicateRecordLabel, UnreachableCode, RefEscapes } from "src/typecheck/errors.nx"
import * as list from "std:list"
import { Option, Some, None } from "std:option"

/** Infer the type of a HIR expression in `state`. `ret_type` is the enclosing function's return type (used to type-check `return`). Threads a substitution and updated state through the result. */
export let infer_expr = fn (state: CheckState, expr: HirExpr, ret_type: TypeExpr) -> InferExprResult throws { TypeError } do
  let HirExpr(node, span: sp) = expr
  match node do
    | Literal(lit) -> return infer_literal(state, lit, span: sp)
    | Variable(name, sigil) -> return infer_variable(state, name, sigil, span: sp)
    | Borrow(name, sigil: _) -> return infer_borrow(state, name, span: sp)
    | BinOp(left, op, right) ->
      return infer_binop(state, left, op, right, span: sp)
    | UnOp(op, operand) ->
      return infer_unop(state, op, operand, span: sp)
    | Call(func, args) ->
      return infer_call(state, func, args, span: sp)
    | Ctor(variant, args, labels, sigil) ->
      return infer_constructor(state, variant, args, labels, sigil, span: sp)
    | Record(fields) ->
      return infer_record(state, fields, span: sp)
    | Array(elems) ->
      return infer_array(state, elems, span: sp)
    | Index(target, index) ->
      return infer_index(state, target, index, span: sp)
    | FieldAccess(target, field) ->
      return infer_field_access(state, target, field, span: sp)
    | If(cond, then_branch: then_b, else_branch: else_b) ->
      return infer_if(state, cond, then_b, else_b, ret_type, span: sp)
    | Match(target, cases) ->
      return infer_match(state, target, cases, ret_type, span: sp)
    | While(cond, body) ->
      return infer_while(state, cond, body, ret_type, span: sp)
    | For(var, start, end_expr: end_e, body) ->
      return infer_for(state, var, start, end_e, body, ret_type, span: sp)
    | Lambda(type_params: tps, params, ret_type: ret, body) ->
      return infer_lambda(state, type_params: tps, params, ret_type: ret, body, span: sp)
    | Raise(expr: inner) ->
      return infer_raise(state, inner, span: sp)
    | Force(expr: inner) ->
      return infer_force(state, inner, ret_type, span: sp)
    | Thunk(body: b) ->
      return infer_thunk(state, body: b, ret_type, span: sp)
    | ExternalRef(symbol: _, type_params: _, arg_names: _, typ) ->
      return InferExprOk(state, subst: subst.subst_empty(), typ)
    | Handler(port_name: pname, requires: handler_req, arms: hms) ->
      // Inline handler expressions type as TyHandler(port, requires).
      // The requires row is now preserved from the source-level `require { ... }`
      // declaration so that inject-site require-subset checking (T-Inject:
      // ∀i. ρ_i ⊆ ρ_q) can verify it against the ambient row at the inject
      // site.  Top-level handler bindings go through register_handler_bindings
      // which still registers an empty requires row; those handlers are
      // looked up by name at inject time and their TyHandler.requires is used
      // for the subset check.
      //
      // spec T-Handler (type-system-formal.md line ~1122)
      // requires `∀y ∈ ⋃_j fv(e_j) ∩ dom(Γ). Γ(y) ≠ ~σ` — the same
      // no-ref-capture premise T-Lambda enforces. Handler arms are hoisted
      // out to top-level HirFunctions later (synthesize_handler) and re-
      // checked via check_handler_arm_bodies, but by then the construction-
      // site env is lost. Run the scan here where we still see it, mirroring
      // infer_lambda's RefCaptureHit handling.
      //
      // T-Handler wfCap: the declared `require { … }` row of an inline handler
      // must satisfy wfCap — every named capability must be in SysCaps or a
      // declared port.  Global handlers are checked in register_handler_bindings
      // (check.nx); inline expression handlers are checked here.
      // We pass `ports: []` here because inline handlers cannot name user ports
      // in their require row (only system capabilities are valid at expression
      // sites without an enclosing port declaration context) — the same
      // convention used by check_handler_arm_throw_rows for arm-level caps.
      tcwf.wf_cap(row: handler_req, ports: [], span: sp)
      match scan_handler_arms_for_ref_capture(arms: hms, outer_env: tctypes.state_env(state)) do
        | Some(val: capture.RefCaptureHit(name: rn, span: rsp)) ->
          return InferExprErr(message: "handler arm captures mutable ref binding " ++ rn ++ " (refs are stack-confined)", span: rsp)
        | None ->
          return InferExprOk(state, subst: subst.subst_empty(), typ: TyHandler(name: pname, requires: handler_req))
      end
  end
end

// ─── Binary operator inference ──────────────────────────────────────────────

let infer_binop = fn (state: CheckState, left: HirExpr, op: BinaryOp, right: HirExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: left, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t1) ->
      match infer_expr(state: st1, expr: right, ret_type: TyUnit) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
        | InferExprOk(state: st2, subst: s2, typ: t2) ->
          let s12 = subst.subst_compose(s1, s2)
          let lt = subst.subst_apply(subst: s12, typ: t1)
          let rt = subst.subst_apply(subst: s12, typ: t2)
          return operators.resolve_binop_types(state: st2, subst: s12, op, lt, rt, span)
      end
  end
end

// ─── Unary operator inference ───────────────────────────────────────────────

let infer_unop = fn (state: CheckState, op: UnaryOp, operand: HirExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: operand, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t) ->
      let tdefs = tctypes.state_typedefs(state: st1)
      let target = match op do
        | OpNeg -> operators.select_int_type(a: t, b: t)
        | OpFNeg -> operators.select_float_type(a: t, b: t)
        | OpNot -> TyBool
      end
      match unify.unify(t1: t, t2: target, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(message: "unary operand: " ++ m, span)
        | UnifyOk(subst: s2) ->
          return InferExprOk(state: st1, subst: subst.subst_compose(s1, s2), typ: target)
      end
  end
end

// ─── Call inference ─────────────────────────────────────────────────────────

let infer_call = fn (state: CheckState, func: string, args: [HirCallArg], span: Span) -> InferExprResult throws { TypeError } do
  match tctypes.env_lookup(env: tctypes.state_env(state), name: func) do
    | None -> return InferExprErr(message: "unbound function: " ++ func, span)
    | Some(val: sch) ->
      match instantiate_scheme(state, scheme: sch) do
        | InstantiateResult(state: st1, typ: func_type_raw) ->
          // Peel `%`/`@` modality wrappers introduced by linear-capture or
          // lazy-capture lambdas: `let f = mk_capture(b)` gives
          // `f : %(z: i64) -> i64`, but calling `f(z: 0)` should still
          // resolve the inner arrow shape.
          let func_type = match func_type_raw do
            | TyLinear(inner: u) | TyLazy(inner: u) -> u
            | _ -> func_type_raw
          end
          match func_type do
            | TyArrow(params, ret, requires: _, throw_row: callee_thr) ->
              match check_call_args(state: st1, params, args, ret, subst: subst.subst_empty(), span) do
                | InferExprErr(message: m, span: esp) -> return InferExprErr(message: m, span: esp)
                | InferExprOk(state: st2, subst: s_all, typ: rt) ->
                  // T-App effect side-condition: every concrete exception
                  // raisable by the callee must be admitted by the caller's
                  // active throws-row. Without this the typechecker tracks
                  // throw_row but never enforces it for calls — narrowing
                  // a function to `throws { LirError }` then calling a
                  // `throws { TypeError }` callee would type-check while violating
                  // the narrow contract. Mirrors the row-subsumption logic
                  // used for direct raises (see check_raise_admitted).
                  let callee_row = subst.subst_apply(subst: s_all, typ: callee_thr)
                  let caller_row = subst.subst_apply(subst: s_all, typ: tctypes.state_throw_row(state: st2))
                  let groups = tctypes.state_exception_groups(state: st2)
                  match check_call_throw_row_admitted(callee_row, caller_row, groups, func) do
                    | RaiseOk -> return InferExprOk(state: st2, subst: s_all, typ: rt)
                    | RaiseRejected(message: m) -> return InferExprErr(message: m, span)
                  end
              end
            | _ ->
              return InferExprErr(message: func ++ " is not a function", span)
          end
      end
  end
end

/** Decide whether calling a function whose declared throws-row is `callee_row`
 *  is admitted by the caller's active `caller_row`. Row-subsumption: every
 *  concrete exception listed in the callee row must appear in the caller row
 *  (literally, as a member of an exception group, or via the universal `Exn`).
 *
 *  Admit rules (parallel to check_raise_admitted):
 *  - Callee row = closed empty `TyRow([], None)`: callee declared no
 *  throws; treated as "unspecified" and admitted (functions that omit the
 *  throws clause parse to this shape).
 *  - Callee row open (rest = Some(_)): effect-polymorphic; admit.
 *  - Caller row open (rest = Some(_)): admits anything.
 *  - Caller row = closed empty `TyRow([], None)`: caller declared no
 *  throws; admit (narrow enforcement activates only when caller declares
 *  an explicit row).
 *  - Either side reduced to a TyVar / non-row shape: admit conservatively.
 */
let check_call_throw_row_admitted = fn (
  callee_row: TypeExpr, caller_row: TypeExpr,
  groups: [ExceptionGroupEntry], func: string
) -> RaiseAdmissionResult throws { TypeError } do
  match callee_row do
    // Callee has no throws (or is effect-polymorphic): always admitted.
    | TyRow(types: [], rest: None) | TyRow(types: _, rest: Some(_)) -> return RaiseOk
    | TyRow(types: callee_types, rest: None) ->
      match caller_row do
        // Open caller row (includes implicit absent-throws rows parsed as
        // TyRow([], Some(TyVar("__implicit")))): admits any callee.
        | TyRow(types: _, rest: Some(_)) -> return RaiseOk
        // Caller declared an explicit closed row (including `throws {}`):
        // enforce that every callee exception is covered.
        | TyRow(types: caller_types, rest: None) ->
          return check_each_callee_member_admitted(callee_types, caller_types, groups, func)
        | _ -> return RaiseOk
      end
    | _ -> return RaiseOk
  end
end

/** Verify each TyUserDefined entry in `callee_types` is admitted by
 *  `caller_types`. Non-TyUserDefined entries (e.g. TyVar arising from
 *  freshly instantiated polymorphic effect parameters) skip — those are
 *  resolved by surrounding unification, not by this row-subsumption check.
 */
let check_each_callee_member_admitted = fn (
  callee_types: [TypeExpr], caller_types: [TypeExpr],
  groups: [ExceptionGroupEntry], func: string
) -> RaiseAdmissionResult throws { TypeError } do
  match callee_types do
    | [] -> return RaiseOk
    | t :: rest ->
      match t do
        | TyUserDefined(name: n, args: _) ->
          if row_admits_exception(name: n, row_types: caller_types, groups) then
            return check_each_callee_member_admitted(callee_types: rest, caller_types, groups, func)
          else
            return RaiseRejected(
              message: "call " ++ func ++ ": exception " ++ n ++ " raised by callee not admitted by caller's throws row"
            )
          end
        | _ -> return check_each_callee_member_admitted(callee_types: rest, caller_types, groups, func)
      end
  end
end

let check_call_args = fn (
  state: CheckState, params: [NamedType], args: [HirCallArg],
  ret: TypeExpr, subst: [SubstEntry], span: Span
) -> InferExprResult throws { TypeError } do
  // validate that every call-arg label matches a parameter
  // name (and vice versa) BEFORE the positional walk. The MIR→LIR
  // lowering sorts both call args and params alphabetically by label (see
  // sort_lir_call_args / sort_lir_params in src/ir/lir/lir.nx). A pun like
  // `f(x, y)` against `fn (a, b)` would otherwise pass through positional-
  // walk, then the sort would place x/y into a/b slots in wrong alphabetic
  // order — a silent wrong-slot runtime miscompile. Reordering by label IS
  // allowed: declared `fn (a, b)` accepts `f(b: 10, a: 52)` because the
  // sort brings both sides into alignment.
  match validate_arg_labels(args, params) do
    | ArgLabelErr(message: m) -> return InferExprErr(message: m, span)
    | ArgLabelOk ->
      let ordered = reorder_args_by_params(args, params)
      // T-App B-set premise (spec §T-App): if any arg is Borrow(&x) and
      // another arg is a consuming use of x (Variable(x), non-Borrow), then
      // x is NOT in B — it must go through the ⊗-split path, and the &x
      // falls through to T-Borrow → x:^ω check → reject. Pre-scan the
      // ordered args before the walk to detect this violation early.
      match check_bset_no_consume_borrow_conflict(args: ordered) do
        | ArgLabelErr(message: m) -> return InferExprErr(message: m, span)
        | ArgLabelOk -> return check_call_args_walk(state, params, args: ordered, ret, subst, span)
      end
  end
end

let check_call_args_walk = fn (
  state: CheckState, params: [NamedType], args: [HirCallArg],
  ret: TypeExpr, subst: [SubstEntry], span: Span
) -> InferExprResult throws { TypeError } do
  match params do
    | [] ->
      match args do
        | [] -> return InferExprOk(state, subst, typ: subst.subst_apply(subst, typ: ret))
        | _ -> return InferExprErr(message: "too many arguments", span)
      end
    | NamedType(name: pname, typ: ptyp) :: rp ->
      match args do
        | [] -> return InferExprErr(message: "missing argument: " ++ pname, span)
        | HirCallArg(label: _, value: val) :: ra ->
          // T-App-BorrowLin (spec §T-App): when the argument is syntactically
          // `&x`, bypass T-Borrow's x:^ω check and use the arg-position form
          // that permits linear/lazy targets. The borrow is discharged on call
          // return; the linear binding `x` survives the call unconsumed.
          let HirExpr(node: val_node, span: val_sp) = val
          // T-App-BorrowLin gate: only invoke `infer_borrow_arg_position`
          // (which skips T-Borrow's x:^ω check) when the *expected* param
          // type is syntactically `&σ`.  For a non-borrow param `P ≠ &σ`,
          // a `&x` argument must route through `infer_expr` → ordinary
          // T-Borrow, which enforces x:^ω and therefore rejects linear `x`.
          // Without this guard, `&_` silently passed to e.g. `i64` params:
          // infer_borrow_arg_position produced TyBorrow(i64), U-Borrow
          // auto-derefed it to i64 during unification, and LinearUnused
          // was silently skipped for `_`-named bindings (linearity.nx L750).
          let p_resolved = subst.subst_apply(subst, typ: ptyp)
          let arg_result = match val_node do
            | Borrow(name: borrow_target, sigil: _) ->
              match p_resolved do
                | TyBorrow(_) ->
                  infer_borrow_arg_position(state, name: borrow_target, span: val_sp)
                | _ ->
                  infer_expr(state, expr: val, ret_type: TyUnit)
              end
            | _ ->
              infer_expr(state, expr: val, ret_type: TyUnit)
          end
          match arg_result do
            | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m, span: espan)
            | InferExprOk(state: st1, subst: s1, typ: arg_t) ->
              let s_merged = subst.subst_compose(s1: subst, s2: s1)
              let expected = subst.subst_apply(subst: s_merged, typ: ptyp)
              let tdefs = tctypes.state_typedefs(state: st1)
              match unify.unify(t1: arg_t, t2: expected, tdefs) do
                | UnifyOk(subst: s2) ->
                  let s_all = subst.subst_compose(s1: s_merged, s2)
                  return check_call_args_walk(state: st1, params: rp, args: ra, ret, subst: s_all, span)
                | UnifyErr(message: m) ->
                  // Linearity-weakening at call sites: permit passing a plain
                  // value `T` where the parameter is `%T` or `@T` by re-unifying
                  // against the inner type. The wrapper is reintroduced
                  // lexically by the param sigil; the value's modality is
                  // preserved by the linear-capture / lazy-capture machinery
                  // downstream.
                  //
                  // a borrow `&x` is syntactically non-linear
                  // (linear(&σ) = false per spec §Linearity), so the weakening
                  // would naively strip %T → T and admit &x against %T —
                  // letting the callee consume the underlying owner of x
                  // while the caller still believes it's live ('borrow-to-
                  // ownership smuggling'). T-App-BorrowLin already covers the
                  // legitimate &x → &σ case; the only remaining shape for an
                  // &x argument is %σ (or @σ), which we reject here.
                  match expected do
                    | TyLinear(inner: pinner) ->
                      match arg_t do
                        | TyBorrow(_) ->
                          return InferExprErr(
                            message: "arg " ++ pname ++ ": cannot pass borrow '&x' where parameter expects linear '%T'; borrows cannot satisfy ownership-consuming parameters (spec §U-Borrow / §T-App weakening;)",
                            span
                          )
                        | _ -> ()
                      end
                      match unify.unify(t1: arg_t, t2: pinner, tdefs) do
                        | UnifyOk(subst: s2) ->
                          let s_all = subst.subst_compose(s1: s_merged, s2)
                          return check_call_args_walk(state: st1, params: rp, args: ra, ret, subst: s_all, span)
                        | UnifyErr(message: _) -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m, span)
                      end
                    | TyLazy(inner: pinner) ->
                      match arg_t do
                        | TyBorrow(_) ->
                          return InferExprErr(
                            message: "arg " ++ pname ++ ": cannot pass borrow '&x' where parameter expects lazy '@T'; borrows cannot satisfy one-shot lazy parameters (spec §U-Borrow;)",
                            span
                          )
                        | _ -> ()
                      end
                      match unify.unify(t1: arg_t, t2: pinner, tdefs) do
                        | UnifyOk(subst: s2) ->
                          let s_all = subst.subst_compose(s1: s_merged, s2)
                          return check_call_args_walk(state: st1, params: rp, args: ra, ret, subst: s_all, span)
                        | UnifyErr(message: _) -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m, span)
                      end
                    | _ ->
                      // Auto-force at call sites: top-level `let
                      // x = e` is registered with type `TyArrow(params: [],
                      // ret: T)` — a nullary-thunk shape — but MIR lowers a
                      // bare `Variable(x)` reference to a plain value read
                      // (no auto-call inserted; see ctx_value_binding_names
                      // in src/ir/mir/mir.nx). Existing call paths (`x()`, `x + 1`
                      // via `infer_call`'s callee-peel) already see through
                      // this thunk shape. The missing symmetric site is the
                      // labeled-call-arg position: passing such an `x` to a
                      // parameter expecting bare `T` would otherwise fail with
                      // a misleading "[E2001] expected arrow type" diagnostic.
                      // Peel `TyArrow(params: [], ret: T)` (and `TyLazy(T)`
                      // for handler-arm-style lazy bindings), re-unify against
                      // the param type. Mirrors the param-side
                      // `TyLinear`/`TyLazy` weakening above, in the opposite
                      // direction.
                      match arg_t do
                        | TyLazy(inner: ainner) ->
                          match unify.unify(t1: ainner, t2: expected, tdefs) do
                            | UnifyOk(subst: s2) ->
                              let s_all = subst.subst_compose(s1: s_merged, s2)
                              return check_call_args_walk(state: st1, params: rp, args: ra, ret, subst: s_all, span)
                            | UnifyErr(message: _) -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m, span)
                          end
                        | TyLinear(inner: TyLazy(inner: ainner)) ->
                          match unify.unify(t1: ainner, t2: expected, tdefs) do
                            | UnifyOk(subst: s2) ->
                              let s_all = subst.subst_compose(s1: s_merged, s2)
                              return check_call_args_walk(state: st1, params: rp, args: ra, ret, subst: s_all, span)
                            | UnifyErr(message: _) -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m, span)
                          end
                        | TyLinear(inner: ainner) ->
                          // T-Let wrapSigil: `let %b = Ctor(...)` gives `b` type
                          // `TyLinear(T)` in the env. At call sites, param sigils are NOT
                          // reflected in the Arrow type (build_param_named_types ignores sigil),
                          // so a `%param: T` param appears with bare type `T`. When arg_t is
                          // `TyLinear(T)` but expected is the bare `T`, strip the Linear wrapper
                          // and re-unify. Linearity enforcement is handled by linearity.nx (which
                          // tracks sigil, not the wrapper), not by the Arrow param type.
                          match unify.unify(t1: ainner, t2: expected, tdefs) do
                            | UnifyOk(subst: s2) ->
                              let s_all = subst.subst_compose(s1: s_merged, s2)
                              return check_call_args_walk(state: st1, params: rp, args: ra, ret, subst: s_all, span)
                            | UnifyErr(message: _) -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m, span)
                          end
                        | TyArrow(params: [], ret: aret, requires: _, throw_row: _) ->
                          match unify.unify(t1: aret, t2: expected, tdefs) do
                            | UnifyOk(subst: s2) ->
                              let s_all = subst.subst_compose(s1: s_merged, s2)
                              return check_call_args_walk(state: st1, params: rp, args: ra, ret, subst: s_all, span)
                            | UnifyErr(message: _) -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m, span)
                          end
                        | _ -> return InferExprErr(message: "arg " ++ pname ++ ": " ++ m, span)
                      end
                  end
              end
          end
      end
  end
end

// ─── Constructor inference ──────────────────────────────────────────────────

let infer_constructor = fn (state: CheckState, variant: string, args: [HirExpr], labels: [string], sigil: Sigil, span: Span) -> InferExprResult throws { TypeError } do
  // The `sigil` parameter records whether the user wrote `%Ctor(...)` at the
  // source — propagated through AST → HIR for downstream consumers (let-binders
  // already see it via the StmtLet sigil bump in parse_let_without_type; the
  // linearity pass keys off the let's sigil, not the value's inferred type).
  //
  // We deliberately do NOT wrap the inferred type in `TyLinear` here. Doing
  // so would break call sites where `f(%Ctor(...))` already works via the
  // "fresh ctor passes %T param" leniency: wrapping makes the arg type
  // `TyLinear<T>` and the param expects bare `T`, so unification fails.
  // The sigil's role here is bookkeeping, not type-shape mutation.
  let _ = sigil
  match tctypes.find_variant(idx: tctypes.state_variant_index(state), variant) do
    | None -> return InferExprErr(message: "unknown constructor: " ++ variant, span)
    | Some(val: EnumVariantInfo(enum_name: ename, type_params: tps, fields)) ->
      let fr = freshen_type_params(state, params: tps)
      let FreshenResult(state: st1, param_subst: psubst) = fr
      let sorted_fields = sort_variant_fields(fields)
      let enum_type = build_enum_type(name: ename, params: tps, param_subst: psubst)
      return check_ctor_args(state: st1, fields: sorted_fields, args, labels, param_subst: psubst, enum_type, subst: subst.subst_empty(), span)
  end
end

let check_ctor_args = fn (
  state: CheckState, fields: [VariantField], args: [HirExpr], labels: [string],
  param_subst: [SubstEntry], enum_type: TypeExpr, subst: [SubstEntry], span: Span
) -> InferExprResult throws { TypeError } do
  match fields do
    | [] ->
      match args do
        | [] -> return InferExprOk(state, subst, typ: subst.subst_apply(subst, typ: enum_type))
        | _ -> return InferExprErr(message: "too many constructor arguments", span)
      end
    | VariantField(name: vfname_opt, typ: ftyp) :: rf ->
      match args do
        | [] -> return InferExprErr(message: "missing constructor argument", span)
        | arg :: ra ->
          // Spec T-Ctor {ℓ} = {ℓ'}: when both the constructor field and the
          // user-supplied argument carry a label, they must match at each
          // position — reordered or misspelled labels (e.g. Box(content: 99)
          // for Box(value: i64)) are rejected here.
          match check_ctor_field_label(labels, vfname_opt) do
            | Some(val: err) -> return InferExprErr(message: err, span)
            | None -> ()
          end
          let labels_tail = match labels do | [] -> [] | _ :: tl -> tl end
          match infer_expr(state, expr: arg, ret_type: TyUnit) do
            | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
            | InferExprOk(state: st1, subst: s1, typ: at) ->
              let sm = subst.subst_compose(s1: subst, s2: s1)
              let expected = subst.subst_apply(subst: subst.subst_compose(s1: param_subst, s2: sm), typ: ftyp)
              let tdefs = tctypes.state_typedefs(state: st1)
              match unify.unify(t1: at, t2: expected, tdefs) do
                | UnifyErr(message: m) -> return InferExprErr(message: "ctor field: " ++ m, span)
                | UnifyOk(subst: s2) ->
                  return check_ctor_args(
                    state: st1, fields: rf, args: ra, labels: labels_tail,
                    param_subst, enum_type,
                    subst: subst.subst_compose(s1: sm, s2), span
                  )
              end
          end
      end
  end
end

// Spec T-Ctor {ℓ} = {ℓ'}: check that the head user-supplied label (if any)
// matches the constructor's declared label at the same position. Both lists
// are in alphabetical order (sort_ctor_args / sort_variant_fields). Returns
// Some(error) on mismatch, None if OK.
let check_ctor_field_label = fn (
  user_labels: [string], vfname_opt: Option<string>
) -> Option<string> do
  match user_labels do
    | [] -> return None
    | fname :: _ ->
      match vfname_opt do
        | None -> return None
        | Some(val: vfname) ->
          // Use ctor_label_in_singleton for the comparison to reuse
          // proven string-equality logic rather than a raw `==` on
          // newly-bound strings (stage-0 codegen bug with match-arm strings).
          if ctor_label_in_singleton(label: fname, expected: vfname) then
            return None
          else
            return Some(val: "constructor argument label `" ++ fname
              ++ "` does not match the declared field label `" ++ vfname
              ++ "` at this position; T-Ctor requires {ℓ} = {ℓ'}")
          end
      end
  end
end

// Checks whether `label` equals `expected` using a list-search pattern to
// avoid the stage-0 raw-string-== codegen issue on newly-bound match-arm
// string variables.
let ctor_label_in_singleton = fn (label: string, expected: string) -> bool do
  return ctor_label_in_singleton_go(label, haystack: expected :: [])
end

let ctor_label_in_singleton_go = fn (label: string, haystack: [string]) -> bool do
  match haystack do
    | [] -> return false
    | h :: rest ->
      if h == label then return true
      else return ctor_label_in_singleton_go(label, haystack: rest)
      end
  end
end

// ─── Record inference ───────────────────────────────────────────────────────

let infer_record = fn (state: CheckState, fields: [HirNamedExpr], span: Span) -> InferExprResult throws { TypeError } do
  return infer_record_fields(state, fields, subst: subst.subst_empty(), acc: [], span)
end

let infer_record_fields = fn (state: CheckState, fields: [HirNamedExpr], subst: [SubstEntry], acc: [NamedType], span: Span) -> InferExprResult throws { TypeError } do
  match fields do
    | [] ->
      return InferExprOk(state, subst, typ: TyRecord(fields: list.reverse(xs: acc)))
    | HirNamedExpr(name: n, value: v) :: rest ->
      // Spec T-Record premise distinct(ℓ̄): reject duplicate field labels.
      match lookup_named_type(nts: acc, name: n) do
        | Some(val: _) -> throw DuplicateRecordLabel(label: n, span)
        | None -> ()
      end
      match infer_expr(state, expr: v, ret_type: TyUnit) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "record field " ++ n ++ ": " ++ m, span: espan)
        | InferExprOk(state: st1, subst: s1, typ: ft) ->
          let sm = subst.subst_compose(s1: subst, s2: s1)
          return infer_record_fields(
            state: st1, fields: rest, subst: sm,
            acc: NamedType(name: n, typ: ft) :: acc, span
          )
      end
  end
end

// ─── Array inference ────────────────────────────────────────────────────────

let infer_array = fn (state: CheckState, elems: [HirExpr], span: Span) -> InferExprResult throws { TypeError } do
  match elems do
    | [] ->
      let FreshResult(state: st, typ: tv) = tctypes.tc_fresh_var(state)
      return InferExprOk(state: st, subst: subst.subst_empty(), typ: TyArray(elem: tv))
    | first :: rest ->
      match infer_expr(state, expr: first, ret_type: TyUnit) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
        | InferExprOk(state: st1, subst: s1, typ: t1) ->
          return unify_array_elems(state: st1, elems: rest, subst: s1, elem_type: t1, span)
      end
  end
end

let unify_array_elems = fn (state: CheckState, elems: [HirExpr], subst: [SubstEntry], elem_type: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  match elems do
    | [] -> return InferExprOk(state, subst, typ: TyArray(elem: subst.subst_apply(subst, typ: elem_type)))
    | e :: rest ->
      match infer_expr(state, expr: e, ret_type: TyUnit) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
        | InferExprOk(state: st1, subst: s1, typ: et) ->
          let sm = subst.subst_compose(s1: subst, s2: s1)
          let tdefs = tctypes.state_typedefs(state: st1)
          match unify.unify(t1: et, t2: subst.subst_apply(subst: sm, typ: elem_type), tdefs) do
            | UnifyErr(message: m) -> return InferExprErr(message: "array element: " ++ m, span)
            | UnifyOk(subst: s2) ->
              return unify_array_elems(state: st1, elems: rest, subst: subst.subst_compose(s1: sm, s2), elem_type, span)
          end
      end
  end
end

// ─── Index inference ────────────────────────────────────────────────────────

let infer_index = fn (state: CheckState, target: HirExpr, index: HirExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: target, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: tt) ->
      match infer_expr(state: st1, expr: index, ret_type: TyUnit) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
        | InferExprOk(state: st2, subst: s2, typ: it) ->
          let sm = subst.subst_compose(s1, s2)
          let tdefs = tctypes.state_typedefs(state: st2)
          match unify.unify(t1: it, t2: TyI64, tdefs) do
            | UnifyErr(message: m) -> return InferExprErr(message: "index must be i64: " ++ m, span)
            | UnifyOk(subst: s3) ->
              let sf = subst.subst_compose(s1: sm, s2: s3)
              let arr_t = subst.subst_apply(subst: sf, typ: tt)
              // Peel TyBorrow / TyLinear / TyLazy wrappers so `arr_borrow[idx]`
              // works whenever the underlying type is `[| T |]`. Same shape as
              // the read-side of the Index arm in infer_stmt's Assign handler
              //
              match arr_t do
                | TyArray(elem: e)
                | TyBorrow(inner: TyArray(elem: e))
                | TyLinear(inner: TyArray(elem: e))
                | TyLazy(inner: TyArray(elem: e)) -> return InferExprOk(state: st2, subst: sf, typ: e)
                | _ -> return InferExprErr(message: "cannot index non-array type", span)
              end
          end
      end
  end
end

// ─── Field access inference ─────────────────────────────────────────────────
//
// T-Proj premise `¬linear(τ)` (spec docs/spec/type-system-formal.md): a
// record whose any field carries a linear type is itself structurally
// linear. Projection on such a record would consume `r` via the sub-
// derivation while exposing only one field — silently dropping the
// other linear obligations. Reject at projection so the linear field
// must be decomposed via record-pattern destructuring (P-Record's `⨄`
// binds every linear field).

let infer_field_access = fn (state: CheckState, target: HirExpr, field: string, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: target, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: tt) ->
      let resolved = subst.subst_apply(subst: s1, typ: tt)
      // T-Proj: expand typedef aliases to their underlying record fields.
      // When the resolved type is TyUserDefined(name, args), look up the
      // typedef, substitute type params, and project the requested field.
      let fs = match resolved do
        | TyRecord(fields: fs) -> Some(val: fs)
        | TyUserDefined(name: n, args: targs) ->
          match tctypes.typedef_lookup(defs: tctypes.state_typedefs(state: st1), name: n) do
            | Some(val: RecordDef(name: _, is_public: _, type_params: tps, fields: rec_fields)) ->
              let param_subst = unify.build_param_subst(params: tps, args: targs)
              Some(val: subst.apply_named_types(subst: param_subst, nts: rec_fields))
            | None -> None
          end
        | _ -> None
      end
      match fs do
        | None -> return InferExprErr(message: "field access on non-record type", span)
        | Some(val: rec_fields) ->
          match lookup_named_type(nts: rec_fields, name: field) do
            | Some(val: ft) ->
              match find_linear_field(fields: rec_fields, tdefs: tctypes.state_typedefs(state: st1), depth: 8) do
                | Some(val: leaker) ->
                  return InferExprErr(
                    message: "T-Proj: cannot project field `" ++ field ++ "` on structurally-linear record (linear field `" ++ leaker ++ "` would be silently dropped); destructure via record pattern instead",
                    span
                  )
                | None -> return InferExprOk(state: st1, subst: s1, typ: ft)
              end
            | None -> return InferExprErr(message: "no field " ++ field ++ " in record", span)
          end
      end
  end
end

// ─── If inference ───────────────────────────────────────────────────────────
// `if c then T else E end` types as the unified tail-expression type of T
// and E (mirrors `infer_match_cases`), so `let d = if v == K then 1 else 0
// end` correctly binds `d : i64` rather than `unit`. An `if` without `else`
// types as TyUnit (the missing-arm path has no value to unify against), and
// non-tail / empty branches fall back to TyUnit through `infer_stmts`.

let infer_if = fn (state: CheckState, cond: HirExpr, then_b: [HirStmt], else_b: Option<[HirStmt]>, ret_type: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: cond, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: ct) ->
      let tdefs = tctypes.state_typedefs(state: st1)
      match unify.unify(t1: ct, t2: TyBool, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(message: "if condition must be bool: " ++ m, span)
        | UnifyOk(subst: s2) ->
          let sm = subst.subst_compose(s1, s2)
          let env1 = subst.subst_apply_env(subst: sm, env: tctypes.state_env(state: st1))
          let st2 = tctypes.state_with_env(state: st1, env: env1)
          match infer_stmts(state: st2, stmts: then_b, ret_type) do
            | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "if then: " ++ m, span: espan)
            | InferExprOk(state: st3, subst: s3, typ: then_t) ->
              let sm2 = subst.subst_compose(s1: sm, s2: s3)
              // T-If: close the then-block scope — bindings introduced
              // inside the then branch must not leak into the else branch or outer scope.
              // Mirrors the env pop in infer_match_cases / infer_try.
              let st3_closed = tctypes.state_with_env(state: st3, env: tctypes.state_env(state: st2))
              match else_b do
                | None ->
                  let st_out = tctypes.state_with_env(state: st3, env: tctypes.state_env(state))
                  return InferExprOk(state: st_out, subst: sm2, typ: TyUnit)
                | Some(val: else_stmts) ->
                  match infer_stmts(state: st3_closed, stmts: else_stmts, ret_type) do
                    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "if else: " ++ m, span: espan)
                    | InferExprOk(state: st4, subst: s4, typ: else_t) ->
                      let sm3 = subst.subst_compose(s1: sm2, s2: s4)
                      let tdefs2 = tctypes.state_typedefs(state: st4)
                      let then_applied = subst.subst_apply(subst: sm3, typ: then_t)
                      let else_applied = subst.subst_apply(subst: sm3, typ: else_t)
                      match unify.unify(t1: then_applied, t2: else_applied, tdefs: tdefs2) do
                        | UnifyErr(message: m) ->
                          return InferExprErr(message: "if branches: type mismatch — then `" ++ tctypes.type_to_string(typ: then_applied) ++ "`, else `" ++ tctypes.type_to_string(typ: else_applied) ++ "`: " ++ m, span)
                        | UnifyOk(subst: s5) ->
                          let final_subst = subst.subst_compose(s1: sm3, s2: s5)
                          let result = subst.subst_apply(subst: final_subst, typ: else_applied)
                          // T-If: close the else-block scope before returning to outer env.
                          let st_out = tctypes.state_with_env(state: st4, env: tctypes.state_env(state))
                          return InferExprOk(state: st_out, subst: final_subst, typ: result)
                      end
                  end
              end
          end
      end
  end
end

// ─── Match inference ────────────────────────────────────────────────────────

let infer_match = fn (state: CheckState, target: HirExpr, cases: [HirMatchCase], ret_type: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: target, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: tt) ->
      let scrutinee = subst.subst_apply(subst: s1, typ: tt)
      match exhaustive.check_match_exhaustive(cases, scrutinee_type: scrutinee, enum_defs: tctypes.state_enums(state: st1), type_defs: tctypes.state_typedefs(state: st1)) do
        | exhaustive.Exhaustive ->
          return infer_match_cases(state: st1, cases, target_type: tt, subst: s1, ret_type, result_type: None, span)
        | exhaustive.NonExhaustive(witness: w) ->
          return InferExprErr(message: "non-exhaustive match on `" ++ tctypes.type_to_string(typ: scrutinee) ++ "`: missing pattern for `" ++ w ++ "`", span)
        | exhaustive.RedundantArm(witness: w) ->
          return InferExprErr(message: "redundant match on `" ++ tctypes.type_to_string(typ: scrutinee) ++ "`: " ++ w, span)
        | exhaustive.ExnNoCatchAll ->
          // Suppress hasCatchAll inside a try/catch catch body: selective
          // catch is valid — unmatched exceptions propagate via WASM EH.
          if tctypes.state_in_catch_body(state: st1) then
            return infer_match_cases(state: st1, cases, target_type: tt, subst: s1, ret_type, result_type: None, span)
          end
          return InferExprErr(message: "match on `Exn` must include a catch-all arm (`_ -> ...` or a variable pattern) to cover future exception constructors", span)
      end
  end
end

let infer_match_cases = fn (
  state: CheckState, cases: [HirMatchCase],
  target_type: TypeExpr, subst: [SubstEntry], ret_type: TypeExpr,
  result_type: Option<TypeExpr>, span: Span
) -> InferExprResult throws { TypeError } do
  match cases do
    | [] ->
      let final_type = match result_type do
        | Some(val: t) -> t
        | None -> TyUnit
      end
      return InferExprOk(state, subst, typ: final_type)
    | HirMatchCase(pattern: pat, body) :: rest ->
      let tt = subst.subst_apply(subst, typ: target_type)
      match bind_pattern(state, pattern: pat, target_type: tt) do
        | BindErr(message: m) -> return InferExprErr(message: "match pattern: " ++ m, span)
        | BindOk(state: st1, subst: ps, env: bindings) ->
          let sm = subst.subst_compose(s1: subst, s2: ps)
          let case_env = append_env(base: tctypes.state_env(state: st1), extra: bindings)
          let st2 = tctypes.state_with_env(state: st1, env: subst.subst_apply_env(subst: sm, env: case_env))
          match infer_stmts(state: st2, stmts: body, ret_type) do
            | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "match case: " ++ m, span: espan)
            | InferExprOk(state: st3, subst: bs, typ: case_type) ->
              let all_subst = subst.subst_compose(s1: sm, s2: bs)
              let new_result = match result_type do
                | None -> case_type
                | Some(val: prev) ->
                  let tdefs = tctypes.state_typedefs(state: st3)
                  let applied_prev = subst.subst_apply(subst: all_subst, typ: prev)
                  match unify.unify(t1: applied_prev, t2: case_type, tdefs) do
                    | UnifyOk(_) -> case_type
                    | UnifyErr(_) ->
                      return InferExprErr(message: "Match case type mismatch: expected `" ++ tctypes.type_to_string(typ: applied_prev) ++ "`, found `" ++ tctypes.type_to_string(typ: case_type) ++ "`", span)
                  end
              end
              // Pop case-local pattern bindings before threading to the next case.
              let st4 = tctypes.state_with_env(state: st3, env: tctypes.state_env(state))
              return infer_match_cases(
                state: st4, cases: rest,
                target_type, subst: all_subst,
                ret_type, result_type: Some(val: new_result), span
              )
          end
      end
  end
end

// ─── While inference ────────────────────────────────────────────────────────

let infer_while = fn (state: CheckState, cond: HirExpr, body: [HirStmt], ret_type: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: cond, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: ct) ->
      let tdefs = tctypes.state_typedefs(state: st1)
      match unify.unify(t1: ct, t2: TyBool, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(message: "while cond must be bool: " ++ m, span)
        | UnifyOk(subst: s2) ->
          let sm = subst.subst_compose(s1, s2)
          let st2 = tctypes.state_with_env(state: st1, env: subst.subst_apply_env(subst: sm, env: tctypes.state_env(state: st1)))
          match infer_stmts(state: st2, stmts: body, ret_type) do
            | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "while body: " ++ m, span: espan)
            | InferExprOk(state: st3, subst: s3, typ: _) ->
              // T-While: close the body scope — bindings introduced
              // inside the loop body must not leak into the outer scope.
              // Mirrors the env pop in infer_match_cases / infer_try.
              let st_out = tctypes.state_with_env(state: st3, env: tctypes.state_env(state))
              return InferExprOk(state: st_out, subst: subst.subst_compose(s1: sm, s2: s3), typ: TyUnit)
          end
      end
  end
end

// ─── For inference ──────────────────────────────────────────────────────────

let infer_for = fn (state: CheckState, var: string, start: HirExpr, end_e: HirExpr, body: [HirStmt], ret_type: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: start, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: st_t) ->
      let tdefs = tctypes.state_typedefs(state: st1)
      match unify.unify(t1: st_t, t2: TyI64, tdefs) do
        | UnifyErr(message: m) -> return InferExprErr(message: "for start must be i64: " ++ m, span)
        | UnifyOk(subst: s2) ->
          let sm = subst.subst_compose(s1, s2)
          match infer_expr(state: st1, expr: end_e, ret_type: TyUnit) do
            | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
            | InferExprOk(state: st2, subst: s3, typ: et_t) ->
              let sm2 = subst.subst_compose(s1: sm, s2: s3)
              match unify.unify(t1: et_t, t2: TyI64, tdefs) do
                | UnifyErr(message: m) -> return InferExprErr(message: "for end must be i64: " ++ m, span)
                | UnifyOk(subst: s4) ->
                  let sm3 = subst.subst_compose(s1: sm2, s2: s4)
                  let body_env = tctypes.env_insert(env: subst.subst_apply_env(subst: sm3, env: tctypes.state_env(state: st2)), name: var, scheme: tctypes.mono(typ: TyI64))
                  let st3 = tctypes.state_with_env(state: st2, env: body_env)
                  match infer_stmts(state: st3, stmts: body, ret_type) do
                    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "for body: " ++ m, span: espan)
                    | InferExprOk(state: st4, subst: s5, typ: _) ->
                      // T-For: close the body scope — the loop variable
                      // and any bindings introduced inside the for body must not leak
                      // into the outer scope.  Mirrors T-While and T-If.
                      let st_out = tctypes.state_with_env(state: st4, env: tctypes.state_env(state))
                      return InferExprOk(state: st_out, subst: subst.subst_compose(s1: sm3, s2: s5), typ: TyUnit)
                  end
              end
          end
      end
  end
end

// ─── Lambda inference ───────────────────────────────────────────────────────

let infer_lambda = fn (state: CheckState, type_params: [string], params: [HirParam], ret_type: TypeExpr, body: [HirStmt], span: Span) -> InferExprResult throws { TypeError } do
  // spec narrative §T-Let-PolyFn restricts polymorphic
  // schemes to top-level `fn`. An inner `let f = fn <T>(...)` would
  // otherwise silently drop the quantifier list, leaving T as a rigid
  // TyUserDefined that fails to unify at the first call site (user would
  // see "cannot unify int literal with non-integer type"). Reject
  // explicitly so the diagnostic points at the real problem.
  // Top-level functions never route through infer_lambda — they are
  // registered with `Scheme(vars: tps, ...)` by `register_functions`
  // (src/typecheck/check.nx) and checked via `check_function`, so this
  // restriction only fires for inner lambdas.
  match type_params do
    | [] -> ()
    | _ ->
      return InferExprErr(
        message: "inner lambda `fn <...>(...)` carries type parameters: polymorphic schemes are only allowed on top-level `let f = fn <T>(...)` declarations (spec type-system-formal.md §T-Let-PolyFn). Hoist this lambda to a top-level binding to make it polymorphic, or drop the `<...>` quantifier list.",
        span
      )
  end
  // T-Lambda gravity rule: ¬escapesRef(τ_r) — the declared return type must
  // not expose a mutable reference cell. Inner lambdas (fn at expression
  // position) with e.g. `-> ref(i64)` are rejected here.
  // Spec: type-system-formal.md §"Gravity Rule" table + §T-Lambda.
  tcwf.enforce_no_escapes_ref(typ: ret_type, context: "return type of lambda", span)
  let param_types = build_param_named_types(params)
  // T-Lambda wfRef at parameter annotation sites (spec §wfRef L385-400):
  // each parameter type ~σ is rejected if σ is linear (TyLinear).
  tcwf.enforce_wf_ref_params(params: param_types, span)
  let outer_env = tctypes.state_env(state)
  let body_env = add_params_to_env(env: outer_env, params)
  let st1 = tctypes.state_with_env(state, env: body_env)
  match infer_stmts(state: st1, stmts: body, ret_type) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "lambda body: " ++ m, span: espan)
    | InferExprOk(state: st2, subst: s1, typ: body_typ) ->
      // T-Lambda: τ_r ≠ unit ⟹ tail(s†) = ⊥.
      // The body must supply the return value by one of two means:
      //   (a) the last statement is a non-unit expression whose type provides
      //       the implicit return value (body_typ ≠ TyUnit), or
      //   (b) every control-flow path ends with an explicit `return`/`throw`
      //       (infer_stmts_tail_diverges = true).
      // If neither holds — i.e. the body "falls off the end" with unit but
      // the declared ret_type is non-unit — reject with E2001.
      let body_is_unit = if let TyUnit = body_typ then true else false end
      let ret_is_unit = if let TyUnit = ret_type then true else false end
      if !ret_is_unit && body_is_unit && !infer_stmts_tail_diverges(stmts: body, depth: 64) then
        return InferExprErr(message: "lambda return type is non-unit but body does not end with a `return` or `throw` on all paths (spec T-Lambda: τ_r ≠ unit ⟹ tail(s†) = ⊥)", span)
      end
      let scan = capture.scan_lambda_captures(body, outer_env, params)
      match scan do
        | capture.CaptureScan(linear: _, ref_hit: Some(val: capture.RefCaptureHit(name: rn, span: rsp))) ->
          return InferExprErr(message: "lambda captures mutable ref binding " ++ rn ++ " (refs are stack-confined)", span: rsp)
        | capture.CaptureScan(linear: lin, ref_hit: None) ->
          let arrow = TyArrow(
            params: param_types,
            ret: ret_type,
            requires: TyRow(types: [], rest: None),
            throw_row: TyRow(types: [], rest: None)
          )
          let wrapped = if lin then TyLinear(inner: arrow) else arrow end
          return InferExprOk(state: st2, subst: s1, typ: subst.subst_apply(subst: s1, typ: wrapped))
      end
  end
end

let build_param_named_types = fn (params: [HirParam]) -> [NamedType] throws { TypeError } do
  return build_param_named_types_go(params, acc: [])
end

let build_param_named_types_go = fn (params: [HirParam], acc: [NamedType]) -> [NamedType] throws { TypeError } do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: _, name: n, sigil: _, typ: t) :: rest ->
      return build_param_named_types_go(params: rest, acc: NamedType(name: n, typ: t) :: acc)
  end
end

let add_params_to_env = fn (env: [EnvEntry], params: [HirParam]) -> [EnvEntry] throws { TypeError } do
  match params do
    | [] -> return env
    | HirParam(label: _, name: n, sigil: _, typ: t) :: rest ->
      return add_params_to_env(env: tctypes.env_insert(env, name: n, scheme: tctypes.mono(typ: t)), params: rest)
  end
end

// ─── Handler-arm capture scan (T-Handler no-ref-capture) ────
//
// Spec T-Handler (type-system-formal.md) carries the same `∀y ∈ fv(e_j).
// Γ(y) ≠ ~σ` premise as T-Lambda. Inline `handler P do fn op(...) ...
// end end` expressions reach infer_expr with the construction-site env
// intact; later passes (synthesize_handler, check_handler_arm_bodies)
// hoist the arm to a top-level HirFunction and lose that env. Scan here
// where it is still available and reject the first ref-capture hit across
// all arms — mirroring infer_lambda's RefCaptureHit handling.

let scan_handler_arms_for_ref_capture = fn (arms: [HirHandlerArm], outer_env: [EnvEntry]) -> Option<capture.RefCaptureHit> do
  match arms do
    | [] -> return None
    | HirHandlerArm(arm: HirFunction(name: _, type_params: _, params: ps, ret_type: _, throw_row: _, body: bd, _), cont_binder: _) :: rest ->
      let body_stmts = match bd do | EagerBody(stmts: ss) -> ss | LazyBody(_) -> [] end
      let scan = capture.scan_lambda_captures(body: body_stmts, outer_env, params: ps)
      match scan do
        | capture.CaptureScan(linear: _, ref_hit: Some(val: hit)) -> return Some(val: hit)
        | capture.CaptureScan(linear: _, ref_hit: None) -> return scan_handler_arms_for_ref_capture(arms: rest, outer_env)
      end
  end
end

// ─── Raise inference ────────────────────────────────────────────────────────

let infer_raise = fn (state: CheckState, inner: HirExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: inner, ret_type: TyUnit) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: _) ->
      // T-Raise: the raised value's exception identity must be admitted by
      // the active throws-row ρ_q. Rows containing TyUserDefined("Exn", _)
      // accept any Exn variant.  Narrow rows like `throws { LirError }`
      // accept only declared members.
      let row = subst.subst_apply(subst: s1, typ: tctypes.state_throw_row(state: st1))
      let groups = tctypes.state_exception_groups(state: st1)
      let exn_name_opt = exception_name_of_raised(expr: inner)
      match check_raise_admitted(name_opt: exn_name_opt, row, groups) do
        | RaiseOk -> ()
        | RaiseRejected(message: m) -> return InferExprErr(message: m, span)
      end
      // Raise diverges; the result type is unconstrained (fresh tyvar so the
      // surrounding context can pick whatever it needs).
      let FreshResult(state: st2, typ: tv) = tctypes.tc_fresh_var(state: st1)
      return InferExprOk(state: st2, subst: s1, typ: tv)
  end
end

let infer_force = fn (state: CheckState, inner: HirExpr, ret_type: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: inner, ret_type) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t) ->
      match t do
        | TyLazy(inner: u) -> return InferExprOk(state: st1, subst: s1, typ: u)
        | _ ->
          // T-Force spec: unify(τ, @β) with fresh β, so that unresolved ?α
          // gets pinned to TyLazy(?β) rather than falling through to an error.
          let FreshResult(state: st2, typ: tv) = tctypes.tc_fresh_var(state: st1)
          let tdefs = tctypes.state_typedefs(state: st2)
          match unify.unify(t1: t, t2: TyLazy(inner: tv), tdefs) do
            | UnifyErr(_) -> return InferExprErr(
                message: "force: expected lazy type '@T', got non-lazy value",
                span)
            | UnifyOk(subst: s2) ->
              let sc = subst.subst_compose(s1, s2)
              return InferExprOk(state: st2, subst: sc, typ: subst.subst_apply(subst: sc, typ: tv))
          end
      end
  end
end

let infer_thunk = fn (state: CheckState, body: HirExpr, ret_type: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr: body, ret_type) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t) ->
      return InferExprOk(state: st1, subst: s1, typ: TyLazy(inner: t))
  end
end

// ─── Statement inference ────────────────────────────────────────────────────

/** Infer types for a statement sequence, threading state and accumulating subst; the result type is that of the final statement (or unit if empty). */
export let infer_stmts = fn (state: CheckState, stmts: [HirStmt], ret_type: TypeExpr) -> InferExprResult throws { TypeError } do
  match stmts do
    | [] -> return InferExprOk(state, subst: subst.subst_empty(), typ: TyUnit)
    | HirStmt(node: s, span: sp) :: rest ->
      match infer_stmt(state, stmt: s, ret_type, span: sp) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
        | InferExprOk(state: st1, subst: s1, typ: stmt_type) ->
          match rest do
            | [] ->
              return InferExprOk(state: st1, subst: s1, typ: stmt_type)
            | HirStmt(node: _, span: rest_sp) :: _ ->
              // T-Seq: if τ₁ = ⊥ (the statement diverges), all following
              // statements are unreachable — reject with E2021.
              if stmt_diverges(s) then
                throw UnreachableCode(span: rest_sp)
              end
              let env1 = subst.subst_apply_env(subst: s1, env: tctypes.state_env(state: st1))
              let st2 = tctypes.state_with_env(state: st1, env: env1)
              match infer_stmts(state: st2, stmts: rest, ret_type: subst.subst_apply(subst: s1, typ: ret_type)) do
                | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
                | InferExprOk(state: st3, subst: s2, typ: t) ->
                  return InferExprOk(state: st3, subst: subst.subst_compose(s1, s2), typ: t)
              end
          end
      end
  end
end

let infer_stmt = fn (state: CheckState, stmt: HirStmtKind, ret_type: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  match stmt do
    | Let(name, sigil, typ: ann, value) ->
      return infer_let(state, name, sigil, ann, value, ret_type, span)
    | Expr(expr) ->
      return infer_expr(state, expr, ret_type)
    | Return(expr) ->
      return infer_return(state, expr, ret_type, span)
    | Assign(target, value) ->
      let HirExpr(node: target_node, span: _) = target
      match target_node do
        | Variable(name: n, sigil: _) ->
          // T-Assign: the LHS must have type `~τ` (TyRef) per
          // the modality rule. We look up the env type directly rather than
          // routing through infer_expr — the lowering hardcodes the target's
          // sigil to SigilMutable, so the auto-deref in infer_variable would
          // strip the wrapper before the assign site can verify it.
          match tctypes.env_lookup(env: tctypes.state_env(state), name: n) do
            | None -> return InferExprErr(message: "assign: unbound variable '" ++ n ++ "'", span)
            | Some(val: sch) ->
              match instantiate_scheme(state, scheme: sch) do
                | InstantiateResult(state: st0, typ: target_type) ->
                  let inner_t = if let TyRef(inner: i) = target_type then i else
                    return InferExprErr(message: "assign '" ++ n ++ "': target is not a mutable ref (`~τ` required)", span)
                  end
                  match infer_expr(state: st0, expr: value, ret_type) do
                    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "assign: " ++ m, span: espan)
                    | InferExprOk(state: st1, subst: s1, typ: t_value) ->
                      let tdefs = tctypes.state_typedefs(state: st1)
                      match unify.unify(t1: t_value, t2: subst.subst_apply(subst: s1, typ: inner_t), tdefs) do
                        | UnifyErr(message: m) -> return InferExprErr(message: "assign '" ++ n ++ "': " ++ m, span)
                        | UnifyOk(subst: s2) -> return InferExprOk(state: st1, subst: subst.subst_compose(s1, s2), typ: TyUnit)
                      end
                  end
              end
          end
        | Index(target: arr, index: idx) ->
          // Indexed assignment `arr[idx] <- val`: the array LHS
          // must be `~τ`-able as an array (linear/owned or borrow), the index
          // must be i64, and the value must unify with the element type. We
          // route the array side through infer_expr so borrow auto-deref and
          // linear-array semantics flow uniformly with the read path.
          match infer_expr(state, expr: arr, ret_type) do
            | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "assign: " ++ m, span: espan)
            | InferExprOk(state: st0, subst: s0, typ: t_arr) ->
              match infer_expr(state: st0, expr: idx, ret_type) do
                | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "assign index: " ++ m, span: espan)
                | InferExprOk(state: st1, subst: s1, typ: t_idx) ->
                  let tdefs1 = tctypes.state_typedefs(state: st1)
                  match unify.unify(t1: t_idx, t2: TyI64, tdefs: tdefs1) do
                    | UnifyErr(message: m) -> return InferExprErr(message: "assign index: " ++ m, span)
                    | UnifyOk(subst: s2) ->
                      // Strip TyBorrow and any TyLinear/TyLazy wrappers when
                      // reading the element type out of the array.
                      let t_arr_a = subst.subst_apply(subst: s2, typ: t_arr)
                      let elem_t = match t_arr_a do
                        | TyArray(elem: e)
                        | TyBorrow(inner: TyArray(elem: e))
                        | TyLinear(inner: TyArray(elem: e))
                        | TyLazy(inner: TyArray(elem: e)) -> e
                        | _ -> return InferExprErr(message: "assign: target is not an array", span)
                      end
                      match infer_expr(state: st1, expr: value, ret_type) do
                        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "assign value: " ++ m, span: espan)
                        | InferExprOk(state: st2, subst: s3, typ: t_value) ->
                          let tdefs2 = tctypes.state_typedefs(state: st2)
                          match unify.unify(t1: t_value, t2: subst.subst_apply(subst: s3, typ: elem_t), tdefs: tdefs2) do
                            | UnifyErr(message: m) -> return InferExprErr(message: "assign element: " ++ m, span)
                            | UnifyOk(subst: s4) ->
                              let s01 = subst.subst_compose(s1: s0, s2: s1)
                              let s23 = subst.subst_compose(s1: s2, s2: s3)
                              let s0123 = subst.subst_compose(s1: s01, s2: s23)
                              let s_all = subst.subst_compose(s1: s0123, s2: s4)
                              return InferExprOk(state: st2, subst: s_all, typ: TyUnit)
                          end
                      end
                  end
              end
          end
        | _ -> return InferExprErr(message: "assign: target must be a variable or indexed access (parser invariant)", span)
      end
    | Try(body, catch_param: cp, catch_body: cb) ->
      return infer_try(state, body, catch_param: cp, catch_body: cb, ret_type, span)
    | Inject(handlers, body) ->
      // Step 1: verify all handler names are bound and not thunks.
      match check_handlers_bound(state, handlers, span) do
        | InferExprErr(message: m, span: esp) -> return InferExprErr(message: m, span: esp)
        | InferExprOk(_) ->
          // Step 2: T-Inject ∀i≠j. P_i ≠ P_j — injection uniqueness.
          // Each port may appear at most once in an inject site.
          check_inject_uniqueness(state, handlers, seen: [], span)
          // Step 3: T-Inject ∀i. ρ_i ⊆ ρ_q — handler require ⊆ ambient.
          // Each handler's declared require row must be a subset of the
          // enclosing function's ambient require row.
          let ambient_req = tctypes.state_require_row(state)
          check_inject_require_subset(state, handlers, ambient: ambient_req, span)
          // T-Inject: close the block scope — bindings introduced
          // inside the inject body must not leak past `end`. Mirrors the env
          // pop in infer_match_cases/infer_try.
          match infer_stmts(state, stmts: body, ret_type) do
            | InferExprErr(message: m, span: espan) -> return InferExprErr(message: m, span: espan)
            | InferExprOk(state: st1, subst: s1, typ: t) ->
              let st2 = tctypes.state_with_env(state: st1, env: tctypes.state_env(state))
              return InferExprOk(state: st2, subst: s1, typ: t)
          end
      end
  end
end

// ─── Let statement inference ────────────────────────────────────────────────

let infer_let = fn (state: CheckState, name: string, sigil: Sigil, ann: Option<TypeExpr>, value: HirExpr, ret_type: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  let HirExpr(node: val_node, span: _) = value
  // T-Borrow's ^ω precondition: only an unrestricted
  // (q = ω) binding may be borrowed. The carve-out for argument
  // position (`f(p: &x)`) lives in T-App: the borrow is discharged
  // when the callee returns, so a linear `x` survives. Let-rhs
  // position has no such discharge — a `let r = &b` would create a
  // long-lived `&T` binding whose target `b` is q = 1, violating the
  // spec. Reject at let-rhs before falling through to `infer_expr`,
  // which is permissive on the borrow form (so the arg-position path
  // through `check_call_args_walk` keeps working untouched).
  //
  // The check is intentionally only against the *syntactic* let-rhs
  // shape `Borrow(target)`. A deeper `let r = (if c then &b else ...)`
  // would also be problematic but is not in scope for this fix —
  // existing flow-sensitive linearity checks downstream already
  // catch the never-consumed half in such constructions.
  match val_node do
    | Borrow(name: target, sigil: _) ->
      match tctypes.env_lookup(env: tctypes.state_env(state), name: target) do
        | Some(val: Scheme(vars: _, typ: tgt_t)) ->
          match tgt_t do
            | TyLinear(_) ->
              return InferExprErr(
                message: "let " ++ name ++ ": cannot borrow '" ++ target ++ "' at let-rhs position: binding is linear (q = 1); T-Borrow requires the target to be ^ω. Borrowing a linear binding is only permitted in argument position (e.g. `f(p: &" ++ target ++ ")`), where T-App discharges the borrow on return. See spec type-system-formal.md §T-Borrow.",
                span
              )
            | TyLazy(_) ->
              return InferExprErr(
                message: "let " ++ name ++ ": cannot borrow '" ++ target ++ "' at let-rhs position: binding is lazy/one-shot (q = 1); T-Borrow requires the target to be ^ω. Borrowing a lazy binding is only permitted in argument position. See spec type-system-formal.md §T-Borrow.",
                span
              )
            | _ -> ()
          end
        | None -> ()
      end
    | _ -> ()
  end
  // Variable-aliasing carve-out for let-polymorphism.
  //   let f = id   // id : Scheme(["T"], T -> T)
  // Without this carve-out, infer_expr looks up `id`, instantiates it to
  // a fresh `?a -> ?a`, and infer_let binds `f` *monomorphically* to
  // that `?a -> ?a`. Subsequent uses `f(x: 10)` would constrain `?a`
  // to i64, and `f(x: true)` would then fail to unify bool with int.
  // By copying the source scheme directly when the RHS is a plain
  // (non-mutable, unannotated) variable reference to a polymorphic
  // binding, every call site of `f` re-instantiates exactly as if it
  // had referenced `id` directly. This is HM-style `generalize` at let,
  // restricted to the syntactic-value case where the RHS is itself a variable.
  // Lambdas and other RHS expressions remain monomorphic-bound to keep
  // linearity / value-restriction invariants intact.
  match alias_poly_scheme(state, name, sigil, ann, val_node, span) do
    | Some(val: result) -> return result
    | None -> ()
  end
  let st0 = if let Lambda(type_params: _, params, ret_type: ret, body: _) = val_node then
    let arrow = TyArrow(
      params: build_param_named_types(params),
      ret,
      requires: TyRow(types: [], rest: None),
      throw_row: TyRow(types: [], rest: None)
    )
    let env1 = tctypes.env_insert(env: tctypes.state_env(state), name, scheme: tctypes.mono(typ: arrow))
    tctypes.state_with_env(state, env: env1)
  else state end
  match infer_expr(state: st0, expr: value, ret_type) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "let " ++ name ++ ": " ++ m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t1) ->
      // T-Let-Lazy modality reading: `let @y : T = v` binds `y` at type `@T`
      // by auto-lazifying the annotation. The HIR pass has already wrapped
      // the rhs in a Thunk (so t1 is `TyLazy(_)`); without this rewrite the
      // bare `T` annotation would mismatch the lazified rhs. Mirrors the
      // call-site weakening rule in `check_call_args` that lets a plain `T`
      // value satisfy a `@T` parameter.
      let effective_ann = match ann do
        | Some(val: expected) ->
          if let SigilLazy = sigil then
            if let TyLazy(_) = expected then Some(val: expected) else Some(val: TyLazy(inner: expected)) end
          else Some(val: expected) end
        | None -> None
      end
      let inferred_type = match effective_ann do
        | Some(val: expected) ->
          let tdefs = tctypes.state_typedefs(state: st1)
          match unify.unify(t1, t2: expected, tdefs) do
            | UnifyErr(message: m) ->
              return InferExprErr(message: "let " ++ name ++ ": " ++ m, span)
            | UnifyOk(_) ->
              expected
          end
        | None -> default_numeric_literals(typ: t1)
      end
      // T-Let-Mutable: a `let ~x = v` binding stores its value
      // in a mutable cell. The env type is `~τ` (TyRef) so that T-Assign can
      // verify the LHS modality and use-site `~x` reads can auto-deref.
      //
      // T-Let premise `μ = ~ ⟹ ¬linear(τ')` :
      // mutable refs cannot hold linear values. "Linear" here is structural:
      // a bare `%T` / `@T` is rejected, but so is a `TyRecord` or
      // `TyUserDefined` record whose fields transitively carry linear
      // components — type_carries_linear walks records, named records, and
      // unwraps through TyRef/TyBorrow nesting (collections.nx). Spec
      // type-system-formal.md §Linearity: "Linearity is entirely structural,
      // so the check also rejects ~ cells holding records or ADTs with any
      // linear component."
      if let SigilMutable = sigil then
        let tdefs_for_lin = tctypes.state_typedefs(state: st1)
        let lin_kind = let_mut_linear_kind(typ: inferred_type, tdefs: tdefs_for_lin)
        match lin_kind do
          | LetMutLinearBare ->
            return InferExprErr(
              message: "let ~" ++ name ++ ": mutable-ref binding cannot hold linear value of type `" ++ tctypes.type_to_string(typ: inferred_type) ++ "` (T-Let premise: μ = ~ ⟹ ¬linear(τ'))",
              span
            )
          | LetMutLinearLazy ->
            return InferExprErr(
              message: "let ~" ++ name ++ ": mutable-ref binding cannot hold linear (one-shot) value of type `" ++ tctypes.type_to_string(typ: inferred_type) ++ "` (T-Let premise: μ = ~ ⟹ ¬linear(τ'))",
              span
            )
          | LetMutLinearStructural ->
            return InferExprErr(
              message: "let ~" ++ name ++ ": mutable-ref binding cannot hold value of type `" ++ tctypes.type_to_string(typ: inferred_type) ++ "` because it transitively carries a linear (%T / @T) component (T-Let premise: μ = ~ ⟹ ¬linear(τ');)",
              span
            )
          | LetMutOk -> ()
        end
      end
      // T-Let wrapSigil: when the binding sigil is `%` (linear)
      // or `@` (lazy), wrap the inferred type in the corresponding modality
      // constructor if it is not already wrapped. `infer_constructor` deliberately
      // omits this wrap (see its comment) to avoid breaking bare-ctor call sites;
      // the let-binder is the canonical place to apply the sigil to the env type.
      let final_type = match sigil do
        | SigilMutable -> wrap_ref(typ: inferred_type)
        | SigilLinear ->
          match inferred_type do
            | TyLinear(_) -> inferred_type
            | _ -> TyLinear(inner: inferred_type)
          end
        | SigilLazy ->
          match inferred_type do
            | TyLazy(_) -> inferred_type
            | _ -> TyLazy(inner: inferred_type)
          end
        | _ -> inferred_type
      end
      let env2 = tctypes.env_insert(
        env: subst.subst_apply_env(subst: s1, env: tctypes.state_env(state: st1)),
        name, scheme: tctypes.mono(typ: final_type)
      )
      return InferExprOk(state: tctypes.state_with_env(state: st1, env: env2), subst: s1, typ: TyUnit)
  end
end

// ─── Return statement inference ─────────────────────────────────────────────

let infer_return = fn (state: CheckState, expr: HirExpr, ret_type: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_expr(state, expr, ret_type) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "return: " ++ m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: t1) ->
      // T-Return gravity rule: ¬escapesRef(τ).
      // Check fires on the *inferred* type τ (not the declared τ_r) so it
      // catches cases where τ_r is a unification variable that happened to
      // resolve to a ref type. Spec: type-system-formal.md §T-Return.
      tcwf.enforce_no_escapes_ref(typ: t1, context: "return statement", span)
      let expected = subst.subst_apply(subst: s1, typ: ret_type)
      let tdefs = tctypes.state_typedefs(state: st1)
      let unify_result = match unify.unify(t1, t2: expected, tdefs) do
        | UnifyOk(subst: s2) -> UnifyOk(subst: s2)
        | UnifyErr(message: m) ->
          // Linearity weakening at the return site: allow
          // returning a plain `T` value where the declared return is `%T`
          // / `@T`. Mirrors `check_call_args` weakening at the call site —
          // the function arrow lexically tags the modality; the value's
          // own linearity is enforced by the linearity pass downstream.
          match expected do
            | TyLinear(inner: pinner) ->
              match unify.unify(t1, t2: pinner, tdefs) do
                | UnifyOk(subst: s2) -> UnifyOk(subst: s2)
                | UnifyErr(_) -> UnifyErr(message: m)
              end
            | TyLazy(inner: pinner) ->
              match unify.unify(t1, t2: pinner, tdefs) do
                | UnifyOk(subst: s2) -> UnifyOk(subst: s2)
                | UnifyErr(_) -> UnifyErr(message: m)
              end
            | _ -> UnifyErr(message: m)
          end
      end
      match unify_result do
        | UnifyErr(message: m) -> return InferExprErr(message: "return type mismatch: " ++ m, span)
        | UnifyOk(subst: s2) ->
          // T-Match diverging-arm carve-out (spec `tail = bottom` for return):
          // a `return e` statement diverges from the surrounding block, so the
          // block's tail type must not constrain the unifier. Mirror the
          // `infer_raise` treatment by exposing a fresh ?alpha — the
          // surrounding context (match arm sigma, if-branch unification)
          // picks whatever it needs. Already-validated `ret_type` ensures the
          // returned value still matches the declared function return type.
          let FreshResult(state: st2, typ: tv) = tctypes.tc_fresh_var(state: st1)
          return InferExprOk(state: st2, subst: subst.subst_compose(s1, s2), typ: tv)
      end
  end
end

// ─── Try inference ──────────────────────────────────────────────────────────

let infer_try = fn (state: CheckState, body: [HirStmt], catch_param: string, catch_body: [HirStmt], ret_type: TypeExpr, span: Span) -> InferExprResult throws { TypeError } do
  match infer_stmts(state, stmts: body, ret_type) do
    | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "try body: " ++ m, span: espan)
    | InferExprOk(state: st1, subst: s1, typ: _) ->
      // T-TryCatch: derive the catch parameter's type from the active
      // throws-row, projecting whatever the body could throw. Every Nexus
      // exception is a variant of the built-in `Exn` enum, so when the row
      // is `{Exn}`, an exception group like `{LirError}`, or specific named
      // exceptions, the catch parameter ends up bound to the same `Exn`
      // enum type — but we read the name out of the row instead of hard-
      // coding the string literal "Exn". The desugared `match catch_param`
      // (built by hir.nx for multi-arm catch) then drives per-arm dispatch
      // through bind_constructor_pattern unchanged.
      let row = subst.subst_apply(subst: s1, typ: tctypes.state_throw_row(state: st1))
      let param_ty = catch_param_type_from_row(row)
      let catch_env = tctypes.env_insert(
        env: tctypes.state_env(state: st1),
        name: catch_param,
        scheme: tctypes.mono(typ: param_ty)
      )
      let st2 = tctypes.state_with_env(state: st1, env: catch_env)
      // Mark that we are inside a catch body so `infer_match` suppresses the
      // hasCatchAll premise: selective catch (`| E1 -> ... | E2 -> ...`) is
      // valid without a wildcard arm — unmatched exceptions propagate via
      // the surrounding WASM EH tag mechanism.
      let st2c = tctypes.state_with_in_catch_body(state: st2, in_catch_body: true)
      match infer_stmts(state: st2c, stmts: catch_body, ret_type) do
        | InferExprErr(message: m, span: espan) -> return InferExprErr(message: "catch: " ++ m, span: espan)
        | InferExprOk(state: st3, subst: s2, typ: _) ->
          let st4 = tctypes.state_with_env(state: st3, env: tctypes.state_env(state))
          return InferExprOk(state: st4, subst: subst.subst_compose(s1, s2), typ: TyUnit)
      end
  end
end

