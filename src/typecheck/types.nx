/** Accessor: whether we are currently typechecking a try/catch catch body. */
export let state_in_catch_body = fn (state: CheckState) -> bool do
  let CheckState(
    supply: _,
    env: _,
    enum_defs: _,
    type_defs: _,
    throw_row: _,
    exception_groups: _,
    variant_index: _,
    in_catch_body: icb,
    _
  ) = state
  return icb
end

/** Return `state` with `in_catch_body` set to the given value. */
export let state_with_in_catch_body = fn (state: CheckState, in_catch_body: bool) -> CheckState do
  let CheckState(
    supply: s,
    env: e,
    enum_defs: ed,
    type_defs: td,
    throw_row: tw,
    exception_groups: egs,
    variant_index: vi,
    in_catch_body: _,
    require_row: rr,
    fn_pure_set: fps,
    caps: cs,
    module_variant_index: mvi,
    current_module: cm,
    full_enum_defs: fed,
    module_import_index: mii,
    catch_rethrow_binder: crb,
    global_sigs: gsi
