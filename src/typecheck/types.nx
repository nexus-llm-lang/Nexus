/** Render a `TypeExpr` as a short human-readable string (used in error messages and IDE hovers). */
export let type_to_string = fn (typ: TypeExpr) -> string do
  match typ do
    | TyI32 -> return "i32"
    | TyI64 -> return "i64"
    | TyF32 -> return "f32"
    | TyF64 -> return "f64"
    | TyBool -> return "bool"
    | TyChar -> return "char"
    | TyString -> return "string"
    | TyUnit -> return "()"
    | TyIntLit -> return "<int>"
    | TyFloatLit -> return "<float>"
    | TyVar(name: n) | TyUserDefined(name: n, args: []) -> return n
    | TyUserDefined(name: n, args: _) -> return n ++ "<...>"
    | TyArrow(_) -> return "fn(...)"
    | TyRef(inner: t) -> return "ref " ++ type_to_string(typ: t)
    | TyLinear(inner: t) -> return "%" ++ type_to_string(typ: t)
    | TyLazy(inner: t, require_row: _, throw_row: _) -> return "@" ++ type_to_string(typ: t)
    | TyBorrow(inner: t) -> return "&" ++ type_to_string(typ: t)
    | TyArray(elem: t) -> return "[|" ++ type_to_string(typ: t) ++ "|]"
    | TyList(elem: t) -> return "[" ++ type_to_string(typ: t) ++ "]"
    | TyRecord(_) -> return "{...}"
    | TyRow(_) -> return "<row>"
    | TyHandler(name: n, requires: _) -> return "handler " ++ n
  end
end
