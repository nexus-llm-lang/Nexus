/**
 * typecheck/types: Core types for the Nexus self-hosting typechecker.
 *
 * Defines Scheme, TypeEnv (as association lists), CheckState,
 * and result types for the typechecker passes.
 */

import { Span } from "src/types/span.nx"
import {
  TypeExpr,
  TyI32,
  TyI64,
  TyF32,
  TyF64,
  TyBool,
  TyChar,
  TyString,
  TyUnit,
  TyIntLit,
  TyFloatLit,
  TyUserDefined,
  TyVar,
  TyArrow,
  TyRef,
  TyLinear,
  TyLazy,
  TyBorrow,
  TyArray,
  TyList,
  TyRecord,
  TyRow,
  TyHandler,
  EnumDef,
  VariantDef,
  VariantField,
  RecordDef
} from "src/types/type_expr.nx"
import { ExceptionGroupEntry, HirCap } from "src/ir/hir/types.nx"
import {
  VariantIndex,
  VariantInfo,
  ModuleVariantIndex
}, * as vidx from "src/ir/support/variant_index.nx"
import { ModuleImportIndex }, * as iidx from "src/typecheck/import_index.nx"
import { Option, Some, None } from "std:option"
import * as str from "std:str"
import { smap_new, smap_put_str, smap_get_str, smap_has_str } from "std:runtime/collection"
import { value_to_i64, value_of_i64 } from "std:runtime/lazy"

/** Single substitution binding: type variable `var` maps to type expression `typ`. */
export type SubstEntry = SubstEntry(var: string, typ: TypeExpr)

// Generalization style: predicative System-F. Polymorphic schemes are
// introduced only by surface-syntax type-parameter lists:
//   let foo = fn <T, U>(x: T) -> U do ... end
// Every other binding (let, lambda parameters, pattern bindings,
// catch parameters, handler bindings) is monomorphic — see `mono`.
// One narrow carve-out: when the RHS is a bare variable referencing a
// polymorphic binding (`let f = id`), `f` inherits the source scheme so
// subsequent uses re-instantiate independently. See T-Let-Alias in
// docs/spec/type-system-formal.md and `infer.nx::alias_poly_scheme`.
//
// `vars` lists the named type parameters in source order; `typ` is the
// type expression possibly mentioning those parameter names as TyVars.

/** Polymorphic type scheme: `vars` are the bound type parameters, `typ` is the body. */
export type Scheme = Scheme(vars: [ string ], typ: TypeExpr)

/** One binding in the type environment: identifier name paired with its scheme. */
export type EnvEntry = EnvEntry(name: string, scheme: Scheme)

/** One enum declaration in the typechecker context: `name` to its `EnumDef`. */
export type EnumEntry = EnumEntry(name: string, def: EnumDef)

/** One type alias / record declaration: alias `name` to its `RecordDef`. */
export type TypeDefEntry = TypeDefEntry(name: string, def: RecordDef)

/** Threaded state for the inference/check passes: fresh-var supply, env, type/enum defs, throws row, and the variant index. */
export type CheckState = CheckState(
  supply: i64,
  env: [ EnvEntry ],
  enum_defs: [ EnumEntry ],
  type_defs: [ TypeDefEntry ],
  /** Active throws-row for the function being checked. T-Raise unifies the
   *  raised value's type against this row; T-TryCatch's catch param draws
   *  its admissible exception types from here too.
   */
  throw_row: TypeExpr,
  exception_groups: [ ExceptionGroupEntry ],
  /** Pre-built `variant_name -> VariantInfo` index for O(1) `find_variant`.
   *  Derived from `enum_defs` once at `tc_new_state` time; never mutated.
   */
  variant_index: VariantIndex,
  /** True while typechecking the catch body of a `try ... catch` statement.
   *  `infer_match` suppresses the T-Match hasCatchAll premise when this flag
   *  is set: selective catch (`catch | E1 -> ... | E2 -> ... end`) is valid
   *  even without a wildcard arm, because the runtime WASM EH mechanism
   *  already routes unmatched exceptions to the enclosing handler.
   */
  in_catch_body: bool,
  /** Ambient require row for the function being checked. Set by check_function
   *  from HirFunction.requires. Used by T-Inject to enforce ∀i. ρ_i ⊆ ρ_q
   *  (each injected handler's declared require row must be a subset of the
   *  enclosing function's ambient require row).
   */
  require_row: TypeExpr,
  /** Set of top-level function names whose bodies are provably non-throwing:
   *  no `Raise` node and no call to any function that can throw (transitively).
   *  Built by `build_fn_pure_set` in check_program before body checking.
   *  Used by `check_call_throw_row_admitted` to admit unannotated (`__implicit`
   *  throw-row) callees that are statically known to never throw, under a
   *  `throws {}` caller.
   */
  fn_pure_set: [ string ],
  /** The program's capability declarations, stored for inline-handler arm-set
   *  validation (spec §T-Handler). Set by `state_with_caps` in check_program
   *  after `register_caps`; initially `[]`.
   */
  caps: [ HirCap ],
  /** Per-module constructor index. Built once in `check_program` from the
   *  program's enum defs and carried unchanged. Constructor resolution against
   *  it is keyed on `current_module` so a function sees its own module's
   *  constructors first, then the program-wide fallback. Empty by default.
   */
  module_variant_index: ModuleVariantIndex,
  /** The source file / module path of the function whose body is currently
   *  being checked. Set per-function by `check_function`. Drives scoped
   *  constructor resolution against `module_variant_index`. Empty `""` outside
   *  a function body (signature registration), where scoped lookup falls back
   *  to the program-wide index.
   */
  current_module: string,
  /** Full (visibility-UNSTRIPPED) enum declarations, used ONLY by the match
   *  exhaustiveness / redundancy check. `enum_defs` strips the variants of
   *  enums not visible from the root module (D-Export) so constructor
   *  resolution and suggestion lists honour import visibility; but coverage
   *  analysis of a function body that legitimately lives in the defining
   *  module must see that enum's REAL variant set, otherwise a stripped
   *  (empty) signature yields spurious non-exhaustive / redundant verdicts
   *  when an imported body is checked. This field carries the unstripped set
   *  so the exhaustiveness check matches standalone checking exactly. It is
   *  never consulted for constructor resolution, so visibility enforcement is
   *  unaffected.
   */
  full_enum_defs: [ EnumEntry ],
  /** Per-module import-visibility index: for the function under check
   *  (`current_module`), which bare type/constructor names it brings into scope
   *  and from which source module. Drives import-graph-aware resolution of an
   *  enum / constructor name that several modules declare under the same bare
   *  name, so an imported body sees the definition IT imports rather than the
   *  program-wide flat first-match. Built once in `check_program`; empty by
   *  default, in which case scoped resolution falls through to the flat path.
   */
  module_import_index: ModuleImportIndex,
  /** Active catch-all binder under check, with the actual exception row the
   *  try body threw (its named-type members are the only exceptions the binder
   *  can hold). Set by `infer_try_impl` while checking a catch-all catch body;
   *  consulted by T-Raise so a rethrow `throw <binder>` of the catch-all binder
   *  is admitted iff that caught row's members are all ⊆ the enclosing declared
   *  throws row. `None` outside a catch-all body — a function/lambda parameter
   *  of type `Exn` is NOT a catch binder, so its `throw` stays strictly checked.
   */
  catch_rethrow_binder: Option<CatchBinderInfo>,
  /** Read-only global signature map: top-level function / external / cap-method
   *  / enum-constructor names to their `Scheme`. Built once during pass-1
   *  registration (and the generic-cap / value-binding re-publishing pre-passes),
   *  then read-only during body checking. Holds the raw `std:runtime/collection`
   *  string-map id (`i64`); the `Scheme` heap value rides the runtime's i64
   *  value channel (`value_to_i64` / `value_of_i64`). The flat `env` keeps ONLY
   *  per-scope locals (params, `let` / `match` binders) so it stays small; a
   *  local correctly SHADOWS a global because lookup consults `env` first. The
   *  map is mutable but never branches: all functionally-copied `CheckState`s
   *  share the one underlying map (globals are registered before any body is
   *  checked, then never structurally diverge), so threading the same id is
   *  sound. See `state_lookup_scheme` / `state_put_global`. */
  global_sigs: i64
)

/** The catch-all binder name plus the actual exception row the try body threw.
 *  Only the row's concrete named members gate admission; an open tail does not
 *  widen the admitted set (the body's actual throws are its named members). */
export type CatchBinderInfo = CatchBinderInfo(name: string, caught_row: TypeExpr)

/** Result of `tc_fresh_var`: the advanced state plus the freshly-allocated TyVar. */
export type FreshResult = FreshResult(state: CheckState, typ: TypeExpr)

/** Result of `unify`: either the resulting substitution or a unification-failure message. */
export type UnifyResult =
  UnifyOk(subst: [ SubstEntry ])
  | UnifyErr(message: string)

/** Result of inferring an expression: success carries threaded state, accumulated subst, and inferred type; error carries message and span. */
export type InferExprResult =
  InferExprOk(state: CheckState, subst: [ SubstEntry ], typ: TypeExpr)
  | InferExprErr(message: string, span: Span)

/** Result of binding a pattern against an expected type: success returns updated state, accumulated subst, and the env extended with new bindings. */
export type BindResult =
  BindOk(state: CheckState, subst: [ SubstEntry ], env: [ EnvEntry ])
  | BindErr(message: string)

/** Lookup record for an enum variant: which enum owns it, its type parameters, and the variant's fields. */
export type EnumVariantInfo = EnumVariantInfo(
  enum_name: string,
  type_params: [ string ],
  fields: [ VariantField ]
)

/** Build a fresh `CheckState` seeded with the program's enum, type, and exception declarations. */
export let tc_new_state = fn (
  enum_defs: [ EnumEntry ],
  type_defs: [ TypeDefEntry ],
  exception_groups: [ ExceptionGroupEntry ],
  full_enum_defs: [ EnumEntry ]
) -> CheckState do
  let variant_index = build_variant_index_from_entries(entries: enum_defs)
  let gsi = smap_new()
  return CheckState(
    supply: 0, env: [], enum_defs, type_defs,
    throw_row: TyRow(types: [], rest: None),
    exception_groups,
    variant_index,
    in_catch_body: false,
    require_row: TyRow(types: [], rest: None),
    fn_pure_set: [],
    caps: [],
    module_variant_index: vidx.empty_module_variant_index(),
    current_module: "",
    full_enum_defs,
    module_import_index: iidx.empty_module_import_index(),
    catch_rethrow_binder: None,
    global_sigs: gsi
  )
end

let build_variant_index_from_entries = fn (entries: [ EnumEntry ]) -> VariantIndex do
  return build_variant_index_from_entries_go(entries, acc: vidx.empty_variant_index())
end

let build_variant_index_from_entries_go = fn (
  entries: [ EnumEntry ],
  acc: VariantIndex
) -> VariantIndex do
  match entries do
    | [] -> return acc
    | EnumEntry(name: _, def: ed) :: rest ->
      return build_variant_index_from_entries_go(
        entries: rest,
        acc: vidx.extend_variant_index(idx: acc, defs: [ ed ])
      )
  end
end

/** Allocate a fresh type variable (named "?N") and return the advanced state alongside it. */
export let tc_fresh_var = fn (state: CheckState) -> FreshResult do
  let CheckState(
    supply: n,
    env: e,
    enum_defs: ed,
    type_defs: td,
    throw_row: tw,
    exception_groups: egs,
    variant_index: vi,
    in_catch_body: icb,
    require_row: rr,
    fn_pure_set: fps,
    caps: cs,
    module_variant_index: mvi,
    current_module: cm,
    full_enum_defs: fed,
    module_import_index: mii,
    catch_rethrow_binder: crb,
    global_sigs: gsi
  ) = state
  let name = "?" ++ str.from_i64(val: n)
  return FreshResult(
    state: CheckState(
      supply: n + 1,
      env: e,
      enum_defs: ed,
      type_defs: td,
      throw_row: tw,
      exception_groups: egs,
      variant_index: vi,
      in_catch_body: icb,
      require_row: rr,
      fn_pure_set: fps,
      caps: cs,
      module_variant_index: mvi,
      current_module: cm,
      full_enum_defs: fed,
      module_import_index: mii,
      catch_rethrow_binder: crb,
      global_sigs: gsi
    ),
    typ: TyVar(name)
  )
end

/** Look up `name` in the environment, returning its scheme if bound. */
export let env_lookup = fn (env: [ EnvEntry ], name: string) -> Option<Scheme> do
  match env do
    | [] -> return None
    | EnvEntry(name: n, scheme: s) :: rest ->
      if n == name then
        return Some(val: s)
      end
      return env_lookup(env: rest, name)
  end
end

/** Prepend a `name → scheme` binding to the environment; lookup uses first-match shadowing. */
export let env_insert = fn (env: [ EnvEntry ], name: string, scheme: Scheme) -> [ EnvEntry ] do
  return EnvEntry(name, scheme) :: env
end

/** Accessor: the read-only global signature map id. */
export let state_global_sigs = fn (state: CheckState) -> i64 do
  let CheckState(
    supply: _, env: _, enum_defs: _, type_defs: _, throw_row: _,
    exception_groups: _, variant_index: _, in_catch_body: _, require_row: _,
    fn_pure_set: _, caps: _, module_variant_index: _, current_module: _,
    full_enum_defs: _, module_import_index: _, catch_rethrow_binder: _, global_sigs: gsi
  ) = state
  return gsi
end

/** Publish a TOP-LEVEL/global signature into the shared global map. Mutates the
 *  one underlying map all `CheckState` copies share, so the binding is visible
 *  to every later lookup regardless of which functional copy reads it. Used by
 *  pass-1 registration and by the generic-cap / value-binding re-publishing
 *  pre-passes (a re-`put` of an existing name OVERWRITES, mirroring the old
 *  first-match `env_insert` shadowing of a prior global registration). The
 *  `Scheme` heap value rides the runtime i64 value channel. Returns `state`
 *  unchanged (the side effect is on the shared map). */
export let state_put_global = fn (state: CheckState, name: string, scheme: Scheme) -> CheckState do
  smap_put_str(id: state_global_sigs(state), key: name, value: value_to_i64(a_x: scheme))
  return state
end

/** Combined name resolution: per-scope LOCALS first (so a local correctly
 *  SHADOWS a global), then the read-only global signature map. Every site that
 *  previously did `env_lookup(env: state_env(state), name)` for a name that may
 *  be a top-level function / external / cap-method / enum-constructor routes
 *  here, so resolution is identical to the old single flat env — the data
 *  structure is split purely to turn the O(N) global scan into an O(1) map probe. */
export let state_lookup_scheme = fn (state: CheckState, name: string) -> Option<Scheme> do
  match env_lookup(env: state_env(state), name) do
    | Some(val: s) -> return Some(val: s)
    | None ->
      let gsi = state_global_sigs(state)
      if smap_has_str(id: gsi, key: name) then
        return Some(val: value_of_i64(a_x: smap_get_str(id: gsi, key: name, default_val: 0)))
      end
      return None
  end
end

/** Wrap a monomorphic type as a closed scheme (empty `vars`). */
export let mono = fn (typ: TypeExpr) -> Scheme do
  return Scheme(vars: [], typ)
end

/** Look up a record/type-alias declaration by name. */
export let typedef_lookup = fn (defs: [ TypeDefEntry ], name: string) -> Option<RecordDef> do
  match defs do
    | [] -> return None
    | TypeDefEntry(name: n, def: d) :: rest ->
      if n == name then
        return Some(val: d)
      end
      return typedef_lookup(defs: rest, name)
  end
end

/** Resolve a variant constructor name to its owning enum and field info via the prebuilt index (O(1)). */
export let find_variant = fn (idx: VariantIndex, variant: string) -> Option<EnumVariantInfo> do
  match vidx.lookup_variant_info(idx, variant) do
    | None -> return None
    | Some(val: VariantInfo(enum_name: ename, type_params: tps, def: VariantDef(name: _, fields: fs))) ->
      return Some(val: EnumVariantInfo(enum_name: ename, type_params: tps, fields: fs))
  end
end

/** Resolve a constructor for the function currently under check.
 *
 *  The program-flat live `variant_index` is consulted FIRST: it applies the
 *  typecheck visibility filter (variants of non-visible enums are stripped), so
 *  every resolution it makes is identical to today's behaviour. Only when the
 *  flat index MISSES does this fall back to the per-module index keyed on
 *  `current_module` — resolving the constructor against ONLY the checked
 *  function's OWN module's enums (no program-wide fallback). This is purely
 *  additive AND visibility-preserving: it recovers a module's OWN constructors
 *  the flat index withheld (the imported-body `UnknownConstructor` case) — a
 *  module's own constructors are always visible to it regardless of export —
 *  without exposing ANOTHER module's non-public constructors, which a global
 *  fallback would. With the default empty per-module index (signature
 *  registration, or before `check_program` installs the real one) the fallback
 *  returns `None`, leaving behaviour byte-identical to
 *  `find_variant(state_variant_index(state), …)`. */
export let find_variant_in_state = fn (
  state: CheckState,
  variant: string
) -> Option<EnumVariantInfo> do
  match find_variant(idx: state_variant_index(state), variant) do
    | Some(val: evi) -> return Some(val: evi)
    | None ->
      match vidx.lookup_variant_info_own_module_with_layout(
        mvi: state_module_variant_index(state),
        module: state_current_module(state),
        variant
      ) do
        | Some(val: VariantInfo(enum_name: ename, type_params: tps, def: VariantDef(name: _, fields: fs))) ->
          return Some(val: EnumVariantInfo(enum_name: ename, type_params: tps, fields: fs))
        | None -> return find_variant_via_import(state, variant)
      end
  end
end

/** Third resolution tier for `find_variant_in_state`: a constructor the current
 *  module brought into scope by `import { C } from "D"`. The flat index withheld
 *  it (D's enum is not visible from the ROOT module) and own-module missed it (C
 *  is not declared in the current module), but the SELECTIVE import edge proves
 *  the current module legitimately imports C from D — so resolve C against D's
 *  own-module scope. Because only selective `import { … }` items create edges, a
 *  wildcard-imported non-exported constructor is never resolved here, keeping
 *  D-Export visibility enforcement intact. Returns `None` (genuine unknown
 *  constructor) when the current module has no import edge for `variant`. */
let find_variant_via_import = fn (state: CheckState, variant: string) -> Option<EnumVariantInfo> do
  match iidx.resolve_import_source(
    idx: state_module_import_index(state),
    importer: state_current_module(state),
    name: variant
  ) do
    | None -> return None
    | Some(val: source) ->
      match vidx.lookup_variant_info_own_module(
        mvi: state_module_variant_index(state),
        module: source,
        variant
      ) do
        | None -> return None
        | Some(val: VariantInfo(enum_name: ename, type_params: tps, def: VariantDef(name: _, fields: fs))) ->
          return Some(val: EnumVariantInfo(enum_name: ename, type_params: tps, fields: fs))
      end
  end
end

/** Replace the env in `state` (other fields preserved). */
export let state_with_env = fn (state: CheckState, env: [ EnvEntry ]) -> CheckState do
  let CheckState(
    supply: s,
    env: _,
    enum_defs: ed,
    type_defs: td,
    throw_row: tw,
    exception_groups: egs,
    variant_index: vi,
    in_catch_body: icb,
    require_row: rr,
    fn_pure_set: fps,
    caps: cs,
    module_variant_index: mvi,
    current_module: cm,
    full_enum_defs: fed,
    module_import_index: mii,
    catch_rethrow_binder: crb,
    global_sigs: gsi
  ) = state
  return CheckState(
    supply: s,
    env,
    enum_defs: ed,
    type_defs: td,
    throw_row: tw,
    exception_groups: egs,
    variant_index: vi,
    in_catch_body: icb,
    require_row: rr,
    fn_pure_set: fps,
    caps: cs,
    module_variant_index: mvi,
    current_module: cm,
    full_enum_defs: fed,
    module_import_index: mii,
    catch_rethrow_binder: crb,
    global_sigs: gsi
  )
end

/** Replace the active throws-row in `state` (used when entering/leaving a function body). */
export let state_with_throw_row = fn (state: CheckState, throw_row: TypeExpr) -> CheckState do
  let CheckState(
    supply: s,
    env: e,
    enum_defs: ed,
    type_defs: td,
    throw_row: _,
    exception_groups: egs,
    variant_index: vi,
    in_catch_body: icb,
    require_row: rr,
    fn_pure_set: fps,
    caps: cs,
    module_variant_index: mvi,
    current_module: cm,
    full_enum_defs: fed,
    module_import_index: mii,
    catch_rethrow_binder: crb,
    global_sigs: gsi
  ) = state
  return CheckState(
    supply: s,
    env: e,
    enum_defs: ed,
    type_defs: td,
    throw_row,
    exception_groups: egs,
    variant_index: vi,
    in_catch_body: icb,
    require_row: rr,
    fn_pure_set: fps,
    caps: cs,
    module_variant_index: mvi,
    current_module: cm,
    full_enum_defs: fed,
    module_import_index: mii,
    catch_rethrow_binder: crb,
    global_sigs: gsi
  )
end

/** Accessor: the current type environment. */
export let state_env = fn (state: CheckState) -> [ EnvEntry ] do
  let CheckState(supply: _, env: e, _) = state
  return e
end

/** Accessor: the program's enum declarations. */
export let state_enums = fn (state: CheckState) -> [ EnumEntry ] do
  let CheckState(supply: _, env: _, enum_defs: ed, _) = state
  return ed
end

/** Accessor: the FULL (visibility-unstripped) enum declarations, consulted
 *  ONLY by the match exhaustiveness / redundancy check so imported-body
 *  coverage analysis sees an enum's real variant set (see the field doc on
 *  `CheckState.full_enum_defs`). */
export let state_full_enums = fn (state: CheckState) -> [ EnumEntry ] do
  let CheckState(
    supply: _,
    env: _,
    enum_defs: _,
    type_defs: _,
    throw_row: _,
    exception_groups: _,
    variant_index: _,
    in_catch_body: _,
    require_row: _,
    fn_pure_set: _,
    caps: _,
    module_variant_index: _,
    current_module: cm,
    full_enum_defs: fed,
    module_import_index: mii,
    catch_rethrow_binder: crb,
    global_sigs: gsi
  ) = state
  return scope_enum_entries(entries: fed, current_module: cm, idx: mii)
end

/** Reorder `entries` so that, for the module under check, each bare enum name
 *  resolves (via `find_enum`'s first-match) to the definition that module can
 *  actually SEE — its OWN definition first, else the one it IMPORTS under that
 *  name — rather than the program-wide first-match, which may belong to an
 *  unrelated module that happens to declare the same bare name. Entries the
 *  current module neither owns nor imports keep their original relative order
 *  and stay AFTER the scoped ones, so resolution is unchanged for names with no
 *  collision and never exposes a definition the module cannot see. With an empty
 *  index / current_module (root checking, signature registration) nothing is
 *  promoted and the list is returned in original order — behaviour-identical to
 *  the previous flat `full_enum_defs`. */
let scope_enum_entries = fn (
  entries: [ EnumEntry ],
  current_module: string,
  idx: ModuleImportIndex
) -> [ EnumEntry ] do
  if current_module == "" then return entries end
  let visible = filter_visible_enum_entries(entries, current_module, idx, acc: [])
  match visible do
    | [] -> return entries
    | _ -> return list_append_entries(xs: visible, ys: entries)
  end
end

let filter_visible_enum_entries = fn (
  entries: [ EnumEntry ],
  current_module: string,
  idx: ModuleImportIndex,
  acc: [ EnumEntry ]
) -> [ EnumEntry ] do
  match entries do
    | [] -> return list_reverse_entries(xs: acc, acc: [])
    | EnumEntry(name: n, def: d) :: rest ->
      let EnumDef(
        name: _,
        is_public: _,
        is_opaque: _,
        type_params: _,
        variants: _,
        layout_variants: _,
        module: m
      ) = d
      let owned = m == current_module
      let imported = match iidx.resolve_import_source(idx, importer: current_module, name: n) do
          | Some(val: src) -> src == m
          | None -> false
        end
      if owned || imported then
        return filter_visible_enum_entries(
          entries: rest,
          current_module,
          idx,
          acc: EnumEntry(name: n, def: d) :: acc
        )
      else
        return filter_visible_enum_entries(entries: rest, current_module, idx, acc)
      end
  end
end

let list_reverse_entries = fn (xs: [ EnumEntry ], acc: [ EnumEntry ]) -> [ EnumEntry ] do
  match xs do
    | [] -> return acc
    | h :: t -> return list_reverse_entries(xs: t, acc: h :: acc)
  end
end

let list_append_entries = fn (xs: [ EnumEntry ], ys: [ EnumEntry ]) -> [ EnumEntry ] do
  match xs do
    | [] -> return ys
    | h :: t -> return h :: list_append_entries(xs: t, ys)
  end
end

/** Accessor: the program's record/type-alias declarations. */
export let state_typedefs = fn (state: CheckState) -> [ TypeDefEntry ] do
  let CheckState(supply: _, env: _, enum_defs: _, type_defs: td, _) = state
  return td
end

/** Extract the raw `[RecordDef]` list from the state's `[TypeDefEntry]` list.
 *  Used by structural linearity predicates (`is_linear_binding_type`) that
 *  take `[RecordDef]` directly.
 */
export let state_record_defs = fn (state: CheckState) -> [ RecordDef ] do
  return typedef_entries_to_record_defs(defs: state_typedefs(state), acc: [])
end

let typedef_entries_to_record_defs = fn (
  defs: [ TypeDefEntry ],
  acc: [ RecordDef ]
) -> [ RecordDef ] do
  match defs do
    | [] -> return acc
    | TypeDefEntry(name: _, def: rd) :: rest ->
      return typedef_entries_to_record_defs(defs: rest, acc: rd :: acc)
  end
end

/** Accessor: the active throws-row for the enclosing function being checked. */
export let state_throw_row = fn (state: CheckState) -> TypeExpr do
  let CheckState(supply: _, env: _, enum_defs: _, type_defs: _, throw_row: tw, _) = state
  return tw
end

/** Accessor: declared exception groups (alias names that expand to a set of exception types). */
export let state_exception_groups = fn (state: CheckState) -> [ ExceptionGroupEntry ] do
  let CheckState(
    supply: _,
    env: _,
    enum_defs: _,
    type_defs: _,
    throw_row: _,
    exception_groups: egs,
    _
  ) = state
  return egs
end

/** Accessor: the prebuilt `variant_name → VariantInfo` index used by `find_variant`. */
export let state_variant_index = fn (state: CheckState) -> VariantIndex do
  let CheckState(
