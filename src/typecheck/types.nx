  return CheckState(
    supply: s,
    env: e,
    enum_defs: ed,
    type_defs: td,
    throw_row: tw,
    exception_groups: egs,
    variant_index: vi,
    in_catch_body,
    require_row: rr,
    fn_pure_set: fps,
    caps: cs,
    module_variant_index: mvi,
    current_module: cm,
    full_enum_defs: fed,
    module_import_index: mii,
    catch_rethrow_binder: crb,
    global_sigs: gsi
  )
end

