/**
 * typecheck/unify: Robinson unification for Nexus types.
 *
 * Handles all TypeExpr variants including numeric literal promotion,
 * cross-unification of List<T> with UserDefined("List", [T]),
 * and simplified row unification.
 */

import {
  TypeExpr, TyI32, TyI64, TyF32, TyF64,
  TyIntLit, TyFloatLit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyLazy, TyBorrow,
  TyArray, TyList, TyRecord, TyRow, TyHandler, NamedType
} from "src/common/ast.nx"
import {
  SubstEntry, UnifyResult, UnifyOk, UnifyErr, TypeDefEntry
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"

// ─── Main unification ───────────────────────────────────────────────────────

/** First-order Robinson unification of `t1` and `t2` under typedef environment `tdefs`. Returns UnifyOk with the most-general substitution, or UnifyErr with a diagnostic message. Handles occurs check, type-var binding, numeric-literal promotion, row unification, and borrow asymmetry. */
export let unify = fn (t1: TypeExpr, t2: TypeExpr, tdefs: [TypeDefEntry]) -> UnifyResult do
  if subst.type_eq(a: t1, b: t2) then
    return UnifyOk(subst: subst.subst_empty())
  end

  // Type variable binding must come BEFORE numeric literal promotion.
  if let TyVar(name: n) = t1 then
    if subst.occurs_check(var: n, typ: t2) then
      return UnifyErr(message: "recursive type: " ++ n)
    end
    return UnifyOk(subst: subst.subst_single(var: n, typ: t2))
  end
  if let TyVar(name: n) = t2 then
    if subst.occurs_check(var: n, typ: t1) then
      return UnifyErr(message: "recursive type: " ++ n)
    end
    return UnifyOk(subst: subst.subst_single(var: n, typ: t1))
  end

  match t1 do
    | TyIntLit ->
      match t2 do
        | TyI32 | TyI64 | TyIntLit -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "cannot unify int literal with non-integer type")
      end
    | TyFloatLit ->
      match t2 do
        | TyF32 | TyF64 | TyFloatLit -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "cannot unify float literal with non-float type")
      end
    | _ -> ()
  end
  match t2 do
    | TyIntLit ->
      match t1 do
        | TyI32 | TyI64 -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "cannot unify int literal with non-integer type")
      end
    | TyFloatLit ->
      match t1 do
        | TyF32 | TyF64 -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "cannot unify float literal with non-float type")
      end
    | _ -> ()
  end

  if let TyArrow(params: p1, ret: r1, requires: req1, throw_row: thr1) = t1 then
    return if let TyArrow(params: p2, ret: r2, requires: req2, throw_row: thr2) = t2 then
      unify_arrow(p1, p2, r1, r2, req1, req2, thr1, thr2, tdefs)
    else UnifyErr(message: "expected arrow type") end
  end

  if let TyUserDefined(name: n1, args: a1) = t1 then
    match t2 do
      // Spec §U-Named (type-system-formal.md): same-name named types unify
      // by pointwise unification of their type arguments.
      | TyUserDefined(name: n2, args: a2) ->
        if n1 == n2 then
          return unify_type_lists(ts1: a1, ts2: a2, tdefs)
        end
        return UnifyErr(message: "type mismatch: " ++ n1 ++ " vs " ++ n2)
      // Spec §U-ListSugar: bridge the `List<T>` named-enum and the `[T]`
      // surface alias. Asymmetric case — left is the named form.
      | TyList(elem: inner) ->
        if n1 == "List" then
          match a1 do
            | [arg] ->
              return unify(t1: arg, t2: inner, tdefs)
            | _ -> return UnifyErr(message: "List type arity mismatch")
          end
        end
        return UnifyErr(message: "cannot unify " ++ n1 ++ " with list")
      // Spec §U-Expand: named record-typedef vs structural record. Unfold
      // the typedef's fields (with type-args substituted) and unify with
      // the structural side. Asymmetric case — left is the named form.
      | TyRecord(_) ->
        return unify_typedef_record(name: n1, args: a1, record: t2, tdefs)
      | _ -> return UnifyErr(message: "type mismatch: user-defined vs other")
    end
  end

  if let TyList(elem: inner) = t1 then
    match t2 do
      | TyList(elem: inner2) -> return unify(t1: inner, t2: inner2, tdefs)
      // Spec §U-ListSugar (symmetric counterpart of the TyUserDefined/TyList
      // arm above): bridge `[T]` (left) and `List<T>` (right).
      | TyUserDefined(name: n, args) ->
        if n == "List" then
          match args do
            | [arg] ->
              return unify(t1: inner, t2: arg, tdefs)
            | _ -> return UnifyErr(message: "List type arity mismatch")
          end
        end
        return UnifyErr(message: "cannot unify list with " ++ n)
      | _ -> return UnifyErr(message: "expected list type")
    end
  end

  if let TyArray(elem: e1) = t1 then
    return if let TyArray(elem: e2) = t2 then
      unify(t1: e1, t2: e2, tdefs)
    else UnifyErr(message: "expected array type") end
  end

  if let TyRecord(fields: f1) = t1 then
    match t2 do
      // Spec §U-Record: two structural records unify field-by-field.
      | TyRecord(fields: f2) -> return unify_named_types(nts1: f1, nts2: f2, tdefs)
      // Spec §U-Expand (symmetric counterpart of the TyUserDefined/TyRecord
      // arm above): structural record (left) vs named record-typedef (right).
      | TyUserDefined(name: n, args) ->
        return unify_typedef_record(name: n, args, record: t1, tdefs)
      | _ -> return UnifyErr(message: "expected record type")
    end
  end

  if let TyRef(inner: i1) = t1 then
    return if let TyRef(inner: i2) = t2 then
      unify(t1: i1, t2: i2, tdefs)
    else UnifyErr(message: "expected ref type") end
  end
  if let TyLinear(inner: i1) = t1 then
    return if let TyLinear(inner: i2) = t2 then
      unify(t1: i1, t2: i2, tdefs)
    else UnifyErr(message: "expected linear type") end
  end
  if let TyLazy(inner: i1) = t1 then
    return if let TyLazy(inner: i2) = t2 then
      unify(t1: i1, t2: i2, tdefs)
    else UnifyErr(message: "expected lazy type") end
  end
  if let TyBorrow(inner: i1) = t1 then
    // U-Borrow: auto-deref the LEFT operand only.
    // Spec type-system-formal.md §U-Borrow declares this rule intentionally
    // asymmetric — there is no symmetric counterpart. A bare TyBorrow on the
    // right of a non-borrow LHS is a type mismatch and must fall through.
    return if let TyBorrow(inner: i2) = t2 then
      unify(t1: i1, t2: i2, tdefs)
    else unify(t1: i1, t2, tdefs) end
  end

  if let TyRow(types: ts1, rest: r1) = t1 then
    return if let TyRow(types: ts2, rest: r2) = t2 then
      unify_rows(ts1, r1, ts2, r2, tdefs)
    else UnifyErr(message: "expected row type") end
  end

  if let TyHandler(name: n1, requires: req1) = t1 then
    return if let TyHandler(name: n2, requires: req2) = t2 then
      if n1 == n2 then
        unify(t1: req1, t2: req2, tdefs)
      else UnifyErr(message: "handler mismatch: " ++ n1 ++ " vs " ++ n2) end
    else UnifyErr(message: "expected handler type") end
  end

  return UnifyErr(message: "type mismatch")
end

// ─── Arrow unification ──────────────────────────────────────────────────────

let unify_arrow = fn (
  p1: [NamedType], p2: [NamedType],
  r1: TypeExpr, r2: TypeExpr,
  req1: TypeExpr, req2: TypeExpr,
  thr1: TypeExpr, thr2: TypeExpr,
  tdefs: [TypeDefEntry]
) -> UnifyResult do
  match unify_named_types(nts1: p1, nts2: p2, tdefs) do
    | UnifyErr(message: m) -> return UnifyErr(message: m)
    | UnifyOk(subst: s1) ->
      match unify(t1: subst.subst_apply(subst: s1, typ: r1), t2: subst.subst_apply(subst: s1, typ: r2), tdefs) do
        | UnifyErr(message: m) -> return UnifyErr(message: m)
        | UnifyOk(subst: s2) ->
          let s12 = subst.subst_compose(s1, s2)
          match unify_with_kind(t1: subst.subst_apply(subst: s12, typ: req1), t2: subst.subst_apply(subst: s12, typ: req2), tdefs, kind: "requires") do
            | UnifyErr(message: m) -> return UnifyErr(message: m)
            | UnifyOk(subst: s3) ->
              let s123 = subst.subst_compose(s1: s12, s2: s3)
              match unify_with_kind(t1: subst.subst_apply(subst: s123, typ: thr1), t2: subst.subst_apply(subst: s123, typ: thr2), tdefs, kind: "throws") do
                | UnifyErr(message: m) -> return UnifyErr(message: m)
                | UnifyOk(subst: s4) ->
                  return UnifyOk(subst: subst.subst_compose(s1: s123, s2: s4))
              end
          end
      end
  end
end

// Unify when the caller knows which row kind (throws/requires) is on the
// surface; dispatches to the row-aware unifier when both sides are
// TyRow, otherwise to plain unify. Every arm has an explicit `return`
// so that the asymmetric (TyRow, TyVar) case (which arises during
// arrow-throw unification with a row-polymorphic callee) is total.
let unify_with_kind = fn (t1: TypeExpr, t2: TypeExpr, tdefs: [TypeDefEntry], kind: string) -> UnifyResult do
  match t1 do
    | TyRow(types: ts1, rest: r1) ->
      match t2 do
        | TyRow(types: ts2, rest: r2) ->
          return unify_rows_kind(ts1, r1, ts2, r2, tdefs, kind)
        | _ -> return unify(t1, t2, tdefs)
      end
    | _ -> return unify(t1, t2, tdefs)
  end
end

// ─── Named type list unification (params, record fields) ────────────────────

let unify_named_types = fn (nts1: [NamedType], nts2: [NamedType], tdefs: [TypeDefEntry]) -> UnifyResult do
  match nts1 do
    | [] ->
      match nts2 do
        | [] -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "arity mismatch")
      end
    | NamedType(name: n1, typ: t1) :: r1 ->
      match nts2 do
        | [] -> return UnifyErr(message: "arity mismatch")
        | NamedType(name: n2, typ: t2) :: r2 ->
          match unify(t1, t2, tdefs) do
            | UnifyErr(message: m) -> return UnifyErr(message: "field " ++ n1 ++ ": " ++ m)
            | UnifyOk(subst: s1) ->
              let r1a = apply_subst_named_types(subst: s1, nts: r1)
              let r2a = apply_subst_named_types(subst: s1, nts: r2)
              match unify_named_types(nts1: r1a, nts2: r2a, tdefs) do
                | UnifyErr(message: m) -> return UnifyErr(message: m)
                | UnifyOk(subst: s2) ->
                  return UnifyOk(subst: subst.subst_compose(s1, s2))
              end
          end
      end
  end
end

let apply_subst_named_types = fn (subst: [SubstEntry], nts: [NamedType]) -> [NamedType] do
  match nts do
    | [] -> return []
    | NamedType(name: n, typ: t) :: rest ->
      return NamedType(name: n, typ: subst.subst_apply(subst, typ: t))
        :: apply_subst_named_types(subst, nts: rest)
  end
end

// ─── Type list unification ──────────────────────────────────────────────────

let unify_type_lists = fn (ts1: [TypeExpr], ts2: [TypeExpr], tdefs: [TypeDefEntry]) -> UnifyResult do
  match ts1 do
    | [] ->
      match ts2 do
        | [] -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "type argument arity mismatch")
      end
    | h1 :: r1 ->
      match ts2 do
        | [] -> return UnifyErr(message: "type argument arity mismatch")
        | h2 :: r2 ->
          match unify(t1: h1, t2: h2, tdefs) do
            | UnifyErr(message: m) -> return UnifyErr(message: m)
            | UnifyOk(subst: s1) ->
              let r1a = apply_subst_type_list(subst: s1, types: r1)
              let r2a = apply_subst_type_list(subst: s1, types: r2)
              match unify_type_lists(ts1: r1a, ts2: r2a, tdefs) do
                | UnifyErr(message: m) -> return UnifyErr(message: m)
                | UnifyOk(subst: s2) ->
                  return UnifyOk(subst: subst.subst_compose(s1, s2))
              end
          end
      end
  end
end

let apply_subst_type_list = fn (subst: [SubstEntry], types: [TypeExpr]) -> [TypeExpr] do
  match types do
    | [] -> return []
    | t :: rest ->
      return subst.subst_apply(subst, typ: t)
        :: apply_subst_type_list(subst, types: rest)
  end
end

// ─── Row unification ────────────────────────────────────────────────────────
// Compute surplus-label vectors (e1r/e2r) and surface them in mismatch
// diagnostics so users see which labels broke unification, not a content-free
// "row: type mismatch".

// Internal helpers: Nexus has no tuple syntax, so the two-value returns
// from the surplus-split walk go through these one-shot ADTs.
type RowRemove = RowRemove(found: bool, rest: [TypeExpr])
type RowSplit = RowSplit(only_left: [TypeExpr], only_right: [TypeExpr])

// Drop the first occurrence of `target` from `xs` using structural type equality.
let row_remove_label = fn (xs: [TypeExpr], target: TypeExpr) -> RowRemove do
  match xs do
    | [] -> return RowRemove(found: false, rest: [])
    | h :: rest ->
      if subst.type_eq(a: h, b: target) then
        return RowRemove(found: true, rest)
      end
      let RowRemove(found, rest: tail) = row_remove_label(xs: rest, target)
      return RowRemove(found, rest: h :: tail)
  end
end

let row_split_surplus = fn (e1: [TypeExpr], e2: [TypeExpr]) -> RowSplit do
  match e1 do
    | [] -> return RowSplit(only_left: [], only_right: e2)
    | h :: rest ->
      let RowRemove(found: matched, rest: e2_after) = row_remove_label(xs: e2, target: h)
      let RowSplit(only_left: e1r, only_right: e2r) = row_split_surplus(e1: rest, e2: e2_after)
      if matched then
        return RowSplit(only_left: e1r, only_right: e2r)
      end
      return RowSplit(only_left: h :: e1r, only_right: e2r)
  end
end

let format_row_labels = fn (labels: [TypeExpr]) -> string do
  match labels do
    | [] -> return "{ }"
    | _ -> return "{ " ++ join_label_names(labels) ++ " }"
  end
end

let join_label_names = fn (labels: [TypeExpr]) -> string do
  match labels do
    | [] -> return ""
    | [t] -> return tctypes.type_to_string(typ: t)
    | t :: rest -> return tctypes.type_to_string(typ: t) ++ ", " ++ join_label_names(labels: rest)
  end
end

let row_kind_prefix = fn (kind: string) -> string do
  if kind == "throws" then return "throws row mismatch" end
  if kind == "requires" then return "requires row mismatch" end
  if kind == "record" then return "record row mismatch" end
  if kind == "port" then return "port row mismatch" end
  return "row mismatch"
end

// True when `ts` contains the Exn sentinel `TyUserDefined("Exn", _)` as a row entry.
let row_contains_exn = fn (ts: [TypeExpr]) -> bool do
  match ts do
    | [] -> return false
    | h :: rest ->
      match h do
        | TyUserDefined(name: n, args: _) ->
          if n == "Exn" then return true end
          return row_contains_exn(ts: rest)
        | _ -> return row_contains_exn(ts: rest)
      end
  end
end

// U-Row-Exn premise check (spec docs/spec/type-system-formal.md §Unification,
// lines 496-508). Given the partner row `other` (every C ∈ other must be
// absorbed by the Exn-bearing side), each entry must be:
//   - the Exn sentinel itself (C = Exn), or
//   - a constructor of Exn (C ∈ variants(Exn)).
// In Nexus, variants(Exn) is realised as "any TyUserDefined name" because
// Exn is the catch-all exception sentinel (see typecheck/check.nx where
// Exn is registered as an open EnumDef and infer.nx::row_admits_exception
// which treats it as universal). Non-TyUserDefined row entries (TyVar,
// TyArrow, etc.) are NOT absorbed — they signal a row shape mismatch.
//
// Note: the common-prefix branch `C ∈ c` from the spec is subsumed here,
// because c ⊆ τ_2 and every c-entry is itself a TyUserDefined (else it
// couldn't be a row label).
let row_all_absorbable_by_exn = fn (other: [TypeExpr]) -> bool do
  match other do
    | [] -> return true
    | h :: rest ->
      match h do
        | TyUserDefined(name: _, args: _) -> return row_all_absorbable_by_exn(other: rest)
        | _ -> return false
      end
  end
end

let unify_rows = fn (
  ts1: [TypeExpr], r1: Option<TypeExpr>,
  ts2: [TypeExpr], r2: Option<TypeExpr>,
  tdefs: [TypeDefEntry]
) -> UnifyResult do
  return unify_rows_kind(ts1, r1, ts2, r2, tdefs, kind: "")
end

let unify_rows_kind = fn (
  ts1: [TypeExpr], r1: Option<TypeExpr>,
  ts2: [TypeExpr], r2: Option<TypeExpr>,
  tdefs: [TypeDefEntry],
  kind: string
) -> UnifyResult do
  let prefix = row_kind_prefix(kind)

  // U-Row-Exn (spec docs/spec/type-system-formal.md §Unification, lines
  // 496-508).
  //
  //   Exn ∈ τ_2      c = τ_2 \ {Exn}
  //   ∀ C ∈ τ_1.  C = Exn  ∨  C ∈ c  ∨  C ∈ variants(Exn)
  //   ────────────────────────────────────────────────────
  //               unify({τ_1}, {τ_2})
  //
  // When one row carries the catch-all Exn sentinel, any constructors of
  // Exn on the partner side are absorbed by it — the only row-inclusion
  // relationship the type system admits. Per spec line 508 this rule is
  // restricted to closed-closed row shapes; the symmetry convention covers
  // both argument orders, so we test (r1=None, r2=None) and either side
  // bearing Exn. Open/closed mixes fall through to U-Row-Closed-Open and
  // can re-enter U-Row-Exn after the tail variable is instantiated.
  //
  // Only meaningful for the `throws` row — Exn is the exception sentinel
  // and is not a valid label in `requires`/`record`/`port` rows.
  if kind == "throws" then
    match r1 do
      | Some(val: _) -> ()
      | None ->
        match r2 do
          | Some(val: _) -> ()
          | None ->
            if row_contains_exn(ts: ts1) then
              if row_all_absorbable_by_exn(other: ts2) then
                return UnifyOk(subst: subst.subst_empty())
              end
              return UnifyErr(message: prefix ++ ": row entries "
                ++ format_row_labels(labels: ts2)
                ++ " not all absorbable by Exn sentinel")
            end
            if row_contains_exn(ts: ts2) then
              if row_all_absorbable_by_exn(other: ts1) then
                return UnifyOk(subst: subst.subst_empty())
              end
              return UnifyErr(message: prefix ++ ": row entries "
                ++ format_row_labels(labels: ts1)
                ++ " not all absorbable by Exn sentinel")
            end
        end
    end
  end

  let RowSplit(only_left: e1r, only_right: e2r) = row_split_surplus(e1: ts1, e2: ts2)

  // Open-row absorption when the partner row has a tail variable.
  match r1 do
    | Some(val: _) -> ()
    | None ->
      match e2r do
        | [] -> ()
        | _ ->
          return UnifyErr(message: prefix ++ ": callee row has extra label(s) "
            ++ format_row_labels(labels: e2r) ++ " not admitted by caller")
      end
  end
  match r2 do
    | Some(val: _) -> ()
    | None ->
      match e1r do
        | [] -> ()
        | _ ->
          return UnifyErr(message: prefix ++ ": caller row has extra label(s) "
            ++ format_row_labels(labels: e1r) ++ " not admitted by callee")
      end
  end

  match r1 do
    | Some(val: tail1) ->
      match r2 do
        | Some(val: tail2) ->
          match unify(t1: tail1, t2: tail2, tdefs) do
            | UnifyErr(message: m) -> return UnifyErr(message: prefix ++ " (tail): " ++ m)
            | UnifyOk(subst: s) -> return UnifyOk(subst: s)
          end
        | None -> return UnifyOk(subst: subst.subst_empty())
      end
    | None -> return UnifyOk(subst: subst.subst_empty())
  end
end

// ─── TypeDef expansion for structural record unification ────────────────────
//
// Spec §U-Expand (type-system-formal.md): given unify(x<τ>, R) where R is a
// structural record, look up the typedef for x, substitute the type arguments
// into its fields, and recursively unify the resulting structural record with
// R. The lookup table `tdefs` only contains *record* typedefs — sum typedefs
// have no structural counterpart and never reach this codepath (cf. U-Expand
// narrative). The recursive call swaps argument order (record on the left,
// expanded on the right), which is admissible by the symmetry convention
// stated at the start of §Unification.

let unify_typedef_record = fn (name: string, args: [TypeExpr], record: TypeExpr, tdefs: [TypeDefEntry]) -> UnifyResult do
  match tctypes.typedef_lookup(defs: tdefs, name) do
    | Some(val: RecordDef(name: _, is_public: _, type_params: tps, fields)) ->
      let param_subst = build_param_subst(params: tps, args)
      let expanded_fields = apply_subst_named_types(subst: param_subst, nts: fields)
      let expanded = TyRecord(fields: expanded_fields)
      return unify(t1: record, t2: expanded, tdefs)
    | None ->
      return UnifyErr(message: "unknown type definition: " ++ name)
  end
end

let build_param_subst = fn (params: [string], args: [TypeExpr]) -> [SubstEntry] do
  match params do
    | [] -> return []
    | p :: rp ->
      match args do
        | [] -> return []
        | a :: ra ->
          return SubstEntry(var: p, typ: a)
            :: build_param_subst(params: rp, args: ra)
      end
  end
end
