/**
 * typecheck/unify: Robinson unification for Nexus types.
 *
 * Handles all TypeExpr variants including numeric literal promotion,
 * cross-unification of List<T> with UserDefined("List", [T]),
 * and simplified row unification.
 *
 * Row unification implements the three spec rules (type-system-formal.md §Unification):
 *   U-Row-Closed-Closed: both closed, multisets must be equal.
 *   U-Row-Closed-Open  : closed left, open right — bind ?t2 to the residual row {r1 \ c}.
 *   U-Row-Open-Open    : both open — introduce a fresh ?γ, bind ?t1 := {r2 | ?γ},
 *                        bind ?t2 := {r1 | ?γ}.
 *
 * Fresh row-variable generation requires a supply counter. To avoid threading
 * CheckState through the entire unification API (which is consumed by 50+ call
 * sites), the public `unify` function carries an implicit supply counter of 0
 * and delegates to `unify_i`, an internal variant that threads `supply: i64`
 * through all recursive calls. The internal result type `UnifyResultS` wraps
 * the substitution together with the advanced supply so callers can propagate
 * freshness across sequential unification calls inside this module.
 *
 * External callers only see `UnifyResult` (no supply) — the supply is local
 * to each top-level `unify` invocation and does not escape.
 */

import {
  TypeExpr,
  TyI32,
  TyI64,
  TyF32,
  TyF64,
  TyIntLit,
  TyFloatLit,
  TyUserDefined,
  TyVar,
  TyArrow,
  TyRef,
  TyLinear,
  TyLazy,
  TyBorrow,
  TyArray,
  TyList,
  TyRecord,
  TyRow,
  TyHandler,
  NamedType
} from "src/types/type_expr.nx"
import {
  SubstEntry, UnifyResult, UnifyOk, UnifyErr, TypeDefEntry
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import { type_carries_linear } from "src/typecheck/infer/collections.nx"
import * as str from "std:str"

// UnifyResultS is module-internal only. It mirrors UnifyResult but also carries
// the advanced supply counter so sequential row unifications can share the
// fresh-name namespace without collisions.
type UnifyResultS =
  UnifyOkS(subst: [ SubstEntry ], supply: i64)
  | UnifyErrS(message: string)

let result_to_s = fn (r: UnifyResult, supply: i64) -> UnifyResultS do
  match r do
    | UnifyOk(subst: s) -> return UnifyOkS(subst: s, supply)
    | UnifyErr(message: m) -> return UnifyErrS(message: m)
  end
end

let result_from_s = fn (r: UnifyResultS) -> UnifyResult do
  match r do
    | UnifyOkS(subst: s, supply: _) -> return UnifyOk(subst: s)
    | UnifyErrS(message: m) -> return UnifyErr(message: m)
  end
end

/** First-order Robinson unification of `t1` and `t2` under typedef environment `tdefs`. Returns UnifyOk with the most-general substitution, or UnifyErr with a diagnostic message. Handles occurs check, type-var binding, numeric-literal promotion, row unification, and borrow asymmetry. */
export let unify = fn (t1: TypeExpr, t2: TypeExpr, tdefs: [ TypeDefEntry ]) -> UnifyResult do
  return result_from_s(r: unify_i(t1, t2, tdefs, supply: 0))
end

let unify_i = fn (
  t1: TypeExpr,
  t2: TypeExpr,
  tdefs: [ TypeDefEntry ],
  supply: i64
) -> UnifyResultS do
  if subst.type_eq(a: t1, b: t2) then
    return UnifyOkS(subst: subst.subst_empty(), supply)
  end

  // Type variable binding must come BEFORE numeric literal promotion.
  if let TyVar(name: n) = t1 then
    if subst.occurs_check(var: n, typ: t2) then
      return UnifyErrS(message: "recursive type: " ++ n)
    end
    return UnifyOkS(subst: subst.subst_single(var: n, typ: t2), supply)
  end
  if let TyVar(name: n) = t2 then
    if subst.occurs_check(var: n, typ: t1) then
      return UnifyErrS(message: "recursive type: " ++ n)
    end
    return UnifyOkS(subst: subst.subst_single(var: n, typ: t1), supply)
  end

  match t1 do
    | TyIntLit ->
      match t2 do
        | TyI32 | TyI64 | TyIntLit -> return UnifyOkS(subst: subst.subst_empty(), supply)
        | _ -> return UnifyErrS(message: "cannot unify int literal with non-integer type")
      end
    | TyFloatLit ->
      match t2 do
        | TyF32 | TyF64 | TyFloatLit -> return UnifyOkS(subst: subst.subst_empty(), supply)
        | _ -> return UnifyErrS(message: "cannot unify float literal with non-float type")
      end
    | _ -> ()
  end
  match t2 do
    | TyIntLit ->
      match t1 do
        | TyI32 | TyI64 -> return UnifyOkS(subst: subst.subst_empty(), supply)
        | _ -> return UnifyErrS(message: "cannot unify int literal with non-integer type")
      end
    | TyFloatLit ->
      match t1 do
        | TyF32 | TyF64 -> return UnifyOkS(subst: subst.subst_empty(), supply)
        | _ -> return UnifyErrS(message: "cannot unify float literal with non-float type")
      end
    | _ -> ()
  end

  if let TyArrow(params: p1, ret: r1, requires: req1, throw_row: thr1) = t1 then
    return if let TyArrow(params: p2, ret: r2, requires: req2, throw_row: thr2) = t2 then
      unify_arrow_i(p1, p2, r1, r2, req1, req2, thr1, thr2, tdefs, supply)
    else UnifyErrS(message: "expected arrow type") end
  end

  if let TyUserDefined(name: n1, args: a1) = t1 then
    match t2 do
      // Spec §U-Named (type-system-formal.md): same-name named types unify
      // by pointwise unification of their type arguments.
      | TyUserDefined(name: n2, args: a2) ->
        if n1 == n2 then
          return unify_type_lists_i(ts1: a1, ts2: a2, tdefs, supply)
        end
        return UnifyErrS(message: "type mismatch: " ++ n1 ++ " vs " ++ n2)
      // Spec §U-ListSugar: bridge the `List<T>` named-enum and the `[T]`
      // surface alias. Asymmetric case — left is the named form.
      | TyList(elem: inner) ->
        if n1 == "List" then
          match a1 do
            | [ arg ] ->
              return unify_i(t1: arg, t2: inner, tdefs, supply)
            | _ -> return UnifyErrS(message: "List type arity mismatch")
          end
        end
        return UnifyErrS(message: "cannot unify " ++ n1 ++ " with list")
      // Spec §U-Expand: named record-typedef vs structural record. Unfold
      // the typedef's fields (with type-args substituted) and unify with
      // the structural side. Asymmetric case — left is the named form.
      | TyRecord(_) ->
        return unify_typedef_record_i(name: n1, args: a1, record: t2, tdefs, supply)
      | _ -> return UnifyErrS(message: "type mismatch: user-defined vs other")
    end
  end

  if let TyList(elem: inner) = t1 then
    match t2 do
      | TyList(elem: inner2) -> return unify_i(t1: inner, t2: inner2, tdefs, supply)
      // Spec §U-ListSugar (symmetric counterpart of the TyUserDefined/TyList
      // arm above): bridge `[T]` (left) and `List<T>` (right).
      | TyUserDefined(name: n, args) ->
        if n == "List" then
          match args do
            | [ arg ] ->
              return unify_i(t1: inner, t2: arg, tdefs, supply)
            | _ -> return UnifyErrS(message: "List type arity mismatch")
          end
        end
        return UnifyErrS(message: "cannot unify list with " ++ n)
      | _ -> return UnifyErrS(message: "expected list type")
    end
  end

  if let TyArray(elem: e1) = t1 then
    return if let TyArray(elem: e2) = t2 then
      unify_i(t1: e1, t2: e2, tdefs, supply)
    else UnifyErrS(message: "expected array type") end
  end

  if let TyRecord(fields: f1) = t1 then
    match t2 do
      // Spec §U-Record: two structural records unify field-by-field.
      | TyRecord(fields: f2) -> return unify_named_types_i(nts1: f1, nts2: f2, tdefs, supply)
      // Spec §U-Expand (symmetric counterpart of the TyUserDefined/TyRecord
      // arm above): structural record (left) vs named record-typedef (right).
      | TyUserDefined(name: n, args) ->
        return unify_typedef_record_i(name: n, args, record: t1, tdefs, supply)
      | _ -> return UnifyErrS(message: "expected record type")
    end
  end

  if let TyRef(inner: i1) = t1 then
    return if let TyRef(inner: i2) = t2 then
      unify_i(t1: i1, t2: i2, tdefs, supply)
    else UnifyErrS(message: "expected ref type") end
  end
  if let TyLinear(inner: i1) = t1 then
    return if let TyLinear(inner: i2) = t2 then
      unify_i(t1: i1, t2: i2, tdefs, supply)
    else UnifyErrS(message: "expected linear type") end
  end
  if let TyLazy(inner: i1, require_row: rq1, throw_row: thr1) = t1 then
    return if let TyLazy(inner: i2, require_row: rq2, throw_row: thr2) = t2 then
      unify_lazy_i(i1, i2, rq1, rq2, thr1, thr2, tdefs, supply)
    else UnifyErrS(message: "expected lazy type") end
  end
  if let TyBorrow(inner: i1) = t1 then
    // U-Borrow: auto-deref the LEFT operand only.
    // Spec type-system-formal.md §U-Borrow declares this rule intentionally
    // asymmetric — there is no symmetric counterpart. A bare TyBorrow on the
    // right of a non-borrow LHS is a type mismatch and must fall through.
    if let TyBorrow(inner: i2) = t2 then
      return unify_i(t1: i1, t2: i2, tdefs, supply)
    end
    // Spec §U-Borrow premise: ¬linear(τ₂). A borrow &σ must not satisfy a
    // linear context τ₂ — that would let the callee consume the resource
    // while the caller still holds the borrow's source.
    if type_carries_linear(typ: t2, tdefs, depth: 8) then
      return UnifyErrS(message: "U-Borrow: cannot pass borrow where linear type is expected (borrow-to-ownership smuggling rejected)")
    end
    return unify_i(t1: i1, t2, tdefs, supply)
  end

  if let TyRow(types: ts1, rest: r1) = t1 then
    return if let TyRow(types: ts2, rest: r2) = t2 then
      unify_rows_i(ts1, r1, ts2, r2, tdefs, supply)
    else UnifyErrS(message: "expected row type") end
  end

  if let TyHandler(name: n1, requires: req1) = t1 then
    return if let TyHandler(name: n2, requires: req2) = t2 then
      if n1 == n2 then
        unify_i(t1: req1, t2: req2, tdefs, supply)
      else UnifyErrS(message: "handler mismatch: " ++ n1 ++ " vs " ++ n2) end
    else UnifyErrS(message: "expected handler type") end
  end

  return UnifyErrS(message: "type mismatch")
end

// Positional (name-ignoring) unification for function parameter lists.
// U-Arrow: parameter labels serve as argument routing at call sites (T-App);
// they are NOT part of the function type's structural identity for unification
// purposes — fn (x: i64) -> string and fn (y: i64) -> string are the same type.
// Contrast with U-Record where field names ARE part of the record type's identity.
let unify_arrow_params_i = fn (
  nts1: [ NamedType ],
  nts2: [ NamedType ],
  tdefs: [ TypeDefEntry ],
  supply: i64
) -> UnifyResultS do
  match nts1 do
    | [] ->
      match nts2 do
        | [] -> return UnifyOkS(subst: subst.subst_empty(), supply)
        | _ -> return UnifyErrS(message: "arity mismatch")
      end
    | NamedType(name: n1, typ: t1) :: r1 ->
      match nts2 do
        | [] -> return UnifyErrS(message: "arity mismatch")
        | NamedType(name: _, typ: t2) :: r2 ->
          match unify_i(t1, t2, tdefs, supply) do
            | UnifyErrS(message: m) -> return UnifyErrS(message: "param " ++ n1 ++ ": " ++ m)
            | UnifyOkS(subst: s1, supply: sup1) ->
              let r1a = apply_subst_named_types(subst: s1, nts: r1)
              let r2a = apply_subst_named_types(subst: s1, nts: r2)
              match unify_arrow_params_i(nts1: r1a, nts2: r2a, tdefs, supply: sup1) do
                | UnifyErrS(message: m) -> return UnifyErrS(message: m)
                | UnifyOkS(subst: s2, supply: sup2) ->
                  return UnifyOkS(subst: subst.subst_compose(s1, s2), supply: sup2)
              end
          end
      end
  end
end

let unify_arrow_i = fn (
  p1: [ NamedType ], p2: [ NamedType ],
  r1: TypeExpr, r2: TypeExpr,
  req1: TypeExpr, req2: TypeExpr,
  thr1: TypeExpr, thr2: TypeExpr,
  tdefs: [ TypeDefEntry ],
  supply: i64
) -> UnifyResultS do
  match unify_arrow_params_i(nts1: p1, nts2: p2, tdefs, supply) do
    | UnifyErrS(message: m) -> return UnifyErrS(message: m)
    | UnifyOkS(subst: s1, supply: sup1) ->
      match unify_i(
        t1: subst.subst_apply(subst: s1, typ: r1),
        t2: subst.subst_apply(subst: s1, typ: r2),
        tdefs,
        supply: sup1
      ) do
        | UnifyErrS(message: m) -> return UnifyErrS(message: m)
        | UnifyOkS(subst: s2, supply: sup2) ->
          let s12 = subst.subst_compose(s1, s2)
          match unify_with_kind_i(
            t1: subst.subst_apply(subst: s12, typ: req1),
            t2: subst.subst_apply(subst: s12, typ: req2),
            tdefs,
            kind: "requires",
            supply: sup2
          ) do
            | UnifyErrS(message: m) -> return UnifyErrS(message: m)
            | UnifyOkS(subst: s3, supply: sup3) ->
              let s123 = subst.subst_compose(s1: s12, s2: s3)
              match unify_with_kind_i(
                t1: subst.subst_apply(subst: s123, typ: thr1),
                t2: subst.subst_apply(subst: s123, typ: thr2),
                tdefs,
                kind: "throws",
                supply: sup3
              ) do
                | UnifyErrS(message: m) -> return UnifyErrS(message: m)
                | UnifyOkS(subst: s4, supply: sup4) ->
                  return UnifyOkS(subst: subst.subst_compose(s1: s123, s2: s4), supply: sup4)
              end
          end
      end
  end
end

// Unify two `TyLazy` types: first unify the result type, then the require
// row, then the throws row (mirroring `unify_arrow_i`).
let unify_lazy_i = fn (
  i1: TypeExpr, i2: TypeExpr,
  rq1: TypeExpr, rq2: TypeExpr,
  thr1: TypeExpr, thr2: TypeExpr,
  tdefs: [ TypeDefEntry ],
  supply: i64
) -> UnifyResultS do
  match unify_i(t1: i1, t2: i2, tdefs, supply) do
    | UnifyErrS(message: m) -> return UnifyErrS(message: m)
    | UnifyOkS(subst: s1, supply: sup1) ->
      match unify_with_kind_i(
        t1: subst.subst_apply(subst: s1, typ: rq1),
        t2: subst.subst_apply(subst: s1, typ: rq2),
        tdefs,
        kind: "requires",
        supply: sup1
      ) do
        | UnifyErrS(message: m) -> return UnifyErrS(message: m)
        | UnifyOkS(subst: s2, supply: sup2) ->
          let s12 = subst.subst_compose(s1, s2)
          match unify_with_kind_i(
            t1: subst.subst_apply(subst: s12, typ: thr1),
            t2: subst.subst_apply(subst: s12, typ: thr2),
            tdefs,
            kind: "throws",
            supply: sup2
          ) do
            | UnifyErrS(message: m) -> return UnifyErrS(message: m)
            | UnifyOkS(subst: s3, supply: sup3) ->
              return UnifyOkS(subst: subst.subst_compose(s1: s12, s2: s3), supply: sup3)
          end
      end
  end
end

// Unify when the caller knows which row kind (throws/requires) is on the
// surface; dispatches to the row-aware unifier when both sides are
// TyRow, otherwise to plain unify. Every arm has an explicit `return`
// so that the asymmetric (TyRow, TyVar) case (which arises during
// arrow-throw unification with a row-polymorphic callee) is total.
let unify_with_kind_i = fn (
  t1: TypeExpr,
  t2: TypeExpr,
  tdefs: [ TypeDefEntry ],
  kind: string,
  supply: i64
) -> UnifyResultS do
  match t1 do
    | TyRow(types: ts1, rest: r1) ->
      match t2 do
        | TyRow(types: ts2, rest: r2) ->
          return unify_rows_kind_i(ts1, r1, ts2, r2, tdefs, kind, supply)
        | _ -> return unify_i(t1, t2, tdefs, supply)
      end
    | _ -> return unify_i(t1, t2, tdefs, supply)
  end
end

// Return type for find_named_type_i: the matched type plus the remaining list
// (with the matched entry removed), so callers can recurse on the residual.
type UnifyNamedPair = UnifyNamedPair(typ: TypeExpr, rest: [ NamedType ])

// Find the NamedType entry with the given name in `nts`, returning the
// associated type and the list with that entry removed.
let find_named_type_i = fn (nts: [ NamedType ], name: string) -> Option<UnifyNamedPair> do
  match nts do
    | [] -> return None
    | NamedType(name: n, typ: t) :: rest ->
      if n == name then
        return Some(val: UnifyNamedPair(typ: t, rest))
      end
      match find_named_type_i(nts: rest, name) do
        | None -> return None
        | Some(val: UnifyNamedPair(typ: t2, rest: r2)) ->
          return Some(val: UnifyNamedPair(typ: t2, rest: NamedType(name: n, typ: t) :: r2))
      end
  end
end

let unify_named_types_i = fn (
  nts1: [ NamedType ],
  nts2: [ NamedType ],
  tdefs: [ TypeDefEntry ],
  supply: i64
) -> UnifyResultS do
  match nts1 do
    | [] ->
      match nts2 do
        | [] -> return UnifyOkS(subst: subst.subst_empty(), supply)
        | _ -> return UnifyErrS(message: "arity mismatch")
      end
    | NamedType(name: n1, typ: t1) :: r1 ->
      // Spec §U-Record / §U-Arrow: labels must match by name (∀i. ℓᵢ¹ = ℓᵢ²).
      // Records may appear with fields in a different order than the parameter
      // declaration (e.g. { y: 2, x: 1 } vs { x: i64, y: i64 }).
      // Look up n1 in nts2 by name; if absent, it is a label mismatch.
      match find_named_type_i(nts: nts2, name: n1) do
        | None -> return UnifyErrS(message: "label mismatch: field " ++ n1 ++ " not found in counterpart")
        | Some(val: UnifyNamedPair(typ: t2, rest: r2)) ->
          match unify_i(t1, t2, tdefs, supply) do
            | UnifyErrS(message: m) -> return UnifyErrS(message: "field " ++ n1 ++ ": " ++ m)
            | UnifyOkS(subst: s1, supply: sup1) ->
              let r1a = apply_subst_named_types(subst: s1, nts: r1)
              let r2a = apply_subst_named_types(subst: s1, nts: r2)
              match unify_named_types_i(nts1: r1a, nts2: r2a, tdefs, supply: sup1) do
                | UnifyErrS(message: m) -> return UnifyErrS(message: m)
                | UnifyOkS(subst: s2, supply: sup2) ->
                  return UnifyOkS(subst: subst.subst_compose(s1, s2), supply: sup2)
              end
          end
      end
  end
end

let apply_subst_named_types = fn (subst: [ SubstEntry ], nts: [ NamedType ]) -> [ NamedType ] do
  match nts do
    | [] -> return []
    | NamedType(name: n, typ: t) :: rest ->
      return NamedType(name: n, typ: subst.subst_apply(subst, typ: t))
        :: apply_subst_named_types(subst, nts: rest)
  end
end

let unify_type_lists_i = fn (
  ts1: [ TypeExpr ],
  ts2: [ TypeExpr ],
  tdefs: [ TypeDefEntry ],
  supply: i64
) -> UnifyResultS do
  match ts1 do
    | [] ->
      match ts2 do
        | [] -> return UnifyOkS(subst: subst.subst_empty(), supply)
        | _ -> return UnifyErrS(message: "type argument arity mismatch")
      end
    | h1 :: r1 ->
      match ts2 do
        | [] -> return UnifyErrS(message: "type argument arity mismatch")
        | h2 :: r2 ->
          match unify_i(t1: h1, t2: h2, tdefs, supply) do
            | UnifyErrS(message: m) -> return UnifyErrS(message: m)
            | UnifyOkS(subst: s1, supply: sup1) ->
              let r1a = apply_subst_type_list(subst: s1, types: r1)
              let r2a = apply_subst_type_list(subst: s1, types: r2)
              match unify_type_lists_i(ts1: r1a, ts2: r2a, tdefs, supply: sup1) do
                | UnifyErrS(message: m) -> return UnifyErrS(message: m)
                | UnifyOkS(subst: s2, supply: sup2) ->
                  return UnifyOkS(subst: subst.subst_compose(s1, s2), supply: sup2)
              end
          end
      end
  end
end

let apply_subst_type_list = fn (subst: [ SubstEntry ], types: [ TypeExpr ]) -> [ TypeExpr ] do
  match types do
    | [] -> return []
    | t :: rest ->
      return subst.subst_apply(subst, typ: t)
        :: apply_subst_type_list(subst, types: rest)
  end
end

// Row unification: compute surplus-label vectors (e1r/e2r) and surface
// them in diagnostics so users see which labels broke unification.

// Internal helpers: Nexus has no tuple syntax, so the two-value returns
// from the surplus-split walk go through these one-shot ADTs.
type RowRemove = RowRemove(found: bool, rest: [ TypeExpr ])
type RowSplit = RowSplit(only_left: [ TypeExpr ], only_right: [ TypeExpr ])

// Drop the first occurrence of `target` from `xs` using structural type equality.
let row_remove_label = fn (xs: [ TypeExpr ], target: TypeExpr) -> RowRemove do
  match xs do
    | [] -> return RowRemove(found: false, rest: [])
    | h :: rest ->
      if subst.type_eq(a: h, b: target) then
        return RowRemove(found: true, rest)
      end
      let RowRemove(found, rest: tail) = row_remove_label(xs: rest, target)
      return RowRemove(found, rest: h :: tail)
  end
end

let row_split_surplus = fn (e1: [ TypeExpr ], e2: [ TypeExpr ]) -> RowSplit do
  match e1 do
    | [] -> return RowSplit(only_left: [], only_right: e2)
    | h :: rest ->
      let RowRemove(found: matched, rest: e2_after) = row_remove_label(xs: e2, target: h)
      let RowSplit(only_left: e1r, only_right: e2r) = row_split_surplus(e1: rest, e2: e2_after)
      if matched then
        return RowSplit(only_left: e1r, only_right: e2r)
      end
      return RowSplit(only_left: h :: e1r, only_right: e2r)
  end
end

let format_row_labels = fn (labels: [ TypeExpr ]) -> string do
  match labels do
    | [] -> return "{ }"
    | _ -> return "{ " ++ join_label_names(labels) ++ " }"
  end
end

let join_label_names = fn (labels: [ TypeExpr ]) -> string do
  match labels do
    | [] -> return ""
    | [ t ] -> return tctypes.type_to_string(typ: t)
    | t :: rest -> return tctypes.type_to_string(typ: t) ++ ", " ++ join_label_names(labels: rest)
  end
end

let row_kind_prefix = fn (kind: string) -> string do
  if kind == "throws" then return "throws row mismatch" end
  if kind == "requires" then return "requires row mismatch" end
  if kind == "record" then return "record row mismatch" end
  if kind == "cap" then return "cap row mismatch" end
  return "row mismatch"
end

// True when `ts` contains the Exn sentinel `TyUserDefined("Exn", _)` as a row entry.
let row_contains_exn = fn (ts: [ TypeExpr ]) -> bool do
  match ts do
    | [] -> return false
    | h :: rest ->
      match h do
        | TyUserDefined(name: n, args: _) ->
          if n == "Exn" then return true end
          return row_contains_exn(ts: rest)
        | _ -> return row_contains_exn(ts: rest)
      end
  end
end

// U-Row-Exn premise check (spec docs/spec/type-system-formal.md §Unification,
// U-Row-Exn). Given the partner row `other` (every C ∈ other must be
// absorbed by the Exn-bearing side), each entry must be:
//   - the Exn sentinel itself (C = Exn), or
//   - a constructor of Exn (C ∈ variants(Exn)).
// In Nexus, variants(Exn) is realised as "any TyUserDefined name" because
// Exn is the catch-all exception sentinel (see typecheck/check.nx where
// Exn is registered as an open EnumDef and infer.nx::row_admits_exception
// which treats it as universal). Non-TyUserDefined row entries (TyVar,
// TyArrow, etc.) are NOT absorbed — they signal a row shape mismatch.
//
// Note: the common-prefix branch `C ∈ c` from the spec is subsumed here,
// because c ⊆ τ_2 and every c-entry is itself a TyUserDefined (else it
// couldn't be a row label).
let row_all_absorbable_by_exn = fn (other: [ TypeExpr ]) -> bool do
  match other do
    | [] -> return true
    | h :: rest ->
      match h do
        | TyUserDefined(name: _, args: _) -> return row_all_absorbable_by_exn(other: rest)
        | _ -> return false
      end
  end
end

let unify_rows_i = fn (
  ts1: [ TypeExpr ], r1: Option<TypeExpr>,
  ts2: [ TypeExpr ], r2: Option<TypeExpr>,
  tdefs: [ TypeDefEntry ],
  supply: i64
) -> UnifyResultS do
  return unify_rows_kind_i(ts1, r1, ts2, r2, tdefs, kind: "", supply)
end

// unify_rows_kind_i: implements the three spec row unification rules:
//
//   U-Row-Closed-Closed  (r1=None, r2=None):
//     Multisets must be equal — no residuals on either side.
//
//   U-Row-Closed-Open    (r1=None, r2=Some(?t2)):
//     Spec premise: r2 (= ts2 \ common) must be empty (the closed left side
//     cannot absorb entries the right has but the left lacks).
//     Then bind: ?t2 := { r1 | (closed) } where r1 = ts1 \ common.
//     Implementation: unify ?t2 against TyRow(types: e1r, rest: None).
//
//   U-Row-Open-Open      (r1=Some(?t1), r2=Some(?t2)):
//     Introduce a fresh row variable ?γ (named "?row_γ_N" for supply N).
//     Then bind:
//       ?t1 := { e2r | ?γ }   (right-only residuals, shared tail)
//       ?t2 := { e1r | ?γ }   (left-only residuals, shared tail)
//     The open-closed case (r1=Some, r2=None) follows by symmetry: swap
//     arguments so the closed side is always on the left.
//
let unify_rows_kind_i = fn (
  ts1: [ TypeExpr ], r1: Option<TypeExpr>,
  ts2: [ TypeExpr ], r2: Option<TypeExpr>,
  tdefs: [ TypeDefEntry ],
  kind: string,
  supply: i64
) -> UnifyResultS do
  let prefix = row_kind_prefix(kind)

  // U-Row-Exn (spec docs/spec/type-system-formal.md §Unification, lines
  // 496-508).
  //
  //   Exn ∈ τ_2      c = τ_2 \ {Exn}
  //   ∀ C ∈ τ_1.  C = Exn  ∨  C ∈ c  ∨  C ∈ variants(Exn)
  //   ────────────────────────────────────────────────────
  //               unify({τ_1}, {τ_2})
  //
  // When one row carries the catch-all Exn sentinel, any constructors of
  // Exn on the partner side are absorbed by it — the only row-inclusion
  // relationship the type system admits. Per spec §Unification (U-Row-Exn)
  // this rule is restricted to closed-closed row shapes; the symmetry convention covers
  // both argument orders, so we test (r1=None, r2=None) and either side
  // bearing Exn. Open/closed mixes fall through to U-Row-Closed-Open and
  // can re-enter U-Row-Exn after the tail variable is instantiated.
  //
  // Only meaningful for the `throws` row — Exn is the exception sentinel
  // and is not a valid label in `requires`/`record`/`cap` rows.
  if kind == "throws" then
    match r1 do
      | Some(val: _) -> ()
      | None ->
        match r2 do
          | Some(val: _) -> ()
          | None ->
            // U-Row-Exn is DIRECTIONAL (spec §Unification, U-Row-Exn): the Exn
            // sentinel is admissible only in the EXPECTED position (ts2, the
            // right argument), per the left=actual / right=expected orientation
            // at throws-subsumption sites (T-Lambda body-vs-declared, T-App
            // arg-vs-param). A specific actual row {NotFound} ⊑ expected {Exn}
            // is sound; the reverse — actual {Exn} (may throw anything) against a
            // narrower declared {NotFound} — must FAIL, else an exception outside
            // the declared row escapes uncaught (P5 hole). So we
            // absorb only when ts2 carries Exn; when only ts1 (actual) does, fall
            // through to U-Row-Closed-Closed, whose multiset check rejects
            // {Exn} vs {narrow} correctly.
            if row_contains_exn(ts: ts2) then
              if row_all_absorbable_by_exn(other: ts1) then
                return UnifyOkS(subst: subst.subst_empty(), supply)
              end
              return UnifyErrS(message: prefix ++ ": row entries "
                ++ format_row_labels(labels: ts1)
                ++ " not all absorbable by Exn sentinel")
            end
        end
    end
  end

  let RowSplit(only_left: e1r, only_right: e2r) = row_split_surplus(e1: ts1, e2: ts2)

  match r1 do
    | Some(val: tail1) ->
      match r2 do
        | Some(val: tail2) ->
          // U-Row-Open-Open (spec §Unification):
          //   c = ts1 ∩ ts2,  r1 = ts1 \ c,  r2 = ts2 \ c
          //   ?γ fresh
          //   unify(?t1, { r2 | ?γ }),  unify(?t2, { r1 | ?γ })
          //
          // Allocate fresh ?γ from the supply counter.
          let gamma_name = "?row_gamma_" ++ str.from_i64(val: supply)
          let supply1 = supply + 1
          let gamma = TyVar(name: gamma_name)
          // Build the two residual rows.
          let row_for_t1 = TyRow(types: e2r, rest: Some(val: gamma))
          let row_for_t2 = TyRow(types: e1r, rest: Some(val: gamma))
          // Bind ?t1 := row_for_t1 (i.e. unify tail1 with row_for_t1).
          match unify_i(t1: tail1, t2: row_for_t1, tdefs, supply: supply1) do
            | UnifyErrS(message: m) -> return UnifyErrS(message: prefix ++ " (open tail1): " ++ m)
            | UnifyOkS(subst: s1, supply: sup1) ->
              // Apply s1 to tail2 and row_for_t2 before the second bind.
              let tail2_applied = subst.subst_apply(subst: s1, typ: tail2)
              let row_for_t2_applied = subst.subst_apply(subst: s1, typ: row_for_t2)
              // Bind ?t2 := row_for_t2.
              match unify_i(t1: tail2_applied, t2: row_for_t2_applied, tdefs, supply: sup1) do
                | UnifyErrS(message: m) -> return UnifyErrS(message: prefix ++ " (open tail2): " ++ m)
                | UnifyOkS(subst: s2, supply: sup2) ->
                  return UnifyOkS(subst: subst.subst_compose(s1, s2), supply: sup2)
              end
          end
        | None ->
          // r1=Some, r2=None: open-closed case. By the symmetry convention
          // (spec §Unification, "the open-closed case follows by the symmetry
          // convention"), we swap and re-enter as U-Row-Closed-Open.
          return unify_rows_kind_i(ts1: ts2, r1: None, ts2: ts1, r2: r1, tdefs, kind, supply)
      end
    | None ->
      match r2 do
        | Some(val: tail2) ->
          // U-Row-Closed-Open (spec §Unification):
          //   c = ts1 ∩ ts2,  r1 = ts1 \ c,  r2 = ts2 \ c
          //   r2 = ∅   (closed left cannot have entries the right lacks)
          //   unify(?t2, { r1 })   (bind the tail to the closed residual)
          match e2r do
            | _ :: _ ->
              return UnifyErrS(message: prefix ++ ": callee row has extra label(s) "
                ++ format_row_labels(labels: e2r) ++ " not admitted by caller")
            | [] ->
              // Bind ?t2 to the closed residual row { e1r }.
              // unify(tail2, TyRow(types: e1r, rest: None))
              let residual_row = TyRow(types: e1r, rest: None)
              match unify_i(t1: tail2, t2: residual_row, tdefs, supply) do
                | UnifyErrS(message: m) -> return UnifyErrS(message: prefix ++ " (closed tail): " ++ m)
                | UnifyOkS(subst: s, supply: sup) -> return UnifyOkS(subst: s, supply: sup)
              end
          end
        | None ->
          // U-Row-Closed-Closed: both tails are None (closed rows).
          // Multisets must be equal — no residuals on either side.
          match e1r do
            | _ :: _ ->
              return UnifyErrS(message: prefix ++ ": caller row has extra label(s) "
                ++ format_row_labels(labels: e1r) ++ " not admitted by callee")
            | [] ->
              match e2r do
                | _ :: _ ->
                  return UnifyErrS(message: prefix ++ ": callee row has extra label(s) "
                    ++ format_row_labels(labels: e2r) ++ " not admitted by caller")
                | [] ->
                  return UnifyOkS(subst: subst.subst_empty(), supply)
              end
          end
      end
  end
end

// These wrappers exist so internal call sites within this module can use
// the _i variants directly (with supply threading) while external callers
// (infer.nx, check.nx, etc.) continue to use the original names.
// Only `unify` is exported; all other names are module-private.

// TypeDef expansion for structural record unification (§U-Expand): given
// unify(x<τ>, R) where R is a
// structural record, look up the typedef for x, substitute the type arguments
// into its fields, and recursively unify the resulting structural record with
// R. The lookup table `tdefs` only contains *record* typedefs — sum typedefs
// have no structural counterpart and never reach this codepath (cf. U-Expand
// narrative). The recursive call swaps argument order (record on the left,
// expanded on the right), which is admissible by the symmetry convention
// stated at the start of §Unification.

let unify_typedef_record_i = fn (
  name: string,
  args: [ TypeExpr ],
  record: TypeExpr,
  tdefs: [ TypeDefEntry ],
  supply: i64
) -> UnifyResultS do
  match tctypes.typedef_lookup(defs: tdefs, name) do
    | Some(val: RecordDef(name: _, is_public: _, type_params: tps, fields)) ->
      let param_subst = build_param_subst(params: tps, args)
      let expanded_fields = apply_subst_named_types(subst: param_subst, nts: fields)
      let expanded = TyRecord(fields: expanded_fields)
      return unify_i(t1: record, t2: expanded, tdefs, supply)
    | None ->
      return UnifyErrS(message: "unknown type definition: " ++ name)
  end
end

export let build_param_subst = fn (params: [ string ], args: [ TypeExpr ]) -> [ SubstEntry ] do
  match params do
    | [] -> return []
    | p :: rp ->
      match args do
        | [] -> return []
        | a :: ra ->
          return SubstEntry(var: p, typ: a)
            :: build_param_subst(params: rp, args: ra)
      end
  end
end
