/**
 * typecheck/unify: Robinson unification for Nexus types.
 *
 * Handles all TypeExpr variants including numeric literal promotion,
 * cross-unification of List<T> with UserDefined("List", [T]),
 * and simplified row unification.
 */

import {
  TypeExpr, TyI32, TyI64, TyF32, TyF64, TyBool, TyChar, TyString, TyUnit,
  TyIntLit, TyFloatLit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyLazy, TyBorrow,
  TyArray, TyList, TyRecord, TyRow, TyHandler, NamedType
} from "src/common/ast.nx"
import {
  SubstEntry, UnifyResult, UnifyOk, UnifyErr, CheckState, TypeDefEntry
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"

// ─── Main unification ───────────────────────────────────────────────────────

export let unify = fn (t1: TypeExpr, t2: TypeExpr, tdefs: [TypeDefEntry]) -> UnifyResult do
  // Identical types
  if subst.type_eq(a: t1, b: t2) then
    return UnifyOk(subst: subst.subst_empty())
  end

  // Type variable binding (must come BEFORE numeric literal promotion)
  if let TyVar(name: n) = t1 then
    if subst.occurs_check(var: n, typ: t2) then
      return UnifyErr(message: "recursive type: " ++ n)
    end
    return UnifyOk(subst: subst.subst_single(var: n, typ: t2))
  end
  if let TyVar(name: n) = t2 then
    if subst.occurs_check(var: n, typ: t1) then
      return UnifyErr(message: "recursive type: " ++ n)
    end
    return UnifyOk(subst: subst.subst_single(var: n, typ: t1))
  end

  // Numeric literal promotion (TyVar already handled above)
  match t1 do
    | TyIntLit ->
      match t2 do
        | TyI32 -> return UnifyOk(subst: subst.subst_empty())
        | TyI64 -> return UnifyOk(subst: subst.subst_empty())
        | TyIntLit -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "cannot unify int literal with non-integer type")
      end
    | TyFloatLit ->
      match t2 do
        | TyF32 -> return UnifyOk(subst: subst.subst_empty())
        | TyF64 -> return UnifyOk(subst: subst.subst_empty())
        | TyFloatLit -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "cannot unify float literal with non-float type")
      end
    | _ -> ()
  end
  match t2 do
    | TyIntLit ->
      match t1 do
        | TyI32 -> return UnifyOk(subst: subst.subst_empty())
        | TyI64 -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "cannot unify int literal with non-integer type")
      end
    | TyFloatLit ->
      match t1 do
        | TyF32 -> return UnifyOk(subst: subst.subst_empty())
        | TyF64 -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "cannot unify float literal with non-float type")
      end
    | _ -> ()
  end

  // Arrow types
  if let TyArrow(params: p1, ret: r1, requires: req1, throw_row: thr1) = t1 then
    return if let TyArrow(params: p2, ret: r2, requires: req2, throw_row: thr2) = t2 then
      unify_arrow(p1, p2, r1, r2, req1, req2, thr1, thr2, tdefs)
    else UnifyErr(message: "expected arrow type") end
  end

  // UserDefined types
  if let TyUserDefined(name: n1, args: a1) = t1 then
    match t2 do
      | TyUserDefined(name: n2, args: a2) ->
        if n1 == n2 then
          return unify_type_lists(ts1: a1, ts2: a2, tdefs)
        end
        return UnifyErr(message: "type mismatch: " ++ n1 ++ " vs " ++ n2)
      // Cross-unify UserDefined("List", [T]) with TyList(T)
      | TyList(elem: inner) ->
        if n1 == "List" then
          match a1 do
            | [arg] ->
              return unify(t1: arg, t2: inner, tdefs)
            | _ -> return UnifyErr(message: "List type arity mismatch")
          end
        end
        return UnifyErr(message: "cannot unify " ++ n1 ++ " with list")
      // Cross-unify UserDefined with Record (expand typedef)
      | TyRecord(_) ->
        return unify_typedef_record(name: n1, args: a1, record: t2, tdefs)
      | _ -> return UnifyErr(message: "type mismatch: user-defined vs other")
    end
  end

  // List cross-unify
  if let TyList(elem: inner) = t1 then
    match t2 do
      | TyList(elem: inner2) -> return unify(t1: inner, t2: inner2, tdefs)
      | TyUserDefined(name: n, args) ->
        if n == "List" then
          match args do
            | [arg] ->
              return unify(t1: inner, t2: arg, tdefs)
            | _ -> return UnifyErr(message: "List type arity mismatch")
          end
        end
        return UnifyErr(message: "cannot unify list with " ++ n)
      | _ -> return UnifyErr(message: "expected list type")
    end
  end

  // Array
  if let TyArray(elem: e1) = t1 then
    return if let TyArray(elem: e2) = t2 then
      unify(t1: e1, t2: e2, tdefs)
    else UnifyErr(message: "expected array type") end
  end

  // Record
  if let TyRecord(fields: f1) = t1 then
    match t2 do
      | TyRecord(fields: f2) -> return unify_named_types(nts1: f1, nts2: f2, tdefs)
      | TyUserDefined(name: n, args) ->
        return unify_typedef_record(name: n, args, record: t1, tdefs)
      | _ -> return UnifyErr(message: "expected record type")
    end
  end

  // Ref / Linear / Borrow
  if let TyRef(inner: i1) = t1 then
    return if let TyRef(inner: i2) = t2 then
      unify(t1: i1, t2: i2, tdefs)
    else UnifyErr(message: "expected ref type") end
  end
  if let TyLinear(inner: i1) = t1 then
    return if let TyLinear(inner: i2) = t2 then
      unify(t1: i1, t2: i2, tdefs)
    else UnifyErr(message: "expected linear type") end
  end
  if let TyLazy(inner: i1) = t1 then
    return if let TyLazy(inner: i2) = t2 then
      unify(t1: i1, t2: i2, tdefs)
    else UnifyErr(message: "expected lazy type") end
  end
  if let TyBorrow(inner: i1) = t1 then
    // U-Borrow: auto-deref the LEFT operand only.
    // Spec type-system-formal.md §U-Borrow declares this rule intentionally
    // asymmetric — there is no symmetric counterpart. A bare TyBorrow on the
    // right of a non-borrow LHS is a type mismatch and must fall through.
    return if let TyBorrow(inner: i2) = t2 then
      unify(t1: i1, t2: i2, tdefs)
    else unify(t1: i1, t2, tdefs) end
  end

  // Row types (simplified)
  if let TyRow(types: ts1, rest: r1) = t1 then
    return if let TyRow(types: ts2, rest: r2) = t2 then
      unify_rows(ts1, r1, ts2, r2, tdefs)
    else UnifyErr(message: "expected row type") end
  end

  // Handler
  if let TyHandler(name: n1, requires: req1) = t1 then
    return if let TyHandler(name: n2, requires: req2) = t2 then
      if n1 == n2 then
        unify(t1: req1, t2: req2, tdefs)
      else UnifyErr(message: "handler mismatch: " ++ n1 ++ " vs " ++ n2) end
    else UnifyErr(message: "expected handler type") end
  end

  return UnifyErr(message: "type mismatch")
end

// ─── Arrow unification ──────────────────────────────────────────────────────

let unify_arrow = fn (
  p1: [NamedType], p2: [NamedType],
  r1: TypeExpr, r2: TypeExpr,
  req1: TypeExpr, req2: TypeExpr,
  thr1: TypeExpr, thr2: TypeExpr,
  tdefs: [TypeDefEntry]
) -> UnifyResult do
  match unify_named_types(nts1: p1, nts2: p2, tdefs) do
    | UnifyErr(message: m) -> return UnifyErr(message: m)
    | UnifyOk(subst: s1) ->
      match unify(t1: subst.subst_apply(subst: s1, typ: r1), t2: subst.subst_apply(subst: s1, typ: r2), tdefs) do
        | UnifyErr(message: m) -> return UnifyErr(message: m)
        | UnifyOk(subst: s2) ->
          let s12 = subst.subst_compose(s1, s2)
          match unify(t1: subst.subst_apply(subst: s12, typ: req1), t2: subst.subst_apply(subst: s12, typ: req2), tdefs) do
            | UnifyErr(message: m) -> return UnifyErr(message: m)
            | UnifyOk(subst: s3) ->
              let s123 = subst.subst_compose(s1: s12, s2: s3)
              match unify(t1: subst.subst_apply(subst: s123, typ: thr1), t2: subst.subst_apply(subst: s123, typ: thr2), tdefs) do
                | UnifyErr(message: m) -> return UnifyErr(message: m)
                | UnifyOk(subst: s4) ->
                  return UnifyOk(subst: subst.subst_compose(s1: s123, s2: s4))
              end
          end
      end
  end
end

// ─── Named type list unification (params, record fields) ────────────────────

let unify_named_types = fn (nts1: [NamedType], nts2: [NamedType], tdefs: [TypeDefEntry]) -> UnifyResult do
  match nts1 do
    | [] ->
      match nts2 do
        | [] -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "arity mismatch")
      end
    | NamedType(name: n1, typ: t1) :: r1 ->
      match nts2 do
        | [] -> return UnifyErr(message: "arity mismatch")
        | NamedType(name: n2, typ: t2) :: r2 ->
          match unify(t1, t2, tdefs) do
            | UnifyErr(message: m) -> return UnifyErr(message: "field " ++ n1 ++ ": " ++ m)
            | UnifyOk(subst: s1) ->
              let r1a = apply_subst_named_types(subst: s1, nts: r1)
              let r2a = apply_subst_named_types(subst: s1, nts: r2)
              match unify_named_types(nts1: r1a, nts2: r2a, tdefs) do
                | UnifyErr(message: m) -> return UnifyErr(message: m)
                | UnifyOk(subst: s2) ->
                  return UnifyOk(subst: subst.subst_compose(s1, s2))
              end
          end
      end
  end
end

let apply_subst_named_types = fn (subst: [SubstEntry], nts: [NamedType]) -> [NamedType] do
  match nts do
    | [] -> return []
    | NamedType(name: n, typ: t) :: rest ->
      return NamedType(name: n, typ: subst.subst_apply(subst, typ: t))
        :: apply_subst_named_types(subst, nts: rest)
  end
end

// ─── Type list unification ──────────────────────────────────────────────────

let unify_type_lists = fn (ts1: [TypeExpr], ts2: [TypeExpr], tdefs: [TypeDefEntry]) -> UnifyResult do
  match ts1 do
    | [] ->
      match ts2 do
        | [] -> return UnifyOk(subst: subst.subst_empty())
        | _ -> return UnifyErr(message: "type argument arity mismatch")
      end
    | h1 :: r1 ->
      match ts2 do
        | [] -> return UnifyErr(message: "type argument arity mismatch")
        | h2 :: r2 ->
          match unify(t1: h1, t2: h2, tdefs) do
            | UnifyErr(message: m) -> return UnifyErr(message: m)
            | UnifyOk(subst: s1) ->
              let r1a = apply_subst_type_list(subst: s1, types: r1)
              let r2a = apply_subst_type_list(subst: s1, types: r2)
              match unify_type_lists(ts1: r1a, ts2: r2a, tdefs) do
                | UnifyErr(message: m) -> return UnifyErr(message: m)
                | UnifyOk(subst: s2) ->
                  return UnifyOk(subst: subst.subst_compose(s1, s2))
              end
          end
      end
  end
end

let apply_subst_type_list = fn (subst: [SubstEntry], types: [TypeExpr]) -> [TypeExpr] do
  match types do
    | [] -> return []
    | t :: rest ->
      return subst.subst_apply(subst, typ: t)
        :: apply_subst_type_list(subst, types: rest)
  end
end

// ─── Row unification (simplified) ───────────────────────────────────────────

let unify_rows = fn (
  ts1: [TypeExpr], r1: Option<TypeExpr>,
  ts2: [TypeExpr], r2: Option<TypeExpr>,
  tdefs: [TypeDefEntry]
) -> UnifyResult do
  // Simplified: just unify the heads pairwise, then tails
  match unify_type_lists(ts1, ts2, tdefs) do
    | UnifyErr(message: m) -> return UnifyErr(message: "row: " ++ m)
    | UnifyOk(subst: s1) ->
      match r1 do
        | Some(val: tail1) ->
          match r2 do
            | Some(val: tail2) ->
              match unify(t1: subst.subst_apply(subst: s1, typ: tail1), t2: subst.subst_apply(subst: s1, typ: tail2), tdefs) do
                | UnifyErr(message: m) -> return UnifyErr(message: "row tail: " ++ m)
                | UnifyOk(subst: s2) -> return UnifyOk(subst: subst.subst_compose(s1, s2))
              end
            | None -> return UnifyOk(subst: s1)
          end
        | None -> return UnifyOk(subst: s1)
      end
  end
end

// ─── TypeDef expansion for structural record unification ────────────────────

let unify_typedef_record = fn (name: string, args: [TypeExpr], record: TypeExpr, tdefs: [TypeDefEntry]) -> UnifyResult do
  match tctypes.typedef_lookup(defs: tdefs, name) do
    | Some(val: RecordDef(name: _, is_public: _, type_params: tps, fields)) ->
      let param_subst = build_param_subst(params: tps, args)
      let expanded_fields = apply_subst_named_types(subst: param_subst, nts: fields)
      let expanded = TyRecord(fields: expanded_fields)
      return unify(t1: record, t2: expanded, tdefs)
    | None ->
      return UnifyErr(message: "unknown type definition: " ++ name)
  end
end

let build_param_subst = fn (params: [string], args: [TypeExpr]) -> [SubstEntry] do
  match params do
    | [] -> return []
    | p :: rp ->
      match args do
        | [] -> return []
        | a :: ra ->
          return SubstEntry(var: p, typ: a)
            :: build_param_subst(params: rp, args: ra)
      end
  end
end
