/**
 * typecheck/errors: Typecheck-phase exception types.
 *
 * Covers all T-rule and linearity diagnostics: TypeMismatch, main-shape
 * errors, linear-binding discipline, quantifier well-formedness, capability
 * and throws-row well-formedness, record/pattern label uniqueness, and
 * unreachable-code detection.  All are E2xxx codes in `format_error`.
 * Internal invariant violations (ThrowsRowInvariantBroken) are E0xxx ICEs.
 */

import { Span } from "src/common/token.nx"

export exception TypeMismatch(func_name: string, detail: string, span: Span)
export exception MissingMain
export exception MainNotFunction
export exception MainNotUnit
/** `main` declares a throws-row that the HIR main-wrap pass cannot synthesise
 *  a top-level handler for: `Exn` (which would swallow every variant), an open
 *  row (rest is Some), or a row containing non-named entries. Narrow
 *  exception groups and concrete exception variants are accepted because the
 *  pass projects them to a closed catch-all + `__nx_exit(1)`.
 */
export exception MainThrowsTooBroad(detail: string)

/** `main` declares a require-row that contains a user-declared cap capability.
 *  Per spec P9 wfMain: ρ_q ⊆ SysCaps — only the seven system capabilities
 *  (PermFs, PermNet, PermConsole, PermRandom, PermClock, PermProc, PermEnv)
 *  may appear in main's require row. User-declared caps have no enclosing
 *  inject to provide them at the program entry point.
 */
export exception MainRequiresTooBroad(cap_name: string)

/** `main` was declared with a parameter list that is neither `()` nor
 *  `(args: [string])`.  The only accepted entry-point shapes per P9 wfMain
 *  (extended to permit the argv form) are:
 *    let main = fn () -> unit ...
 *    let main = fn (args: [string]) -> unit ...
 *  Any other parameter list is rejected.
 */
export exception MainWrongParams

/** `main` was declared with the `export` prefix.
 *  Per spec P9 wfMain: main ∉ exports(T) — main is a runtime entry-point hook,
 *  not part of any module's public API. Other modules cannot import and call it.
 */
export exception MainExported

/** Public exception LazyBindingUnused. */
export exception LazyBindingUnused(name: string, span: Span)
/** Public exception LazyBindingDoubleUse. */
export exception LazyBindingDoubleUse(name: string, span: Span)

/** same-name top-level `let` redeclaration. The HIR-to-WASM
 *  pipeline does not handle lexical shadowing of top-level function names:
 *  the second definition silently overwrites the first in the type env,
 *  while a downstream lir_opt pass mis-resolves `return_call` to itself and
 *  corrupts UNRELATED functions' return atoms with `default_atom(typ)`.
 *  Reject the redeclaration at typecheck time to eliminate the bug class.
 */
export exception DuplicateTopLevelBinding(name: string, span: Span)

/** a top-level `fn <X1,.,Xn>(.)` declaration whose
 *  quantifier `X` does not occur in the function signature.
 *  Spec §"Polymorphism Introduction" (type-system-formal.md L548–L571):
 *  `kindOf(X, σ)` is *undefined* when neither `occurs_τ(X, σ)` nor
 *  `occurs_ρ(X, σ)` holds — the spec calls this case a static error at
 *  T-Let-PolyFn and asks the diagnostic to surface at the binding site
 *  ("malformed quantifier list"), not at a use site. The impl previously
 *  silently substituted, leaving the surplus quantifier as dead weight in
 *  the scheme.
 */
export exception UnusedTypeParam(name: string, func_name: string, span: Span)

/** a top-level `fn <X1,.,Xn>(.)` declaration whose
 *  quantifier `X` occurs *both* at a type position and as a row tail in
 *  the signature. Spec §"Polymorphism Introduction" (L548–L571):
 *  `kindOf(X, σ)` is *undefined* when `occurs_τ(X, σ) ∧ occurs_ρ(X, σ)`
 *  ("kind clash"). Without binding-site rejection, the unifier surfaces
 *  a confusing "expected Type, got Row" only when a call site exercises
 *  both positions — the spec asks us to reject at the binding site so
 *  the diagnostic points at the malformed quantifier list directly.
 */
export exception KindClashTypeParam(name: string, func_name: string, span: Span)

/** %T binding lints: linearity discipline for `%T`
 *  bindings. `LinearUnused` fires when a linear binding leaves scope
 *  without being consumed; `LinearReuse` is reserved for double-use of a
 *  linear local (the structural pass currently relies on consume-removes-
 *  from-set semantics, so a reuse manifests as Unused at the next site;
 *  the constructor is kept as a distinct kind for diagnostic clarity).
 *  `LinearMismatch` fires when an if/match/while/for/try-catch arm
 *  finishes with a different live-linear set than its sibling arms — a
 *  linear that survives one path but not another would silently leak.
 * `LinearLeakAcrossThrowableCall` is the check: a
 *  stmt-level call whose callee may throw must not leave any linear live
 *  that a catch arm would not be obliged to consume.
 */
/** Public exception LinearUnused. */
export exception LinearUnused(name: string, span: Span)
/** Public exception LinearReuse. */
export exception LinearReuse(name: string, span: Span)
/** Public exception LinearMismatch. */
export exception LinearMismatch(detail: string, span: Span)
/** Public exception LinearLeakAcrossThrowableCall. */
export exception LinearLeakAcrossThrowableCall(callee: string, leaked: [string], span: Span)

/** Typecheck invariant violation: the throws-row passed to
 *  `catch_param_type_from_row` / `project_exn_from_row_types` was neither
 *  a `TyRow` / `TyVar` nor an Exn-rooted entry. Reaching this arm means
 *  a prior phase produced a malformed throws-row; surface as ICE rather
 * than fabricating a Span(0,0,0)-bearing TypeMismatch.
 *  Raised exclusively by src/typecheck/infer.nx, hence grouped under TypeError.
 */
export exception ThrowsRowInvariantBroken(detail: string)

/** Raised at every introduction site of a require row (T-Lambda, T-Handler,
 *  D-Cap methods) when the row contains a name that is neither a system
 *  capability (`PermFs`, `PermConsole`, ...) nor a cap declared by `cap X`.
 *  Enforces wfCap from docs/spec/type-system-formal.md §1 (wfCap).
 *  `suggestions` carries up to 3 near-match cap names (Levenshtein ≤ 2).
 */
export exception UnknownCapability(name: string, suggestions: [string], span: Span)

/** Raised at every introduction site of a throws row (T-Lambda fn arrow,
 *  D-Cap methods, handler arms) when the row contains a name that is not
 *  the universal `Exn` sentinel, a variant of `Exn` (i.e. a declared
 *  `exception` or built-in), or a declared exception group.
 *  Enforces wfThrow from docs/spec/type-system-formal.md §1 (wfThrow).
 *  `suggestions` carries up to 3 near-match exception/group names.
 */
export exception UnknownThrowVariant(name: string, suggestions: [string], span: Span)

/** Raised when a constructor expression or pattern references a variant name
 *  that is not present in any declared enum. `suggestions` carries up to 3
 *  near-match variant names (Levenshtein ≤ 2) across all in-scope enums.
 */
export exception UnknownConstructor(name: string, suggestions: [string], span: Span)

/** Raised when a field access (`.field`) or record pattern references a field
 *  name that is not declared on the record type. `suggestions` carries up to 3
 *  near-match field names from the record's declared fields.
 */
export exception UnknownField(name: string, suggestions: [string], span: Span)

/** Raised when an `inject` site lists two or more handlers that target the
 *  same cap (capability). Enforces T-Inject premise ∀i≠j. P_i ≠ P_j
 *  from docs/spec/type-system-formal.md.
 */
export exception DuplicateInjectCap(cap_name: string, span: Span)

/** Raised when an `inject` site includes a handler whose declared `require`
 *  row contains a capability not present in the enclosing function's ambient
 *  require row. Enforces T-Inject premise ∀i. ρ_i ⊆ ρ_q.
 */
export exception HandlerRequireNotSubset(handler_name: string, missing_cap: string, span: Span)

/** Raised when a record literal `{ℓ₁: e₁, …, ℓₖ: eₖ}` contains a
 *  duplicate field label. Enforces T-Record premise distinct(ℓ̄):
 *  |ℓ̄| = |{ℓ₁, …, ℓₖ}| must hold; a label-set, not a multiset.
 */
export exception DuplicateRecordLabel(label: string, span: Span)

/** Raised when a record pattern `{ℓ₁: p₁, …, ℓₖ: pₖ}` contains a
 *  duplicate field label. Enforces P-Record premise distinct(ℓ̄).
 */
export exception DuplicatePatternLabel(label: string, span: Span)

/** Raised when a variable reference cannot be resolved in the current
 *  type environment. `suggestions` carries up to 3 in-scope binding names
 *  with Levenshtein distance ≤ 2 from `name`, used by `format_error` to
 *  emit "did you mean ...?" hints.
 */
export exception UnknownVariable(name: string, suggestions: [string], span: Span)

/** Raised when statements follow a diverging statement (return / throw) in
 *  the same block.  Enforces T-Seq premise: if τ₁ = ⊥, the rest is unreachable.
 */
export exception UnreachableCode(span: Span)

/** Raised when a mutable reference type (~σ) appears in an escape position:
 *  the return type of a function declaration (T-Lambda / T-Let-PolyFn /
 *  D-External), or the value returned by a `return` statement (T-Return).
 *  Enforces the gravity rule: ¬escapesRef(τ) — ref cells are stack-confined
 *  and must not outlive the function that owns them.
 *  Reference: docs/spec/type-system-formal.md §"Gravity Rule".
 */
export exception RefEscapes(context: string, span: Span)

/** Raised when a mutable reference type ~σ has a linear inner type σ = %τ.
 *  Enforces wfRef(~σ) ⟺ ¬linear(σ): a ref cell whose inner type is linear
 *  would allow each deref (~x) to produce a fresh copy of the linear payload,
 *  duplicating a single-use resource and violating linearity's single-use
 *  discipline.
 *  Checked at every parameter annotation site where ~σ is introduced:
 *  T-Lambda / T-Let-PolyFn parameter slots, D-External, D-Cap method params,
 *  and T-Handler arm params.
 *  Reference: docs/spec/type-system-formal.md §wfRef.
 */
export exception RefInnerLinear(param: string, span: Span)

/** Public exception group TypeError. */
export exception group TypeError = TypeMismatch | MissingMain | MainNotFunction | MainNotUnit | MainThrowsTooBroad
  | MainRequiresTooBroad | MainWrongParams | MainExported
  | LazyBindingUnused | LazyBindingDoubleUse
  | LinearUnused | LinearReuse | LinearMismatch | LinearLeakAcrossThrowableCall
  | ThrowsRowInvariantBroken
  | DuplicateTopLevelBinding
  | UnusedTypeParam | KindClashTypeParam
  | UnknownCapability | UnknownThrowVariant
  | UnknownConstructor | UnknownField
  | DuplicateInjectCap | HandlerRequireNotSubset
  | DuplicateRecordLabel | DuplicatePatternLabel
  | UnreachableCode | RefEscapes | RefInnerLinear
  | UnknownVariable
