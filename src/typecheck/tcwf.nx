/**
 * typecheck/tcwf: introduction-site well-formedness checks for capability
 * and throws rows.
 *
 * Enforces the spec-mandated wfCap and wfThrow predicates at every place
 * a row is *introduced* (T-Lambda fn arrow, D-Cap method signatures,
 * T-Handler annotations). Use sites do not re-check: by the spec, once
 * a row passes wfCap/wfThrow at introduction, every later operation
 * (T-App, T-CapCall, T-Inject, T-Raise, T-TryCatch) inherits the
 * invariant via unification.
 *
 * Reference: docs/spec/type-system-formal.md §1 — SysCaps / wfCap / wfThrow.
 *
 * The spec rationale that motivates this module:
 *   "Without wfCap at the introduction sites, a typo such as
 *    `require { Logr }` (intended `Logger`) would propagate as an
 *    uninhabitable row entry and surface only at a use site that
 *    happens to look it up — moving the diagnostic far from the source
 *    of the typo."
 *
 * Both predicates throw a typed diagnostic on the *first* offending entry
 * rather than collecting all of them — the rest of the typecheck pipeline
 * already uses fail-fast for register_functions, and stopping early keeps
 * the diagnostic shape simple while still giving the user a precise
 * source-spanned message.
 *
 * Issues: (wfCap) (wfThrow).
 */

import { Span } from "src/types/span.nx"
import {
  TypeExpr,
  TyRef,
  TyArrow,
  TyLinear,
  TyLazy,
  TyBorrow,
  TyArray,
  TyList,
  TyRecord,
  TyRow,
  TyUserDefined,
  NamedType,
  EnumDef,
  VariantDef,
  VariantField,
  RecordDef
} from "src/types/type_expr.nx"
import {
  HirCap,
  HirCapMethod,
  ExceptionGroupEntry,
  HirProgram,
  HirFunction,
  HirHandlerArm,
  HirHandlerBindingEntry,
  HirHandlerBinding,
  HirParam,
  HirStmt,
  HirStmtKind,
  HirExpr,
  HirExprKind,
  HirCallArg,
  HirNamedExpr,
  HirMatchCase,
  HirBody
} from "src/ir/hir/types.nx"
import {
  TypeError,
  UnknownCapability,
  UnknownThrowVariant,
  MalformedRowTail,
  RefEscapes,
  RefInnerLinear,
  LinearTypeInGenericArg,
  ReservedDeclarationName,
  DuplicateDeclaration,
  InvalidGroupMember,
  DuplicateCapMethod
} from "src/typecheck/errors.nx"
import { VariantIndex, VariantInfo }, * as vidx from "src/ir/support/variant_index.nx"
import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"
import { is_linear_binding_type } from "src/ir/shared/type_pred.nx"
import { suggest_names } from "src/diagnostics/levenshtein.nx"

// The seven WASI-grant capabilities. Kept here (rather than imported from
// main.nx) because tcwf lives in src/typecheck/ and driver depends on
// typecheck, not the other way around. The single source of truth for the
// runtime mapping is main.nx::perm_to_cap_name; adding a new system cap
// requires updating both places (small, intentional duplication — there
// are seven entries and they essentially never change).

/** True when `name` is one of the seven system capabilities defined by
 *  the spec's `SysCaps` set (`PermFs`, `PermNet`, `PermConsole`,
 *  `PermRandom`, `PermClock`, `PermProc`, `PermEnv`). */
export let is_sys_cap = fn (name: string) -> bool do
  if name == "PermFs" then return true end
  if name == "PermNet" then return true end
  if name == "PermConsole" then return true end
  if name == "PermRandom" then return true end
  if name == "PermClock" then return true end
  if name == "PermProc" then return true end
  if name == "PermEnv" then return true end
  return false
end

// Cap names land in HirCap.name canonically renamed to
// "<sanitized_path>#<bare>" (see src/ir/rdrname.nx::canonical_name). The
// require row, however, carries the source-level identifier — bare
// `Clock`, not `nxlib_stdlib_clock_nx#Clock` — so we compare against the
// suffix after the last '#'. When no '#' is present (e.g. local caps
// in the entry file), the full string is the bare name.
//
// Exported so that inject_cap_entries_acc (effects.nx) can use the same
// stripping logic when extending the ambient require row with handler cap
// names — ensuring the ambient row always carries bare names that match
// the unqualified names in handler `require { ... }` rows.
export let base_name_of = fn (qualified: string) -> string do
  let n = str.length(s: qualified)
  let idx = last_index_of_hash(s: qualified, i: n - 1)
  if idx < 0 then return qualified end
  return str.substring(s: qualified, start: idx + 1, len: n - idx - 1)
end

let last_index_of_hash = fn (s: string, i: i64) -> i64 do
  if i < 0 then return 0 - 1 end
  // 35 = ASCII '#'
  if str.char_code(s, idx: i) == 35 then return i end
  return last_index_of_hash(s, i: i - 1)
end

let cap_declared = fn (name: string, caps: [ HirCap ]) -> bool do
  match caps do
    | [] -> return false
    | HirCap(name: cn, methods: _) :: rest ->
      if base_name_of(qualified: cn) == name then return true end
      return cap_declared(name, caps: rest)
  end
end

/** Collect all candidate cap names: sys caps + declared caps (bare names). */
let cap_candidates = fn (caps: [ HirCap ]) -> [ string ] do
  let sys = [ "PermFs", "PermNet", "PermConsole", "PermRandom", "PermClock", "PermProc", "PermEnv" ]
  return cap_candidates_go(caps, acc: sys)
end

let cap_candidates_go = fn (caps: [ HirCap ], acc: [ string ]) -> [ string ] do
  match caps do
    | [] -> return acc
    | HirCap(name: cn, methods: _) :: rest ->
      return cap_candidates_go(caps: rest, acc: base_name_of(qualified: cn) :: acc)
  end
end

let check_cap_entries = fn (
  entries: [ TypeExpr ],
  caps: [ HirCap ],
  span: Span
) -> unit throws { TypeError } do
  match entries do
    | [] -> return ()
    | t :: rest ->
      match t do
        | TyUserDefined(name: n, args: _) ->
          if is_sys_cap(name: n) then
            return check_cap_entries(entries: rest, caps, span)
          end
          if cap_declared(name: n, caps) then
            return check_cap_entries(entries: rest, caps, span)
          end
          let sugs = suggest_names(typo: n, candidates: cap_candidates(caps))
          throw UnknownCapability(name: n, suggestions: sugs, span)
        // Row entries are constrained to be identifiers; non-identifier shapes
        // (TyVar/TyArrow/...) are rejected at the parser. If one slips
        // through, treat it as unknown to avoid silently admitting a malformed row.
        | _ -> throw UnknownCapability(name: "<non-identifier row entry>", suggestions: [], span)
      end
  end
end

/** wfCap(ρ_q): every named entry in the require row must be a system
 *  capability or a cap declared by `cap X`. The row tail (`{... | ?r}`)
 *  is unconstrained — tail vars are pinned by unification at use sites,
 *  which transitively inherits well-formedness from the closed-row context.
 *
 *  `span` is the span of the introducing site (fn-arrow, handler arm)
 *  used as the diagnostic location when no per-entry span is available.
 */
export let wf_cap = fn (row: TypeExpr, caps: [ HirCap ], span: Span) -> unit throws { TypeError } do
  match row do
    | TyRow(types: ts, rest: _) -> return check_cap_entries(entries: ts, caps, span)
    // Non-row require slots (TyUnit / TyVar) bypass the check — they only
    // appear via parser defaults or generic-arg substitution that pre-row.
    | _ -> return ()
  end
end

let group_declared = fn (name: string, groups: [ ExceptionGroupEntry ]) -> bool do
  match groups do
    | [] -> return false
    | ExceptionGroupEntry(name: gn, members: _) :: rest ->
      if gn == name then return true end
      return group_declared(name, groups: rest)
  end
end

let is_exn_variant = fn (name: string, vidx_: VariantIndex) -> bool do
  match vidx.lookup_variant_info(idx: vidx_, variant: name) do
    | Some(val: VariantInfo(enum_name: en, type_params: _, def: _)) ->
      // Only variants of the Exn enum count as "constructor of Exn".
      // A variant from another enum (e.g. List.Cons) sharing a name would
      // not satisfy the throws-row well-formedness criterion.
      return en == "Exn"
    | None -> return false
  end
end

/** Collect all exception/group names usable in a throws row: group names +
 *  each group's member names. The universal sentinel `Exn` is included too
 *  so users who typo "Exn" as e.g. "Exnn" get a suggestion.
 */
let throw_candidates = fn (groups: [ ExceptionGroupEntry ]) -> [ string ] do
  return throw_candidates_go(groups, acc: [ "Exn"])
end

let throw_candidates_go = fn (groups: [ ExceptionGroupEntry ], acc: [ string ]) -> [ string ] do
  match groups do
    | [] -> return acc
    | ExceptionGroupEntry(name: gn, members: ms) :: rest ->
      let acc2 = gn :: acc
      let acc3 = throw_candidates_members(ms, acc: acc2)
      return throw_candidates_go(groups: rest, acc: acc3)
  end
end

let throw_candidates_members = fn (members: [ string ], acc: [ string ]) -> [ string ] do
  match members do
    | [] -> return acc
    | m :: rest -> return throw_candidates_members(members: rest, acc: m :: acc)
  end
end

let check_throw_entries = fn (
  entries: [ TypeExpr ], vidx_: VariantIndex,
  groups: [ ExceptionGroupEntry ], span: Span
) -> unit throws { TypeError } do
  match entries do
    | [] -> return ()
    | t :: rest ->
      match t do
        | TyUserDefined(name: n, args: _) ->
          // The universal sentinel `Exn` is always admitted; T-Raise/T-TryCatch
          // already special-case it (see infer.nx::row_admits_exception).
          if n == "Exn" then return check_throw_entries(entries: rest, vidx_, groups, span) end
          if is_exn_variant(name: n, vidx_) then
            return check_throw_entries(entries: rest, vidx_, groups, span)
          end
          if group_declared(name: n, groups) then
            return check_throw_entries(entries: rest, vidx_, groups, span)
          end
          let sugs = suggest_names(typo: n, candidates: throw_candidates(groups))
          throw UnknownThrowVariant(name: n, suggestions: sugs, span)
        | _ -> throw UnknownThrowVariant(name: "<non-identifier row entry>", suggestions: [], span)
      end
  end
end

/** wfThrow tail check: the pipe-tail of a throws row `{ ... | T }` must be a
 *  ROW VARIABLE — the open-row form opens over a polymorphic row variable
 *  (a bound `<R>` quantifier). At an introduction site the row is still in
 *  pre-conversion form, so a bound quantifier `R` appears as the surface name
 *  `TyUserDefined("R", [])`; only names in `type_params` qualify. A concrete
 *  exception or an undeclared name in tail position is malformed: it would
 *  otherwise be treated as a fully-open row downstream, silently dropping the
 *  tail member from containment. The `__implicit` absent-annotation sentinel
 *  and genuine inference/row variables are always accepted. The inclusive
 *  closed multi-member form is the comma list `{ E, F }`.
 */
let check_throw_tail = fn (
  rest: Option<TypeExpr>, type_params: [ string ], span: Span
) -> unit throws { TypeError } do
  match rest do
    | None -> return ()
    | Some(val: tail) ->
      match tail do
        // Already a row variable (e.g. an inference var, or a quantifier that
        // was converted by convert_ud_to_var before reaching this check).
        | TyVar(name: _) -> return ()
        // Surface-name tail: legitimate only when it names a bound `<R>`
        // quantifier (kindOf will further constrain R to Row).
        | TyUserDefined(name: n, args: []) ->
          if str_list_has(names: type_params, s: n) then return () end
          throw MalformedRowTail(name: n, span)
        // Any other shape after '|' is not a row variable.
        | TyUserDefined(name: n, args: _) -> throw MalformedRowTail(name: n, span)
        | _ -> throw MalformedRowTail(name: "<non-row-variable pipe-tail>", span)
      end
  end
end

/** wfThrow(ρ_e): every named entry in the throws row must be either the
 *  universal `Exn` sentinel, a constructor (variant) of `Exn`, or a
 *  declared exception group. The pipe-tail must be a row variable — a bound
 *  `<R>` quantifier (open-row form) — and is validated by `check_throw_tail`;
 *  a concrete exception / undeclared name after `|` is rejected (use the
 *  comma form `{ E, F }` for an inclusive closed list).
 *
 *  `type_params` are the quantifiers in scope at the introduction site, used
 *  to recognise a legitimate row-variable tail. Sites without quantifiers in
 *  scope (cap methods, handler arms) pass `[]`.
 */
export let wf_throw = fn (
  row: TypeExpr, vidx_: VariantIndex,
  groups: [ ExceptionGroupEntry ], span: Span,
  type_params: [ string ]
) -> unit throws { TypeError } do
  match row do
    | TyRow(types: ts, rest: r) ->
      check_throw_entries(entries: ts, vidx_, groups, span)
      return check_throw_tail(rest: r, type_params, span)
    | _ -> return ()
  end
end

// escapesRef(τ) — spec §"Gravity Rule": iff τ contains ~σ (TyRef) at any structurally reachable
// position: as the type itself, inside TyLinear/TyLazy/TyBorrow wrappers,
// as an array or list element, as a record field, or as the parameter/return
// of an arrow (function types may not expose ref cells in their signatures
// either — that path is caught at T-Lambda, but structural recursion into
// arrows ensures nested fn-returning-ref is also caught).
//
// The check does NOT recurse into TyArrow param/ret positions here: function
// types are first-class values and a `fn () -> ref(i64)` *type* in an outer
// return position would be caught at the outer function's declaration site.
// Only the *direct* TyRef in a return/field/escape position is our concern.
// Recursion into structural wrappers (Linear, Lazy, Borrow, Array, List,
// Record) is performed so that e.g. [~i64] or {f: ~i64} are also rejected.

/** `escapes_ref(τ)` — true iff τ contains a TyRef (~σ) at any structurally
 *  reachable position (spec §"Gravity Rule"). Used to enforce:
 *    - T-Return: ¬escapesRef(τ) on the inferred return type
 *    - T-Lambda / T-Let-PolyFn: ¬escapesRef(τ_r) on the declared ret type
 *    - D-External: ¬escapesRef(τ_r) on the external binding ret type
 */
export let escapes_ref = fn (typ: TypeExpr) -> bool do
  match typ do
    | TyRef(_) -> return true
    | TyLinear(inner: i) | TyLazy(
      inner: i,
      require_row: _,
      throw_row: _
    ) | TyBorrow(inner: i) -> return escapes_ref(typ: i)
    | TyArray(elem: e) | TyList(elem: e) -> return escapes_ref(typ: e)
    | TyRecord(fields: fs) -> return escapes_ref_named(types: fs)
    // Spec §Gravity Rule: escapesRef is structural — a ~σ reachable through a
    // named type's TYPE ARGUMENT (e.g. `Box<ref(i64)>`) escapes just as a ref
    // in a record/variant field does. Recurse into the direct args.
    | TyUserDefined(name: _, args: type_args) -> return escapes_ref_args(args: type_args)
    // Arrow: do not recurse — a fn-type in return position is not itself a
    // ref escape; the arrow's own ret-type is screened when that lambda is
    // registered (T-Lambda / T-Let-PolyFn enforcement).
    | _ -> return false
  end
end

let escapes_ref_args = fn (args: [ TypeExpr ]) -> bool do
  match args do
    | [] -> return false
    | a :: rest ->
      if escapes_ref(typ: a) then return true end
      return escapes_ref_args(args: rest)
  end
end

let escapes_ref_named = fn (types: [ NamedType ]) -> bool do
  match types do
    | [] -> return false
    | NamedType(name: _, typ: t) :: rest ->
      if escapes_ref(typ: t) then return true end
      return escapes_ref_named(types: rest)
  end
end

/** Enforce ¬escapesRef(τ) at a declaration/return site. Throws `RefEscapes`
 *  if τ contains a mutable-reference type. `context` is a short description
 *  for the diagnostic (e.g. "return type of 'foo'" or "return statement").
 */
export let enforce_no_escapes_ref = fn (
  typ: TypeExpr,
  context: string,
  span: Span
) -> unit throws { TypeError } do
  if escapes_ref(typ) then
    throw RefEscapes(context, span)
  end
end

// ── Generic-instantiation-at-linear well-formedness (spec §Linearity) ─────
//
// Persistent generic containers (`Pair`, `Map`, `Option`, ...) deliver their
// payload by alias on every read: `map.get` returns a fresh copy of the
// stored value, two unpacks of `let Pair(left: x, right: y) = p` are distinct
// uses of the same underlying slot, etc. If the slot holds a LINEAR value,
// each read duplicates that single-use resource — a `bb.empty()` placed in
// `Map<string, %ByteBuffer>` is observable as two `%ByteBuffer` aliases and
// freeing both is a double-free.
//
// Spec §Linearity states the predicate `linear` recurses into the type
// arguments of a named type (worked example `linear(Pair<%i64,i64>) = true`).
// At the IMPL level the 4j5l1 close left the variant-field path
// deliberately shallow (so PbField → PbValue → %ByteBuffer wouldn't
// retroactively mark every `[PbField]` linear and break protobuf code that
// doesn't clean up on throw paths). The shallow tradeoff is preserved here;
// instead we enforce the rule at TYPE-FORMATION: a generic type parameter
// cannot be instantiated with a linear type. Equivalently, a
// `TyUserDefined(name, args)` is well-formed only when no `args[i]` is
// structurally linear. The rule fires at every type-introduction site
// (params, return, fields, variant fields), close to the source line that
// wrote the bad type expression.
//
// Concrete (no-args) user types like `PbField` itself do NOT trigger the
// rule because `args = []`; this is the carve-out that keeps protobuf
// compiling. Type-parameter occurrences `TyUserDefined("T", [])` are also
// args-less and so do not trigger; instantiation at a linear actual happens
// when the caller writes the explicit `<%X>`, which IS caught here.

/** True iff `args` contains a structurally-linear type at any position.
 *  Returns the 1-based position of the FIRST offending arg (or 0 if none).
 *  Linear means: TyLinear, TyLazy, TyArray, or a TyUserDefined whose own
 *  args (recursively) include one — see `is_linear_binding_type`.
 */
let first_linear_arg_position = fn (
  args: [ TypeExpr ],
  idx: i64,
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ]
) -> i64 do
  match args do
    | [] -> return 0
    | a :: rest ->
      if is_linear_binding_type(t: a, tdefs, enum_defs) then return idx end
      return first_linear_arg_position(args: rest, idx: idx + 1, tdefs, enum_defs)
  end
end

/** Walk a type structurally and reject every `TyUserDefined(name, args)`
 *  node whose `args` contain a linear type (spec §Linearity: persistent
 *  generic container cannot hold a linear payload). `context` is a short
 *  description of the introduction site, used in the diagnostic.
 *  Recurses into wrappers and into the args themselves so that
 *  `Box<Pair<%bb, i64>>` is caught at the inner Pair as well as the outer
 *  Box (whichever fires first reports the inner-most precise location).
 *  Arrow types are NOT recursed into here: a `fn () -> Map<string, %bb>`
 *  *type* in an outer return position is caught at the outer site, and the
 *  arrow's own ret-type is screened when that lambda is registered.
 */
export let enforce_no_linear_type_args = fn (
  typ: TypeExpr,
  context: string,
  span: Span,
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ]
) -> unit throws { TypeError } do
  match typ do
    // Wrappers: peel and recurse. The wrappers themselves carry no args
    // we'd reject; the inner type may.
    | TyLinear(inner: i) | TyLazy(
      inner: i,
      require_row: _,
      throw_row: _
    ) | TyBorrow(inner: i) | TyRef(inner: i) ->
      return enforce_no_linear_type_args(typ: i, context, span, tdefs, enum_defs)
    | TyArray(elem: e) | TyList(elem: e) ->
      return enforce_no_linear_type_args(typ: e, context, span, tdefs, enum_defs)
    | TyRecord(fields: fs) ->
      return enforce_no_linear_named_types(fields: fs, context, span, tdefs, enum_defs)
    | TyUserDefined(name: n, args: type_args) ->
      // Recurse into args FIRST so the innermost `Pair<%bb, _>` in
      // `Box<Pair<%bb, _>>` is reported (more precise) before the outer
      // Box-of-linear. After the recursion, check this level.
      enforce_no_linear_args_each(args: type_args, context, span, tdefs, enum_defs)
      let pos = first_linear_arg_position(args: type_args, idx: 1, tdefs, enum_defs)
      if pos > 0 then
        throw LinearTypeInGenericArg(context, outer_type: n, position: pos, span)
      end
      return ()
    | _ -> return ()
  end
end

let enforce_no_linear_args_each = fn (
  args: [ TypeExpr ],
  context: string,
  span: Span,
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ]
) -> unit throws { TypeError } do
  match args do
    | [] -> return ()
    | a :: rest ->
      enforce_no_linear_type_args(typ: a, context, span, tdefs, enum_defs)
      return enforce_no_linear_args_each(args: rest, context, span, tdefs, enum_defs)
  end
end

let enforce_no_linear_named_types = fn (
  fields: [ NamedType ],
  context: string,
  span: Span,
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ]
) -> unit throws { TypeError } do
  match fields do
    | [] -> return ()
    | NamedType(name: _, typ: t) :: rest ->
      enforce_no_linear_type_args(typ: t, context, span, tdefs, enum_defs)
      return enforce_no_linear_named_types(fields: rest, context, span, tdefs, enum_defs)
  end
end

/** Apply `enforce_no_linear_type_args` to each named-typed slot (e.g. a list
 *  of function parameters or D-Cap method parameters). `param_label_fmt` is
 *  used to format the per-param context string.
 */
let enforce_no_linear_args_in_params = fn (
  params: [ NamedType ],
  context_prefix: string,
  span: Span,
  tdefs: [ RecordDef ],
  enum_defs: [ EnumDef ]
) -> unit throws { TypeError } do
  match params do
    | [] -> return ()
    | NamedType(name: n, typ: t) :: rest ->
      enforce_no_linear_type_args(
        typ: t,
        context: "parameter '" ++ n ++ "' of " ++ context_prefix,
        span,
        tdefs,
        enum_defs
      )
      return enforce_no_linear_args_in_params(params: rest, context_prefix, span, tdefs, enum_defs)
  end
end

// ── Function-body let-annotation walk ──────────────────────────────────────
//
// `let x: Map<string, %bb> = ...` is the second of the four spec-listed
// reject sites and slips through the param/return walks above. The body
// walker visits every `Let` statement in an EagerBody (the form normal
// lambdas are converted into), and runs the type-formation check against
// the user-written annotation when present (the Option<TypeExpr>). It
// recurses through block-bearing statement / expression kinds so that
// annotations inside nested If/Match/While/For/Try/Inject/Lambda branches
// are also covered. LazyBody (rare; only top-level non-lambda lets pre
// `iterative_resolve`) is skipped — those convert to a single value
// binding whose own annotation is captured elsewhere if at all.

let walk_body_let_annots = fn (
  body: HirBody,
  fn_name: string,
  tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match body do
    | EagerBody(stmts) -> return walk_stmts_let_annots(stmts, fn_name, tdefs)
    | LazyBody(ast_expr: _, entries: _) -> return ()
  end
end

let walk_stmts_let_annots = fn (
  stmts: [ HirStmt ],
  fn_name: string,
  tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match stmts do
    | [] -> return ()
    | HirStmt(node: kind, span: sp) :: rest ->
      walk_stmt_kind_let_annots(kind, span: sp, fn_name, tdefs)
      return walk_stmts_let_annots(stmts: rest, fn_name, tdefs)
  end
end

let walk_stmt_kind_let_annots = fn (
  kind: HirStmtKind,
  span: Span,
  fn_name: string,
  tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match kind do
    | Let(name: ln, sigil: _, typ: ann, value: v) ->
      match ann do
        | Some(val: t) ->
          enforce_no_linear_type_args(
            typ: t,
            context: "let binding '" ++ ln ++ "' in '" ++ fn_name ++ "'",
            span,
            tdefs,
            enum_defs: []
          )
        | None -> ()
      end
      return walk_expr_let_annots(expr: v, fn_name, tdefs)
    | Expr(expr: e) -> return walk_expr_let_annots(expr: e, fn_name, tdefs)
    | Return(expr: e) -> return walk_expr_let_annots(expr: e, fn_name, tdefs)
    | Assign(target: tgt, value: v) ->
      walk_expr_let_annots(expr: tgt, fn_name, tdefs)
      return walk_expr_let_annots(expr: v, fn_name, tdefs)
    | Try(body: tb, catch_param: _, catch_body: cb) ->
      walk_stmts_let_annots(stmts: tb, fn_name, tdefs)
      return walk_stmts_let_annots(stmts: cb, fn_name, tdefs)
    | Inject(handlers: _, body: ib) ->
      return walk_stmts_let_annots(stmts: ib, fn_name, tdefs)
  end
end

let walk_expr_let_annots = fn (
  expr: HirExpr,
  fn_name: string,
  tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  let HirExpr(node: kind, span: _) = expr
  match kind do
    | Literal(lit: _) -> return ()
    | Variable(name: _, sigil: _) -> return ()
    | Borrow(name: _, sigil: _) -> return ()
    | BinOp(left: l, op: _, right: r) ->
      walk_expr_let_annots(expr: l, fn_name, tdefs)
      return walk_expr_let_annots(expr: r, fn_name, tdefs)
    | UnOp(op: _, operand: o) -> return walk_expr_let_annots(expr: o, fn_name, tdefs)
    | Call(func: _, args: as_) -> return walk_call_args_let_annots(args: as_, fn_name, tdefs)
    | CallExpr(callee: c, args: as_) ->
      walk_expr_let_annots(expr: c, fn_name, tdefs)
      return walk_call_args_let_annots(args: as_, fn_name, tdefs)
    | Ctor(variant: _, args: as_, labels: _, sigil: _) ->
      return walk_exprs_let_annots(exprs: as_, fn_name, tdefs)
    | Record(fields: fs) -> return walk_named_exprs_let_annots(fields: fs, fn_name, tdefs)
    | Array(elems: es) -> return walk_exprs_let_annots(exprs: es, fn_name, tdefs)
    | Index(target: t, index: i) ->
      walk_expr_let_annots(expr: t, fn_name, tdefs)
      return walk_expr_let_annots(expr: i, fn_name, tdefs)
    | FieldAccess(target: t, field: _) -> return walk_expr_let_annots(expr: t, fn_name, tdefs)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      walk_expr_let_annots(expr: c, fn_name, tdefs)
      walk_stmts_let_annots(stmts: tb, fn_name, tdefs)
      match eb do
        | Some(val: es) -> return walk_stmts_let_annots(stmts: es, fn_name, tdefs)
        | None -> return ()
      end
    | Match(target: t, cases: cs) ->
      walk_expr_let_annots(expr: t, fn_name, tdefs)
      return walk_match_cases_let_annots(cases: cs, fn_name, tdefs)
    | While(cond: c, body: wb) ->
      walk_expr_let_annots(expr: c, fn_name, tdefs)
      return walk_stmts_let_annots(stmts: wb, fn_name, tdefs)
    | For(var: _, start: s, end_expr: e, body: fb) ->
      walk_expr_let_annots(expr: s, fn_name, tdefs)
      walk_expr_let_annots(expr: e, fn_name, tdefs)
      return walk_stmts_let_annots(stmts: fb, fn_name, tdefs)
    | Lambda(
        type_params: _,
        params: _,
        ret_type: _,
        requires: _,
        throw_row: _,
        body: lb
      ) ->
      // Nested lambda: walk its body too. Its own params/ret are checked by
      // walk_funcs when it surfaces as a top-level HirFunction (after lambda
      // lifting) or here (anonymous, lifted later). To be safe also include
      // them now — but conservatively only the body since the lambda's params
      // are checked at the parent level once the lambda is lifted.
      return walk_stmts_let_annots(stmts: lb, fn_name, tdefs)
    | Raise(expr: e) -> return walk_expr_let_annots(expr: e, fn_name, tdefs)
    | Force(expr: e) -> return walk_expr_let_annots(expr: e, fn_name, tdefs)
    | Thunk(body: e) -> return walk_expr_let_annots(expr: e, fn_name, tdefs)
    | ExternalRef(symbol: _, type_params: _, arg_names: _, typ: _) -> return ()
    | Handler(cap_name: _, requires: _, arms: _) ->
      // Handler arms are themselves HirFunctions in handler_bindings; their
      // let-annotations get walked when walk_handler_bindings invokes us on
      // each arm's body. Anonymous Handler-expr arms are not currently lifted
      // into handler_bindings; conservatively skip — annotation checks at
      // params/return are still applied at the lambda surface.
      return ()
  end
end

let walk_call_args_let_annots = fn (
  args: [ HirCallArg ],
  fn_name: string,
  tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match args do
    | [] -> return ()
    | HirCallArg(label: _, value: v) :: rest ->
      walk_expr_let_annots(expr: v, fn_name, tdefs)
      return walk_call_args_let_annots(args: rest, fn_name, tdefs)
  end
end

let walk_exprs_let_annots = fn (
  exprs: [ HirExpr ],
  fn_name: string,
  tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match exprs do
    | [] -> return ()
    | e :: rest ->
      walk_expr_let_annots(expr: e, fn_name, tdefs)
      return walk_exprs_let_annots(exprs: rest, fn_name, tdefs)
  end
end

let walk_named_exprs_let_annots = fn (
  fields: [ HirNamedExpr ],
  fn_name: string,
  tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match fields do
    | [] -> return ()
    | HirNamedExpr(name: _, value: v) :: rest ->
      walk_expr_let_annots(expr: v, fn_name, tdefs)
      return walk_named_exprs_let_annots(fields: rest, fn_name, tdefs)
  end
end

let walk_match_cases_let_annots = fn (
  cases: [ HirMatchCase ],
  fn_name: string,
  tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match cases do
    | [] -> return ()
    | HirMatchCase(pattern: _, body: b) :: rest ->
      walk_stmts_let_annots(stmts: b, fn_name, tdefs)
      return walk_match_cases_let_annots(cases: rest, fn_name, tdefs)
  end
end

// wfRef (spec §wfRef): wfRef(~σ) ⟺ ¬linear(σ).
// A ref cell's inner type must not be linear — each deref (~x) would
// otherwise produce a fresh copy of the linear payload, duplicating the
// resource and violating single-use discipline.
// We check every parameter type annotation: TyRef(inner) with TyLinear inner
// is rejected at declaration rather than letting ref(%T) smuggle through.
//
// Enforcement sites: fn param slots, cap method signatures, external
// binding annotations, handler arm params. The return-type slot goes
// through enforce_no_escapes_ref (gravity rule) — only wfRef needed here.

/** Enforce wfRef on a single parameter type: if it is `~σ` (TyRef) and
 *  σ is structurally linear (spec `linear(σ)` predicate), throw `RefInnerLinear`.
 *  `param` is the parameter label used for the diagnostic.
 */
let enforce_wf_ref_one = fn (
  typ: TypeExpr,
  param: string,
  span: Span,
  tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match typ do
    | TyRef(inner: i) ->
      if is_linear_binding_type(
        t: i,
        tdefs,
        enum_defs: []
      ) then throw RefInnerLinear(param, span) end
      return ()
    | _ -> return ()
  end
end

/** Enforce wfRef over a list of named parameter types. Each parameter whose
 *  declared type is `~σ` is checked: if σ is structurally linear the function
 *  throws `RefInnerLinear` naming the offending parameter label.
 */
export let enforce_wf_ref_params = fn (
  params: [ NamedType ],
  span: Span,
  tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match params do
    | [] -> return ()
    | NamedType(name: n, typ: t) :: rest ->
      enforce_wf_ref_one(typ: t, param: n, span, tdefs)
      return enforce_wf_ref_params(params: rest, span, tdefs)
  end
end

// Used by `walk_funcs` and `walk_handler_arms` (pre-DCE whole-program pass)
// to extract parameter type annotations from HirFunction.params so that
// `enforce_wf_ref_params` can check them. A separate helper rather than
// an import of check.nx::hir_params_to_named_types because tcwf.nx must
// not import typecheck/check.nx (circular dependency).

let hir_params_to_named_types_tcwf = fn (params: [ HirParam ]) -> [ NamedType ] do
  return hir_params_to_nt_go(params, acc: [])
end

let hir_params_to_nt_go = fn (params: [ HirParam ], acc: [ NamedType ]) -> [ NamedType ] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: l, name: _, sigil: _, typ: t) :: rest ->
      return hir_params_to_nt_go(params: rest, acc: NamedType(name: l, typ: t) :: acc)
  end
end

// `check_program_wf_rows` runs wfCap/wfThrow over every function in the
// program. Invoked on the post-build, pre-DCE HirProgram so a typo in an
// unused (dead-code) function is still caught — a typo'd row entry on an
// unused function would otherwise never surface.

let variant_index_of = fn (enum_defs: [ EnumDef ]) -> VariantIndex do
  return vidx.build_variant_index(defs: enum_defs)
end

let walk_funcs = fn (
  funcs: [ HirFunction ], caps: [ HirCap ],
  vidx_: VariantIndex, groups: [ ExceptionGroupEntry ], tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match funcs do
    | [] -> return ()
    | HirFunction(
      name: fn_name,
      type_params: tps,
      params: fn_params,
      ret_type: ret,
      throw_row: tw,
      body: _,
      span: sp,
      file: _,
      requires: req
    ) :: rest ->
      wf_cap(row: req, caps, span: sp)
      wf_throw(row: tw, vidx_, groups, span: sp, type_params: tps)
      // Gravity rule: ¬escapesRef(τ_r) on the declared return type.
      // Pre-DCE so even unused functions with `ref(T)` return types are rejected.
      enforce_no_escapes_ref(typ: ret, context: "return type of '" ++ fn_name ++ "'", span: sp)
      // wfRef on parameter types: pre-DCE so even unused functions with ref(%T) params are rejected.
      let fn_param_nts = hir_params_to_named_types_tcwf(params: fn_params)
      enforce_wf_ref_params(params: fn_param_nts, span: sp, tdefs)
      // Spec §Linearity (type-formation): no generic instantiation at a linear
      // type argument. Checked on declared return type and every parameter type.
      enforce_no_linear_type_args(
        typ: ret,
        context: "return type of '" ++ fn_name ++ "'",
        span: sp,
        tdefs,
        enum_defs: []
      )
      enforce_no_linear_args_in_params(
        params: fn_param_nts,
        context_prefix: "'" ++ fn_name ++ "'",
        span: sp,
        tdefs,
        enum_defs: []
      )
      // NOTE: body let-annotation walking is intentionally NOT done here:
      // `check_program_wf_rows` runs on pre-resolve HirProgram where all
      // top-level lambda bodies are still LazyBody. Body walking happens in
      // `check_program_wf_let_annots` after `iterative_resolve` has flipped
      // bodies to EagerBody.
      return walk_funcs(funcs: rest, caps, vidx_, groups, tdefs)
  end
end

let walk_handler_bindings = fn (
  hbs: [ HirHandlerBindingEntry ], caps: [ HirCap ],
  vidx_: VariantIndex, groups: [ ExceptionGroupEntry ], tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match hbs do
    | [] -> return ()
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      walk_handler_arms(arms, caps, vidx_, groups, tdefs)
      return walk_handler_bindings(hbs: rest, caps, vidx_, groups, tdefs)
  end
end

let walk_handler_arms = fn (
  arms: [ HirHandlerArm ], caps: [ HirCap ],
  vidx_: VariantIndex, groups: [ ExceptionGroupEntry ], tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(
      arm: HirFunction(
        name: _,
        type_params: arm_tps,
        params: arm_ps,
        ret_type: _,
        throw_row: tw,
        body: _,
        span: sp,
        file: _,
        requires: req
      ),
      cont_binder: _
    ) :: rest ->
      wf_cap(row: req, caps, span: sp)
      wf_throw(row: tw, vidx_, groups, span: sp, type_params: arm_tps)
      // wfRef on handler arm parameter types.
      let arm_param_nts = hir_params_to_named_types_tcwf(params: arm_ps)
      enforce_wf_ref_params(params: arm_param_nts, span: sp, tdefs)
      // Spec §Linearity (type-formation): no generic-of-linear in handler arm params.
      enforce_no_linear_args_in_params(
        params: arm_param_nts,
        context_prefix: "handler arm",
        span: sp,
        tdefs,
        enum_defs: []
      )
      // NOTE: body let-annotation walking is deferred to `check_program_wf_let_annots`.
      return walk_handler_arms(arms: rest, caps, vidx_, groups, tdefs)
  end
end

let walk_caps = fn (
  caps: [ HirCap ], all_caps: [ HirCap ],
  vidx_: VariantIndex, groups: [ ExceptionGroupEntry ]
) -> unit throws { TypeError } do
  match caps do
    | [] -> return ()
    | HirCap(name: qn, methods) :: rest ->
      let bn = base_name_of(qualified: qn)
      walk_cap_methods(cap_name: bn, methods, seen: [], caps: all_caps, vidx_, groups)
      return walk_caps(caps: rest, all_caps, vidx_, groups)
  end
end

let walk_cap_methods = fn (
  cap_name: string,
  methods: [ HirCapMethod ],
  seen: [ string ],
  caps: [ HirCap ],
  vidx_: VariantIndex, groups: [ ExceptionGroupEntry ]
) -> unit throws { TypeError } do
  match methods do
    | [] -> return ()
    | HirCapMethod(
      name: mn,
      requires: req,
      span: sp,
      throw_row: tw,
      typ_params: _,
      typ_ret: _
    ) :: rest ->
      // D-Cap: distinct(ℓ_j) — method names within a cap must be pairwise distinct.
      if str_list_has(names: seen, s: mn) then
        throw DuplicateCapMethod(cap_name, method_name: mn, span: sp)
      end
      wf_cap(row: req, caps, span: sp)
      // Cap methods declare no generic row quantifiers, so a pipe-tail here can
      // never be a legitimate row variable: pass the empty quantifier list.
      wf_throw(row: tw, vidx_, groups, span: sp, type_params: [])
      return walk_cap_methods(cap_name, methods: rest, seen: mn :: seen, caps, vidx_, groups)
  end
end

let walk_caps_wf_ref = fn (
  caps: [ HirCap ], vidx_: VariantIndex, groups: [ ExceptionGroupEntry ], tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match caps do
    | [] -> return ()
    | HirCap(name: _, methods) :: rest ->
      walk_cap_methods_wf_ref(methods, vidx_, groups, tdefs)
      return walk_caps_wf_ref(caps: rest, vidx_, groups, tdefs)
  end
end

let walk_cap_methods_wf_ref = fn (
  methods: [ HirCapMethod ], vidx_: VariantIndex, groups: [ ExceptionGroupEntry ], tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match methods do
    | [] -> return ()
    | HirCapMethod(
      name: mname,
      requires: _,
      span: sp,
      throw_row: _,
      typ_params: mparams,
      typ_ret: mret
    ) :: rest ->
      // Gravity rule: ¬escapesRef(κ_j) on D-Cap method return type (spec §escapesRef table, D-Cap).
      enforce_no_escapes_ref(
        typ: mret,
        context: "return type of cap method '" ++ mname ++ "'",
        span: sp
      )
      // wfRef on D-Cap method parameter types (spec §wfRef table, D-Cap).
      let method_param_nts = hir_params_to_named_types_tcwf(params: mparams)
      enforce_wf_ref_params(params: method_param_nts, span: sp, tdefs)
      // Spec §Linearity (type-formation): no generic-of-linear in cap method params/return.
      enforce_no_linear_type_args(
        typ: mret,
        context: "return type of cap method '" ++ mname ++ "'",
        span: sp,
        tdefs,
        enum_defs: []
      )
      enforce_no_linear_args_in_params(
        params: method_param_nts,
        context_prefix: "cap method '" ++ mname ++ "'",
        span: sp,
        tdefs,
        enum_defs: []
      )
      return walk_cap_methods_wf_ref(methods: rest, vidx_, groups, tdefs)
  end
end

// D-Type-Sum / D-Type-Sum-Opaque wfRef + escapesRef enforcement
// (spec §wfRef table row "Field types of a sum-type variant" and
//  §escapesRef table row "Field types of a sum-type variant").
// EnumDef/RecordDef carry no span; Span(0,0,0) used as in D-External.

let variant_field_context = fn (
  field_name: Option<string>,
  idx: i64,
  variant_name: string,
  enum_name: string
) -> string do
  match field_name do
    | Some(val: n) -> return "field '" ++ n ++ "' of variant '" ++ variant_name ++ "' in type '" ++ enum_name ++ "'"
    | None -> return "field #" ++ str.from_i64(val: idx) ++ " of variant '" ++ variant_name ++ "' in type '" ++ enum_name ++ "'"
  end
end

let walk_variant_fields = fn (
  fields: [ VariantField ], idx: i64, variant_name: string, enum_name: string,
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> unit throws { TypeError } do
  match fields do
    | [] -> return ()
    | VariantField(name: mname, typ: t) :: rest ->
      let ctx = variant_field_context(field_name: mname, idx, variant_name, enum_name)
      // wfRef: if t = ref(σ) and linear(σ), reject.
      match t do
        | TyRef(inner: i) ->
          if is_linear_binding_type(t: i, tdefs, enum_defs) then
            throw RefInnerLinear(param: ctx, span: Span(offset: 0, line: 0, col: 0))
          end
        | _ -> ()
      end
      // escapesRef: reject ref(σ) at any structurally reachable position.
      enforce_no_escapes_ref(typ: t, context: ctx, span: Span(offset: 0, line: 0, col: 0))
      // Spec §Linearity (type-formation): a variant field that names a generic
      // type instantiated at a linear type-arg (e.g. `Pair<%bb, _>`) violates
      // the persistent-container rule. Concrete user enums whose body
      // transitively reaches a linear (PbField->PbValue->%ByteBuffer) are NOT
      // touched here (the protobuf carve-out): only the direct `<%T>`
      // type-arg position is rejected.
      enforce_no_linear_type_args(
        typ: t,
        context: ctx,
        span: Span(offset: 0, line: 0, col: 0),
        tdefs,
        enum_defs: []
      )
      return walk_variant_fields(
        fields: rest,
        idx: idx + 1,
        variant_name,
        enum_name,
        tdefs,
        enum_defs
      )
  end
end

let walk_variants = fn (
  variants: [ VariantDef ], enum_name: string,
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> unit throws { TypeError } do
  match variants do
    | [] -> return ()
    | VariantDef(name: vname, fields: fs) :: rest ->
      walk_variant_fields(fields: fs, idx: 0, variant_name: vname, enum_name, tdefs, enum_defs)
      return walk_variants(variants: rest, enum_name, tdefs, enum_defs)
  end
end

let walk_enum_defs = fn (
  defs: [ EnumDef ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> unit throws { TypeError } do
  match defs do
    | [] -> return ()
    | EnumDef(name: ename, is_public: _, is_opaque: _, type_params: _, variants: vs) :: rest ->
      walk_variants(variants: vs, enum_name: ename, tdefs, enum_defs)
      return walk_enum_defs(defs: rest, tdefs, enum_defs)
  end
end

// D-Type-Record wfRef + escapesRef enforcement
// (spec §wfRef table row "Field types of a record type declaration" and
//  §escapesRef table row "Field types of a record type declaration").

let walk_record_fields = fn (
  fields: [ NamedType ], type_name: string,
  tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> unit throws { TypeError } do
  match fields do
    | [] -> return ()
    | NamedType(name: fname, typ: t) :: rest ->
      let ctx = "field '" ++ fname ++ "' of record type '" ++ type_name ++ "'"
      // wfRef: if t = ref(σ) and linear(σ), reject.
      match t do
        | TyRef(inner: i) ->
          if is_linear_binding_type(t: i, tdefs, enum_defs) then
            throw RefInnerLinear(param: ctx, span: Span(offset: 0, line: 0, col: 0))
          end
        | _ -> ()
      end
      // escapesRef: reject ref(σ) at any structurally reachable position.
      enforce_no_escapes_ref(typ: t, context: ctx, span: Span(offset: 0, line: 0, col: 0))
      // Spec §Linearity (type-formation): no generic-of-linear in record-typedef fields.
      enforce_no_linear_type_args(
        typ: t,
        context: ctx,
        span: Span(offset: 0, line: 0, col: 0),
        tdefs,
        enum_defs: []
      )
      return walk_record_fields(fields: rest, type_name, tdefs, enum_defs)
  end
end

let walk_type_defs = fn (
  defs: [ RecordDef ], tdefs: [ RecordDef ], enum_defs: [ EnumDef ]
) -> unit throws { TypeError } do
  match defs do
    | [] -> return ()
    | RecordDef(name: rname, is_public: _, type_params: _, fields: fs) :: rest ->
      walk_record_fields(fields: fs, type_name: rname, tdefs, enum_defs)
      return walk_type_defs(defs: rest, tdefs, enum_defs)
  end
end

// ─── D-Exception / D-Cap / D-ExceptionGroup name-binding validation ───────────
//
// Spec §type-system-formal.md §D-Exception, §D-Cap, §D-ExceptionGroup.
// These checks enforce the freshness/membership premises on the BOUND NAME(s)
// that wfCap/wfThrow at row-position sites do NOT cover:
//
//   D-Exception : C ∉ {Exn} ∪ SysCaps ∪ dom(methods) ∪ variants(Exn)
//   D-Cap       : X ∉ {Exn} ∪ SysCaps ∪ dom(methods)
//   D-ExceptionGroup: ∀i. C_i ∈ variants(Exn) ∧ distinct(C_1..C_n)

// Return the first method span of a cap, falling back to Span(0,0,0).
let cap_first_span = fn (methods: [ HirCapMethod ]) -> Span do
  match methods do
    | [] -> return Span(offset: 0, line: 0, col: 0)
    | HirCapMethod(
      name: _,
      requires: _,
      span: sp,
      throw_row: _,
      typ_params: _,
      typ_ret: _
    ) :: _ -> return sp
  end
end

// Check whether `name` already exists as a variant in `names`.
let str_list_has = fn (names: [ string ], s: string) -> bool do
  match names do
    | [] -> return false
    | n :: rest ->
      if n == s then return true end
      return str_list_has(names: rest, s)
  end
end

// ── D-Exception: validate each exception (Exn variant) name ────────────────

let check_exn_decl_names = fn (defs: [ EnumDef ]) -> unit throws { TypeError } do
  match defs do
    | [] -> return ()
    | EnumDef(name: n, is_public: _, is_opaque: _, type_params: _, variants: vs) :: rest ->
      if n == "Exn" then
        // Only the Exn enum carries user-declared exceptions.
        return check_exn_variants(variants: vs, seen: [])
      end
      return check_exn_decl_names(defs: rest)
  end
end

// Walk Exn variants in declaration order. Variants added by register_exn_variant
// are prepended (last-wins build), so the list is in reverse declaration order;
// that is fine — we only need to detect duplicates and reserved names.
let check_exn_variants = fn (
  variants: [ VariantDef ],
  seen: [ string ]
) -> unit throws { TypeError } do
  match variants do
    | [] -> return ()
    | VariantDef(name: vn, fields: _) :: rest ->
      // Built-in variants seeded into empty_accum: RuntimeError, InvalidIndex.
      // We must not flag them — only user-declared names that are reserved.
      // A variant is "built-in" only if it was seeded before any TLException;
      // we cannot distinguish by position here, so check only the two
      // invariants that apply regardless of source:
      //   1. name == "Exn" is always reserved.
      //   2. name matches a SysCap name.
      //   3. duplicate within this file's own exception declarations.
      let span0 = Span(offset: 0, line: 0, col: 0)
      if vn == "Exn" then
        throw ReservedDeclarationName(kind: "exception", name: vn, span: span0)
      end
      if is_sys_cap(name: vn) then
        throw ReservedDeclarationName(kind: "exception", name: vn, span: span0)
      end
      if str_list_has(names: seen, s: vn) then
        throw DuplicateDeclaration(kind: "exception", name: vn, span: span0)
      end
      return check_exn_variants(variants: rest, seen: vn :: seen)
  end
end

// ── D-Cap: validate each cap name ──────────────────────────────────────────

let check_cap_decl_names = fn (caps: [ HirCap ], seen: [ string ]) -> unit throws { TypeError } do
  match caps do
    | [] -> return ()
    | HirCap(name: qn, methods) :: rest ->
      let bn = base_name_of(qualified: qn)
      let sp = cap_first_span(methods)
      if bn == "Exn" then
        throw ReservedDeclarationName(kind: "cap", name: bn, span: sp)
      end
      if is_sys_cap(name: bn) then
        throw ReservedDeclarationName(kind: "cap", name: bn, span: sp)
      end
      if str_list_has(names: seen, s: bn) then
        throw DuplicateDeclaration(kind: "cap", name: bn, span: sp)
      end
      return check_cap_decl_names(caps: rest, seen: bn :: seen)
  end
end

// ── D-ExceptionGroup: validate each group's members ────────────────────────

let check_group_decls = fn (
  groups: [ ExceptionGroupEntry ],
  vidx_: VariantIndex
) -> unit throws { TypeError } do
  match groups do
    | [] -> return ()
    | ExceptionGroupEntry(name: gn, members: ms) :: rest ->
      check_group_members(group_name: gn, members: ms, seen: [], vidx_)
      return check_group_decls(groups: rest, vidx_)
  end
end

let check_group_members = fn (
  group_name: string,
  members: [ string ],
  seen: [ string ],
  vidx_: VariantIndex
) -> unit throws { TypeError } do
  match members do
    | [] -> return ()
    | m :: rest ->
      let span0 = Span(offset: 0, line: 0, col: 0)
      if !is_exn_variant(name: m, vidx_) then
        throw InvalidGroupMember(
          group_name,
          member: m,
          reason: "not a declared exception constructor",
          span: span0
        )
      end
      if str_list_has(names: seen, s: m) then
        throw InvalidGroupMember(group_name, member: m, reason: "duplicate member", span: span0)
      end
      return check_group_members(group_name, members: rest, seen: m :: seen, vidx_)
  end
end

/** Run wfCap and wfThrow over every introduction site in the program.
 *  Pre-DCE so unused functions with typo'd rows are still rejected.
 *  Covers D-Cap method signatures: ∀j∈J. wfCap(α_j) ∧ wfThrow(β_j).
 *  Also validates declaration name-binding premises:
 *    D-Exception: C ∉ {Exn} ∪ SysCaps ∧ C ∉ variants(Exn) (no reserved/duplicate)
 *    D-Cap: X ∉ {Exn} ∪ SysCaps ∧ X ∉ dom(caps) (no reserved/duplicate)
 *    D-ExceptionGroup: ∀i. C_i ∈ variants(Exn) ∧ distinct(C_1..C_n)
 */
export let check_program_wf_rows = fn (prog: HirProgram) -> unit throws { TypeError } do
  let HirProgram(
    caps,
    functions: funcs,
    externals: _,
    handler_bindings: hbs,
    enum_defs: edefs,
    exception_groups: egs,
    value_binding_names: _,
    type_defs: tdefs,
    visible_enum_names: _
  ) = prog
  let vi = variant_index_of(enum_defs: edefs)
  // D-Exception / D-Cap / D-ExceptionGroup name-binding validation.
  check_exn_decl_names(defs: edefs)
  check_cap_decl_names(caps, seen: [])
  check_group_decls(groups: egs, vidx_: vi)
  walk_caps(caps, all_caps: caps, vidx_: vi, groups: egs)
  // Gravity rule (¬escapesRef) + wfRef on D-Cap method signatures.
  walk_caps_wf_ref(caps, vidx_: vi, groups: egs, tdefs)
  walk_funcs(funcs, caps, vidx_: vi, groups: egs, tdefs)
  walk_handler_bindings(hbs, caps, vidx_: vi, groups: egs, tdefs)
  // D-Type-Sum / D-Type-Sum-Opaque: wfRef + escapesRef on variant fields.
  walk_enum_defs(defs: edefs, tdefs, enum_defs: edefs)
  // D-Type-Record: wfRef + escapesRef on record fields.
  return walk_type_defs(defs: tdefs, tdefs, enum_defs: edefs)
end

// ── Post-resolve let-annotation walk ──────────────────────────────────────
//
// `check_program_wf_rows` walks the pre-resolve HIR where top-level lambda
// bodies are still `LazyBody`; nested `let x: T = e` annotations inside
// those bodies aren't visible there. This pass runs after
// `iterative_resolve` (or `resolve_all_lazy_no_filter`) has converted
// reachable bodies to `EagerBody`, and applies the type-formation rule to
// every let-annotation found in function bodies.

let walk_funcs_let_annots = fn (
  funcs: [ HirFunction ], tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match funcs do
    | [] -> return ()
    | HirFunction(
      name: fn_name,
      type_params: _,
      params: _,
      ret_type: _,
      throw_row: _,
      body: fn_body,
      span: _,
      file: _,
      requires: _
    ) :: rest ->
      walk_body_let_annots(body: fn_body, fn_name, tdefs)
      return walk_funcs_let_annots(funcs: rest, tdefs)
  end
end

let walk_handler_bindings_let_annots = fn (
  hbs: [ HirHandlerBindingEntry ], tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match hbs do
    | [] -> return ()
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      walk_handler_arms_let_annots(arms, tdefs)
      return walk_handler_bindings_let_annots(hbs: rest, tdefs)
  end
end

let walk_handler_arms_let_annots = fn (
  arms: [ HirHandlerArm ], tdefs: [ RecordDef ]
) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(
      arm: HirFunction(
        name: arm_name,
        type_params: _,
        params: _,
        ret_type: _,
        throw_row: _,
        body: arm_body,
        span: _,
        file: _,
        requires: _
      ),
      cont_binder: _
    ) :: rest ->
      walk_body_let_annots(body: arm_body, fn_name: arm_name, tdefs)
      return walk_handler_arms_let_annots(arms: rest, tdefs)
  end
end

/** Spec §Linearity (type-formation) for let-annotations: walk every
 *  function body and handler-arm body in the program and reject any
 *  `let x: T = e` whose annotation T instantiates a generic at a linear
 *  type-arg (`Map<string, %bb>`, `Pair<%bb, _>`, …). Must run on the
 *  post-resolve HirProgram (bodies converted from LazyBody to EagerBody).
 */
export let check_program_wf_let_annots = fn (prog: HirProgram) -> unit throws { TypeError } do
  let HirProgram(
    caps: _,
    functions: funcs,
    externals: _,
    handler_bindings: hbs,
    enum_defs: _,
    exception_groups: _,
    value_binding_names: _,
    type_defs: tdefs,
    visible_enum_names: _
  ) = prog
  walk_funcs_let_annots(funcs, tdefs)
  return walk_handler_bindings_let_annots(hbs, tdefs)
end
