/**
 * typecheck/tcwf: introduction-site well-formedness checks for capability
 * and throws rows.
 *
 * Enforces the spec-mandated wfCap and wfThrow predicates at every place
 * a row is *introduced* (T-Lambda fn arrow, D-Cap method signatures,
 * T-Handler annotations). Use sites do not re-check: by the spec, once
 * a row passes wfCap/wfThrow at introduction, every later operation
 * (T-App, T-CapCall, T-Inject, T-Raise, T-TryCatch) inherits the
 * invariant via unification.
 *
 * Reference: docs/spec/type-system-formal.md §1 — SysCaps / wfCap / wfThrow.
 *
 * The spec rationale that motivates this module:
 *   "Without wfCap at the introduction sites, a typo such as
 *    `require { Logr }` (intended `Logger`) would propagate as an
 *    uninhabitable row entry and surface only at a use site that
 *    happens to look it up — moving the diagnostic far from the source
 *    of the typo."
 *
 * Both predicates throw a typed diagnostic on the *first* offending entry
 * rather than collecting all of them — the rest of the typecheck pipeline
 * already uses fail-fast for register_functions, and stopping early keeps
 * the diagnostic shape simple while still giving the user a precise
 * source-spanned message.
 *
 * Issues: (wfCap) (wfThrow).
 */

import { Span } from "src/common/token.nx"
import { TypeExpr, TyRef, TyArrow, TyLinear, TyLazy, TyBorrow, TyArray, TyList, TyRecord, TyRow, TyUserDefined, NamedType, EnumDef, VariantDef, VariantField, RecordDef } from "src/common/ast.nx"
import { HirCap, HirCapMethod, ExceptionGroupEntry, HirProgram, HirFunction, HirHandlerArm, HirHandlerBindingEntry, HirHandlerBinding, HirParam } from "src/ir/hir/types.nx"
import { TypeError, UnknownCapability, UnknownThrowVariant, RefEscapes, RefInnerLinear } from "src/typecheck/errors.nx"
import { VariantIndex, VariantInfo }, * as vidx from "src/common/variant_index.nx"
import { Option, Some, None } from "std:option"
import * as str from "std:str"
import * as list from "std:list"
import { is_linear_binding_type } from "src/ir/shared/type_pred.nx"
import { suggest_names } from "src/common/levenshtein.nx"

// The seven WASI-grant capabilities. Kept here (rather than imported from
// main.nx) because tcwf lives in src/typecheck/ and driver depends on
// typecheck, not the other way around. The single source of truth for the
// runtime mapping is main.nx::perm_to_cap_name; adding a new system cap
// requires updating both places (small, intentional duplication — there
// are seven entries and they essentially never change).

/** True when `name` is one of the seven system capabilities defined by
 *  the spec's `SysCaps` set (`PermFs`, `PermNet`, `PermConsole`,
 *  `PermRandom`, `PermClock`, `PermProc`, `PermEnv`). */
export let is_sys_cap = fn (name: string) -> bool do
  if name == "PermFs" then return true end
  if name == "PermNet" then return true end
  if name == "PermConsole" then return true end
  if name == "PermRandom" then return true end
  if name == "PermClock" then return true end
  if name == "PermProc" then return true end
  if name == "PermEnv" then return true end
  return false
end

// Cap names land in HirCap.name canonically renamed to
// "<sanitized_path>#<bare>" (see src/ir/rdrname.nx::canonical_name). The
// require row, however, carries the source-level identifier — bare
// `Clock`, not `nxlib_stdlib_clock_nx#Clock` — so we compare against the
// suffix after the last '#'. When no '#' is present (e.g. local caps
// in the entry file), the full string is the bare name.
//
// Exported so that inject_cap_entries_acc (effects.nx) can use the same
// stripping logic when extending the ambient require row with handler cap
// names — ensuring the ambient row always carries bare names that match
// the unqualified names in handler `require { ... }` rows.
export let base_name_of = fn (qualified: string) -> string do
  let n = str.length(s: qualified)
  let idx = last_index_of_hash(s: qualified, i: n - 1)
  if idx < 0 then return qualified end
  return str.substring(s: qualified, start: idx + 1, len: n - idx - 1)
end

let last_index_of_hash = fn (s: string, i: i64) -> i64 do
  if i < 0 then return 0 - 1 end
  // 35 = ASCII '#'
  if str.char_code(s, idx: i) == 35 then return i end
  return last_index_of_hash(s, i: i - 1)
end

let cap_declared = fn (name: string, caps: [HirCap]) -> bool do
  match caps do
    | [] -> return false
    | HirCap(name: cn, methods: _) :: rest ->
      if base_name_of(qualified: cn) == name then return true end
      return cap_declared(name, caps: rest)
  end
end

/** Collect all candidate cap names: sys caps + declared caps (bare names). */
let cap_candidates = fn (caps: [HirCap]) -> [string] do
  let sys = ["PermFs", "PermNet", "PermConsole", "PermRandom", "PermClock", "PermProc", "PermEnv"]
  return cap_candidates_go(caps, acc: sys)
end

let cap_candidates_go = fn (caps: [HirCap], acc: [string]) -> [string] do
  match caps do
    | [] -> return acc
    | HirCap(name: cn, methods: _) :: rest ->
      return cap_candidates_go(caps: rest, acc: base_name_of(qualified: cn) :: acc)
  end
end

let check_cap_entries = fn (entries: [TypeExpr], caps: [HirCap], span: Span) -> unit throws { TypeError } do
  match entries do
    | [] -> return ()
    | t :: rest ->
      match t do
        | TyUserDefined(name: n, args: _) ->
          if is_sys_cap(name: n) then
            return check_cap_entries(entries: rest, caps, span)
          end
          if cap_declared(name: n, caps) then
            return check_cap_entries(entries: rest, caps, span)
          end
          let sugs = suggest_names(typo: n, candidates: cap_candidates(caps))
          throw UnknownCapability(name: n, suggestions: sugs, span)
        // Row entries are constrained to be identifiers; non-identifier shapes
        // (TyVar/TyArrow/...) are rejected at the parser. If one slips
        // through, treat it as unknown to avoid silently admitting a malformed row.
        | _ -> throw UnknownCapability(name: "<non-identifier row entry>", suggestions: [], span)
      end
  end
end

/** wfCap(ρ_q): every named entry in the require row must be a system
 *  capability or a cap declared by `cap X`. The row tail (`{... | ?r}`)
 *  is unconstrained — tail vars are pinned by unification at use sites,
 *  which transitively inherits well-formedness from the closed-row context.
 *
 *  `span` is the span of the introducing site (fn-arrow, handler arm)
 *  used as the diagnostic location when no per-entry span is available.
 */
export let wf_cap = fn (row: TypeExpr, caps: [HirCap], span: Span) -> unit throws { TypeError } do
  match row do
    | TyRow(types: ts, rest: _) -> return check_cap_entries(entries: ts, caps, span)
    // Non-row require slots (TyUnit / TyVar) bypass the check — they only
    // appear via parser defaults or generic-arg substitution that pre-row.
    | _ -> return ()
  end
end

let group_declared = fn (name: string, groups: [ExceptionGroupEntry]) -> bool do
  match groups do
    | [] -> return false
    | ExceptionGroupEntry(name: gn, members: _) :: rest ->
      if gn == name then return true end
      return group_declared(name, groups: rest)
  end
end

let is_exn_variant = fn (name: string, vidx_: VariantIndex) -> bool do
  match vidx.lookup_variant_info(idx: vidx_, variant: name) do
    | Some(val: VariantInfo(enum_name: en, type_params: _, def: _)) ->
      // Only variants of the Exn enum count as "constructor of Exn".
      // A variant from another enum (e.g. List.Cons) sharing a name would
      // not satisfy the throws-row well-formedness criterion.
      return en == "Exn"
    | None -> return false
  end
end

/** Collect all exception/group names usable in a throws row: group names +
 *  each group's member names. The universal sentinel `Exn` is included too
 *  so users who typo "Exn" as e.g. "Exnn" get a suggestion.
 */
let throw_candidates = fn (groups: [ExceptionGroupEntry]) -> [string] do
  return throw_candidates_go(groups, acc: ["Exn"])
end

let throw_candidates_go = fn (groups: [ExceptionGroupEntry], acc: [string]) -> [string] do
  match groups do
    | [] -> return acc
    | ExceptionGroupEntry(name: gn, members: ms) :: rest ->
      let acc2 = gn :: acc
      let acc3 = throw_candidates_members(ms, acc: acc2)
      return throw_candidates_go(groups: rest, acc: acc3)
  end
end

let throw_candidates_members = fn (members: [string], acc: [string]) -> [string] do
  match members do
    | [] -> return acc
    | m :: rest -> return throw_candidates_members(members: rest, acc: m :: acc)
  end
end

let check_throw_entries = fn (
  entries: [TypeExpr], vidx_: VariantIndex,
  groups: [ExceptionGroupEntry], span: Span
) -> unit throws { TypeError } do
  match entries do
    | [] -> return ()
    | t :: rest ->
      match t do
        | TyUserDefined(name: n, args: _) ->
          // The universal sentinel `Exn` is always admitted; T-Raise/T-TryCatch
          // already special-case it (see infer.nx::row_admits_exception).
          if n == "Exn" then return check_throw_entries(entries: rest, vidx_, groups, span) end
          if is_exn_variant(name: n, vidx_) then
            return check_throw_entries(entries: rest, vidx_, groups, span)
          end
          if group_declared(name: n, groups) then
            return check_throw_entries(entries: rest, vidx_, groups, span)
          end
          let sugs = suggest_names(typo: n, candidates: throw_candidates(groups))
          throw UnknownThrowVariant(name: n, suggestions: sugs, span)
        | _ -> throw UnknownThrowVariant(name: "<non-identifier row entry>", suggestions: [], span)
      end
  end
end

/** wfThrow(ρ_e): every named entry in the throws row must be either the
 *  universal `Exn` sentinel, a constructor (variant) of `Exn`, or a
 *  declared exception group. Tail vars are unconstrained (same rationale
 *  as wfCap).
 */
export let wf_throw = fn (
  row: TypeExpr, vidx_: VariantIndex,
  groups: [ExceptionGroupEntry], span: Span
) -> unit throws { TypeError } do
  match row do
    | TyRow(types: ts, rest: _) -> return check_throw_entries(entries: ts, vidx_, groups, span)
    | _ -> return ()
  end
end

// escapesRef(τ) — spec §"Gravity Rule": iff τ contains ~σ (TyRef) at any structurally reachable
// position: as the type itself, inside TyLinear/TyLazy/TyBorrow wrappers,
// as an array or list element, as a record field, or as the parameter/return
// of an arrow (function types may not expose ref cells in their signatures
// either — that path is caught at T-Lambda, but structural recursion into
// arrows ensures nested fn-returning-ref is also caught).
//
// The check does NOT recurse into TyArrow param/ret positions here: function
// types are first-class values and a `fn () -> ref(i64)` *type* in an outer
// return position would be caught at the outer function's declaration site.
// Only the *direct* TyRef in a return/field/escape position is our concern.
// Recursion into structural wrappers (Linear, Lazy, Borrow, Array, List,
// Record) is performed so that e.g. [~i64] or {f: ~i64} are also rejected.

/** `escapes_ref(τ)` — true iff τ contains a TyRef (~σ) at any structurally
 *  reachable position (spec §"Gravity Rule"). Used to enforce:
 *    - T-Return: ¬escapesRef(τ) on the inferred return type
 *    - T-Lambda / T-Let-PolyFn: ¬escapesRef(τ_r) on the declared ret type
 *    - D-External: ¬escapesRef(τ_r) on the external binding ret type
 */
export let escapes_ref = fn (typ: TypeExpr) -> bool do
  match typ do
    | TyRef(_) -> return true
    | TyLinear(inner: i) | TyLazy(inner: i) | TyBorrow(inner: i) -> return escapes_ref(typ: i)
    | TyArray(elem: e) | TyList(elem: e) -> return escapes_ref(typ: e)
    | TyRecord(fields: fs) -> return escapes_ref_named(types: fs)
    // Arrow: do not recurse — a fn-type in return position is not itself a
    // ref escape; the arrow's own ret-type is screened when that lambda is
    // registered (T-Lambda / T-Let-PolyFn enforcement).
    | _ -> return false
  end
end

let escapes_ref_named = fn (types: [NamedType]) -> bool do
  match types do
    | [] -> return false
    | NamedType(name: _, typ: t) :: rest ->
      if escapes_ref(typ: t) then return true end
      return escapes_ref_named(types: rest)
  end
end

/** Enforce ¬escapesRef(τ) at a declaration/return site. Throws `RefEscapes`
 *  if τ contains a mutable-reference type. `context` is a short description
 *  for the diagnostic (e.g. "return type of 'foo'" or "return statement").
 */
export let enforce_no_escapes_ref = fn (typ: TypeExpr, context: string, span: Span) -> unit throws { TypeError } do
  if escapes_ref(typ) then
    throw RefEscapes(context, span)
  end
end

// wfRef (spec §wfRef): wfRef(~σ) ⟺ ¬linear(σ).
// A ref cell's inner type must not be linear — each deref (~x) would
// otherwise produce a fresh copy of the linear payload, duplicating the
// resource and violating single-use discipline.
// We check every parameter type annotation: TyRef(inner) with TyLinear inner
// is rejected at declaration rather than letting ref(%T) smuggle through.
//
// Enforcement sites: fn param slots, cap method signatures, external
// binding annotations, handler arm params. The return-type slot goes
// through enforce_no_escapes_ref (gravity rule) — only wfRef needed here.

/** Enforce wfRef on a single parameter type: if it is `~σ` (TyRef) and
 *  σ is structurally linear (spec `linear(σ)` predicate), throw `RefInnerLinear`.
 *  `param` is the parameter label used for the diagnostic.
 */
let enforce_wf_ref_one = fn (typ: TypeExpr, param: string, span: Span, tdefs: [RecordDef]) -> unit throws { TypeError } do
  match typ do
    | TyRef(inner: i) ->
      if is_linear_binding_type(t: i, tdefs, enum_defs: []) then throw RefInnerLinear(param, span) end
      return ()
    | _ -> return ()
  end
end

/** Enforce wfRef over a list of named parameter types. Each parameter whose
 *  declared type is `~σ` is checked: if σ is structurally linear the function
 *  throws `RefInnerLinear` naming the offending parameter label.
 */
export let enforce_wf_ref_params = fn (params: [NamedType], span: Span, tdefs: [RecordDef]) -> unit throws { TypeError } do
  match params do
    | [] -> return ()
    | NamedType(name: n, typ: t) :: rest ->
      enforce_wf_ref_one(typ: t, param: n, span, tdefs)
      return enforce_wf_ref_params(params: rest, span, tdefs)
  end
end

// Used by `walk_funcs` and `walk_handler_arms` (pre-DCE whole-program pass)
// to extract parameter type annotations from HirFunction.params so that
// `enforce_wf_ref_params` can check them. A separate helper rather than
// an import of check.nx::hir_params_to_named_types because tcwf.nx must
// not import typecheck/check.nx (circular dependency).

let hir_params_to_named_types_tcwf = fn (params: [HirParam]) -> [NamedType] do
  return hir_params_to_nt_go(params, acc: [])
end

let hir_params_to_nt_go = fn (params: [HirParam], acc: [NamedType]) -> [NamedType] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: l, name: _, sigil: _, typ: t) :: rest ->
      return hir_params_to_nt_go(params: rest, acc: NamedType(name: l, typ: t) :: acc)
  end
end

// `check_program_wf_rows` runs wfCap/wfThrow over every function in the
// program. Invoked on the post-build, pre-DCE HirProgram so a typo in an
// unused (dead-code) function is still caught — a typo'd row entry on an
// unused function would otherwise never surface.

let variant_index_of = fn (enum_defs: [EnumDef]) -> VariantIndex do
  return vidx.build_variant_index(defs: enum_defs)
end

let walk_funcs = fn (
  funcs: [HirFunction], caps: [HirCap],
  vidx_: VariantIndex, groups: [ExceptionGroupEntry], tdefs: [RecordDef]
) -> unit throws { TypeError } do
  match funcs do
    | [] -> return ()
    | HirFunction(name: fn_name, type_params: _, params: fn_params, ret_type: ret, throw_row: tw, body: _, span: sp, file: _, requires: req) :: rest ->
      wf_cap(row: req, caps, span: sp)
      wf_throw(row: tw, vidx_, groups, span: sp)
      // Gravity rule: ¬escapesRef(τ_r) on the declared return type.
      // Pre-DCE so even unused functions with `ref(T)` return types are rejected.
      enforce_no_escapes_ref(typ: ret, context: "return type of '" ++ fn_name ++ "'", span: sp)
      // wfRef on parameter types: pre-DCE so even unused functions with ref(%T) params are rejected.
      let fn_param_nts = hir_params_to_named_types_tcwf(params: fn_params)
      enforce_wf_ref_params(params: fn_param_nts, span: sp, tdefs)
      return walk_funcs(funcs: rest, caps, vidx_, groups, tdefs)
  end
end

let walk_handler_bindings = fn (
  hbs: [HirHandlerBindingEntry], caps: [HirCap],
  vidx_: VariantIndex, groups: [ExceptionGroupEntry], tdefs: [RecordDef]
) -> unit throws { TypeError } do
  match hbs do
    | [] -> return ()
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(cap_name: _, requires: _, arms)) :: rest ->
      walk_handler_arms(arms, caps, vidx_, groups, tdefs)
      return walk_handler_bindings(hbs: rest, caps, vidx_, groups, tdefs)
  end
end

let walk_handler_arms = fn (
  arms: [HirHandlerArm], caps: [HirCap],
  vidx_: VariantIndex, groups: [ExceptionGroupEntry], tdefs: [RecordDef]
) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(arm: HirFunction(name: _, type_params: _, params: arm_ps, ret_type: _, throw_row: tw, body: _, span: sp, file: _, requires: req), cont_binder: _) :: rest ->
      wf_cap(row: req, caps, span: sp)
      wf_throw(row: tw, vidx_, groups, span: sp)
      // wfRef on handler arm parameter types.
      let arm_param_nts = hir_params_to_named_types_tcwf(params: arm_ps)
      enforce_wf_ref_params(params: arm_param_nts, span: sp, tdefs)
      return walk_handler_arms(arms: rest, caps, vidx_, groups, tdefs)
  end
end

let walk_caps = fn (
  caps: [HirCap], all_caps: [HirCap],
  vidx_: VariantIndex, groups: [ExceptionGroupEntry]
) -> unit throws { TypeError } do
  match caps do
    | [] -> return ()
    | HirCap(name: _, methods) :: rest ->
      walk_cap_methods(methods, all_caps, vidx_, groups)
      return walk_caps(caps: rest, all_caps, vidx_, groups)
  end
end

let walk_cap_methods = fn (
  methods: [HirCapMethod], caps: [HirCap],
  vidx_: VariantIndex, groups: [ExceptionGroupEntry]
) -> unit throws { TypeError } do
  match methods do
    | [] -> return ()
    | HirCapMethod(name: _, requires: req, span: sp, throw_row: tw, typ_params: _, typ_ret: _) :: rest ->
      wf_cap(row: req, caps, span: sp)
      wf_throw(row: tw, vidx_, groups, span: sp)
      return walk_cap_methods(methods: rest, caps, vidx_, groups)
  end
end

let walk_caps_wf_ref = fn (
  caps: [HirCap], vidx_: VariantIndex, groups: [ExceptionGroupEntry], tdefs: [RecordDef]
) -> unit throws { TypeError } do
  match caps do
    | [] -> return ()
    | HirCap(name: _, methods) :: rest ->
      walk_cap_methods_wf_ref(methods, vidx_, groups, tdefs)
      return walk_caps_wf_ref(caps: rest, vidx_, groups, tdefs)
  end
end

let walk_cap_methods_wf_ref = fn (
  methods: [HirCapMethod], vidx_: VariantIndex, groups: [ExceptionGroupEntry], tdefs: [RecordDef]
) -> unit throws { TypeError } do
  match methods do
    | [] -> return ()
    | HirCapMethod(name: mname, requires: _, span: sp, throw_row: _, typ_params: mparams, typ_ret: mret) :: rest ->
      // Gravity rule: ¬escapesRef(κ_j) on D-Cap method return type (spec §escapesRef table, D-Cap).
      enforce_no_escapes_ref(typ: mret, context: "return type of cap method '" ++ mname ++ "'", span: sp)
      // wfRef on D-Cap method parameter types (spec §wfRef table, D-Cap).
      let method_param_nts = hir_params_to_named_types_tcwf(params: mparams)
      enforce_wf_ref_params(params: method_param_nts, span: sp, tdefs)
      return walk_cap_methods_wf_ref(methods: rest, vidx_, groups, tdefs)
  end
end

// D-Type-Sum / D-Type-Sum-Opaque wfRef + escapesRef enforcement
// (spec §wfRef table row "Field types of a sum-type variant" and
//  §escapesRef table row "Field types of a sum-type variant").
// EnumDef/RecordDef carry no span; Span(0,0,0) used as in D-External.

let variant_field_context = fn (field_name: Option<string>, idx: i64, variant_name: string, enum_name: string) -> string do
  match field_name do
    | Some(val: n) -> return "field '" ++ n ++ "' of variant '" ++ variant_name ++ "' in type '" ++ enum_name ++ "'"
    | None -> return "field #" ++ str.from_i64(val: idx) ++ " of variant '" ++ variant_name ++ "' in type '" ++ enum_name ++ "'"
  end
end

let walk_variant_fields = fn (
  fields: [VariantField], idx: i64, variant_name: string, enum_name: string,
  tdefs: [RecordDef], enum_defs: [EnumDef]
) -> unit throws { TypeError } do
  match fields do
    | [] -> return ()
    | VariantField(name: mname, typ: t) :: rest ->
      let ctx = variant_field_context(field_name: mname, idx, variant_name, enum_name)
      // wfRef: if t = ref(σ) and linear(σ), reject.
      match t do
        | TyRef(inner: i) ->
          if is_linear_binding_type(t: i, tdefs, enum_defs) then
            throw RefInnerLinear(param: ctx, span: Span(offset: 0, line: 0, col: 0))
          end
        | _ -> ()
      end
      // escapesRef: reject ref(σ) at any structurally reachable position.
      enforce_no_escapes_ref(typ: t, context: ctx, span: Span(offset: 0, line: 0, col: 0))
      return walk_variant_fields(fields: rest, idx: idx + 1, variant_name, enum_name, tdefs, enum_defs)
  end
end

let walk_variants = fn (
  variants: [VariantDef], enum_name: string,
  tdefs: [RecordDef], enum_defs: [EnumDef]
) -> unit throws { TypeError } do
  match variants do
    | [] -> return ()
    | VariantDef(name: vname, fields: fs) :: rest ->
      walk_variant_fields(fields: fs, idx: 0, variant_name: vname, enum_name, tdefs, enum_defs)
      return walk_variants(variants: rest, enum_name, tdefs, enum_defs)
  end
end

let walk_enum_defs = fn (
  defs: [EnumDef], tdefs: [RecordDef], enum_defs: [EnumDef]
) -> unit throws { TypeError } do
  match defs do
    | [] -> return ()
    | EnumDef(name: ename, is_public: _, is_opaque: _, type_params: _, variants: vs) :: rest ->
      walk_variants(variants: vs, enum_name: ename, tdefs, enum_defs)
      return walk_enum_defs(defs: rest, tdefs, enum_defs)
  end
end

// D-Type-Record wfRef + escapesRef enforcement
// (spec §wfRef table row "Field types of a record type declaration" and
//  §escapesRef table row "Field types of a record type declaration").

let walk_record_fields = fn (
  fields: [NamedType], type_name: string,
  tdefs: [RecordDef], enum_defs: [EnumDef]
) -> unit throws { TypeError } do
  match fields do
    | [] -> return ()
    | NamedType(name: fname, typ: t) :: rest ->
      let ctx = "field '" ++ fname ++ "' of record type '" ++ type_name ++ "'"
      // wfRef: if t = ref(σ) and linear(σ), reject.
      match t do
        | TyRef(inner: i) ->
          if is_linear_binding_type(t: i, tdefs, enum_defs) then
            throw RefInnerLinear(param: ctx, span: Span(offset: 0, line: 0, col: 0))
          end
        | _ -> ()
      end
      // escapesRef: reject ref(σ) at any structurally reachable position.
      enforce_no_escapes_ref(typ: t, context: ctx, span: Span(offset: 0, line: 0, col: 0))
      return walk_record_fields(fields: rest, type_name, tdefs, enum_defs)
  end
end

let walk_type_defs = fn (
  defs: [RecordDef], tdefs: [RecordDef], enum_defs: [EnumDef]
) -> unit throws { TypeError } do
  match defs do
    | [] -> return ()
    | RecordDef(name: rname, is_public: _, type_params: _, fields: fs) :: rest ->
      walk_record_fields(fields: fs, type_name: rname, tdefs, enum_defs)
      return walk_type_defs(defs: rest, tdefs, enum_defs)
  end
end

/** Run wfCap and wfThrow over every introduction site in the program.
 *  Pre-DCE so unused functions with typo'd rows are still rejected.
 *  Covers D-Cap method signatures: ∀j∈J. wfCap(α_j) ∧ wfThrow(β_j).
 */
export let check_program_wf_rows = fn (prog: HirProgram) -> unit throws { TypeError } do
  let HirProgram(caps, functions: funcs, externals: _, handler_bindings: hbs, enum_defs: edefs, exception_groups: egs, value_binding_names: _, type_defs: tdefs, visible_enum_names: _) = prog
  let vi = variant_index_of(enum_defs: edefs)
  walk_caps(caps, all_caps: caps, vidx_: vi, groups: egs)
  // Gravity rule (¬escapesRef) + wfRef on D-Cap method signatures.
  walk_caps_wf_ref(caps, vidx_: vi, groups: egs, tdefs)
  walk_funcs(funcs, caps, vidx_: vi, groups: egs, tdefs)
  walk_handler_bindings(hbs, caps, vidx_: vi, groups: egs, tdefs)
  // D-Type-Sum / D-Type-Sum-Opaque: wfRef + escapesRef on variant fields.
  walk_enum_defs(defs: edefs, tdefs, enum_defs: edefs)
  // D-Type-Record: wfRef + escapesRef on record fields.
  return walk_type_defs(defs: tdefs, tdefs, enum_defs: edefs)
end
