/**
 * typecheck/check: Top-level program type checking entry point.
 *
 * Takes HirProgram, validates types of all functions, and returns
 * the HirProgram unchanged on success or raises CompileError.
 *
 * Sub-modules:
 *   check/builtins.nx      — add_builtins / build_enum_entries / build_type_def_entries
 *   check/occurs.nx        — occurs_tau/rho, enforce_kindof_quantifiers, convert_ud_to_var
 *   check/registration.nx  — register_functions / register_externals / register_caps /
 *                            alias fix-up (resolve_alias_registrations)
 *   check/handler_validation.nx — register_handler_bindings / validate_handler_arm_sets /
 *                            validate_inline_handler_arm_set (T-Handler)
 *   check/enum_registration.nx — register_enum_constructors / is_local
 *   check/main_validation.nx — validate_main + require/throw row checks
 */

import * as list from "std:list"
import * as lazy from "std:lazy"
import { heap_mark, heap_reset } from "std:runtime/arena"
import {
  TypeExpr,
  TyUnit,
  TyI64,
  TyUserDefined,
  TyVar,
  TyArrow,
  TyRef,
  TyLinear,
  TyLazy,
  TyBorrow,
  TyArray,
  TyList,
  TyRecord,
  TyRow,
  TyHandler,
  NamedType,
  EnumDef,
  RecordDef,
  VariantDef,
  VariantField
} from "src/types/type_expr.nx"
import {
  HirProgram,
  HirFunction,
  HirHandlerArm,
  HirParam,
  HirExternal,
  HirCap,
  HirCapMethod,
  HirHandlerBindingEntry,
  HirHandlerBinding,
  EagerBody,
  LazyBody,
  ExceptionGroupEntry,
  HirStmt,
  HirStmtKind,
  HirExpr,
  HirExprKind,
  HirCallArg,
  HirMatchCase,
  HirNamedExpr
} from "src/ir/hir/types.nx"
import { Span } from "src/types/span.nx"
import {
  TypeError,
  TypeMismatch,
  MissingMain,
  MainNotFunction,
  MainNotUnit,
  MainThrowsTooBroad,
  MainRequiresTooBroad,
  DuplicateTopLevelBinding,
  UnusedTypeParam,
  KindClashTypeParam,
  RefEscapes
} from "src/typecheck/errors.nx"
import {
  CheckState,
  Scheme,
  EnvEntry,
  EnumEntry,
  TypeDefEntry,
  InferExprOk,
  InferExprErr,
  UnifyOk,
  UnifyErr
}, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as unify from "src/typecheck/unify.nx"
import * as infer from "src/typecheck/infer.nx"
import { infer_stmts_tail_diverges } from "src/typecheck/infer/control_flow.nx"
import * as tcwf from "src/typecheck/tcwf.nx"
import {
  add_builtins,
  build_enum_entries,
  build_enum_entries_full,
  build_type_def_entries
} from "src/typecheck/check/builtins.nx"
import {
  convert_ud_to_var,
  convert_named_types,
  convert_hir_params,
  str_list_contains
} from "src/typecheck/check/occurs.nx"
import {
  hir_params_to_named_types,
  register_externals, register_functions, register_caps,
  alias_src_name, resolve_alias_registrations
} from "src/typecheck/check/registration.nx"
import { derive_generic_cap_contracts } from "src/typecheck/check/cap_contract.nx"
import { resolve_value_binding_types } from "src/typecheck/check/value_binding.nx"
import {
  register_handler_bindings, validate_handler_arm_sets
} from "src/typecheck/check/handler_validation.nx"
import { register_enum_constructors, is_local } from "src/typecheck/check/enum_registration.nx"
import { validate_main } from "src/typecheck/check/main_validation.nx"
import { check_cont_no_escape_stmts } from "src/typecheck/check/cont_escape.nx"
import { build_module_variant_index } from "src/ir/support/variant_index.nx"
import { ModuleImportIndex } from "src/typecheck/import_index.nx"

// ─── Public entry point ─────────────────────────────────────────────────────

/** Run the typechecker over an `HirProgram`: validates every function body, returns the program unchanged on success, raises `TypeError` on any mismatch. `require_main` enables main-signature checks. */
export let check_program = fn (
  hir: HirProgram,
  local_names: [ string ],
  import_index: ModuleImportIndex,
  require_main: bool
) -> HirProgram throws { TypeError } do
  let HirProgram(
    caps,
    functions: funcs,
    externals: exts,
    handler_bindings: hbs,
    enum_defs: edefs,
    exception_groups: egs,
    value_binding_names: _,
    type_defs: tdefs,
    visible_enum_names: venms
  ) = hir
  // build_enum_entries receives the visible_enum_names filter so it can strip
  // variants of non-visible enums in the typecheck VariantIndex. Codegen uses
  // enum_defs directly (full variants preserved).
  let enum_entries = build_enum_entries(defs: edefs, visible_names: venms)
  let enum_entries2 = add_builtins(entries: enum_entries)
  /** Full (visibility-unstripped) enum entries seed CheckState.full_enum_defs,
   *  consulted ONLY by the match exhaustiveness / redundancy check so an
   *  imported function body sees its own module's real variant set rather than
   *  the [] left by D-Export stripping. */
  let full_enum_entries = add_builtins(entries: build_enum_entries_full(defs: edefs))
  // TypeDefEntry list lets the unifier expand `TyUserDefined("Foo", _)`
  // into its underlying record shape.
  let type_def_entries = build_type_def_entries(defs: tdefs)
  let state0 = tctypes.tc_new_state(
    enum_defs: enum_entries2,
    type_defs: type_def_entries,
    exception_groups: egs,
    full_enum_defs: full_enum_entries
  )
  let state_mvi = tctypes.state_with_module_variant_index(
    state: state0,
    module_variant_index: build_module_variant_index(defs: edefs)
  )
  let state = tctypes.state_with_module_import_index(
    state: state_mvi,
    module_import_index: import_index
  )

  // Pass 1: Register all signatures
  let st1 = register_externals(state, exts, tdefs)
  // Register-time wfCap/wfThrow needs the full cap + exception vocabulary
  // visible (other files' caps get pulled in via import collection). We
  // pass `caps` and `egs` directly because CheckState does not carry the
  // raw cap list (only env entries for their methods).
  let st2 = register_functions(state: st1, funcs, caps, exception_groups: egs, tdefs)
  // Pass 1a-alias: D-Let-Top → T-Let-Alias fix-up.
  // Overwrites env entries for alias-pattern functions with the source scheme.
  let st2a = resolve_alias_registrations(state: st2, funcs)
  let st3 = register_caps(state: st2a, caps, exception_groups: egs)
  // Store caps in state so inline-handler arm-set validation (T-Handler) can
  // access the declared method names from within infer_expr.
  let st3b = tctypes.state_with_caps(state: st3, caps)
  // Pass 1b: T-Handler arm/method 1-1 correspondence (spec §T-Handler).
  // Reject any handler that supplies an extra arm or omits a declared cap method
  // before any signature/body is registered; missing arms would otherwise leave
  // a cap-method slot unimplemented and turn into runtime UB at cap-call
  // dispatch, and extra arms would silently introduce a never-routed name.
  validate_handler_arm_sets(caps, hbs)
  let st4 = register_handler_bindings(state: st3b, hbs, caps, exception_groups: egs, tdefs)
  let st5 = register_enum_constructors(state: st4, defs: edefs, visible_names: venms)

  let cont_binder_map = build_cont_binder_map(hbs)

  // Build the fn_pure_set: names of top-level functions whose bodies are
  // provably non-throwing (no direct Raise, no call to a can-throw function).
  // Used by check_call_throw_row_admitted to admit unannotated callees that
  // are statically pure under a `throws {}` caller.
  let pure_set = build_fn_pure_set(funcs, exts)
  let st6 = tctypes.state_with_fn_pure_set(state: st5, fn_pure_set: pure_set)

  // Slot-reading intrinsics (externals whose wasm symbol is `value_of_i64`):
  // the only callees a `with @k` continuation binder may be passed to as a value
  // (they bitcast it to its raw i64 cont-table slot and never force it). Used by
  // the cont-binder escape check so the cooperative scheduler's `kont_slot(k: k)`
  // is admitted while a binder passed to any forcing callee is rejected.
  let safe_callees = collect_slot_read_external_names(exts)

  // Generic-cap soundness (nexus-3ibql): derive each generic-cap-requiring
  // function's committed element contract by REAL body inference over a
  // call-graph fixpoint, re-publishing `require { Box<i64> }` onto its scheme.
  // Runs after every signature/cap/enum is registered (inference inside the
  // pass needs the full env) and before body checking, which then sees the
  // refined callee contracts at call sites (check_cap_args_covered). A no-op for
  // programs with no generic caps.
  let st7 = derive_generic_cap_contracts(state: st6, funcs, caps)

  /** Resolve each top-level value binding's REAL type. A `let x = <non-literal>`
   *  with no annotation is registered with the `() -> i64` placeholder (HIR
   *  build cannot infer without an env); referrers of such a binding would
   *  otherwise see a value of declared type `i64` where the real value is e.g. a
   *  `Span`. This pass infers the initializer and re-publishes the scheme as
   *  `() -> realT` for STRUCTURED results, before any referrer body is checked.
   *  Best-effort and inert on the live path (no root-local body references these
   *  placeholder bindings, so no local check result changes). */
  let st7b = resolve_value_binding_types(state: st7, funcs)

  check_all_functions(state: st7b, funcs, local_names, cont_map: cont_binder_map, safe_callees)

  // Pass 2b: Check handler arm bodies (synthesised function names aren't in
  // local_names, so they're missed by check_all_functions). With-kont arms
  // need their body re-checked with the cont binder bound in env so that
  // forcing @k at the wrong type is a TypeMismatch.
  check_handler_arm_bodies(state: st7, hbs, safe_callees)

  // Validate main exists and has correct signature. Skipped for library-only
  // typecheck (require_main=false): files with only exports are legitimate
  // imports for other modules and have no executable entry point.
  if require_main then
    validate_main(state: st7, funcs)
  end

  return hir
end

// ─── Continuation-binder map ─────────────────────────────────────────────────

/** Map from synthesised arm function name (e.g. `__handler_scheduler_yield`)
 *  to the `with @k` binder name. Empty for arms without cont_binder.
 */
type ContBinderMap = ContBinderMap(entries: [ ContBinderEntry ])
type ContBinderEntry = ContBinderEntry(arm_fn_name: string, binder: string)

let build_cont_binder_map = fn (hbs: [ HirHandlerBindingEntry ]) -> ContBinderMap throws { TypeError } do
  return ContBinderMap(entries: build_cont_binder_entries(hbs, acc: []))
end

let build_cont_binder_entries = fn (
  hbs: [ HirHandlerBindingEntry ],
  acc: [ ContBinderEntry ]
) -> [ ContBinderEntry ] throws { TypeError } do
  match hbs do
    | [] -> return acc
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: _, requires: _, arms)
    ) :: rest ->
      let acc2 = collect_arm_binders(arms, acc)
      return build_cont_binder_entries(hbs: rest, acc: acc2)
  end
end

let collect_arm_binders = fn (
  arms: [ HirHandlerArm ],
  acc: [ ContBinderEntry ]
) -> [ ContBinderEntry ] throws { TypeError } do
  match arms do
    | [] -> return acc
    | HirHandlerArm(
      arm: HirFunction(name: fname, type_params: _, params: _, ret_type: _, _),
      cont_binder: Some(val: k)
    ) :: rest ->
      return collect_arm_binders(
        arms: rest,
        acc: ContBinderEntry(arm_fn_name: fname, binder: k) :: acc
      )
    | _ :: rest -> return collect_arm_binders(arms: rest, acc)
  end
end

let lookup_cont_binder = fn (fname: string, map: ContBinderMap) -> Option<string> do
  let ContBinderMap(entries) = map
  return lookup_cont_binder_in(fname, entries)
end

let lookup_cont_binder_in = fn (fname: string, entries: [ ContBinderEntry ]) -> Option<string> do
  match entries do
    | [] -> return None
    | ContBinderEntry(arm_fn_name: an, binder: b) :: rest ->
      if an == fname then return Some(val: b) end
      return lookup_cont_binder_in(fname, entries: rest)
  end
end

// ─── Check all function bodies ──────────────────────────────────────────────
//
// Parallelism: when list.length(funcs) > tc_parallel_threshold(), function
// bodies are dispatched as `@bool` thunks via `lazy.force_all` (WASI threads
// / sequential-force fallback), mirroring `nexus lint`'s `collect_parallel` /
// `parallel_threshold` design.  `@bool` (not `@unit`) avoids the unit-closure
// codegen gap: unit closures produce no i64 on the WASM value stack.
// For N <= threshold the sequential path is taken so that small files and any
// wasm context without threads never reach force_all.  Results arrive in input
// order (force_all joins left-to-right), so TypeError diagnostics are reported
// in the same deterministic order as the sequential path.

/** File-count threshold below which the sequential path is taken.
 *  Set to 2 so that single-function files never call force_all, which requires
 *  WASI threads.  Large programs (the compiler itself etc.) take the parallel
 *  path.
 */
let tc_parallel_threshold = fn () -> i64 do return 2 end

/** Check one function body, reclaiming its transient typecheck allocations
 *  before returning. A `check_function` call returns `unit` and reads only the
 *  pre-allocated `state`, so every allocation it makes (freshened type vars,
 *  substitutions, inference scratch) is dead once it completes. Bracketing the
 *  call with `heap_mark`/`heap_reset` frees that scratch in O(1), keeping the
 *  body-check loop's peak bump-allocator usage bounded by a single function's
 *  working set rather than the cumulative sum over every checked function. The
 *  mark is taken after `state` was built (by the caller), so resetting to it
 *  never reclaims the loop's own inputs. Without this, a body-check pass over a
 *  large function set walks the bump pointer toward the 4GB wasm32 ceiling and
 *  trips the allocator's overflow trap. */
let check_function_bounded = fn (
  state: CheckState,
  func: HirFunction,
  cont_map: ContBinderMap,
  safe_callees: [ string ]
) -> unit throws { TypeError } do
  let mark = heap_mark()
  check_function(state, func, cont_map, safe_callees)
  heap_reset(mark: mark)
  return ()
end

/** Sequential body-check: mirror of the original check_all_functions loop.
 *  Used for N <= tc_parallel_threshold() and as the guaranteed-safe fallback.
 */
let check_all_sequential = fn (
  state: CheckState,
  funcs: [ HirFunction ],
  local_names: [ string ],
  cont_map: ContBinderMap,
  safe_callees: [ string ]
) -> unit throws { TypeError } do
  match funcs do
    | [] -> return ()
    | func :: rest ->
      let HirFunction(name: _, type_params: _, params: _, ret_type: _, _) = func
      match alias_src_name(func) do
        | Some(val: _) -> ()
        | None -> check_function_bounded(state, func, cont_map, safe_callees)
      end
      return check_all_sequential(state, funcs: rest, local_names, cont_map, safe_callees)
  end
end

/** Build a list of `@unit` thunks — one per qualifying function (local, non-alias).
 *  Alias-pattern functions and non-local functions are silently skipped.
 *  The `throws { TypeError }` annotation propagates from the deferred
 *  `check_function` calls captured inside each thunk.
 */
let build_check_thunks = fn (
  state: CheckState,
  funcs: [ HirFunction ],
  local_names: [ string ],
  cont_map: ContBinderMap,
  safe_callees: [ string ],
  acc: [ @unit ]
) -> [ @unit ] throws { TypeError } do
  match funcs do
    | [] -> return list.reverse(xs: acc)
    | func :: rest ->
      let HirFunction(name: _, type_params: _, params: _, ret_type: _, _) = func
      match alias_src_name(func) do
        | Some(val: _) ->
          return build_check_thunks(state, funcs: rest, local_names, cont_map, safe_callees, acc)
        | None ->
          let @t = check_function_bounded(state, func, cont_map, safe_callees)
          return build_check_thunks(
            state,
            funcs: rest,
            local_names,
            cont_map,
            safe_callees,
            acc: t :: acc
          )
      end
  end
end

/** Parallel body-check: bind each qualifying check_function call as an @unit
 *  thunk, then hand the list to lazy.force_all.  Results arrive in input
 *  order (force_all joins left-to-right), so diagnostic order is deterministic.
 *  Requires WASI threads; only called when N > tc_parallel_threshold().
 */
let check_all_parallel = fn (
  state: CheckState,
  funcs: [ HirFunction ],
  local_names: [ string ],
  cont_map: ContBinderMap,
  safe_callees: [ string ]
) -> unit throws { TypeError } do
  let thunks = build_check_thunks(state, funcs, local_names, cont_map, safe_callees, acc: [])
  lazy.force_all(tasks: thunks)
  return ()
end

/** Dispatch to sequential or parallel body-check depending on function count.
 *  For N <= tc_parallel_threshold(), uses the sequential path (safe in all
 *  wasm contexts).  For N > threshold, uses the parallel path via force_all.
 */
let check_all_functions = fn (
  state: CheckState,
  funcs: [ HirFunction ],
  local_names: [ string ],
  cont_map: ContBinderMap,
  safe_callees: [ string ]
) -> unit throws { TypeError } do
  let n = list.length(xs: funcs)
  if n <= tc_parallel_threshold() then
    return check_all_sequential(state, funcs, local_names, cont_map, safe_callees)
  else
    return check_all_parallel(state, funcs, local_names, cont_map, safe_callees)
  end
end

let check_handler_arm_bodies = fn (
  state: CheckState,
  hbs: [ HirHandlerBindingEntry ],
  safe_callees: [ string ]
) -> unit throws { TypeError } do
  match hbs do
    | [] -> return ()
    | HirHandlerBindingEntry(
      name: _,
      binding: HirHandlerBinding(cap_name: _, requires: hreq, arms)
    ) :: rest ->
      // `hreq` is the handler's declared `require { … }` row — the ambient ρ_q
      // for every arm body (spec T-Handler / T-Inject). Thread it down so cap
      // calls inside an arm are checked against it (T-CapCall x ∈ ρ_q).
      check_arm_bodies(state, arms, handler_req: hreq, safe_callees)
      return check_handler_arm_bodies(state, hbs: rest, safe_callees)
  end
end

let check_arm_bodies = fn (
  state: CheckState,
  arms: [ HirHandlerArm ],
  handler_req: TypeExpr,
  safe_callees: [ string ]
) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(arm: f, cont_binder: kb) :: rest ->
      // Every arm body is checked here: synthesised arm function names are not
      // in `local_names`, so `check_all_functions` never visits them. With-kont
      // arms additionally bind @k in env. Both paths must pin the handler's
      // require row as ambient ρ_q.
      check_arm_body(state, func: f, cont_binder: kb, handler_req, safe_callees)
      return check_arm_bodies(state, arms: rest, handler_req, safe_callees)
  end
end

/** Close the implicit-open tail of a cap-method/arm throw row.
 *
 *  An absent `throws` clause parses to `TyRow([], Some(TyVar("__implicit")))`
 *  — an open row that the inference engine treats as effect-polymorphic (any
 *  throw admitted) for backward-compat with un-annotated function arrows. A
 *  handler arm body, however, is the runtime implementation of a cap method:
 *  its published interface is the cap-method declaration, and an absent throws
 *  clause there means "raises nothing". We therefore strip only the
 *  `__implicit` tail, turning it into a closed row while preserving any
 *  concrete labels (a thunk-deferred `TyRow([E], Some(__implicit))` keeps E but
 *  loses the open tail). Genuine effect-polymorphic tails (fresh inference
 *  variables) and already-closed rows are returned unchanged.
 */
let close_implicit_throw_row = fn (row: TypeExpr) -> TypeExpr do
  match row do
    | TyRow(types: ts, rest: Some(val: TyVar(name: nm))) ->
      if nm == "__implicit" then return TyRow(types: ts, rest: None) end
      return row
    | _ -> return row
  end
end

let check_arm_body = fn (
  state: CheckState,
  func: HirFunction,
  cont_binder: Option<string>,
  handler_req: TypeExpr,
  safe_callees: [ string ]
) -> unit throws { TypeError } do
  let HirFunction(
    name,
    type_params: tps,
    params,
    ret_type: ret,
    throw_row: tw,
    body: hir_body,
    span: fn_span,
    file: fn_file,
    requires: _
  ) = func
  let body = match hir_body do | EagerBody(stmts: s) -> s | LazyBody(_) -> [] end
  // Reject indirect (non-direct-force, non-let-alias, non-slot-reader) uses of
  // the `with @k` continuation binder before inference, so the runtime
  // miscompile can never be reached (see check_cont_no_escape_stmts).
  match cont_binder do
    | Some(val: k) -> check_cont_no_escape_stmts(
      stmts: body,
      binders: [ k ],
      safe_callees,
      fname: name
    )
    | None -> ()
  end
  let conv_params = convert_hir_params(params, vars: tps)
  let conv_ret = convert_ud_to_var(typ: ret, vars: tps)
  let conv_tw = convert_ud_to_var(typ: tw, vars: tps)
  let body_env = add_func_params(env: tctypes.state_env(state), params: conv_params)
  // If the arm has `with @k`, bind k in env as @ret_type (pure thunk —
  // `throws {}` / `require {}`). Standard inference then catches
  // force-at-wrong-type mismatches.
  let body_env2 = match cont_binder do
    | Some(val: k) -> tctypes.env_insert(
      env: body_env,
      name: k,
      scheme: tctypes.mono(typ: TyLazy(inner: conv_ret, require_row: TyRow(types: [], rest: None), throw_row: TyRow(types: [], rest: None)))
    )
    | None -> body_env
  end
  let body_state = tctypes.state_with_env(state, env: body_env2)
  // T-Handler throws reconciliation: a handler arm IS the implementation of a
  // cap method, dispatched at runtime through the cap table. The arm body's
  // throws must therefore stay within the method's declared `throws` row — an
  // exception the body raises but the method does not declare escapes invisibly
  // (the main-wrap pass only wraps exceptions present in a body's *inferred*
  // throw row, so an unreconciled throw leaks straight to the host as a Wasm
  // exception under a closed `throws {}` entry point).
  //
  // `validate_handler_arm_throw_rows` already pins `arm_tw == method_tw`, so the
  // arm's own `conv_tw` is the method's declared row. The only gap is that an
  // *absent* `throws` clause parses to the open `__implicit` row (legacy
  // effect-polymorphism for un-annotated function arrows), which would admit any
  // throw. A cap-method declaration is an interface site, not legacy code: an
  // absent throws clause means the method publishes no exceptions, so close the
  // implicit tail before pinning it as the arm body's ambient throw row. This is
  // the throws-side sibling of the require-row pinning below (nexus-4twfh).
  let arm_throw_row = close_implicit_throw_row(row: conv_tw)
  let body_state2 = tctypes.state_with_throw_row(state: body_state, throw_row: arm_throw_row)
  // Pin the handler's declared require row as the arm body's ambient ρ_q so
  // T-CapCall (x ∈ ρ_q) rejects cap calls not covered by the handler require
  // row. Mirrors check_function's state_with_require_row; without this the arm
  // body inherits the surrounding (wide) require row and cap calls leak through
  // to a downstream MIR "no handler bound" failure instead of a typecheck error.
  let conv_req = convert_ud_to_var(typ: handler_req, vars: tps)
  let body_state3 = tctypes.state_with_require_row(state: body_state2, require_row: conv_req)
  let body_state4 = tctypes.state_with_current_module(state: body_state3, current_module: fn_file)
  match infer.infer_stmts(state: body_state4, stmts: body, ret_type: conv_ret) do
    | InferExprErr(message: m, span: err_span) ->
      throw TypeMismatch(func_name: name, detail: m, span: err_span)
    | InferExprOk(state: _, subst: _, typ: body_typ) ->
      // T-Continuation: for `with @k` arms, every control path must terminate
      // divergently (return, throw, or loop) — no implicit-unit fall-through,
      // because κ may be non-unit and the arm is obligated to produce one.
      // Mirror the same guard used in check_function for let-bound handlers.
      let is_kont_arm = match cont_binder do | Some(_) -> true | None -> false end
      let body_is_unit = if let TyUnit = body_typ then true else false end
      let ret_is_unit = if let TyUnit = conv_ret then true else false end
      if is_kont_arm && !ret_is_unit && body_is_unit && !infer_stmts_tail_diverges(
        stmts: body,
        depth: 64
      ) then
        throw TypeMismatch(
          func_name: name,
          detail: "return type is non-unit but body does not end with a `return` or `throw` on all paths (spec T-Lambda: τ_r ≠ unit ⟹ tail(s†) = ⊥)",
          span: fn_span
        )
      end
      return ()
  end
end

/** Resolved return type for a top-level value binding whose declared type is
 *  the `TyI64` placeholder. Returns `Some(structuredRet)` only when `func` is a
 *  nullary, non-type-param binding (params == [], tps == []) whose declared
 *  return type is exactly `TyI64` AND the value-binding pre-pass has published a
 *  structured `() -> ret` scheme for it in the env. `None` for every other
 *  function, and for placeholder bindings whose initializer stayed scalar /
 *  failed inference (their scheme is still the `() -> i64` placeholder, which
 *  `cur == TyI64` filters out). */
let resolved_value_binding_ret = fn (
  state: CheckState,
  name: string,
  tps: [ string ],
  params: [ HirParam ],
  declared: TypeExpr
) -> Option<TypeExpr> do
  match tps do | [] -> () | _ -> return None end
  match params do | [] -> () | _ -> return None end
  match declared do | TyUnit -> return None | _ -> () end
  let is_placeholder = if let TyVar(name: _) = declared then false else
    match declared do | TyI64 -> true | _ -> false end
  end
  if !is_placeholder then return None end
  match tctypes.state_lookup_scheme(state, name) do
    | Some(val: Scheme(vars: [], typ: TyArrow(params: [], ret: cur, requires: _, throw_row: _))) ->
      match cur do
        | TyI64 -> return None
        | _ -> return Some(val: cur)
      end
    | _ -> return None
  end
end

let check_function = fn (
  state: CheckState,
  func: HirFunction,
  cont_map: ContBinderMap,
  safe_callees: [ string ]
) -> unit throws { TypeError } do
  let HirFunction(
    name,
    type_params: tps,
    params,
    ret_type: ret,
    throw_row: tw,
    body: hir_body,
    span: fn_span,
    file: fn_file,
    requires: fn_req
  ) = func
  let body = match hir_body do | EagerBody(stmts: s) -> s | LazyBody(_) -> [] end
  // Reject indirect uses of a `with @k` continuation binder (let-bound handler
  // arm path; mirrors check_arm_body for inline handlers).
  match lookup_cont_binder(fname: name, map: cont_map) do
    | Some(val: k) -> check_cont_no_escape_stmts(
      stmts: body,
      binders: [ k ],
      safe_callees,
      fname: name
    )
    | None -> ()
  end
  let conv_params = convert_hir_params(params, vars: tps)
  /** A top-level value binding `let x = <non-literal>` carries the `TyI64`
   *  placeholder in its `ret_type` field (HIR build could not infer it). The
   *  value-binding pre-pass (resolve_value_binding_types) has, by now, inferred
   *  the real type and re-published the env scheme as `() -> realT`. Use that
   *  resolved return type when checking the binding's OWN body so a `return
   *  Span(...)` is validated against `Span` rather than the stale `i64`. Only
   *  nullary, non-type-param bindings whose scheme was resolved to a structured
   *  ret are affected; every other function uses its declared return type. */
  let conv_ret = match resolved_value_binding_ret(state, name, tps, params, declared: ret) do
    | Some(val: r) -> r
    | None -> convert_ud_to_var(typ: ret, vars: tps)
  end
  let conv_tw = convert_ud_to_var(typ: tw, vars: tps)
  let conv_req = convert_ud_to_var(typ: fn_req, vars: tps)
  let body_env = add_func_params(env: tctypes.state_env(state), params: conv_params)
  // If this function is a handler arm with `with @k`, bind k as @ret in the
  // body env (pure thunk — `throws {}` / `require {}`).
  // Standard inference catches force-at-wrong-type mismatches.
  let body_env2 = match lookup_cont_binder(fname: name, map: cont_map) do
    | Some(val: k) -> tctypes.env_insert(
      env: body_env,
      name: k,
      scheme: tctypes.mono(typ: TyLazy(inner: conv_ret, require_row: TyRow(types: [], rest: None), throw_row: TyRow(types: [], rest: None)))
    )
    | None -> body_env
  end
  let body_state = tctypes.state_with_env(state, env: body_env2)
  let body_state2 = tctypes.state_with_throw_row(state: body_state, throw_row: conv_tw)
  // Propagate the ambient require row so that inject-site checking (T-Inject
  // ∀i. ρ_i ⊆ ρ_q) can validate handler require rows against it.
  let body_state3 = tctypes.state_with_require_row(state: body_state2, require_row: conv_req)
  let body_state4 = tctypes.state_with_current_module(state: body_state3, current_module: fn_file)
  match infer.infer_stmts(state: body_state4, stmts: body, ret_type: conv_ret) do
    | InferExprErr(message: m, span: err_span) ->
      throw TypeMismatch(func_name: name, detail: m, span: err_span)
    | InferExprOk(state: _, subst: s_body, typ: _) ->
      // T-Lambda: τ_r ≠ unit ⟹ tail(s†) = ⊥.
      // A non-unit function MUST terminate every control-flow path with an
      // explicit `return`/`throw` (infer_stmts_tail_diverges = true).  There is
      // NO implicit return of a trailing expression: a body that merely "falls
      // off the end" with a value (or with unit) is rejected with E2001.  This
      // mirrors the kont-arm guard above; the only sanctioned non-`return` tail
      // is `@k` in a `with @k` arm (handled on the is_kont_arm path).
      let ret_is_unit = if let TyUnit = conv_ret then true else false end
      if !ret_is_unit && !infer_stmts_tail_diverges(stmts: body, depth: 64) then
        throw TypeMismatch(
          func_name: name,
          detail: "return type is non-unit but body does not end with a `return` or `throw` on all paths (spec T-Lambda: τ_r ≠ unit ⟹ tail(s†) = ⊥)",
          span: fn_span
        )
      end
      s_body
      return ()
  end
end

let add_func_params = fn (env: [ EnvEntry ], params: [ HirParam ]) -> [ EnvEntry ] do
  match params do
    | [] -> return env
    | HirParam(label: _, name: n, sigil: _, typ: t) :: rest ->
      return add_func_params(
        env: tctypes.env_insert(env, name: n, scheme: tctypes.mono(typ: t)),
        params: rest
      )
  end
end

// ─── fn_pure_set: provably-non-throwing function set ─────────────────────────

/** Collect all top-level function names. */
let collect_fn_names = fn (funcs: [ HirFunction ]) -> [ string ] do
  return collect_fn_names_go(funcs, acc: [])
end

let collect_fn_names_go = fn (funcs: [ HirFunction ], acc: [ string ]) -> [ string ] do
  match funcs do
    | [] -> return acc
    | HirFunction(name: n, _) :: rest ->
      return collect_fn_names_go(funcs: rest, acc: n :: acc)
  end
end

/** True if the HirExpr contains any Raise node or any Call to a function in `can_throw`.
 *  Also returns true for calls to names NOT in `all_fns` (unknown callees — conservative). */
let expr_can_escape = fn (expr: HirExpr, can_throw: [ string ], all_fns: [ string ]) -> bool do
  let HirExpr(node: k, span: _) = expr
  return expr_kind_can_escape(k: k, can_throw, all_fns)
end

let expr_kind_can_escape = fn (
  k: HirExprKind,
  can_throw: [ string ],
  all_fns: [ string ]
) -> bool do
  match k do
    | Raise(expr: _) -> return true
    | Call(func: f, args: call_args) ->
      // Unknown callee (not a top-level fn): conservatively treat as can-throw.
      if !str_list_contains(xs: all_fns, s: f) then return true end
      // Known callee in can_throw: this call can throw.
      if str_list_contains(xs: can_throw, s: f) then return true end
      // Otherwise check the arg expressions for nested raises/calls.
      return call_args_can_escape(args: call_args, can_throw, all_fns)
    | BinOp(left: l, op: _, right: r) ->
      if expr_can_escape(expr: l, can_throw, all_fns) then return true end
      return expr_can_escape(expr: r, can_throw, all_fns)
    | UnOp(op: _, operand: e) -> return expr_can_escape(expr: e, can_throw, all_fns)
    | Ctor(variant: _, args: es, labels: _, sigil: _) ->
      return exprs_can_escape(es: es, can_throw, all_fns)
    | Array(elems: es) -> return exprs_can_escape(es: es, can_throw, all_fns)
    | Index(target: t, index: i) ->
      if expr_can_escape(expr: t, can_throw, all_fns) then return true end
      return expr_can_escape(expr: i, can_throw, all_fns)
    | FieldAccess(target: t, field: _) -> return expr_can_escape(expr: t, can_throw, all_fns)
    | If(cond: c, then_branch: tb, else_branch: eb) ->
      if expr_can_escape(expr: c, can_throw, all_fns) then return true end
      if stmts_can_escape(stmts: tb, can_throw, all_fns) then return true end
      match eb do
        | None -> return false
        | Some(val: ebs) -> return stmts_can_escape(stmts: ebs, can_throw, all_fns)
      end
    | Match(target: t, cases: cs) ->
      if expr_can_escape(expr: t, can_throw, all_fns) then return true end
      return cases_can_escape(cs: cs, can_throw, all_fns)
    | While(cond: c, body: b) ->
      if expr_can_escape(expr: c, can_throw, all_fns) then return true end
      return stmts_can_escape(stmts: b, can_throw, all_fns)
    | For(var: _, start: s, end_expr: e, body: b) ->
      if expr_can_escape(expr: s, can_throw, all_fns) then return true end
      if expr_can_escape(expr: e, can_throw, all_fns) then return true end
      return stmts_can_escape(stmts: b, can_throw, all_fns)
    | Lambda(type_params: _, params: _, ret_type: _, requires: _, throw_row: _, body: _) ->
      // Lambda bodies are checked independently; don't recurse into them for
      // the outer function's purity — a lambda that throws is a value, not a
      // direct escape from the enclosing function.
      return false
    | Force(expr: e) -> return expr_can_escape(expr: e, can_throw, all_fns)
    | Thunk(body: _) ->
      // Thunk bodies are deferred; same as Lambda — don't recurse.
      return false
    | Record(fields: flds) -> return named_exprs_can_escape(flds: flds, can_throw, all_fns)
    | Inject(handlers: _, body: b) ->
      // inject (the SOLE inject form; a statement-position inject reaches here as
      // HirStmtKind::Expr(Inject)): a throw from its body escapes the inject
      // (inject suspends on the cap, it does not catch exceptions), so the
      // enclosing function can-throw. Recurse into the body.
      return stmts_can_escape(stmts: b, can_throw, all_fns)
    | _ -> return false
  end
end

let exprs_can_escape = fn (es: [ HirExpr ], can_throw: [ string ], all_fns: [ string ]) -> bool do
  match es do
    | [] -> return false
    | e :: rest ->
      if expr_can_escape(expr: e, can_throw, all_fns) then return true end
      return exprs_can_escape(es: rest, can_throw, all_fns)
  end
end

let call_args_can_escape = fn (
  args: [ HirCallArg ],
  can_throw: [ string ],
  all_fns: [ string ]
) -> bool do
  match args do
    | [] -> return false
    | HirCallArg(label: _, value: v) :: rest ->
      if expr_can_escape(expr: v, can_throw, all_fns) then return true end
      return call_args_can_escape(args: rest, can_throw, all_fns)
  end
end

let named_exprs_can_escape = fn (
  flds: [ HirNamedExpr ],
  can_throw: [ string ],
  all_fns: [ string ]
) -> bool do
  match flds do
    | [] -> return false
    | HirNamedExpr(name: _, value: v) :: rest ->
      if expr_can_escape(expr: v, can_throw, all_fns) then return true end
      return named_exprs_can_escape(flds: rest, can_throw, all_fns)
  end
end

let cases_can_escape = fn (
  cs: [ HirMatchCase ],
  can_throw: [ string ],
  all_fns: [ string ]
) -> bool do
  match cs do
    | [] -> return false
    | HirMatchCase(pattern: _, body: b) :: rest ->
      if stmts_can_escape(stmts: b, can_throw, all_fns) then return true end
      return cases_can_escape(cs: rest, can_throw, all_fns)
  end
end

let stmts_can_escape = fn (
  stmts: [ HirStmt ],
  can_throw: [ string ],
  all_fns: [ string ]
) -> bool do
  match stmts do
    | [] -> return false
    | HirStmt(node: s, span: _) :: rest ->
      if stmt_kind_can_escape(s: s, can_throw, all_fns) then return true end
      return stmts_can_escape(stmts: rest, can_throw, all_fns)
  end
end

let stmt_kind_can_escape = fn (
  s: HirStmtKind,
  can_throw: [ string ],
  all_fns: [ string ]
) -> bool do
  match s do
    | Let(
      name: _,
      sigil: _,
      typ: _,
      value: v
    ) -> return expr_can_escape(expr: v, can_throw, all_fns)
    | Expr(expr: e) | Return(expr: e) -> return expr_can_escape(expr: e, can_throw, all_fns)
    | Assign(target: t, value: v) ->
      if expr_can_escape(expr: t, can_throw, all_fns) then return true end
      return expr_can_escape(expr: v, can_throw, all_fns)
    | Try(body: _, catch_param: _, catch_body: cb) ->
      // In HIR, `try`/`catch` is already desugared to a single catch-all binder
      // (`catch_param` binds every exception; selective `catch | E -> …` lowers
      // to a `match` inside `catch_body` with a synthetic `_ -> throw param`
      // rethrow arm). The catch binder therefore absorbs ALL throws from the try
      // body — only the catch body can let an exception escape (via its own
      // raises/throwing calls or the synthetic rethrow). Counting the try body
      // as an escape source mislabels otherwise-pure functions that fully absorb
      // their throws (e.g. `emit_json`'s `try … catch _ -> ()`), which then
      // spuriously fails the closed-throw check at a handler-arm call site.
      return stmts_can_escape(stmts: cb, can_throw, all_fns)
  end
end

/** True when a function body can escape exceptions under `can_throw`+`all_fns`. */
let fn_body_can_escape = fn (
  func: HirFunction,
  can_throw: [ string ],
  all_fns: [ string ]
) -> bool do
  let HirFunction(
    name: _,
    type_params: _,
    params: _,
    ret_type: _,
    throw_row: _,
    body: hir_body,
    _
  ) = func
  match hir_body do
    | LazyBody(
      ast_expr: _,
      entries: _
    ) -> return true  // unknown: conservatively treat as can-throw
    | EagerBody(stmts: stmts) -> return stmts_can_escape(stmts, can_throw, all_fns)
  end
end

/** One fixpoint step: add to `can_throw` any fn whose body can escape under current `can_throw`. */
let fixpoint_step = fn (
  funcs: [ HirFunction ],
  can_throw: [ string ],
  all_fns: [ string ]
) -> [ string ] do
  return fixpoint_step_go(funcs, can_throw, all_fns, acc: can_throw)
end

let fixpoint_step_go = fn (
  funcs: [ HirFunction ],
  can_throw: [ string ],
  all_fns: [ string ],
  acc: [ string ]
) -> [ string ] do
  match funcs do
    | [] -> return acc
    | func :: rest ->
      let HirFunction(name: n, _) = func
      let new_acc = if !str_list_contains(
        xs: acc,
        s: n
      ) && fn_body_can_escape(func, can_throw, all_fns) then
        n :: acc
      else
        acc
      end
      return fixpoint_step_go(funcs: rest, can_throw, all_fns, acc: new_acc)
  end
end

/** Compute the fixpoint of can_throw: iterate until stable. */
let fixpoint_can_throw = fn (
  funcs: [ HirFunction ],
  can_throw: [ string ],
  all_fns: [ string ]
) -> [ string ] do
  let next = fixpoint_step(funcs, can_throw, all_fns)
  let changed = list.length(xs: next) != list.length(xs: can_throw)
  if changed then
    return fixpoint_can_throw(funcs, can_throw: next, all_fns)
  end
  return next
end

/** Build the set of provably-non-throwing top-level function names.
 *  Returns a list of function names that cannot throw (directly or transitively).
 */
let build_fn_pure_set = fn (funcs: [ HirFunction ], exts: [ HirExternal ]) -> [ string ] do
  // Externals are WASM imports with no body — they can never contain a `Raise`,
  // so an external whose declared throw row is empty/closed is provably
  // non-throwing. Fold those names into `all_fns` so a call to (e.g.) a pure
  // `w_proc_exit` intrinsic is treated as a known non-escaping callee rather
  // than the conservative unknown-callee `return true`. Without this, handler
  // arm bodies that delegate to such intrinsics under the closed throw row
  // pinned by `check_arm_body` would be spuriously rejected.
  let nothrow_ext_names = collect_nothrow_external_names(exts)
  let all_fns = list_append(xs: collect_fn_names(funcs), ys: nothrow_ext_names)
  // Initial can_throw: functions whose bodies directly contain Raise or call unknowns.
  let initial_can_throw = initial_can_throw_set(funcs, all_fns)
  // Fixpoint: propagate transitively.
  let final_can_throw = fixpoint_can_throw(funcs, can_throw: initial_can_throw, all_fns)
  // Pure set = all_fns minus can_throw. (External names carry through too — a
  // closed-throw external call site admits them just like a pure top-level fn.)
  return filter_not_in(xs: all_fns, exclude: final_can_throw)
end

/** Names of externals whose declared throw row admits no exceptions: either a
 *  closed empty row `{}` or the implicit absent-throws row. Externals have no
 *  body, so an empty declared row is an honest no-throw contract.
 */
let collect_nothrow_external_names = fn (exts: [ HirExternal ]) -> [ string ] do
  match exts do
    | [] -> return []
    | HirExternal(
      name: n,
      wasm_module: _,
      wasm_name: _,
      type_params: _,
      params: _,
      ret_type: _,
      throw_row: tw
    ) :: rest ->
      let tail = collect_nothrow_external_names(exts: rest)
      if external_throw_row_is_empty(row: tw) then return n :: tail end
      return tail
  end
end

let external_throw_row_is_empty = fn (row: TypeExpr) -> bool do
  match row do
    | TyRow(types: [], rest: None) -> return true
    | TyRow(types: [], rest: Some(val: TyVar(name: nm))) -> return nm == "__implicit"
    | _ -> return false
  end
end

/** Names of externals that are slot-reading intrinsics — externals whose wasm
 *  symbol is `value-of-i64` (the canonicalised form of the source `value_of_i64`
 *  pun). These are pure reinterpret-as-i64 bitcasts (e.g. std:runtime/sched's
 *  `kont_slot`): they read their argument's raw bits and can never `@`-force it.
 *  A `with @k` continuation binder may therefore be passed to one of them as a
 *  value without risking the indirect-force miscompile, so they form the
 *  allowlist consulted by the cont-binder escape check. Keying on the wasm symbol
 *  (not the Nexus name) keeps the rule robust against renames.
 */
let collect_slot_read_external_names = fn (exts: [ HirExternal ]) -> [ string ] do
  match exts do
    | [] -> return []
    | HirExternal(
      name: n,
      wasm_module: _,
      wasm_name: wn,
      type_params: _,
      params: _,
      ret_type: _,
      throw_row: _
    ) :: rest ->
      let tail = collect_slot_read_external_names(exts: rest)
      if wn == "value-of-i64" then return n :: tail end
      return tail
  end
end

let list_append = fn (xs: [ string ], ys: [ string ]) -> [ string ] do
  match xs do
    | [] -> return ys
    | x :: rest -> return x :: list_append(xs: rest, ys)
  end
end

let initial_can_throw_set = fn (funcs: [ HirFunction ], all_fns: [ string ]) -> [ string ] do
  return initial_can_throw_go(funcs, all_fns, acc: [])
end

let initial_can_throw_go = fn (
  funcs: [ HirFunction ],
  all_fns: [ string ],
  acc: [ string ]
) -> [ string ] do
  match funcs do
    | [] -> return acc
    | func :: rest ->
      let HirFunction(name: n, _) = func
      let new_acc = if fn_body_can_escape(func, can_throw: [], all_fns) then
        n :: acc
      else
        acc
      end
      return initial_can_throw_go(funcs: rest, all_fns, acc: new_acc)
  end
end

let filter_not_in = fn (xs: [ string ], exclude: [ string ]) -> [ string ] do
  return filter_not_in_go(xs, exclude, acc: [])
end

let filter_not_in_go = fn (xs: [ string ], exclude: [ string ], acc: [ string ]) -> [ string ] do
  match xs do
    | [] -> return acc
    | x :: rest ->
      let new_acc = if str_list_contains(xs: exclude, s: x) then acc else x :: acc end
      return filter_not_in_go(xs: rest, exclude, acc: new_acc)
  end
end
