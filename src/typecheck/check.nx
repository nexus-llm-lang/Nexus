/**
 * typecheck/check: Top-level program type checking entry point.
 *
 * Takes HirProgram, validates types of all functions, and returns
 * the HirProgram unchanged on success or raises CompileError.
 */

import * as bb from "std:bytebuffer"
import * as naming from "src/common/naming.nx"
import { TypeExpr, TyUnit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyLazy, TyBorrow, TyArray, TyList, TyRecord, TyRow, TyHandler, NamedType, EnumDef, VariantDef, VariantField } from "src/common/ast.nx"
import { HirProgram, HirFunction, HirHandlerArm, HirParam, HirExternal, HirPort, HirHandlerBindingEntry, HirHandlerBinding, EagerBody, LazyBody } from "src/ir/hir_types.nx"
import { TypeMismatch, MissingMain, MainNotFunction, MainNotUnit, MainThrowsTooBroad } from "src/common/error.nx"
import { CheckState, Scheme, EnvEntry, EnumEntry, InferExprOk, InferExprErr }, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as infer from "src/typecheck/infer.nx"

// ─── Public entry point ─────────────────────────────────────────────────────

export let check_program = fn (hir: HirProgram, local_names: [string]) -> HirProgram throws { Exn } do
  let HirProgram(ports, functions: funcs, externals: exts, handler_bindings: hbs, enum_defs: edefs, exception_groups: egs) = hir
  // Build enum entries
  let enum_entries = build_enum_entries(defs: edefs)
  // Add built-in Exn and List
  let enum_entries2 = add_builtins(entries: enum_entries)
  // Build initial state
  let state = tctypes.tc_new_state(enum_defs: enum_entries2, type_defs: [], exception_groups: egs)

  // Pass 1: Register all signatures
  let st1 = register_externals(state, exts)
  let st2 = register_functions(state: st1, funcs)
  let st3 = register_ports(state: st2, ports)
  let st4 = register_handler_bindings(state: st3, hbs)
  let st5 = register_enum_constructors(state: st4, defs: edefs)

  // Build cont_binder map for arm functions: synthesised arm fn name → binder name.
  let cont_binder_map = build_cont_binder_map(hbs)

  // Pass 2: Check only local (main module) function bodies
  check_all_functions(state: st5, funcs, local_names, cont_map: cont_binder_map)

  // Pass 2b: Check handler arm bodies (synthesised function names aren't in
  // local_names, so they're missed by check_all_functions). With-kont arms
  // need their body re-checked with the cont binder bound in env so that
  // forcing @k at the wrong type is a TypeMismatch.
  check_handler_arm_bodies(state: st5, hbs)

  // Validate main exists and has correct signature
  validate_main(state: st5)

  return hir
end

// ─── Built-in types ─────────────────────────────────────────────────────────

let add_builtins = fn (entries: [EnumEntry]) -> [EnumEntry] do
  // Add Exn (empty enum for exception base type)
  let exn = EnumEntry(
    name: "Exn",
    def: EnumDef(name: "Exn", is_public: true, is_opaque: false, type_params: [], variants: [])
  )
  // Add List with []/Cons
  let list_variants = [
    VariantDef(name: "Nil", fields: []),
    VariantDef(name: "Cons", fields: [
      VariantField(name: Some(val: "v"), typ: TyVar(name: "T")),
      VariantField(name: Some(val: "rest"), typ: TyList(elem: TyVar(name: "T")))
    ])
  ]
  let list_def = EnumEntry(
    name: "List",
    def: EnumDef(name: "List", is_public: true, is_opaque: false,
      type_params: ["T"], variants: list_variants)
  )
  // Add Option with None/Some
  let option_variants = [
    VariantDef(name: "None", fields: []),
    VariantDef(name: "Some", fields: [
      VariantField(name: Some(val: "val"), typ: TyVar(name: "T"))
    ])
  ]
  let option_def = EnumEntry(
    name: "Option",
    def: EnumDef(name: "Option", is_public: true, is_opaque: false,
      type_params: ["T"], variants: option_variants)
  )
  return exn :: list_def :: option_def :: entries
end

// ─── Build enum entries ─────────────────────────────────────────────────────

let build_enum_entries = fn (defs: [EnumDef]) -> [EnumEntry] do
  return build_enum_entries_go(defs, acc: [])
end

let build_enum_entries_go = fn (defs: [EnumDef], acc: [EnumEntry]) -> [EnumEntry] do
  match defs do
    | [] -> return rev_enum_entries(lst: acc, out: [])
    | EnumDef(name: n, is_public: p, is_opaque: o, type_params: tps, variants: vs) :: rest ->
      // Convert TyUserDefined("T",[]) → TyVar("T") in variant field types so
      // that infer_constructor's freshen+subst_apply pipeline can rename T to
      // a fresh metavar. Without this, T survives as a frozen UD inside the
      // EnumVariantInfo and downstream unification fails to instantiate it.
      let converted_vs = convert_variants(variants: vs, vars: tps)
      return build_enum_entries_go(defs: rest, acc: EnumEntry(name: n, def: EnumDef(name: n, is_public: p, is_opaque: o, type_params: tps, variants: converted_vs)) :: acc)
  end
end

let convert_variants = fn (variants: [VariantDef], vars: [string]) -> [VariantDef] do
  return convert_variants_go(variants, vars, acc: [])
end

let convert_variants_go = fn (variants: [VariantDef], vars: [string], acc: [VariantDef]) -> [VariantDef] do
  match variants do
    | [] -> return rev_variant_defs(lst: acc, out: [])
    | VariantDef(name: vn, fields: fs) :: rest ->
      let cf = convert_variant_fields(fields: fs, vars)
      return convert_variants_go(variants: rest, vars, acc: VariantDef(name: vn, fields: cf) :: acc)
  end
end

let convert_variant_fields = fn (fields: [VariantField], vars: [string]) -> [VariantField] do
  return convert_variant_fields_go(fields, vars, acc: [])
end

let convert_variant_fields_go = fn (fields: [VariantField], vars: [string], acc: [VariantField]) -> [VariantField] do
  match fields do
    | [] -> return rev_variant_fields(lst: acc, out: [])
    | VariantField(name: mn, typ: t) :: rest ->
      return convert_variant_fields_go(fields: rest, vars,
        acc: VariantField(name: mn, typ: convert_ud_to_var(typ: t, vars)) :: acc)
  end
end

let rev_variant_defs = fn (lst: [VariantDef], out: [VariantDef]) -> [VariantDef] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_variant_defs(lst: rest, out: x :: out)
  end
end

let rev_variant_fields = fn (lst: [VariantField], out: [VariantField]) -> [VariantField] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_variant_fields(lst: rest, out: x :: out)
  end
end

// ─── Register externals ────────────────────────────────────────────────────

let register_externals = fn (state: CheckState, exts: [HirExternal]) -> CheckState do
  match exts do
    | [] -> return state
    | HirExternal(name: n, wasm_module: _, wasm_name: _, type_params: tps, params, ret_type: ret, throw_row: thr) :: rest ->
      let param_types = hir_params_to_named_types(params)
      // Convert TyUserDefined("T",[]) → TyVar("T") for declared type params,
      // then register as a polymorphic Scheme so each call site instantiates
      // T to a fresh metavar. Without this `external f: <T>(val: T) -> unit`
      // freezes T as a frozen non-int type and rejects int-literal callers.
      let arrow = TyArrow(
        params: convert_named_types(nts: param_types, vars: tps),
        ret: convert_ud_to_var(typ: ret, vars: tps),
        requires: TyRow(types: [], rest: None),
        throw_row: convert_ud_to_var(typ: thr, vars: tps)
      )
      let env = tctypes.env_insert(env: tctypes.state_env(state), name: n, scheme: Scheme(vars: tps, typ: arrow))
      return register_externals(state: tctypes.state_with_env(state, env), exts: rest)
  end
end

// ─── Generic type parameter resolution ──────────────────────────────────────
// Convert TyUserDefined("T", []) → TyVar("T") when "T" is a type parameter.
// Mirrors Rust compiler's convert_generic_user_defined_to_var.

let str_list_contains = fn (xs: [string], s: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true end
      return str_list_contains(xs: rest, s)
  end
end

let convert_ud_to_var = fn (typ: TypeExpr, vars: [string]) -> TypeExpr do
  match typ do
    | TyUserDefined(name: n, args: []) ->
      if str_list_contains(xs: vars, s: n) then return TyVar(name: n) end
      return typ
    | TyUserDefined(name: n, args: targs) ->
      return TyUserDefined(name: n, args: convert_type_list(types: targs, vars))
    | TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return TyArrow(
        params: convert_named_types(nts: ps, vars),
        ret: convert_ud_to_var(typ: r, vars),
        requires: convert_ud_to_var(typ: req, vars),
        throw_row: convert_ud_to_var(typ: thr, vars)
      )
    | TyList(elem: e) -> return TyList(elem: convert_ud_to_var(typ: e, vars))
    | TyArray(elem: e) -> return TyArray(elem: convert_ud_to_var(typ: e, vars))
    | TyRef(inner: i) -> return TyRef(inner: convert_ud_to_var(typ: i, vars))
    | TyLinear(inner: i) -> return TyLinear(inner: convert_ud_to_var(typ: i, vars))
    | TyLazy(inner: i) -> return TyLazy(inner: convert_ud_to_var(typ: i, vars))
    | TyBorrow(inner: i) -> return TyBorrow(inner: convert_ud_to_var(typ: i, vars))
    | TyRecord(fields: fs) -> return TyRecord(fields: convert_named_types(nts: fs, vars))
    | TyRow(types: ts, rest: r) ->
      let new_rest = match r do
        | Some(val: t) -> Some(val: convert_ud_to_var(typ: t, vars))
        | None -> None
      end
      return TyRow(types: convert_type_list(types: ts, vars), rest: new_rest)
    | TyHandler(name: n, requires: req) ->
      return TyHandler(name: n, requires: convert_ud_to_var(typ: req, vars))
    | _ -> return typ
  end
end

let convert_named_types = fn (nts: [NamedType], vars: [string]) -> [NamedType] do
  return convert_named_types_go(nts, vars, acc: [])
end

let convert_named_types_go = fn (nts: [NamedType], vars: [string], acc: [NamedType]) -> [NamedType] do
  match nts do
    | [] -> return rev_named_types(lst: acc, out: [])
    | NamedType(name: n, typ: t) :: rest ->
      return convert_named_types_go(nts: rest, vars, acc: NamedType(name: n, typ: convert_ud_to_var(typ: t, vars)) :: acc)
  end
end

let convert_type_list = fn (types: [TypeExpr], vars: [string]) -> [TypeExpr] do
  return convert_type_list_go(types, vars, acc: [])
end

let convert_type_list_go = fn (types: [TypeExpr], vars: [string], acc: [TypeExpr]) -> [TypeExpr] do
  match types do
    | [] -> return rev_type_exprs(lst: acc, out: [])
    | t :: rest ->
      return convert_type_list_go(types: rest, vars, acc: convert_ud_to_var(typ: t, vars) :: acc)
  end
end

let convert_hir_params = fn (params: [HirParam], vars: [string]) -> [HirParam] do
  return convert_hir_params_go(params, vars, acc: [])
end

let convert_hir_params_go = fn (params: [HirParam], vars: [string], acc: [HirParam]) -> [HirParam] do
  match params do
    | [] -> return rev_hir_params(lst: acc, out: [])
    | HirParam(name: n, label: l, typ: t) :: rest ->
      return convert_hir_params_go(params: rest, vars, acc: HirParam(name: n, label: l, typ: convert_ud_to_var(typ: t, vars)) :: acc)
  end
end

// ─── Register functions ─────────────────────────────────────────────────────

let register_functions = fn (state: CheckState, funcs: [HirFunction]) -> CheckState do
  match funcs do
    | [] -> return state
    | HirFunction(name: n, type_params: tps, params, ret_type: ret, throw_row: tw, _) :: rest ->
      let param_types = hir_params_to_named_types(params)
      let arrow = TyArrow(
        params: convert_named_types(nts: param_types, vars: tps),
        ret: convert_ud_to_var(typ: ret, vars: tps),
        requires: TyRow(types: [], rest: None),
        throw_row: convert_ud_to_var(typ: tw, vars: tps)
      )
      let env = tctypes.env_insert(env: tctypes.state_env(state), name: n, scheme: Scheme(vars: tps, typ: arrow))
      return register_functions(state: tctypes.state_with_env(state, env), funcs: rest)
  end
end

// ─── Register ports ─────────────────────────────────────────────────────────

let register_ports = fn (state: CheckState, ports: [HirPort]) -> CheckState do
  match ports do
    | [] -> return state
    | HirPort(_) :: rest ->
      // Ports are structural — methods are registered via handler bindings
      return register_ports(state, ports: rest)
  end
end

// ─── Register handler bindings ──────────────────────────────────────────────

let register_handler_bindings = fn (state: CheckState, hbs: [HirHandlerBindingEntry]) -> CheckState do
  match hbs do
    | [] -> return state
    | HirHandlerBindingEntry(name: n, binding: HirHandlerBinding(port_name: pname, arms: arms)) :: rest ->
      let handler_type = TyHandler(name: pname, requires: TyRow(types: [], rest: None))
      let env1 = tctypes.env_insert(env: tctypes.state_env(state), name: n, scheme: tctypes.mono(typ: handler_type))
      let prefix_len = naming.handler_prefix_len(handler_name: n)
      let env2 = register_handler_methods(env: env1, port_name: pname, prefix_len, arms)
      let st1 = tctypes.state_with_env(state, env: env2)
      return register_handler_bindings(state: st1, hbs: rest)
  end
end

let register_handler_methods = fn (env: [EnvEntry], port_name: string, prefix_len: i64, arms: [HirHandlerArm]) -> [EnvEntry] do
  match arms do
    | [] -> return env
    | HirHandlerArm(arm: HirFunction(name: n, type_params: _, params, ret_type: ret, throw_row: tw, _), cont_binder: kb) :: rest ->
      let original_name = str.substring(s: n, start: prefix_len, len: str.length(s: n) - prefix_len)
      let method_name = bb.concat(parts: [port_name, ".", original_name])
      let user_params = match kb do
        | Some(_) -> list_init(xs: params)
        | None -> params
      end
      let param_types = hir_params_to_named_types(params: user_params)
      let arrow = TyArrow(
        params: param_types, ret,
        requires: TyRow(types: [], rest: None),
        throw_row: tw
      )
      let env1 = tctypes.env_insert(env, name: method_name, scheme: tctypes.mono(typ: arrow))
      return register_handler_methods(env: env1, port_name, prefix_len, arms: rest)
  end
end

let list_init = fn (xs: [HirParam]) -> [HirParam] do
  match xs do
    | [] -> return []
    | _ :: [] -> return []
    | x :: rest -> return x :: list_init(xs: rest)
  end
end

// ─── Register enum constructors ─────────────────────────────────────────────

let register_enum_constructors = fn (state: CheckState, defs: [EnumDef]) -> CheckState do
  match defs do
    | [] -> return state
    | EnumDef(name: ename, is_public: _, is_opaque: _, type_params: tps, variants: vs) :: rest ->
      let st1 = register_variants(state, enum_name: ename, type_params: tps, variants: vs)
      return register_enum_constructors(state: st1, defs: rest)
  end
end

let register_variants = fn (state: CheckState, enum_name: string, type_params: [string], variants: [VariantDef]) -> CheckState do
  match variants do
    | [] -> return state
    | VariantDef(name: vname, fields) :: rest ->
      let enum_type = build_enum_type_from_params(name: enum_name, params: type_params)
      let ctor_type = match fields do
        | [] -> enum_type
        | _ ->
          let param_types = variant_fields_to_named_types(fields, idx: 0)
          TyArrow(
            params: param_types, ret: enum_type,
            requires: TyRow(types: [], rest: None),
            throw_row: TyRow(types: [], rest: None)
          )
      end
      let env = tctypes.env_insert(env: tctypes.state_env(state), name: vname, scheme: tctypes.mono(typ: ctor_type))
      return register_variants(state: tctypes.state_with_env(state, env), enum_name, type_params, variants: rest)
  end
end

let build_enum_type_from_params = fn (name: string, params: [string]) -> TypeExpr do
  match params do
    | [] -> return TyUserDefined(name, args: [])
    | _ -> return TyUserDefined(name, args: params_to_vars(params))
  end
end

let params_to_vars = fn (params: [string]) -> [TypeExpr] do
  return params_to_vars_go(params, acc: [])
end

let params_to_vars_go = fn (params: [string], acc: [TypeExpr]) -> [TypeExpr] do
  match params do
    | [] -> return rev_type_exprs(lst: acc, out: [])
    | p :: rest ->
      return params_to_vars_go(params: rest, acc: TyVar(name: p) :: acc)
  end
end

let variant_fields_to_named_types = fn (fields: [VariantField], idx: i64) -> [NamedType] do
  return variant_fields_to_named_types_go(fields, idx, acc: [])
end

let variant_fields_to_named_types_go = fn (fields: [VariantField], idx: i64, acc: [NamedType]) -> [NamedType] do
  match fields do
    | [] -> return rev_named_types(lst: acc, out: [])
    | VariantField(name: mname, typ: t) :: rest ->
      let fname = match mname do
        | Some(val: n) -> n
        | None -> "_" ++ str.from_i64(val: idx)
      end
      return variant_fields_to_named_types_go(fields: rest, idx: idx + 1, acc: NamedType(name: fname, typ: t) :: acc)
  end
end

// ─── Check all function bodies ──────────────────────────────────────────────

let is_local = fn (name: string, local_names: [string]) -> bool do
  match local_names do
    | [] -> return false
    | n :: rest ->
      if n == name then return true end
      return is_local(name, local_names: rest)
  end
end

/// Map from synthesised arm function name (e.g. `__handler_scheduler_yield`)
/// to the `with @k` binder name. Empty for arms without cont_binder.
type ContBinderMap = ContBinderMap(entries: [ContBinderEntry])
type ContBinderEntry = ContBinderEntry(arm_fn_name: string, binder: string)

let build_cont_binder_map = fn (hbs: [HirHandlerBindingEntry]) -> ContBinderMap throws { Exn } do
  return ContBinderMap(entries: build_cont_binder_entries(hbs, acc: []))
end

let build_cont_binder_entries = fn (hbs: [HirHandlerBindingEntry], acc: [ContBinderEntry]) -> [ContBinderEntry] throws { Exn } do
  match hbs do
    | [] -> return acc
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, arms)) :: rest ->
      let acc2 = collect_arm_binders(arms, acc)
      return build_cont_binder_entries(hbs: rest, acc: acc2)
  end
end

let collect_arm_binders = fn (arms: [HirHandlerArm], acc: [ContBinderEntry]) -> [ContBinderEntry] throws { Exn } do
  match arms do
    | [] -> return acc
    | HirHandlerArm(arm: HirFunction(name: fname, type_params: _, params: _, ret_type: _, _), cont_binder: Some(val: k)) :: rest ->
      return collect_arm_binders(arms: rest, acc: ContBinderEntry(arm_fn_name: fname, binder: k) :: acc)
    | _ :: rest -> return collect_arm_binders(arms: rest, acc)
  end
end

let lookup_cont_binder = fn (fname: string, map: ContBinderMap) -> Option<string> throws { Exn } do
  match map do | ContBinderMap(entries) -> return lookup_cont_binder_in(fname, entries) end
end

let lookup_cont_binder_in = fn (fname: string, entries: [ContBinderEntry]) -> Option<string> throws { Exn } do
  match entries do
    | [] -> return None
    | ContBinderEntry(arm_fn_name: an, binder: b) :: rest ->
      if an == fname then return Some(val: b) end
      return lookup_cont_binder_in(fname, entries: rest)
  end
end

let check_all_functions = fn (state: CheckState, funcs: [HirFunction], local_names: [string], cont_map: ContBinderMap) -> unit throws { Exn } do
  match funcs do
    | [] -> return ()
    | func :: rest ->
      let HirFunction(name, type_params: _, params: _, ret_type: _, _) = func
      if is_local(name, local_names) then
        check_function(state, func, cont_map)
      end
      return check_all_functions(state, funcs: rest, local_names, cont_map)
  end
end

let check_handler_arm_bodies = fn (state: CheckState, hbs: [HirHandlerBindingEntry]) -> unit throws { Exn } do
  match hbs do
    | [] -> return ()
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, arms)) :: rest ->
      check_arm_bodies(state, arms)
      return check_handler_arm_bodies(state, hbs: rest)
  end
end

let check_arm_bodies = fn (state: CheckState, arms: [HirHandlerArm]) -> unit throws { Exn } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(arm: f, cont_binder: Some(val: k)) :: rest ->
      // Only with-kont arms re-checked here so we can bind @k in env;
      // non-kont arms are picked up via the normal function pass.
      check_arm_body(state, func: f, cont_binder: Some(val: k))
      return check_arm_bodies(state, arms: rest)
    | _ :: rest -> return check_arm_bodies(state, arms: rest)
  end
end

let check_arm_body = fn (state: CheckState, func: HirFunction, cont_binder: Option<string>) -> unit throws { Exn } do
  let HirFunction(name, type_params: tps, params, ret_type: ret, throw_row: tw, body: hir_body, span: _) = func
  let body = match hir_body do | EagerBody(stmts: s) -> s | LazyBody(_) -> [] end
  let conv_params = convert_hir_params(params, vars: tps)
  let conv_ret = convert_ud_to_var(typ: ret, vars: tps)
  let conv_tw = convert_ud_to_var(typ: tw, vars: tps)
  let body_env = add_func_params(env: tctypes.state_env(state), params: conv_params)
  // If the arm has `with @k`, bind k in env as @ret_type. Standard inference
  // then catches type mismatches when the arm body forces k at a wrong type.
  let body_env2 = match cont_binder do
    | Some(val: k) -> tctypes.env_insert(env: body_env, name: k, scheme: tctypes.mono(typ: TyLazy(inner: conv_ret)))
    | None -> body_env
  end
  let body_state = tctypes.state_with_env(state, env: body_env2)
  let body_state2 = tctypes.state_with_throw_row(state: body_state, throw_row: conv_tw)
  match infer.infer_stmts(state: body_state2, stmts: body, ret_type: conv_ret) do
    | InferExprErr(message: m, span: err_span) ->
      raise TypeMismatch(func_name: name, detail: m, span: err_span)
    | InferExprOk(_) ->
      return ()
  end
end

let check_function = fn (state: CheckState, func: HirFunction, cont_map: ContBinderMap) -> unit throws { Exn } do
  let HirFunction(name, type_params: tps, params, ret_type: ret, throw_row: tw, body: hir_body, span) = func
  let body = match hir_body do | EagerBody(stmts: s) -> s | LazyBody(_) -> [] end
  // Convert UserDefined type params to TyVar in param types and return type
  let conv_params = convert_hir_params(params, vars: tps)
  let conv_ret = convert_ud_to_var(typ: ret, vars: tps)
  let conv_tw = convert_ud_to_var(typ: tw, vars: tps)
  // Build local env with function params
  let body_env = add_func_params(env: tctypes.state_env(state), params: conv_params)
  // If this function is a handler arm with `with @k`, bind k as @ret in the
  // body env. Forcing k yields the arm's return type; using it at any other
  // type is a TypeMismatch (acceptance (d) for nexus-x7w).
  // If this function is a handler arm with `with @k`, bind k as @ret in the
  // body env. Standard inference catches force-at-wrong-type mismatches.
  let body_env2 = match lookup_cont_binder(fname: name, map: cont_map) do
    | Some(val: k) -> tctypes.env_insert(env: body_env, name: k, scheme: tctypes.mono(typ: TyLazy(inner: conv_ret)))
    | None -> body_env
  end
  let body_state = tctypes.state_with_env(state, env: body_env2)
  let body_state2 = tctypes.state_with_throw_row(state: body_state, throw_row: conv_tw)
  match infer.infer_stmts(state: body_state2, stmts: body, ret_type: conv_ret) do
    | InferExprErr(message: m, span: err_span) ->
      raise TypeMismatch(func_name: name, detail: m, span: err_span)
    | InferExprOk(_) ->
      return ()
  end
end

let add_func_params = fn (env: [EnvEntry], params: [HirParam]) -> [EnvEntry] do
  match params do
    | [] -> return env
    | HirParam(name: n, label: _, typ: t) :: rest ->
      return add_func_params(env: tctypes.env_insert(env, name: n, scheme: tctypes.mono(typ: t)), params: rest)
  end
end

// ─── Validate main function ────────────────────────────────────────────────

/// Validates that `main` exists, is a `() -> unit` (or `[string] -> unit`)
/// arrow, and that its declared throws-row is one the runtime can wrap.
///
/// The HIR main-wrap pass (`src/ir/main_wrap.nx`) replaces a wrappable
/// non-empty main with a synthesised wrapper whose throws are `{}`, so by
/// the time validate_main runs the row is normally either empty (nothing
/// to wrap) or post-wrap empty. The wrap pass intentionally leaves
/// unwrappable rows intact — open rows, rows with a free type variable,
/// or rows containing non-exception entries — and validate_main rejects
/// them here as `MainThrowsTooBroad`. The previous wildcard check accepted
/// *any* row and masked these mis-narrowings.
let validate_main = fn (state: CheckState) -> unit throws { Exn } do
  match tctypes.env_lookup(env: tctypes.state_env(state), name: "main") do
    | None ->
      raise MissingMain
    | Some(val: Scheme(vars: _, typ: main_type)) ->
      match main_type do
        | TyArrow(params: _, ret, requires: _, throw_row: tw) ->
          // Check return type is Unit
          if subst.type_eq(a: ret, b: TyUnit) then
            return validate_main_throw_row(throw_row: tw)
          end
          raise MainNotUnit
        | _ ->
          raise MainNotFunction
      end
  end
end

/// Reject throws-rows the main-wrap pass cannot handle: open rows, rows
/// whose entries are not named exception (group) variants, or rows that
/// have collapsed to a free type variable. Empty rows and closed rows of
/// named entries (concrete exceptions, exception groups, or the universal
/// `Exn`) are accepted — the wrap pass routes them through a match-on-Exn
/// with a wildcard arm.
let validate_main_throw_row = fn (throw_row: TypeExpr) -> unit throws { Exn } do
  match throw_row do
    | TyRow(types: ts, rest: r) ->
      match r do
        | Some(_) -> raise MainThrowsTooBroad(detail: "open row (rest tail) is not permitted")
        | None -> return validate_main_throw_row_entries(entries: ts)
      end
    | TyUnit -> return ()
    | _ -> raise MainThrowsTooBroad(detail: "throws-row must be a closed row, got non-row type")
  end
end

let validate_main_throw_row_entries = fn (entries: [TypeExpr]) -> unit throws { Exn } do
  match entries do
    | [] -> return ()
    | t :: rest ->
      validate_main_throw_row_entry(entry: t)
      return validate_main_throw_row_entries(entries: rest)
  end
end

let validate_main_throw_row_entry = fn (entry: TypeExpr) -> unit throws { Exn } do
  match entry do
    | TyUserDefined(name: _, args: _) ->
      // Concrete exceptions, exception groups, and the universal `Exn` are
      // all admitted: the main-wrap pass synthesises a match-on-Exn with a
      // wildcard arm that handles any variant. Note that the pass *replaces*
      // the user's main with a `throws {}` wrapper, so this entry is only
      // reached for `__nx_user_main` (which validate_main does not visit) or
      // for the unwrappable cases left intact below.
      return ()
    | TyVar(name: _) ->
      raise MainThrowsTooBroad(detail: "throws-row contains a free type variable; resolve before reaching main")
    | _ ->
      raise MainThrowsTooBroad(detail: "throws-row entry is not a named exception or group")
  end
end

// ─── Helpers ────────────────────────────────────────────────────────────────

let hir_params_to_named_types = fn (params: [HirParam]) -> [NamedType] do
  return hir_params_to_named_types_go(params, acc: [])
end

let hir_params_to_named_types_go = fn (params: [HirParam], acc: [NamedType]) -> [NamedType] do
  match params do
    | [] -> return rev_named_types(lst: acc, out: [])
    | HirParam(name: n, label: l, typ: t) :: rest ->
      return hir_params_to_named_types_go(params: rest, acc: NamedType(name: l, typ: t) :: acc)
  end
end

// ─── Local type-specific reverses (see src/common/mono_reverse.nx) ─────────────

let rev_enum_entries = fn (lst: [EnumEntry], out: [EnumEntry]) -> [EnumEntry] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_enum_entries(lst: rest, out: x :: out)
  end
end

let rev_named_types = fn (lst: [NamedType], out: [NamedType]) -> [NamedType] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_named_types(lst: rest, out: x :: out)
  end
end

let rev_type_exprs = fn (lst: [TypeExpr], out: [TypeExpr]) -> [TypeExpr] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_type_exprs(lst: rest, out: x :: out)
  end
end

let rev_hir_params = fn (lst: [HirParam], out: [HirParam]) -> [HirParam] do
  match lst do
    | [] -> return out
    | x :: rest -> return rev_hir_params(lst: rest, out: x :: out)
  end
end

import * as str from "std:str"
