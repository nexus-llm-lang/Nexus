/**
 * typecheck/check: Top-level program type checking entry point.
 *
 * Takes HirProgram, validates types of all functions, and returns
 * the HirProgram unchanged on success or raises CompileError.
 */

import * as bb from "std:bytebuffer"
import * as list from "std:list"
import * as naming from "src/common/naming.nx"
import { TypeExpr, TyUnit, TyUserDefined, TyVar, TyArrow, TyRef, TyLinear, TyLazy, TyBorrow, TyArray, TyList, TyRecord, TyRow, TyHandler, NamedType, EnumDef, RecordDef, VariantDef, VariantField } from "src/common/ast.nx"
import { HirProgram, HirFunction, HirHandlerArm, HirParam, HirExternal, HirPort, HirPortMethod, HirHandlerBindingEntry, HirHandlerBinding, EagerBody, LazyBody, ExceptionGroupEntry } from "src/ir/hir/types.nx"
import { Span } from "src/common/token.nx"
import { TypeError, TypeMismatch, MissingMain, MainNotFunction, MainNotUnit, MainThrowsTooBroad, MainRequiresTooBroad, DuplicateTopLevelBinding, UnusedTypeParam, KindClashTypeParam, RefEscapes } from "src/typecheck/errors.nx"
import { CheckState, Scheme, EnvEntry, EnumEntry, TypeDefEntry, InferExprOk, InferExprErr }, * as tctypes from "src/typecheck/types.nx"
import * as subst from "src/typecheck/subst.nx"
import * as infer from "src/typecheck/infer.nx"
import { infer_stmts_tail_diverges } from "src/typecheck/infer/control_flow.nx"
import * as tcwf from "src/typecheck/tcwf.nx"

// ─── Public entry point ─────────────────────────────────────────────────────

/** Run the typechecker over an `HirProgram`: validates every function body, returns the program unchanged on success, raises `TypeError` on any mismatch. `require_main` enables main-signature checks. */
export let check_program = fn (hir: HirProgram, local_names: [string], require_main: bool) -> HirProgram throws { TypeError } do
  let HirProgram(ports, functions: funcs, externals: exts, handler_bindings: hbs, enum_defs: edefs, exception_groups: egs, value_binding_names: _, type_defs: tdefs, visible_enum_names: venms) = hir
  // D-Export (nexus-8xke): build_enum_entries receives the visible_enum_names
  // filter so it can strip variants of non-visible enums in the typecheck
  // VariantIndex. Codegen uses enum_defs directly (full variants preserved).
  let enum_entries = build_enum_entries(defs: edefs, visible_names: venms)
  let enum_entries2 = add_builtins(entries: enum_entries)
  // TypeDefEntry list lets the unifier expand `TyUserDefined("Foo", _)`
  // into its underlying record shape.
  let type_def_entries = build_type_def_entries(defs: tdefs)
  let state = tctypes.tc_new_state(enum_defs: enum_entries2, type_defs: type_def_entries, exception_groups: egs)

  // Pass 1: Register all signatures
  let st1 = register_externals(state, exts)
  // Register-time wfCap/wfThrow needs the full port + exception vocabulary
  // visible (other files' ports get pulled in via import collection). We
  // pass `ports` and `egs` directly because CheckState does not carry the
  // raw port list (only env entries for their methods).
  let st2 = register_functions(state: st1, funcs, ports, exception_groups: egs)
  let st3 = register_ports(state: st2, ports, exception_groups: egs)
  // Pass 1b: T-Handler arm/method 1-1 correspondence (spec §T-Handler line 1119).
  // Reject any handler that supplies an extra arm or omits a declared port method
  // before any signature/body is registered; missing arms would otherwise leave
  // a port-method slot unimplemented and turn into runtime UB at port-call
  // dispatch, and extra arms would silently introduce a never-routed name.
  validate_handler_arm_sets(ports, hbs)
  let st4 = register_handler_bindings(state: st3, hbs, ports, exception_groups: egs)
  let st5 = register_enum_constructors(state: st4, defs: edefs, visible_names: venms)

  let cont_binder_map = build_cont_binder_map(hbs)

  check_all_functions(state: st5, funcs, local_names, cont_map: cont_binder_map)

  // Pass 2b: Check handler arm bodies (synthesised function names aren't in
  // local_names, so they're missed by check_all_functions). With-kont arms
  // need their body re-checked with the cont binder bound in env so that
  // forcing @k at the wrong type is a TypeMismatch.
  check_handler_arm_bodies(state: st5, hbs)

  // Validate main exists and has correct signature. Skipped for library-only
  // typecheck (require_main=false): files with only exports are legitimate
  // imports for other modules and have no executable entry point.
  if require_main then
    validate_main(state: st5, funcs)
  end

  return hir
end

// ─── Built-in types ─────────────────────────────────────────────────────────

let add_builtins = fn (entries: [EnumEntry]) -> [EnumEntry] do
  let exn = EnumEntry(
    name: "Exn",
    def: EnumDef(name: "Exn", is_public: true, is_opaque: false, type_params: [], variants: [])
  )
  let list_variants = [
    VariantDef(name: "Nil", fields: []),
    VariantDef(name: "Cons", fields: [
      VariantField(name: Some(val: "v"), typ: TyVar(name: "T")),
      VariantField(name: Some(val: "rest"), typ: TyList(elem: TyVar(name: "T")))
    ])
  ]
  let list_def = EnumEntry(
    name: "List",
    def: EnumDef(name: "List", is_public: true, is_opaque: false,
      type_params: ["T"], variants: list_variants)
  )
  let option_variants = [
    VariantDef(name: "None", fields: []),
    VariantDef(name: "Some", fields: [
      VariantField(name: Some(val: "val"), typ: TyVar(name: "T"))
    ])
  ]
  let option_def = EnumEntry(
    name: "Option",
    def: EnumDef(name: "Option", is_public: true, is_opaque: false,
      type_params: ["T"], variants: option_variants)
  )
  // Add Result with Ok/Err — same auto-prelude treatment as Option.
  let result_variants = [
    VariantDef(name: "Ok", fields: [
      VariantField(name: Some(val: "val"), typ: TyVar(name: "T"))
    ]),
    VariantDef(name: "Err", fields: [
      VariantField(name: Some(val: "err"), typ: TyVar(name: "E"))
    ])
  ]
  let result_def = EnumEntry(
    name: "Result",
    def: EnumDef(name: "Result", is_public: true, is_opaque: false,
      type_params: ["T", "E"], variants: result_variants)
  )
  return exn :: list_def :: option_def :: result_def :: entries
end

// ─── Build enum entries ─────────────────────────────────────────────────────

let build_enum_entries = fn (defs: [EnumDef], visible_names: [string]) -> [EnumEntry] do
  return build_enum_entries_go(defs, visible_names, acc: [])
end

let build_enum_entries_go = fn (defs: [EnumDef], visible_names: [string], acc: [EnumEntry]) -> [EnumEntry] do
  match defs do
    | [] -> return list.reverse(xs: acc)
    | EnumDef(name: n, is_public: p, is_opaque: o, type_params: tps, variants: vs) :: rest ->
      // Convert TyUserDefined("T",[]) → TyVar("T") in variant field types so
      // that infer_constructor's freshen+subst_apply pipeline can rename T to
      // a fresh metavar. Without this, T survives as a frozen UD inside the
      // EnumVariantInfo and downstream unification fails to instantiate it.
      //
      // D-Export (nexus-8xke): strip variants to [] for non-visible enums so
      // that find_variant returns None for their constructors in the typecheck
      // VariantIndex, producing "unknown constructor" errors for importing code.
      // The codegen VariantIndex uses enum_defs directly (unchanged).
      let eff_vs = if enum_name_visible(name: n, names: visible_names) then vs else [] end
      let converted_vs = convert_variants(variants: eff_vs, vars: tps)
      return build_enum_entries_go(defs: rest, visible_names, acc: EnumEntry(name: n, def: EnumDef(name: n, is_public: p, is_opaque: o, type_params: tps, variants: converted_vs)) :: acc)
  end
end

let convert_variants = fn (variants: [VariantDef], vars: [string]) -> [VariantDef] do
  return convert_variants_go(variants, vars, acc: [])
end

let convert_variants_go = fn (variants: [VariantDef], vars: [string], acc: [VariantDef]) -> [VariantDef] do
  match variants do
    | [] -> return list.reverse(xs: acc)
    | VariantDef(name: vn, fields: fs) :: rest ->
      let cf = convert_variant_fields(fields: fs, vars)
      return convert_variants_go(variants: rest, vars, acc: VariantDef(name: vn, fields: cf) :: acc)
  end
end

let convert_variant_fields = fn (fields: [VariantField], vars: [string]) -> [VariantField] do
  return convert_variant_fields_go(fields, vars, acc: [])
end

let convert_variant_fields_go = fn (fields: [VariantField], vars: [string], acc: [VariantField]) -> [VariantField] do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | VariantField(name: mn, typ: t) :: rest ->
      return convert_variant_fields_go(fields: rest, vars,
        acc: VariantField(name: mn, typ: convert_ud_to_var(typ: t, vars)) :: acc)
  end
end

// ─── Build type-def entries (record-form `type T = { ... }`) ────────────────
//
// Convert each RecordDef collected by HIR construction (TLTypeDef arm in
// src/ir/hir/hir.nx) into a TypeDefEntry so that the unifier can expand
// `TyUserDefined("T", args)` into its underlying record shape via
// `unify_typedef_record`. Without this the unifier raises
// "unknown type definition: T [E2001]" for any annotation referencing T —
// the bug fixed.
//
// Field types are run through `convert_ud_to_var` against the declared type
// parameters so that bare `TyUserDefined("T", [])` references to type-params
// become `TyVar("T")`, mirroring the same conversion applied to enum variant
// fields. Record-form decls in the codebase are currently monomorphic, but
// the pipeline must already handle the polymorphic case to avoid frozen-UD
// regressions when generic record types are introduced.

let build_type_def_entries = fn (defs: [RecordDef]) -> [TypeDefEntry] do
  return build_type_def_entries_go(defs, acc: [])
end

let build_type_def_entries_go = fn (defs: [RecordDef], acc: [TypeDefEntry]) -> [TypeDefEntry] do
  match defs do
    | [] -> return list.reverse(xs: acc)
    | RecordDef(name: n, is_public: p, type_params: tps, fields: fs) :: rest ->
      let converted_fs = convert_named_types(nts: fs, vars: tps)
      let entry = TypeDefEntry(
        name: n,
        def: RecordDef(name: n, is_public: p, type_params: tps, fields: converted_fs)
      )
      return build_type_def_entries_go(defs: rest, acc: entry :: acc)
  end
end

// ─── Register externals ────────────────────────────────────────────────────

let register_externals = fn (state: CheckState, exts: [HirExternal]) -> CheckState throws { TypeError } do
  match exts do
    | [] -> return state
    | HirExternal(name: n, wasm_module: _, wasm_name: _, type_params: tps, params, ret_type: ret, throw_row: thr) :: rest ->
      let param_types = hir_params_to_named_types(params)
      // kindOf binding-site enforcement (spec L548–L571).
      // Externals carry no Span, so we attribute the diagnostic to the
      // externals header (Span(0,0,0)) — the func_name plus the type-param
      // name in the message is enough to locate the malformed declaration.
      // The σ pieces for an external arrow are exactly (params, ret, throws);
      // there is no `requires` slot (always `{}` for FFI declarations).
      let ext_parts = thr :: (ret :: named_type_typs(nts: param_types))
      enforce_kindof_quantifiers(tps, parts: ext_parts, func_name: n, span: Span(offset: 0, line: 0, col: 0))
      // D-External gravity rule: ¬escapesRef(τ_r).
      // Spec: type-system-formal.md §"Gravity Rule" + §D-External.
      tcwf.enforce_no_escapes_ref(typ: ret, context: "return type of external '" ++ n ++ "'", span: Span(offset: 0, line: 0, col: 0))
      // D-External wfRef at parameter annotation sites (spec §wfRef L385-400).
      tcwf.enforce_wf_ref_params(params: param_types, span: Span(offset: 0, line: 0, col: 0))
      // Convert TyUserDefined("T",[]) → TyVar("T") for declared type params,
      // then register as a polymorphic Scheme so each call site instantiates
      // T to a fresh metavar. Without this `external f: <T>(val: T) -> unit`
      // freezes T as a frozen non-int type and rejects int-literal callers.
      let arrow = TyArrow(
        params: convert_named_types(nts: param_types, vars: tps),
        ret: convert_ud_to_var(typ: ret, vars: tps),
        requires: TyRow(types: [], rest: None),
        throw_row: convert_ud_to_var(typ: thr, vars: tps)
      )
      let env = tctypes.env_insert(env: tctypes.state_env(state), name: n, scheme: Scheme(vars: tps, typ: arrow))
      return register_externals(state: tctypes.state_with_env(state, env), exts: rest)
  end
end

// ─── Generic type parameter resolution ──────────────────────────────────────
// Convert TyUserDefined("T", []) → TyVar("T") when "T" is a type parameter.

let str_list_contains = fn (xs: [string], s: string) -> bool do
  match xs do
    | [] -> return false
    | x :: rest ->
      if x == s then return true end
      return str_list_contains(xs: rest, s)
  end
end

// ─── kindOf binding-site enforcement ─────────────────────────────────────────
//
// Spec: type-system-formal.md §"Polymorphism Introduction"
// (L548–L571). For each declared quantifier X in a top-level
// `fn <X1,...,Xn>(...)` signature, the spec defines
//
//   kindOf(X, σ) = { Type   if  occurs_τ(X, σ) ∧ ¬occurs_ρ(X, σ)
//                  { Row    if  occurs_ρ(X, σ) ∧ ¬occurs_τ(X, σ)
//                  { undefined otherwise   ── unused (both false) OR clash (both true)
//
// and explicitly classifies the *undefined* cases as static errors raised
// at the binding site (T-Let-PolyFn), surfacing as "malformed quantifier
// list" rather than as a downstream unification failure at a use site.
//
// The two recursive predicates below mirror L556–L568 of the spec.
// `occurs_tau` covers every place a τ is expected (incl. row entries);
// `occurs_rho` surfaces *only* row-tail occurrences of X. The driver is
// `enforce_kindof_quantifiers`, which folds over the declared `tps` and
// raises `UnusedTypeParam` / `KindClashTypeParam` for the malformed ones.
//
// Both predicates accept arbitrary signature TypeExprs (pre-conversion —
// quantifier names show up as `TyUserDefined(X, [])` at this point, not
// `TyVar(X)`, because `convert_ud_to_var` has not yet run).

let occurs_tau = fn (x: string, typ: TypeExpr) -> bool do
  match typ do
    // L557: occurs_τ(X, X) = true. At binding-site time the quantifier
    // still appears under its surface name `TyUserDefined(X, [])`.
    | TyUserDefined(name: n, args: []) ->
      return n == x
    // L564 (right disjunct): occurs_τ(X, x<τ̄>) = ∃i. occurs_τ(X, τᵢ).
    // Generic type applications recurse into their argument list.
    | TyUserDefined(name: _, args: targs) ->
      return occurs_tau_in_list(x, types: targs)
    // L560-L561: occurs_τ(X, (ℓ̄:τ̄) → τr ; ρq ; ρe) recurses into every
    // parameter type, the return, and (via occurs_τ^ρ) into the row
    // entries of both requires and throws.
    | TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      if occurs_tau_in_named(x, nts: ps) then return true end
      if occurs_tau(x, typ: r) then return true end
      if occurs_tau(x, typ: req) then return true end
      return occurs_tau(x, typ: thr)
    // L562: occurs_τ(X, %τ) = occurs_τ(X, @τ) = occurs_τ(X, &τ) = occurs_τ(X, τ).
    // We have an extra TyRef constructor — same recursive rule applies.
    | TyList(elem: e) -> return occurs_tau(x, typ: e)
    | TyArray(elem: e) -> return occurs_tau(x, typ: e)
    | TyRef(inner: i) -> return occurs_tau(x, typ: i)
    | TyLinear(inner: i) -> return occurs_tau(x, typ: i)
    | TyLazy(inner: i) -> return occurs_tau(x, typ: i)
    | TyBorrow(inner: i) -> return occurs_tau(x, typ: i)
    // L564 (left disjunct): occurs_τ(X, {ℓ̄:τ̄}) = ∃i. occurs_τ(X, τᵢ).
    | TyRecord(fields: fs) -> return occurs_tau_in_named(x, nts: fs)
    // L565-L566: occurs_τ^ρ({τ̄}) and occurs_τ^ρ({τ̄ | Y}) both look at
    // the row entries via occurs_τ. The rest tail is handled separately
    // by `occurs_rho`, not here — so we do NOT recurse into `rest`.
    | TyRow(types: ts, rest: _) -> return occurs_tau_in_list(x, types: ts)
    // TyHandler's `requires` field is a row; recurse via occurs_τ.
    | TyHandler(name: _, requires: req) -> return occurs_tau(x, typ: req)
    // L558-L559: base types and unrelated names contribute nothing.
    | _ -> return false
  end
end

let occurs_tau_in_list = fn (x: string, types: [TypeExpr]) -> bool do
  match types do
    | [] -> return false
    | t :: rest ->
      if occurs_tau(x, typ: t) then return true end
      return occurs_tau_in_list(x, types: rest)
  end
end

let occurs_tau_in_named = fn (x: string, nts: [NamedType]) -> bool do
  match nts do
    | [] -> return false
    | NamedType(name: _, typ: t) :: rest ->
      if occurs_tau(x, typ: t) then return true end
      return occurs_tau_in_named(x, nts: rest)
  end
end

// L567-L568: occurs_ρ surfaces only row-tail occurrences of X. We recurse
// through every type-bearing constructor that might *contain* a row, and
// inspect the row's `rest` slot for a TyUserDefined(X, []) tail.
let occurs_rho = fn (x: string, typ: TypeExpr) -> bool do
  match typ do
    // Arrow: recurse into params (their types may contain inner rows),
    // return, and most importantly the two row positions (requires/throws).
    | TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      if occurs_rho_in_named(x, nts: ps) then return true end
      if occurs_rho(x, typ: r) then return true end
      if occurs_rho(x, typ: req) then return true end
      return occurs_rho(x, typ: thr)
    | TyList(elem: e) -> return occurs_rho(x, typ: e)
    | TyArray(elem: e) -> return occurs_rho(x, typ: e)
    | TyRef(inner: i) -> return occurs_rho(x, typ: i)
    | TyLinear(inner: i) -> return occurs_rho(x, typ: i)
    | TyLazy(inner: i) -> return occurs_rho(x, typ: i)
    | TyBorrow(inner: i) -> return occurs_rho(x, typ: i)
    | TyRecord(fields: fs) -> return occurs_rho_in_named(x, nts: fs)
    // The load-bearing case: a row {τ̄ | X} matches L567 — `rest` is
    // `Some(TyUserDefined(X, []))`. We also recurse into the row's
    // entries because each entry is itself a TypeExpr that may transport
    // a nested row (e.g. a closure-typed capability whose own throws-row
    // mentions X as a tail).
    | TyRow(types: ts, rest: r) ->
      if occurs_rho_in_list(x, types: ts) then return true end
      match r do
        | Some(val: t) ->
          match t do
            | TyUserDefined(name: n, args: []) -> return n == x
            | _ -> return occurs_rho(x, typ: t)
          end
        | None -> return false
      end
    | TyHandler(name: _, requires: req) -> return occurs_rho(x, typ: req)
    // A TyUserDefined<...> can contain nested rows in its type arguments
    // (e.g. `Option<() -> unit require { Foo | X }>`). Recurse so the
    // tail is still discovered.
    | TyUserDefined(name: _, args: targs) -> return occurs_rho_in_list(x, types: targs)
    // Base types, plain TyVar, etc.: no row tail possible.
    | _ -> return false
  end
end

let occurs_rho_in_list = fn (x: string, types: [TypeExpr]) -> bool do
  match types do
    | [] -> return false
    | t :: rest ->
      if occurs_rho(x, typ: t) then return true end
      return occurs_rho_in_list(x, types: rest)
  end
end

let occurs_rho_in_named = fn (x: string, nts: [NamedType]) -> bool do
  match nts do
    | [] -> return false
    | NamedType(name: _, typ: t) :: rest ->
      if occurs_rho(x, typ: t) then return true end
      return occurs_rho_in_named(x, nts: rest)
  end
end

// Spec L548–L552 enforcement. Walks every declared quantifier X in `tps`
// and inspects the (still-pre-conversion) signature pieces. Raises
// `UnusedTypeParam` (kindOf=undefined, unused case) or `KindClashTypeParam`
// (kindOf=undefined, clash case) at the function's binding site span.
//
// `signature_parts` is the list of TypeExprs that together form σ —
// callers pass the params (as their NamedType list — folded into a
// TyRecord for uniform recursion), the return type, and the throws row.
// The requires row is part of TyArrow for top-level functions but lives
// implicitly in `TyRow(types: [], rest: None)` for externals, so callers
// pass exactly the σ pieces that exist for their declaration form.
let enforce_kindof_quantifiers = fn (tps: [string], parts: [TypeExpr], func_name: string, span: Span) -> unit throws { TypeError } do
  match tps do
    | [] -> return ()
    | x :: rest ->
      let in_tau = occurs_tau_in_list(x, types: parts)
      let in_rho = occurs_rho_in_list(x, types: parts)
      // Unused case (spec L551, "otherwise / unused"): X appears nowhere
      // in σ. Diagnostic must surface at the binding site, NOT silently
      // pass.
      if !in_tau then
        if !in_rho then
          throw UnusedTypeParam(name: x, func_name, span)
        end
      end
      // Clash case (spec L551, "otherwise / kind clash"): X is used at
      // BOTH a type position and a row tail. The unifier would otherwise
      // pick one kind and report a confusing downstream mismatch at the
      // first use site that disagrees. We reject upfront at the binding.
      if in_tau then
        if in_rho then
          throw KindClashTypeParam(name: x, func_name, span)
        end
      end
      return enforce_kindof_quantifiers(tps: rest, parts, func_name, span)
  end
end

// Convert the function's param list (NamedType, where `typ` is what
// matters for kindOf — the parameter *name* never contributes) into a
// flat list of TypeExprs for `enforce_kindof_quantifiers`.
let named_type_typs = fn (nts: [NamedType]) -> [TypeExpr] do
  return named_type_typs_go(nts, acc: [])
end

let named_type_typs_go = fn (nts: [NamedType], acc: [TypeExpr]) -> [TypeExpr] do
  match nts do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: _, typ: t) :: rest ->
      return named_type_typs_go(nts: rest, acc: t :: acc)
  end
end

let convert_ud_to_var = fn (typ: TypeExpr, vars: [string]) -> TypeExpr do
  match typ do
    | TyUserDefined(name: n, args: []) ->
      if str_list_contains(xs: vars, s: n) then return TyVar(name: n) end
      return typ
    | TyUserDefined(name: n, args: targs) ->
      return TyUserDefined(name: n, args: convert_type_list(types: targs, vars))
    | TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return TyArrow(
        params: convert_named_types(nts: ps, vars),
        ret: convert_ud_to_var(typ: r, vars),
        requires: convert_ud_to_var(typ: req, vars),
        throw_row: convert_ud_to_var(typ: thr, vars)
      )
    | TyList(elem: e) -> return TyList(elem: convert_ud_to_var(typ: e, vars))
    | TyArray(elem: e) -> return TyArray(elem: convert_ud_to_var(typ: e, vars))
    | TyRef(inner: i) -> return TyRef(inner: convert_ud_to_var(typ: i, vars))
    | TyLinear(inner: i) -> return TyLinear(inner: convert_ud_to_var(typ: i, vars))
    | TyLazy(inner: i) -> return TyLazy(inner: convert_ud_to_var(typ: i, vars))
    | TyBorrow(inner: i) -> return TyBorrow(inner: convert_ud_to_var(typ: i, vars))
    | TyRecord(fields: fs) -> return TyRecord(fields: convert_named_types(nts: fs, vars))
    | TyRow(types: ts, rest: r) ->
      let new_rest = match r do
        | Some(val: t) -> Some(val: convert_ud_to_var(typ: t, vars))
        | None -> None
      end
      return TyRow(types: convert_type_list(types: ts, vars), rest: new_rest)
    | TyHandler(name: n, requires: req) ->
      return TyHandler(name: n, requires: convert_ud_to_var(typ: req, vars))
    | _ -> return typ
  end
end

let convert_named_types = fn (nts: [NamedType], vars: [string]) -> [NamedType] do
  return convert_named_types_go(nts, vars, acc: [])
end

let convert_named_types_go = fn (nts: [NamedType], vars: [string], acc: [NamedType]) -> [NamedType] do
  match nts do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: n, typ: t) :: rest ->
      return convert_named_types_go(nts: rest, vars, acc: NamedType(name: n, typ: convert_ud_to_var(typ: t, vars)) :: acc)
  end
end

let convert_type_list = fn (types: [TypeExpr], vars: [string]) -> [TypeExpr] do
  return convert_type_list_go(types, vars, acc: [])
end

let convert_type_list_go = fn (types: [TypeExpr], vars: [string], acc: [TypeExpr]) -> [TypeExpr] do
  match types do
    | [] -> return list.reverse(xs: acc)
    | t :: rest ->
      return convert_type_list_go(types: rest, vars, acc: convert_ud_to_var(typ: t, vars) :: acc)
  end
end

let convert_hir_params = fn (params: [HirParam], vars: [string]) -> [HirParam] do
  return convert_hir_params_go(params, vars, acc: [])
end

let convert_hir_params_go = fn (params: [HirParam], vars: [string], acc: [HirParam]) -> [HirParam] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: l, name: n, sigil: s, typ: t) :: rest ->
      return convert_hir_params_go(params: rest, vars, acc: HirParam(label: l, name: n, sigil: s, typ: convert_ud_to_var(typ: t, vars)) :: acc)
  end
end

// ─── Register functions ─────────────────────────────────────────────────────

// track names registered so far to reject same-name redeclaration.
// Downstream lir_opt mis-resolves `return_call` for shadowed top-level lets
// and corrupts UNRELATED functions' return atoms; rejecting at typecheck
// eliminates the bug class entirely.
let register_functions = fn (state: CheckState, funcs: [HirFunction], ports: [HirPort], exception_groups: [ExceptionGroupEntry]) -> CheckState throws { TypeError } do
  return register_functions_go(state, funcs, seen: [], ports, exception_groups)
end

let register_functions_go = fn (state: CheckState, funcs: [HirFunction], seen: [string], ports: [HirPort], exception_groups: [ExceptionGroupEntry]) -> CheckState throws { TypeError } do
  match funcs do
    | [] -> return state
    | HirFunction(name: n, type_params: tps, params, ret_type: ret, throw_row: tw, body: _, span: sp, file: _, requires: req) :: rest ->
      if str_list_contains(xs: seen, s: n) then
        throw DuplicateTopLevelBinding(name: n, span: sp)
      end
      // Introduction-site well-formedness checks (T-Lambda fn arrow):
      // wfCap on the require row and wfThrow on the throws row. Per spec
      // §1 line 112/116, these are checked here so a typo (`require { Logr }`
      // for `Logger`) is rejected at the source location rather than
      // surviving as an uninhabitable row entry until a use site looks
      // it up — issues (wfCap) and (wfThrow).
      tcwf.wf_cap(row: req, ports, span: sp)
      tcwf.wf_throw(row: tw, vidx_: tctypes.state_variant_index(state), groups: exception_groups, span: sp)
      // T-Lambda / T-Let-PolyFn gravity rule: ¬escapesRef(τ_r).
      // Checked at the declaration site so a typo such as `fn () -> ref(i64)`
      // is rejected at the binding, not at a downstream return statement.
      // Spec: type-system-formal.md §"Gravity Rule" + §T-Lambda.
      tcwf.enforce_no_escapes_ref(typ: ret, context: "return type of '" ++ n ++ "'", span: sp)
      let param_types = hir_params_to_named_types(params)
      // wfRef at parameter annotation sites (spec §wfRef L385-400):
      // each parameter type ~σ is rejected if σ is linear (TyLinear).
      tcwf.enforce_wf_ref_params(params: param_types, span: sp)
      // kindOf binding-site enforcement
      // (spec L548–L571). σ for a top-level fn is its parameter types,
      // return type, and throws-row. The `requires` slot is always `{}`
      // here (HirFunction does not surface a separate requires; row
      // capability requirements live inside higher-order param signatures
      // and are already covered by recursion into `param_types`).
      let parts = tw :: (ret :: named_type_typs(nts: param_types))
      enforce_kindof_quantifiers(tps, parts, func_name: n, span: sp)
      let arrow = TyArrow(
        params: convert_named_types(nts: param_types, vars: tps),
        ret: convert_ud_to_var(typ: ret, vars: tps),
        requires: TyRow(types: [], rest: None),
        throw_row: convert_ud_to_var(typ: tw, vars: tps)
      )
      let env = tctypes.env_insert(env: tctypes.state_env(state), name: n, scheme: Scheme(vars: tps, typ: arrow))
      return register_functions_go(state: tctypes.state_with_env(state, env), funcs: rest, seen: n :: seen, ports, exception_groups)
  end
end

// ─── Register ports ─────────────────────────────────────────────────────────
//
// D-Port introduction-site wfCap/wfThrow (spec §D-Port line 1647):
// `∀j∈J. wfCap(α_j) ∧ wfThrow(β_j)` for each declared method signature.
// HirPortMethod now carries the full require/throw rows from the source
// FunctionSig, so we can enforce these premises here at registration time.
let register_ports = fn (state: CheckState, ports: [HirPort], exception_groups: [ExceptionGroupEntry]) -> CheckState throws { TypeError } do
  match ports do
    | [] -> return state
    | HirPort(name: _, methods) :: rest ->
      check_port_method_rows(methods, state, exception_groups)
      return register_ports(state, ports: rest, exception_groups)
  end
end

let check_port_method_rows = fn (methods: [HirPortMethod], state: CheckState, exception_groups: [ExceptionGroupEntry]) -> unit throws { TypeError } do
  match methods do
    | [] -> return ()
    | HirPortMethod(name: _, requires: req, throw_row: tw, span: sp) :: rest ->
      tcwf.wf_cap(row: req, ports: [], span: sp)
      tcwf.wf_throw(row: tw, vidx_: tctypes.state_variant_index(state), groups: exception_groups, span: sp)
      return check_port_method_rows(methods: rest, state, exception_groups)
  end
end

// ─── Register handler bindings ──────────────────────────────────────────────

let register_handler_bindings = fn (state: CheckState, hbs: [HirHandlerBindingEntry], ports: [HirPort], exception_groups: [ExceptionGroupEntry]) -> CheckState throws { TypeError } do
  match hbs do
    | [] -> return state
    | HirHandlerBindingEntry(name: n, binding: HirHandlerBinding(port_name: pname, requires: handler_req, arms)) :: rest ->
      let handler_type = TyHandler(name: pname, requires: handler_req)
      let env1 = tctypes.env_insert(env: tctypes.state_env(state), name: n, scheme: tctypes.mono(typ: handler_type))
      let prefix_len = naming.handler_prefix_len(handler_name: n)
      let env2 = register_handler_methods(env: env1, port_name: pname, prefix_len, arms)
      // Per-arm wfThrow at the T-Handler introduction site: each arm body
      // is a HirFunction whose `throw_row` was preserved through HIR, so a
      // typo like `throws { BogusVariant }` on an arm is rejected here.
      // The arm's `requires` row is currently empty (handler arms don't
      // declare per-arm caps), so wfCap there is a no-op until that
      // syntax exists.
      check_handler_arm_throw_rows(arms, state, exception_groups)
      let st1 = tctypes.state_with_env(state, env: env2)
      return register_handler_bindings(state: st1, hbs: rest, ports, exception_groups)
  end
end

let check_handler_arm_throw_rows = fn (arms: [HirHandlerArm], state: CheckState, exception_groups: [ExceptionGroupEntry]) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(arm: HirFunction(name: _, type_params: _, params: arm_params, ret_type: _, throw_row: tw, body: _, span: sp, file: _, requires: req), cont_binder: _) :: rest ->
      tcwf.wf_cap(row: req, ports: [], span: sp)
      tcwf.wf_throw(row: tw, vidx_: tctypes.state_variant_index(state), groups: exception_groups, span: sp)
      // T-Handler wfRef at parameter annotation sites (spec §wfRef L385-400).
      let arm_param_types = hir_params_to_named_types(params: arm_params)
      tcwf.enforce_wf_ref_params(params: arm_param_types, span: sp)
      return check_handler_arm_throw_rows(arms: rest, state, exception_groups)
  end
end

let register_handler_methods = fn (env: [EnvEntry], port_name: string, prefix_len: i64, arms: [HirHandlerArm]) -> [EnvEntry] do
  match arms do
    | [] -> return env
    | HirHandlerArm(arm: HirFunction(name: n, type_params: _, params, ret_type: ret, throw_row: tw, _), cont_binder: kb) :: rest ->
      let original_name = str.substring(s: n, start: prefix_len, len: str.length(s: n) - prefix_len)
      let method_name = bb.concat(parts: [port_name, ".", original_name])
      let user_params = match kb do
        | Some(_) -> list_init(xs: params)
        | None -> params
      end
      let param_types = hir_params_to_named_types(params: user_params)
      let arrow = TyArrow(
        params: param_types, ret,
        requires: TyRow(types: [], rest: None),
        throw_row: tw
      )
      let env1 = tctypes.env_insert(env, name: method_name, scheme: tctypes.mono(typ: arrow))
      return register_handler_methods(env: env1, port_name, prefix_len, arms: rest)
  end
end

let list_init = fn (xs: [HirParam]) -> [HirParam] do
  match xs do
    | [] | _ :: [] -> return []
    | x :: rest -> return x :: list_init(xs: rest)
  end
end

// ─── T-Handler arm/method 1-1 correspondence ────────────────────────────────
// Spec (type-system-formal.md §T-Handler, line 1119):
//   { ℓ_j | j ∈ J } = { ℓ | (ℓ = e) ∈ overline{ℓ_j = e_j} }
// The handler literal must supply exactly the methods declared on its port —
// no missing arm, no extra arm. The earlier impl in this file registered arms
// (register_handler_bindings / register_handler_methods) and type-checked each
// arm body individually (check_handler_arm_bodies) without ever comparing the
// supplied arm-name set against methods(port). That left a missing arm silently
// admitted (and exposed at runtime as undefined dispatch) and an extra arm
// silently admitted as dead, unroutable code.
//
// We validate set-equality at the top of check_program, before any arm
// signature/body work happens, so a structurally incomplete handler is rejected
// with a TypeMismatch keyed off the handler binding's first failing arm span
// (or the first arm's span if the failure is "missing arm").

/** Spec §T-Handler arm/method 1-1 correspondence (line 1119): rejects
 *  handlers that supply an extra arm or omit a declared port method. Public
 *  for direct unit-test against handcrafted (ports, hbs) pairs without
 *  building a full HirProgram.
 */
export let validate_handler_arm_sets = fn (ports: [HirPort], hbs: [HirHandlerBindingEntry]) -> unit throws { TypeError } do
  match hbs do
    | [] -> return ()
    | HirHandlerBindingEntry(name: hname, binding: HirHandlerBinding(port_name: pname, requires: _, arms)) :: rest ->
      let port_methods = lookup_port_methods(ports, port_name: pname)
      let prefix_len = naming.handler_prefix_len(handler_name: hname)
      let supplied = collect_arm_original_names(arms, prefix_len)
      let arm_span = first_arm_span(arms)
      check_no_extra_arm(handler_name: hname, port_name: pname, supplied, port_methods, arms, prefix_len)
      check_no_missing_arm(handler_name: hname, port_name: pname, supplied, port_methods, arm_span)
      return validate_handler_arm_sets(ports, hbs: rest)
  end
end

let lookup_port_methods = fn (ports: [HirPort], port_name: string) -> [string] do
  match ports do
    | [] -> return []
    | HirPort(name: n, methods) :: rest ->
      if n == port_name then return port_method_names(methods) end
      return lookup_port_methods(ports: rest, port_name)
  end
end

let port_method_names = fn (methods: [HirPortMethod]) -> [string] do
  match methods do
    | [] -> return []
    | HirPortMethod(name: n, requires: _, throw_row: _, span: _) :: rest -> return n :: port_method_names(methods: rest)
  end
end

let collect_arm_original_names = fn (arms: [HirHandlerArm], prefix_len: i64) -> [string] do
  match arms do
    | [] -> return []
    | HirHandlerArm(arm: HirFunction(name: n, _), cont_binder: _) :: rest ->
      let original = str.substring(s: n, start: prefix_len, len: str.length(s: n) - prefix_len)
      return original :: collect_arm_original_names(arms: rest, prefix_len)
  end
end

let first_arm_span = fn (arms: [HirHandlerArm]) -> Span do
  match arms do
    | [] -> return Span(offset: 0, line: 0, col: 0)
    | HirHandlerArm(arm: HirFunction(name: _, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span, file: _), cont_binder: _) :: _ -> return span
  end
end

let check_no_extra_arm = fn (handler_name: string, port_name: string, supplied: [string], port_methods: [string], arms: [HirHandlerArm], prefix_len: i64) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(arm: HirFunction(name: n, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span, file: _), cont_binder: _) :: rest ->
      let original = str.substring(s: n, start: prefix_len, len: str.length(s: n) - prefix_len)
      if str_list_contains(xs: port_methods, s: original) then
        return check_no_extra_arm(handler_name, port_name, supplied, port_methods, arms: rest, prefix_len)
      end
      let detail = bb.concat(parts: [
        "handler '", handler_name, "' for port '", port_name,
        "' supplies arm '", original,
        "' which is not declared as a method of port '", port_name,
        "' (T-Handler arm/method 1-1 correspondence: no extra arm)"
      ])
      throw TypeMismatch(func_name: handler_name, detail, span)
  end
end

let check_no_missing_arm = fn (handler_name: string, port_name: string, supplied: [string], port_methods: [string], arm_span: Span) -> unit throws { TypeError } do
  match port_methods do
    | [] -> return ()
    | m :: rest ->
      if str_list_contains(xs: supplied, s: m) then
        return check_no_missing_arm(handler_name, port_name, supplied, port_methods: rest, arm_span)
      end
      let detail = bb.concat(parts: [
        "handler '", handler_name, "' for port '", port_name,
        "' is missing arm for declared method '", m,
        "' (T-Handler arm/method 1-1 correspondence: no missing arm)"
      ])
      throw TypeMismatch(func_name: handler_name, detail, span: arm_span)
  end
end

// ─── Register enum constructors ─────────────────────────────────────────────

// D-Export (nexus-8xke): only register constructors for enums whose names
// appear in `visible_names`. Non-visible enums are kept in `enum_defs` for
// codegen (VariantIndex field layout) but their constructors must not enter
// the type environment of the importing module.
let register_enum_constructors = fn (state: CheckState, defs: [EnumDef], visible_names: [string]) -> CheckState do
  match defs do
    | [] -> return state
    | EnumDef(name: ename, is_public: _, is_opaque: _, type_params: tps, variants: vs) :: rest ->
      let st1 = if enum_name_visible(name: ename, names: visible_names) then
        register_variants(state, enum_name: ename, type_params: tps, variants: vs)
      else
        state
      end
      return register_enum_constructors(state: st1, defs: rest, visible_names)
  end
end

let enum_name_visible = fn (name: string, names: [string]) -> bool do
  match names do
    | [] -> return false
    | n :: rest ->
      if n == name then return true end
      return enum_name_visible(name, names: rest)
  end
end

let register_variants = fn (state: CheckState, enum_name: string, type_params: [string], variants: [VariantDef]) -> CheckState do
  match variants do
    | [] -> return state
    | VariantDef(name: vname, fields) :: rest ->
      let enum_type = build_enum_type_from_params(name: enum_name, params: type_params)
      let ctor_type = match fields do
        | [] -> enum_type
        | _ ->
          let param_types = variant_fields_to_named_types(fields, idx: 0)
          TyArrow(
            params: param_types, ret: enum_type,
            requires: TyRow(types: [], rest: None),
            throw_row: TyRow(types: [], rest: None)
          )
      end
      let env = tctypes.env_insert(env: tctypes.state_env(state), name: vname, scheme: tctypes.mono(typ: ctor_type))
      return register_variants(state: tctypes.state_with_env(state, env), enum_name, type_params, variants: rest)
  end
end

let build_enum_type_from_params = fn (name: string, params: [string]) -> TypeExpr do
  match params do
    | [] -> return TyUserDefined(name, args: [])
    | _ -> return TyUserDefined(name, args: params_to_vars(params))
  end
end

let params_to_vars = fn (params: [string]) -> [TypeExpr] do
  return params_to_vars_go(params, acc: [])
end

let params_to_vars_go = fn (params: [string], acc: [TypeExpr]) -> [TypeExpr] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | p :: rest ->
      return params_to_vars_go(params: rest, acc: TyVar(name: p) :: acc)
  end
end

let variant_fields_to_named_types = fn (fields: [VariantField], idx: i64) -> [NamedType] do
  return variant_fields_to_named_types_go(fields, idx, acc: [])
end

let variant_fields_to_named_types_go = fn (fields: [VariantField], idx: i64, acc: [NamedType]) -> [NamedType] do
  match fields do
    | [] -> return list.reverse(xs: acc)
    | VariantField(name: mname, typ: t) :: rest ->
      let fname = match mname do
        | Some(val: n) -> n
        | None -> "_" ++ str.from_i64(val: idx)
      end
      return variant_fields_to_named_types_go(fields: rest, idx: idx + 1, acc: NamedType(name: fname, typ: t) :: acc)
  end
end

// ─── Check all function bodies ──────────────────────────────────────────────

let is_local = fn (name: string, local_names: [string]) -> bool do
  match local_names do
    | [] -> return false
    | n :: rest ->
      if n == name then return true end
      return is_local(name, local_names: rest)
  end
end

/** Map from synthesised arm function name (e.g. `__handler_scheduler_yield`)
 *  to the `with @k` binder name. Empty for arms without cont_binder.
 */
type ContBinderMap = ContBinderMap(entries: [ContBinderEntry])
type ContBinderEntry = ContBinderEntry(arm_fn_name: string, binder: string)

let build_cont_binder_map = fn (hbs: [HirHandlerBindingEntry]) -> ContBinderMap throws { TypeError } do
  return ContBinderMap(entries: build_cont_binder_entries(hbs, acc: []))
end

let build_cont_binder_entries = fn (hbs: [HirHandlerBindingEntry], acc: [ContBinderEntry]) -> [ContBinderEntry] throws { TypeError } do
  match hbs do
    | [] -> return acc
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, requires: _, arms)) :: rest ->
      let acc2 = collect_arm_binders(arms, acc)
      return build_cont_binder_entries(hbs: rest, acc: acc2)
  end
end

let collect_arm_binders = fn (arms: [HirHandlerArm], acc: [ContBinderEntry]) -> [ContBinderEntry] throws { TypeError } do
  match arms do
    | [] -> return acc
    | HirHandlerArm(arm: HirFunction(name: fname, type_params: _, params: _, ret_type: _, _), cont_binder: Some(val: k)) :: rest ->
      return collect_arm_binders(arms: rest, acc: ContBinderEntry(arm_fn_name: fname, binder: k) :: acc)
    | _ :: rest -> return collect_arm_binders(arms: rest, acc)
  end
end

let lookup_cont_binder = fn (fname: string, map: ContBinderMap) -> Option<string> do
  match map do | ContBinderMap(entries) -> return lookup_cont_binder_in(fname, entries) end
end

let lookup_cont_binder_in = fn (fname: string, entries: [ContBinderEntry]) -> Option<string> do
  match entries do
    | [] -> return None
    | ContBinderEntry(arm_fn_name: an, binder: b) :: rest ->
      if an == fname then return Some(val: b) end
      return lookup_cont_binder_in(fname, entries: rest)
  end
end

let check_all_functions = fn (state: CheckState, funcs: [HirFunction], local_names: [string], cont_map: ContBinderMap) -> unit throws { TypeError } do
  match funcs do
    | [] -> return ()
    | func :: rest ->
      let HirFunction(name, type_params: _, params: _, ret_type: _, _) = func
      if is_local(name, local_names) then
        check_function(state, func, cont_map)
      end
      return check_all_functions(state, funcs: rest, local_names, cont_map)
  end
end

let check_handler_arm_bodies = fn (state: CheckState, hbs: [HirHandlerBindingEntry]) -> unit throws { TypeError } do
  match hbs do
    | [] -> return ()
    | HirHandlerBindingEntry(name: _, binding: HirHandlerBinding(port_name: _, requires: _, arms)) :: rest ->
      check_arm_bodies(state, arms)
      return check_handler_arm_bodies(state, hbs: rest)
  end
end

let check_arm_bodies = fn (state: CheckState, arms: [HirHandlerArm]) -> unit throws { TypeError } do
  match arms do
    | [] -> return ()
    | HirHandlerArm(arm: f, cont_binder: Some(val: k)) :: rest ->
      // Only with-kont arms re-checked here so we can bind @k in env;
      // non-kont arms are picked up via the normal function pass.
      check_arm_body(state, func: f, cont_binder: Some(val: k))
      return check_arm_bodies(state, arms: rest)
    | _ :: rest -> return check_arm_bodies(state, arms: rest)
  end
end

let check_arm_body = fn (state: CheckState, func: HirFunction, cont_binder: Option<string>) -> unit throws { TypeError } do
  let HirFunction(name, type_params: tps, params, ret_type: ret, throw_row: tw, body: hir_body, _) = func
  let body = match hir_body do | EagerBody(stmts: s) -> s | LazyBody(_) -> [] end
  let conv_params = convert_hir_params(params, vars: tps)
  let conv_ret = convert_ud_to_var(typ: ret, vars: tps)
  let conv_tw = convert_ud_to_var(typ: tw, vars: tps)
  let body_env = add_func_params(env: tctypes.state_env(state), params: conv_params)
  // If the arm has `with @k`, bind k in env as @ret_type. Standard inference
  // then catches type mismatches when the arm body forces k at a wrong type.
  let body_env2 = match cont_binder do
    | Some(val: k) -> tctypes.env_insert(env: body_env, name: k, scheme: tctypes.mono(typ: TyLazy(inner: conv_ret)))
    | None -> body_env
  end
  let body_state = tctypes.state_with_env(state, env: body_env2)
  let body_state2 = tctypes.state_with_throw_row(state: body_state, throw_row: conv_tw)
  match infer.infer_stmts(state: body_state2, stmts: body, ret_type: conv_ret) do
    | InferExprErr(message: m, span: err_span) ->
      throw TypeMismatch(func_name: name, detail: m, span: err_span)
    | InferExprOk(_) ->
      return ()
  end
end

let check_function = fn (state: CheckState, func: HirFunction, cont_map: ContBinderMap) -> unit throws { TypeError } do
  let HirFunction(name, type_params: tps, params, ret_type: ret, throw_row: tw, body: hir_body, span: fn_span, file: _, requires: fn_req) = func
  let body = match hir_body do | EagerBody(stmts: s) -> s | LazyBody(_) -> [] end
  let conv_params = convert_hir_params(params, vars: tps)
  let conv_ret = convert_ud_to_var(typ: ret, vars: tps)
  let conv_tw = convert_ud_to_var(typ: tw, vars: tps)
  let conv_req = convert_ud_to_var(typ: fn_req, vars: tps)
  let body_env = add_func_params(env: tctypes.state_env(state), params: conv_params)
  // If this function is a handler arm with `with @k`, bind k as @ret in the
  // body env. Standard inference catches force-at-wrong-type mismatches.
  let body_env2 = match lookup_cont_binder(fname: name, map: cont_map) do
    | Some(val: k) -> tctypes.env_insert(env: body_env, name: k, scheme: tctypes.mono(typ: TyLazy(inner: conv_ret)))
    | None -> body_env
  end
  let body_state = tctypes.state_with_env(state, env: body_env2)
  let body_state2 = tctypes.state_with_throw_row(state: body_state, throw_row: conv_tw)
  // Propagate the ambient require row so that inject-site checking (T-Inject
  // ∀i. ρ_i ⊆ ρ_q) can validate handler require rows against it.
  let body_state3 = tctypes.state_with_require_row(state: body_state2, require_row: conv_req)
  match infer.infer_stmts(state: body_state3, stmts: body, ret_type: conv_ret) do
    | InferExprErr(message: m, span: err_span) ->
      throw TypeMismatch(func_name: name, detail: m, span: err_span)
    | InferExprOk(state: _, subst: s_body, typ: body_typ) ->
      // T-Lambda: τ_r ≠ unit ⟹ tail(s†) = ⊥.
      // The body must supply the return value by one of two means:
      //   (a) the last statement is a non-unit expression whose type provides
      //       the implicit return value (body_typ ≠ TyUnit), or
      //   (b) every control-flow path ends with an explicit `return`/`throw`
      //       (infer_stmts_tail_diverges = true).
      // If neither holds — body "falls off the end" with unit but ret ≠ unit.
      let body_is_unit = if let TyUnit = body_typ then true else false end
      let ret_is_unit = if let TyUnit = conv_ret then true else false end
      if !ret_is_unit && body_is_unit && !infer_stmts_tail_diverges(stmts: body, depth: 64) then
        throw TypeMismatch(func_name: name, detail: "return type is non-unit but body does not end with a `return` or `throw` on all paths (spec T-Lambda: τ_r ≠ unit ⟹ tail(s†) = ⊥)", span: fn_span)
      end
      let _ = s_body
      return ()
  end
end

let add_func_params = fn (env: [EnvEntry], params: [HirParam]) -> [EnvEntry] do
  match params do
    | [] -> return env
    | HirParam(label: _, name: n, sigil: _, typ: t) :: rest ->
      return add_func_params(env: tctypes.env_insert(env, name: n, scheme: tctypes.mono(typ: t)), params: rest)
  end
end

// ─── Validate main function ────────────────────────────────────────────────

/** Validates that `main` exists, is a `() -> unit` (or `[string] -> unit`)
 *  arrow, and that its declared throws-row is one the runtime can wrap.
 *
 *  The HIR main-wrap pass (`src/ir/main_wrap.nx`) replaces a wrappable
 *  non-empty main with a synthesised wrapper whose throws are `{}`, so by
 *  the time validate_main runs the row is normally either empty (nothing
 *  to wrap) or post-wrap empty. The wrap pass intentionally leaves
 *  unwrappable rows intact — open rows, rows with a free type variable,
 *  or rows containing non-exception entries — and validate_main rejects
 *  them here as `MainThrowsTooBroad`.
 */
let validate_main = fn (state: CheckState, funcs: [HirFunction]) -> unit throws { TypeError } do
  // The type environment registers TyArrow with requires: TyRow([],None)
  // for every function (register_functions_go L538). The HirFunction.requires
  // field carries the source-level require row and must be consulted directly.
  //
  // When main_wrap synthesises a wrapper, the original main is renamed to
  // `__nx_user_main` (requires row preserved). Check that first.
  match find_func_requires(name: "__nx_user_main", funcs) do
    | Some(val: user_req) -> validate_main_require_row(require_row: user_req)
    | None -> ()
  end
  match tctypes.env_lookup(env: tctypes.state_env(state), name: "main") do
    | None ->
      throw MissingMain
    | Some(val: Scheme(vars: _, typ: main_type)) ->
      match main_type do
        | TyArrow(params: _, ret, requires: _, throw_row: tw) ->
          if subst.type_eq(a: ret, b: TyUnit) then
            // Check the HirFunction.requires directly (env value is always empty).
            match find_func_requires(name: "main", funcs) do
              | Some(val: req) -> validate_main_require_row(require_row: req)
              | None -> ()
            end
            return validate_main_throw_row(throw_row: tw)
          end
          throw MainNotUnit
        | _ ->
          throw MainNotFunction
      end
  end
end

/** Look up a HirFunction by name and return its source-level require row,
 *  or None if not found.
 */
let find_func_requires = fn (name: string, funcs: [HirFunction]) -> Option<TypeExpr> do
  match funcs do
    | [] -> return None
    | HirFunction(name: n, type_params: _, params: _, ret_type: _, throw_row: _, body: _, span: _, file: _, requires: req) :: rest ->
      if n == name then return Some(val: req) end
      return find_func_requires(name, funcs: rest)
  end
end

/** Enforce spec P9 wfMain: ρ_q ⊆ SysCaps.
 *  main's require row may only contain system capabilities. User-declared
 *  port names are rejected because there is no enclosing inject at the
 *  program entry point to provide them.
 *  Empty rows and implicit-tail rows (`__implicit`) are accepted.
 */
let validate_main_require_row = fn (require_row: TypeExpr) -> unit throws { TypeError } do
  match require_row do
    | TyRow(types: ts, rest: _) ->
      return validate_main_require_row_entries(entries: ts)
    | TyUnit -> return ()
    | _ -> return ()
  end
end

let validate_main_require_row_entries = fn (entries: [TypeExpr]) -> unit throws { TypeError } do
  match entries do
    | [] -> return ()
    | t :: rest ->
      validate_main_require_row_entry(entry: t)
      return validate_main_require_row_entries(entries: rest)
  end
end

let validate_main_require_row_entry = fn (entry: TypeExpr) -> unit throws { TypeError } do
  match entry do
    | TyUserDefined(name: n, args: _) ->
      if tcwf.is_sys_cap(name: n) then return () end
      throw MainRequiresTooBroad(port_name: n)
    | _ -> return ()
  end
end

/** Reject throws-rows the main-wrap pass cannot handle: open rows, rows
 *  whose entries are not named exception (group) variants, or rows that
 *  have collapsed to a free type variable. Empty rows and closed rows of
 *  named entries (concrete exceptions, exception groups, or the universal
 *  `Exn`) are accepted — the wrap pass routes them through a match-on-Exn
 *  with a wildcard arm.
 */
let validate_main_throw_row = fn (throw_row: TypeExpr) -> unit throws { TypeError } do
  match throw_row do
    | TyRow(types: ts, rest: r) ->
      match r do
        // Implicit absent-throws row: `parse_optional_throws` encodes a missing
        // `throws` clause as `TyRow([], Some(TyVar("__implicit")))`.  Treat it
        // the same as a closed empty row for main-wrap validation purposes.
        | Some(val: TyVar(name: "__implicit")) ->
          return validate_main_throw_row_entries(entries: ts)
        | Some(_) -> throw MainThrowsTooBroad(detail: "open row (rest tail) is not permitted")
        | None -> return validate_main_throw_row_entries(entries: ts)
      end
    | TyUnit -> return ()
    | _ -> throw MainThrowsTooBroad(detail: "throws-row must be a closed row, got non-row type")
  end
end

let validate_main_throw_row_entries = fn (entries: [TypeExpr]) -> unit throws { TypeError } do
  match entries do
    | [] -> return ()
    | t :: rest ->
      validate_main_throw_row_entry(entry: t)
      return validate_main_throw_row_entries(entries: rest)
  end
end

let validate_main_throw_row_entry = fn (entry: TypeExpr) -> unit throws { TypeError } do
  match entry do
    | TyUserDefined(name: _, args: _) ->
      // Concrete exceptions, exception groups, and the universal `Exn` are
      // all admitted: the main-wrap pass synthesises a match-on-Exn with a
      // wildcard arm that handles any variant. Note that the pass *replaces*
      // the user's main with a `throws {}` wrapper, so this entry is only
      // reached for `__nx_user_main` (which validate_main does not visit) or
      // for the unwrappable cases left intact below.
      return ()
    | TyVar(name: _) ->
      throw MainThrowsTooBroad(detail: "throws-row contains a free type variable; resolve before reaching main")
    | _ ->
      throw MainThrowsTooBroad(detail: "throws-row entry is not a named exception or group")
  end
end

// ─── Helpers ────────────────────────────────────────────────────────────────

let hir_params_to_named_types = fn (params: [HirParam]) -> [NamedType] do
  return hir_params_to_named_types_go(params, acc: [])
end

let hir_params_to_named_types_go = fn (params: [HirParam], acc: [NamedType]) -> [NamedType] do
  match params do
    | [] -> return list.reverse(xs: acc)
    | HirParam(label: l, name: _, sigil: _, typ: t) :: rest ->
      return hir_params_to_named_types_go(params: rest, acc: NamedType(name: l, typ: t) :: acc)
  end
end

import * as str from "std:str"
