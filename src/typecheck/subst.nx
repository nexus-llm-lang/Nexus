/**
 * typecheck/subst: Type substitution operations.
 *
 * Association-list based substitution: apply, compose, lookup.
 * Also provides structural type equality (type_eq) since Nexus == only
 * works on primitives.
 */

import {
  TypeExpr,
  TyI32,
  TyI64,
  TyF32,
  TyF64,
  TyBool,
  TyChar,
  TyString,
  TyUnit,
  TyIntLit,
  TyFloatLit,
  TyUserDefined,
  TyVar,
  TyArrow,
  TyRef,
  TyLinear,
  TyLazy,
  TyBorrow,
  TyArray,
  TyList,
  TyRecord,
  TyRow,
  TyHandler,
  NamedType
} from "src/types/type_expr.nx"
import * as list from "std:list"
import { SubstEntry, Scheme, EnvEntry } from "src/typecheck/types.nx"

/** Empty substitution. */
export let subst_empty = fn () -> [ SubstEntry ] do
  return []
end

/** Singleton substitution binding `var` to `typ`. */
export let subst_single = fn (var: string, typ: TypeExpr) -> [ SubstEntry ] do
  return [SubstEntry(var, typ)]
end

let subst_lookup = fn (subst: [ SubstEntry ], var: string) -> Option<TypeExpr> do
  match subst do
    | [] -> return None
    | SubstEntry(var: v, typ: t) :: rest ->
      if v == var then
        return Some(val: t)
      end
      return subst_lookup(subst: rest, var)
  end
end

/** Apply a substitution to a type, recursively rewriting bound TyVar names. */
export let subst_apply = fn (subst: [ SubstEntry ], typ: TypeExpr) -> TypeExpr do
  if list.is_empty(xs: subst) then return typ end
  match typ do
    | TyVar(name: n) ->
      match subst_lookup(subst, var: n) do
        | Some(val: t) -> return t
        | None -> return typ
      end
    | TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return TyArrow(
        params: apply_named_types(subst, nts: ps),
        ret: subst_apply(subst, typ: r),
        requires: subst_apply(subst, typ: req),
        throw_row: subst_apply(subst, typ: thr)
      )
    | TyUserDefined(name: n, args) ->
      return TyUserDefined(name: n, args: apply_type_list(subst, types: args))
    | TyRef(inner: i) -> return TyRef(inner: subst_apply(subst, typ: i))
    | TyLinear(inner: i) -> return TyLinear(inner: subst_apply(subst, typ: i))
    | TyLazy(inner: i, require_row: rq, throw_row: thr) -> return TyLazy(
        inner: subst_apply(subst, typ: i),
        require_row: subst_apply(subst, typ: rq),
        throw_row: subst_apply(subst, typ: thr)
      )
    | TyBorrow(inner: i) -> return TyBorrow(inner: subst_apply(subst, typ: i))
    | TyArray(elem: e) -> return TyArray(elem: subst_apply(subst, typ: e))
    | TyList(elem: e) -> return TyList(elem: subst_apply(subst, typ: e))
    | TyRecord(fields: fs) ->
      return TyRecord(fields: apply_named_types(subst, nts: fs))
    | TyRow(types: ts, rest: r) ->
      let new_rest = match r do
        | Some(val: t) -> Some(val: subst_apply(subst, typ: t))
        | None -> None
      end
      return TyRow(types: apply_type_list(subst, types: ts), rest: new_rest)
    | TyHandler(name: n, requires: req) ->
      return TyHandler(name: n, requires: subst_apply(subst, typ: req))
    | _ -> return typ
  end
end

export let apply_named_types = fn (subst: [ SubstEntry ], nts: [ NamedType ]) -> [ NamedType ] do
  if list.is_empty(xs: subst) then return nts end
  return apply_named_types_go(subst, nts, acc: [])
end
let apply_named_types_go = fn (
  subst: [ SubstEntry ],
  nts: [ NamedType ],
  acc: [ NamedType ]
) -> [ NamedType ] do
  match nts do
    | [] -> return list.reverse(xs: acc)
    | NamedType(name: n, typ: t) :: rest ->
      return apply_named_types_go(subst, nts: rest,
        acc: NamedType(name: n, typ: subst_apply(subst, typ: t)) :: acc)
  end
end
/** Apply a substitution to every element of a type list. */
export let subst_apply_each = fn (subst: [ SubstEntry ], typs: [ TypeExpr ]) -> [ TypeExpr ] do
  return apply_type_list(subst, types: typs)
end
let apply_type_list = fn (subst: [ SubstEntry ], types: [ TypeExpr ]) -> [ TypeExpr ] do
  if list.is_empty(xs: subst) then return types end
  return apply_type_list_go(subst, types, acc: [])
end
let apply_type_list_go = fn (
  subst: [ SubstEntry ],
  types: [ TypeExpr ],
  acc: [ TypeExpr ]
) -> [ TypeExpr ] do
  match types do
    | [] -> return list.reverse(xs: acc)
    | t :: rest ->
      return apply_type_list_go(subst, types: rest,
        acc: subst_apply(subst, typ: t) :: acc)
  end
end
/** Compose substitutions: returns `s2 ∘ s1`, applying `s2` to `s1`'s targets then merging. */
export let subst_compose = fn (s1: [ SubstEntry ], s2: [ SubstEntry ]) -> [ SubstEntry ] do
  let applied = apply_subst_to_entries(entries: s1, subst: s2)
  return merge_entries(base: applied, extra: s2)
end

/**
 * Apply `subst` to the target type of every entry in `entries`.
 *
 * Relevance filter (mirrors `subst_apply_env`): `subst` only rewrites the
 * TyVar names in its domain. If NO entry's target mentions any domain var the
 * whole list is returned shared, unchanged, with zero allocation — the common
 * case in `subst_compose`, where the incoming `subst` (`s2`) binds only freshly
 * generated unification vars that the growing accumulator (`s1`) has never seen.
 * The accumulator reaches thousands of entries on large bodies, so rebuilding
 * it on every compose when nothing changes is the dominant typecheck allocation
 * (~92% of `subst_compose`'s composes are pure identities here). Even when some
 * entry IS touched, each untouched entry is shared rather than reallocated. The
 * domain set is built once per call (the `subst` side is small); the per-entry
 * "mentions any domain var" test is an allocation-free occurs-style walk that
 * short-circuits on first hit.
 */
let apply_subst_to_entries = fn (
  entries: [ SubstEntry ],
  subst: [ SubstEntry ]
) -> [ SubstEntry ] do
  let domain = subst_domain(subst, acc: [])
  if entries_touch_domain(domain, entries) then
    return apply_subst_to_entries_go(subst, domain, entries, acc: [])
  end
  return entries
end
let entries_touch_domain = fn (domain: [ string ], entries: [ SubstEntry ]) -> bool do
  match entries do
    | [] -> return false
    | SubstEntry(var: _, typ: t) :: rest ->
      if type_mentions_any(domain, typ: t) then return true end
      return entries_touch_domain(domain, entries: rest)
  end
end
let apply_subst_to_entries_go = fn (
  subst: [ SubstEntry ],
  domain: [ string ],
  entries: [ SubstEntry ],
  acc: [ SubstEntry ]
) -> [ SubstEntry ] do
  match entries do
    | [] -> return list.reverse(xs: acc)
    | SubstEntry(var: v, typ: t) :: rest ->
      if type_mentions_any(domain, typ: t) then
        return apply_subst_to_entries_go(subst, domain, entries: rest,
          acc: SubstEntry(var: v, typ: subst_apply(subst, typ: t)) :: acc)
      end
      return apply_subst_to_entries_go(subst, domain, entries: rest,
        acc: SubstEntry(var: v, typ: t) :: acc)
  end
end
/** Add entries from extra that are not already in base. */
let merge_entries = fn (base: [ SubstEntry ], extra: [ SubstEntry ]) -> [ SubstEntry ] do
  match extra do
    | [] -> return base
    | SubstEntry(var: v, typ: t) :: rest ->
      if entry_exists(entries: base, var: v) then
        return merge_entries(base, extra: rest)
      end
      return merge_entries(base: SubstEntry(var: v, typ: t) :: base, extra: rest)
  end
end

let entry_exists = fn (entries: [ SubstEntry ], var: string) -> bool do
  match entries do
    | [] -> return false
    | SubstEntry(var: v, typ: _) :: rest ->
      if v == var then
        return true
      end
      return entry_exists(entries: rest, var)
  end
end

/**
 * Apply a substitution to every scheme body in a type environment.
 *
 * Relevance filter: a substitution only rewrites the TyVar names in its
 * domain (the `var` fields of its entries). An entry whose body mentions no
 * domain var is returned byte-identical by `subst_apply`, so the original
 * `EnvEntry` is shared unchanged (no walk, no allocation). The whole-program
 * env is ~all fully-generalized schemes that mention no fresh unification var,
 * so the common case skips with zero allocation. The domain-name set is built
 * once per call; the per-entry "mentions any domain var" check is an
 * allocation-free occurs-style walk that short-circuits on first hit.
 */
export let subst_apply_env = fn (subst: [ SubstEntry ], env: [ EnvEntry ]) -> [ EnvEntry ] do
  let domain = subst_domain(subst, acc: [])
  return subst_apply_env_go(subst, domain, env, acc: [])
end
let subst_apply_env_go = fn (
  subst: [ SubstEntry ],
  domain: [ string ],
  env: [ EnvEntry ],
  acc: [ EnvEntry ]
) -> [ EnvEntry ] do
  match env do
    | [] -> return list.reverse(xs: acc)
    | EnvEntry(name: n, scheme: Scheme(vars: vs, typ: t)) :: rest ->
      if type_mentions_any(domain, typ: t) then
        return subst_apply_env_go(subst, domain, env: rest,
          acc: EnvEntry(name: n, scheme: Scheme(vars: vs, typ: subst_apply(subst, typ: t))) :: acc)
      end
      return subst_apply_env_go(subst, domain, env: rest,
        acc: EnvEntry(name: n, scheme: Scheme(vars: vs, typ: t)) :: acc)
  end
end

/** Collect the domain (the `var` names) of a substitution into a list. */
let subst_domain = fn (subst: [ SubstEntry ], acc: [ string ]) -> [ string ] do
  match subst do
    | [] -> return list.reverse(xs: acc)
    | SubstEntry(var: v, typ: _) :: rest ->
      return subst_domain(subst: rest, acc: v :: acc)
  end
end

/** True if `name` is in the (small) domain-name list. Allocation-free scan. */
let name_in_domain = fn (domain: [ string ], name: string) -> bool do
  match domain do
    | [] -> return false
    | d :: rest ->
      if d == name then
        return true
      end
      return name_in_domain(domain: rest, name)
  end
end

/**
 * True if `typ` mentions any TyVar whose name is in `domain`.
 * Mirrors `occurs_check`'s structural walk but tests membership in the domain
 * set instead of equality with a single var; short-circuits on first hit and
 * allocates nothing. Like `subst_apply`, it does not treat scheme binders
 * specially (subst-domain vars are fresh and never collide with bound vars).
 */
let type_mentions_any = fn (domain: [ string ], typ: TypeExpr) -> bool do
  match typ do
    | TyVar(name: n) -> return name_in_domain(domain, name: n)
    | TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return mentions_in_named_types(domain, nts: ps)
        || type_mentions_any(domain, typ: r)
        || type_mentions_any(domain, typ: req)
        || type_mentions_any(domain, typ: thr)
    | TyUserDefined(name: _, args) ->
      return mentions_in_type_list(domain, types: args)
    | TyRef(inner: i) | TyLinear(inner: i) | TyBorrow(inner: i) ->
      return type_mentions_any(domain, typ: i)
    | TyLazy(inner: i, require_row: rq, throw_row: thr) ->
      return type_mentions_any(domain, typ: i)
        || type_mentions_any(domain, typ: rq)
        || type_mentions_any(domain, typ: thr)
    | TyArray(elem: e) | TyList(elem: e) -> return type_mentions_any(domain, typ: e)
    | TyRecord(fields: fs) -> return mentions_in_named_types(domain, nts: fs)
    | TyRow(types: ts, rest: r) ->
      if mentions_in_type_list(domain, types: ts) then
        return true
      end
      match r do
        | Some(val: t) -> return type_mentions_any(domain, typ: t)
        | None -> return false
      end
    | TyHandler(name: _, requires: req) -> return type_mentions_any(domain, typ: req)
    | _ -> return false
  end
end

let mentions_in_type_list = fn (domain: [ string ], types: [ TypeExpr ]) -> bool do
  match types do
    | [] -> return false
    | t :: rest ->
      if type_mentions_any(domain, typ: t) then
        return true
      end
      return mentions_in_type_list(domain, types: rest)
  end
end

let mentions_in_named_types = fn (domain: [ string ], nts: [ NamedType ]) -> bool do
  match nts do
    | [] -> return false
    | NamedType(name: _, typ: t) :: rest ->
      if type_mentions_any(domain, typ: t) then
        return true
      end
      return mentions_in_named_types(domain, nts: rest)
  end
end
/** Structural equality on `TypeExpr` (Nexus `==` only compares primitives). */
export let type_eq = fn (a: TypeExpr, b: TypeExpr) -> bool do
  match a do
    | TyI32 -> return if let TyI32 = b then true else false end
    | TyI64 -> return if let TyI64 = b then true else false end
    | TyF32 -> return if let TyF32 = b then true else false end
    | TyF64 -> return if let TyF64 = b then true else false end
    | TyBool -> return if let TyBool = b then true else false end
    | TyChar -> return if let TyChar = b then true else false end
    | TyString -> return if let TyString = b then true else false end
    | TyUnit -> return if let TyUnit = b then true else false end
    | TyIntLit -> return if let TyIntLit = b then true else false end
    | TyFloatLit -> return if let TyFloatLit = b then true else false end
    | TyVar(name: n1) ->
      return if let TyVar(name: n2) = b then n1 == n2 else false end
    | TyUserDefined(name: n1, args: a1) ->
      return if let TyUserDefined(name: n2, args: a2) = b then
        if n1 == n2 then type_list_eq(a: a1, b: a2) else false end
      else false end
    | TyArrow(params: p1, ret: r1, requires: req1, throw_row: t1) ->
      return if let TyArrow(params: p2, ret: r2, requires: req2, throw_row: t2) = b then
        named_types_eq(a: p1, b: p2)
          && type_eq(a: r1, b: r2)
          && type_eq(a: req1, b: req2)
          && type_eq(a: t1, b: t2)
      else false end
    | TyRef(inner: i1) ->
      return if let TyRef(inner: i2) = b then type_eq(a: i1, b: i2) else false end
    | TyLinear(inner: i1) ->
      return if let TyLinear(inner: i2) = b then type_eq(a: i1, b: i2) else false end
    | TyLazy(inner: i1, require_row: rq1, throw_row: thr1) ->
      return if let TyLazy(inner: i2, require_row: rq2, throw_row: thr2) = b then
        type_eq(a: i1, b: i2) && type_eq(a: rq1, b: rq2) && type_eq(a: thr1, b: thr2)
      else false end
    | TyBorrow(inner: i1) ->
      return if let TyBorrow(inner: i2) = b then type_eq(a: i1, b: i2) else false end
    | TyArray(elem: e1) ->
      return if let TyArray(elem: e2) = b then type_eq(a: e1, b: e2) else false end
    | TyList(elem: e1) ->
      return if let TyList(elem: e2) = b then type_eq(a: e1, b: e2) else false end
    | TyRecord(fields: f1) ->
      return if let TyRecord(fields: f2) = b then named_types_eq(a: f1, b: f2) else false end
    | TyRow(types: ts1, rest: r1) ->
      return if let TyRow(types: ts2, rest: r2) = b then
        if type_list_eq(a: ts1, b: ts2) then
          match r1 do
            | Some(val: t1) ->
              if let Some(val: t2) = r2 then type_eq(a: t1, b: t2) else false end
            | None ->
              if let Some(_) = r2 then false else true end
          end
        else false end
      else false end
    | TyHandler(name: n1, requires: req1) ->
      return if let TyHandler(name: n2, requires: req2) = b then
        n1 == n2 && type_eq(a: req1, b: req2)
      else false end
  end
end

let type_list_eq = fn (a: [ TypeExpr ], b: [ TypeExpr ]) -> bool do
  match a do
    | [] ->
      return if let [] = b then true else false end
    | ha :: ra ->
      match b do
        | [] -> return false
        | hb :: rb ->
          if type_eq(a: ha, b: hb) then
            return type_list_eq(a: ra, b: rb)
          end
          return false
      end
  end
end

let named_types_eq = fn (a: [ NamedType ], b: [ NamedType ]) -> bool do
  match a do
    | [] ->
      return if let [] = b then true else false end
    | NamedType(name: n1, typ: t1) :: ra ->
      match b do
        | [] -> return false
        | NamedType(name: n2, typ: t2) :: rb ->
          if n1 == n2 && type_eq(a: t1, b: t2) then
            return named_types_eq(a: ra, b: rb)
          end
          return false
      end
  end
end

/** True if `var` occurs anywhere inside `typ`; used to prevent infinite-type unifications. */
export let occurs_check = fn (var: string, typ: TypeExpr) -> bool do
  match typ do
    | TyVar(name: n) -> return n == var
    | TyArrow(params: ps, ret: r, requires: req, throw_row: thr) ->
      return occurs_in_named_types(var, nts: ps)
        || occurs_check(var, typ: r)
        || occurs_check(var, typ: req)
        || occurs_check(var, typ: thr)
    | TyUserDefined(name: _, args) ->
      return occurs_in_type_list(var, types: args)
    | TyRef(inner: i) | TyLinear(inner: i) | TyBorrow(inner: i) -> return occurs_check(var, typ: i)
    | TyLazy(inner: i, require_row: rq, throw_row: thr) ->
      return occurs_check(var, typ: i)
        || occurs_check(var, typ: rq)
        || occurs_check(var, typ: thr)
    | TyArray(elem: e) | TyList(elem: e) -> return occurs_check(var, typ: e)
    | TyRecord(fields: fs) -> return occurs_in_named_types(var, nts: fs)
    | TyRow(types: ts, rest: r) ->
      if occurs_in_type_list(var, types: ts) then
        return true
      end
      match r do
        | Some(val: t) -> return occurs_check(var, typ: t)
        | None -> return false
      end
    | TyHandler(name: _, requires: req) -> return occurs_check(var, typ: req)
    | _ -> return false
  end
end

let occurs_in_type_list = fn (var: string, types: [ TypeExpr ]) -> bool do
  match types do
    | [] -> return false
    | t :: rest ->
      if occurs_check(var, typ: t) then
        return true
      end
      return occurs_in_type_list(var, types: rest)
  end
end

let occurs_in_named_types = fn (var: string, nts: [ NamedType ]) -> bool do
  match nts do
    | [] -> return false
    | NamedType(name: _, typ: t) :: rest ->
      if occurs_check(var, typ: t) then
        return true
      end
      return occurs_in_named_types(var, nts: rest)
  end
end
