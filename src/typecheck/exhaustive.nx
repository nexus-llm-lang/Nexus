/**
 * typecheck/exhaustive: Maranget-style usefulness + exhaustiveness check.
 *
 * Entry point and glue. Core logic lives in:
 *   - exhaustive/signatures.nx — column-signature extraction, ctor/record
 *     field-type helpers (`ColumnSig`, `CtorSig`, `column_signature`, …)
 *   - exhaustive/decision.nx  — `is_useful`, matrix specialization,
 *     redundancy scan, witness generation
 *
 * Decisions:
 *   - Redundancy is reported as an error (not a warning) — Nexus has no
 *     warning subsystem yet and an unreachable arm is virtually always a
 *     bug. Witness string for redundancy is the literal "redundant arm".
 *   - When a column type carries free type variables (e.g. `T` from
 *     `Option<T>`) we conservatively treat the column as infinite-signature
 *     — only wildcard / variable patterns cover it. This means
 *     `match Some(val: x) | None end` over `Option<T>` works the same way
 *     v1 did when `T` is unknown, while `Option<i64>` correctly recognizes
 *     `Some(val: 1) | None` as non-exhaustive.
 *   - Record fields are inner columns: each field pattern becomes a
 *     sub-column typed by the record field's type. Missing fields in a
 *     partial pattern (`{ x: ..., _ }`) expand to wildcards.
 *   - Modality wrappers (Linear/Lazy/Borrow/Ref) on the scrutinee or
 *     constructor field types are stripped before matching.
 */

import { TypeExpr, TyUserDefined, EnumDef, VariantDef } from "src/types/type_expr.nx"
import { HirMatchCase, HirPatternKind, PVar, PWild, PCtor } from "src/ir/hir/types.nx"
import { EnumEntry, TypeDefEntry } from "src/typecheck/types.nx"
import { Some, None } from "std:option"
import * as list from "std:list"
import * as decision from "src/typecheck/exhaustive/decision.nx"
import { strip_mod, bare_nominal_name } from "src/ir/shared/type_pred.nx"

/** Import-aware reordering of `enum_defs` so the exhaustiveness check resolves
 *  the scrutinee's enum name to the SAME declaration the match arms' ctors
 *  resolve to under the current module's import visibility.
 *
 *  When two modules export an enum with the same name (e.g. `std:stringmap` and
 *  `std:hashmap` both export `Lookup = Found | Missing`), the flat first-match
 *  `find_enum` picks an arbitrary one. If it picks the WRONG module's `Lookup`,
 *  its `Found`/`Missing` ctors are module-qualified to that module, so they
 *  fail to cover the arms' (correctly-resolved) ctors and the match is reported
 *  spuriously non-exhaustive.
 *
 *  Resolution: take a ctor name from the arms (already module-qualified at this
 *  stage), and hoist the same-named EnumDef that actually DECLARES that ctor to
 *  the front of `enum_defs`. Because each module's `Lookup` carries its own
 *  qualified `Found`/`Missing`, ctor membership unambiguously identifies the
 *  arms' enum. Falls through unchanged when the scrutinee is not a named enum,
 *  no ctor arm exists, or no same-named ambiguity is present. */
export let reorder_enum_defs_for_scrutinee = fn (
  scrutinee_type: TypeExpr,
  cases: [ HirMatchCase ],
  enum_defs: [ EnumEntry ]
) -> [ EnumEntry ] do
  match strip_mod(typ: scrutinee_type) do
    | TyUserDefined(name: ename, args: _) ->
      match first_ctor_name(cases) do
        | None -> return enum_defs
        | Some(val: ctor) ->
          return hoist_enum_def(enum_defs, ename, ctor, acc: [])
      end
    | _ -> return enum_defs
  end
end

/** First top-level constructor name appearing in the match arms, if any. */
let first_ctor_name = fn (cases: [ HirMatchCase ]) -> Option<string> do
  match cases do
    | [] -> return None
    | HirMatchCase(pattern: p, body: _) :: rest ->
      match p do
        | PCtor(variant: v, fields: _, sigil: _) -> return Some(val: v)
        | _ -> return first_ctor_name(cases: rest)
      end
  end
end

/** Move the `EnumEntry` named `ename` that actually DECLARES constructor `ctor`
 *  to the front, so the flat first-match `find_enum` selects the same `Lookup`
 *  the arms' (module-qualified) ctors belong to rather than an arbitrary
 *  same-named one. Matching on ctor membership is robust to the qualified-name
 *  encoding: each module's `Lookup` carries its OWN qualified `Found`/`Missing`,
 *  and the arms reference exactly one module's qualified ctor, so this picks the
 *  unambiguously-correct declaration. No-op when no `ename` entry declares
 *  `ctor` (no ambiguity, or the arms used a wildcard / built-in). */
let hoist_enum_def = fn (
  enum_defs: [ EnumEntry ], ename: string, ctor: string, acc: [ EnumEntry ]
) -> [ EnumEntry ] do
  match enum_defs do
    | [] -> return list.reverse(xs: acc)
    | EnumEntry(name: n, def: d) :: rest ->
      let EnumDef(name: _, is_public: _, is_opaque: _, type_params: _, variants: vs, layout_variants: _, module: _) = d
      if bare_nominal_name(n: n) == bare_nominal_name(n: ename) && enum_declares_ctor(variants: vs, ctor) then
        return EnumEntry(name: n, def: d) :: list.concat(xs: list.reverse(xs: acc), ys: rest)
      end
      return hoist_enum_def(enum_defs: rest, ename, ctor, acc: EnumEntry(name: n, def: d) :: acc)
  end
end

/** True when one of `variants` is the constructor `ctor` (exact name match;
 *  names are already module-qualified at this stage). */
let enum_declares_ctor = fn (variants: [ VariantDef ], ctor: string) -> bool do
  match variants do
    | [] -> return false
    | VariantDef(name: vn, fields: _) :: rest ->
      if vn == ctor then return true end
      return enum_declares_ctor(variants: rest, ctor)
  end
end

/** Outcome of an exhaustiveness check: either every value is covered, a witness of an uncovered value, or a redundant (unreachable) arm.
 *  `ExnNoCatchAll` is returned when the scrutinee is the open `Exn` type but
 *  none of the arms is a wildcard / variable catch-all — required by T-Match
 *  hasCatchAll premise. */
export type ExhaustiveResult =
  Exhaustive
  | NonExhaustive(witness: string)
  | RedundantArm(witness: string)
  | ExnNoCatchAll

/** Run Maranget-style usefulness + exhaustiveness on a `match`. Returns `Exhaustive`, a `NonExhaustive` witness, or a `RedundantArm` witness for the first unreachable arm. */
export let check_match_exhaustive = fn (
  cases: [ HirMatchCase ],
  scrutinee_type: TypeExpr,
  enum_defs: [ EnumEntry ],
  type_defs: [ TypeDefEntry ]
) -> ExhaustiveResult do
  let st = strip_mod(typ: scrutinee_type)
  let full_matrix = matrix_from_cases(cases: cases, acc: [])
  // The universal `Exn` exception type is an open enum (no variants in its
  // EnumDef). It always has an implicit wildcard catch via the
  // main-wrap pass, so the exhaustiveness leg (spec §T-TryCatch, §Exh-Sum)
  // is trivially satisfied — every arm shape covers Exn. We must NOT also
  // short-circuit the redundancy scan (spec §Exh-Sum per-arm usefulness):
  // a second arm matching the
  // same declared `exception` constructor is unreachable, and Maranget's
  // `is_useful(M[0..i-1], M[i])` correctly detects it because
  // `specialize_matrix_ctor` projects on the ctor's name regardless of
  // whether the parent type's signature is finite or open.
  if is_universal_exn(typ: st) then
    // T-Match hasCatchAll premise: Exn is open, so every match on Exn must
    // have at least one arm that is a wildcard or variable pattern, ensuring
    // future exception constructors are handled.
    if !(has_catch_all(cases: cases)) then
      return ExnNoCatchAll
    end
    let redund_exn = decision.check_redundancy(
      cases: cases, types: [ st ], enum_defs: enum_defs, type_defs: type_defs, matrix: [], idx: 0
    )
    match redund_exn do
      | Some(val: witness) -> return RedundantArm(witness: witness)
      | None -> return Exhaustive
    end
  end
  let useful = decision.is_useful(
    matrix: full_matrix,
    row: [ PWild ],
    types: [ st ],
    enum_defs: enum_defs,
    type_defs: type_defs
  )
  if useful then
    let w = decision.witness_from_matrix(
      matrix: full_matrix,
      types: [ st ],
      enum_defs: enum_defs,
      type_defs: type_defs
    )
    return NonExhaustive(witness: w)
  end
  let redund = decision.check_redundancy(
    cases: cases, types: [ st ], enum_defs: enum_defs, type_defs: type_defs, matrix: [], idx: 0
  )
  match redund do
    | Some(val: witness) -> return RedundantArm(witness: witness)
    | None -> return Exhaustive
  end
end

let is_universal_exn = fn (typ: TypeExpr) -> bool do
  match typ do
    | TyUserDefined(name: n, args: _) -> return n == "Exn"
    | _ -> return false
  end
end

// Returns true iff at least one arm has a top-level wildcard or variable
// pattern — i.e. a catch-all that covers any exception constructor.
let has_catch_all = fn (cases: [ HirMatchCase ]) -> bool do
  match cases do
    | [] -> return false
    | HirMatchCase(pattern: p, body: _) :: rest ->
      match p do
        | PWild | PVar(_) -> return true
        | _ -> return has_catch_all(cases: rest)
      end
  end
end

let matrix_from_cases = fn (
  cases: [ HirMatchCase ],
  acc: [ [ HirPatternKind ] ]
) -> [ [ HirPatternKind ] ] do
  match cases do
    | [] -> return list.reverse(xs: acc)
    | HirMatchCase(pattern: p, body: _) :: rest ->
      return matrix_from_cases(cases: rest, acc: [ p ] :: acc)
  end
end
